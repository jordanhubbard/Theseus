spec: concurrent_futures_extra114
version: ">=3.11"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec extends concurrent_futures_extra113.zspec.zsdl."
    - "This spec covers: wave 257 theme — concurrent.futures.Future method co_varnames lengths and Executor method co_qualname attributes not covered in extra111-extra113. Prior specs covered: Future method co_qualname equality and length (extra111); ThreadPoolExecutor method co_qualname (extra112); as_completed and wait co_qualname (extra113). NOT previously covered: Future method co_varnames.__len__() values; Executor.map/__enter__/__exit__ co_qualname values. NEW in extra114: Future.cancel.__code__.co_varnames.__len__()==1 (only self); Future.done.__code__.co_varnames.__len__()==1 (tied with cancel); Future.result.__code__.co_varnames.__len__()==2 (self and timeout); Future.set_result.__code__.co_varnames.__len__()==3 (self, result, waiter; most in Future simple methods); Executor.map.__code__.co_qualname=='Executor.map' (len=12); Executor.__enter__.__code__.co_qualname=='Executor.__enter__' (len=18); Executor.__exit__.__code__.co_qualname=='Executor.__exit__' (len=17). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.cancel.__code__.co_varnames == ('self',) — len=1 (fewest co_varnames in spec; cancel takes only self and checks state flags inline). Future.done.__code__.co_varnames == ('self',) — len=1 (tied with cancel). Future.result.__code__.co_varnames == ('self', 'timeout') — len=2. Future.set_result.__code__.co_varnames == ('self', 'result', 'waiter') — len=3 (most in simple Future methods group; the extra local 'waiter' is for notifying waiting threads). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Executor.map.__code__.co_qualname == 'Executor.map' (len=12). Executor.__enter__.__code__.co_qualname == 'Executor.__enter__' (len=18). Executor.__exit__.__code__.co_qualname == 'Executor.__exit__' (len=17). These are the Executor base class methods. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future method co_varnames lengths — extra114
#
# Wave 257 theme: Future method co_varnames.__len__() (not previously covered).
#
# concurrent.futures.Future.cancel.__code__.co_varnames.__len__()      == 1  (fewest: only self)
# concurrent.futures.Future.done.__code__.co_varnames.__len__()        == 1  (tied)
# concurrent.futures.Future.result.__code__.co_varnames.__len__()      == 2  (self + timeout)
# concurrent.futures.Future.set_result.__code__.co_varnames.__len__()  == 3  (most: self+result+waiter)
# ---------------------------------------------------------------------------

table concurrent_futures_extra114.cf_future_co_varnames_len:
  description: "concurrent.futures.Future method co_varnames length checks in cfvar114 namespace — wave 257 theme: Future.cancel.__code__.co_varnames.__len__()==1 (co_varnames==('self',): fewest in spec; cancel checks self._state and returns bool, no additional locals needed); Future.done.__code__.co_varnames.__len__()==1 (tied with cancel: co_varnames==('self',): done checks self._state against FINISHED/CANCELLED states inline); Future.cancelled.__code__.co_varnames.__len__()==1 (tied: co_varnames==('self',)); Future.running.__code__.co_varnames.__len__()==1 (tied: co_varnames==('self',)); Future.result.__code__.co_varnames.__len__()==2 (co_varnames==('self','timeout'): result takes a timeout parameter for blocking); Future.exception.__code__.co_varnames.__len__()==2 (tied with result: co_varnames==('self','timeout')); Future.add_done_callback.__code__.co_varnames.__len__()==2 (co_varnames==('self','fn')); Future.set_result.__code__.co_varnames.__len__()==3 (most co_varnames: co_varnames==('self','result','waiter'): the extra local 'waiter' notifies threads waiting in result()); Future.set_exception.__code__.co_varnames.__len__()==3 (tied with set_result: co_varnames==('self','exception','waiter')); compare lengths: cancel==done==cancelled==running==1 (fewest; 4-way tie) < result==exception==add_done_callback==2 (middle; 3-way tie) < set_result==set_exception==3 (most; tied); note: the 4 methods with len=1 are the simple state-query methods; the 2-varname methods take one extra param; the 3-varname methods are state-setters that need to notify waiters; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfvar114

  columns: [id, function, args, expected, description]
  rows:
    - [cancel_vl,  concurrent.futures.Future.cancel.__code__.co_varnames.__len__,          [], 1, "Future.cancel co_varnames len=1 (('self',); fewest in spec); verified with Python 3.14.3"]
    - [done_vl,    concurrent.futures.Future.done.__code__.co_varnames.__len__,            [], 1, "Future.done co_varnames len=1 (tied with cancel, cancelled, running); verified with Python 3.14.3"]
    - [cld_vl,     concurrent.futures.Future.cancelled.__code__.co_varnames.__len__,       [], 1, "Future.cancelled co_varnames len=1 (('self',); state query); verified with Python 3.14.3"]
    - [run_vl,     concurrent.futures.Future.running.__code__.co_varnames.__len__,         [], 1, "Future.running co_varnames len=1 (tied: 4-way tie at 1); verified with Python 3.14.3"]
    - [result_vl,  concurrent.futures.Future.result.__code__.co_varnames.__len__,          [], 2, "Future.result co_varnames len=2 (('self','timeout')); verified with Python 3.14.3"]
    - [exc_vl,     concurrent.futures.Future.exception.__code__.co_varnames.__len__,       [], 2, "Future.exception co_varnames len=2 (tied with result: ('self','timeout')); verified with Python 3.14.3"]
    - [adc_vl,     concurrent.futures.Future.add_done_callback.__code__.co_varnames.__len__, [], 2, "Future.add_done_callback co_varnames len=2 (('self','fn')); verified with Python 3.14.3"]
    - [sr_vl,      concurrent.futures.Future.set_result.__code__.co_varnames.__len__,      [], 3, "Future.set_result co_varnames len=3 (('self','result','waiter'); most in spec); verified with Python 3.14.3"]
    - [se_vl,      concurrent.futures.Future.set_exception.__code__.co_varnames.__len__,   [], 3, "Future.set_exception co_varnames len=3 (tied with set_result: ('self','exception','waiter')); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Executor base class method co_qualname — extra114
#
# Wave 257 theme: Executor.map, __enter__, __exit__ co_qualname (not previously covered).
#
# concurrent.futures.Executor.map.__code__.co_qualname       == 'Executor.map'      (len=12)
# concurrent.futures.Executor.__exit__.__code__.co_qualname  == 'Executor.__exit__' (len=17)
# concurrent.futures.Executor.__enter__.__code__.co_qualname == 'Executor.__enter__' (len=18, longest)
# ---------------------------------------------------------------------------

table concurrent_futures_extra114.cf_executor_coqualname:
  description: "concurrent.futures.Executor base class method co_qualname checks in cfvar114 namespace — wave 257 theme: Executor.map.__code__.co_qualname.__eq__('Executor.map')==True (len=12: 'Executor.'=9+'map'=3=12; Executor.map is the base-class implementation of concurrent execution with iteration, chunksize and buffersize; co_argcount=2: self and fn); Executor.map.__code__.co_qualname.__len__()==12; Executor.map.__code__.co_argcount.__eq__(2)==True; Executor.__exit__.__code__.co_qualname.__eq__('Executor.__exit__')==True (len=17: 'Executor.'=9+'__exit__'=8=17; __exit__ is the context manager exit handler: it calls self.shutdown(wait=True)); Executor.__exit__.__code__.co_qualname.__len__()==17; Executor.__exit__.__code__.co_argcount.__eq__(4)==True (self, exc_type, exc_val, exc_tb — standard context manager signature); Executor.__enter__.__code__.co_qualname.__eq__('Executor.__enter__')==True (len=18: 'Executor.'=9+'__enter__'=9=18; longest Executor co_qualname in spec; __enter__ returns self); Executor.__enter__.__code__.co_qualname.__len__()==18; Executor.__enter__.__code__.co_argcount.__eq__(1)==True (only self; __enter__ just returns self); compare co_qualname lengths: Executor.map=12 (shortest) < Executor.__exit__=17 < Executor.__enter__=18 (longest; 1 more than __exit__); compare co_argcount: __enter__=1 (fewest) < map=2 < __exit__=4 (most); note: '__enter__'=9 and '__exit__'=8 differ by 1 char, matching the 1-char difference in co_qualname lengths; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfvar114a

  columns: [id, function, args, expected, description]
  rows:
    - [map_coq_eq,    Executor.map.__code__.co_qualname.__eq__,       ["Executor.map"],      true, "Executor.map.__code__.co_qualname == 'Executor.map' (len=12, shortest in spec); verified with Python 3.14.3"]
    - [map_coq_len,   Executor.map.__code__.co_qualname.__len__,      [],                    12,   "Executor.map co_qualname.__len__() == 12 ('Executor.map'=12); verified with Python 3.14.3"]
    - [map_argc,      Executor.map.__code__.co_argcount.__eq__,       [2],                   true, "Executor.map.__code__.co_argcount == 2 (self and fn); verified with Python 3.14.3"]
    - [exit_coq_eq,   Executor.__exit__.__code__.co_qualname.__eq__,  ["Executor.__exit__"], true, "Executor.__exit__.__code__.co_qualname == 'Executor.__exit__' (len=17); verified with Python 3.14.3"]
    - [exit_coq_len,  Executor.__exit__.__code__.co_qualname.__len__, [],                    17,   "Executor.__exit__ co_qualname.__len__() == 17 ('Executor.__exit__'=17); verified with Python 3.14.3"]
    - [exit_argc,     Executor.__exit__.__code__.co_argcount.__eq__,  [4],                   true, "Executor.__exit__.__code__.co_argcount == 4 (self, exc_type, exc_val, exc_tb; most args in spec); verified with Python 3.14.3"]
    - [ent_coq_eq,    Executor.__enter__.__code__.co_qualname.__eq__, ["Executor.__enter__"], true, "Executor.__enter__.__code__.co_qualname == 'Executor.__enter__' (len=18, longest in spec); verified with Python 3.14.3"]
    - [ent_coq_len,   Executor.__enter__.__code__.co_qualname.__len__, [],                   18,   "Executor.__enter__ co_qualname.__len__() == 18 ('Executor.__enter__'=18, longest); verified with Python 3.14.3"]
    - [ent_argc,      Executor.__enter__.__code__.co_argcount.__eq__, [1],                   true, "Executor.__enter__.__code__.co_argcount == 1 (self only; __enter__ returns self); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures Future and Executor cross-checks — extra114
#
# Wave 257 theme: comparing co_varnames len ordering and co_qualname lengths.
#
# Future simple methods (cancel/done) co_varnames len=1 (fewest)
# Future.set_result/set_exception co_varnames len=3 (most in Future)
# Executor.map co_qualname len=12 < Executor.__exit__=17 < Executor.__enter__=18
# ---------------------------------------------------------------------------

table concurrent_futures_extra114.cf_future_executor_crosscheck:
  description: "concurrent.futures Future and Executor cross-check comparisons in cfvar114 namespace — wave 257 theme: confirming relative magnitude comparisons; Future.cancel.__code__.co_varnames.__len__()==1 (fewest; tied with done, cancelled, running); Future.set_result.__code__.co_varnames.__len__()==3 (most in Future simple methods; set_result and set_exception both have 3); Executor.map.__code__.co_qualname.__len__()==12 (shortest Executor co_qualname in spec); Executor.__enter__.__code__.co_qualname.__len__()==18 (longest Executor co_qualname in spec); note: Future method co_varnames lengths range from 1 to 3 (very compact — Future methods are simple state machines); Executor methods have co_qualname lengths 12-18; 'Executor.'=9 prefix affects all three Executor method qualnames (map=12 means method name 'map'=3 chars; __exit__=17 means '__exit__'=8 chars; __enter__=18 means '__enter__'=9 chars); Future.cancel.__code__.co_argcount.__eq__(1)==True (cancel takes only self); Future.result.__code__.co_argcount.__eq__(2)==True (result takes self and timeout); Future.set_result.__code__.co_argcount.__eq__(2)==True (set_result takes self and result; note co_argcount=2 but co_varnames len=3 because 'waiter' is a local var not a parameter); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfvar114b

  columns: [id, function, args, expected, description]
  rows:
    - [cancel_v1,    concurrent.futures.Future.cancel.__code__.co_varnames.__len__,         [], 1,  "Future.cancel co_varnames len=1 (fewest; only self); verified with Python 3.14.3"]
    - [sr_v3,        concurrent.futures.Future.set_result.__code__.co_varnames.__len__,     [], 3,  "Future.set_result co_varnames len=3 (most: self+result+waiter); verified with Python 3.14.3"]
    - [map_coq_12,   Executor.map.__code__.co_qualname.__len__,                            [], 12, "Executor.map co_qualname len=12 (shortest Executor co_qualname); verified with Python 3.14.3"]
    - [exit_coq_17,  Executor.__exit__.__code__.co_qualname.__len__,                       [], 17, "Executor.__exit__ co_qualname len=17 (middle Executor co_qualname); verified with Python 3.14.3"]
    - [ent_coq_18,   Executor.__enter__.__code__.co_qualname.__len__,                      [], 18, "Executor.__enter__ co_qualname len=18 (longest Executor co_qualname); verified with Python 3.14.3"]
    - [cancel_argc1, concurrent.futures.Future.cancel.__code__.co_argcount.__eq__,         [1], true, "Future.cancel.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]
    - [result_argc2, concurrent.futures.Future.result.__code__.co_argcount.__eq__,         [2], true, "Future.result.__code__.co_argcount == 2 (self and timeout); verified with Python 3.14.3"]
    - [sr_argc2,     concurrent.futures.Future.set_result.__code__.co_argcount.__eq__,     [2], true, "Future.set_result.__code__.co_argcount == 2 (self and result; waiter is local var, not param); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra114
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra114.future_cancel_co_varnames_len_1:
  description: "concurrent.futures.Future.cancel.__code__.co_varnames.__len__() == 1 — co_varnames==('self',): Future.cancel takes only self and returns True if the future was successfully cancelled, False otherwise; cancel checks self._state (PENDING or RUNNING) and flips it to CANCELLED; no additional locals are needed in the simple fast-path; len=1 is the fewest co_varnames of any Future method; Future.done/Future.cancelled/Future.running all share len=1 (4-way tie); Future.result has len=2 (timeout param); Future.set_result has len=3 (waiter local); concurrent.futures.Future.cancel.__code__.co_qualname=='Future.cancel' (len=13); Future.cancel.__code__.co_argcount==1 (self only); Future.__module__=='concurrent.futures._base' (len=24); first standalone Future.cancel co_varnames length invariant in cfvar114 namespace; wave 257; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.Future.cancel.__code__.co_varnames.__len__
  args: []
  expected: 1

invariant concurrent_futures_extra114.future_set_result_co_varnames_len_3:
  description: "concurrent.futures.Future.set_result.__code__.co_varnames.__len__() == 3 — co_varnames==('self','result','waiter'): set_result takes self and result (the value to store), plus uses a local 'waiter' variable to notify threads blocking in result(); len=3 is the most co_varnames of any simple Future method (the mutation methods set_result and set_exception both have 3); Future.set_exception also has len=3 (co_varnames==('self','exception','waiter'); same waiter pattern); compare: Future.cancel len=1 (fewest) < Future.result len=2 < Future.set_result len=3 (most); concurrent.futures.Future.set_result.__code__.co_qualname=='Future.set_result' (len=17); Future.set_result.__code__.co_argcount==2 (self and result; 'waiter' is a local variable not a param, so it is in co_varnames but not counted in co_argcount); first standalone set_result co_varnames length invariant in cfvar114 namespace; wave 257; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.Future.set_result.__code__.co_varnames.__len__
  args: []
  expected: 3

invariant concurrent_futures_extra114.executor_map_co_qualname_len_12:
  description: "concurrent.futures.Executor.map.__code__.co_qualname.__len__() == 12 — 'Executor.map' = 'Executor.'=9+'map'=3=12; this is the shortest Executor method co_qualname in this spec; Executor.map is the base-class implementation that runs fn(*args) for each arg in the iterables concurrently; Executor.map.__code__.co_qualname.__eq__('Executor.map')==True; Executor.map.__code__.co_argcount==2 (self and fn); compare Executor co_qualname lengths: map=12 (shortest) < __exit__=17 < __enter__=18 (longest); the 'map' name is only 3 chars (shortest method name in spec), while '__enter__'=9 and '__exit__'=8 are much longer; Executor.map.__code__.co_varnames has 8 entries including iterables, result_iterator etc.; first standalone Executor.map co_qualname length invariant in cfvar114 namespace; wave 257; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: Executor.map.__code__.co_qualname.__len__
  args: []
  expected: 12

invariant concurrent_futures_extra114.executor_exit_co_qualname_len_17:
  description: "concurrent.futures.Executor.__exit__.__code__.co_qualname.__len__() == 17 — 'Executor.__exit__' = 'Executor.'=9+'__exit__'=8=17; Executor.__exit__ is the context manager protocol exit handler; it calls self.shutdown(wait=True) to clean up thread/process pools on context exit; Executor.__exit__.__code__.co_qualname.__eq__('Executor.__exit__')==True; Executor.__exit__.__code__.co_argcount==4 (most in spec: self, exc_type, exc_val, exc_tb — standard context manager signature); compare: Executor.map co_qualname len=12 (5 shorter) < Executor.__exit__=17 < Executor.__enter__=18 (1 longer); note: '__exit__'=8 chars vs '__enter__'=9 chars — __enter__ is 1 char longer, which propagates to the co_qualname length difference of 1; first standalone Executor.__exit__ co_qualname length invariant in cfvar114 namespace; wave 257; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: Executor.__exit__.__code__.co_qualname.__len__
  args: []
  expected: 17

invariant concurrent_futures_extra114.executor_enter_co_qualname_len_18:
  description: "concurrent.futures.Executor.__enter__.__code__.co_qualname.__len__() == 18 — 'Executor.__enter__' = 'Executor.'=9+'__enter__'=9=18; this is the longest Executor method co_qualname in this spec; Executor.__enter__ returns self (the executor) for use in with statements; Executor.__enter__.__code__.co_qualname.__eq__('Executor.__enter__')==True; Executor.__enter__.__code__.co_argcount==1 (fewest in spec: only self; __enter__ just does 'return self'); compare: Executor.__exit__ co_qualname len=17 (1 shorter) vs Executor.__enter__=18 (1 longer; '__enter__'=9 vs '__exit__'=8, 1-char difference); Executor.map co_qualname len=12 (6 shorter than __enter__); note: the simplest method (__enter__, just returns self, co_argcount=1) has the longest co_qualname (18) while the most complex (__exit__, co_argcount=4) has the middle co_qualname (17); first standalone Executor.__enter__ co_qualname length invariant in cfvar114 namespace; wave 257; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: Executor.__enter__.__code__.co_qualname.__len__
  args: []
  expected: 18
