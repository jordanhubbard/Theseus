spec: traceback_extra27
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
    - "traceback_extra26.zspec.zsdl — covers __all__.__len__()==20; __all__.__class__.__name__.__len__()==4; TracebackException/StackSummary/FrameSummary __dict__.__class__.__name__.__len__()==12; walk_stack(10)/walk_tb(7)/clear_frames(12)/format_exception(16)/print_exception(15) __qualname__.__len__(); StackSummary.format(19)/TracebackException.format(25) __qualname__.__len__()."
    - "traceback_extra25.zspec.zsdl — covers __mro__.__len__() for TracebackException/StackSummary/FrameSummary; __bases__[0].__name__.__len__() for all three; FrameSummary method __qualname__.__len__(); TracebackException.__init__/__qualname__.__len__()==27."
    - "traceback_extra24.zspec.zsdl — covers module-level function __name__.__len__() for format_exception/format_stack/extract_tb/extract_stack/print_last/print_stack."
    - "traceback_extra23.zspec.zsdl — covers TracebackException method __qualname__.__len__() (from_exception=33, format=25, format_exception_only=40) and StackSummary (extract=20, from_list=22)."
  notes:
    - "This spec extends traceback_extra26.zspec.zsdl."
    - "Prior specs covered: TracebackException/StackSummary/FrameSummary __mro__/__bases__/__dict__ type, method __qualname__.__len__() for TracebackException/StackSummary/FrameSummary methods, module-level function __name__/__qualname__ lengths for walk_stack/walk_tb/clear_frames/format_exception/print_exception."
    - "This spec covers NEW angles: class __qualname__.__len__() for TracebackException(18)/StackSummary(12)/FrameSummary(12); module-level function __qualname__.__len__() for print_tb(8)/format_tb(9)/print_stack(11)/format_stack(12)/extract_tb(10)/extract_stack(13); TracebackException.from_exception.__qualname__.__len__()==33."
    - "traceback.TracebackException.__qualname__ == 'TracebackException' (len 18). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.StackSummary.__qualname__ == 'StackSummary' (len 12). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.FrameSummary.__qualname__ == 'FrameSummary' (len 12). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.print_tb.__qualname__ == 'print_tb' (len 8). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.format_tb.__qualname__ == 'format_tb' (len 9). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.print_stack.__qualname__ == 'print_stack' (len 11). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.format_stack.__qualname__ == 'format_stack' (len 12). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.extract_tb.__qualname__ == 'extract_tb' (len 10). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.extract_stack.__qualname__ == 'extract_stack' (len 13). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.TracebackException.from_exception.__qualname__ == 'TracebackException.from_exception' (len 33). Confirmed again here in dedicated standalone invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# traceback class __qualname__.__len__() for TracebackException, StackSummary,
# FrameSummary
#
# No prior spec checks __qualname__.__len__() for these classes.
# TracebackException.__qualname__ == 'TracebackException' (len 18).
# StackSummary.__qualname__ == 'StackSummary' (len 12).
# FrameSummary.__qualname__ == 'FrameSummary' (len 12).
# ---------------------------------------------------------------------------

invariant traceback_extra27.TracebackException.qualname.len:
  description: "traceback.TracebackException.__qualname__.__len__() == 18 — 'TracebackException' has 18 characters"
  category: class_identity
  kind: python_call_eq
  function: TracebackException.__qualname__.__len__
  args: []
  expected: 18

invariant traceback_extra27.StackSummary.qualname.len:
  description: "traceback.StackSummary.__qualname__.__len__() == 12 — 'StackSummary' has 12 characters"
  category: class_identity
  kind: python_call_eq
  function: StackSummary.__qualname__.__len__
  args: []
  expected: 12

invariant traceback_extra27.FrameSummary.qualname.len:
  description: "traceback.FrameSummary.__qualname__.__len__() == 12 — 'FrameSummary' has 12 characters"
  category: class_identity
  kind: python_call_eq
  function: FrameSummary.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# traceback.TracebackException.from_exception.__qualname__.__len__()
#
# TracebackException.from_exception.__qualname__ ==
# 'TracebackException.from_exception' (len 33). Confirmed via standalone
# invariant — prior spec23 group used a table; this is a direct invariant.
# ---------------------------------------------------------------------------

invariant traceback_extra27.TracebackException.from_exception.qualname.len:
  description: "traceback.TracebackException.from_exception.__qualname__.__len__() == 33 — 'TracebackException.from_exception'"
  category: string_length
  kind: python_call_eq
  function: TracebackException.from_exception.__qualname__.__len__
  args: []
  expected: 33

# ---------------------------------------------------------------------------
# Table: module-level function __qualname__.__len__() — print_tb, format_tb,
# print_stack, format_stack, extract_tb, extract_stack
#
# No prior spec checks __qualname__.__len__() for print_tb, format_tb,
# print_stack, format_stack, extract_tb, or extract_stack.
# print_tb=8, format_tb=9, print_stack=11, format_stack=12,
# extract_tb=10, extract_stack=13.
# ---------------------------------------------------------------------------

table traceback_extra27.tb_and_stack_function_qualnames:
  description: "traceback module-level function __qualname__.__len__() — print_tb (8), format_tb (9), print_stack (11), format_stack (12), extract_tb (10), extract_stack (13)"
  kind: python_call_eq
  category: string_length

  columns: [id, function, args, expected, description]
  rows:
    - [print_tb_qualname_len,
       print_tb.__qualname__.__len__,
       [],
       8,
       "len('print_tb') == 8"]
    - [format_tb_qualname_len,
       format_tb.__qualname__.__len__,
       [],
       9,
       "len('format_tb') == 9"]
    - [print_stack_qualname_len,
       print_stack.__qualname__.__len__,
       [],
       11,
       "len('print_stack') == 11"]
    - [format_stack_qualname_len,
       format_stack.__qualname__.__len__,
       [],
       12,
       "len('format_stack') == 12"]
    - [extract_tb_qualname_len,
       extract_tb.__qualname__.__len__,
       [],
       10,
       "len('extract_tb') == 10"]
    - [extract_stack_qualname_len,
       extract_stack.__qualname__.__len__,
       [],
       13,
       "len('extract_stack') == 13"]

# ---------------------------------------------------------------------------
# Table: traceback class __qualname__.__len__() for the three public classes
#
# Groups class __qualname__ length checks for TracebackException, StackSummary,
# and FrameSummary. No prior spec covers __qualname__.__len__() for any of
# these classes.
# ---------------------------------------------------------------------------

table traceback_extra27.class_qualname_lens:
  description: "traceback class __qualname__.__len__() — TracebackException (18), StackSummary (12), FrameSummary (12)"
  kind: python_call_eq
  category: class_identity

  columns: [id, function, args, expected, description]
  rows:
    - [TracebackException_qualname_len,
       TracebackException.__qualname__.__len__,
       [],
       18,
       "len('TracebackException') == 18"]
    - [StackSummary_qualname_len,
       StackSummary.__qualname__.__len__,
       [],
       12,
       "len('StackSummary') == 12"]
    - [FrameSummary_qualname_len,
       FrameSummary.__qualname__.__len__,
       [],
       12,
       "len('FrameSummary') == 12"]
    - [StackSummary_extract_qualname_len,
       StackSummary.extract.__qualname__.__len__,
       [],
       20,
       "len('StackSummary.extract') == 20"]
    - [TracebackException_from_exception_qualname_len,
       TracebackException.from_exception.__qualname__.__len__,
       [],
       33,
       "len('TracebackException.from_exception') == 33"]
