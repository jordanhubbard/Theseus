spec: struct_extra49
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra48.zspec.zsdl — covers Struct/__dict__/__class__/__name__.__eq__('mappingproxy') and /__qualname__.__eq__('mappingproxy') and /__module__.__eq__('builtins'); error/__dict__ same three axes."
    - "struct_extra47.zspec.zsdl — covers Struct/error __mro__[0]/__name__/__qualname__.__eq__; Struct.size/format __class__.__qualname__/__module__."
    - "struct_extra46.zspec.zsdl — covers pack/unpack/calcsize/Struct/error __module__.__class__.__name__/__qualname__ and __module__.__len__()."
    - "struct_extra45.zspec.zsdl — covers Struct/pack/error __doc__.__class__.__qualname__.__eq__('str'), module __doc__.__class__.__name__/__qualname__/__module__, and Struct method qualname table."
    - "struct_extra44.zspec.zsdl — covers Struct/pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/error __doc__.__class__.__name__.__eq__('str')."
    - "struct_extra43.zspec.zsdl — covers Struct/error __class__.__qualname__.__eq__('type') and pack/unpack/calcsize/pack_into/unpack_from/iter_unpack __class__.__qualname__.__eq__('builtin_function_or_method') and Struct/pack/error __class__.__module__.__eq__('builtins')."
    - "struct_extra27.zspec.zsdl — covers Struct/error __dict__.__class__.__name__.__len__()==12 (length only, via __name__ chain)."
    - "struct_extra23.zspec.zsdl — covers calcsize/pack_into/unpack_from/iter_unpack __qualname__.__class__.__name__.__eq__('str')."
    - "struct_extra20.zspec.zsdl — covers pack/unpack __qualname__.__class__.__name__.__eq__('str')."
    - "struct_extra19.zspec.zsdl — covers struct module __name__.__eq__('struct'), __package__.__eq__(''), __name__/__package__.__class__.__name__.__eq__('str')."
    - "struct_extra18.zspec.zsdl — covers Struct/__module__.__eq__('_struct') and all six module-level functions __module__.__eq__('_struct') and error/__module__.__eq__('struct')."
    - "struct_extra4.zspec.zsdl — covers Struct.__name__.__eq__('Struct'), all module-level function __qualname__.__eq__ and error.__qualname__.__eq__('error')."
  notes:
    - "This spec extends struct through struct_extra48; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: No prior struct spec checks the struct module's own __dict__.__class__.__name__ or __qualname__. struct_extra45 checks the module __doc__.__class__.__name__/__qualname__ (the doc string's type, not the namespace dict's type). struct_extra19 checks struct.__name__.__eq__('struct') (the module's __name__ attribute, not __dict__.__class__.__name__). Under python_module(struct), function: __dict__.__class__.__name__.__eq__ resolves to struct.__dict__.__class__.__name__.__eq__('mappingproxy'). Module namespaces are mappingproxy objects in CPython. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.__dict__.__class__.__name__ == 'mappingproxy'. The struct module's namespace dict is a mappingproxy. No prior struct spec checks __dict__.__class__.__name__.__eq__('mappingproxy') for the module itself. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.__dict__.__class__.__qualname__ == 'mappingproxy'. The mappingproxy type's __qualname__ for the module namespace. Independent of __name__ axis. No prior struct spec checks __dict__.__class__.__qualname__.__eq__('mappingproxy') for the struct module. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior struct spec checks __dict__.__class__.__module__ for the struct module itself. struct_extra48 covers Struct.__dict__.__class__.__module__.__eq__('builtins') and error.__dict__.__class__.__module__.__eq__('builtins') (the class dicts). But the module-level __dict__.__class__.__module__ is a distinct check: the mappingproxy type that wraps the module namespace is the same C builtin type, so its __module__ is also 'builtins'. The access path struct.__dict__.__class__.__module__ has never been checked. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.__dict__.__class__.__module__ == 'builtins'. mappingproxy is a C builtin type; its __module__ is 'builtins' regardless of whether it wraps a class namespace or a module namespace. struct_extra48 covers Struct/__dict__/__class__/__module__ and error/__dict__/__class__/__module__ (class dicts). No prior spec checks __dict__.__class__.__module__.__eq__('builtins') for the struct module itself. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module __dict__.__class__.__name__ and __qualname__
#
# No prior struct spec checks the module's own __dict__.__class__.__name__
# or __qualname__. struct_extra48 covers Struct.__dict__/__class__/__name__
# and error.__dict__/__class__/__name__ (class dicts, not the module dict).
# struct_extra19 covers struct.__name__.__eq__('struct') (the module's own
# __name__ attribute, not its __dict__.__class__.__name__).
# Under python_module(struct), function: __dict__.__class__.__name__.__eq__
# resolves to struct.__dict__.__class__.__name__.__eq__('mappingproxy').
# Module namespaces in CPython are always mappingproxy objects.
# ---------------------------------------------------------------------------

invariant struct_extra49.module.dict_class_name_eq:
  description: "struct.__dict__.__class__.__name__ == 'mappingproxy' — the struct module's namespace dict is a mappingproxy; distinct from Struct.__dict__ and error.__dict__ (class dicts covered in extra48); no prior struct spec checks __dict__.__class__.__name__.__eq__('mappingproxy') for the module itself"
  category: module_identity
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant struct_extra49.module.dict_class_qualname_eq:
  description: "struct.__dict__.__class__.__qualname__ == 'mappingproxy' — the mappingproxy type's __qualname__ for the module namespace; independent of __name__ axis; no prior struct spec checks __dict__.__class__.__qualname__.__eq__('mappingproxy') for the struct module"
  category: module_identity
  kind: python_call_eq
  function: __dict__.__class__.__qualname__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# struct module __dict__.__class__.__module__
#
# No prior struct spec checks __dict__.__class__.__module__ for the struct
# module itself. struct_extra48 covers Struct.__dict__.__class__.__module__
# and error.__dict__.__class__.__module__ (class dicts, different objects).
# The mappingproxy type wrapping the module namespace is the same C builtin
# type as the one wrapping class namespaces; its __module__ is 'builtins'.
# Under python_module(struct), function: __dict__.__class__.__module__.__eq__
# resolves to struct.__dict__.__class__.__module__.__eq__('builtins').
# ---------------------------------------------------------------------------

invariant struct_extra49.module.dict_class_module_eq:
  description: "struct.__dict__.__class__.__module__ == 'builtins' — mappingproxy is a C builtin type; its __module__ is 'builtins'; struct_extra48 covers Struct/__dict__/__class__/__module__ and error/__dict__/__class__/__module__ (class dicts); no prior spec checks __dict__.__class__.__module__.__eq__('builtins') for the struct module itself"
  category: module_identity
  kind: python_call_eq
  function: __dict__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true
