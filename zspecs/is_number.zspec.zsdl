spec: is_number
version: ">=7.0.0"
backend: node(is-number)

docs: https://github.com/jonschlinkert/is-number#readme

provenance:
  derived_from:
    - "is-number README — https://github.com/jonschlinkert/is-number#readme"
    - "Test vectors verified with is-number@7.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-number source"
  notes:
    - "is-number exports the function directly as module.exports."
    - "Returns true if the value is a finite number or a numeric string."
    - "Returns false for NaN, Infinity, booleans, objects, and non-numeric strings."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean. No errors."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_number.check:
  kind: node_module_call_eq
  function: ~
  category: check
  id_prefix: isn

  columns: [id, args, expected]
  rows:
    - [integer,    [1],       true]
    - [float,      [1.5],     true]
    - [num_str,    ["42"],    true]
    - [nan,        [null],    false]
    - [boolean,    [true],    false]
    - [text,       ["abc"],   false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:29:13Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
