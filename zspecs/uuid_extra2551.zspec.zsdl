spec: uuid_extra2551
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module UUID class documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Theme: __reduce__, __reduce_ex__, and __getnewargs__ dict-presence — checking whether uuid.UUID defines its own pickling/serialization protocol in its class __dict__."
    - "uuid.UUID IS picklable: pickle.dumps(uuid.UUID(int=0)) succeeds and round-trips correctly."
    - "uuid.UUID defines __getstate__ and __setstate__ in its own __dict__ (present), but NOT __reduce__, __reduce_ex__, __getnewargs__, or __getnewargs_ex__."
    - "The pickle protocol for uuid.UUID is implemented via __getstate__/__setstate__, not via __reduce__ or __getnewargs__."
    - "uuid.UUID.__getstate__ returns the instance __dict__; __setstate__ restores it using object.__setattr__ to bypass the immutability enforced by __setattr__."
    - "__reduce__ and __reduce_ex__ are inherited from object (appear in object.__dict__, not in uuid.UUID.__dict__)."
    - "All expected values verified by running Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: uuid.UUID.__dict__ — __reduce__ and __getnewargs__ absent
#
# uuid.UUID does NOT define __reduce__, __reduce_ex__, __getnewargs__, or
# __getnewargs_ex__ in its own class __dict__. These are inherited from object.
# Pickling works via __getstate__/__setstate__ instead.
# ---------------------------------------------------------------------------

table uuid_extra2551.UUID_reduce_getnewargs_absent:
  description: "__reduce__, __reduce_ex__, __getnewargs__, __getnewargs_ex__ absent from uuid.UUID.__dict__; UUID uses __getstate__/__setstate__ for pickling; verified Python 3.14"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2551

  columns: [id, function, args, expected]
  rows:
    - ["uu2551-001", uuid.UUID.__dict__.__contains__, ["__reduce__"],        false]
    - ["uu2551-002", uuid.UUID.__dict__.__contains__, ["__reduce_ex__"],     false]
    - ["uu2551-003", uuid.UUID.__dict__.__contains__, ["__getnewargs__"],    false]
    - ["uu2551-004", uuid.UUID.__dict__.__contains__, ["__getnewargs_ex__"], false]

# ---------------------------------------------------------------------------
# Table 2: uuid.UUID.__dict__ — __getstate__ and __setstate__ ARE present
#
# uuid.UUID defines its serialization protocol via __getstate__ and __setstate__,
# not via __reduce__ or __getnewargs__. Both are present in uuid.UUID.__dict__.
# This is the positive counterpart to Table 1 — UUID DOES define custom
# pickle support, just through the state protocol rather than the reduce protocol.
# ---------------------------------------------------------------------------

table uuid_extra2551.UUID_getstate_setstate_present:
  description: "__getstate__ and __setstate__ ARE present in uuid.UUID.__dict__; UUID implements the pickle state protocol; verified Python 3.14"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2551

  columns: [id, function, args, expected]
  rows:
    - ["uu2551-005", uuid.UUID.__dict__.__contains__, ["__getstate__"], true]
    - ["uu2551-006", uuid.UUID.__dict__.__contains__, ["__setstate__"], true]

# ---------------------------------------------------------------------------
# Table 3: uuid.UUID.__dict__ — cross-check all six pickle dunders together
#
# Consolidates the absence/presence of all six pickle-protocol dunders in one
# table for compact cross-reference:
# - __reduce__, __reduce_ex__, __getnewargs__, __getnewargs_ex__: ABSENT
# - __getstate__, __setstate__: PRESENT
# ---------------------------------------------------------------------------

table uuid_extra2551.UUID_all_pickle_dunders_parity:
  description: "Full pickle-protocol dunder presence parity for uuid.UUID.__dict__: __reduce__/__reduce_ex__/__getnewargs__/__getnewargs_ex__ absent; __getstate__/__setstate__ present; verified Python 3.14"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2551

  columns: [id, function, args, expected]
  rows:
    - ["uu2551-007", uuid.UUID.__dict__.__contains__, ["__reduce__"],        false]
    - ["uu2551-008", uuid.UUID.__dict__.__contains__, ["__reduce_ex__"],     false]
    - ["uu2551-009", uuid.UUID.__dict__.__contains__, ["__getnewargs__"],    false]
    - ["uu2551-010", uuid.UUID.__dict__.__contains__, ["__getnewargs_ex__"], false]
    - ["uu2551-011", uuid.UUID.__dict__.__contains__, ["__getstate__"],      true]
    - ["uu2551-012", uuid.UUID.__dict__.__contains__, ["__setstate__"],      true]

# ---------------------------------------------------------------------------
# Table 4: uuid.UUID.__dict__ — positive controls for non-pickle members
#
# Confirms __dict__.__contains__ works correctly on uuid.UUID.
# Members that are expected to be present in uuid.UUID.__dict__:
# __init__, __str__, __hash__, __eq__, __int__ are all defined on UUID.
# ---------------------------------------------------------------------------

table uuid_extra2551.UUID_dict_positive_controls:
  description: "uuid.UUID.__dict__ positive controls — core members present; confirms __dict__.__contains__ is operational; verified Python 3.14"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2551

  columns: [id, function, args, expected]
  rows:
    - ["uu2551-013", uuid.UUID.__dict__.__contains__, ["__init__"],   true]
    - ["uu2551-014", uuid.UUID.__dict__.__contains__, ["__str__"],    true]
    - ["uu2551-015", uuid.UUID.__dict__.__contains__, ["__hash__"],   true]
    - ["uu2551-016", uuid.UUID.__dict__.__contains__, ["__eq__"],     true]
    - ["uu2551-017", uuid.UUID.__dict__.__contains__, ["__int__"],    true]
