spec: theseus_xml_sax_cr
version: ">=3.0"
backend: python_cleanroom(theseus_xml_sax_cr)
blocks: xml.sax

docs: https://docs.python.org/3/library/xml.sax.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/xml.sax.html"
  not_derived_from:
    - "CPython source: Lib/xml/sax/*.py"
  notes:
    - "Clean-room xml.sax module. Do NOT import xml.sax."

error_model: python_exceptions

invariant theseus_xml_sax_cr.xmlsax2_exceptions:
  description: "SAXException and SAXParseException exist"
  category: behavior
  kind: python_call_eq
  function: xmlsax2_exceptions
  args: []
  expected: true

invariant theseus_xml_sax_cr.xmlsax2_parsestring:
  description: "parseString() parses a simple XML document"
  category: behavior
  kind: python_call_eq
  function: xmlsax2_parsestring
  args: []
  expected: true

invariant theseus_xml_sax_cr.xmlsax2_handler:
  description: "ContentHandler class is present with startElement"
  category: behavior
  kind: python_call_eq
  function: xmlsax2_handler
  args: []
  expected: true
