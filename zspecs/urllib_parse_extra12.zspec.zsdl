spec: urllib_parse_extra12
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
    - "urllib_parse_extra3.zspec.zsdl — covers urlparse scheme/netloc/path with 'http://example.com/path' URL (no query, no fragment)"
    - "urllib_parse_extra8.zspec.zsdl — covers urlsplit port/fragment/username/password; unquote_plus plus_to_space"
    - "urllib_parse_extra11.zspec.zsdl — covers quote space->%20; unquote %20->space; urlencode return class; urlparse result class"
  notes:
    - "This spec extends urllib_parse.zspec.zsdl through urllib_parse_extra11.zspec.zsdl."
    - "Focus: urlparse with a full URL (scheme/netloc/path/query/fragment); urlencode with two keys; quote_plus space->plus."
    - "urllib.parse.urlparse('https://example.com/path?q=1#frag').scheme == 'https' — https scheme with fragment."
    - "urllib.parse.urlparse('https://example.com/path?q=1#frag').netloc == 'example.com'."
    - "urllib.parse.urlparse('https://example.com/path?q=1#frag').path == '/path'."
    - "urllib.parse.urlparse('https://example.com/path?q=1#frag').query == 'q=1'."
    - "urllib.parse.urlparse('https://example.com/path?q=1#frag').fragment == 'frag'."
    - "urllib.parse.urlencode({'a': '1', 'b': '2'}) == 'a=1&b=2' — insertion-order preserved in Python 3.7+."
    - "urllib.parse.quote_plus('hello world') == 'hello+world' — space encodes as + in query string encoding."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# urllib.parse.urlparse — full URL with scheme/netloc/path/query/fragment
#
# urllib_parse_extra3 covers scheme/netloc/path with 'http://example.com/path'
# (no query string, no fragment). This spec adds query and fragment fields and
# uses an https URL as a distinct input.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra12.urlparse.scheme:
  description: "urllib.parse.urlparse('https://example.com/path?q=1#frag').scheme == 'https'"
  category: urlparse
  kind: python_call_eq
  function: urlparse
  args: ["https://example.com/path?q=1#frag"]
  method: scheme.__eq__
  method_args: ["https"]
  expected: true

invariant urllib_parse_extra12.urlparse.netloc:
  description: "urllib.parse.urlparse('https://example.com/path?q=1#frag').netloc == 'example.com'"
  category: urlparse
  kind: python_call_eq
  function: urlparse
  args: ["https://example.com/path?q=1#frag"]
  method: netloc.__eq__
  method_args: ["example.com"]
  expected: true

invariant urllib_parse_extra12.urlparse.path:
  description: "urllib.parse.urlparse('https://example.com/path?q=1#frag').path == '/path'"
  category: urlparse
  kind: python_call_eq
  function: urlparse
  args: ["https://example.com/path?q=1#frag"]
  method: path.__eq__
  method_args: ["/path"]
  expected: true

invariant urllib_parse_extra12.urlparse.query:
  description: "urllib.parse.urlparse('https://example.com/path?q=1#frag').query == 'q=1'"
  category: urlparse
  kind: python_call_eq
  function: urlparse
  args: ["https://example.com/path?q=1#frag"]
  method: query.__eq__
  method_args: ["q=1"]
  expected: true

invariant urllib_parse_extra12.urlparse.fragment:
  description: "urllib.parse.urlparse('https://example.com/path?q=1#frag').fragment == 'frag'"
  category: urlparse
  kind: python_call_eq
  function: urlparse
  args: ["https://example.com/path?q=1#frag"]
  method: fragment.__eq__
  method_args: ["frag"]
  expected: true

# ---------------------------------------------------------------------------
# urllib.parse.urlencode — two-key dict produces key=val&key=val string
#
# urllib_parse_extra3 covers urlencode({'a': 1}) == 'a=1' (single key).
# urllib_parse_extra11 checks the return type is str.
# The two-key string value 'a=1&b=2' with string values is new.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra12.urlencode.two_keys:
  description: "urllib.parse.urlencode({'a': '1', 'b': '2'}) == 'a=1&b=2'"
  category: urlencode
  kind: python_call_eq
  function: urlencode
  args: [{"a": "1", "b": "2"}]
  expected: "a=1&b=2"

# ---------------------------------------------------------------------------
# urllib.parse.quote_plus — space encodes as +
#
# urllib_parse_extra3 covers quote('hello world') == 'hello%20world' (percent
# encoding). quote_plus is the query-string variant that maps space to '+'.
# No prior spec checks the behavioral output of quote_plus.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra12.quote_plus.space_to_plus:
  description: "urllib.parse.quote_plus('hello world') == 'hello+world'"
  category: quote_plus
  kind: python_call_eq
  function: quote_plus
  args: ["hello world"]
  expected: "hello+world"
