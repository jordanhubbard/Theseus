spec: statistics_extra17
version: ">=3.8"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics.zspec.zsdl and prior extras through statistics_extra16.zspec.zsdl."
    - "statistics_extra16 covers mean/median/mode/variance with [1,2,3,4,5] and stdev return type."
    - "statistics_extra covers StatisticsError.__name__, StatisticsError.__module__, error cases."
    - "statistics_extra4 covers mean.__qualname__ in a table alongside fmean/geometric_mean/harmonic_mean."
    - "No prior spec covers statistics.stdev([1,2,3,4,5]) == 1.5811388300841898 as a value invariant."
    - "No prior spec covers statistics.variance([1,2,3,4,5]) == 2.5 as a value invariant."
    - "No prior spec covers statistics.mean.__qualname__ == 'mean' as a standalone invariant."
    - "No prior spec covers statistics.StatisticsError.__qualname__ == 'StatisticsError'."
    - "statistics.stdev([1,2,3,4,5]) == 1.5811388300841898 — sample standard deviation with n-1 denominator."
    - "statistics.variance([1,2,3,4,5]) == 2.5 — sample variance: sum of squared deviations / (n-1) = 10/4 = 2.5."
    - "statistics.mean.__qualname__ == 'mean' — top-level function qualname equals simple name."
    - "statistics.StatisticsError.__qualname__ == 'StatisticsError' — exception class qualname."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# stdev and variance with [1, 2, 3, 4, 5]
#
# statistics_extra16 covers stdev([2,4,4,4,5,5,7,9]) return type and
# variance([2,4,4,4,5,5,7,9]) value. No prior spec records the exact
# numeric results for stdev and variance of [1,2,3,4,5].
# ---------------------------------------------------------------------------

invariant statistics_extra17.stdev.list_1_to_5:
  description: "statistics.stdev([1,2,3,4,5]) == 1.5811388300841898 — sample stdev with n-1 denominator"
  category: descriptive
  kind: python_call_eq
  function: stdev
  args: [[1, 2, 3, 4, 5]]
  expected: 1.5811388300841898

invariant statistics_extra17.variance.list_1_to_5:
  description: "statistics.variance([1,2,3,4,5]) == 2.5 — sample variance: 10/4 = 2.5"
  category: descriptive
  kind: python_call_eq
  function: variance
  args: [[1, 2, 3, 4, 5]]
  expected: 2.5

# ---------------------------------------------------------------------------
# Function and exception __qualname__ attributes
#
# statistics_extra4 records mean.__qualname__ in a table row alongside other
# functions. No prior spec has a standalone invariant for mean.__qualname__.
# No prior spec covers StatisticsError.__qualname__.
# ---------------------------------------------------------------------------

invariant statistics_extra17.mean.qualname:
  description: "statistics.mean.__qualname__ == 'mean' — top-level function qualname equals simple name"
  category: introspection
  kind: python_call_eq
  function: mean.__qualname__.__eq__
  args: ["mean"]
  expected: true

invariant statistics_extra17.StatisticsError.qualname:
  description: "statistics.StatisticsError.__qualname__ == 'StatisticsError' — exception class qualname"
  category: introspection
  kind: python_call_eq
  function: StatisticsError.__qualname__.__eq__
  args: ["StatisticsError"]
  expected: true
