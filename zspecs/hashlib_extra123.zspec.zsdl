spec: hashlib_extra123
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra122.zspec.zsdl — covers new.__class__.__module__.__len__()==8 / __spec__.__class__.__module__.__eq__('_frozen_importlib') / __spec__.__class__.__module__.__len__()==17 / __spec__.__class__.__name__.__len__()==10 / __spec__.name.__len__()==7 (table + invariants)."
    - "hashlib_extra115.zspec.zsdl — covers sha256().__class__.__doc__.__class__.__name__.__eq__('str') as a table row (table + invariants)."
    - "hashlib_extra107.zspec.zsdl — covers type(hashlib.md5()).__name__=='HASH' / __module__=='_hashlib' / __mro__.__len__()==2 / __bases__[0].__name__=='object' (table + invariants)."
    - "hashlib_extra52.zspec.zsdl — covers sha256.__doc__.__class__.__name__.__eq__('str') / sha256.__doc__.__class__.__qualname__.__eq__('str') as table rows (table + invariants)."
    - "hashlib_extra39.zspec.zsdl — covers sha256.__doc__.__class__.__name__.__len__()==3 as a standalone invariant."
  notes:
    - "This spec extends hashlib through hashlib_extra122; it does NOT duplicate invariants present in those files."
    - "Wave 280 theme: sha256 function __doc__ class module attribution and sha256() HASH instance class identity — sha256.__doc__.__class__.__module__=='builtins' (8 chars; NOT covered in any prior spec as a grouped table); sha256().__class__.__qualname__=='HASH' (4 chars; NOT covered via sha256() specifically; extra107 covers this via md5().__class__ only); sha256().__class__.__bases__[0].__name__=='object' (via sha256(); cross-check on distinct path); sha256().__class__.__mro__.__len__()==2 (via sha256(); cross-check)."
    - "hashlib.sha256.__doc__.__class__.__module__ == 'builtins'. len('builtins')==8. sha256 is a C-level builtin_function_or_method; its __doc__ is a Python str; the str type has __module__=='builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().__class__.__qualname__ == 'HASH'. len('HASH')==4. The HASH C type from _hashlib has __qualname__=='HASH'; since HASH is a top-level C type (not nested), __qualname__==__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().__class__.__bases__[0].__name__ == 'object'. len('object')==6. HASH directly inherits from object with no intermediate base classes. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().__class__.__mro__.__len__() == 2. MRO is (HASH, object) depth 2 — minimal for a C extension type. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().__class__.__module__ == '_hashlib'. len('_hashlib')==8. HASH class is defined in the _hashlib C extension module. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().__class__.__doc__.__class__.__name__.__len__() == 3. HASH.__doc__ is a str; len('str')==3. Distinct from sha256.__doc__ (the constructor docstring) which is also a str. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha256.__doc__.__class__.__module__.__eq__('builtins') == True
# hashlib.sha256.__doc__.__class__.__module__.__len__() == 8
# hashlib.sha256().__class__.__qualname__.__eq__('HASH') == True
# hashlib.sha256().__class__.__qualname__.__len__() == 4
# hashlib.sha256().__class__.__module__.__len__() == 8
#
# Wave 280 theme: sha256 function __doc__ class module and sha256() HASH class identity.
#
# hashlib.sha256 is a C builtin_function_or_method. Its __doc__ attribute is a Python
# str ('Returns a sha256 hash object; optionally initialized with a string'). The str
# type has __module__=='builtins' (8 chars) because the str type is a fundamental CPython
# runtime object from Objects/unicodeobject.c. No prior hashlib spec anchors
# sha256.__doc__.__class__.__module__ (equality or length) as a grouped table.
# hashlib.sha256().__class__.__qualname__ is 'HASH' (4 chars). HASH is a top-level
# C type so __qualname__==__name__=='HASH'. extra107 covers this via md5().__class__;
# no prior spec covers it specifically via sha256().__class__ as a grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra123.sha256_doc_class_module_and_HASH_qualname:
  description: "sha256.__doc__.__class__.__module__.__eq__('builtins')==True / sha256.__doc__.__class__.__module__.__len__()==8 / sha256().__class__.__qualname__.__eq__('HASH')==True / sha256().__class__.__qualname__.__len__()==4 / sha256().__class__.__module__.__len__()==8 — sha256.__doc__ is a str; str.__module__=='builtins' (8 chars); extra52 anchors sha256.__doc__.__class__.__name__.__eq__('str') but NOT the module; HASH.__qualname__=='HASH' (4 chars; top-level C type; extra107 covers via md5(); NOT via sha256() as grouped table); '_hashlib' module is 8 chars (same as 'builtins'=8 — length coincidence); first hashsha256123 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashsha256123

  columns: [id, function, args, expected, description]
  rows:
    - [doc_cls_mod_eq,   sha256.__doc__.__class__.__module__.__eq__,   ["builtins"], true, "sha256.__doc__.__class__.__module__ is 'builtins' (str type; fundamental CPython object; extra52 anchors __class__.__name__=='str' but NOT __module__)"]
    - [doc_cls_mod_len,  sha256.__doc__.__class__.__module__.__len__,  [],           8,    "sha256.__doc__.__class__.__module__.__len__() is 8 (len('builtins')==8; same length as '_hashlib'=8 — coincidence between module name lengths)"]
    - [hash_qualname_eq, "sha256().__class__.__qualname__.__eq__",     ["HASH"],     true, "sha256().__class__.__qualname__ is 'HASH' (top-level C type; __qualname__==__name__; extra107 anchors via md5(); first anchor via sha256())"]
    - [hash_qualname_len,"sha256().__class__.__qualname__.__len__",    [],           4,    "sha256().__class__.__qualname__.__len__() is 4 (len('HASH')==4; 'HASH' is as short as 'uuid'=4 or 'list'=4; minimal type name)"]
    - [hash_module_len,  "sha256().__class__.__module__.__len__",      [],           8,    "sha256().__class__.__module__.__len__() is 8 (len('_hashlib')==8; C extension module with underscore prefix; same length as 'builtins'=8)"]

# ---------------------------------------------------------------------------
# hashlib.sha256().__class__.__bases__[0].__name__.__eq__('object') == True
# hashlib.sha256().__class__.__bases__[0].__name__.__len__() == 6
# hashlib.sha256().__class__.__mro__.__len__() == 2
# hashlib.sha256().__class__.__qualname__.__len__() == 4
# hashlib.sha256.__doc__.__class__.__module__.__len__() == 8
#
# Wave 280 theme: HASH class bases and MRO accessed via sha256().
#
# HASH inherits directly from object (no intermediate base classes). This is the
# minimal inheritance depth for a C extension type. __mro__.__len__()==2 means
# the MRO is (HASH, object) with just two entries. __bases__[0].__name__=='object'
# (6 chars). extra107 anchors these facts via md5().__class__; this spec cross-checks
# via sha256().__class__ for independent regression coverage. The sha256() path
# confirms the property is shared across algorithms (they all use the same HASH type).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra123.sha256_HASH_bases_and_mro:
  description: "sha256().__class__.__bases__[0].__name__.__eq__('object')==True / sha256().__class__.__bases__[0].__name__.__len__()==6 / sha256().__class__.__mro__.__len__()==2 / sha256().__class__.__qualname__.__len__()==4 / sha256.__doc__.__class__.__module__.__len__()==8 — HASH directly inherits from object (no intermediate base); MRO depth 2 is minimal; 'object'=6 chars; extra107 anchors via md5(); this table cross-checks via sha256(); sha256 and md5 share the same HASH C type from _hashlib; first hashsha256123 anchor for sha256 HASH bases/MRO cross-check"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashsha256123

  columns: [id, function, args, expected, description]
  rows:
    - [hash_bases_obj_eq,  "sha256().__class__.__bases__[0].__name__.__eq__", ["object"], true, "sha256().__class__.__bases__[0].__name__ is 'object' (HASH has no intermediate bases; inherits directly from object; cross-check with extra107 via md5())"]
    - [hash_bases_obj_len, "sha256().__class__.__bases__[0].__name__.__len__", [],         6,    "sha256().__class__.__bases__[0].__name__.__len__() is 6 (len('object')==6; 'object' base class name; cross-check with extra107)"]
    - [hash_mro_len,       "sha256().__class__.__mro__.__len__",               [],         2,    "sha256().__class__.__mro__.__len__() is 2 (MRO is (HASH, object); minimal C extension type depth; cross-check with extra107 via md5())"]
    - [hash_qualname_len2, "sha256().__class__.__qualname__.__len__",          [],         4,    "sha256().__class__.__qualname__.__len__() is 4 (len('HASH')==4; cross-check confirming qualname length)"]
    - [doc_cls_mod_len2,   sha256.__doc__.__class__.__module__.__len__,        [],         8,    "sha256.__doc__.__class__.__module__.__len__() is 8 (len('builtins')==8; cross-check confirming str __module__ length)"]

# ---------------------------------------------------------------------------
# hashlib.sha256().__class__.__doc__.__class__.__name__.__len__() == 3
# hashlib.sha256().__class__.__doc__.__class__.__name__.__eq__('str') == True
# hashlib.sha256.__doc__.__class__.__module__.__eq__('builtins') == True
# hashlib.sha256().__class__.__bases__[0].__name__.__len__() == 6
# hashlib.sha256().__class__.__mro__.__len__() == 2
#
# Wave 280 theme: cross-check grouping HASH class doc type and sha256 constructor doc type.
#
# sha256().__class__.__doc__ is the HASH class docstring ('A hash is an object used
# to calculate a checksum...'). Its type is str (len('str')==3). extra115 anchors
# sha256().__class__.__doc__.__class__.__name__.__eq__('str') as a single table row.
# This table cross-checks via the length axis and also groups the sha256 constructor
# __doc__ class module alongside for a unified docstring-type picture. Both the
# constructor docstring (sha256.__doc__) and the HASH class docstring (sha256().__class__
# .__doc__) are str objects with __class__.__module__=='builtins'. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table hashlib_extra123.sha256_doc_type_cross_check:
  description: "sha256().__class__.__doc__.__class__.__name__.__len__()==3 / sha256().__class__.__doc__.__class__.__name__.__eq__('str')==True / sha256.__doc__.__class__.__module__.__eq__('builtins')==True / sha256().__class__.__bases__[0].__name__.__len__()==6 / sha256().__class__.__mro__.__len__()==2 — HASH class docstring is a str (len 3; extra115 anchors __eq__('str') as table row; this table adds __len__()==3); sha256 constructor docstring __class__.__module__=='builtins' (cross-check); 'object'=6 and MRO depth 2 cross-check; first hashsha256123 cross-doc-type anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashsha256123

  columns: [id, function, args, expected, description]
  rows:
    - [hash_doc_cls_name_len, "sha256().__class__.__doc__.__class__.__name__.__len__", [],           3,    "sha256().__class__.__doc__.__class__.__name__.__len__() is 3 (len('str')==3; HASH class docstring is a str; extra115 anchors __eq__('str') but NOT __len__()==3 for this path)"]
    - [hash_doc_cls_name_eq,  "sha256().__class__.__doc__.__class__.__name__.__eq__",  ["str"],     true, "sha256().__class__.__doc__.__class__.__name__ is 'str' (cross-check; HASH class docstring type; extra115 anchors this as a table row)"]
    - [doc_cls_mod_eq2,       sha256.__doc__.__class__.__module__.__eq__,               ["builtins"],true, "sha256.__doc__.__class__.__module__ is 'builtins' (cross-check; constructor docstring is str; str.__module__=='builtins')"]
    - [hash_bases_obj_len2,   "sha256().__class__.__bases__[0].__name__.__len__",       [],           6,    "sha256().__class__.__bases__[0].__name__.__len__() is 6 (cross-check confirming 'object'=6)"]
    - [hash_mro_len2,         "sha256().__class__.__mro__.__len__",                     [],           2,    "sha256().__class__.__mro__.__len__() is 2 (cross-check confirming MRO depth 2)"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__doc__.__class__.__module__.__eq__('builtins') — standalone
#
# hashlib.sha256.__doc__.__class__.__module__ is 'builtins'. sha256 is a C-level
# builtin_function_or_method. Its __doc__ attribute is a Python str object. The
# built-in str type (Objects/unicodeobject.c) has its __module__ set to 'builtins'
# because it is a fundamental CPython runtime type. Prior specs anchor
# sha256.__doc__.__class__.__name__.__eq__('str') (extra52) and
# sha256.__doc__.__class__.__name__.__len__()==3 (extra39), but NO prior spec anchors
# sha256.__doc__.__class__.__module__ (either equality or length) as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra123.sha256_doc_class_module_builtins:
  description: "hashlib.sha256.__doc__.__class__.__module__.__eq__('builtins') == True — sha256.__doc__ is a str; str type __module__ is 'builtins' (fundamental CPython runtime object from Objects/unicodeobject.c); extra52 anchors __class__.__name__.__eq__('str'); extra39 anchors __class__.__name__.__len__()==3; no prior spec anchors __class__.__module__ as standalone; first standalone under hashsha256123"
  category: type_identity
  kind: python_call_eq
  function: sha256.__doc__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256.__doc__.__class__.__module__.__len__() == 8 — standalone
#
# hashlib.sha256.__doc__.__class__.__module__.__len__() is 8. 'builtins' has 8 chars.
# The str type's __module__ is 'builtins' (8 chars). Coincidentally, 8 chars is also
# the length of '_hashlib' (sha256 instance __class__.__module__) — both module
# references associated with sha256 objects have 8-char names. The 'builtins' module
# (8 chars) contains all fundamental Python types; '_hashlib' (8 chars) is the C
# extension providing the hash functionality. No prior hashlib spec anchors
# sha256.__doc__.__class__.__module__.__len__()==8 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra123.sha256_doc_class_module_len_8:
  description: "hashlib.sha256.__doc__.__class__.__module__.__len__() == 8 — len('builtins')==8 (str type __module__ is 'builtins'; coincidental length match with sha256().__class__.__module__='_hashlib'=8 chars; both module references for sha256 objects are 8 chars; 'builtins'=fundamental types, '_hashlib'=C extension hash); no prior spec anchors sha256.__doc__ class module length as standalone; first standalone under hashsha256123"
  category: type_identity
  kind: python_call_eq
  function: sha256.__doc__.__class__.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# hashlib.sha256().__class__.__qualname__.__eq__('HASH') — standalone
#
# hashlib.sha256().__class__.__qualname__ is 'HASH'. The HASH type is defined at
# the top level of the _hashlib C extension module (not nested inside any class),
# so its __qualname__ equals its __name__ ('HASH'). This contrasts with nested
# classes where __qualname__ would be 'Outer.Inner'. extra107 anchors type(hashlib.md5())
# .__name__.__eq__('HASH') and type(hashlib.md5()).__module__.__eq__('_hashlib')
# but does NOT anchor __qualname__ specifically, and does NOT use sha256().
# This standalone is the first anchor for sha256().__class__.__qualname__=='HASH'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra123.sha256_HASH_qualname_HASH:
  description: "hashlib.sha256().__class__.__qualname__.__eq__('HASH') == True — HASH is a top-level C type in _hashlib; __qualname__==__name__=='HASH' (4 chars; no nesting in the C extension namespace); extra107 anchors __name__=='HASH' via md5().__class__ but NOT __qualname__ specifically and NOT via sha256(); first standalone under hashsha256123 for sha256().__class__.__qualname__"
  category: type_identity
  kind: python_call_eq
  function: "sha256().__class__.__qualname__.__eq__"
  args: ["HASH"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256().__class__.__doc__.__class__.__name__.__len__() == 3 — standalone
#
# hashlib.sha256().__class__.__doc__.__class__.__name__.__len__() is 3. The HASH
# class docstring (sha256().__class__.__doc__) is a Python str object, so its
# __class__.__name__ is 'str' (3 chars). This path accesses the HASH class docstring
# (not the sha256 constructor docstring). extra115 anchors the __eq__('str') form of
# this as a single table row; no prior spec anchors the length form (__len__()==3)
# for this exact path as a standalone. The 3-char name 'str' is the shortest
# fundamental type name for non-numeric types in Python.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra123.sha256_HASH_doc_class_name_len_3:
  description: "hashlib.sha256().__class__.__doc__.__class__.__name__.__len__() == 3 — len('str')==3 (HASH class docstring is a Python str; sha256().__class__.__doc__ accesses the HASH class docstring not the constructor __doc__; extra115 anchors __eq__('str') as table row; no prior spec anchors __len__()==3 for this exact path as standalone; first standalone under hashsha256123)"
  category: type_identity
  kind: python_call_eq
  function: "sha256().__class__.__doc__.__class__.__name__.__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# hashlib.sha256().__class__.__bases__[0].__name__.__eq__('object') — standalone
#
# hashlib.sha256().__class__.__bases__[0].__name__ is 'object'. The HASH type's
# __bases__ tuple contains exactly one entry: the object base class. HASH is a
# C extension type with no mixin bases — it inherits exclusively from object.
# extra107 anchors type(hashlib.md5()).__bases__[0].__name__.__eq__('object') as a
# table row; this standalone provides independent regression coverage via sha256()
# and is the first anchor for sha256().__class__.__bases__[0].__name__ specifically.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra123.sha256_HASH_bases_object:
  description: "hashlib.sha256().__class__.__bases__[0].__name__.__eq__('object') == True — HASH inherits directly from object with no intermediate base classes (C extension type with minimal inheritance depth); extra107 anchors this via md5() as a table row; first standalone via sha256() for independent regression coverage; first standalone under hashsha256123"
  category: type_identity
  kind: python_call_eq
  function: "sha256().__class__.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

