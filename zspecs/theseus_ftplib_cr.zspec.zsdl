spec: theseus_ftplib_cr
version: ">=3.8"
backend: python_cleanroom(theseus_ftplib_cr)
blocks: ftplib

docs: https://docs.python.org/3/library/ftplib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ftplib.html"
  not_derived_from:
    - "CPython source: Lib/ftplib.py"
  notes:
    - "Clean-room ftplib module. Do NOT import ftplib."
    - "FTP class with connect, login, quit, nlst, retrbinary, storbinary."
    - "error_reply, error_temp, error_perm, error_proto exceptions."

error_model: python_exceptions

invariant theseus_ftplib_cr.ftplib2_exceptions:
  description: "ftplib exception classes exist and inherit from Error"
  category: exceptions
  kind: python_call_eq
  function: ftplib2_exceptions
  args: []
  expected: true

invariant theseus_ftplib_cr.ftplib2_parse227:
  description: "PASV response parser returns host and port"
  category: parsing
  kind: python_call_eq
  function: ftplib2_parse227
  args: []
  expected: true

invariant theseus_ftplib_cr.ftplib2_parse257:
  description: "PWD response parser returns directory path"
  category: parsing
  kind: python_call_eq
  function: ftplib2_parse257
  args: []
  expected: true
