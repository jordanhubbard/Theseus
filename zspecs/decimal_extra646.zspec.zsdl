spec: decimal_extra646
version: ">=3.9"
backend: python_module(decimal)
docs: "Behavioral spec for decimal signal class __doc__ type, module identity, and rounding constant string values."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module signal and rounding constant reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All signal classes derive from decimal.DecimalException."
    - "Rounding constants are plain str objects exposed at module level."
  created_at: "2026-04-12T00:00:00Z"

table decimal_extra646.signal_doc_class_names:
  description: "Class name of __doc__ for decimal signal exception classes."
  kind: python_call_eq
  category: doc_type
  id_prefix: de646dc
  columns: [id, function, args, expected]
  rows:
    - [de646dc001, decimal.InvalidOperation.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [de646dc002, decimal.DivisionByZero.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [de646dc003, decimal.Overflow.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [de646dc004, decimal.Underflow.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [de646dc005, decimal.Inexact.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [de646dc006, decimal.Rounded.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [de646dc007, decimal.Subnormal.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [de646dc008, decimal.FloatOperation.__doc__.__class__.__name__.__eq__, ["str"], true]

table decimal_extra646.signal_module_identity:
  description: "Module identity of decimal.Subnormal and decimal.FloatOperation."
  kind: python_call_eq
  category: module_identity
  id_prefix: de646sg
  columns: [id, function, args, expected]
  rows:
    - [de646sg001, decimal.Subnormal.__module__.__eq__, ["decimal"], true]
    - [de646sg002, decimal.FloatOperation.__module__.__eq__, ["decimal"], true]

table decimal_extra646.rounding_constants:
  description: "String values of decimal rounding mode constants."
  kind: python_call_eq
  category: rounding
  id_prefix: de646rc
  columns: [id, function, args, expected]
  rows:
    - [de646rc001, decimal.ROUND_UP.__eq__, ["ROUND_UP"], true]
    - [de646rc002, decimal.ROUND_DOWN.__eq__, ["ROUND_DOWN"], true]
    - [de646rc003, decimal.ROUND_CEILING.__eq__, ["ROUND_CEILING"], true]
    - [de646rc004, decimal.ROUND_FLOOR.__eq__, ["ROUND_FLOOR"], true]
