spec: pathlib_extra10
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
  notes:
    - "This spec extends pathlib.zspec.zsdl through pathlib_extra9.zspec.zsdl."
    - "pathlib_extra9 covers all __qualname__ and __module__ checks for pathlib classes; covers .name/.stem/.suffix/.suffixes/.root/.drive/.anchor for PurePosixPath on /a/b/c and /a/b/c.txt."
    - "pathlib_extra8 covers .parent.__str__() == '/a/b' for PurePosixPath('/a/b/c'), relative_to, anchor, parts[0]."
    - "pathlib.zspec.zsdl covers __str__ and as_posix for PurePosixPath('/etc/passwd')."
    - "Focus (new vectors): with_stem (Python 3.9+), is_relative_to (Python 3.9+), and __str__/as_posix on distinct paths not yet tested."
    - "PurePosixPath('/a/b/c.txt').with_stem('d') gives PurePosixPath('/a/b/d.txt'); str is '/a/b/d.txt'."
    - "PurePosixPath('/a/b/c.py').with_stem('main') gives PurePosixPath('/a/b/main.py'); str is '/a/b/main.py'."
    - "PurePosixPath('/a/b/c').is_relative_to('/a') == True (Python 3.9+)."
    - "PurePosixPath('/a/b/c').is_relative_to('/x') == False (Python 3.9+)."
    - "PurePosixPath('/a/b/c').is_relative_to('/a/b/c') == True — path is relative to itself."
    - "PurePosixPath('/usr/local/bin').as_posix() == '/usr/local/bin' — on a new distinct path."
    - "PurePosixPath('/usr/local/bin').__str__() == '/usr/local/bin' — same new path via __str__."
    - "PurePosixPath('/a/b/c.txt').with_suffix('.py').__str__() is covered in pathlib_extra8 — not duplicated here."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePosixPath.with_stem — Python 3.9+
#
# with_stem(name) replaces the final path component stem while keeping the
# suffix. This method was introduced in Python 3.9 and has not been tested
# in any prior pathlib spec.
# ---------------------------------------------------------------------------

invariant pathlib_extra10.PurePosixPath.with_stem_txt:
  description: "pathlib.PurePosixPath('/a/b/c.txt').with_stem('d').__str__() == '/a/b/d.txt'"
  category: with_stem
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c.txt"]
  method: with_stem.__func__.__name__.__eq__
  method_args: ["with_stem"]
  expected: true
  version: ">=3.9"

invariant pathlib_extra10.PurePosixPath.with_stem_result:
  description: "str(pathlib.PurePosixPath('/a/b/c.txt').with_stem('d')) == '/a/b/d.txt'"
  category: with_stem
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c.txt"]
  method: with_stem
  method_args: ["d"]
  expected: "/a/b/d.txt"
  version: ">=3.9"

invariant pathlib_extra10.PurePosixPath.with_stem_py:
  description: "str(pathlib.PurePosixPath('/a/b/c.py').with_stem('main')) == '/a/b/main.py'"
  category: with_stem
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c.py"]
  method: with_stem
  method_args: ["main"]
  expected: "/a/b/main.py"
  version: ">=3.9"

# ---------------------------------------------------------------------------
# PurePosixPath.is_relative_to — Python 3.9+
#
# is_relative_to(other) returns True if the path is relative to other.
# Introduced in Python 3.9. Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

invariant pathlib_extra10.PurePosixPath.is_relative_to_true:
  description: "pathlib.PurePosixPath('/a/b/c').is_relative_to('/a') == True"
  category: is_relative_to
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: is_relative_to
  method_args: ["/a"]
  expected: true
  version: ">=3.9"

invariant pathlib_extra10.PurePosixPath.is_relative_to_false:
  description: "pathlib.PurePosixPath('/a/b/c').is_relative_to('/x') == False"
  category: is_relative_to
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: is_relative_to
  method_args: ["/x"]
  expected: false
  version: ">=3.9"

invariant pathlib_extra10.PurePosixPath.is_relative_to_self:
  description: "pathlib.PurePosixPath('/a/b/c').is_relative_to('/a/b/c') == True — path is relative to itself"
  category: is_relative_to
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: is_relative_to
  method_args: ["/a/b/c"]
  expected: true
  version: ">=3.9"

# ---------------------------------------------------------------------------
# PurePosixPath.__str__ and as_posix on a new distinct path
#
# pathlib.zspec.zsdl covers '/etc/passwd'; this adds '/usr/local/bin'.
# ---------------------------------------------------------------------------

invariant pathlib_extra10.PurePosixPath.str_usr_local_bin:
  description: "str(pathlib.PurePosixPath('/usr/local/bin')) == '/usr/local/bin'"
  category: str_repr
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/local/bin"]
  method: __str__
  expected: "/usr/local/bin"

invariant pathlib_extra10.PurePosixPath.as_posix_usr_local_bin:
  description: "pathlib.PurePosixPath('/usr/local/bin').as_posix() == '/usr/local/bin'"
  category: str_repr
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/local/bin"]
  method: as_posix
  expected: "/usr/local/bin"

# ---------------------------------------------------------------------------
# PurePosixPath.with_name — new path not covered in prior specs
#
# pathlib_extra8 covers with_name method existence check but not value.
# We add a behavioral vector for a new distinct path.
# ---------------------------------------------------------------------------

invariant pathlib_extra10.PurePosixPath.with_name_result:
  description: "str(pathlib.PurePosixPath('/a/b/c.txt').with_name('e.md')) == '/a/b/e.md'"
  category: with_name
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c.txt"]
  method: with_name
  method_args: ["e.md"]
  expected: "/a/b/e.md"
