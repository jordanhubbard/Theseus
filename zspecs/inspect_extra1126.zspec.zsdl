spec: inspect_extra1126
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks inspect.__name__, inspect.__spec__.name, inspect.__doc__.__class__.__name__, ismodule/__doc__/__class__/__name__, isclass/__doc__/__class__/__name__, isfunction/__doc__/__class__/__name__, getmembers/__doc__/__class__/__name__, signature/__doc__/__class__/__name__ — not covered in _extra1096/_extra1111"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1126.module_name_spec_doc:
  description: "inspect module-level __name__, __spec__.name, and __doc__ class identity"
  kind: python_call_eq
  category: module_name_spec_doc
  id_prefix: ip1126mn
  columns: [id, function, args, expected]
  rows:
    - [ip1126mn001, inspect.__name__.__eq__,                                      ["inspect"],                          true]
    - [ip1126mn002, inspect.__spec__.name.__eq__,                                 ["inspect"],                          true]
    - [ip1126mn003, inspect.__doc__.__class__.__name__.__eq__,                    ["str"],                              true]
    - [ip1126mn004, inspect.ismodule.__doc__.__class__.__name__.__eq__,           ["str"],                              true]
    - [ip1126mn005, inspect.isclass.__doc__.__class__.__name__.__eq__,            ["str"],                              true]
    - [ip1126mn006, inspect.isfunction.__doc__.__class__.__name__.__eq__,         ["str"],                              true]
    - [ip1126mn007, inspect.getmembers.__doc__.__class__.__name__.__eq__,         ["str"],                              true]
    - [ip1126mn008, inspect.signature.__doc__.__class__.__name__.__eq__,          ["str"],                              true]

table inspect_extra1126.ismodule_isclass_qualnames:
  description: "inspect.ismodule, isclass qualname and module identity not covered in _extra1096"
  kind: python_call_eq
  category: ismodule_isclass_qualnames
  id_prefix: ip1126ic
  columns: [id, function, args, expected]
  rows:
    - [ip1126ic001, inspect.ismodule.__qualname__.__eq__,                         ["ismodule"],                         true]
    - [ip1126ic002, inspect.ismodule.__module__.__eq__,                           ["inspect"],                          true]
    - [ip1126ic003, inspect.ismodule.__class__.__name__.__eq__,                   ["function"],                         true]
    - [ip1126ic004, inspect.isclass.__qualname__.__eq__,                          ["isclass"],                          true]
    - [ip1126ic005, inspect.isclass.__module__.__eq__,                            ["inspect"],                          true]
    - [ip1126ic006, inspect.isfunction.__qualname__.__eq__,                       ["isfunction"],                       true]
    - [ip1126ic007, inspect.getmembers.__qualname__.__eq__,                       ["getmembers"],                       true]
    - [ip1126ic008, inspect.getmembers.__module__.__eq__,                         ["inspect"],                          true]

table inspect_extra1126.getmembers_signature_doc_class_identity:
  description: "inspect.getmembers, signature, isroutine, ismethod doc and module identity"
  kind: python_call_eq
  category: getmembers_signature_doc_class
  id_prefix: ip1126gs
  columns: [id, function, args, expected]
  rows:
    - [ip1126gs001, inspect.signature.__qualname__.__eq__,                        ["signature"],                        true]
    - [ip1126gs002, inspect.isroutine.__qualname__.__eq__,                        ["isroutine"],                        true]
    - [ip1126gs003, inspect.isroutine.__module__.__eq__,                          ["inspect"],                          true]
    - [ip1126gs004, inspect.isroutine.__doc__.__class__.__name__.__eq__,          ["str"],                              true]
    - [ip1126gs005, inspect.ismethod.__qualname__.__eq__,                         ["ismethod"],                         true]
    - [ip1126gs006, inspect.ismethod.__module__.__eq__,                           ["inspect"],                          true]
    - [ip1126gs007, inspect.ismethod.__doc__.__class__.__name__.__eq__,           ["str"],                              true]
    - [ip1126gs008, inspect.ismethod.__class__.__name__.__eq__,                   ["function"],                         true]
