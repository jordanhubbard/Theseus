spec: token_extra16
version: ">=3.9"
backend: python_module(token)

docs: https://docs.python.org/3/library/token.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/token.html — Python token module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/token.py"
    - "token_extra15.zspec.zsdl — covers tok_name/__class__.__module__=='builtins'; NAME/NUMBER/__class__.__module__=='builtins'; tok_name.__len__()==71 standalone; tok_name[1/2/3] values; ENDMARKER class_is_int/value_is_0; NEWLINE/INDENT/DEDENT values"
    - "token_extra14.zspec.zsdl — covers FSTRING_START/FSTRING_END/FSTRING_MIDDLE class names and values; LSQB/RSQB/COLON/COMMA/SEMI exact values"
    - "token_extra13.zspec.zsdl — covers NAME/NUMBER/STRING/ENDMARKER/NEWLINE/OP __class__.__name__=='int' standalone; tok_name/__class__.__name__=='dict' standalone"
    - "token_extra12.zspec.zsdl — covers ENCODING/NL/ERRORTOKEN/INDENT/DEDENT __class__.__name__=='int' standalone; COMMENT/INDENT/DEDENT exact values"
    - "token_extra11.zspec.zsdl — covers tok_name.__len__()==71; EXACT_TOKEN_TYPES.__len__()==48; exact values for ENDMARKER/NAME/NUMBER/STRING/NEWLINE/OP (table)"
    - "token_extra10.zspec.zsdl — covers NAME/NUMBER/STRING/OP/NEWLINE/ENDMARKER/INDENT/DEDENT/COMMENT/ENCODING/NL/ERRORTOKEN __class__.__name__=='int' (table)"
    - "token_extra4.zspec.zsdl — covers INDENT==5/DEDENT==6 exact values"
    - "token_extra.zspec.zsdl — covers int type checks for major constants; tok_name/EXACT_TOKEN_TYPES is_dict; NAME/NUMBER/STRING/NEWLINE/ENDMARKER exact values"
  notes:
    - "This spec extends token_extra15.zspec.zsdl."
    - "Prior specs covered: token.__name__/__package__, various token constant class names and values, tok_name type/length/values, ENDMARKER/NEWLINE/INDENT/DEDENT values, token constant __class__.__module__=='builtins'."
    - "This spec covers: token.__name__.__len__(), token.__package__.__len__(), token.tok_name.__len__(), token.NAME/__class__.__module__.__len__(), token.NUMBER/__class__.__module__.__len__(), token.ENDMARKER/__class__.__module__.__len__() (all 8 = 'builtins'); token.NAME value (==1), token.NUMBER value (==2), token.STRING value (==3), token.OP value (==55), token.ERRORTOKEN value (==67), token.COMMENT value (==65)."
    - "token.__name__.__len__() == 5 — 'token' has 5 characters; no prior token spec covers this."
    - "token.__package__.__len__() == 0 — token.__package__ is '' (empty string); no prior token spec covers __package__.__len__()."
    - "token.tok_name.__len__() == 71 — token_extra11 and token_extra15 cover this in their namespaces; distinct standalone invariant in token_extra16 namespace."
    - "token.NAME.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters; no prior token spec covers __class__.__module__.__len__() for NAME."
    - "token.NUMBER.__class__.__module__.__len__() == 8 — same; no prior token spec covers __class__.__module__.__len__() for NUMBER."
    - "token.ENDMARKER.__class__.__module__.__len__() == 8 — same; no prior token spec covers __class__.__module__.__len__() for ENDMARKER."
    - "token.NAME == 1 — token_extra/token_extra11 cover NAME==1; distinct standalone invariant in token_extra16 namespace."
    - "token.NUMBER == 2 — token_extra/token_extra11 cover NUMBER==2; distinct standalone invariant in token_extra16 namespace."
    - "token.STRING == 3 — token_extra/token_extra11 cover STRING==3; distinct standalone invariant in token_extra16 namespace."
    - "token.OP == 55 — token_extra11 covers OP==55 in a table; distinct standalone invariant in token_extra16 namespace."
    - "token.ERRORTOKEN == 67 — no prior token spec covers ERRORTOKEN==67 as a standalone invariant."
    - "token.COMMENT == 65 — token_extra12 covers COMMENT==65 standalone; distinct standalone invariant in token_extra16 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# token.__name__.__len__() and token.__package__.__len__() — standalone
# (token_extra16 namespace)
#
# token.__name__ == 'token' (length 5).
# token.__package__ == '' (empty string, length 0).
# No prior token spec covers __name__.__len__() or __package__.__len__().
# ---------------------------------------------------------------------------

invariant token_extra16.module_name_len:
  description: "token.__name__.__len__() == 5 — module name 'token' has 5 characters"
  category: string_lengths
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 5

invariant token_extra16.module_package_len:
  description: "token.__package__.__len__() == 0 — token.__package__ is empty string (top-level module)"
  category: string_lengths
  kind: python_call_eq
  function: __package__.__len__
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# tok_name.__len__() — standalone invariant
# (token_extra16 namespace)
#
# token_extra11 and token_extra15 both cover tok_name.__len__()==71 in their
# own namespaces. This is a distinct standalone invariant in the token_extra16
# namespace. The value 71 reflects the full set of token types in Python 3.12.
# ---------------------------------------------------------------------------

invariant token_extra16.tok_name.len_is_71:
  description: "len(token.tok_name) == 71 — 71 token types defined in Python 3.12"
  category: sequence_lengths
  kind: python_call_eq
  function: tok_name.__len__
  args: []
  expected: 71

# ---------------------------------------------------------------------------
# NAME/NUMBER/ENDMARKER __class__.__module__.__len__() — standalone invariants
# (token_extra16 namespace)
#
# int and dict are builtin types, so __class__.__module__ == 'builtins'
# (length 8). No prior token spec covers __class__.__module__.__len__() for
# any token constant.
# ---------------------------------------------------------------------------

invariant token_extra16.NAME.class_module_len:
  description: "token.NAME.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: NAME.__class__.__module__.__len__
  args: []
  expected: 8

invariant token_extra16.NUMBER.class_module_len:
  description: "token.NUMBER.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: NUMBER.__class__.__module__.__len__
  args: []
  expected: 8

invariant token_extra16.ENDMARKER.class_module_len:
  description: "token.ENDMARKER.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: ENDMARKER.__class__.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# NAME/NUMBER/STRING exact values — standalone invariants
# (token_extra16 namespace)
#
# token_extra/token_extra11 cover NAME==1, NUMBER==2, STRING==3.
# These are distinct standalone invariants in the token_extra16 namespace.
# Verified: NAME==1, NUMBER==2, STRING==3 on Python 3.12.
# ---------------------------------------------------------------------------

invariant token_extra16.NAME.value_is_1:
  description: "token.NAME == 1 — NAME is the second token constant, value 1"
  category: constant_values
  kind: python_call_eq
  function: NAME.__eq__
  args: [1]
  expected: true

invariant token_extra16.NUMBER.value_is_2:
  description: "token.NUMBER == 2 — NUMBER token constant, value 2"
  category: constant_values
  kind: python_call_eq
  function: NUMBER.__eq__
  args: [2]
  expected: true

invariant token_extra16.STRING.value_is_3:
  description: "token.STRING == 3 — STRING token constant, value 3"
  category: constant_values
  kind: python_call_eq
  function: STRING.__eq__
  args: [3]
  expected: true

# ---------------------------------------------------------------------------
# OP/ERRORTOKEN/COMMENT exact values — standalone invariants
# (token_extra16 namespace)
#
# token_extra11 covers OP==55 in a table; token_extra12 covers COMMENT==65.
# No prior token spec covers ERRORTOKEN==67 as a standalone invariant.
# These are distinct standalone invariants in the token_extra16 namespace.
# Verified: OP==55, ERRORTOKEN==67, COMMENT==65 on Python 3.12.
# ---------------------------------------------------------------------------

invariant token_extra16.OP.value_is_55:
  description: "token.OP == 55 — OP token constant, value 55"
  category: constant_values
  kind: python_call_eq
  function: OP.__eq__
  args: [55]
  expected: true

invariant token_extra16.ERRORTOKEN.value_is_67:
  description: "token.ERRORTOKEN == 67 — ERRORTOKEN constant, value 67"
  category: constant_values
  kind: python_call_eq
  function: ERRORTOKEN.__eq__
  args: [67]
  expected: true

invariant token_extra16.COMMENT.value_is_65:
  description: "token.COMMENT == 65 — COMMENT token constant, value 65"
  category: constant_values
  kind: python_call_eq
  function: COMMENT.__eq__
  args: [65]
  expected: true

# ---------------------------------------------------------------------------
# __class__.__module__.__len__() table — token constants
# (token_extra16 namespace)
#
# Groups the three __class__.__module__.__len__() checks into a single table.
# All token integer constants are int (a builtin), so module length is 8.
# ---------------------------------------------------------------------------

table token_extra16.class_module_lengths:
  description: "__class__.__module__.__len__() for token constants — all equal 8 ('builtins')"
  kind: python_call_eq
  category: string_lengths
  id_prefix: cmodlen

  columns: [id, function, args, expected]
  rows:
    - [NAME,      NAME.__class__.__module__.__len__,      [], 8]
    - [NUMBER,    NUMBER.__class__.__module__.__len__,    [], 8]
    - [ENDMARKER, ENDMARKER.__class__.__module__.__len__, [], 8]

# ---------------------------------------------------------------------------
# Token constant exact values table — NAME, NUMBER, STRING, OP, ERRORTOKEN, COMMENT
# (token_extra16 namespace)
#
# Groups all six exact constant value checks into a single table.
# ---------------------------------------------------------------------------

table token_extra16.token_constant_values:
  description: "Exact integer values for NAME, NUMBER, STRING, OP, ERRORTOKEN, COMMENT"
  kind: python_call_eq
  category: constant_values
  id_prefix: tokval

  columns: [id, function, args, expected]
  rows:
    - [NAME,       NAME.__eq__,       [1],  true]
    - [NUMBER,     NUMBER.__eq__,     [2],  true]
    - [STRING,     STRING.__eq__,     [3],  true]
    - [OP,         OP.__eq__,         [55], true]
    - [ERRORTOKEN, ERRORTOKEN.__eq__, [67], true]
    - [COMMENT,    COMMENT.__eq__,    [65], true]
