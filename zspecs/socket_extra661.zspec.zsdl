spec: socket_extra661
backend: python_module(socket)
description: "socket module constant class name identity for IPPROTO/SOL constants and socket method qualnames"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module constants and socket class methods"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers IPPROTO and SOL_SOCKET constant class names, and recv/send method qualnames on socket.socket"]
  created_at: "2026-04-12T00:00:00Z"

table socket_extra661.ipproto_sol_class_names:
  description: "Class names of IPPROTO and SOL socket constants"
  kind: python_call_eq
  category: constant_identity
  id_prefix: sk661cln
  columns: [id, function, args, expected]
  rows:
    - [sk661cln001, socket.IPPROTO_TCP.__class__.__name__.__eq__, ["int"], true]
    - [sk661cln002, socket.IPPROTO_UDP.__class__.__name__.__eq__, ["int"], true]
    - [sk661cln003, socket.IPPROTO_IP.__class__.__name__.__eq__, ["int"], true]
    - [sk661cln004, socket.SOL_SOCKET.__class__.__name__.__eq__, ["int"], true]
    - [sk661cln005, socket.SO_REUSEADDR.__class__.__name__.__eq__, ["int"], true]
    - [sk661cln006, socket.SO_KEEPALIVE.__class__.__name__.__eq__, ["int"], true]
    - [sk661cln007, socket.SOMAXCONN.__class__.__name__.__eq__, ["int"], true]

table socket_extra661.socket_method_qualnames:
  description: "Qualified names of socket.socket recv/send methods"
  kind: python_call_eq
  category: method_qualname
  id_prefix: sk661mqn
  columns: [id, function, args, expected]
  rows:
    - [sk661mqn001, socket.socket.recv_into.__qualname__.__eq__, ["socket.recv_into"], true]
    - [sk661mqn002, socket.socket.sendall.__qualname__.__eq__, ["socket.sendall"], true]
    - [sk661mqn003, socket.socket.recvfrom.__qualname__.__eq__, ["socket.recvfrom"], true]
    - [sk661mqn004, socket.socket.sendto.__qualname__.__eq__, ["socket.sendto"], true]
    - [sk661mqn005, socket.socket.recvmsg.__qualname__.__eq__, ["socket.recvmsg"], true]
