spec: asyncio_extra1261
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio.__all__ membership checks via __contains__; __all__ type verification"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 531 (_extra1261): __all__ membership checks — asyncio.__all__ is a tuple (not list); verified Python 3.14.3."
    - "asyncio.__all__.__contains__('Queue') == True — Queue is in asyncio.__all__; verified Python 3.14.3."
    - "asyncio.__all__.__contains__('Thread') == False — Thread is NOT in asyncio.__all__; Thread belongs to threading, not asyncio; verified Python 3.14.3."
    - "asyncio.__all__.__class__.__name__ == 'tuple' — asyncio.__all__ is a tuple, unlike most stdlib modules which use list; verified Python 3.14.3."
    - "Distinct from extra1246 (__doc__ class checks), extra1231 (__dict__.__contains__), extra1216 (__mro__.__len__), extra1201 (__bases__/__mro__ lengths)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra1261.all_contains_in:
  description: "asyncio.__all__.__contains__ returns true for names that ARE in __all__: Queue, Task, Future, Lock, Event, Semaphore, run, sleep, gather, wait_for, create_task, shield, wait"
  kind: python_call_eq
  category: all_membership
  id_prefix: as1261in
  columns: [id, function, args, expected]
  rows:
    - [as1261in001, asyncio.__all__.__contains__, ["Queue"],       true]
    - [as1261in002, asyncio.__all__.__contains__, ["Task"],        true]
    - [as1261in003, asyncio.__all__.__contains__, ["Future"],      true]
    - [as1261in004, asyncio.__all__.__contains__, ["Lock"],        true]
    - [as1261in005, asyncio.__all__.__contains__, ["Event"],       true]
    - [as1261in006, asyncio.__all__.__contains__, ["Semaphore"],   true]
    - [as1261in007, asyncio.__all__.__contains__, ["run"],         true]
    - [as1261in008, asyncio.__all__.__contains__, ["sleep"],       true]
    - [as1261in009, asyncio.__all__.__contains__, ["gather"],      true]
    - [as1261in010, asyncio.__all__.__contains__, ["wait_for"],    true]
    - [as1261in011, asyncio.__all__.__contains__, ["create_task"], true]
    - [as1261in012, asyncio.__all__.__contains__, ["shield"],      true]
    - [as1261in013, asyncio.__all__.__contains__, ["wait"],        true]

table asyncio_extra1261.all_contains_not_in:
  description: "asyncio.__all__.__contains__ returns false for names NOT in __all__: Thread, Process, Executor, Pool, socket, subprocess, selector"
  kind: python_call_eq
  category: all_membership
  id_prefix: as1261ni
  columns: [id, function, args, expected]
  rows:
    - [as1261ni001, asyncio.__all__.__contains__, ["Thread"],     false]
    - [as1261ni002, asyncio.__all__.__contains__, ["Process"],    false]
    - [as1261ni003, asyncio.__all__.__contains__, ["Executor"],   false]
    - [as1261ni004, asyncio.__all__.__contains__, ["Pool"],       false]
    - [as1261ni005, asyncio.__all__.__contains__, ["socket"],     false]
    - [as1261ni006, asyncio.__all__.__contains__, ["subprocess"], false]
    - [as1261ni007, asyncio.__all__.__contains__, ["selector"],   false]

table asyncio_extra1261.all_type_is_tuple:
  description: "asyncio.__all__.__class__.__name__ is 'tuple' — asyncio uses a tuple for __all__, not a list; cross-checks against 'list', 'set', 'dict'"
  kind: python_call_eq
  category: all_type
  id_prefix: as1261ty
  columns: [id, function, args, expected]
  rows:
    - [as1261ty001, asyncio.__all__.__class__.__name__.__eq__, ["tuple"], true]
    - [as1261ty002, asyncio.__all__.__class__.__name__.__eq__, ["list"],  false]
    - [as1261ty003, asyncio.__all__.__class__.__name__.__eq__, ["set"],   false]
    - [as1261ty004, asyncio.__all__.__class__.__name__.__eq__, ["dict"],  false]
    - [as1261ty005, asyncio.__all__.__class__.__name__.__eq__, ["str"],   false]
    - [as1261ty006, asyncio.__all__.__class__.__name__.__eq__, ["int"],   false]
