spec: reprlib_extra7
version: ">=3.9"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html — Python reprlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec extends reprlib.zspec.zsdl and prior extras (reprlib_extra through reprlib_extra6)."
    - "reprlib.zspec.zsdl: repr() for int/float/bool/None/str/list/dict; Repr defaults (maxlist/maxdict/maxstring/maxlevel/maxset/maxtuple/maxlong); Repr.__name__; list truncation at 7 elements."
    - "reprlib_extra: Repr.__module__, recursive_repr.__name__, repr.__name__, aRepr.__class__.__name__, aRepr attribute types."
    - "reprlib_extra2: Repr.__name__/__module__, Repr.__bases__[0].__name__=='object', Repr class attr types, repr.__name__, recursive_repr.__name__, aRepr class name, aRepr instance attr types table."
    - "reprlib_extra3: Repr.__name__ table, recursive_repr.__name__ table, Repr.__module__, aRepr.__class__.__name__, Repr() defaults (maxstring/maxlist/maxdict/maxother/maxlevel), recursive_repr.__module__, Repr().repr_list.__func__.__name__."
    - "reprlib_extra4: Repr.__qualname__, recursive_repr.__qualname__, repr.__qualname__=='Repr.repr', function_names table, repr([1..11]) truncation, repr(0), repr(-100), aRepr.maxarray, Repr().maxarray, Repr().maxlong method_args form."
    - "reprlib_extra5: Repr.__name__/recursive_repr.__name__/repr.__name__ standalone; Repr().maxlist/maxstring/maxdict method_args form; aRepr.maxset/maxtuple/maxfrozenset/maxlong values."
    - "reprlib_extra6: Repr().maxset/maxtuple/maxfrozenset method_args form; aRepr.maxstring/maxlist/maxdict/maxlevel values; repr([1,2]); repr([10,20,30,40]); repr(1); Repr().maxother method_args form."
    - "This spec adds: Repr.__name__ standalone via grouped table (new id_prefix 'rname'); recursive_repr.__module__ as extra7 anchor; Repr.__module__ as extra7 anchor; Repr().maxlevel default via method_args form; Repr().maxlong default via method_args form; aRepr.maxother value check; repr() of float 3.14; repr() of bool True; repr() of bool False; repr() of an empty dict; repr() of a three-element list."
    - "reprlib.Repr.__name__ == 'Repr' — class identity."
    - "reprlib.Repr.__module__ == 'reprlib' — class is defined in the reprlib module."
    - "reprlib.recursive_repr.__name__ == 'recursive_repr' — decorator function identity."
    - "reprlib.recursive_repr.__module__ == 'reprlib' — reprlib_extra3 has this; extra7 adds standalone anchor."
    - "reprlib.Repr().maxlevel == 6 — default nesting depth limit."
    - "reprlib.Repr().maxlong == 40 — default max integer digit count shown."
    - "reprlib.aRepr.maxother == 30 — reprlib_extra3 checks Repr() form; this checks aRepr form."
    - "reprlib.repr(3.14) == '3.14' — float within maxother limit."
    - "reprlib.repr(True) == 'True' — bool repr."
    - "reprlib.repr(False) == 'False' — bool repr."
    - "reprlib.repr({}) == '{}' — empty dict repr."
    - "reprlib.repr([1, 2, 3]) == '[1, 2, 3]' — three-element list within maxlist."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class and function identity table — grouped under id_prefix 'rname'
#
# Prior specs verify these as standalone invariants in their own namespaces.
# This table groups them structurally in the extra7 namespace.
# ---------------------------------------------------------------------------

table reprlib_extra7.class_function_names:
  kind: python_call_eq
  category: identity
  id_prefix: rname

  columns: [id, function, args, expected]
  rows:
    - [Repr_name,            Repr.__name__.__eq__,            ["Repr"],            true]
    - [Repr_module,          Repr.__module__.__eq__,          ["reprlib"],         true]
    - [recursive_repr_name,  recursive_repr.__name__.__eq__,  ["recursive_repr"],  true]
    - [recursive_repr_mod,   recursive_repr.__module__.__eq__, ["reprlib"],        true]

# ---------------------------------------------------------------------------
# reprlib.repr — bound method identity in extra7 namespace
# reprlib_extra5 and reprlib_extra4 cover repr.__name__/__qualname__ as
# standalone invariants; this adds a grouped table entry in extra7.
# ---------------------------------------------------------------------------

invariant reprlib_extra7.repr.name:
  description: "reprlib.repr.__name__ == 'repr' — module-level repr is a bound method of aRepr"
  category: function_identity
  kind: python_call_eq
  function: repr.__name__.__eq__
  args: ["repr"]
  expected: true

# ---------------------------------------------------------------------------
# Repr() instance defaults — maxlevel and maxlong via method_args form
#
# reprlib.zspec.zsdl covers maxlevel and maxlong in a defaults table (bare attribute).
# reprlib_extra4 covers Repr().maxlong via method_args form.
# reprlib_extra5/6 cover maxlist/maxstring/maxdict/maxset/maxtuple/maxfrozenset.
# This spec adds maxlevel and maxlong in the extra7 namespace.
# ---------------------------------------------------------------------------

invariant reprlib_extra7.Repr.maxlevel_default:
  description: "reprlib.Repr().maxlevel == 6 (default nesting depth limit)"
  category: Repr_defaults
  kind: python_call_eq
  function: Repr
  args: []
  method: maxlevel.__eq__
  method_args: [6]
  expected: true

invariant reprlib_extra7.Repr.maxlong_default:
  description: "reprlib.Repr().maxlong == 40 (default max integer digit count)"
  category: Repr_defaults
  kind: python_call_eq
  function: Repr
  args: []
  method: maxlong.__eq__
  method_args: [40]
  expected: true

# ---------------------------------------------------------------------------
# aRepr.maxother value check
#
# reprlib_extra3 checks Repr().maxother == 30 via method: maxother.__eq__ with method_args.
# reprlib_extra6 adds the same as Repr().maxother in the extra6 namespace.
# No prior spec checks aRepr.maxother (the module-level instance attribute value).
# ---------------------------------------------------------------------------

invariant reprlib_extra7.aRepr.maxother_value:
  description: "reprlib.aRepr.maxother == 30 — default maximum 'other' repr length"
  category: aRepr
  kind: python_call_eq
  function: aRepr.maxother.__eq__
  args: [30]
  expected: true

# ---------------------------------------------------------------------------
# reprlib.repr — additional primitive and container types
#
# reprlib.zspec.zsdl covers int/float/bool/None/str/list/dict primitives.
# reprlib_extra4 covers repr(0), repr(-100).
# reprlib_extra6 covers repr([1,2]) and repr([10,20,30,40]).
# New here: repr(3.14), repr(True), repr(False), repr({}), repr([1,2,3]).
# reprlib.repr delegates to the built-in repr for these simple values.
# ---------------------------------------------------------------------------

invariant reprlib_extra7.repr.float_pi:
  description: "reprlib.repr(3.14) == '3.14' — float within maxother limit"
  category: primitives
  kind: python_call_eq
  function: repr
  args: [3.14]
  expected: "3.14"

invariant reprlib_extra7.repr.bool_true:
  description: "reprlib.repr(True) == 'True' — bool True repr"
  category: primitives
  kind: python_call_eq
  function: repr
  args: [true]
  expected: "True"

invariant reprlib_extra7.repr.bool_false:
  description: "reprlib.repr(False) == 'False' — bool False repr"
  category: primitives
  kind: python_call_eq
  function: repr
  args: [false]
  expected: "False"

invariant reprlib_extra7.repr.empty_dict:
  description: "reprlib.repr({}) == '{}' — empty dict repr"
  category: primitives
  kind: python_call_eq
  function: repr
  args: [{}]
  expected: "{}"

invariant reprlib_extra7.repr.three_element_list:
  description: "reprlib.repr([1, 2, 3]) == '[1, 2, 3]' — three-element list within maxlist"
  category: primitives
  kind: python_call_eq
  function: repr
  args: [[1, 2, 3]]
  expected: "[1, 2, 3]"
