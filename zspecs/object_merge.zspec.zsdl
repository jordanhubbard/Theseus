spec: object_merge
version: ">=2.5.1"
backend: node(object-merge)

docs: https://www.npmjs.com/package/object-merge

provenance:
  derived_from:
    - "object-merge README — https://www.npmjs.com/package/object-merge"
    - "Test vectors verified with object-merge via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "object-merge source"
  notes:
    - "object-merge is an npm package. Install: npm install object-merge"
    - "Merges multiple objects. Later arguments win on key conflicts."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a merged object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table object_merge.merge:
  kind: node_module_call_eq
  function: ~
  category: object
  id_prefix: omerge

  columns: [id, args, expected]
  rows:
    - [disjoint,   [{"a": 1}, {"b": 2}],          {"a": 1, "b": 2}]
    - [override,   [{"a": 1}, {"a": 2, "b": 3}],  {"a": 2, "b": 3}]
    - [three,      [{"x": 1}, {"y": 2}, {"z": 3}], {"x": 1, "y": 2, "z": 3}]
