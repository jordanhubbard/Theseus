spec: asyncio_extra229
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Futures documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "asyncio.Task.__name__ == 'Task' — 4 characters; C accelerator class (_asyncio); verified with Python 3.14.3."
    - "asyncio.Future.__name__ == 'Future' — 6 characters; C accelerator class (_asyncio); verified with Python 3.14.3."
    - "asyncio.Task.__module__ == '_asyncio' — Task is implemented in the C accelerator module; verified with Python 3.14.3."
    - "asyncio.Future.__module__ == '_asyncio' — Future is implemented in the C accelerator module; verified with Python 3.14.3."
    - "asyncio.Lock.__name__ == 'Lock' — 4 characters; module is asyncio.locks; verified with Python 3.14.3."
    - "asyncio.Event.__name__ == 'Event' — 5 characters; module is asyncio.locks; verified with Python 3.14.3."
    - "asyncio.Condition.__name__ == 'Condition' — 9 characters; module is asyncio.locks; verified with Python 3.14.3."
    - "asyncio.Semaphore.__name__.__len__() == 9 — 'Semaphore' has 9 characters; verified with Python 3.14.3."
    - "asyncio.BoundedSemaphore.__name__.__len__() == 16 — 'BoundedSemaphore' has 16 characters; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Task and Future class __name__ length contracts — extra229 namespace
#
# Task.__name__ == 'Task' (4 chars); Future.__name__ == 'Future' (6 chars).
# Both are C-accelerated classes from _asyncio module.
# ---------------------------------------------------------------------------

table asyncio_extra229.task_future_name_lengths:
  description: "asyncio Task and Future __name__ length contracts in aio229tf namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio229tf

  columns: [id, function, args, expected, description]
  rows:
    - [task_name_eq,         Task.__name__.__eq__,           ["Task"],   true, "asyncio.Task.__name__ == 'Task'; verified with Python 3.14.3"]
    - [task_name_len_4,      Task.__name__.__len__,          [],         4,    "asyncio.Task.__name__.__len__() == 4 — 'Task' has 4 characters; verified with Python 3.14.3"]
    - [future_name_eq,       Future.__name__.__eq__,         ["Future"], true, "asyncio.Future.__name__ == 'Future'; verified with Python 3.14.3"]
    - [future_name_len_6,    Future.__name__.__len__,        [],         6,    "asyncio.Future.__name__.__len__() == 6 — 'Future' has 6 characters; verified with Python 3.14.3"]
    - [task_module_eq,       Task.__module__.__eq__,         ["_asyncio"], true, "asyncio.Task.__module__ == '_asyncio' — C accelerator module; verified with Python 3.14.3"]
    - [future_module_eq,     Future.__module__.__eq__,       ["_asyncio"], true, "asyncio.Future.__module__ == '_asyncio' — C accelerator module; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio synchronization primitive __name__ contracts — extra229 namespace
#
# Lock, Event, Condition live in asyncio.locks; Semaphore/BoundedSemaphore length checks.
# ---------------------------------------------------------------------------

table asyncio_extra229.sync_name_contracts:
  description: "asyncio synchronization primitive __name__ and __module__ contracts in aio229sync namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio229sync

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_eq,        Lock.__name__.__eq__,             ["Lock"],      true, "asyncio.Lock.__name__ == 'Lock'; verified with Python 3.14.3"]
    - [lock_module_eq,      Lock.__module__.__eq__,           ["asyncio.locks"], true, "asyncio.Lock.__module__ == 'asyncio.locks'; verified with Python 3.14.3"]
    - [event_name_eq,       Event.__name__.__eq__,            ["Event"],     true, "asyncio.Event.__name__ == 'Event'; verified with Python 3.14.3"]
    - [event_module_eq,     Event.__module__.__eq__,          ["asyncio.locks"], true, "asyncio.Event.__module__ == 'asyncio.locks'; verified with Python 3.14.3"]
    - [condition_name_eq,   Condition.__name__.__eq__,        ["Condition"], true, "asyncio.Condition.__name__ == 'Condition'; verified with Python 3.14.3"]
    - [sem_name_len_9,      Semaphore.__name__.__len__,       [],            9,    "asyncio.Semaphore.__name__.__len__() == 9 — 'Semaphore' has 9 characters; verified with Python 3.14.3"]
    - [bsem_name_len_16,    BoundedSemaphore.__name__.__len__, [],           16,   "asyncio.BoundedSemaphore.__name__.__len__() == 16 — 'BoundedSemaphore' has 16 characters; verified with Python 3.14.3"]
