spec: uuid_extra9
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra.zspec.zsdl — covers UUID.__name__/__module__, uuid1/3/4/5 __name__ (table), uuid4 return type/version, NAMESPACE_* class names (table), UUID int/hex attribute types"
    - "uuid_extra2.zspec.zsdl — covers uuid1/3/4/5 __name__ standalone, NAMESPACE_* class names standalone, RESERVED_*/RFC_4122 values and type table"
    - "uuid_extra3.zspec.zsdl — covers uuid1/3/4/5 __module__, UUID.__bases__[0].__name__, uuid4 version/class standalone, UUID(int=0).version is None, NAMESPACE_* class names standalone"
    - "uuid_extra4.zspec.zsdl — covers NAMESPACE_* class names (table), uuid4 version, uuid4 class name, uuid4 hex len, uuid5/__name__, uuid3/__name__, UUID str format, UUID int type, NAMESPACE_DNS str repr"
    - "uuid_extra5.zspec.zsdl — covers __qualname__ for UUID class and uuid1/3/4/5 functions (table), UUID instance class name via fixed literal"
    - "uuid_extra6.zspec.zsdl — covers RESERVED_*/RFC_4122 __class__.__name__ (table), UUID.bytes/__class__/__name__, UUID.bytes_le/__class__/__name__, UUID.fields/__class__/__name__, UUID.fields.__len__() == 6"
    - "uuid_extra7.zspec.zsdl — covers SafeUUID class metadata (__name__/__module__/__qualname__/safe.value/unsafe.value/__bases__[0]), NAMESPACE_* .version table (all == 1), uuid1/uuid4 return class name and version"
    - "uuid_extra8.zspec.zsdl — covers UUID.__bases__.__len__()==1, NAMESPACE_DNS.int/__class__/__name__, NAMESPACE_URL.int/__class__/__name__, NAMESPACE_DNS.bytes/__class__/__name__, UUID/__doc__/__class__/__name__, uuid1/__doc__/__class__/__name__, uuid4/__doc__/__class__/__name__"
  notes:
    - "This spec extends the uuid chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: uuid3/__doc__ and uuid5/__doc__ type checks (extra8 covers UUID/uuid1/uuid4 __doc__ but not uuid3 or uuid5); NAMESPACE_URL.bytes and NAMESPACE_DNS.bytes_le type checks (extra8 covers NAMESPACE_DNS.bytes and NAMESPACE_URL.int but not URL.bytes or DNS.bytes_le); NAMESPACE_OID/NAMESPACE_X500 .int and .bytes type checks (extra8 covers only DNS and URL for these attributes); SafeUUID.__bases__.__len__()==1 (extra7 covers __bases__[0].__name__ but not tuple length); NAMESPACE_OID/NAMESPACE_X500 .fields.__len__()==6 (extra6 covers fields for a generic UUID, not for named namespace constants)."
    - "uuid.uuid3.__doc__.__class__.__name__ == 'str' — uuid3 has a docstring; extra8 covers uuid1 and uuid4 but not uuid3 or uuid5."
    - "uuid.uuid5.__doc__.__class__.__name__ == 'str' — uuid5 has a docstring; same gap as uuid3."
    - "uuid.NAMESPACE_URL.bytes.__class__.__name__ == 'bytes' — extra8 covers NAMESPACE_DNS.bytes; NAMESPACE_URL.bytes is a new vector."
    - "uuid.NAMESPACE_DNS.bytes_le.__class__.__name__ == 'bytes' — extra8 covers NAMESPACE_DNS.bytes but not NAMESPACE_DNS.bytes_le."
    - "uuid.NAMESPACE_OID.int.__class__.__name__ == 'int' — extra8 covers NAMESPACE_DNS.int and NAMESPACE_URL.int but not OID or X500."
    - "uuid.NAMESPACE_X500.int.__class__.__name__ == 'int' — same gap as OID."
    - "uuid.NAMESPACE_OID.bytes.__class__.__name__ == 'bytes' — neither OID nor X500 .bytes is covered in any prior spec."
    - "uuid.SafeUUID.__bases__.__len__() == 1 — extra7 verifies __bases__[0].__name__ but not the tuple length."
    - "uuid.NAMESPACE_OID.fields.__len__() == 6 — extra6 checks this for a generic fixed UUID; no prior spec checks fields length for the predefined namespace constants."
    - "uuid.NAMESPACE_X500.fields.__len__() == 6 — same gap as OID."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid3 and uuid5 __doc__ type checks.
# uuid_extra8 covers UUID.__doc__, uuid1.__doc__, and uuid4.__doc__ as a table.
# No prior spec checks uuid3.__doc__ or uuid5.__doc__.
# Both have non-None docstrings; their type is str.
# ---------------------------------------------------------------------------

table uuid_extra9.doc_class_names:
  kind: python_call_eq
  category: docstrings
  id_prefix: doc9

  columns: [id, function, args, expected]
  rows:
    - [uuid3, uuid3.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uuid5, uuid5.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# NAMESPACE_URL.bytes and NAMESPACE_DNS.bytes_le type checks.
# uuid_extra8 verifies NAMESPACE_DNS.bytes.__class__.__name__ == 'bytes' and
# NAMESPACE_URL.int.__class__.__name__ == 'int'.
# NAMESPACE_URL.bytes and NAMESPACE_DNS.bytes_le are new vectors.
# ---------------------------------------------------------------------------

invariant uuid_extra9.NAMESPACE_URL.bytes_class:
  description: "uuid.NAMESPACE_URL.bytes.__class__.__name__ == 'bytes' — NAMESPACE_URL.bytes is a 16-byte bytes object"
  category: namespace_attributes
  kind: python_call_eq
  function: NAMESPACE_URL.bytes.__class__.__name__.__eq__
  args: ["bytes"]
  expected: true

invariant uuid_extra9.NAMESPACE_DNS.bytes_le_class:
  description: "uuid.NAMESPACE_DNS.bytes_le.__class__.__name__ == 'bytes' — NAMESPACE_DNS.bytes_le is a 16-byte bytes object in little-endian layout"
  category: namespace_attributes
  kind: python_call_eq
  function: NAMESPACE_DNS.bytes_le.__class__.__name__.__eq__
  args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# NAMESPACE_OID and NAMESPACE_X500 .int and .bytes type checks.
# uuid_extra8 covers NAMESPACE_DNS.int and NAMESPACE_URL.int.
# No prior spec checks these attributes on NAMESPACE_OID or NAMESPACE_X500.
# ---------------------------------------------------------------------------

table uuid_extra9.oid_x500_int_class:
  kind: python_call_eq
  category: namespace_attributes
  id_prefix: nsintcls9

  columns: [id, function, args, expected]
  rows:
    - [NAMESPACE_OID,  NAMESPACE_OID.int.__class__.__name__.__eq__,  ["int"], true]
    - [NAMESPACE_X500, NAMESPACE_X500.int.__class__.__name__.__eq__, ["int"], true]

invariant uuid_extra9.NAMESPACE_OID.bytes_class:
  description: "uuid.NAMESPACE_OID.bytes.__class__.__name__ == 'bytes' — NAMESPACE_OID.bytes is a 16-byte bytes object"
  category: namespace_attributes
  kind: python_call_eq
  function: NAMESPACE_OID.bytes.__class__.__name__.__eq__
  args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# SafeUUID.__bases__.__len__() == 1 — single-inheritance confirmation.
# uuid_extra7 verifies SafeUUID.__bases__[0].__name__ but not the tuple length.
# ---------------------------------------------------------------------------

invariant uuid_extra9.SafeUUID.bases_len:
  description: "uuid.SafeUUID.__bases__.__len__() == 1 — SafeUUID has exactly one direct base class"
  category: SafeUUID
  kind: python_call_eq
  function: SafeUUID.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# NAMESPACE_OID and NAMESPACE_X500 .fields.__len__() == 6.
# uuid_extra6 checks UUID.fields.__len__() == 6 for a generic UUID instance.
# No prior spec checks .fields length for the predefined namespace constants.
# All UUID instances have exactly 6 fields (time_low, time_mid, time_hi_version,
# clock_seq_hi_variant, clock_seq_low, node) per RFC 4122.
# ---------------------------------------------------------------------------

table uuid_extra9.namespace_fields_len:
  kind: python_call_eq
  category: namespace_attributes
  id_prefix: nsfld9

  columns: [id, function, args, expected]
  rows:
    - [NAMESPACE_OID,  NAMESPACE_OID.fields.__len__,  [], 6]
    - [NAMESPACE_X500, NAMESPACE_X500.fields.__len__, [], 6]
