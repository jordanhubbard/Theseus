spec: inspect_extra184
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getsource, getsourcelines, getsourcefile function identity — inspect.getsource.__name__=='getsource' (len=9); inspect.getsource.__module__=='inspect'; inspect.getsource.__qualname__=='getsource'; inspect.getsource.__class__.__name__=='function'; inspect.getsourcelines.__name__=='getsourcelines' (len=14); inspect.getsourcefile.__name__=='getsourcefile' (len=13); inspect.getfile.__name__=='getfile' (len=7); inspect.getmodule.__name__=='getmodule' (len=9); inspect.getdoc.__name__=='getdoc' (len=6)."
    - "inspect.getsource.__name__ == 'getsource' — getsource is a pure-Python function in Lib/inspect.py that returns the text of the source code for an object; its __name__ is 'getsource', 9 characters. Verified with Python 3.14.3."
    - "inspect.getsource.__module__ == 'inspect' — getsource is defined in the pure-Python inspect module Lib/inspect.py; its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.getsource.__qualname__ == 'getsource' — getsource is a module-level function (not nested), so __qualname__ equals __name__ 'getsource'. Verified with Python 3.14.3."
    - "inspect.getsource.__class__.__name__ == 'function' — getsource is a regular Python function, so type(getsource).__name__ is 'function'. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__name__ == 'getsourcelines' — getsourcelines returns a list of source code lines and the line number of the first line; its __name__ is 'getsourcelines', 14 characters. Verified with Python 3.14.3."
    - "inspect.getsourcefile.__name__ == 'getsourcefile' — getsourcefile returns the Python source file for an object; its __name__ is 'getsourcefile', 13 characters. Verified with Python 3.14.3."
    - "inspect.getfile.__name__ == 'getfile' — getfile returns the file in which an object was defined; its __name__ is 'getfile', 7 characters. Verified with Python 3.14.3."
    - "inspect.getmodule.__name__ == 'getmodule' — getmodule tries to guess the module where an object was defined; its __name__ is 'getmodule', 9 characters. Verified with Python 3.14.3."
    - "inspect.getdoc.__name__ == 'getdoc' — getdoc returns the docstring for an object cleaned up with cleandoc; its __name__ is 'getdoc', 6 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getsource __name__, __module__, __qualname__
#
# inspect.getsource.__name__ == 'getsource'
# inspect.getsource.__name__.__len__() == 9
# inspect.getsource.__module__ == 'inspect'
# inspect.getsource.__qualname__ == 'getsource'
#
# getsource is a pure-Python function in Lib/inspect.py that returns the text
# of the source code for an object (module, class, method, function, traceback,
# frame, or code object). Its __name__ is 'getsource' (9 chars) and __module__
# is 'inspect'. New to extra184.
# ---------------------------------------------------------------------------

table inspect_extra184.getsource_identity:
  description: "inspect.getsource.__name__=='getsource' len 9; __module__=='inspect'; __qualname__=='getsource'; new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgetsource184

  columns: [id, function, args, expected, description]
  rows:
    - [getsource_name_eq,
       getsource.__name__.__eq__,
       ["getsource"],
       true,
       "inspect.getsource.__name__.__eq__('getsource') == True — getsource is a pure-Python function in Lib/inspect.py that returns the text of source code for an object; its __name__ is 'getsource'; str.__eq__('getsource') returns True; new to extra184"]
    - [getsource_name_len_9,
       getsource.__name__.__len__,
       [],
       9,
       "inspect.getsource.__name__.__len__() == 9 — the name 'getsource' has exactly 9 characters: g-e-t-s-o-u-r-c-e; str.__len__() returns 9; new to extra184"]
    - [getsource_module_eq,
       getsource.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getsource.__module__.__eq__('inspect') == True — getsource is defined in the pure-Python inspect module Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra184"]
    - [getsource_qualname_eq,
       getsource.__qualname__.__eq__,
       ["getsource"],
       true,
       "inspect.getsource.__qualname__.__eq__('getsource') == True — getsource is a module-level Python function (not nested), so __qualname__ equals __name__ 'getsource' (9 chars); str.__eq__('getsource') returns True; new to extra184"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getsource __class__ and inspect.getsourcelines identity
#
# inspect.getsource.__class__.__name__ == 'function'
# inspect.getsourcelines.__name__ == 'getsourcelines'
# inspect.getsourcelines.__name__.__len__() == 14
# inspect.getsourcelines.__module__ == 'inspect'
#
# getsource is a regular Python function so __class__.__name__ is 'function'.
# getsourcelines is the lower-level helper that returns a list of source lines
# and the starting line number; its __name__ is 'getsourcelines' (14 chars).
# New to extra184.
# ---------------------------------------------------------------------------

table inspect_extra184.getsource_class_and_getsourcelines:
  description: "inspect.getsource.__class__.__name__=='function'; inspect.getsourcelines.__name__=='getsourcelines' len 14; __module__=='inspect'; new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgetsource184

  columns: [id, function, args, expected, description]
  rows:
    - [getsource_class_eq,
       getsource.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getsource.__class__.__name__.__eq__('function') == True — getsource is a regular Python function in Lib/inspect.py, so type(getsource).__name__ is 'function'; str.__eq__('function') returns True; new to extra184"]
    - [getsrclines_name_eq,
       getsourcelines.__name__.__eq__,
       ["getsourcelines"],
       true,
       "inspect.getsourcelines.__name__.__eq__('getsourcelines') == True — getsourcelines returns a list of source code lines and the line number of the first line; its __name__ is 'getsourcelines'; str.__eq__('getsourcelines') returns True; new to extra184"]
    - [getsrclines_name_len_14,
       getsourcelines.__name__.__len__,
       [],
       14,
       "inspect.getsourcelines.__name__.__len__() == 14 — the name 'getsourcelines' has exactly 14 characters: g-e-t-s-o-u-r-c-e-l-i-n-e-s; str.__len__() returns 14; new to extra184"]
    - [getsrclines_module_eq,
       getsourcelines.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getsourcelines.__module__.__eq__('inspect') == True — getsourcelines is defined in the pure-Python inspect module Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra184"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getsourcefile, getfile, getmodule, getdoc identity
#
# inspect.getsourcefile.__name__ == 'getsourcefile'
# inspect.getsourcefile.__name__.__len__() == 13
# inspect.getfile.__name__ == 'getfile'
# inspect.getfile.__name__.__len__() == 7
# inspect.getmodule.__name__ == 'getmodule'
# inspect.getdoc.__name__ == 'getdoc'
#
# getsourcefile returns the Python source file for an object (13 chars).
# getfile returns the file in which an object was defined (7 chars).
# getmodule guesses the module where an object was defined (9 chars).
# getdoc returns the cleaned docstring for an object (6 chars).
# All are pure-Python functions in Lib/inspect.py. New to extra184.
# ---------------------------------------------------------------------------

table inspect_extra184.getsourcefile_getfile_getmodule_getdoc:
  description: "inspect.getsourcefile.__name__=='getsourcefile' len 13; getfile.__name__=='getfile' len 7; getmodule.__name__=='getmodule' len 9; getdoc.__name__=='getdoc' len 6; new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgetsource184

  columns: [id, function, args, expected, description]
  rows:
    - [getsrcfile_name_eq,
       getsourcefile.__name__.__eq__,
       ["getsourcefile"],
       true,
       "inspect.getsourcefile.__name__.__eq__('getsourcefile') == True — getsourcefile returns the Python source file in which an object was defined; its __name__ is 'getsourcefile'; str.__eq__('getsourcefile') returns True; new to extra184"]
    - [getsrcfile_name_len_13,
       getsourcefile.__name__.__len__,
       [],
       13,
       "inspect.getsourcefile.__name__.__len__() == 13 — the name 'getsourcefile' has exactly 13 characters: g-e-t-s-o-u-r-c-e-f-i-l-e; str.__len__() returns 13; new to extra184"]
    - [getfile_name_eq,
       getfile.__name__.__eq__,
       ["getfile"],
       true,
       "inspect.getfile.__name__.__eq__('getfile') == True — getfile returns the file in which an object was defined (Python source or compiled .pyc); its __name__ is 'getfile'; str.__eq__('getfile') returns True; new to extra184"]
    - [getfile_name_len_7,
       getfile.__name__.__len__,
       [],
       7,
       "inspect.getfile.__name__.__len__() == 7 — the name 'getfile' has exactly 7 characters: g-e-t-f-i-l-e; str.__len__() returns 7; new to extra184"]
    - [getmodule_name_eq,
       getmodule.__name__.__eq__,
       ["getmodule"],
       true,
       "inspect.getmodule.__name__.__eq__('getmodule') == True — getmodule tries to guess the module in which an object was defined; its __name__ is 'getmodule'; str.__eq__('getmodule') returns True; new to extra184"]

