spec: io_extra1996
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "_io_extra.zspec.zsdl — covers _io C-module class metadata"
    - "io_extra1981.zspec.zsdl — covers __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence"
    - "any proprietary source"
  notes:
    - "Wave 580 (_extra1996): __index__, __complex__, __float__, __round__, __abs__ dict-presence checks."
    - "IO classes are stream/buffer types, not numeric types; none define numeric conversion protocols."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.BytesIO, io.StringIO, io.FileIO — all False for all five methods."
    - "These methods are not inherited from object and not defined in any IO class own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __index__ dict-presence — io core classes
# __index__ signals integer-index protocol (PEP 357). IO classes are stream
# objects, not integer-like; none define __index__ in their own __dict__.
# ---------------------------------------------------------------------------

table io_extra1996.index_protocol:
  description: "io class __dict__.__contains__('__index__') — all False (IO classes are not integer-like)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1996

  columns: [id, function, args, expected]
  rows:
    - ["io1996001", "io.IOBase.__dict__.__contains__",       ["__index__"], false]
    - ["io1996002", "io.RawIOBase.__dict__.__contains__",    ["__index__"], false]
    - ["io1996003", "io.BufferedIOBase.__dict__.__contains__", ["__index__"], false]
    - ["io1996004", "io.BytesIO.__dict__.__contains__",      ["__index__"], false]
    - ["io1996005", "io.StringIO.__dict__.__contains__",     ["__index__"], false]
    - ["io1996006", "io.FileIO.__dict__.__contains__",       ["__index__"], false]

# ---------------------------------------------------------------------------
# __complex__ dict-presence — io core classes
# __complex__ is the numeric conversion protocol for complex numbers.
# IO classes are not numeric; none define __complex__ in their own __dict__.
# ---------------------------------------------------------------------------

table io_extra1996.complex_protocol:
  description: "io class __dict__.__contains__('__complex__') — all False (IO classes are not numeric)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1996

  columns: [id, function, args, expected]
  rows:
    - ["io1996007", "io.IOBase.__dict__.__contains__",         ["__complex__"], false]
    - ["io1996008", "io.RawIOBase.__dict__.__contains__",      ["__complex__"], false]
    - ["io1996009", "io.BufferedIOBase.__dict__.__contains__", ["__complex__"], false]
    - ["io1996010", "io.BytesIO.__dict__.__contains__",        ["__complex__"], false]
    - ["io1996011", "io.StringIO.__dict__.__contains__",       ["__complex__"], false]
    - ["io1996012", "io.FileIO.__dict__.__contains__",         ["__complex__"], false]

# ---------------------------------------------------------------------------
# __float__ dict-presence — io core classes
# __float__ is the floating-point conversion protocol.
# IO stream objects carry no numeric value; none define __float__.
# ---------------------------------------------------------------------------

table io_extra1996.float_protocol:
  description: "io class __dict__.__contains__('__float__') — all False (IO classes carry no numeric value)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1996

  columns: [id, function, args, expected]
  rows:
    - ["io1996013", "io.IOBase.__dict__.__contains__",         ["__float__"], false]
    - ["io1996014", "io.RawIOBase.__dict__.__contains__",      ["__float__"], false]
    - ["io1996015", "io.BufferedIOBase.__dict__.__contains__", ["__float__"], false]
    - ["io1996016", "io.BytesIO.__dict__.__contains__",        ["__float__"], false]
    - ["io1996017", "io.StringIO.__dict__.__contains__",       ["__float__"], false]
    - ["io1996018", "io.FileIO.__dict__.__contains__",         ["__float__"], false]

# ---------------------------------------------------------------------------
# __round__ dict-presence — io core classes
# __round__ is used by the built-in round() function.
# IO classes do not represent numeric values and do not define __round__.
# ---------------------------------------------------------------------------

table io_extra1996.round_protocol:
  description: "io class __dict__.__contains__('__round__') — all False (IO classes are not roundable)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1996

  columns: [id, function, args, expected]
  rows:
    - ["io1996019", "io.IOBase.__dict__.__contains__",         ["__round__"], false]
    - ["io1996020", "io.RawIOBase.__dict__.__contains__",      ["__round__"], false]
    - ["io1996021", "io.BufferedIOBase.__dict__.__contains__", ["__round__"], false]
    - ["io1996022", "io.BytesIO.__dict__.__contains__",        ["__round__"], false]
    - ["io1996023", "io.StringIO.__dict__.__contains__",       ["__round__"], false]
    - ["io1996024", "io.FileIO.__dict__.__contains__",         ["__round__"], false]

