spec: struct_extra1756
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 564 (_extra1756): arithmetic operator protocol dict-presence checks."
    - "struct.Struct: C extension type — a compiled struct object; not a numeric type; no arithmetic operators in __dict__; all eight arithmetic dunders absent."
    - "struct.error: Python exception class — a subclass of Exception; not a numeric type; no arithmetic operators in __dict__; all eight arithmetic dunders absent."
    - "Complementary checks: struct.pack.__class__.__name__ == 'builtin_function_or_method'; struct.unpack.__class__.__name__ == 'builtin_function_or_method'; struct.calcsize.__class__.__name__ == 'builtin_function_or_method'; struct.iter_unpack.__class__.__name__ == 'builtin_function_or_method'."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operator protocol dict-presence checks for struct types
#
# Wave 564 theme: which struct types define __add__, __sub__, __mul__,
# __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__.
#
# struct.Struct: C extension type (Modules/_struct.c) — a compiled struct
#   format object; used for packing/unpacking binary data; not a numeric type;
#   no arithmetic operators defined in __dict__.
# struct.error: Python exception class (subclass of Exception) — raised for
#   format string or buffer errors; not a numeric type; no arithmetic operators
#   in __dict__.
# ---------------------------------------------------------------------------

table struct_extra1756.arithmetic_operators:
  description: "struct types arithmetic operator dict-presence checks — all False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1756

  columns: [id, function, args, expected]
  rows:
    - ["st1756001", "struct.Struct.__dict__.__contains__", ["__add__"], false]
    - ["st1756002", "struct.Struct.__dict__.__contains__", ["__sub__"], false]
    - ["st1756003", "struct.Struct.__dict__.__contains__", ["__mul__"], false]
    - ["st1756004", "struct.Struct.__dict__.__contains__", ["__truediv__"], false]
    - ["st1756005", "struct.Struct.__dict__.__contains__", ["__floordiv__"], false]
    - ["st1756006", "struct.Struct.__dict__.__contains__", ["__pow__"], false]
    - ["st1756007", "struct.Struct.__dict__.__contains__", ["__neg__"], false]
    - ["st1756008", "struct.Struct.__dict__.__contains__", ["__pos__"], false]
    - ["st1756009", "struct.error.__dict__.__contains__", ["__add__"], false]
    - ["st1756010", "struct.error.__dict__.__contains__", ["__sub__"], false]
    - ["st1756011", "struct.error.__dict__.__contains__", ["__mul__"], false]
    - ["st1756012", "struct.error.__dict__.__contains__", ["__truediv__"], false]
    - ["st1756013", "struct.error.__dict__.__contains__", ["__floordiv__"], false]
    - ["st1756014", "struct.error.__dict__.__contains__", ["__pow__"], false]
    - ["st1756015", "struct.error.__dict__.__contains__", ["__neg__"], false]
    - ["st1756016", "struct.error.__dict__.__contains__", ["__pos__"], false]

# ---------------------------------------------------------------------------
# Table 2: complementary module-level attribute checks for struct
#
# Unique checks not covered in earlier waves:
# - struct.pack.__class__.__name__ == 'builtin_function_or_method'
# - struct.unpack.__class__.__name__ == 'builtin_function_or_method'
# - struct.calcsize.__class__.__name__ == 'builtin_function_or_method'
# - struct.iter_unpack.__class__.__name__ == 'builtin_function_or_method'
# These confirm that all top-level struct functions are C builtins (not Python
# functions), contrasting with the class __dict__ checks above.
# ---------------------------------------------------------------------------

table struct_extra1756.module_level_attributes:
  description: "struct module-level function class name checks — all builtin_function_or_method — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1756

  columns: [id, function, args, expected]
  rows:
    - ["st1756017", "struct.pack.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st1756018", "struct.unpack.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st1756019", "struct.calcsize.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st1756020", "struct.iter_unpack.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st1756021", "struct.Struct.__dict__.__contains__", ["__add__"], false]
    - ["st1756022", "struct.Struct.__dict__.__contains__", ["__floordiv__"], false]
    - ["st1756023", "struct.error.__dict__.__contains__", ["__neg__"], false]
