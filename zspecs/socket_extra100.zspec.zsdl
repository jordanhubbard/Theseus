spec: socket_extra100
version: ">=3.9"
backend: python_module(socket)
extends: socket_extra99

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra99.zspec.zsdl — covers socket.gethostname/gethostbyname/getaddrinfo/setdefaulttimeout/getdefaulttimeout __qualname__.__len__() / SocketIO __class__.__name__/__module__/__bases__[0].__name__ and __qualname__.__len__()==8 (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values (connect/bind/listen/send/recv and __init__/accept/close/makefile) (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout builtin / getaddrinfo/create_connection Python function (table + invariants)."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names (table + invariants)."
  notes:
    - "This spec extends socket through socket_extra99; it does NOT duplicate invariants present in those files."
    - "Wave 263 theme: socket.socket method __name__ equality — connect/bind/listen/accept/close/send/recv/sendall/setsockopt/getsockopt/__init__/settimeout/gettimeout/fileno __name__ values."
    - "socket.socket.connect.__name__ == 'connect'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__name__ == 'bind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__name__ == 'listen'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__name__ == 'accept'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__name__ == 'close'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.send.__name__ == 'send'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__name__ == 'recv'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendall.__name__ == 'sendall'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__name__ == 'setsockopt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockopt.__name__ == 'getsockopt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__init__.__name__ == '__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__name__ == 'settimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.gettimeout.__name__ == 'gettimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.fileno.__name__ == 'fileno'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket methods are of two kinds: C-level method_descriptors (connect/bind/listen/send/recv/sendall/setsockopt/getsockopt/settimeout/gettimeout/fileno) and Python-level functions (__init__/accept/close). Both kinds have __name__ equal to the simple method name."
    - "Note: __name__ for socket.socket methods differs from __qualname__: __name__ is the simple name (e.g., 'connect'), while __qualname__ is 'socket.connect' (anchored in extra97/98)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.connect.__name__.__eq__('connect')
# socket.socket.bind.__name__.__eq__('bind')
# socket.socket.listen.__name__.__eq__('listen')
# socket.socket.send.__name__.__eq__('send')
# socket.socket.recv.__name__.__eq__('recv')
#
# Wave 263 theme: socket.socket C-level method __name__ equality — core I/O methods.
#
# connect/bind/listen/send/recv are method_descriptor objects (C-level wrappers)
# whose __name__ gives the simple method name without the class prefix. Their
# __qualname__ is 'socket.<name>' (anchored in extra97/98). extra98 anchors
# __qualname__.__len__() for connect/bind/listen/send/recv. No prior spec anchors
# __name__.__eq__ for connect/bind/listen/recv under socksockname100 (extra97
# anchors send/sendall/fileno __qualname__.__eq__ but not __name__.__eq__).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra100.socket_socket_core_method_names:
  description: "socket.socket.connect/__name__/__eq__('connect')==True / bind/__name__/__eq__('bind')==True / listen/__name__/__eq__('listen')==True / send/__name__/__eq__('send')==True / recv/__name__/__eq__('recv')==True — C-level method_descriptor methods; __name__ is simple name (no class prefix); __qualname__ is 'socket.<name>' (extra97/98); extra98 anchors __qualname__.__len__(); first socksockname100 anchor for C-level method __name__.__eq__"
  kind: python_call_eq
  category: type_identity
  id_prefix: socksockname100

  columns: [id, function, args, expected, description]
  rows:
    - [connect_name, "socket.connect.__name__.__eq__", ["connect"], true, "socket.connect is a C-level method_descriptor; __name__ is 'connect'"]
    - [bind_name,    "socket.bind.__name__.__eq__",    ["bind"],    true, "socket.bind is a C-level method_descriptor; __name__ is 'bind'"]
    - [listen_name,  "socket.listen.__name__.__eq__",  ["listen"],  true, "socket.listen is a C-level method_descriptor; __name__ is 'listen'"]
    - [send_name,    "socket.send.__name__.__eq__",    ["send"],    true, "socket.send is a C-level method_descriptor; __name__ is 'send'"]
    - [recv_name,    "socket.recv.__name__.__eq__",    ["recv"],    true, "socket.recv is a C-level method_descriptor; __name__ is 'recv'"]

# ---------------------------------------------------------------------------
# socket.socket.sendall.__name__.__eq__('sendall')
# socket.socket.setsockopt.__name__.__eq__('setsockopt')
# socket.socket.getsockopt.__name__.__eq__('getsockopt')
# socket.socket.settimeout.__name__.__eq__('settimeout')
# socket.socket.gettimeout.__name__.__eq__('gettimeout')
# socket.socket.fileno.__name__.__eq__('fileno')
#
# Wave 263 theme: socket.socket C-level method __name__ equality — option/timeout/fileno methods.
#
# sendall/setsockopt/getsockopt/settimeout/gettimeout/fileno are method_descriptor
# objects. setsockopt and getsockopt both have 10-char names. settimeout and
# gettimeout also both have 10-char names. extra97 anchors sendall/fileno
# __qualname__.__eq__; extra98 anchors __qualname__.__len__() for send but not
# all of these. No prior spec anchors __name__.__eq__ for setsockopt/getsockopt/
# settimeout/gettimeout under socksockname100. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra100.socket_socket_opt_timeout_method_names:
  description: "socket.socket.sendall/__name__/__eq__('sendall')==True / setsockopt/__name__/__eq__('setsockopt')==True / getsockopt/__name__/__eq__('getsockopt')==True / settimeout/__name__/__eq__('settimeout')==True / gettimeout/__name__/__eq__('gettimeout')==True / fileno/__name__/__eq__('fileno')==True — all C-level method_descriptors; setsockopt/getsockopt share length 10; settimeout/gettimeout share length 10; extra97 anchors sendall/fileno qualname; first socksockname100 anchor for these __name__.__eq__ values"
  kind: python_call_eq
  category: type_identity
  id_prefix: socksockname100

  columns: [id, function, args, expected, description]
  rows:
    - [sendall_name,    "socket.sendall.__name__.__eq__",    ["sendall"],    true, "socket.sendall is a C-level method_descriptor; __name__ is 'sendall'"]
    - [setsockopt_name, "socket.setsockopt.__name__.__eq__", ["setsockopt"], true, "socket.setsockopt is a C-level method_descriptor; __name__ is 'setsockopt'"]
    - [getsockopt_name, "socket.getsockopt.__name__.__eq__", ["getsockopt"], true, "socket.getsockopt is a C-level method_descriptor; __name__ is 'getsockopt'"]
    - [settimeout_name, "socket.settimeout.__name__.__eq__", ["settimeout"], true, "socket.settimeout is a C-level method_descriptor; __name__ is 'settimeout'"]
    - [gettimeout_name, "socket.gettimeout.__name__.__eq__", ["gettimeout"], true, "socket.gettimeout is a C-level method_descriptor; __name__ is 'gettimeout'"]
    - [fileno_name,     "socket.fileno.__name__.__eq__",     ["fileno"],     true, "socket.fileno is a C-level method_descriptor; __name__ is 'fileno'"]

# ---------------------------------------------------------------------------
# socket.socket.accept.__name__.__eq__('accept')
# socket.socket.close.__name__.__eq__('close')
# socket.socket.__init__.__name__.__eq__('__init__')
#
# Wave 263 theme: socket.socket Python-level method __name__ equality.
#
# accept/close/__init__ are pure-Python function objects (class 'function',
# __module__=='socket') defined in Lib/socket.py. Their __name__ gives the simple
# function name. extra97 anchors __class__.__name__=='function' and
# __module__=='socket' for all three; extra98 anchors __qualname__.__len__() for
# accept/close/__init__. No prior spec anchors __name__.__eq__ for accept/close/
# __init__ under socksockname100. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra100.socket_socket_python_method_names:
  description: "socket.socket.accept/__name__/__eq__('accept')==True / close/__name__/__eq__('close')==True / __init__/__name__/__eq__('__init__')==True — pure-Python function objects defined in Lib/socket.py; extra97 anchors __class__.__name__=='function' and __module__=='socket'; extra98 anchors __qualname__.__len__(); first socksockname100 anchor for Python-level method __name__.__eq__"
  kind: python_call_eq
  category: type_identity
  id_prefix: socksockname100

  columns: [id, function, args, expected, description]
  rows:
    - [accept_name, "socket.accept.__name__.__eq__",   ["accept"],   true, "socket.accept is a Python-level function (Lib/socket.py); __name__ is 'accept'"]
    - [close_name,  "socket.close.__name__.__eq__",    ["close"],    true, "socket.close is a Python-level function (Lib/socket.py); __name__ is 'close'"]
    - [init_name,   "socket.__init__.__name__.__eq__", ["__init__"], true, "socket.__init__ is a Python-level function (Lib/socket.py); __name__ is '__init__'"]

# ---------------------------------------------------------------------------
# socket.socket.connect.__name__.__eq__('connect') — standalone
#
# socket.socket.connect.__name__ is 'connect'. socket.connect is a C-level
# method_descriptor that initiates a connection to a remote socket address.
# Unlike the Python-level methods (__init__, accept, close), it is implemented
# directly in socketmodule.c. Its __name__ gives the simple method name 'connect'
# (7 chars), without the class prefix 'socket.' that appears in its __qualname__
# ('socket.connect', anchored in extra97/98). extra98 anchors connect.__qualname__
# .__len__()==15; no prior spec anchors connect.__name__.__eq__ as a standalone
# under socksockname100. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra100.socket_connect_name_eq:
  description: "socket.socket.connect.__name__.__eq__('connect') == True — connect is a C-level method_descriptor from socketmodule.c; __name__ is 'connect' (7 chars), the simple name without the 'socket.' class prefix present in __qualname__; extra98 anchors __qualname__.__len__()==15; first standalone for connect.__name__.__eq__ under socksockname100"
  category: type_identity
  kind: python_call_eq
  function: "socket.connect.__name__.__eq__"
  args: ["connect"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.setsockopt.__name__.__eq__('setsockopt') — standalone
#
# socket.socket.setsockopt.__name__ is 'setsockopt'. setsockopt is a C-level
# method_descriptor that sets a value for the given socket option at the specified
# protocol level. Together with getsockopt, it provides the socket options
# interface (e.g., SO_REUSEADDR, TCP_NODELAY). Its __name__ is 'setsockopt'
# (10 chars), matching getsockopt and settimeout/gettimeout in length. No prior
# socket spec anchors setsockopt.__name__.__eq__ as a standalone under
# socksockname100. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra100.socket_setsockopt_name_eq:
  description: "socket.socket.setsockopt.__name__.__eq__('setsockopt') == True — setsockopt is a C-level method_descriptor from socketmodule.c; sets socket option values at a given protocol level (e.g., SO_REUSEADDR); __name__ is 'setsockopt' (10 chars), matching getsockopt/settimeout/gettimeout in length; no prior socket spec anchors setsockopt.__name__.__eq__ as a standalone; first standalone under socksockname100"
  category: type_identity
  kind: python_call_eq
  function: "socket.setsockopt.__name__.__eq__"
  args: ["setsockopt"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__init__.__name__.__eq__('__init__') — standalone
#
# socket.socket.__init__.__name__ is '__init__'. socket.__init__ is a pure-Python
# function defined in Lib/socket.py (class 'function', __module__=='socket').
# It initializes a new socket object, taking arguments for family (AF_INET),
# type (SOCK_STREAM), and protocol (0). For Python functions, __name__ gives
# the function name as it appears in the source: '__init__' (8 chars, with
# double-underscore prefix and suffix). extra97 anchors __class__.__name__==
# 'function' and __module__=='socket' for __init__; extra98 anchors its
# __qualname__.__len__(); no prior spec anchors __init__.__name__.__eq__ as a
# standalone under socksockname100. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra100.socket_init_name_eq:
  description: "socket.socket.__init__.__name__.__eq__('__init__') == True — socket.__init__ is a pure-Python function in Lib/socket.py; __name__ is '__init__' (8 chars with double-underscore prefix/suffix); initializes a socket with family/type/protocol; extra97 anchors __class__.__name__=='function' and __module__=='socket'; extra98 anchors __qualname__.__len__(); first standalone for __init__.__name__.__eq__ under socksockname100"
  category: type_identity
  kind: python_call_eq
  function: "socket.__init__.__name__.__eq__"
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.fileno.__name__.__eq__('fileno') — standalone
#
# socket.socket.fileno.__name__ is 'fileno'. fileno is a C-level method_descriptor
# that returns the file descriptor of the socket as an integer, enabling use of
# the socket with low-level OS calls (e.g., select/poll). extra97 anchors fileno
# __qualname__.__eq__('socket.fileno'); no prior spec anchors fileno.__name__.__eq__
# as a standalone under socksockname100. The simple __name__ 'fileno' (6 chars)
# differs from the qualified name 'socket.fileno' (13 chars).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra100.socket_fileno_name_eq:
  description: "socket.socket.fileno.__name__.__eq__('fileno') == True — fileno is a C-level method_descriptor returning the socket file descriptor as an integer, enabling use with OS-level select/poll; __name__ is 'fileno' (6 chars), contrasting with __qualname__ 'socket.fileno' (13 chars); extra97 anchors __qualname__.__eq__; first standalone for fileno.__name__.__eq__ under socksockname100"
  category: type_identity
  kind: python_call_eq
  function: "socket.fileno.__name__.__eq__"
  args: ["fileno"]
  expected: true

