spec: strnum
version: ">=2.0.0"
backend: node(strnum)

docs: https://github.com/NaturalIntelligence/strnum#readme

provenance:
  derived_from:
    - "strnum README — https://github.com/NaturalIntelligence/strnum#readme"
    - "Test vectors verified with strnum via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "strnum source"
  notes:
    - "Smart string-to-number coercion (used by fast-xml-parser)."
    - "Install: npm install strnum"
    - "v2 ESM with CJS shim; default export is the parser function."
    - "Returns the parsed number when the input represents a number; returns the original string otherwise."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table strnum.parse:
  kind: node_module_call_eq
  category: parse
  function: default
  id_prefix: parse

  columns: [id, args, expected]
  rows:
    - [int,           ["42"],           42]
    - [float,         ["3.14"],         3.14]
    - [negative,      ["-7"],           -7]
    - [zero,          ["0"],            0]
    - [exponential,   ["1e3"],          1000]
    - [neg_exponent,  ["1e-3"],         0.001]
    - [hex_parsed_as_int,
                      ["0x10"],         16]
    - [non_numeric,   ["hello"],        "hello"]
    - [empty,         [""],             ""]
    - [number_with_letters,
                      ["42px"],         "42px"]
