spec: lzma_extra3
version: ">=3.3"
backend: python_module(lzma)

docs: https://docs.python.org/3/library/lzma.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/lzma.html — Python lzma documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/lzma.py"
    - "CPython source: Modules/_lzmamodule.c"
  notes:
    - "This spec extends lzma.zspec.zsdl and lzma_extra2.zspec.zsdl."
    - "lzma (base) covers: LZMAFile/LZMACompressor/LZMADecompressor/LZMAError __name__ (table), compress/decompress/open __name__ (table), LZMAFile.__module__, FORMAT_AUTO/FORMAT_XZ/FORMAT_ALONE/FORMAT_RAW eq values (table), CHECK_NONE/CHECK_CRC32/CHECK_CRC64/CHECK_SHA256 eq values (table), LZMAError.__bases__[0].__name__ == 'Exception' (string form), compress returns bytes, is_check_supported(CHECK_NONE/CHECK_CRC32)."
    - "lzma_extra2 covers: class __name__ table (fresh id_prefix ln2), class __qualname__ table, LZMAFile/__module__ standalone and LZMAError/__module__ table, LZMAError base name bool form."
    - "This spec adds: FORMAT_AUTO/FORMAT_XZ/FORMAT_ALONE/FORMAT_RAW __class__.__name__ == 'int' (type identity; not in any prior spec); CHECK_NONE/CHECK_CRC32/CHECK_CRC64/CHECK_SHA256 __class__.__name__ == 'int' (not in any prior spec); CHECK_ID_MAX value check (not in any prior spec); FILTER_LZMA1/__class__.__name__ == 'int' (not in any prior spec); FILTER_LZMA2/__class__.__name__ == 'int' (not in any prior spec); LZMAFile/__class__.__name__ == 'type'; LZMAError/__class__.__name__ == 'type'; LZMACompressor/__class__.__name__ == 'type'; LZMADecompressor/__class__.__name__ == 'type'; compress/decompress/__class__.__name__ == 'function'; open/__class__.__name__ == 'function'."
    - "lzma.CHECK_ID_MAX == 15 — the maximum valid check-type identifier (from the lzma C extension)."
    - "lzma.FILTER_LZMA1 is an integer constant used as a filter ID in raw/alone streams."
    - "lzma.FILTER_LZMA2 is an integer constant used as a filter ID in XZ streams."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# FORMAT_* constants — __class__.__name__ == 'int'
# lzma (base) and lzma_extra2 only check eq values, not type identity.
# These are new type-identity checks via the bool-form pattern.
# ---------------------------------------------------------------------------

table lzma_extra3.format_constant_class_names:
  description: "lzma FORMAT_* constants are plain int objects"
  kind: python_call_eq
  category: constants
  id_prefix: fmttype3

  columns: [id, function, args, expected]
  rows:
    - [FORMAT_AUTO,  FORMAT_AUTO.__class__.__name__.__eq__,  ["int"], true]
    - [FORMAT_XZ,    FORMAT_XZ.__class__.__name__.__eq__,    ["int"], true]
    - [FORMAT_ALONE, FORMAT_ALONE.__class__.__name__.__eq__, ["int"], true]
    - [FORMAT_RAW,   FORMAT_RAW.__class__.__name__.__eq__,   ["int"], true]

# ---------------------------------------------------------------------------
# CHECK_* constants — __class__.__name__ == 'int'
# lzma (base) checks eq values; lzma_extra2 does not add type checks.
# These are new type-identity checks.
# ---------------------------------------------------------------------------

table lzma_extra3.check_constant_class_names:
  description: "lzma CHECK_* constants are plain int objects"
  kind: python_call_eq
  category: constants
  id_prefix: chktype3

  columns: [id, function, args, expected]
  rows:
    - [CHECK_NONE,   CHECK_NONE.__class__.__name__.__eq__,   ["int"], true]
    - [CHECK_CRC32,  CHECK_CRC32.__class__.__name__.__eq__,  ["int"], true]
    - [CHECK_CRC64,  CHECK_CRC64.__class__.__name__.__eq__,  ["int"], true]
    - [CHECK_SHA256, CHECK_SHA256.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# CHECK_ID_MAX — value check
# Not covered in any prior lzma spec.
# lzma.CHECK_ID_MAX == 15 — the highest valid check ID in the lzma C extension.
# ---------------------------------------------------------------------------

invariant lzma_extra3.CHECK_ID_MAX.value:
  description: "lzma.CHECK_ID_MAX == 15 — maximum valid check-type identifier"
  category: constants
  kind: python_call_eq
  function: CHECK_ID_MAX.__eq__
  args: [15]
  expected: true

invariant lzma_extra3.CHECK_ID_MAX.class_name:
  description: "lzma.CHECK_ID_MAX.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: CHECK_ID_MAX.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# FILTER_LZMA1 and FILTER_LZMA2 — type checks
# Not covered in any prior lzma spec.
# ---------------------------------------------------------------------------

invariant lzma_extra3.FILTER_LZMA1.class_name:
  description: "lzma.FILTER_LZMA1.__class__.__name__ == 'int' — FILTER_LZMA1 is a plain int"
  category: constants
  kind: python_call_eq
  function: FILTER_LZMA1.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant lzma_extra3.FILTER_LZMA2.class_name:
  description: "lzma.FILTER_LZMA2.__class__.__name__ == 'int' — FILTER_LZMA2 is a plain int"
  category: constants
  kind: python_call_eq
  function: FILTER_LZMA2.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Class type identity — LZMAFile, LZMAError, LZMACompressor, LZMADecompressor
# Prior specs check __name__, __module__, __qualname__, and bases for these
# classes; __class__.__name__ == 'type' is not in any prior lzma spec.
# ---------------------------------------------------------------------------

table lzma_extra3.class_type_checks:
  description: "lzma classes are class objects (__class__.__name__=='type')"
  kind: python_call_eq
  category: type_identity
  id_prefix: ltype3

  columns: [id, function, args, expected]
  rows:
    - [LZMAFile,         LZMAFile.__class__.__name__.__eq__,         ["type"], true]
    - [LZMAError,        LZMAError.__class__.__name__.__eq__,        ["type"], true]
    - [LZMACompressor,   LZMACompressor.__class__.__name__.__eq__,   ["type"], true]
    - [LZMADecompressor, LZMADecompressor.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# Function type identity — compress, decompress, open
# Prior specs check __name__, __module__, __qualname__ for these functions.
# __class__.__name__ == 'function' is not in any prior lzma spec.
# ---------------------------------------------------------------------------

table lzma_extra3.function_type_checks:
  description: "lzma compress/decompress/open are plain Python functions (__class__.__name__=='function')"
  kind: python_call_eq
  category: type_identity
  id_prefix: lftype3

  columns: [id, function, args, expected]
  rows:
    - [compress,   compress.__class__.__name__.__eq__,   ["function"], true]
    - [decompress, decompress.__class__.__name__.__eq__, ["function"], true]
    - [open,       open.__class__.__name__.__eq__,       ["function"], true]
