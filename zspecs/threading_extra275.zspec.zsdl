spec: threading_extra275
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.local.__name__ == '_local' (NOT 'local'); its __module__ == '_thread' (C extension)."
    - "threading.local.__bases__[0].__name__ == 'object' — _local directly subclasses object."
    - "threading.stack_size.__module__ == '_thread' — C builtin from _thread; __class__.__name__ == 'builtin_function_or_method'."
    - "threading.TIMEOUT_MAX == 9223372036.0 — float; equals (2**63 - 1) / 10**9 nanoseconds → ~9.22e9 seconds."
    - "threading.TIMEOUT_MAX is type float; it is > 9.2e9 and < 9.3e9."
    - "threading.Condition.__module__ == 'threading'; __bases__[0].__name__ == 'object'."
    - "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — subclasses Semaphore."
    - "threading.active_count.__module__ == 'threading' (pure-Python function); get_ident.__module__ == '_thread' (C builtin)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.local — class identity
#
# threading.local is actually the C-level _thread._local type.
# __name__ == '_local' (NOT 'local' — surprising!); __module__ == '_thread'.
# __bases__[0].__name__ == 'object'; __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

table threading_extra275.local_class_identity:
  description: "threading.local class identity — __name__=='_local', __module__=='_thread', __bases__[0].__name__=='object'; C-level type; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex275lci

  columns: [id, function, args, expected, description]
  rows:
    - [lc_name_eq,    local.__name__.__eq__,                       ["_local"],   true, "threading.local.__name__ == '_local' (not 'local' — C-level private name); verified with Python 3.14.3"]
    - [lc_name_len,   local.__name__.__len__,                      [],           6,    "threading.local.__name__.__len__() == 6 (underscore + 'local'); verified with Python 3.14.3"]
    - [lc_mod_eq,     local.__module__.__eq__,                     ["_thread"],  true, "threading.local.__module__ == '_thread' (C extension, not 'threading'); verified with Python 3.14.3"]
    - [lc_cls_eq,     local.__class__.__name__.__eq__,             ["type"],     true, "threading.local.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [lc_base_name,  local.__bases__.__getitem__(0).__name__.__eq__, ["object"], true, "threading.local.__bases__[0].__name__ == 'object' — directly subclasses object; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# threading.stack_size and threading.TIMEOUT_MAX
#
# stack_size is a C builtin from _thread: __module__ == '_thread',
#   __class__.__name__ == 'builtin_function_or_method'.
# TIMEOUT_MAX == 9223372036.0 (float); > 9.2e9 and < 9.3e9.
# Condition and BoundedSemaphore identity.
# ---------------------------------------------------------------------------

table threading_extra275.stack_size_and_timeout_identity:
  description: "threading.stack_size module/class; TIMEOUT_MAX float value bounds; Condition and BoundedSemaphore identity; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex275ss

  columns: [id, function, args, expected, description]
  rows:
    - [ss_mod_eq,    stack_size.__module__.__eq__,                  ["_thread"],                    true,  "threading.stack_size.__module__ == '_thread' (C builtin from _thread extension); verified with Python 3.14.3"]
    - [ss_cls_eq,    stack_size.__class__.__name__.__eq__,          ["builtin_function_or_method"], true,  "threading.stack_size.__class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3"]
    - [ss_name_eq,   stack_size.__name__.__eq__,                    ["stack_size"],                 true,  "threading.stack_size.__name__ == 'stack_size'; verified with Python 3.14.3"]
    - [tm_gt_9e9,    TIMEOUT_MAX.__gt__,                            [9200000000.0],                 true,  "threading.TIMEOUT_MAX > 9.2e9 (approx 9.22e9); verified with Python 3.14.3"]
    - [tm_lt_93e9,   TIMEOUT_MAX.__lt__,                            [9300000000.0],                 true,  "threading.TIMEOUT_MAX < 9.3e9; verified with Python 3.14.3"]
    - [co_name_eq,   Condition.__name__.__eq__,                     ["Condition"],                  true,  "threading.Condition.__name__ == 'Condition'; verified with Python 3.14.3"]
    - [co_mod_eq,    Condition.__module__.__eq__,                   ["threading"],                  true,  "threading.Condition.__module__ == 'threading'; verified with Python 3.14.3"]
    - [co_base_name, Condition.__bases__.__getitem__(0).__name__.__eq__, ["object"],                true,  "threading.Condition.__bases__[0].__name__ == 'object'; verified with Python 3.14.3"]
    - [bs_name_eq,   BoundedSemaphore.__name__.__eq__,              ["BoundedSemaphore"],           true,  "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore'; verified with Python 3.14.3"]
    - [bs_mod_eq,    BoundedSemaphore.__module__.__eq__,            ["threading"],                  true,  "threading.BoundedSemaphore.__module__ == 'threading'; verified with Python 3.14.3"]
    - [bs_base_name, BoundedSemaphore.__bases__.__getitem__(0).__name__.__eq__, ["Semaphore"],      true,  "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore subclasses Semaphore; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra275
# ---------------------------------------------------------------------------

invariant threading_extra275.local_name_is_underscore_local:
  description: "threading.local.__name__ == '_local' — the C-level type's true name is '_local', not 'local'; this is a common pitfall"
  category: identity
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra275.local_module_is_c_thread:
  description: "threading.local.__module__ == '_thread' — the _local type is defined in the C extension _thread, not in the Python threading module"
  category: identity
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra275.local_base_is_object:
  description: "threading.local.__bases__[0].__name__ == 'object' — _local directly subclasses object"
  category: identity
  kind: python_call_eq
  function: local.__bases__.__getitem__(0).__name__.__eq__
  args: ["object"]
  expected: true

invariant threading_extra275.stack_size_module_is_c_thread:
  description: "threading.stack_size.__module__ == '_thread' — stack_size is a C builtin from the _thread extension"
  category: identity
  kind: python_call_eq
  function: stack_size.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra275.timeout_max_is_float:
  description: "type(threading.TIMEOUT_MAX).__name__ == 'float' — TIMEOUT_MAX is a float, not an int"
  category: constants
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra275.timeout_max_is_large:
  description: "threading.TIMEOUT_MAX > 9.2e9 — TIMEOUT_MAX is approximately 9.22e9 seconds (~292 years), derived from (2^63-1) nanoseconds"
  category: constants
  kind: python_call_eq
  function: TIMEOUT_MAX.__gt__
  args: [9200000000.0]
  expected: true

invariant threading_extra275.boundedsemaphore_subclasses_semaphore:
  description: "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore extends Semaphore with an upper bound check"
  category: identity
  kind: python_call_eq
  function: BoundedSemaphore.__bases__.__getitem__(0).__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra275.active_count_module_is_threading:
  description: "threading.active_count.__module__ == 'threading' — active_count is a pure-Python function defined in threading"
  category: identity
  kind: python_call_eq
  function: active_count.__module__.__eq__
  args: ["threading"]
  expected: true
