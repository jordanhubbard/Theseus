spec: heapq_extra3
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "Python heapq documentation — https://docs.python.org/3/library/heapq.html"
    - "Test vectors verified by running Python 3.14.3 heapq module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
    - "heapq.zspec.zsdl — covers nlargest/nsmallest tables; heapify/heappush/heappop/merge __name__"
    - "heapq_extra.zspec.zsdl — covers __name__ and __module__ for heappush; __name__ for heappop/heapify/heapreplace/heappushpop/merge/nlargest/nsmallest; nlargest(3)/nsmallest(3) on [1,5,3,2,4]"
    - "heapq_extra2.zspec.zsdl — covers __name__ table for heappush/heappop/heapify/heapreplace/nlargest/nsmallest; nlargest(2)/nsmallest(2) on [5,1,3,2,4]"
  notes:
    - "heappop, heapify, heapreplace, heappushpop are C-implemented; __module__ == '_heapq'."
    - "nlargest and nsmallest are pure-Python; __module__ == 'heapq'."
    - "merge is a pure-Python generator function; __module__ == 'heapq'."
    - "heappush.__module__ was confirmed in heapq_extra; this spec adds the remaining C-level functions."
    - "nlargest(3, [1,5,2,4,3]) == [5,4,3] — three largest in descending order."
    - "nsmallest(3, [1,5,2,4,3]) == [1,2,3] — three smallest in ascending order."
    - "All expected values verified by running Python 3.14.3 heapq module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks for C-level heap functions
# heappush.__module__ was already covered in heapq_extra; new IDs here add
# heappop, heapify, heapreplace, and heappushpop with heapq_extra3. prefix.
# ---------------------------------------------------------------------------

invariant heapq_extra3.heappush.module:
  description: "heapq.heappush.__module__ == '_heapq' — C implementation"
  category: module_identity
  kind: python_call_eq
  function: heappush.__module__.__eq__
  args: ["_heapq"]
  expected: true

invariant heapq_extra3.heappop.module:
  description: "heapq.heappop.__module__ == '_heapq' — C implementation"
  category: module_identity
  kind: python_call_eq
  function: heappop.__module__.__eq__
  args: ["_heapq"]
  expected: true

invariant heapq_extra3.heapify.module:
  description: "heapq.heapify.__module__ == '_heapq' — C implementation"
  category: module_identity
  kind: python_call_eq
  function: heapify.__module__.__eq__
  args: ["_heapq"]
  expected: true

invariant heapq_extra3.heapreplace.module:
  description: "heapq.heapreplace.__module__ == '_heapq' — C implementation"
  category: module_identity
  kind: python_call_eq
  function: heapreplace.__module__.__eq__
  args: ["_heapq"]
  expected: true

invariant heapq_extra3.heappushpop.module:
  description: "heapq.heappushpop.__module__ == '_heapq' — C implementation"
  category: module_identity
  kind: python_call_eq
  function: heappushpop.__module__.__eq__
  args: ["_heapq"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ checks for pure-Python heapq functions
# nlargest, nsmallest, and merge are defined in Lib/heapq.py
# ---------------------------------------------------------------------------

invariant heapq_extra3.nlargest.module:
  description: "heapq.nlargest.__module__ == 'heapq' — pure-Python implementation"
  category: module_identity
  kind: python_call_eq
  function: nlargest.__module__.__eq__
  args: ["heapq"]
  expected: true

invariant heapq_extra3.nsmallest.module:
  description: "heapq.nsmallest.__module__ == 'heapq' — pure-Python implementation"
  category: module_identity
  kind: python_call_eq
  function: nsmallest.__module__.__eq__
  args: ["heapq"]
  expected: true

invariant heapq_extra3.merge.module:
  description: "heapq.merge.__module__ == 'heapq' — pure-Python generator function"
  category: module_identity
  kind: python_call_eq
  function: merge.__module__.__eq__
  args: ["heapq"]
  expected: true

# ---------------------------------------------------------------------------
# __name__ confirmations — orthogonal IDs distinct from heapq_extra/heapq_extra2
# ---------------------------------------------------------------------------

invariant heapq_extra3.heappush.name:
  description: "heapq.heappush.__name__ == 'heappush'"
  category: identity
  kind: python_call_eq
  function: heappush.__name__.__eq__
  args: ["heappush"]
  expected: true

invariant heapq_extra3.heappop.name:
  description: "heapq.heappop.__name__ == 'heappop'"
  category: identity
  kind: python_call_eq
  function: heappop.__name__.__eq__
  args: ["heappop"]
  expected: true

invariant heapq_extra3.heapify.name:
  description: "heapq.heapify.__name__ == 'heapify'"
  category: identity
  kind: python_call_eq
  function: heapify.__name__.__eq__
  args: ["heapify"]
  expected: true

invariant heapq_extra3.nlargest.name:
  description: "heapq.nlargest.__name__ == 'nlargest'"
  category: identity
  kind: python_call_eq
  function: nlargest.__name__.__eq__
  args: ["nlargest"]
  expected: true

invariant heapq_extra3.nsmallest.name:
  description: "heapq.nsmallest.__name__ == 'nsmallest'"
  category: identity
  kind: python_call_eq
  function: nsmallest.__name__.__eq__
  args: ["nsmallest"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral invariants — nlargest and nsmallest on [1, 5, 2, 4, 3]
# Different input list from heapq_extra ([1,5,3,2,4]) and heapq_extra2 ([5,1,3,2,4])
# ---------------------------------------------------------------------------

invariant heapq_extra3.nlargest.top3_on_12453:
  description: "heapq.nlargest(3, [1,5,2,4,3]) == [5, 4, 3] — three largest in descending order"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [3, [1, 5, 2, 4, 3]]
  expected: [5, 4, 3]

invariant heapq_extra3.nsmallest.top3_on_12453:
  description: "heapq.nsmallest(3, [1,5,2,4,3]) == [1, 2, 3] — three smallest in ascending order"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [3, [1, 5, 2, 4, 3]]
  expected: [1, 2, 3]
