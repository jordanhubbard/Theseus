spec: uuid_extra2086
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python 3 uuid documentation — https://docs.python.org/3/library/uuid.html"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace, July 2005"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid.zspec.zsdl"
  notes:
    - "Wave extra2086, theme: __format__ string formatting protocol dict-presence; __bytes__ bytes conversion dict-presence; __fspath__ filesystem path protocol dict-presence; __buffer__/__release_buffer__ buffer protocol dict-presence."
    - "uuid.UUID does not define __format__, __bytes__, __fspath__, __buffer__, or __release_buffer__ in its own __dict__; these are all inherited from object."
    - "uuid.UUID uses __slots__ = ('int', 'is_safe', '__weakref__'), so instance dicts are absent; class __dict__ only contains what UUID explicitly defines."
    - "uuid.SafeUUID is an IntEnum subclass. Its __format__ is not in SafeUUID.__dict__ directly; it is inherited through the IntEnum/Enum MRO."
    - "SafeUUID.safe.value == 0, SafeUUID.unsafe.value == -1, SafeUUID.unknown.value is None."
    - "uuid3(NAMESPACE_DNS, 'python.org') == '6fa459ea-ee8a-3ca4-894e-db77e160355e' (RFC 4122 MD5-based)."
    - "uuid5(NAMESPACE_DNS, 'python.org') == '886313e1-3b8a-5372-9b90-0c9aee199e5d' (RFC 4122 SHA-1-based)."
    - "All expected values verified by running Python 3.12 uuid on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __format__ string formatting protocol dict-presence
# ---------------------------------------------------------------------------

table uuid_extra2086.format_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["uu2086001", "uuid.UUID.__dict__.__contains__", ["__format__"], false]
    - ["uu2086002", "uuid.SafeUUID.__dict__.__contains__", ["__format__"], false]

# ---------------------------------------------------------------------------
# __bytes__ bytes conversion protocol dict-presence
# ---------------------------------------------------------------------------

table uuid_extra2086.bytes_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["uu2086003", "uuid.UUID.__dict__.__contains__", ["__bytes__"], false]
    - ["uu2086004", "uuid.SafeUUID.__dict__.__contains__", ["__bytes__"], false]

# ---------------------------------------------------------------------------
# __fspath__ filesystem path protocol dict-presence
# ---------------------------------------------------------------------------

table uuid_extra2086.fspath_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["uu2086005", "uuid.UUID.__dict__.__contains__", ["__fspath__"], false]
    - ["uu2086006", "uuid.SafeUUID.__dict__.__contains__", ["__fspath__"], false]

# ---------------------------------------------------------------------------
# __buffer__ / __release_buffer__ buffer protocol dict-presence
# ---------------------------------------------------------------------------

table uuid_extra2086.buffer_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["uu2086007", "uuid.UUID.__dict__.__contains__", ["__buffer__"], false]
    - ["uu2086008", "uuid.UUID.__dict__.__contains__", ["__release_buffer__"], false]
    - ["uu2086009", "uuid.SafeUUID.__dict__.__contains__", ["__buffer__"], false]
    - ["uu2086010", "uuid.SafeUUID.__dict__.__contains__", ["__release_buffer__"], false]

# ---------------------------------------------------------------------------
# UUID class __dict__ — explicitly defined dunder and property names
# ---------------------------------------------------------------------------

table uuid_extra2086.uuid_class_dict:
  columns: [id, function, args, expected]
  rows:
    - ["uu2086011", "uuid.UUID.__dict__.__contains__", ["__init__"], true]
    - ["uu2086012", "uuid.UUID.__dict__.__contains__", ["__str__"], true]
    - ["uu2086013", "uuid.UUID.__dict__.__contains__", ["__repr__"], true]
    - ["uu2086014", "uuid.UUID.__dict__.__contains__", ["__int__"], true]
    - ["uu2086015", "uuid.UUID.__dict__.__contains__", ["__hash__"], true]
    - ["uu2086016", "uuid.UUID.__dict__.__contains__", ["__eq__"], true]
    - ["uu2086017", "uuid.UUID.__dict__.__contains__", ["__lt__"], true]
    - ["uu2086018", "uuid.UUID.__dict__.__contains__", ["__gt__"], true]
    - ["uu2086019", "uuid.UUID.__dict__.__contains__", ["__le__"], true]
    - ["uu2086020", "uuid.UUID.__dict__.__contains__", ["__ge__"], true]
    - ["uu2086021", "uuid.UUID.__dict__.__contains__", ["__setattr__"], true]
    - ["uu2086022", "uuid.UUID.__dict__.__contains__", ["bytes"], true]
    - ["uu2086023", "uuid.UUID.__dict__.__contains__", ["bytes_le"], true]
    - ["uu2086024", "uuid.UUID.__dict__.__contains__", ["hex"], true]
    - ["uu2086025", "uuid.UUID.__dict__.__contains__", ["urn"], true]
    - ["uu2086026", "uuid.UUID.__dict__.__contains__", ["fields"], true]
    - ["uu2086027", "uuid.UUID.__dict__.__contains__", ["version"], true]
    - ["uu2086028", "uuid.UUID.__dict__.__contains__", ["variant"], true]
    - ["uu2086029", "uuid.UUID.__dict__.__contains__", ["node"], true]
    - ["uu2086030", "uuid.UUID.__dict__.__contains__", ["time"], true]
    - ["uu2086031", "uuid.UUID.__dict__.__contains__", ["clock_seq"], true]
    - ["uu2086032", "uuid.UUID.__dict__.__contains__", ["time_low"], true]
    - ["uu2086033", "uuid.UUID.__dict__.__contains__", ["time_mid"], true]
    - ["uu2086034", "uuid.UUID.__dict__.__contains__", ["time_hi_version"], true]
    - ["uu2086035", "uuid.UUID.__dict__.__contains__", ["is_safe"], true]
