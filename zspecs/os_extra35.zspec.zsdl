# ---------------------------------------------------------------------------
# Standalone invariants — function __name__ string lengths
# ---------------------------------------------------------------------------

invariant os_extra35.getcwd.name_len:
  description: "os.getcwd.__name__.__len__() == 6 — 'getcwd' has 6 characters"
  category: function_attrs
  kind: python_call_eq
  function: getcwd.__name__.__len__
  args: []
  expected: 6

invariant os_extra35.listdir.name_len:
  description: "os.listdir.__name__.__len__() == 7 — 'listdir' has 7 characters"
