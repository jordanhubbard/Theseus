spec: os_extra35
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "os_extra33.zspec.zsdl — covers __module__ values for getcwd/listdir/remove/rename/getpid/cpu_count (posix) and makedirs/getenv (os) in a table; NOT __len__() on any __module__ strings."
    - "os_extra34.zspec.zsdl — covers __qualname__ for os functions; NOT __module__.__len__() or __name__.__len__() for any function."
  notes:
    - "This spec extends os.zspec.zsdl and all prior os_extra specs through os_extra34.zspec.zsdl."
    - "Prior specs covered: os.__name__/__package__, various function __name__/__module__/__qualname__, environ/__class__.__name__, sep/linesep/curdir/pardir/pathsep __class__.__name__, various attribute values."
    - "This spec covers: __module__.__len__() for getcwd/listdir/mkdir/remove/rename/stat/getpid (all 5, 'posix') and makedirs (2, 'os'); __name__.__len__() for getcwd/listdir/mkdir/makedirs."
    - "QUIRK: C-level posix wrappers (getcwd, listdir, mkdir, remove, rename, stat, getpid) have __module__ == 'posix' (len 5). Pure-Python makedirs has __module__ == 'os' (len 2)."
    - "__name__ lengths: getcwd=6, listdir=7, mkdir=5, makedirs=8."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# os C-level posix function __module__ string lengths
#
# os_extra33 covers __module__ values for getcwd/listdir/remove/rename/getpid
# in a table (all 'posix'). No prior os spec checks __len__() on these
# __module__ strings. 'posix' has 5 characters.
# ---------------------------------------------------------------------------

table os_extra35.posix_function_module_lengths:
  description: "__module__.__len__() == 5 for C-level posix function wrappers (all 'posix')"
  kind: python_call_eq
  category: function_attrs
  id_prefix: posixmodlen35

  columns: [id, function, args, expected]
  rows:
    - [getcwd,  getcwd.__module__.__len__,  [], 5]
    - [listdir, listdir.__module__.__len__, [], 5]
    - [mkdir,   mkdir.__module__.__len__,   [], 5]
    - [remove,  remove.__module__.__len__,  [], 5]
    - [rename,  rename.__module__.__len__,  [], 5]
    - [stat,    stat.__module__.__len__,    [], 5]
    - [getpid,  getpid.__module__.__len__,  [], 5]

# ---------------------------------------------------------------------------
# os function __name__ string lengths
#
# No prior os spec checks __len__() on function __name__ strings.
# Lengths: getcwd=6, listdir=7, mkdir=5, makedirs=8.
# makedirs is pure-Python (os.py); the others are C-level posix wrappers.
# ---------------------------------------------------------------------------

table os_extra35.function_name_lengths:
  description: "__name__.__len__() for os functions"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fnnlen35

  columns: [id, function, args, expected]
  rows:
    - [getcwd,   getcwd.__name__.__len__,   [], 6]
    - [listdir,  listdir.__name__.__len__,  [], 7]
    - [mkdir,    mkdir.__name__.__len__,    [], 5]
    - [makedirs, makedirs.__name__.__len__, [], 8]

# ---------------------------------------------------------------------------
# os.makedirs __module__ string length — pure-Python quirk
#
# makedirs is a pure-Python function defined in os.py so its __module__ == 'os'
# (len 2), unlike the C-level posix wrappers whose __module__ == 'posix' (len 5).
# os_extra33 confirms makedirs.__module__ == 'os'. No prior os spec checks
# makedirs.__module__.__len__().
# ---------------------------------------------------------------------------

invariant os_extra35.makedirs.module_len:
  description: "os.makedirs.__module__.__len__() == 2 — 'os' has 2 characters (pure-Python, not 'posix')"
  category: function_attrs
  kind: python_call_eq
  function: makedirs.__module__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# Standalone invariants — C-level posix function __module__ string lengths
# ---------------------------------------------------------------------------

invariant os_extra35.getcwd.module_len:
  description: "os.getcwd.__module__.__len__() == 5 — 'posix' has 5 characters"
  category: function_attrs
  kind: python_call_eq
  function: getcwd.__module__.__len__
  args: []
  expected: 5

