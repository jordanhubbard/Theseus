spec: string_extra_rust
version: ">=3.9"
backend: rust_module(string_extra_rust)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — string stdlib"
  notes:
    - "string provides common string operations."
    - "string.ascii_letters is a non-empty string."
    - "string.digits == '0123456789'."
    - "string.Template('$name').substitute(name='Alice') == 'Alice'."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant string_extra_rust.digits_correct:
  description: "string.digits == '0123456789'"
  category: constants
  kind: python_call_eq
  function: string_extra_digits
  args: []
  expected: "0123456789"

invariant string_extra_rust.ascii_letters_nonempty:
  description: "string.ascii_letters is non-empty"
  category: constants
  kind: python_call_eq
  function: string_extra_ascii_letters_nonempty
  args: []
  expected: true

invariant string_extra_rust.template_substitute:
  description: "Template('$name').substitute(name='Alice') == 'Alice'"
  category: template
  kind: python_call_eq
  function: string_extra_template_substitute
  args: []
  expected: "Alice"

