spec: struct_extra2041
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
    - "CPython source: Modules/_struct.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2041): __lshift__, __rshift__, __and__, __or__, __xor__, __invert__ dict-presence checks."
    - "struct.Struct is a binary packing type, not a bitwise type; it defines none of these bit-shift or bitwise protocols in its own __dict__."
    - "struct.error is an Exception subclass; it defines no bitwise protocols in its own __dict__."
    - "All bit-shift and bitwise dunder methods are absent from both struct.Struct.__dict__ and struct.error.__dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2041.struct_lshift_protocol:
  description: "struct.Struct __lshift__/__rlshift__/__ilshift__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2041

  columns: [id, function, args, expected]
  rows:
    - ["st2041001", "struct.Struct.__dict__.__contains__", ["__lshift__"],  false]
    - ["st2041002", "struct.Struct.__dict__.__contains__", ["__rlshift__"], false]
    - ["st2041003", "struct.Struct.__dict__.__contains__", ["__ilshift__"], false]

