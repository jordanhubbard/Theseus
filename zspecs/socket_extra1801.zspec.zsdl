spec: socket_extra1801
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python socket documentation — https://docs.python.org/3/library/socket.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "socket.zspec.zsdl — covers AF_INET/SOCK_STREAM constants, inet_aton, htonl"
    - "socket_extra.zspec.zsdl — covers additional constant and function checks"
    - "socket_extra2.zspec.zsdl — covers AddressFamily/SocketKind enum class names, gethostname/getfqdn return types, error/timeout aliases"
    - "socket_extra1786.zspec.zsdl — covers __class_getitem__/__init_subclass__ hooks; socket.socket __enter__/__exit__/__weakref__, settimeout/gettimeout/setblocking/makefile/detach/get_inheritable, send/fileno/accept/bind/connect/recv; AF_INET/SOCK_STREAM enum class names"
    - "socket_extra1771.zspec.zsdl — covers async protocol dict-presence checks for socket.socket"
  notes:
    - "Wave 567 (_extra1801): __bool__/__len__ truth-value protocol; container and context manager protocol presence."
    - "Theme: which socket types define __bool__/__len__ and context-manager/container protocol methods in their own __dict__."
    - "socket.socket.__dict__.__contains__('__bool__') -> False — socket.socket does not define a custom truth value; bool(s) defers to object.__bool__ which returns True."
    - "socket.socket.__dict__.__contains__('__len__') -> False — socket.socket is not a sized container."
    - "socket.error.__dict__.__contains__('__bool__') -> False — socket.error is an alias for OSError; OSError does not define __bool__ in its own __dict__."
    - "socket.error.__dict__.__contains__('__len__') -> False — OSError is not a container."
    - "socket.timeout.__dict__.__contains__('__bool__') -> False — socket.timeout is an alias for TimeoutError; TimeoutError does not define __bool__ in its own __dict__."
    - "socket.timeout.__dict__.__contains__('__len__') -> False — TimeoutError is not a container."
    - "socket.socket.__dict__.__contains__('__enter__') -> True — socket.socket defines __enter__ for the 'with' statement (context manager protocol)."
    - "socket.socket.__dict__.__contains__('__exit__') -> True — socket.socket defines __exit__ which closes the socket on exit."
    - "socket.socket.__dict__.__contains__('__iter__') -> False — socket.socket is not iterable."
    - "socket.socket.__dict__.__contains__('__contains__') -> False — socket.socket does not support the 'in' operator."
    - "socket.socket.__dict__.__contains__('__getitem__') -> False — socket.socket does not support subscript access."
    - "socket.socket.__dict__.__contains__('bind') -> False — bind is inherited from the C-level _socket.socket base; it is not in socket.socket's own Python-level __dict__."
    - "socket.socket.__dict__.__contains__('listen') -> False — listen is inherited from C base."
    - "socket.socket.__dict__.__contains__('accept') -> False — accept is inherited from C base."
    - "socket.socket.__dict__.__contains__('connect') -> False — connect is inherited from C base."
    - "socket.socket.__dict__.__contains__('connect_ex') -> False — connect_ex is inherited from C base."
    - "socket.socket.__dict__.__contains__('close') -> True — close is overridden in the Python-level socket.socket to handle reference counting."
    - "socket.socket.__dict__.__contains__('shutdown') -> False — shutdown is inherited from C base."
    - "socket.socket.__dict__.__contains__('setsockopt') -> False — setsockopt is inherited from C base."
    - "socket.socket.__dict__.__contains__('getsockopt') -> False — getsockopt is inherited from C base."
    - "socket.socket.__dict__.__contains__('settimeout') -> True — settimeout is defined in the Python-level socket.socket wrapper."
    - "socket.socket.__dict__.__contains__('gettimeout') -> True — gettimeout is defined in the Python-level socket.socket wrapper."
    - "socket.socket.__dict__.__contains__('fileno') -> False — fileno is inherited from C base."
    - "All expected values verified by running Python 3.14 socket module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra1801.truth_protocol:
  description: "socket.socket, socket.error, and socket.timeout __bool__/__len__ dict-presence checks — wave 567 _extra1801"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1801

  columns: [id, function, args, expected]
  rows:
    - ["sk1801001", "socket.socket.__dict__.__contains__",  ["__bool__"], false]
    - ["sk1801002", "socket.socket.__dict__.__contains__",  ["__len__"],  false]
    - ["sk1801003", "socket.error.__dict__.__contains__",   ["__bool__"], false]
    - ["sk1801004", "socket.error.__dict__.__contains__",   ["__len__"],  false]
    - ["sk1801005", "socket.timeout.__dict__.__contains__", ["__bool__"], false]
    - ["sk1801006", "socket.timeout.__dict__.__contains__", ["__len__"],  false]

table socket_extra1801.context_manager_protocol:
  description: "socket.socket context manager and container protocol dict-presence checks — wave 567 _extra1801"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1801

  columns: [id, function, args, expected]
  rows:
    - ["sk1801007", "socket.socket.__dict__.__contains__", ["__enter__"],    true]
    - ["sk1801008", "socket.socket.__dict__.__contains__", ["__exit__"],     true]
    - ["sk1801009", "socket.socket.__dict__.__contains__", ["__iter__"],     false]
    - ["sk1801010", "socket.socket.__dict__.__contains__", ["__contains__"], false]
    - ["sk1801011", "socket.socket.__dict__.__contains__", ["__getitem__"],  false]

table socket_extra1801.socket_attrs:
  description: "socket.socket method dict-presence checks — Python-wrapper vs C-inherited — wave 567 _extra1801"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1801

  columns: [id, function, args, expected]
  rows:
    - ["sk1801012", "socket.socket.__dict__.__contains__", ["bind"],        false]
    - ["sk1801013", "socket.socket.__dict__.__contains__", ["listen"],      false]
    - ["sk1801014", "socket.socket.__dict__.__contains__", ["accept"],      false]
    - ["sk1801015", "socket.socket.__dict__.__contains__", ["connect"],     false]
    - ["sk1801016", "socket.socket.__dict__.__contains__", ["connect_ex"],  false]
    - ["sk1801017", "socket.socket.__dict__.__contains__", ["close"],       true]
    - ["sk1801018", "socket.socket.__dict__.__contains__", ["shutdown"],    false]
    - ["sk1801019", "socket.socket.__dict__.__contains__", ["setsockopt"],  false]
    - ["sk1801020", "socket.socket.__dict__.__contains__", ["getsockopt"],  false]
    - ["sk1801021", "socket.socket.__dict__.__contains__", ["settimeout"],  true]
    - ["sk1801022", "socket.socket.__dict__.__contains__", ["gettimeout"],  true]
    - ["sk1801023", "socket.socket.__dict__.__contains__", ["fileno"],      false]
