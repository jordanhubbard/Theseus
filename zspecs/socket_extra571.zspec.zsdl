spec: socket_extra571
version: ">=3.9"
backend: python_module(socket)
docs: "https://docs.python.org/3/library/socket.html"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers socket module class and exception identity including enum types"
  created_at: "2026-04-12T00:00:00Z"

table socket_extra571.class_identity:
  description: "socket class and exception __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: ske571ci
  columns: [id, function, args, expected]
  rows:
    - [ske571ci001, socket.socket.__class__.__name__.__eq__, ["type"], true]
    - [ske571ci002, socket.AddressFamily.__class__.__name__.__eq__, ["EnumType"], true]
    - [ske571ci003, socket.SocketKind.__class__.__name__.__eq__, ["EnumType"], true]
    - [ske571ci004, socket.error.__class__.__name__.__eq__, ["type"], true]
    - [ske571ci005, socket.timeout.__class__.__name__.__eq__, ["type"], true]
    - [ske571ci006, socket.herror.__class__.__name__.__eq__, ["type"], true]
    - [ske571ci007, socket.gaierror.__class__.__name__.__eq__, ["type"], true]
table socket_extra571.qualname_identity:
  description: "socket class and exception __qualname__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: ske571qi
  columns: [id, function, args, expected]
  rows:
    - [ske571qi001, socket.socket.__qualname__.__eq__, ["socket"], true]
    - [ske571qi002, socket.error.__qualname__.__eq__, ["OSError"], true]
    - [ske571qi003, socket.timeout.__qualname__.__eq__, ["timeout"], true]
    - [ske571qi004, socket.AddressFamily.__qualname__.__eq__, ["AddressFamily"], true]
    - [ske571qi005, socket.SocketKind.__qualname__.__eq__, ["SocketKind"], true]
table socket_extra571.module_identity:
  description: "socket enum __module__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: ske571mi
  columns: [id, function, args, expected]
  rows:
    - [ske571mi001, socket.AddressFamily.__module__.__eq__, ["socket"], true]
    - [ske571mi002, socket.SocketKind.__module__.__eq__, ["socket"], true]