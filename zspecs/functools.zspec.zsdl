spec: functools
version: ">=3.0"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "Python functools documentation — https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14 on macOS Darwin 25.4.0, 2026-04-08"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "WRAPPER_ASSIGNMENTS on Python 3.14 is a 6-tuple: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__."
    - "__annotations__ is NOT in WRAPPER_ASSIGNMENTS on Python 3.14; it was replaced by __annotate__ and __type_params__."
    - "WRAPPER_UPDATES on Python 3.14 is a 1-tuple: ('__dict__',)."
    - "reduce is a C-level built-in: type(reduce).__name__ == 'builtin_function_or_method'."
    - "partial, cached_property are types: type(X).__name__ == 'type'."
    - "lru_cache, cache, wraps, total_ordering, singledispatch are Python functions: type(X).__name__ == 'function'."
    - "cmp_to_key is a C-level built-in: type(cmp_to_key).__name__ == 'builtin_function_or_method'."
    - "All expected values verified by running Python 3.14 on macOS Darwin 25.4.0, 2026-04-08."
  created_at: "2026-04-08T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS — tuple of attribute names copied by @wraps
#
# On Python 3.14: ('__module__', '__name__', '__qualname__', '__doc__',
#                  '__annotate__', '__type_params__')
# ---------------------------------------------------------------------------

invariant functools.wrapper_assignments.is_tuple:
  description: "WRAPPER_ASSIGNMENTS is a tuple"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools.wrapper_assignments.length:
  description: "len(WRAPPER_ASSIGNMENTS) == 6 on Python 3.14"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools.wrapper_assignments.contains_name:
  description: "WRAPPER_ASSIGNMENTS contains '__name__'"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__name__"]
  expected: true

invariant functools.wrapper_assignments.contains_qualname:
  description: "WRAPPER_ASSIGNMENTS contains '__qualname__'"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__qualname__"]
  expected: true

invariant functools.wrapper_assignments.contains_module:
  description: "WRAPPER_ASSIGNMENTS contains '__module__'"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__module__"]
  expected: true

invariant functools.wrapper_assignments.contains_doc:
  description: "WRAPPER_ASSIGNMENTS contains '__doc__'"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__doc__"]
  expected: true

invariant functools.wrapper_assignments.contains_annotate:
  description: "WRAPPER_ASSIGNMENTS contains '__annotate__' (Python 3.14 replaced __annotations__)"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__annotate__"]
  expected: true

invariant functools.wrapper_assignments.contains_type_params:
  description: "WRAPPER_ASSIGNMENTS contains '__type_params__' (Python 3.14+)"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__type_params__"]
  expected: true

# ---------------------------------------------------------------------------
# WRAPPER_UPDATES — tuple of attributes merged (not replaced) by @wraps
#
# On Python 3.14: ('__dict__',)
# ---------------------------------------------------------------------------

invariant functools.wrapper_updates.is_tuple:
  description: "WRAPPER_UPDATES is a tuple"
  category: wrapper_updates
  kind: python_call_eq
  function: WRAPPER_UPDATES.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools.wrapper_updates.length:
  description: "len(WRAPPER_UPDATES) == 1"
  category: wrapper_updates
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools.wrapper_updates.contains_dict:
  description: "WRAPPER_UPDATES contains '__dict__'"
  category: wrapper_updates
  kind: python_call_eq
  function: WRAPPER_UPDATES.__contains__
  args: ["__dict__"]
  expected: true

# ---------------------------------------------------------------------------
# callable types — verify the type of each public functools symbol
#
# reduce: C-level built-in function
# partial, cached_property: type (class objects)
# lru_cache, cache, wraps, total_ordering, singledispatch: Python functions
# cmp_to_key: C-level built-in function
# ---------------------------------------------------------------------------

invariant functools.types.reduce_is_builtin:
  description: "type(functools.reduce).__name__ == 'builtin_function_or_method'"
  category: types
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools.types.partial_is_type:
  description: "type(functools.partial).__name__ == 'type'"
  category: types
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools.types.lru_cache_is_function:
  description: "type(functools.lru_cache).__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: lru_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools.types.cache_is_function:
  description: "type(functools.cache).__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools.types.wraps_is_function:
  description: "type(functools.wraps).__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: wraps.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools.types.cached_property_is_type:
  description: "type(functools.cached_property).__name__ == 'type'"
  category: types
  kind: python_call_eq
  function: cached_property.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools.types.total_ordering_is_function:
  description: "type(functools.total_ordering).__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: total_ordering.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools.types.singledispatch_is_function:
  description: "type(functools.singledispatch).__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: singledispatch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools.types.cmp_to_key_is_builtin:
  description: "type(functools.cmp_to_key).__name__ == 'builtin_function_or_method'"
  category: types
  kind: python_call_eq
  function: cmp_to_key.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

