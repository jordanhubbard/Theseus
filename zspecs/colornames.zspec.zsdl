spec: colornames
version: ">=1.1.1"
backend: node(colornames)

docs: https://www.npmjs.com/package/colornames

provenance:
  derived_from:
    - "colornames README — https://www.npmjs.com/package/colornames"
    - "Test vectors verified with colornames via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "colornames source"
  notes:
    - "colornames is an npm package. Install: npm install colornames"
    - "Returns the hex color code for a named CSS color."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a hex color string or undefined for unknown names."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table colornames.lookup:
  kind: node_module_call_eq
  function: ~
  category: color
  id_prefix: cnames

  columns: [id, args, expected]
  rows:
    - [red,    ["red"],    "#FF0000"]
    - [blue,   ["blue"],   "#0000FF"]
    - [green,  ["green"],  "#008000"]
