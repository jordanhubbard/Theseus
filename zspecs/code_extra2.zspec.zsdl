spec: code_extra2
version: ">=3.9"
backend: python_module(code)

docs: https://docs.python.org/3/library/code.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/code.html — Python code module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/code.py"
  notes:
    - "Extends code.zspec.zsdl and code_extra.zspec.zsdl; does NOT duplicate invariants already present there."
    - "code.zspec.zsdl covers: interact.__name__, compile_command.__name__, InteractiveConsole.__name__, InteractiveInterpreter.__name__, CommandCompiler.__name__; InteractiveConsole.__module__, InteractiveConsole.__bases__[0].__name__; method names on InteractiveInterpreter; behavioral compile_command tests."
    - "code_extra.zspec.zsdl covers: InteractiveConsole.__name__/__module__, InteractiveInterpreter.__name__/__module__, InteractiveConsole.__bases__[0].__name__, CommandCompiler.__name__/__module__, compile_command.__name__, interact.__name__; InteractiveInterpreter method names table."
    - "This spec adds: InteractiveInterpreter.__bases__[0].__name__, compile_command.__module__, interact.__module__; class names table via __qualname__."
    - "code.InteractiveInterpreter.__bases__[0].__name__ == 'object' — InteractiveInterpreter is a root-level class inheriting only from object."
    - "code.compile_command is imported from the codeop module; its __module__ attribute is 'codeop'."
    - "code.interact.__module__ == 'code' — interact is defined directly in the code module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# InteractiveInterpreter — base class hierarchy (not in code.zspec or code_extra.zspec)
# ---------------------------------------------------------------------------

invariant code_extra2.InteractiveInterpreter.base_is_object:
  description: "code.InteractiveInterpreter.__bases__[0].__name__ == 'object' — inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: InteractiveInterpreter.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# compile_command — module affiliation (not in code.zspec or code_extra.zspec)
# compile_command is imported from codeop; __module__ reflects the defining module.
# ---------------------------------------------------------------------------

invariant code_extra2.compile_command.module:
  description: "code.compile_command.__module__ == 'codeop' — compile_command is imported from codeop"
  category: function_modules
  kind: python_call_eq
  function: compile_command.__module__.__eq__
  args: ["codeop"]
  expected: true

# ---------------------------------------------------------------------------
# interact — module affiliation (not in code.zspec or code_extra.zspec)
# ---------------------------------------------------------------------------

invariant code_extra2.interact.module:
  description: "code.interact.__module__ == 'code' — interact is defined in the code module"
  category: function_modules
  kind: python_call_eq
  function: interact.__module__.__eq__
  args: ["code"]
  expected: true

# ---------------------------------------------------------------------------
# class names table — InteractiveConsole, InteractiveInterpreter via __qualname__
# Complements the __name__ tables already in code.zspec and code_extra.zspec.
# ---------------------------------------------------------------------------

table code_extra2.class_qualnames:
  kind: python_call_eq
  category: class_names
  id_prefix: qualname
  columns: [id, function, args, expected]
  rows:
    - [InteractiveConsole,     InteractiveConsole.__qualname__.__eq__,     ["InteractiveConsole"],     true]
    - [InteractiveInterpreter, InteractiveInterpreter.__qualname__.__eq__, ["InteractiveInterpreter"], true]
