spec: uuid_extra1786
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python uuid documentation — https://docs.python.org/3/library/uuid.html"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "uuid_extra.zspec.zsdl — covers UUID constructor, str(), int, bytes attributes"
    - "CPython source: Lib/uuid.py"
    - "uuid_extra1771.zspec.zsdl — covers async protocol dict-presence checks for uuid.UUID (__aenter__/__aexit__/__aiter__/__anext__/__await__ all False) and complementary UUID.__dict__ checks (fields, bytes_le, bytes, node, is_safe, int, version, __init__)."
  notes:
    - "Wave 566 (_extra1786): __class_getitem__ and __init_subclass__ class creation hooks dict-presence checks."
    - "Theme: which uuid stdlib types define __class_getitem__ and __init_subclass__ in their own __dict__."
    - "uuid.UUID: a Python-level immutable class representing a 128-bit UUID value. UUID[T] is not meaningful; it does not implement generics -> __class_getitem__ False."
    - "uuid.SafeUUID: an IntEnum subclass representing whether the UUID was generated in a multiprocessing-safe manner. IntEnum and Enum do define __class_getitem__ (PEP 663 / Python 3.11+) but SafeUUID relies on the inherited version, not its own __dict__ -> False."
    - "__init_subclass__ is a classmethod added to all Python classes by the type machinery; uuid.UUID and uuid.SafeUUID do not redefine it -> both False."
    - "uuid.UUID.__dict__.__contains__('__class_getitem__') -> False — UUID is not a generic type; UUID[T] is not meaningful."
    - "uuid.UUID.__dict__.__contains__('__init_subclass__') -> False — UUID does not redefine __init_subclass__; the classmethod is inherited from object."
    - "uuid.SafeUUID.__dict__.__contains__('__class_getitem__') -> False — SafeUUID inherits __class_getitem__ from Enum/IntEnum, not its own __dict__."
    - "uuid.SafeUUID.__dict__.__contains__('__init_subclass__') -> False — SafeUUID does not redefine __init_subclass__."
    - "uuid.UUID.__dict__.__contains__('__weakref__') -> False — UUID uses __slots__, so instances cannot be weakly referenced and __weakref__ is not in the class dict."
    - "uuid.UUID.__dict__.__contains__('__abstractmethods__') -> False — UUID is a concrete class, not an ABC; __abstractmethods__ is absent."
    - "uuid.UUID.__dict__.__contains__('__slots__') -> True — UUID defines __slots__ to reduce memory usage."
    - "uuid.SafeUUID.__name__.__eq__('SafeUUID') -> True — the enum is named SafeUUID."
    - "All expected values verified by running Python 3.14 uuid module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __class_getitem__ and __init_subclass__ dict-presence checks
#          for uuid.UUID and uuid.SafeUUID
#
# Wave 566 theme: which uuid types define __class_getitem__ and
# __init_subclass__ in their own __dict__.
#
# uuid.UUID: an immutable 128-bit value class. Not a generic type.
# uuid.SafeUUID: an IntEnum subclass. Inherits __class_getitem__ from
# the Enum metaclass machinery, not defined in SafeUUID.__dict__ itself.
# Both __class_getitem__ and __init_subclass__ checks return False for
# both classes.
# ---------------------------------------------------------------------------

table uuid_extra1786.class_creation_hooks:
  description: "uuid.UUID and uuid.SafeUUID __class_getitem__ and __init_subclass__ dict-presence checks — all False — wave 566 _extra1786"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1786

  columns: [id, function, args, expected]
  rows:
    - ["uu1786001", "uuid.UUID.__dict__.__contains__",     ["__class_getitem__"],  false]
    - ["uu1786002", "uuid.UUID.__dict__.__contains__",     ["__init_subclass__"],  false]
    - ["uu1786003", "uuid.SafeUUID.__dict__.__contains__", ["__class_getitem__"],  false]
    - ["uu1786004", "uuid.SafeUUID.__dict__.__contains__", ["__init_subclass__"],  false]

# ---------------------------------------------------------------------------
# Table 2: complementary checks for uuid.UUID and uuid.SafeUUID
#
# The class-creation-hooks theme is all-False for both uuid classes.
# Complementary checks confirm genuine uuid-specific structural properties:
# - uuid.UUID uses __slots__ (no __weakref__, no __abstractmethods__)
# - uuid.UUID defines key properties in its own __dict__
# - uuid.SafeUUID is an IntEnum subclass
# - uuid.UUID.__name__ and __module__ identity
# - uuid.SafeUUID.__name__ and __module__ identity
# - uuid.UUID.__dict__.__contains__('__slots__') -> True
# - uuid.UUID.__dict__.__contains__('__weakref__') -> False (slots)
# - uuid.UUID.__dict__.__contains__('__abstractmethods__') -> False
# - uuid.UUID.__dict__.__contains__('hex') -> True (property)
# - uuid.UUID.__dict__.__contains__('urn') -> True (property)
# - uuid.UUID.__dict__.__contains__('variant') -> True (property)
# - uuid.UUID.__dict__.__contains__('time') -> True (property)
# - uuid.SafeUUID.__bases__[0].__name__.__eq__('IntEnum') -> True
# ---------------------------------------------------------------------------

table uuid_extra1786.complementary_checks:
  description: "uuid.UUID slots/property presence and uuid.SafeUUID base class checks — wave 566 _extra1786"
  kind: python_call_eq
  category: complementary
  id_prefix: uu1786

  columns: [id, function, args, expected]
  rows:
    - ["uu1786005", "uuid.UUID.__dict__.__contains__",              ["__slots__"],          true]
    - ["uu1786006", "uuid.UUID.__dict__.__contains__",              ["__weakref__"],         false]
    - ["uu1786007", "uuid.UUID.__dict__.__contains__",              ["__abstractmethods__"], false]
    - ["uu1786008", "uuid.UUID.__dict__.__contains__",              ["hex"],                 true]
    - ["uu1786009", "uuid.UUID.__dict__.__contains__",              ["urn"],                 true]
    - ["uu1786010", "uuid.UUID.__dict__.__contains__",              ["variant"],             true]
    - ["uu1786011", "uuid.UUID.__dict__.__contains__",              ["time"],                true]
    - ["uu1786012", "uuid.UUID.__dict__.__contains__",              ["fields"],              true]
    - ["uu1786013", "uuid.UUID.__dict__.__contains__",              ["is_safe"],             true]
    - ["uu1786014", "uuid.UUID.__name__.__eq__",                    ["UUID"],                true]
    - ["uu1786015", "uuid.UUID.__module__.__eq__",                  ["uuid"],                true]
    - ["uu1786016", "uuid.SafeUUID.__name__.__eq__",                ["SafeUUID"],            true]
    - ["uu1786017", "uuid.SafeUUID.__module__.__eq__",              ["uuid"],                true]
    - ["uu1786018", "uuid.SafeUUID.__bases__[0].__name__.__eq__",   ["IntEnum"],             true]
    - ["uu1786019", "uuid.UUID.__dict__.__contains__",              ["int"],                 true]
    - ["uu1786020", "uuid.UUID.__dict__.__contains__",              ["bytes"],               true]
    - ["uu1786021", "uuid.UUID.__dict__.__contains__",              ["bytes_le"],            true]
    - ["uu1786022", "uuid.UUID.__dict__.__contains__",              ["node"],                true]
    - ["uu1786023", "uuid.UUID.__dict__.__contains__",              ["version"],             true]
