spec: uuid_extra98
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant/clock_seq_hi_variant / RFC field property qualname lengths / type(UUID.hex).__name__=='property' (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__/__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length (table + invariants)."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__.__eq__ and __name__.__len__()==8 / SafeUUID.__bases__[0].__name__=='Enum' / UUID.hex/bytes/urn/fields/variant/version fget.__qualname__.__len__() (table + invariants)."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 / UUID.__setattr__.__class__.__name__=='function' / uuid3/uuid5/getnode __qualname__.__len__() / SafeUUID metaclass/module/MRO depth (table + invariants)."
    - "uuid_extra93.zspec.zsdl — covers uuid module name/spec/loader lengths / UUID/__module__/__len__()==4 / uuid1/uuid4/__module__/__len__()==4 (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra97; it does NOT duplicate invariants present in those files."
    - "Wave 268 theme: UUID NAMESPACE constants (NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500) — their __class__.__name__ ('UUID'), str() representation, hex values, and version attributes."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "str(uuid.NAMESPACE_DNS) == '6ba7b810-9dad-11d1-80b4-00c04fd430c8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "str(uuid.NAMESPACE_URL) == '6ba7b811-9dad-11d1-80b4-00c04fd430c8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "str(uuid.NAMESPACE_OID) == '6ba7b812-9dad-11d1-80b4-00c04fd430c8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "str(uuid.NAMESPACE_X500) == '6ba7b814-9dad-11d1-80b4-00c04fd430c8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.version == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.version == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.hex == '6ba7b8109dad11d180b400c04fd430c8' (len 32). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.hex == '6ba7b8119dad11d180b400c04fd430c8' (len 32). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.hex == '6ba7b8129dad11d180b400c04fd430c8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.hex == '6ba7b8149dad11d180b400c04fd430c8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All four NAMESPACE constants are version-1 UUIDs defined in RFC 4122 Appendix C. They are used as namespace arguments for uuid.uuid3() (MD5-based) and uuid.uuid5() (SHA-1-based) to generate deterministic UUIDs from names."
    - "Note: The NAMESPACE UUIDs are all in the variant 1 (RFC 4122) family and all have version==1. Their hex strings differ only in one digit: DNS=...10..., URL=...11..., OID=...12..., X500=...14... (position 7 in the hex string)."
    - "Note: NAMESPACE_DNS.hex.__len__() == 32 (UUID hex always 32 hex chars without hyphens). The str() form adds 4 hyphens for 36 total chars."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_OID.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_X500.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_DNS.version.__eq__(1)
#
# Wave 268 theme: NAMESPACE constant class names and version attributes.
#
# All four NAMESPACE constants are instances of uuid.UUID (__class__.__name__
# == 'UUID'). They are all version-1 UUIDs defined in RFC 4122 Appendix C
# as fixed namespaces for uuid3/uuid5 name-based UUID generation.
# No prior uuid spec anchors NAMESPACE_* __class__.__name__ or .version
# as a grouped table under uuidns98.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra98.NAMESPACE_class_names_and_version:
  description: "NAMESPACE_DNS.__class__.__name__.__eq__('UUID')==True / NAMESPACE_URL.__class__.__name__.__eq__('UUID')==True / NAMESPACE_OID.__class__.__name__.__eq__('UUID')==True / NAMESPACE_X500.__class__.__name__.__eq__('UUID')==True / NAMESPACE_DNS.version.__eq__(1)==True — all NAMESPACE constants are uuid.UUID instances (class name 'UUID'); all are version-1 UUIDs from RFC 4122 Appendix C; used as namespace args for uuid3/uuid5; no prior uuid spec anchors NAMESPACE __class__.__name__ or version; first uuidns98 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidns98

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_class_name,  "NAMESPACE_DNS.__class__.__name__.__eq__",   ["UUID"], true, "NAMESPACE_DNS.__class__.__name__ is 'UUID' (it is a UUID instance)"]
    - [ns_url_class_name,  "NAMESPACE_URL.__class__.__name__.__eq__",   ["UUID"], true, "NAMESPACE_URL.__class__.__name__ is 'UUID' (it is a UUID instance)"]
    - [ns_oid_class_name,  "NAMESPACE_OID.__class__.__name__.__eq__",   ["UUID"], true, "NAMESPACE_OID.__class__.__name__ is 'UUID' (it is a UUID instance)"]
    - [ns_x500_class_name, "NAMESPACE_X500.__class__.__name__.__eq__",  ["UUID"], true, "NAMESPACE_X500.__class__.__name__ is 'UUID' (it is a UUID instance)"]
    - [ns_dns_version,     "NAMESPACE_DNS.version.__eq__",              [1],      true, "NAMESPACE_DNS.version is 1 (RFC 4122 version-1 UUID used as namespace)"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.hex.__eq__('6ba7b8109dad11d180b400c04fd430c8')
# uuid.NAMESPACE_URL.hex.__eq__('6ba7b8119dad11d180b400c04fd430c8')
# uuid.NAMESPACE_OID.hex.__eq__('6ba7b8129dad11d180b400c04fd430c8')
# uuid.NAMESPACE_X500.hex.__eq__('6ba7b8149dad11d180b400c04fd430c8')
# uuid.NAMESPACE_DNS.hex.__len__()==32
#
# Wave 268 theme: NAMESPACE constant hex string values and length.
#
# The .hex attribute of each NAMESPACE UUID is a 32-character lowercase hex
# string (no hyphens). The four NAMESPACE UUIDs share the same prefix
# '6ba7b81' and differ only in position 7: DNS=0, URL=1, OID=2, X500=4.
# All are exactly 32 chars. No prior uuid spec anchors any NAMESPACE hex
# values as a grouped table under uuidns98.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra98.NAMESPACE_hex_values:
  description: "NAMESPACE_DNS.hex.__eq__('6ba7b8109dad11d180b400c04fd430c8')==True / NAMESPACE_URL.hex.__eq__('6ba7b8119dad11d180b400c04fd430c8')==True / NAMESPACE_OID.hex.__eq__('6ba7b8129dad11d180b400c04fd430c8')==True / NAMESPACE_X500.hex.__eq__('6ba7b8149dad11d180b400c04fd430c8')==True / NAMESPACE_DNS.hex.__len__()==32 — all 32-char hex strings; DNS/URL/OID/X500 differ at position 7 (0/1/2/4); RFC 4122 Appendix C constants; used for uuid3/uuid5 deterministic UUID generation; no prior uuid spec anchors NAMESPACE hex values; first uuidns98 anchor"
  kind: python_call_eq
  category: namespace_values
  id_prefix: uuidns98

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_hex_eq,   "NAMESPACE_DNS.hex.__eq__",   ["6ba7b8109dad11d180b400c04fd430c8"], true, "NAMESPACE_DNS.hex is '6ba7b8109dad11d180b400c04fd430c8' (RFC 4122 Appendix C DNS namespace)"]
    - [ns_url_hex_eq,   "NAMESPACE_URL.hex.__eq__",   ["6ba7b8119dad11d180b400c04fd430c8"], true, "NAMESPACE_URL.hex is '6ba7b8119dad11d180b400c04fd430c8' (RFC 4122 Appendix C URL namespace)"]
    - [ns_oid_hex_eq,   "NAMESPACE_OID.hex.__eq__",   ["6ba7b8129dad11d180b400c04fd430c8"], true, "NAMESPACE_OID.hex is '6ba7b8129dad11d180b400c04fd430c8' (RFC 4122 Appendix C OID namespace)"]
    - [ns_x500_hex_eq,  "NAMESPACE_X500.hex.__eq__",  ["6ba7b8149dad11d180b400c04fd430c8"], true, "NAMESPACE_X500.hex is '6ba7b8149dad11d180b400c04fd430c8' (RFC 4122 Appendix C X.500 namespace)"]
    - [ns_dns_hex_len,  "NAMESPACE_DNS.hex.__len__",  [],                                   32,   "NAMESPACE_DNS.hex is 32 chars (UUID hex always 32 hex chars without hyphens)"]

# ---------------------------------------------------------------------------
# str(uuid.NAMESPACE_DNS).__eq__('6ba7b810-9dad-11d1-80b4-00c04fd430c8')
# str(uuid.NAMESPACE_URL).__eq__('6ba7b811-9dad-11d1-80b4-00c04fd430c8')
# str(uuid.NAMESPACE_OID).__eq__('6ba7b812-9dad-11d1-80b4-00c04fd430c8')
# str(uuid.NAMESPACE_X500).__eq__('6ba7b814-9dad-11d1-80b4-00c04fd430c8')
# uuid.NAMESPACE_URL.version.__eq__(1)
#
# Wave 268 theme: NAMESPACE constant str() representation (hyphenated form).
#
# The str() form of each NAMESPACE UUID adds 4 hyphens for 36 total chars
# in the format xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx. The four NAMESPACE
# constants share the same prefix '6ba7b81' and the same suffix
# '-9dad-11d1-80b4-00c04fd430c8'. They differ only in position 7 of the
# first group: DNS=0, URL=1, OID=2, X500=4. NAMESPACE_URL.version==1
# confirms all four share the same version. No prior uuid spec anchors
# NAMESPACE str() representations as a grouped table under uuidns98.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra98.NAMESPACE_str_values:
  description: "str(NAMESPACE_DNS).__eq__('6ba7b810-9dad-11d1-80b4-00c04fd430c8')==True / str(NAMESPACE_URL).__eq__('6ba7b811-9dad-11d1-80b4-00c04fd430c8')==True / str(NAMESPACE_OID).__eq__('6ba7b812-9dad-11d1-80b4-00c04fd430c8')==True / str(NAMESPACE_X500).__eq__('6ba7b814-9dad-11d1-80b4-00c04fd430c8')==True / NAMESPACE_URL.version.__eq__(1)==True — hyphenated 36-char str form; all share '-9dad-11d1-80b4-00c04fd430c8' suffix; differ at position 7 in first group; all version-1; no prior uuid spec anchors NAMESPACE str values; first uuidns98 anchor"
  kind: python_call_eq
  category: namespace_values
  id_prefix: uuidns98

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_str_eq,   "NAMESPACE_DNS.__str__",   [], "6ba7b810-9dad-11d1-80b4-00c04fd430c8", "str(NAMESPACE_DNS) is '6ba7b810-9dad-11d1-80b4-00c04fd430c8' (hyphenated RFC 4122 form, 36 chars)"]
    - [ns_url_str_eq,   "NAMESPACE_URL.__str__",   [], "6ba7b811-9dad-11d1-80b4-00c04fd430c8", "str(NAMESPACE_URL) is '6ba7b811-9dad-11d1-80b4-00c04fd430c8' (differs from DNS at position 7)"]
    - [ns_oid_str_eq,   "NAMESPACE_OID.__str__",   [], "6ba7b812-9dad-11d1-80b4-00c04fd430c8", "str(NAMESPACE_OID) is '6ba7b812-9dad-11d1-80b4-00c04fd430c8' (OID namespace for ASN.1 object IDs)"]
    - [ns_x500_str_eq,  "NAMESPACE_X500.__str__",  [], "6ba7b814-9dad-11d1-80b4-00c04fd430c8", "str(NAMESPACE_X500) is '6ba7b814-9dad-11d1-80b4-00c04fd430c8' (X.500 distinguished name namespace)"]
    - [ns_url_version,  "NAMESPACE_URL.version.__eq__", [1], true, "NAMESPACE_URL.version is 1 (all four NAMESPACE constants are version-1 UUIDs)"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') — standalone
#
# uuid.NAMESPACE_DNS.__class__.__name__ is 'UUID'. NAMESPACE_DNS is one of
# the four predefined UUID namespace constants from RFC 4122 Appendix C.
# It is an instance of uuid.UUID with the well-known value
# 6ba7b810-9dad-11d1-80b4-00c04fd430c8. It is used as the namespace
# argument when calling uuid.uuid3(NAMESPACE_DNS, name) or
# uuid.uuid5(NAMESPACE_DNS, name) to generate DNS-based name UUIDs.
# No prior uuid spec anchors NAMESPACE_DNS.__class__.__name__ as a
# standalone under uuidns98. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra98.NAMESPACE_DNS_class_name_UUID:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — NAMESPACE_DNS is a uuid.UUID instance; RFC 4122 Appendix C predefined DNS namespace constant; value '6ba7b810-9dad-11d1-80b4-00c04fd430c8'; used as namespace arg for uuid3/uuid5 to generate DNS-based UUIDs; no prior uuid spec anchors NAMESPACE_DNS class name as standalone; first standalone under uuidns98"
  category: type_identity
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.hex.__eq__('6ba7b8109dad11d180b400c04fd430c8') — standalone
#
# uuid.NAMESPACE_DNS.hex is '6ba7b8109dad11d180b400c04fd430c8'. This is the
# 32-character hex form (without hyphens) of the DNS namespace UUID from
# RFC 4122 Appendix C. The hex property on UUID instances returns the UUID
# as a 32-char lowercase hexadecimal string. 32 chars = 16 bytes = 128 bits.
# No prior uuid spec anchors NAMESPACE_DNS.hex equality as a standalone
# under uuidns98. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra98.NAMESPACE_DNS_hex_eq:
  description: "uuid.NAMESPACE_DNS.hex.__eq__('6ba7b8109dad11d180b400c04fd430c8') == True — NAMESPACE_DNS hex is 32-char lowercase string without hyphens; hex property returns 128-bit UUID as 32 hex chars; RFC 4122 Appendix C DNS namespace constant; no prior uuid spec anchors NAMESPACE_DNS hex as standalone; first standalone under uuidns98"
  category: namespace_values
  kind: python_call_eq
  function: NAMESPACE_DNS.hex.__eq__
  args: ["6ba7b8109dad11d180b400c04fd430c8"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_URL.hex.__eq__('6ba7b8119dad11d180b400c04fd430c8') — standalone
#
# uuid.NAMESPACE_URL.hex is '6ba7b8119dad11d180b400c04fd430c8'. The URL
# namespace UUID differs from DNS by exactly one hex digit at position 7
# (0 vs 1). It is used as the namespace for generating name-based UUIDs
# for URLs (e.g., uuid5(NAMESPACE_URL, 'https://example.com')). All four
# NAMESPACE constants share the same suffix '9dad11d180b400c04fd430c8'.
# No prior uuid spec anchors NAMESPACE_URL.hex equality as a standalone
# under uuidns98. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra98.NAMESPACE_URL_hex_eq:
  description: "uuid.NAMESPACE_URL.hex.__eq__('6ba7b8119dad11d180b400c04fd430c8') == True — NAMESPACE_URL hex differs from NAMESPACE_DNS by 1 digit at position 7 (0→1); used for URL-based name UUIDs via uuid3/uuid5; all NAMESPACE hex share same suffix '9dad11d180b400c04fd430c8'; no prior uuid spec anchors NAMESPACE_URL hex as standalone; first standalone under uuidns98"
  category: namespace_values
  kind: python_call_eq
  function: NAMESPACE_URL.hex.__eq__
  args: ["6ba7b8119dad11d180b400c04fd430c8"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.version.__eq__(1) — standalone
#
# uuid.NAMESPACE_DNS.version is 1. All four NAMESPACE constants (DNS, URL,
# OID, X500) are version-1 UUIDs as defined in RFC 4122 Appendix C. However,
# they are used as *namespace arguments* for uuid3 (version 3) and uuid5
# (version 5) generation — they do not generate a v1 UUID, they ARE v1 UUIDs
# that act as namespaces. The version property on UUID returns the version
# field (bits 12-15 of the time_hi_version field). No prior uuid spec anchors
# NAMESPACE_DNS.version as a standalone under uuidns98.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra98.NAMESPACE_DNS_version_1:
  description: "uuid.NAMESPACE_DNS.version.__eq__(1) == True — NAMESPACE_DNS is a version-1 UUID (RFC 4122 Appendix C); all four NAMESPACE constants are v1 UUIDs; they act as namespace args for uuid3/uuid5 (v3/v5) — they ARE v1 UUIDs, not the output type; version property reads bits 12-15 of time_hi_version field; no prior uuid spec anchors NAMESPACE_DNS.version as standalone; first standalone under uuidns98"
  category: namespace_values
  kind: python_call_eq
  function: NAMESPACE_DNS.version.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_X500.hex.__eq__('6ba7b8149dad11d180b400c04fd430c8') — standalone
#
# uuid.NAMESPACE_X500.hex is '6ba7b8149dad11d180b400c04fd430c8'. The X.500
# namespace UUID differs from DNS at position 7: DNS=0, URL=1, OID=2, X500=4.
# Note the gap: OID=2 and X500=4 (not 3). This is the RFC 4122 defined value
# for the X.500 distinguished name namespace, used for generating UUIDs from
# X.500 distinguished names via uuid3(NAMESPACE_X500, dn) or uuid5(NAMESPACE_X500,
# dn). No prior uuid spec anchors NAMESPACE_X500.hex as a standalone
# under uuidns98. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra98.NAMESPACE_X500_hex_eq:
  description: "uuid.NAMESPACE_X500.hex.__eq__('6ba7b8149dad11d180b400c04fd430c8') == True — NAMESPACE_X500 hex has digit 4 at position 7 (DNS=0, URL=1, OID=2, X500=4; note gap at 3); used for X.500 distinguished name UUIDs via uuid3/uuid5; RFC 4122 Appendix C value; no prior uuid spec anchors NAMESPACE_X500 hex as standalone; first standalone under uuidns98"
  category: namespace_values
  kind: python_call_eq
  function: NAMESPACE_X500.hex.__eq__
  args: ["6ba7b8149dad11d180b400c04fd430c8"]
  expected: true
