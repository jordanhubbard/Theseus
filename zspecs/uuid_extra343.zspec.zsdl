spec: uuid_extra343
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid.UUID.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4().version == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1().version == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID is a pure-Python class (defined in Lib/uuid.py); its __bases__[0] is object (single-level hierarchy)."
    - "Note: NAMESPACE_DNS and NAMESPACE_URL are pre-defined UUID constants (instances of the UUID class). Their __class__.__name__ is 'UUID'."
    - "Note: NAMESPACE_DNS is '6ba7b810-9dad-11d1-80b4-00c04fd430c8' (the DNS namespace UUID from RFC 4122)."
    - "Note: NAMESPACE_URL is '6ba7b811-9dad-11d1-80b4-00c04fd430c8' (the URL namespace UUID from RFC 4122)."
    - "Note: uuid4().version == 4 because uuid4() generates a random UUID and sets the version nibble to 4 in the time_hi_and_version field."
    - "Note: uuid1().version == 1 because uuid1() generates a time-based UUID and sets the version nibble to 1."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__name__.__eq__('UUID')
# uuid.UUID.__module__.__eq__('uuid')
# uuid.UUID.__bases__[0].__name__.__eq__('object')
#
# Wave 343 theme: uuid.UUID class identity — name, module, and base class.
#
# uuid.UUID is a pure-Python class defined in Lib/uuid.py. Its __name__ is
# 'UUID' and its __module__ is 'uuid'. It is a direct subclass of object
# (single-level hierarchy — no intermediate base classes). UUID represents
# a 128-bit universally unique identifier with properties for various
# representations (hex, bytes, int, urn, etc.).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra343.uuid_class_identity:
  description: "UUID.__name__.__eq__('UUID')==True / UUID.__module__.__eq__('uuid')==True / UUID.__bases__[0].__name__.__eq__('object')==True — uuid.UUID is a pure-Python class: __name__=='UUID', __module__=='uuid', direct subclass of object (single-level hierarchy); defined in Lib/uuid.py; first uuidclassid343 anchor for UUID class identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: uuidclassid343

  columns: [id, function, args, expected, description]
  rows:
    - [uuid_class_name,   "UUID.__name__.__eq__",              ["UUID"],   true, "uuid.UUID.__name__ is 'UUID' — top-level class in the uuid module"]
    - [uuid_class_module, "UUID.__module__.__eq__",            ["uuid"],   true, "uuid.UUID.__module__ is 'uuid' — defined in Lib/uuid.py (pure-Python)"]
    - [uuid_base_name,    "UUID.__bases__[0].__name__.__eq__", ["object"], true, "uuid.UUID.__bases__[0].__name__ is 'object' — direct subclass of object, no intermediate base classes"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID')
#
# Wave 343 theme: NAMESPACE_DNS and NAMESPACE_URL are UUID instances.
#
# NAMESPACE_DNS and NAMESPACE_URL are pre-defined UUID constants defined in
# RFC 4122. Both are instances of the uuid.UUID class. Their __class__.__name__
# is 'UUID'. NAMESPACE_DNS is '6ba7b810-9dad-11d1-80b4-00c04fd430c8' and
# NAMESPACE_URL is '6ba7b811-9dad-11d1-80b4-00c04fd430c8'. These constants
# are used as namespace UUIDs for version 3 and version 5 UUID generation
# (uuid.uuid3() and uuid.uuid5()).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra343.namespace_constants_class_identity:
  description: "NAMESPACE_DNS.__class__.__name__.__eq__('UUID')==True / NAMESPACE_URL.__class__.__name__.__eq__('UUID')==True — NAMESPACE_DNS and NAMESPACE_URL are uuid.UUID instances (RFC 4122 namespace constants used for uuid3/uuid5 generation); both have __class__.__name__=='UUID'; first uuidclassid343 anchor for namespace constant class identity"
  kind: python_call_eq
  category: namespace_constants
  id_prefix: uuidclassid343

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_class,  "NAMESPACE_DNS.__class__.__name__.__eq__", ["UUID"], true, "uuid.NAMESPACE_DNS.__class__.__name__ is 'UUID' — DNS namespace constant ('6ba7b810-...') is a UUID instance"]
    - [ns_url_class,  "NAMESPACE_URL.__class__.__name__.__eq__", ["UUID"], true, "uuid.NAMESPACE_URL.__class__.__name__ is 'UUID' — URL namespace constant ('6ba7b811-...') is a UUID instance"]

# ---------------------------------------------------------------------------
# uuid.uuid4().version == 4
# uuid.uuid1().version == 1
#
# Wave 343 theme: uuid version constants for uuid4 and uuid1.
#
# uuid.uuid4() generates a random UUID and sets the version nibble to 4
# in bits 12-15 of the time_hi_and_version field (per RFC 4122 section 4.4).
# uuid.uuid1() generates a time-based UUID and sets the version nibble to 1
# (per RFC 4122 section 4.1.3). The .version property returns the version
# as a plain Python int. Both functions are non-deterministic (uuid4 is
# random, uuid1 is time-based), but the version field is always fixed.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra343.uuid4_version_is_4:
  description: "uuid.uuid4().version.__eq__(4) == True — uuid4() generates a random UUID with version nibble 4 (RFC 4122 section 4.4, bits 12-15 of time_hi_and_version field); .version returns a plain int; uuid4 is non-deterministic but version is always 4; first standalone for uuid4().version under uuidclassid343"
  category: version_constants
  kind: python_call_eq
  function: uuid4
  args: []
  method: version.__eq__
  method_args: [4]
  expected: true

invariant uuid_extra343.uuid1_version_is_1:
  description: "uuid.uuid1().version.__eq__(1) == True — uuid1() generates a time-based UUID with version nibble 1 (RFC 4122 section 4.1.3); .version returns a plain int; uuid1 is non-deterministic (time-based) but version is always 1; first standalone for uuid1().version under uuidclassid343"
  category: version_constants
  kind: python_call_eq
  function: uuid1
  args: []
  method: version.__eq__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__name__.__eq__('UUID') — standalone
#
# uuid.UUID.__name__ is 'UUID'. uuid.UUID is the central class of the uuid
# module, defined in Lib/uuid.py. It represents a universally unique
# identifier with 128 bits (16 bytes). UUID is a top-level class — its
# __name__ and __qualname__ are both 'UUID'. Unlike hashlib hash types
# (which are C-level HASH objects), uuid.UUID is a pure-Python class with
# standard Python class attributes.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra343.UUID_name_is_UUID:
  description: "uuid.UUID.__name__.__eq__('UUID') == True — UUID is a top-level pure-Python class; __name__ is 'UUID' (same as __qualname__); defined in Lib/uuid.py; represents a 128-bit universally unique identifier; unlike _hashlib HASH (C type), UUID is a Python class; first standalone for UUID.__name__ under uuidclassid343"
  category: class_identity
  kind: python_call_eq
  function: UUID.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__bases__[0].__name__.__eq__('object') — standalone
#
# uuid.UUID.__bases__[0].__name__ is 'object'. uuid.UUID is a direct
# subclass of Python's built-in object type — a single-level class
# hierarchy with no intermediate base classes. This means UUID does not
# inherit from any container, mapping, or sequence type. All UUID
# behavior is defined directly in the class. uuid.UUID uses __slots__
# for memory efficiency, storing the 128-bit integer in a C struct slot.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra343.UUID_base_is_object:
  description: "uuid.UUID.__bases__[0].__name__.__eq__('object') == True — UUID is a direct subclass of object (single-level hierarchy; no container/mapping/sequence base); uses __slots__ for memory efficiency; 128-bit integer stored in C struct slot named 'int'; first standalone for UUID.__bases__[0].__name__ under uuidclassid343"
  category: class_identity
  kind: python_call_eq
  function: "UUID.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
