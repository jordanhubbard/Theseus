spec: threading_extra99
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra98

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra98.zspec.zsdl."
    - "This spec covers: threading.Lock/__module__ identity; threading.Semaphore/Event/Condition/Barrier class identity; threading.Timer class identity and MRO; threading primitive __qualname__ and __name__ attrs; __mro__ lengths (Wave 255)."
    - "threading.Lock.__class__.__name__ == 'type' — threading.Lock is the C-extension class _thread.lock exposed as threading.Lock; it is a type (class), NOT a builtin_function_or_method. Verified with Python 3.14.3."
    - "threading.Lock.__module__ == '_thread' — Lock is actually _thread.lock, a C extension class from _threadmodule.c. Verified with Python 3.14.3."
    - "threading.Lock.__qualname__ == 'lock' — the underlying C type name is 'lock', not 'Lock'. Verified with Python 3.14.3."
    - "threading.RLock.__class__.__name__ == 'function' — threading.RLock is a factory function (not a class) defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Semaphore.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "threading.Semaphore.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Event.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "threading.Event.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Condition.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "threading.Condition.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Barrier.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "threading.Barrier.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Timer.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "threading.Timer.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer subclasses Thread. Verified with Python 3.14.3."
    - "len(threading.Timer.__mro__) == 3 — [Timer, Thread, object]. Verified with Python 3.14.3."
    - "len(threading.Semaphore.__mro__) == 2 — [Semaphore, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Lock/Semaphore/Event/Condition/Barrier class identity
#
# Wave 255 theme: threading synchronization primitive class identity.
#
# threading.Lock.__class__.__name__ == 'type'
# threading.Lock.__module__ == '_thread'
# threading.Semaphore.__class__.__name__ == 'type'
# threading.Semaphore.__module__ == 'threading'
# threading.Event.__class__.__name__ == 'type'
# threading.Event.__module__ == 'threading'
# threading.Condition.__class__.__name__ == 'type'
# threading.Condition.__module__ == 'threading'
# threading.Barrier.__class__.__name__ == 'type'
# threading.Barrier.__module__ == 'threading'
#
# threading.Lock is actually the C extension class _thread.lock (not a factory
# function); its __module__ is '_thread'. All other primitives are pure-Python
# classes defined in Lib/threading.py. New to extra99.
# ---------------------------------------------------------------------------

table threading_extra99.sync_primitive_class_identity:
  description: "threading.Lock/Semaphore/Event/Condition/Barrier __class__.__name__ and __module__; Lock is _thread.lock C type; others are Python classes in threading; wave 255; new to extra99"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingprimitive99

  columns: [id, function, args, expected, description]
  rows:
    - [lock_class_name_eq_type,
       "Lock.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Lock.__class__.__name__.__eq__('type') == True — threading.Lock is actually the C extension class _thread.lock defined in Modules/_threadmodule.c; it is a proper class (type), not a factory function; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra99"]
    - [lock_module_eq_thread,
       "Lock.__module__.__eq__",
       ["_thread"],
       true,
       "threading.Lock.__module__.__eq__('_thread') == True — threading.Lock is an alias for the C extension class _thread.lock; its __module__ attribute points to the underlying C module '_thread'; str.__eq__('_thread') returns True; new to extra99"]
    - [semaphore_class_name_eq_type,
       "Semaphore.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Semaphore.__class__.__name__.__eq__('type') == True — Semaphore is a pure-Python class defined with 'class Semaphore:' in Lib/threading.py; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra99"]
    - [semaphore_module_eq_threading,
       "Semaphore.__module__.__eq__",
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — Semaphore is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra99"]
    - [event_class_name_eq_type,
       "Event.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Event.__class__.__name__.__eq__('type') == True — Event is a pure-Python class defined in Lib/threading.py; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra99"]
    - [event_module_eq_threading,
       "Event.__module__.__eq__",
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — Event is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra99"]
    - [condition_class_name_eq_type,
       "Condition.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Condition.__class__.__name__.__eq__('type') == True — Condition is a pure-Python class defined in Lib/threading.py; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra99"]
    - [condition_module_eq_threading,
       "Condition.__module__.__eq__",
       ["threading"],
       true,
       "threading.Condition.__module__.__eq__('threading') == True — Condition is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra99"]
    - [barrier_class_name_eq_type,
       "Barrier.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Barrier.__class__.__name__.__eq__('type') == True — Barrier is a pure-Python class defined in Lib/threading.py; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra99"]
    - [barrier_module_eq_threading,
       "Barrier.__module__.__eq__",
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — Barrier is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra99"]

# ---------------------------------------------------------------------------
# Table 2: threading.Lock __qualname__ and __name__; threading.RLock identity
#
# Wave 255 theme: threading.Lock __qualname__ is 'lock' (C type name); RLock identity.
#
# threading.Lock.__qualname__ == 'lock'
# threading.Lock.__name__ == 'lock'
# threading.RLock.__class__.__name__ == 'function'
# threading.RLock.__module__ == 'threading'
#
# Lock's qualname and name are 'lock' (lowercase) because the underlying C type
# is named 'lock'. RLock is a factory function, not a class. New to extra99.
# ---------------------------------------------------------------------------

table threading_extra99.lock_qualname_rlock_identity:
  description: "threading.Lock __qualname__/__name__ == 'lock'; threading.RLock is a function; wave 255; new to extra99"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingprimitive99

  columns: [id, function, args, expected, description]
  rows:
    - [lock_qualname_eq_lock,
       "Lock.__qualname__.__eq__",
       ["lock"],
       true,
       "threading.Lock.__qualname__.__eq__('lock') == True — threading.Lock is the C extension class _thread.lock; the underlying C type name is 'lock' (lowercase); the __qualname__ attribute reflects the C type name rather than the Python alias 'Lock'; str.__eq__('lock') returns True; new to extra99"]
    - [lock_name_eq_lock,
       "Lock.__name__.__eq__",
       ["lock"],
       true,
       "threading.Lock.__name__.__eq__('lock') == True — threading.Lock is _thread.lock; the __name__ attribute is 'lock' (lowercase), matching the C type definition; str.__eq__('lock') returns True; new to extra99"]
    - [rlock_class_name_eq_function,
       "RLock.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.RLock.__class__.__name__.__eq__('function') == True — threading.RLock is a factory function defined in Lib/threading.py that returns either a _thread.RLock C object or a Python Rlock fallback; it is not a class itself; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra99"]
    - [rlock_module_eq_threading,
       "RLock.__module__.__eq__",
       ["threading"],
       true,
       "threading.RLock.__module__.__eq__('threading') == True — RLock is a factory function defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra99"]

# ---------------------------------------------------------------------------
# Table 3: threading.Timer identity and MRO lengths
#
# Wave 255 theme: threading.Timer subclasses Thread; MRO lengths for primitives.
#
# threading.Timer.__class__.__name__ == 'type'
# threading.Timer.__module__ == 'threading'
# threading.Timer.__bases__[0].__name__ == 'Thread'
# len(threading.Timer.__mro__) == 3
# len(threading.Semaphore.__mro__) == 2
# len(threading.Event.__mro__) == 2
# len(threading.Condition.__mro__) == 2
# len(threading.Barrier.__mro__) == 2
#
# Timer is a Thread subclass; its MRO is [Timer, Thread, object] (length 3).
# Semaphore/Event/Condition/Barrier all inherit directly from object (MRO length 2).
# New to extra99.
# ---------------------------------------------------------------------------

table threading_extra99.timer_mro_lengths:
  description: "threading.Timer class identity and MRO length 3; Semaphore/Event/Condition/Barrier MRO length 2; wave 255; new to extra99"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingprimitive99

  columns: [id, function, args, expected, description]
  rows:
    - [timer_class_name_eq_type,
       "Timer.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Timer.__class__.__name__.__eq__('type') == True — Timer is a pure-Python class defined in Lib/threading.py as a subclass of Thread; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra99"]
    - [timer_module_eq_threading,
       "Timer.__module__.__eq__",
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — Timer is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra99"]
    - [timer_bases_first_eq_Thread,
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer is defined as 'class Timer(Thread):' in Lib/threading.py; it inherits from Thread as its single base class; __bases__[0].__name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra99"]
    - [timer_mro_len_eq_3,
       "Timer.__mro__.__len__",
       [],
       3,
       "threading.Timer.__mro__.__len__() == 3 — the MRO of Timer is [Timer, Thread, object]; Timer inherits from Thread which inherits from object; the MRO has exactly 3 entries; len() == 3; new to extra99"]
    - [semaphore_mro_len_eq_2,
       "Semaphore.__mro__.__len__",
       [],
       2,
       "threading.Semaphore.__mro__.__len__() == 2 — Semaphore inherits directly from object with no intermediate base classes; MRO is [Semaphore, object]; len() == 2; new to extra99"]
    - [event_mro_len_eq_2,
       "Event.__mro__.__len__",
       [],
       2,
       "threading.Event.__mro__.__len__() == 2 — Event inherits directly from object; MRO is [Event, object]; len() == 2; new to extra99"]
    - [condition_mro_len_eq_2,
       "Condition.__mro__.__len__",
       [],
       2,
       "threading.Condition.__mro__.__len__() == 2 — Condition inherits directly from object; MRO is [Condition, object]; len() == 2; new to extra99"]
    - [barrier_mro_len_eq_2,
       "Barrier.__mro__.__len__",
       [],
       2,
       "threading.Barrier.__mro__.__len__() == 2 — Barrier inherits directly from object; MRO is [Barrier, object]; len() == 2; new to extra99"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra99
# ---------------------------------------------------------------------------

invariant threading_extra99.lock_class_name:
  description: "threading.Lock.__class__.__name__ == 'type' — Lock is the C extension class _thread.lock, a proper type; wave 255; new to extra99"
  kind: python_call_eq
  function: Lock.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra99.lock_module:
  description: "threading.Lock.__module__ == '_thread' — Lock is actually _thread.lock, a C extension class; wave 255; new to extra99"
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra99.rlock_class_name:
  description: "threading.RLock.__class__.__name__ == 'function' — RLock is a factory function, not a class; wave 255; new to extra99"
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra99.timer_bases_first:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer subclasses Thread; wave 255; new to extra99"
  kind: python_call_eq
  function: Timer.__bases__[0].__name__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra99.timer_mro_len:
  description: "len(threading.Timer.__mro__) == 3 — MRO is [Timer, Thread, object]; wave 255; new to extra99"
  kind: python_call_eq
  function: Timer.__mro__.__len__
  args: []
  expected: 3
