spec: io_extra259
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers io.IOBase method identity and error handling for closed file operations."
    - "io.IOBase.readline, readlines, writelines, flush, close are all C-level method_descriptor objects; their __class__.__name__ is 'method_descriptor'."
    - "io.IOBase.closed is a getset_descriptor (type(io.IOBase.closed).__name__ == 'getset_descriptor'); its __qualname__ is '_IOBase.closed'."
    - "io.IOBase method __qualname__ values carry the '_IOBase.' prefix (e.g., io.IOBase.readline.__qualname__ == '_IOBase.readline'), reflecting the C-level internal name."
    - "io.StringIO().closed == False before close(); after close() the stream is closed and most operations raise ValueError."
    - "Reading from a closed io.StringIO raises ValueError: 'I/O operation on closed file'."
    - "Reading from a closed io.BytesIO raises ValueError: 'I/O operation on closed file.'."
    - "Writing to a closed io.StringIO raises ValueError: 'I/O operation on closed file'."
    - "Seeking a closed io.StringIO raises ValueError: 'I/O operation on closed file'."
    - "Writing to a closed io.BytesIO raises ValueError: 'I/O operation on closed file.'."
    - "io.IOBase does not have a 'read' method (hasattr(io.IOBase, 'read') == False); read is defined on subclasses."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.IOBase method __name__ identity
#
# readline, readlines, writelines, flush, close are all method_descriptor
# objects defined in the _io C extension. Their __name__ values match exactly.
# ---------------------------------------------------------------------------

table io_extra259.iobase_method_names:
  description: "io.IOBase method __name__ identity — readline, readlines, writelines, flush, close; new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: ioxibmn259

  columns: [id, function, args, expected, description]
  rows:
    - [readline_name,
       "IOBase.readline.__name__.__eq__",
       ["readline"],
       true,
       "io.IOBase.readline.__name__.__eq__('readline') == True — IOBase.readline is a method_descriptor for reading up to the next newline; its __name__ is 'readline'; str.__eq__('readline') returns True; new to extra259"]
    - [readlines_name,
       "IOBase.readlines.__name__.__eq__",
       ["readlines"],
       true,
       "io.IOBase.readlines.__name__.__eq__('readlines') == True — IOBase.readlines is a method_descriptor for reading all lines into a list; its __name__ is 'readlines'; str.__eq__('readlines') returns True; new to extra259"]
    - [writelines_name,
       "IOBase.writelines.__name__.__eq__",
       ["writelines"],
       true,
       "io.IOBase.writelines.__name__.__eq__('writelines') == True — IOBase.writelines is a method_descriptor for writing a list of lines to the stream; its __name__ is 'writelines'; str.__eq__('writelines') returns True; new to extra259"]
    - [flush_name,
       "IOBase.flush.__name__.__eq__",
       ["flush"],
       true,
       "io.IOBase.flush.__name__.__eq__('flush') == True — IOBase.flush is a method_descriptor for flushing the write buffers; its __name__ is 'flush'; str.__eq__('flush') returns True; new to extra259"]
    - [close_name,
       "IOBase.close.__name__.__eq__",
       ["close"],
       true,
       "io.IOBase.close.__name__.__eq__('close') == True — IOBase.close is a method_descriptor for flushing and closing the stream; its __name__ is 'close'; str.__eq__('close') returns True; new to extra259"]

# ---------------------------------------------------------------------------
# Table 2: io.IOBase method __qualname__ identity
#
# All IOBase methods are defined on the C _IOBase type, so their __qualname__
# values carry the '_IOBase.' prefix (not 'IOBase.').
# ---------------------------------------------------------------------------

table io_extra259.iobase_method_qualnames:
  description: "io.IOBase method __qualname__ identity — all use '_IOBase.' prefix (C internal name); new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: ioxibmq259

  columns: [id, function, args, expected, description]
  rows:
    - [readline_qualname,
       "IOBase.readline.__qualname__.__eq__",
       ["_IOBase.readline"],
       true,
       "io.IOBase.readline.__qualname__.__eq__('_IOBase.readline') == True — IOBase.readline is defined on the C _IOBase type; its __qualname__ is '_IOBase.readline', not 'IOBase.readline'; str.__eq__('_IOBase.readline') returns True; new to extra259"]
    - [readlines_qualname,
       "IOBase.readlines.__qualname__.__eq__",
       ["_IOBase.readlines"],
       true,
       "io.IOBase.readlines.__qualname__.__eq__('_IOBase.readlines') == True — IOBase.readlines is defined on the C _IOBase type; its __qualname__ is '_IOBase.readlines'; str.__eq__('_IOBase.readlines') returns True; new to extra259"]
    - [writelines_qualname,
       "IOBase.writelines.__qualname__.__eq__",
       ["_IOBase.writelines"],
       true,
       "io.IOBase.writelines.__qualname__.__eq__('_IOBase.writelines') == True — IOBase.writelines is defined on the C _IOBase type; its __qualname__ is '_IOBase.writelines'; str.__eq__('_IOBase.writelines') returns True; new to extra259"]
    - [flush_qualname,
       "IOBase.flush.__qualname__.__eq__",
       ["_IOBase.flush"],
       true,
       "io.IOBase.flush.__qualname__.__eq__('_IOBase.flush') == True — IOBase.flush is defined on the C _IOBase type; its __qualname__ is '_IOBase.flush'; str.__eq__('_IOBase.flush') returns True; new to extra259"]
    - [close_qualname,
       "IOBase.close.__qualname__.__eq__",
       ["_IOBase.close"],
       true,
       "io.IOBase.close.__qualname__.__eq__('_IOBase.close') == True — IOBase.close is defined on the C _IOBase type; its __qualname__ is '_IOBase.close'; str.__eq__('_IOBase.close') returns True; new to extra259"]

# ---------------------------------------------------------------------------
# Table 3: io.IOBase method __class__.__name__ — all are method_descriptor
#
# readline, readlines, writelines, flush, close are all C-level
# method_descriptor objects, not Python functions.
# ---------------------------------------------------------------------------

table io_extra259.iobase_method_class_names:
  description: "io.IOBase method __class__.__name__ — all are 'method_descriptor'; new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: ioxibmcn259

  columns: [id, function, args, expected, description]
  rows:
    - [readline_class,
       "IOBase.readline.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.IOBase.readline.__class__.__name__.__eq__('method_descriptor') == True — IOBase.readline is a C-level method_descriptor, not a Python function; str.__eq__('method_descriptor') returns True; new to extra259"]
    - [readlines_class,
       "IOBase.readlines.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.IOBase.readlines.__class__.__name__.__eq__('method_descriptor') == True — IOBase.readlines is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra259"]
    - [writelines_class,
       "IOBase.writelines.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.IOBase.writelines.__class__.__name__.__eq__('method_descriptor') == True — IOBase.writelines is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra259"]
    - [flush_class,
       "IOBase.flush.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.IOBase.flush.__class__.__name__.__eq__('method_descriptor') == True — IOBase.flush is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra259"]
    - [close_class,
       "IOBase.close.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.IOBase.close.__class__.__name__.__eq__('method_descriptor') == True — IOBase.close is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra259"]

# ---------------------------------------------------------------------------
# Table 4: io.IOBase.closed descriptor identity
#
# io.IOBase.closed is a getset_descriptor whose __qualname__ is '_IOBase.closed'.
# It returns False before the stream is closed and True after.
# ---------------------------------------------------------------------------

table io_extra259.iobase_closed_descriptor:
  description: "io.IOBase.closed descriptor identity — getset_descriptor with _IOBase.closed qualname; new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: ioxibcd259

  columns: [id, function, args, expected, description]
  rows:
    - [closed_class,
       "IOBase.closed.__class__.__name__.__eq__",
       ["getset_descriptor"],
       true,
       "io.IOBase.closed.__class__.__name__.__eq__('getset_descriptor') == True — IOBase.closed is a C-level getset_descriptor providing read-only access to the closed state; its __class__.__name__ is 'getset_descriptor'; str.__eq__('getset_descriptor') returns True; new to extra259"]
    - [closed_name,
       "IOBase.closed.__name__.__eq__",
       ["closed"],
       true,
       "io.IOBase.closed.__name__.__eq__('closed') == True — IOBase.closed descriptor's __name__ is 'closed'; str.__eq__('closed') returns True; new to extra259"]
    - [closed_qualname,
       "IOBase.closed.__qualname__.__eq__",
       ["_IOBase.closed"],
       true,
       "io.IOBase.closed.__qualname__.__eq__('_IOBase.closed') == True — IOBase.closed is defined on the C _IOBase type; its __qualname__ is '_IOBase.closed'; str.__eq__('_IOBase.closed') returns True; new to extra259"]

# ---------------------------------------------------------------------------
# Raises invariants — closed StringIO and BytesIO operations
#
# After calling close(), reading from or writing to a StringIO or BytesIO
# raises ValueError. This is the standard contract for closed io streams.
# ---------------------------------------------------------------------------

invariant io_extra259.stringio_read_after_close_raises:
  description: "io.StringIO().close(); f.read() raises ValueError — reading from a closed StringIO raises 'I/O operation on closed file'; new to extra259"
  category: errors
  kind: python_call_raises
  function: StringIO.read
  args: []
  raises: ValueError

invariant io_extra259.bytesio_read_after_close_raises:
  description: "io.BytesIO().close(); b.read() raises ValueError — reading from a closed BytesIO raises 'I/O operation on closed file.'; new to extra259"
  category: errors
  kind: python_call_raises
  function: BytesIO.read
  args: []
  raises: ValueError

# ---------------------------------------------------------------------------
# Standalone invariants — io_extra259
# ---------------------------------------------------------------------------

invariant io_extra259.iobase_readline_name:
  description: "io.IOBase.readline.__name__ == 'readline' — IOBase.readline reads up to the next newline; new to extra259"
  kind: python_call_eq
  function: IOBase.readline.__name__.__eq__
  args: ["readline"]
  expected: true

invariant io_extra259.iobase_readline_qualname:
  description: "io.IOBase.readline.__qualname__ == '_IOBase.readline' — readline is defined on the C _IOBase type; new to extra259"
  kind: python_call_eq
  function: IOBase.readline.__qualname__.__eq__
  args: ["_IOBase.readline"]
  expected: true

invariant io_extra259.iobase_readline_is_method_descriptor:
  description: "io.IOBase.readline.__class__.__name__ == 'method_descriptor' — all IOBase methods are C-level method_descriptors; new to extra259"
  kind: python_call_eq
  function: IOBase.readline.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra259.iobase_flush_name:
  description: "io.IOBase.flush.__name__ == 'flush' — IOBase.flush flushes the write buffers of the stream; new to extra259"
  kind: python_call_eq
  function: IOBase.flush.__name__.__eq__
  args: ["flush"]
  expected: true

invariant io_extra259.iobase_close_name:
  description: "io.IOBase.close.__name__ == 'close' — IOBase.close flushes and closes the stream, releasing resources; new to extra259"
  kind: python_call_eq
  function: IOBase.close.__name__.__eq__
  args: ["close"]
  expected: true

invariant io_extra259.iobase_closed_is_getset_descriptor:
  description: "io.IOBase.closed.__class__.__name__ == 'getset_descriptor' — closed uses C getter/setter functions rather than a struct member; new to extra259"
  kind: python_call_eq
  function: IOBase.closed.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant io_extra259.iobase_closed_qualname:
  description: "io.IOBase.closed.__qualname__ == '_IOBase.closed' — closed is defined on the C _IOBase type, not 'IOBase.closed'; new to extra259"
  kind: python_call_eq
  function: IOBase.closed.__qualname__.__eq__
  args: ["_IOBase.closed"]
  expected: true

invariant io_extra259.iobase_writelines_qualname:
  description: "io.IOBase.writelines.__qualname__ == '_IOBase.writelines' — writelines is defined on the C _IOBase type; new to extra259"
  kind: python_call_eq
  function: IOBase.writelines.__qualname__.__eq__
  args: ["_IOBase.writelines"]
  expected: true
