spec: turndown
version: ">=7.0.0"
backend: node(turndown)

docs: https://github.com/mixmark-io/turndown#readme

provenance:
  derived_from:
    - "Turndown README — https://github.com/mixmark-io/turndown#readme"
    - "Test vectors verified with turndown via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "turndown source"
  notes:
    - "HTML → Markdown converter — the inverse direction of showdown / marked."
    - "Install: npm install turndown"
    - "v7 CJS; module export IS the TurndownService class."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure conversion; never throws on string HTML."
  stderr: "null"
  stickiness: "N/A — each TurndownService independent."
  codes: {}

invariant turndown.h1_setext_default:
  description: "<h1>Hello</h1> becomes 'Hello' followed by '=====' (setext default)"
  category: render
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: turndown, args: ["<h1>Hello</h1>"]}
  expected: "Hello\n====="

invariant turndown.bold:
  description: "<strong> becomes ** wrapping"
  category: render
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: turndown, args: ["<p><strong>bold</strong></p>"]}
  expected: "**bold**"

invariant turndown.italic_underscore_default:
  description: "<em> becomes _italic_ (underscore default per CommonMark)"
  category: render
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: turndown, args: ["<p><em>italic</em></p>"]}
  expected: "_italic_"

invariant turndown.link:
  description: "<a href=...> becomes [text](url)"
  category: render
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: turndown, args: ["<p><a href=\"http://example.com\">link</a></p>"]}
  expected: "[link](http://example.com)"

invariant turndown.bullet_list:
  description: "<ul><li> becomes '*' bullets (default)"
  category: render
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: turndown, args: ["<ul><li>a</li><li>b</li></ul>"]}
  expected: "*   a\n*   b"

invariant turndown.option_atx_headers:
  description: "{headingStyle:'atx'} produces '# Hello' instead of setext"
  category: options
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: [{headingStyle: "atx"}]
  chain:
    - {method: turndown, args: ["<h1>Hello</h1>"]}
  expected: "# Hello"

invariant turndown.option_dash_bullets:
  description: "{bulletListMarker:'-'} produces dash bullets"
  category: options
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: [{bulletListMarker: "-"}]
  chain:
    - {method: turndown, args: ["<ul><li>a</li></ul>"]}
  expected: "-   a"

invariant turndown.empty_input:
  description: "Empty HTML returns empty string"
  category: edge
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: turndown, args: [""]}
  expected: ""

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:54:59Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
