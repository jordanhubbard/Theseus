spec: decimal_extra318
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal integer/float conversion and as_tuple() invariants
# All test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0.
# Decimal(42).__str__() == '42'
# Decimal(42).__class__.__name__ == 'Decimal'
# Decimal(0).__bool__() == False; Decimal(-1).__bool__() == True
# Decimal('1.5').as_tuple().__class__.__name__ == 'DecimalTuple'
# Decimal('1.5').as_tuple().sign == 0; .exponent == -1
# Decimal('-1.5').as_tuple().sign == 1; .exponent == -1
# ---------------------------------------------------------------------------

invariant decimal_extra318.Decimal.int_str_42:
  description: "decimal.Decimal(42).__str__().__eq__('42') == True — integer-constructed Decimal stringifies without decimal point; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal(42).__str__().__eq__"
  args: ["42"]
  expected: true

invariant decimal_extra318.Decimal.class_name:
  description: "decimal.Decimal(42).__class__.__name__ == 'Decimal' — Decimal instances report class name 'Decimal'; verified Python 3.14.3"
  category: classnames
  kind: python_call_eq
  function: "Decimal(42).__class__.__name__.__eq__"
  args: ["Decimal"]
  expected: true

invariant decimal_extra318.Decimal.bool_zero_false:
  description: "decimal.Decimal(0).__bool__() == False — integer zero Decimal is falsy; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal(0).__bool__"
  args: []
  expected: false

invariant decimal_extra318.Decimal.bool_neg_one_true:
  description: "decimal.Decimal(-1).__bool__() == True — negative integer Decimal is truthy; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal(-1).__bool__"
  args: []
  expected: true

invariant decimal_extra318.Decimal.as_tuple_class_name:
  description: "decimal.Decimal('1.5').as_tuple().__class__.__name__ == 'DecimalTuple' — as_tuple() returns a DecimalTuple named tuple; verified Python 3.14.3"
  category: classnames
  kind: python_call_eq
  function: "Decimal('1.5').as_tuple().__class__.__name__.__eq__"
  args: ["DecimalTuple"]
  expected: true

invariant decimal_extra318.Decimal.as_tuple_sign_positive:
  description: "decimal.Decimal('1.5').as_tuple().sign.__eq__(0) == True — positive Decimal has sign field 0; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('1.5').as_tuple().sign.__eq__"
  args: [0]
  expected: true

invariant decimal_extra318.Decimal.as_tuple_exponent:
  description: "decimal.Decimal('1.5').as_tuple().exponent.__eq__(-1) == True — '1.5' has one decimal place so exponent is -1; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('1.5').as_tuple().exponent.__eq__"
  args: [-1]
  expected: true

invariant decimal_extra318.Decimal.as_tuple_sign_negative:
  description: "decimal.Decimal('-1.5').as_tuple().sign.__eq__(1) == True — negative Decimal has sign field 1; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('-1.5').as_tuple().sign.__eq__"
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# decimal.Decimal integer construction — table form
# ---------------------------------------------------------------------------

table decimal_extra318.decimal_int_construction:
  description: "decimal.Decimal integer construction: __str__, __class__.__name__, __bool__ for 42, 0, -1"
  kind: python_call_eq
  category: behavioral
  id_prefix: decimalint318

  columns: [id, function, args, expected]
  rows:
    - [str_42,        "Decimal(42).__str__().__eq__",          ["42"], true]
    - [class_name,    "Decimal(42).__class__.__name__.__eq__", ["Decimal"], true]
    - [bool_zero,     "Decimal(0).__bool__",                   [],     false]
    - [bool_neg_one,  "Decimal(-1).__bool__",                  [],     true]

# ---------------------------------------------------------------------------
# decimal.Decimal.as_tuple() field values — table form
# ---------------------------------------------------------------------------

table decimal_extra318.decimal_as_tuple_fields:
  description: "decimal.Decimal.as_tuple() fields: class name, sign and exponent for '1.5' and '-1.5'"
  kind: python_call_eq
  category: behavioral
  id_prefix: decimaltuple318

  columns: [id, function, args, expected]
  rows:
    - [tuple_cls,      "Decimal('1.5').as_tuple().__class__.__name__.__eq__", ["DecimalTuple"], true]
    - [pos_sign,       "Decimal('1.5').as_tuple().sign.__eq__",               [0],              true]
    - [pos_exponent,   "Decimal('1.5').as_tuple().exponent.__eq__",           [-1],             true]
    - [neg_sign,       "Decimal('-1.5').as_tuple().sign.__eq__",              [1],              true]
    - [neg_exponent,   "Decimal('-1.5').as_tuple().exponent.__eq__",          [-1],             true]
