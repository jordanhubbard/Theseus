spec: is_ip
version: ">=5.0.1"
backend: node(is-ip)

docs: https://www.npmjs.com/package/is-ip

provenance:
  derived_from:
    - "is-ip README — https://www.npmjs.com/package/is-ip"
    - "Test vectors verified with is-ip via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-ip source"
  notes:
    - "is-ip is an npm package. Install: npm install is-ip"
    - "Checks whether a string is a valid IPv4 or IPv6 address."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_ip.isIP:
  kind: node_module_call_eq
  function: isIP
  category: network
  id_prefix: isip

  columns: [id, args, expected]
  rows:
    - [ipv4,     ["192.168.0.1"],  true]
    - [ipv6,     ["::1"],          true]
    - [invalid,  ["not-an-ip"],    false]

table is_ip.isIPv4:
  kind: node_module_call_eq
  function: isIPv4
  category: network
  id_prefix: isipv4

  columns: [id, args, expected]
  rows:
    - [valid,   ["192.168.0.1"],  true]
    - [ipv6,    ["::1"],          false]
    - [invalid, ["foo"],          false]

table is_ip.isIPv6:
  kind: node_module_call_eq
  function: isIPv6
  category: network
  id_prefix: isipv6

  columns: [id, args, expected]
  rows:
    - [valid,   ["::1"],          true]
    - [ipv4,    ["192.168.0.1"],  false]
    - [invalid, ["foo"],          false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:28:01Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
