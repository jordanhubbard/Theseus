spec: concurrent_futures_extra1306
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 534 (_extra1306): focuses on exception-raising behavior for bad argument types and values."
    - "concurrent.futures.ThreadPoolExecutor(max_workers=-1) raises ValueError — max_workers must be > 0."
    - "concurrent.futures.ThreadPoolExecutor(max_workers=0) raises ValueError — max_workers must be > 0."
    - "concurrent.futures.ThreadPoolExecutor(max_workers='a') raises TypeError — str vs int comparison."
    - "concurrent.futures.ProcessPoolExecutor(max_workers=-1) raises ValueError — max_workers must be > 0."
    - "concurrent.futures.ProcessPoolExecutor(max_workers=0) raises ValueError — max_workers must be > 0."
    - "concurrent.futures.ProcessPoolExecutor(max_workers='a') raises TypeError — str vs int comparison."
    - "concurrent.futures.wait(42) raises TypeError — 'int' object is not iterable."
    - "concurrent.futures.wait('hello') raises AttributeError — 'str' object has no attribute '_condition'."
    - "concurrent.futures.as_completed(42) raises TypeError — 'int' object is not iterable."
    - "concurrent.futures.as_completed(None) raises TypeError — 'NoneType' object is not iterable."
    - "All exceptions verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table concurrent_futures_extra1306.thread_pool_errors:
  description: "concurrent.futures.ThreadPoolExecutor raises ValueError for non-positive max_workers and TypeError for non-integer max_workers"
  kind: python_call_raises
  category: constructor_errors
  id_prefix: cf1306tp
  columns: [id, function, args, exception]
  rows:
    - [cf1306tp001, concurrent.futures.ThreadPoolExecutor, [{max_workers: -1}], "ValueError"]
    - [cf1306tp002, concurrent.futures.ThreadPoolExecutor, [{max_workers: 0}],  "ValueError"]
    - [cf1306tp003, concurrent.futures.ThreadPoolExecutor, [{max_workers: -10}],"ValueError"]
    - [cf1306tp004, concurrent.futures.ThreadPoolExecutor, [{max_workers: "a"}],"TypeError"]
    - [cf1306tp005, concurrent.futures.ThreadPoolExecutor, [{max_workers: "1"}],"TypeError"]
    - [cf1306tp006, concurrent.futures.ThreadPoolExecutor, [{max_workers: []}],  "TypeError"]

table concurrent_futures_extra1306.process_pool_errors:
  description: "concurrent.futures.ProcessPoolExecutor raises ValueError for non-positive max_workers and TypeError for non-integer max_workers"
  kind: python_call_raises
  category: constructor_errors
  id_prefix: cf1306pp
  columns: [id, function, args, exception]
  rows:
    - [cf1306pp001, concurrent.futures.ProcessPoolExecutor, [{max_workers: -1}], "ValueError"]
    - [cf1306pp002, concurrent.futures.ProcessPoolExecutor, [{max_workers: 0}],  "ValueError"]
    - [cf1306pp003, concurrent.futures.ProcessPoolExecutor, [{max_workers: -10}],"ValueError"]
    - [cf1306pp004, concurrent.futures.ProcessPoolExecutor, [{max_workers: "a"}],"TypeError"]
    - [cf1306pp005, concurrent.futures.ProcessPoolExecutor, [{max_workers: "1"}],"TypeError"]
    - [cf1306pp006, concurrent.futures.ProcessPoolExecutor, [{max_workers: 1.5}],"TypeError"]

table concurrent_futures_extra1306.wait_and_as_completed_errors:
  description: "concurrent.futures.wait and as_completed raise TypeError or AttributeError for non-iterable or non-Future arguments"
  kind: python_call_raises
  category: type_errors
  id_prefix: cf1306wc
  columns: [id, function, args, exception]
  rows:
    - [cf1306wc001, concurrent.futures.wait,         [42],    "TypeError"]
    - [cf1306wc002, concurrent.futures.wait,         [null],  "TypeError"]
    - [cf1306wc003, concurrent.futures.wait,         ["hello"],"AttributeError"]
    - [cf1306wc004, concurrent.futures.as_completed, [42],    "TypeError"]
    - [cf1306wc005, concurrent.futures.as_completed, [null],  "TypeError"]
    - [cf1306wc006, concurrent.futures.as_completed, [true],  "TypeError"]
