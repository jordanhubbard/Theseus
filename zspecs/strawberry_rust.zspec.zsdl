spec: strawberry_rust
version: ">=3.9"
backend: rust_module(strawberry_rust)

docs: https://strawberry.rocks/

provenance:
  derived_from:
    - "https://strawberry.rocks/ — Strawberry GraphQL"
  notes:
    - "Strawberry provides type-annotation-based GraphQL framework."
    - "strawberry.Schema is a class."
    - "strawberry.type is a decorator."
    - "strawberry.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant strawberry_rust.has_schema:
  description: "strawberry.Schema is a class"
  category: presence
  kind: python_call_eq
  function: strawberry_has_schema
  args: []
  expected: true

invariant strawberry_rust.has_type_decorator:
  description: "strawberry.type is callable"
  category: presence
  kind: python_call_eq
  function: strawberry_has_type_decorator
  args: []
  expected: true

invariant strawberry_rust.version_nonempty:
  description: "strawberry.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: strawberry_version_nonempty
  args: []
  expected: true

