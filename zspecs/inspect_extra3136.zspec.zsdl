spec: in3136
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 656 (in3136): __call__, __len__, __getitem__ dict-presence checks for inspect types."
    - "No inspect type defines __call__, __len__, or __getitem__ in its own __dict__."
    - "inspect.Signature is callable at runtime (sig(*args, **kwargs) binds arguments), but __call__ is not defined in inspect.Signature.__dict__; callability is inherited from object via tp_call."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3136.call:
  description: "inspect types __call__ dict-presence checks; wave 656"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in3136
  columns: [id, function, args, expected]
  rows:
    - ["in3136001", operator.contains, [inspect.Parameter.__dict__,           "__call__"], false]
    - ["in3136002", operator.contains, [inspect.Signature.__dict__,           "__call__"], false]
    - ["in3136003", operator.contains, [inspect.BoundArguments.__dict__,      "__call__"], false]
    - ["in3136004", operator.contains, [inspect.FrameInfo.__dict__,           "__call__"], false]
    - ["in3136005", operator.contains, [inspect.ArgInfo.__dict__,             "__call__"], false]
    - ["in3136006", operator.contains, [inspect.FullArgSpec.__dict__,         "__call__"], false]
    - ["in3136007", operator.contains, [inspect.Attribute.__dict__,           "__call__"], false]
    - ["in3136008", operator.contains, [inspect.ClassFoundException.__dict__, "__call__"], false]
    - ["in3136009", operator.contains, [inspect.EndOfBlock.__dict__,          "__call__"], false]

