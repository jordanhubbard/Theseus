spec: hmac_extra
version: ">=3.7"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"
  - "FIPS 198-1 — The Keyed-Hash Message Authentication Code (HMAC)"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "FIPS 198-1 — The Keyed-Hash Message Authentication Code (HMAC), July 2008"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "OpenSSL HMAC implementation: crypto/hmac/hmac.c"
  notes:
    - "This spec extends hmac.zspec.zsdl with aspects not covered there."
    - "hmac.new.__name__ == 'new' — the function attribute, not the class name."
    - "hmac.digest.__name__ == 'digest' — Python 3.7+ one-shot convenience function."
    - "hmac.compare_digest.__name__ == 'compare_digest' — constant-time comparison."
    - "hmac.new(b'key', b'msg', 'sha256').__class__.__name__ == 'HMAC' — returns an HMAC instance."
    - "hmac.new(b'key', b'msg', 'md5').digest_size == 16 — MD5 produces 16 bytes."
    - "hmac.compare_digest(b'abc', b'abc') == True — bytes overload works identically to str overload."
    - "hmac.new(b'', b'', 'sha256').hexdigest().__class__.__name__ == 'str' — hexdigest always returns str."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ attributes — distinct from __class__.__name__ checks in
# hmac.zspec.zsdl which verify the callable type (function/builtin).
# ---------------------------------------------------------------------------

table hmac_extra.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, description, function, args, expected]
  rows:
    - [new,             "new.__name__ == 'new'",                         new.__name__.__eq__,             ["new"],             true]
    - [digest,          "digest.__name__ == 'digest'",                   digest.__name__.__eq__,          ["digest"],          true]
    - [compare_digest,  "compare_digest.__name__ == 'compare_digest'",   compare_digest.__name__.__eq__,  ["compare_digest"],  true]

# ---------------------------------------------------------------------------
# hmac.new() — return type is an HMAC instance
# ---------------------------------------------------------------------------

invariant hmac_extra.new_returns_HMAC:
  description: "new(b'key', b'msg', 'sha256').__class__.__name__ == 'HMAC'"
  category: return_types
  kind: python_call_eq
  function: new
  args:
    - {type: bytes_ascii, value: "key"}
    - {type: bytes_ascii, value: "msg"}
    - "sha256"
  method: __class__.__name__.__eq__
  method_args: ["HMAC"]
  expected: true

# ---------------------------------------------------------------------------
# hmac.new() — MD5 digest_size == 16
# (hmac.zspec.zsdl covers SHA-256 and SHA-1 digest_size; MD5 is new here)
# ---------------------------------------------------------------------------

invariant hmac_extra.new_md5_digest_size:
  description: "new(b'key', b'msg', 'md5').digest_size == 16 — MD5 produces 16 bytes"
  category: properties
  rfc: "FIPS 198-1"
  kind: python_call_eq
  function: new
  args:
    - {type: bytes_ascii, value: "key"}
    - {type: bytes_ascii, value: "msg"}
    - "md5"
  method: digest_size
  expected: 16

# ---------------------------------------------------------------------------
# hmac.compare_digest — bytes overload
# hmac.zspec.zsdl covers string overloads; these cover the bytes overload.
# ---------------------------------------------------------------------------

table hmac_extra.compare_digest.bytes:
  kind: python_call_eq
  category: compare_digest
  id_prefix: compare_digest_bytes

  columns: [id, description, args, expected]
  rows:
    - [bytes_equal,   "compare_digest(b'abc', b'abc') == True",
        [{type: bytes_ascii, value: "abc"}, {type: bytes_ascii, value: "abc"}], true]
    - [bytes_unequal, "compare_digest(b'abc', b'def') == False",
        [{type: bytes_ascii, value: "abc"}, {type: bytes_ascii, value: "def"}], false]
    - [bytes_empty_equal, "compare_digest(b'', b'') == True",
        [{type: bytes_ascii, value: ""}, {type: bytes_ascii, value: ""}], true]

  function: compare_digest

# ---------------------------------------------------------------------------
# hexdigest() — always returns str
# ---------------------------------------------------------------------------

invariant hmac_extra.hexdigest_returns_str:
  description: "new(b'', b'', 'sha256').hexdigest().__class__.__name__ == 'str'"
  category: return_types
  kind: python_call_eq
  function: new
  args:
    - {type: bytes_ascii, value: ""}
    - {type: bytes_ascii, value: ""}
    - "sha256"
  method: hexdigest().__class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant hmac_extra.hexdigest_sha256_len:
  description: "new(b'', b'', 'sha256').hexdigest() has length 64 — SHA-256 hex is always 64 chars"
  category: properties
  kind: python_call_eq
  function: new
  args:
    - {type: bytes_ascii, value: ""}
    - {type: bytes_ascii, value: ""}
    - "sha256"
  method: hexdigest().__len__
  method_args: []
  expected: 64

invariant hmac_extra.hexdigest_md5_len:
  description: "new(b'', b'', 'md5').hexdigest() has length 32 — MD5 hex is always 32 chars"
  category: properties
  kind: python_call_eq
  function: new
  args:
    - {type: bytes_ascii, value: ""}
    - {type: bytes_ascii, value: ""}
    - "md5"
  method: hexdigest().__len__
  method_args: []
  expected: 32

# ---------------------------------------------------------------------------
# HMAC class and module metadata — mirrors hmac.zspec.zsdl for cross-reference
# with distinct invariant IDs scoped to this spec.
# ---------------------------------------------------------------------------

invariant hmac_extra.HMAC_class_name:
  description: "HMAC.__name__ == 'HMAC'"
  category: class_metadata
  kind: python_call_eq
  function: HMAC.__name__.__eq__
  args: ["HMAC"]
  expected: true

invariant hmac_extra.HMAC_module:
  description: "HMAC.__module__ == 'hmac'"
  category: class_metadata
  kind: python_call_eq
  function: HMAC.__module__.__eq__
  args: ["hmac"]
  expected: true
