spec: asyncio_extra26
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec extends asyncio.zspec.zsdl and prior extras through asyncio_extra25.zspec.zsdl."
    - "asyncio_extra18 covers: Task/Future/Queue/Lock/Event/Semaphore __qualname__ eq table."
    - "asyncio_extra25 covers: PriorityQueue/LifoQueue qualnames; Semaphore/BoundedSemaphore/Event/Condition method qualnames."
    - "NOT yet covered in any prior spec: asyncio.Queue.__module__ (== 'asyncio.queues') in extra26 namespace."
    - "NOT yet covered: asyncio.PriorityQueue.__module__ and asyncio.LifoQueue.__module__ in extra26 namespace."
    - "NOT yet covered: asyncio.Lock.__module__ and asyncio.Event.__module__ in extra26 namespace."
    - "NOT yet covered: asyncio.Semaphore.__module__ in extra26 namespace."
    - "NOT yet covered: asyncio.Task.__module__ (== '_asyncio', C extension) in extra26 namespace."
    - "NOT yet covered: asyncio.Future.__module__ (== '_asyncio', C extension) in extra26 namespace."
    - "NOT yet covered: asyncio.create_task/__qualname__ and __module__ in extra26 namespace."
    - "NOT yet covered: asyncio.sleep/__qualname__ and __module__ in extra26 namespace."
    - "NOT yet covered: asyncio.gather/__qualname__ and __module__ in extra26 namespace."
    - "Queue.__module__ == 'asyncio.queues' — length 14."
    - "PriorityQueue.__module__ == 'asyncio.queues' — length 14."
    - "LifoQueue.__module__ == 'asyncio.queues' — length 14."
    - "Lock.__module__ == 'asyncio.locks' — length 13."
    - "Event.__module__ == 'asyncio.locks' — length 13."
    - "Semaphore.__module__ == 'asyncio.locks' — length 13."
    - "Task.__module__ == '_asyncio' — C-extension module (length 8)."
    - "Future.__module__ == '_asyncio' — C-extension module (length 8)."
    - "create_task.__qualname__ == 'create_task' — module-level coroutine function (length 11)."
    - "create_task.__module__ == 'asyncio.tasks' — length 13."
    - "sleep.__qualname__ == 'sleep' — module-level coroutine function (length 5)."
    - "sleep.__module__ == 'asyncio.tasks' — length 13."
    - "gather.__qualname__ == 'gather' — module-level coroutine function (length 6)."
    - "gather.__module__ == 'asyncio.tasks' — length 13."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Queue class __module__ table — extra26 namespace
#
# asyncio.Queue, PriorityQueue, and LifoQueue are all defined in
# asyncio.queues. No prior spec checks their __module__ values.
# All have __module__ == 'asyncio.queues' (length 14).
# ---------------------------------------------------------------------------

table asyncio_extra26.queue_class_modules:
  description: "asyncio Queue class __module__ values in extra26 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: qclsmod26

  columns: [id, function, args, expected]
  rows:
    - [Queue,         Queue.__module__.__eq__,         ["asyncio.queues"], true]
    - [PriorityQueue, PriorityQueue.__module__.__eq__, ["asyncio.queues"], true]
    - [LifoQueue,     LifoQueue.__module__.__eq__,     ["asyncio.queues"], true]

# ---------------------------------------------------------------------------
# Queue class __module__ length table — extra26 namespace
#
# All three queue classes have __module__ length 14.
# ---------------------------------------------------------------------------

table asyncio_extra26.queue_class_module_lengths:
  description: "asyncio Queue class __module__ lengths in extra26 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: qclsmodlen26

  columns: [id, function, args, expected]
  rows:
    - [Queue,         Queue.__module__.__len__,         [], 14]
    - [PriorityQueue, PriorityQueue.__module__.__len__, [], 14]
    - [LifoQueue,     LifoQueue.__module__.__len__,     [], 14]

# ---------------------------------------------------------------------------
# Lock primitive class __module__ table — extra26 namespace
#
# asyncio.Lock, Event, and Semaphore are all defined in asyncio.locks.
# No prior spec checks their __module__ values.
# All have __module__ == 'asyncio.locks' (length 13).
# ---------------------------------------------------------------------------

table asyncio_extra26.lock_class_modules:
  description: "asyncio lock primitive class __module__ values in extra26 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: lkclsmod26

  columns: [id, function, args, expected]
  rows:
    - [Lock,      Lock.__module__.__eq__,      ["asyncio.locks"], true]
    - [Event,     Event.__module__.__eq__,     ["asyncio.locks"], true]
    - [Semaphore, Semaphore.__module__.__eq__, ["asyncio.locks"], true]

# ---------------------------------------------------------------------------
# Lock primitive class __module__ length table — extra26 namespace
#
# All three lock classes have __module__ length 13.
# ---------------------------------------------------------------------------

table asyncio_extra26.lock_class_module_lengths:
  description: "asyncio lock primitive class __module__ lengths in extra26 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: lkclsmodlen26

  columns: [id, function, args, expected]
  rows:
    - [Lock,      Lock.__module__.__len__,      [], 13]
    - [Event,     Event.__module__.__len__,     [], 13]
    - [Semaphore, Semaphore.__module__.__len__, [], 13]

# ---------------------------------------------------------------------------
# Module-level coroutine function __qualname__ table — extra26 namespace
#
# asyncio.create_task, sleep, and gather are module-level coroutine functions
# defined in asyncio.tasks. No prior spec checks their __qualname__ values.
# create_task.__qualname__ == 'create_task' (length 11).
# sleep.__qualname__ == 'sleep' (length 5).
# gather.__qualname__ == 'gather' (length 6).
# ---------------------------------------------------------------------------

table asyncio_extra26.task_function_qualnames:
  description: "asyncio module-level coroutine function __qualname__ values in extra26 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: tfqn26

  columns: [id, function, args, expected]
  rows:
    - [create_task, create_task.__qualname__.__eq__, ["create_task"], true]
    - [sleep,       sleep.__qualname__.__eq__,       ["sleep"],       true]
    - [gather,      gather.__qualname__.__eq__,      ["gather"],      true]

# ---------------------------------------------------------------------------
# Module-level coroutine function __module__ table — extra26 namespace
#
# All three functions are defined in asyncio.tasks (length 13).
# No prior spec checks these __module__ values.
# ---------------------------------------------------------------------------

table asyncio_extra26.task_function_modules:
  description: "asyncio module-level coroutine function __module__ values in extra26 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: tfmod26

  columns: [id, function, args, expected]
  rows:
    - [create_task, create_task.__module__.__eq__, ["asyncio.tasks"], true]
    - [sleep,       sleep.__module__.__eq__,       ["asyncio.tasks"], true]
    - [gather,      gather.__module__.__eq__,      ["asyncio.tasks"], true]

# ---------------------------------------------------------------------------
# Task and Future __module__ — standalone extra26 invariants
#
# asyncio.Task and asyncio.Future are C-extension types implemented in
# _asynciomodule.c and exposed via the _asyncio module. Their __module__
# is '_asyncio' (length 8), not 'asyncio'. No prior spec checks this.
# ---------------------------------------------------------------------------

invariant asyncio_extra26.Task.module:
  description: "asyncio.Task.__module__ == '_asyncio' — Task is a C-extension type"
  category: method_names
  kind: python_call_eq
  function: Task.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra26.Future.module:
  description: "asyncio.Future.__module__ == '_asyncio' — Future is a C-extension type"
  category: method_names
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["_asyncio"]
  expected: true
