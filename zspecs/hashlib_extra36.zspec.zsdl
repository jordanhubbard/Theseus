spec: hashlib_extra36
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra35.zspec.zsdl — covers HASH.name.__len__() for md5/sha1/sha256/sha512; md5/sha1 block_size/digest_size; sha3_256.digest_size; sha3_512.block_size/digest_size."
    - "hashlib_extra33.zspec.zsdl — covers HASH method __qualname__.__len__(); HASH.__mro__.__len__(); sha3_512/shake_128/shake_256 __name__.__len__(); algorithms_guaranteed/__class__/__name__.__len__()==3."
    - "hashlib_extra32.zspec.zsdl — covers sha1/sha512/sha224/sha384 __module__.__len__()==8; blake2b/blake2s __module__/__name__.__len__(); new/__module__/__name__.__len__(); sha3_256 __name__/__module__.__len__()."
    - "hashlib_extra31.zspec.zsdl — covers md5/sha1/sha256/sha512/sha224/sha384 __name__.__len__(); md5/sha1/sha256/sha512 __module__.__eq__('_hashlib')."
    - "hashlib_extra28.zspec.zsdl — covers sha3_256/sha3_512/blake2b/blake2s __qualname__.__eq__ and __qualname__.__len__()."
    - "hashlib_extra25.zspec.zsdl — covers algorithms_guaranteed/__class__/__qualname__; algorithms_guaranteed/__len__()==14; isdisjoint(set())."
    - "hashlib_extra24.zspec.zsdl — covers __qualname__.__len__() for md5/sha1/sha256/sha512/sha224/sha384/new/pbkdf2_hmac."
    - "hashlib_extra19.zspec.zsdl — covers sha256/sha512 hexdigest_len (64 and 128)."
    - "hashlib_extra12.zspec.zsdl — covers sha256/sha1/md5 digest().__len__() via method_chain."
  notes:
    - "This spec extends hashlib through hashlib_extra35; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: md5/sha1/sha256/sha512/sha224/sha384 __name__.__len__() (extra31); sha3_256/sha3_512/blake2b/blake2s/shake_128/shake_256 __name__.__len__() (extra32/extra33); sha3_256/sha3_512/blake2b/blake2s __qualname__.__len__() (extra28); md5/sha1/sha256/sha512/sha224/sha384/new/pbkdf2_hmac __qualname__.__len__() (extra24); algorithms_guaranteed class name/qualname/len (extra25/extra26/extra33); HASH method qualname lens (extra33); HASH digest_size/block_size (extra14/extra23/extra35); hexdigest string lengths (extra19); digest() byte lengths (extra12); sha3_512 block_size/digest_size (extra35)."
    - "This spec covers: sha3_224.__name__.__len__() (NOVEL — extra32 covers sha3_256 __name__.__len__(); extra33 covers sha3_512; sha3_224 not covered by any prior spec via __len__()); sha3_384.__name__.__len__() (NOVEL — same gap); sha3_224.__module__.__len__() (NOVEL — extra32 covers sha3_256.__module__.__len__()==8; sha3_224 not covered); sha3_384.__module__.__len__() (NOVEL — same); hashlib.__spec__.__name__.__len__() (NOVEL — no prior spec checks __spec__.__name__.__len__() for hashlib); hashlib.__loader__.__class__.__name__.__len__() (NOVEL — 'SourceFileLoader' is 16 chars; no prior spec checks __loader__.__class__.__name__ for hashlib); shake_128.__qualname__.__len__() (NOVEL — extra33 covers shake_128.__name__.__len__(); no prior spec checks __qualname__.__len__() for shake_128); shake_256.__qualname__.__len__() (NOVEL — same; extra13 covers shake_256.__qualname__.__eq__ not __len__())."
    - "hashlib.sha3_224.__name__ == 'openssl_sha3_224' (len 16). extra32 covers sha3_256.__name__.__len__()==16; extra33 covers sha3_512.__name__.__len__()==16; sha3_224 not covered by any prior spec via __len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__name__ == 'openssl_sha3_384' (len 16). Same gap as sha3_224. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__module__ == '_hashlib' (len 8). No prior spec checks __module__.__len__() for sha3_224. extra32 covers sha3_256.__module__.__len__()==8. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__module__ == '_hashlib' (len 8). No prior spec checks __module__.__len__() for sha3_384. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.__name__ == 'hashlib' (len 7). No prior spec checks __spec__.__name__.__len__() for the hashlib module itself. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' (len 16). hashlib.py is a pure-Python module backed by importlib.machinery.SourceFileLoader. No prior spec checks the loader class name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__qualname__ == 'openssl_shake_128' (len 17). extra33 covers shake_128.__name__.__len__()==17 but NOT __qualname__.__len__(). On OpenSSL-backed CPython 3.12, __name__ and __qualname__ are identical for these C extension types. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__qualname__ == 'openssl_shake_256' (len 17). extra13 covers shake_256.__qualname__.__eq__ but no prior spec checks __qualname__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: sha3_224 and sha3_384 __name__.__len__() and __module__.__len__()
#
# extra32 covers sha3_256 __name__.__len__()==16 and __module__.__len__()==8.
# extra33 covers sha3_512 __name__.__len__()==16 and __module__.__len__()==8.
# sha3_224 and sha3_384 have the same structure (OpenSSL-backed, module
# '_hashlib') but neither their __name__.__len__() nor __module__.__len__()
# has been checked in any prior spec.
# sha3_224.__name__ == 'openssl_sha3_224' -> len 16
# sha3_384.__name__ == 'openssl_sha3_384' -> len 16
# sha3_224.__module__ == '_hashlib' -> len 8
# sha3_384.__module__ == '_hashlib' -> len 8
# ---------------------------------------------------------------------------

table hashlib_extra36.sha3_224_sha3_384_name_module_lens:
  description: "sha3_224/sha3_384 __name__.__len__()==16 and __module__.__len__()==8 — novel; extra32 covers sha3_256 and extra33 covers sha3_512 but sha3_224/sha3_384 are absent"
  kind: python_call_eq
  category: hash_introspection
  id_prefix: hs3nm36

  columns: [id, function, args, expected]
  rows:
    - [sha3_224_name_len,   sha3_224.__name__.__len__,   [], 16]
    - [sha3_384_name_len,   sha3_384.__name__.__len__,   [], 16]
    - [sha3_224_module_len, sha3_224.__module__.__len__,  [], 8]
    - [sha3_384_module_len, sha3_384.__module__.__len__,  [], 8]

# ---------------------------------------------------------------------------
# hashlib.__spec__.__name__.__len__() and __loader__.__class__.__name__.__len__()
#
# No prior hashlib spec checks module-level import machinery attributes.
# hashlib.__spec__.__name__ == 'hashlib' -> len 7
# hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' -> len 16
# hashlib is a pure-Python module loaded by importlib.machinery.SourceFileLoader.
# ---------------------------------------------------------------------------

invariant hashlib_extra36.module_spec_name_len:
  description: "hashlib.__spec__.__name__.__len__() == 7 — 'hashlib' has 7 characters; novel module-level import machinery check"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__name__.__len__
  args: []
  expected: 7

invariant hashlib_extra36.module_loader_class_name_len:
  description: "hashlib.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters; hashlib is a pure-Python module"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# shake_128 and shake_256 __qualname__.__len__()
#
# extra33 covers shake_128.__name__.__len__()==17 and shake_256.__name__.__len__()==17.
# No prior spec checks __qualname__.__len__() for either.
# On OpenSSL-backed CPython 3.12, __qualname__ == __name__ for these C extension
# types (both 'openssl_shake_128' and 'openssl_shake_256', length 17 each).
# extra13 covers shake_256.__qualname__.__eq__ but not __qualname__.__len__().
# ---------------------------------------------------------------------------

invariant hashlib_extra36.shake_128_qualname_len:
  description: "hashlib.shake_128.__qualname__.__len__() == 17 — 'openssl_shake_128' has 17 characters; novel __qualname__.__len__() check (extra33 covers __name__.__len__ only)"
  category: hash_introspection
  kind: python_call_eq
  function: shake_128.__qualname__.__len__
  args: []
  expected: 17

invariant hashlib_extra36.shake_256_qualname_len:
  description: "hashlib.shake_256.__qualname__.__len__() == 17 — 'openssl_shake_256' has 17 characters; extra13 covers __qualname__.__eq__ not __len__()"
  category: hash_introspection
  kind: python_call_eq
  function: shake_256.__qualname__.__len__
  args: []
  expected: 17
