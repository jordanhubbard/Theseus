invariant inspect_extra256.Signature.bind_partial_qualname:
  description: "inspect.Signature.bind_partial.__qualname__ == 'Signature.bind_partial'; new to extra256"
  category: identity
  kind: python_call_eq
  function: Signature.bind_partial.__qualname__.__eq__
  args: ["Signature.bind_partial"]
