invariant inspect_extra256.Signature.base_is_object:
  description: "inspect.Signature.__bases__[0].__name__ == 'object' — inherits from object; new to extra256"
  category: identity
  kind: python_call_eq
  function: "Signature.__bases__[0].__name__.__eq__"
