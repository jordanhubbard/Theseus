spec: inspect_extra256
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.BoundArguments and inspect.Signature class and method identity contracts."
    - "inspect.BoundArguments.__name__ == 'BoundArguments' — class name. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__module__ == 'inspect' — defined in inspect. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.3."
    - "inspect.BoundArguments.apply_defaults.__name__ == 'apply_defaults' — method name. Verified with Python 3.14.3."
    - "inspect.BoundArguments.apply_defaults.__qualname__ == 'BoundArguments.apply_defaults' — bound method qualname. Verified with Python 3.14.3."
    - "inspect.BoundArguments.args.__class__.__name__ == 'property' — args is a property descriptor. Verified with Python 3.14.3."
    - "inspect.BoundArguments.kwargs.__class__.__name__ == 'property' — kwargs is a property descriptor. Verified with Python 3.14.3."
    - "inspect.BoundArguments.args.fget.__name__ == 'args' — property getter name. Verified with Python 3.14.3."
    - "inspect.BoundArguments.kwargs.fget.__name__ == 'kwargs' — property getter name. Verified with Python 3.14.3."
    - "inspect.Signature.__name__ == 'Signature' — class name. Verified with Python 3.14.3."
    - "inspect.Signature.__module__ == 'inspect' — defined in inspect. Verified with Python 3.14.3."
    - "inspect.Signature.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.3."
    - "inspect.Signature.bind.__qualname__ == 'Signature.bind' — method qualname. Verified with Python 3.14.3."
    - "inspect.Signature.bind_partial.__qualname__ == 'Signature.bind_partial' — method qualname. Verified with Python 3.14.3."
    - "inspect.Signature.replace.__qualname__ == 'Signature.replace' — method qualname. Verified with Python 3.14.3."
    - "inspect.Signature.parameters.__class__.__name__ == 'property' — parameters is a property descriptor. Verified with Python 3.14.3."
    - "inspect.Signature.parameters.fget.__name__ == 'parameters' — property getter name. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.BoundArguments class identity contracts
#
# inspect.BoundArguments.__name__                          == 'BoundArguments'
# inspect.BoundArguments.__module__                        == 'inspect'
# inspect.BoundArguments.__bases__[0].__name__             == 'object'
# inspect.BoundArguments.__class__.__name__                == 'type'
# inspect.BoundArguments.apply_defaults.__qualname__       == 'BoundArguments.apply_defaults'
#
# BoundArguments is a pure-Python class in inspect. New to extra256.
# ---------------------------------------------------------------------------

table inspect_extra256.boundarguments_identity:
  description: "inspect.BoundArguments class name, module, base, class, apply_defaults qualname contracts; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: ibnd256

  columns: [id, function, args, expected, description]
  rows:
    - [ba_name_eq,
       BoundArguments.__name__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — class name; new to extra256"]
    - [ba_module_eq,
       BoundArguments.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — defined in inspect module; new to extra256"]
    - [ba_base_name_eq,
       "BoundArguments.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra256"]
    - [ba_class_name_eq,
       BoundArguments.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.BoundArguments.__class__.__name__.__eq__('type') == True — it is a class; metaclass is type; new to extra256"]
    - [ba_apply_defaults_qualname_eq,
       BoundArguments.apply_defaults.__qualname__.__eq__,
       ["BoundArguments.apply_defaults"],
       true,
       "inspect.BoundArguments.apply_defaults.__qualname__.__eq__('BoundArguments.apply_defaults') == True — method qualname; new to extra256"]

# ---------------------------------------------------------------------------
# Table 2: inspect.BoundArguments property descriptor contracts
#
# inspect.BoundArguments.args.__class__.__name__    == 'property'
# inspect.BoundArguments.kwargs.__class__.__name__  == 'property'
# inspect.BoundArguments.args.fget.__name__         == 'args'
# inspect.BoundArguments.kwargs.fget.__name__       == 'kwargs'
# inspect.BoundArguments.apply_defaults.__name__    == 'apply_defaults'
#
# args and kwargs are property descriptors on BoundArguments. New to extra256.
# ---------------------------------------------------------------------------

table inspect_extra256.boundarguments_properties:
  description: "inspect.BoundArguments args, kwargs property descriptor and fget name contracts; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: ibndprop256

  columns: [id, function, args, expected, description]
  rows:
    - [ba_args_class_eq,
       BoundArguments.args.__class__.__name__.__eq__,
       ["property"],
       true,
       "inspect.BoundArguments.args.__class__.__name__.__eq__('property') == True — args is a property descriptor; new to extra256"]
    - [ba_kwargs_class_eq,
       BoundArguments.kwargs.__class__.__name__.__eq__,
       ["property"],
       true,
       "inspect.BoundArguments.kwargs.__class__.__name__.__eq__('property') == True — kwargs is a property descriptor; new to extra256"]
    - [ba_args_fget_name_eq,
       BoundArguments.args.fget.__name__.__eq__,
       ["args"],
       true,
       "inspect.BoundArguments.args.fget.__name__.__eq__('args') == True — property getter is named 'args'; new to extra256"]
    - [ba_kwargs_fget_name_eq,
       BoundArguments.kwargs.fget.__name__.__eq__,
       ["kwargs"],
       true,
       "inspect.BoundArguments.kwargs.fget.__name__.__eq__('kwargs') == True — property getter is named 'kwargs'; new to extra256"]
    - [ba_apply_defaults_name_eq,
       BoundArguments.apply_defaults.__name__.__eq__,
       ["apply_defaults"],
       true,
       "inspect.BoundArguments.apply_defaults.__name__.__eq__('apply_defaults') == True — method name; new to extra256"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Signature class and method identity contracts
#
# inspect.Signature.__name__                        == 'Signature'
# inspect.Signature.__module__                      == 'inspect'
# inspect.Signature.__bases__[0].__name__           == 'object'
# inspect.Signature.bind.__qualname__               == 'Signature.bind'
# inspect.Signature.bind_partial.__qualname__       == 'Signature.bind_partial'
#
# Signature is a pure-Python class in inspect. New to extra256.
# ---------------------------------------------------------------------------

table inspect_extra256.signature_identity:
  description: "inspect.Signature class name, module, base, bind/bind_partial qualname contracts; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: isig256

  columns: [id, function, args, expected, description]
  rows:
    - [sig_name_eq,
       Signature.__name__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — class name; new to extra256"]
    - [sig_module_eq,
       Signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — defined in inspect module; new to extra256"]
    - [sig_base_name_eq,
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra256"]
    - [sig_bind_qualname_eq,
       Signature.bind.__qualname__.__eq__,
       ["Signature.bind"],
       true,
       "inspect.Signature.bind.__qualname__.__eq__('Signature.bind') == True — bind method qualname; new to extra256"]
    - [sig_bind_partial_qualname_eq,
       Signature.bind_partial.__qualname__.__eq__,
       ["Signature.bind_partial"],
       true,
       "inspect.Signature.bind_partial.__qualname__.__eq__('Signature.bind_partial') == True — bind_partial method qualname; new to extra256"]

# ---------------------------------------------------------------------------
# Table 4: inspect.Signature replace, parameters property, and class contracts
#
# inspect.Signature.replace.__qualname__           == 'Signature.replace'
# inspect.Signature.parameters.__class__.__name__  == 'property'
# inspect.Signature.parameters.fget.__name__       == 'parameters'
# inspect.Signature.__class__.__name__             == 'type'
# inspect.Signature.bind.__name__                  == 'bind'
#
# New to extra256.
# ---------------------------------------------------------------------------

table inspect_extra256.signature_methods:
  description: "inspect.Signature replace qualname, parameters property, class, bind name contracts; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: isigm256

  columns: [id, function, args, expected, description]
  rows:
    - [sig_replace_qualname_eq,
       Signature.replace.__qualname__.__eq__,
       ["Signature.replace"],
       true,
       "inspect.Signature.replace.__qualname__.__eq__('Signature.replace') == True — replace method qualname; new to extra256"]
    - [sig_parameters_class_eq,
       Signature.parameters.__class__.__name__.__eq__,
       ["property"],
       true,
       "inspect.Signature.parameters.__class__.__name__.__eq__('property') == True — parameters is a property descriptor; new to extra256"]
    - [sig_parameters_fget_name_eq,
       Signature.parameters.fget.__name__.__eq__,
       ["parameters"],
       true,
       "inspect.Signature.parameters.fget.__name__.__eq__('parameters') == True — property getter is named 'parameters'; new to extra256"]
    - [sig_class_name_eq,
       Signature.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Signature.__class__.__name__.__eq__('type') == True — it is a class; metaclass is type; new to extra256"]
    - [sig_bind_name_eq,
       Signature.bind.__name__.__eq__,
       ["bind"],
       true,
       "inspect.Signature.bind.__name__.__eq__('bind') == True — bind method name; new to extra256"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra256
# ---------------------------------------------------------------------------

invariant inspect_extra256.BoundArguments.name_eq:
  description: "inspect.BoundArguments.__name__ == 'BoundArguments' — class name; new to extra256"
  category: identity
  kind: python_call_eq
  function: BoundArguments.__name__.__eq__
  args: ["BoundArguments"]
  expected: true

invariant inspect_extra256.BoundArguments.module_eq:
  description: "inspect.BoundArguments.__module__ == 'inspect' — defined in inspect; new to extra256"
  category: identity
  kind: python_call_eq
  function: BoundArguments.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra256.BoundArguments.base_is_object:
  description: "inspect.BoundArguments.__bases__[0].__name__ == 'object' — inherits from object; new to extra256"
  category: identity
  kind: python_call_eq
  function: "BoundArguments.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra256.BoundArguments.apply_defaults_qualname:
  description: "inspect.BoundArguments.apply_defaults.__qualname__ == 'BoundArguments.apply_defaults'; new to extra256"
  category: identity
  kind: python_call_eq
  function: BoundArguments.apply_defaults.__qualname__.__eq__
  args: ["BoundArguments.apply_defaults"]
  expected: true

invariant inspect_extra256.BoundArguments.args_is_property:
  description: "inspect.BoundArguments.args.__class__.__name__ == 'property' — args is a property descriptor; new to extra256"
  category: identity
  kind: python_call_eq
  function: BoundArguments.args.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant inspect_extra256.BoundArguments.kwargs_is_property:
  description: "inspect.BoundArguments.kwargs.__class__.__name__ == 'property' — kwargs is a property descriptor; new to extra256"
  category: identity
  kind: python_call_eq
  function: BoundArguments.kwargs.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant inspect_extra256.Signature.name_eq:
  description: "inspect.Signature.__name__ == 'Signature' — class name; new to extra256"
  category: identity
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra256.Signature.module_eq:
  description: "inspect.Signature.__module__ == 'inspect' — defined in inspect; new to extra256"
  category: identity
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
