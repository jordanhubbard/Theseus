# ---------------------------------------------------------------------------

invariant collections_extra.userlist.class_name:
  description: "UserList.__name__ == 'UserList'"
  category: userlist
  kind: python_call_eq
  function: UserList.__name__.__eq__
  args: ["UserList"]
  expected: true

invariant collections_extra.userlist.module_name:
  description: "UserList.__module__ == 'collections'"
  category: userlist
  kind: python_call_eq
  function: UserList.__module__.__eq__
  args: ["collections"]
  expected: true

# ---------------------------------------------------------------------------
# UserString — class identity
# ---------------------------------------------------------------------------

invariant collections_extra.userstring.class_name:
  description: "UserString.__name__ == 'UserString'"
  category: userstring
  kind: python_call_eq
  function: UserString.__name__.__eq__
  args: ["UserString"]
  expected: true

invariant collections_extra.userstring.module_name:
  description: "UserString.__module__ == 'collections'"
  category: userstring
  kind: python_call_eq
  function: UserString.__module__.__eq__
  args: ["collections"]
  expected: true
