# ---------------------------------------------------------------------------

invariant collections_extra.userdict.class_name:
  description: "UserDict.__name__ == 'UserDict'"
  category: userdict
  kind: python_call_eq
  function: UserDict.__name__.__eq__
  args: ["UserDict"]
  expected: true

invariant collections_extra.userdict.module_name:
  description: "UserDict.__module__ == 'collections'"
  category: userdict
  kind: python_call_eq
  function: UserDict.__module__.__eq__
  args: ["collections"]
  expected: true

# ---------------------------------------------------------------------------
