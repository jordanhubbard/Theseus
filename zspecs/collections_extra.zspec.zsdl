spec: collections_extra
version: ">=3.3"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec covers aspects not in collections.zspec.zsdl: __module__ checks, UserDict/UserList/UserString class names, deque maxlen=5 and None-maxlen, and Counter(['a','b','a']) list input."
    - "deque.__module__ is 'collections' because deque is exposed from collections even though its C implementation is in _collections."
    - "UserDict, UserList, UserString are pure-Python wrappers in collections with __module__ == 'collections'."
    - "deque(maxlen=5) sets a bounded maximum length; deque([1,2,3]).maxlen is None when no maxlen is given."
    - "Counter(['a','b','a'])['a'] == 2 — list input counts element occurrences."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# deque — module identity
# ---------------------------------------------------------------------------

invariant collections_extra.deque.module_name:
  description: "deque.__module__ == 'collections'"
  category: deque
  kind: python_call_eq
  function: deque.__module__.__eq__
  args: ["collections"]
  expected: true

# ---------------------------------------------------------------------------
# deque — maxlen with bound and without bound
#
# deque(maxlen=5).maxlen == 5
# deque([1,2,3]).maxlen is None — no maxlen argument means unbounded (None)
# ---------------------------------------------------------------------------

invariant collections_extra.deque.maxlen_five:
  description: "deque(maxlen=5).maxlen == 5"
  category: deque
  kind: python_call_eq
  function: deque
  args: []
  kwargs: {maxlen: 5}
  method: maxlen
  expected: 5

invariant collections_extra.deque.maxlen_none:
  description: "deque([1,2,3]).maxlen is None — unbounded deque has maxlen None"
  category: deque
  kind: python_call_eq
  function: deque
  args: [[1, 2, 3]]
  method: maxlen
  expected: null

# ---------------------------------------------------------------------------
# ChainMap — module identity
# ---------------------------------------------------------------------------

invariant collections_extra.chainmap.module_name:
  description: "ChainMap.__module__ == 'collections'"
  category: chainmap
  kind: python_call_eq
  function: ChainMap.__module__.__eq__
  args: ["collections"]
  expected: true

# ---------------------------------------------------------------------------
# Counter — module identity and list input counting
#
# Counter(['a','b','a'])['a'] == 2 — list input counts element occurrences
# ---------------------------------------------------------------------------

invariant collections_extra.counter.module_name:
  description: "Counter.__module__ == 'collections'"
  category: counter
  kind: python_call_eq
  function: Counter.__module__.__eq__
  args: ["collections"]
  expected: true

invariant collections_extra.counter.list_a_count:
  description: "Counter(['a','b','a'])['a'] == 2 — 'a' appears twice in list"
  category: counter
  kind: python_call_eq
  function: Counter
  args: [["a", "b", "a"]]
  method: __getitem__
  method_args: ["a"]
  expected: 2

invariant collections_extra.counter.list_b_count:
  description: "Counter(['a','b','a'])['b'] == 1 — 'b' appears once in list"
  category: counter
  kind: python_call_eq
  function: Counter
  args: [["a", "b", "a"]]
  method: __getitem__
  method_args: ["b"]
  expected: 1

# ---------------------------------------------------------------------------
# defaultdict — module identity
# ---------------------------------------------------------------------------

invariant collections_extra.defaultdict.module_name:
  description: "defaultdict.__module__ == 'collections'"
  category: defaultdict
  kind: python_call_eq
  function: defaultdict.__module__.__eq__
  args: ["collections"]
  expected: true

