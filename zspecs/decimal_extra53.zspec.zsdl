spec: decimal_extra53
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra52.zspec.zsdl — covers Decimal/Context __repr__.__class__.__name__.__eq__('wrapper_descriptor'); DecimalException/InvalidOperation __repr__.__class__.__name__.__eq__('wrapper_descriptor'); Decimal/Context __hash__.__class__.__name__.__eq__('wrapper_descriptor')."
    - "decimal_extra51.zspec.zsdl — covers Decimal/Context __class__.__module__.__eq__('builtins'); DecimalException/InvalidOperation/DivisionByZero/Overflow/Underflow/Clamped __class__.__module__.__eq__('builtins')."
    - "decimal_extra50.zspec.zsdl — covers Decimal/Context/DecimalException/InvalidOperation/DivisionByZero __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy'); decimal module __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy')."
    - "decimal_extra49.zspec.zsdl — covers all 8 decimal exception __module__=='decimal' equality and __module__.__class__.__name__=='str'."
    - "decimal_extra45.zspec.zsdl — covers ROUND_HALF_DOWN/ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN/ROUND_05UP __class__.__module__=='builtins'."
    - "decimal_extra43.zspec.zsdl — covers Decimal/__class__.__name__.__eq__('type'); Context/__class__.__name__.__eq__('type')."
    - "decimal_extra29.zspec.zsdl — covers Decimal/Context/DecimalException __dict__.__class__.__name__.__len__()==12."
  notes:
    - "This spec extends decimal_extra52.zspec.zsdl."
    - "Prior specs collectively covered: decimal_extra52 covers __repr__.__class__.__name__ and __hash__.__class__.__name__ for Decimal/Context/DecimalException/InvalidOperation; decimal_extra51 covers __class__.__module__ for decimal types. NOT YET COVERED: decimal module does NOT define __all__ (confirmed: hasattr(decimal, '__all__') == False) — no prior decimal spec documents this absence; novel observation; Decimal.__eq__.__class__.__name__.__eq__('wrapper_descriptor') — no prior decimal spec checks __eq__.__class__.__name__ for any decimal class; novel; Context/DecimalException/InvalidOperation __eq__.__class__.__name__.__eq__('wrapper_descriptor') — all three inherit object.__eq__ as wrapper_descriptor; novel."
    - "IMPORTANT: The decimal module does NOT define __all__. Verified: hasattr(decimal, '__all__') == False. Accessing decimal.__all__ raises AttributeError. This is a documented characteristic of the decimal module — it does not expose a __all__ list. No prior decimal spec documents this. This spec records the absence via a python_call_eq invariant checking decimal.__dict__.__contains__('__all__') == False."
    - "decimal.Decimal.__eq__.__class__.__name__ == 'wrapper_descriptor'. Decimal is a C-extension type from the _decimal module. Decimal defines __eq__ in its own __dict__ (confirmed: '__eq__' in Decimal.__dict__ == True). The __eq__.__qualname__ is 'Decimal.__eq__'. It is a C-level slot wrapper — a wrapper_descriptor. Decimal defines both __eq__ and __hash__, making instances hashable. No prior decimal spec checks __eq__.__class__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.Context.__eq__.__class__.__name__ == 'wrapper_descriptor'. Context is a C-extension type that does NOT define __eq__ in its own __dict__ (confirmed: '__eq__' in Context.__dict__ == False; Context.__eq__ is object.__eq__ == True). It inherits object.__eq__, which is a wrapper_descriptor. __eq__.__qualname__ == 'object.__eq__'. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.DecimalException.__eq__.__class__.__name__ == 'wrapper_descriptor'. DecimalException is a pure-Python ArithmeticError subclass. It does NOT define __eq__ in its own __dict__ (confirmed: '__eq__' in DecimalException.__dict__ == False; DecimalException.__eq__ is object.__eq__ == True). Inherits object.__eq__ as wrapper_descriptor. __eq__.__qualname__ == 'object.__eq__'. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.InvalidOperation.__eq__.__class__.__name__ == 'wrapper_descriptor'. InvalidOperation is a DecimalException subclass. Same inheritance from object.__eq__. __eq__.__qualname__ == 'object.__eq__'. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal module has no __all__ attribute
#
# The decimal module does NOT define __all__. This is confirmed by:
#   hasattr(decimal, '__all__') == False
# Accessing decimal.__all__ raises AttributeError.
#
# This differs from io (24 entries), pathlib (7 entries), and re (31 entries),
# which all define __all__. The decimal module deliberately omits __all__ and
# relies on conventional underscore-prefixed names for private names.
#
# This is confirmed via: decimal.__dict__.__contains__('__all__') == False.
# No prior decimal spec documents the absence of __all__.
# This invariant is novel in the decall53 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant decimal_extra53.no_all_in_module_dict:
  description: "decimal module has no __all__ attribute — decimal.__dict__.__contains__('__all__') == False; hasattr(decimal, '__all__') == False; the decimal module does not define __all__ unlike io (24 entries), pathlib (7 entries), and re (31 entries); no prior decimal spec documents this absence; novel observation in decall53 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["__all__"]
  expected: false

# ---------------------------------------------------------------------------
# decimal Decimal/Context __eq__.__class__.__name__ == 'wrapper_descriptor'
#
# Decimal is a C-extension type that defines __eq__ in its own __dict__
# (confirmed: '__eq__' in Decimal.__dict__ == True; __eq__.__qualname__ ==
# 'Decimal.__eq__'). Decimal defines both __eq__ and __hash__, so instances
# are hashable. The __eq__ is a C-level slot wrapper — a wrapper_descriptor.
#
# Context is a C-extension type that does NOT define __eq__ in its own
# __dict__ (confirmed: '__eq__' in Context.__dict__ == False;
# Context.__eq__ is object.__eq__ == True). It inherits object.__eq__,
# which is also a wrapper_descriptor.
#
#   Decimal.__eq__.__class__.__name__ == 'wrapper_descriptor'
#   Context.__eq__.__class__.__name__ == 'wrapper_descriptor'
#
# No prior decimal spec checks __eq__.__class__.__name__ for any decimal class.
# Both anchors are novel in the decall53 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra53.cext_eq_class_name:
  description: "decimal Decimal/Context __eq__.__class__.__name__.__eq__('wrapper_descriptor') — Decimal defines __eq__ in its own __dict__ as a wrapper_descriptor (C-level slot; Decimal is hashable defining both __eq__ and __hash__); Context does not define __eq__ in its own __dict__ and inherits object.__eq__ which is also a wrapper_descriptor; no prior decimal spec checks __eq__.__class__.__name__; both novel anchors in decall53 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decall53ceq

  columns: [id, function, args, expected]
  rows:
    - [Decimal_eq_class_name, "Decimal.__eq__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - [Context_eq_class_name, "Context.__eq__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# decimal DecimalException/InvalidOperation __eq__.__class__.__name__ == 'wrapper_descriptor'
#
# DecimalException is a pure-Python ArithmeticError subclass. It does NOT
# define __eq__ in its own __dict__ (confirmed: '__eq__' in
# DecimalException.__dict__ == False; DecimalException.__eq__ is
# object.__eq__ == True). Inherits object.__eq__ as wrapper_descriptor.
# __eq__.__qualname__ == 'object.__eq__'.
#
# InvalidOperation is a DecimalException subclass. Same inheritance chain
# from object.__eq__. Same wrapper_descriptor. Same qualname.
#
#   DecimalException.__eq__.__class__.__name__ == 'wrapper_descriptor'
#   InvalidOperation.__eq__.__class__.__name__ == 'wrapper_descriptor'
#
# No prior decimal spec checks __eq__.__class__.__name__ for decimal exception classes.
# Both anchors are novel in the decall53 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra53.exception_eq_class_name:
  description: "decimal DecimalException/InvalidOperation __eq__.__class__.__name__.__eq__('wrapper_descriptor') — neither class defines __eq__ in its own __dict__; both inherit object.__eq__ (confirmed: T.__eq__ is object.__eq__ == True for both; __eq__.__qualname__=='object.__eq__'); object.__eq__ is a wrapper_descriptor; no prior decimal spec checks __eq__.__class__.__name__ for decimal exception classes; both novel anchors in decall53 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decall53exc

  columns: [id, function, args, expected]
  rows:
    - [DecimalException_eq_class_name, "DecimalException.__eq__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - [InvalidOperation_eq_class_name, "InvalidOperation.__eq__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

invariant decimal_extra53.Decimal_eq_class_name_wrapper_descriptor:
  description: "decimal.Decimal.__eq__.__class__.__name__ == 'wrapper_descriptor' — Decimal is a C-extension type that defines __eq__ in its own __dict__ (confirmed: '__eq__' in Decimal.__dict__ == True; __eq__.__qualname__=='Decimal.__eq__'); Decimal defines both __eq__ and __hash__ so instances are hashable; no prior decimal spec checks __eq__.__class__.__name__; novel anchor in decall53 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__eq__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra53.Context_eq_class_name_wrapper_descriptor:
  description: "decimal.Context.__eq__.__class__.__name__ == 'wrapper_descriptor' — Context is a C-extension type that does not define __eq__ in its own __dict__ (confirmed: '__eq__' in Context.__dict__ == False; Context.__eq__ is object.__eq__); inherits object.__eq__ which is a wrapper_descriptor; no prior decimal spec checks __eq__.__class__.__name__; novel anchor in decall53 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Context.__eq__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra53.DecimalException_eq_class_name_wrapper_descriptor:
  description: "decimal.DecimalException.__eq__.__class__.__name__ == 'wrapper_descriptor' — DecimalException is a pure-Python ArithmeticError subclass that does not define __eq__ in its own __dict__ (confirmed: DecimalException.__eq__ is object.__eq__); inherits object.__eq__ which is a wrapper_descriptor; no prior decimal spec checks __eq__.__class__.__name__ for decimal exception classes; novel anchor in decall53 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__eq__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true
