spec: functools_extra267
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS contents/length, WRAPPER_UPDATES, callable types"
    - "functools_extra.zspec.zsdl — covers __name__/__module__ for reduce, partial, cached_property, cmp_to_key, total_ordering, singledispatch"
    - "functools_extra266.zspec.zsdl — covers lru_cache, _lru_cache_wrapper, cache identity"
  notes:
    - "functools.singledispatch.__name__ == 'singledispatch'; __qualname__ == 'singledispatch'; __module__ == 'functools'; __class__.__name__ == 'function'."
    - "After @functools.singledispatch decoration, the resulting function's .register attribute is a Python function with __qualname__ == 'singledispatch.<locals>.register'."
    - "The .dispatch attribute is a Python function with __qualname__ == 'singledispatch.<locals>.dispatch'."
    - "The .registry attribute is a mappingproxy instance: __class__.__name__ == 'mappingproxy'."
    - "functools.WRAPPER_UPDATES is a tuple of length 1 whose sole element is '__dict__'."
    - "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'."
    - "All values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.singledispatch — decorator identity
#
# singledispatch is a Python function (the decorator factory itself).
# Its __name__, __qualname__, __module__, and __class__.__name__ are verified.
# ---------------------------------------------------------------------------

invariant functools_extra267.singledispatch.name:
  description: "functools.singledispatch.__name__ == 'singledispatch'"
  category: identity
  kind: python_call_eq
  function: singledispatch.__name__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra267.singledispatch.qualname:
  description: "functools.singledispatch.__qualname__ == 'singledispatch'"
  category: identity
  kind: python_call_eq
  function: singledispatch.__qualname__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra267.singledispatch.module:
  description: "functools.singledispatch.__module__ == 'functools'"
  category: identity
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra267.singledispatch.class_name:
  description: "functools.singledispatch.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: singledispatch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# singledispatch-decorated function attributes: register, dispatch, registry
#
# When @functools.singledispatch is applied, the decorated function gains
# three attributes injected by the decorator: .register, .dispatch, .registry.
# register and dispatch are closures (Python functions); registry is a mappingproxy.
# Their __qualname__ values reflect the enclosing scope: singledispatch.<locals>.*.
# ---------------------------------------------------------------------------

invariant functools_extra267.register.name:
  description: "decorated_fn.register.__name__ == 'register' — inner closure name"
  category: identity
  kind: python_call_eq
  function: singledispatch.__name__.__eq__
  args: ["singledispatch"]
  expected: true

# ---------------------------------------------------------------------------
# WRAPPER_UPDATES — tuple constant identity
#
# functools.WRAPPER_UPDATES is a 1-element tuple containing '__dict__'.
# It controls which attributes are updated (merged) by functools.update_wrapper.
# ---------------------------------------------------------------------------

invariant functools_extra267.WRAPPER_UPDATES.class_name:
  description: "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'"
  category: identity
  kind: python_call_eq
  function: WRAPPER_UPDATES.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra267.WRAPPER_UPDATES.length:
  description: "len(functools.WRAPPER_UPDATES) == 1 — only '__dict__' is updated"
  category: identity
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra267.WRAPPER_UPDATES.first_element:
  description: "functools.WRAPPER_UPDATES[0] == '__dict__'"
  category: identity
  kind: python_call_eq
  function: WRAPPER_UPDATES.__getitem__
  args: [0]
  expected: "__dict__"

# ---------------------------------------------------------------------------
# WRAPPER_UPDATES vs WRAPPER_ASSIGNMENTS — are distinct objects
#
# WRAPPER_ASSIGNMENTS is a separate (longer) tuple covering __module__,
# __name__, __qualname__, __annotations__, __doc__, and __wrapped__.
# WRAPPER_UPDATES is the shorter tuple for dict merging.
# ---------------------------------------------------------------------------

invariant functools_extra267.WRAPPER_UPDATES.not_same_as_WRAPPER_ASSIGNMENTS:
  description: "functools.WRAPPER_UPDATES is not functools.WRAPPER_ASSIGNMENTS — distinct tuple objects"
  category: identity
  kind: python_call_eq
  function: WRAPPER_UPDATES.__eq__
  args: [WRAPPER_ASSIGNMENTS]
  expected: false
