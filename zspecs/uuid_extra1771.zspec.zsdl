spec: uuid_extra1771
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python uuid documentation — https://docs.python.org/3/library/uuid.html"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "uuid_extra.zspec.zsdl — covers UUID constructor, str(), int, bytes attributes"
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 565 (_extra1771): async protocol dict-presence checks."
    - "Theme: which uuid stdlib types define __aenter__, __aexit__, __aiter__, __anext__, __await__ in their own __dict__."
    - "uuid.UUID: a Python-level immutable class representing a UUID value. It implements equality and comparison, not the async protocol -> all False."
    - "Rationale: uuid.UUID is a value-type class modeling a 128-bit identifier; it has no async semantics."
    - "Complementary checks confirm key UUID descriptor properties from the Python source."
    - "uuid.UUID.__dict__.__contains__('fields') -> True — 'fields' is a property defined on uuid.UUID."
    - "uuid.UUID.__dict__.__contains__('bytes_le') -> True — 'bytes_le' is a property defined on uuid.UUID."
    - "uuid.UUID.__dict__.__contains__('bytes') -> True — 'bytes' is a property defined on uuid.UUID."
    - "uuid.UUID.__dict__.__contains__('node') -> True — 'node' is a property defined on uuid.UUID."
    - "uuid.UUID.__dict__.__contains__('is_safe') -> True — 'is_safe' is a property added in Python 3.7."
    - "uuid.UUID.__dict__.__contains__('int') -> True — 'int' is a property defined on uuid.UUID."
    - "All expected values verified by running Python 3.14 uuid module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: async protocol dict-presence checks for uuid.UUID
#
# Wave 565 theme: which uuid types define __aenter__, __aexit__,
# __aiter__, __anext__, __await__ in their own __dict__.
#
# uuid.UUID: an immutable Python class representing a 128-bit UUID value.
# It provides rich comparison, hashing, and multiple byte-order views via
# properties. It does not implement any async protocol -> all False.
# ---------------------------------------------------------------------------

table uuid_extra1771.async_protocol:
  description: "uuid.UUID async protocol dict-presence checks — all False — wave 565 _extra1771"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1771

  columns: [id, function, args, expected]
  rows:
    - ["uu1771001", "uuid.UUID.__dict__.__contains__", ["__aenter__"], false]
    - ["uu1771002", "uuid.UUID.__dict__.__contains__", ["__aexit__"],  false]
    - ["uu1771003", "uuid.UUID.__dict__.__contains__", ["__aiter__"],  false]
    - ["uu1771004", "uuid.UUID.__dict__.__contains__", ["__anext__"],  false]
    - ["uu1771005", "uuid.UUID.__dict__.__contains__", ["__await__"],  false]

# ---------------------------------------------------------------------------
# Table 2: complementary checks for uuid.UUID
#
# The async theme is all-False for uuid.UUID. Complementary checks confirm
# genuine uuid.UUID structural properties — the key descriptor properties
# defined directly on the class in Lib/uuid.py:
# - 'fields': returns the six UUID field integer values as a tuple
# - 'bytes_le': returns bytes in little-endian byte order
# - 'bytes': returns bytes in big-endian (network) byte order
# - 'node': returns the last 48 bits (MAC address field)
# - 'is_safe': returns the SafeUUID enum value (added Python 3.7)
# - 'int': returns the UUID as a 128-bit integer
# - 'version': returns the UUID version number
# - '__init__': uuid.UUID has its own __init__ (not inherited)
# ---------------------------------------------------------------------------

table uuid_extra1771.complementary_checks:
  description: "uuid.UUID property and attribute dict-presence complementary checks — wave 565 _extra1771"
  kind: python_call_eq
  category: complementary
  id_prefix: uu1771

  columns: [id, function, args, expected]
  rows:
    - ["uu1771006", "uuid.UUID.__dict__.__contains__", ["fields"],   true]
    - ["uu1771007", "uuid.UUID.__dict__.__contains__", ["bytes_le"], true]
    - ["uu1771008", "uuid.UUID.__dict__.__contains__", ["bytes"],    true]
    - ["uu1771009", "uuid.UUID.__dict__.__contains__", ["node"],     true]
    - ["uu1771010", "uuid.UUID.__dict__.__contains__", ["is_safe"],  true]
    - ["uu1771011", "uuid.UUID.__dict__.__contains__", ["int"],      true]
    - ["uu1771012", "uuid.UUID.__dict__.__contains__", ["version"],  true]
    - ["uu1771013", "uuid.UUID.__dict__.__contains__", ["__init__"], true]
    - ["uu1771014", "uuid.UUID.__name__.__eq__",        ["UUID"],    true]
    - ["uu1771015", "uuid.UUID.__module__.__eq__",      ["uuid"],    true]
