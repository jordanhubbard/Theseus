spec: socket_extra169
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra168.zspec.zsdl — covers socket.socket class base identity and socket.create_connection/__create_server/__getaddrinfo function identity (table + invariants)."
    - "socket_extra167.zspec.zsdl — covers socket.AddressFamily/__SocketKind __name__/__module__/__bases__[0].__name__=='IntEnum' and name lengths (13/10) (table + invariants)."
    - "socket_extra166.zspec.zsdl — covers socket.AF_INET/__SOCK_STREAM/__AF_INET6/__SOCK_DGRAM/__IPPROTO_TCP/__IPPROTO_UDP enum constant class names and integer values (table + invariants)."
    - "socket_extra165.zspec.zsdl — covers socket.error/__timeout/__gaierror/__herror class identity (table + invariants)."
    - "socket_extra164.zspec.zsdl — covers socket.socket.__dict__ method membership (table + invariants)."
    - "socket_extra159.zspec.zsdl — covers socket.socket.__name__/__module__/__bases__[0].__name__ (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra168."
    - "Wave 351 theme: socket.socket.__dict__ membership — which methods are Python-defined vs C-inherited — and socket.socket class identity (__name__/__module__/__dict__.__len__). socket_extra164 anchors socket.socket.__dict__ method membership; this spec covers: connect (NOT in socket.socket.__dict__ — inherited from C base _socket.socket), makefile (in socket.socket.__dict__ — Python-defined), sendfile (in socket.socket.__dict__ — Python-defined), socket.__dict__.__len__()==28, socket.__name__=='socket', socket.__module__=='socket'."
    - "socket.socket.__dict__.__contains__('connect') == False. Verified Python 3.14.3 macOS/Darwin 25.4.0. connect is defined in the C base _socket.socket, NOT in the Python socket.socket subclass dict."
    - "socket.socket.__dict__.__contains__('makefile') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. makefile is a Python-defined method in Lib/socket.py."
    - "socket.socket.__dict__.__contains__('sendfile') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. sendfile is a Python-defined method in Lib/socket.py."
    - "socket.socket.__dict__.__len__() == 28. Verified Python 3.14.3 macOS/Darwin 25.4.0. The 28 keys are: __doc__/__enter__/__exit__/__firstlineno__/__getstate__/__init__/__module__/__repr__/__slots__/__static_attributes__/__weakref__/_check_sendfile_params/_closed/_decref_socketios/_io_refs/_real_close/_sendfile_use_send/_sendfile_use_sendfile/accept/close/detach/dup/family/get_inheritable/makefile/sendfile/set_inheritable/type."
    - "socket.socket.__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket.__dict__ has exactly 28 keys on Python 3.14.3 macOS/Darwin 25.4.0. The dict contains Python-defined members only; C-inherited methods (connect, bind, listen, accept (also Python), recv, send, etc.) may or may not be present. 'connect' is not in socket.socket.__dict__ because it is implemented in the C base _socket.socket. 'makefile' is present because it is a pure Python method defined in Lib/socket.py."
    - "Note: socket.socket.__dict__.__len__() == 28 (verified on Python 3.14.3). This count includes dunders (__doc__/__enter__/__exit__/__firstlineno__/__getstate__/__init__/__module__/__repr__/__slots__/__static_attributes__/__weakref__ = 11 dunders), private helper methods (7: _check_sendfile_params/_closed/_decref_socketios/_io_refs/_real_close/_sendfile_use_send/_sendfile_use_sendfile), and public methods/attributes (10: accept/close/detach/dup/family/get_inheritable/makefile/sendfile/set_inheritable/type). Total = 11 + 7 + 10 = 28."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('connect')==False
# socket.socket.__dict__.__contains__('makefile')==True
# socket.socket.__dict__.__contains__('sendfile')==True
# socket.socket.__dict__.__len__()==28
#
# Wave 351 theme: Python-defined vs C-inherited in socket.socket.__dict__.
#
# socket.__dict__.__contains__('connect') == False (connect is in C base _socket.socket).
# socket.__dict__.__contains__('makefile') == True (Python-defined in Lib/socket.py).
# socket.__dict__.__contains__('sendfile') == True (Python-defined in Lib/socket.py).
# socket.__dict__.__len__() == 28 (total Python-defined dict entries on Python 3.14.3 macOS).
# socket_extra164 anchors socket.socket.__dict__ method membership;
# this spec adds the 'connect' False case and __dict__.__len__() as primary novel content.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra169.socket_dict_membership_and_len:
  description: "socket.socket.__dict__.__contains__('connect')==False / socket.__dict__.__contains__('makefile')==True / socket.__dict__.__contains__('sendfile')==True / socket.__dict__.__len__()==28 — socket.__dict__.__contains__('connect') is False (connect is NOT in socket.socket.__dict__; connect is defined in the C base class _socket.socket, not in the Python socket.socket subclass in Lib/socket.py; accessing socket.socket_instance.connect() works via MRO lookup in the C base, but 'connect' is not a key in socket.socket.__dict__; this is the primary novel anchor — socket_extra164 covers method membership but not the False case for connect; 'connect'(7 chars) is absent from the 28-key Python dict); socket.__dict__.__contains__('makefile') is True ('makefile' is a key in socket.socket.__dict__; makefile is defined in pure Python in Lib/socket.py as socket.socket.makefile(mode='r', buffering=None, *, encoding=None, errors=None, newline=None); it returns a file-like object backed by the socket; 'makefile'(8 chars) = 'make'=4 + 'file'=4; socket_extra164 anchors makefile membership; confirmed here); socket.__dict__.__contains__('sendfile') is True ('sendfile' is a key in socket.socket.__dict__; sendfile is defined in pure Python in Lib/socket.py and uses the OS sendfile() syscall when available, falling back to send() otherwise; 'sendfile'(8 chars) = 'send'=4 + 'file'=4; socket_extra164 anchors sendfile membership; confirmed here; 'sendfile'(8)=='makefile'(8) — both 8-char Python-defined methods); socket.__dict__.__len__() is 28 (socket.socket.__dict__ has exactly 28 keys on Python 3.14.3 macOS/Darwin 25.4.0: 11 dunders + 7 private helpers + 10 public methods/attributes = 28; novel anchor: no prior socket spec anchors __dict__.__len__()==28 under sockdict169; first sockdict169 anchor for dict membership False case and total length)"
  kind: python_call_eq
  category: identity
  id_prefix: sockdict169

  columns: [id, function, args, expected, description]
  rows:
    - [dict_no_connect,     "socket.__dict__.__contains__", ["connect"],  false, "socket.socket.__dict__.__contains__('connect') == False ('connect' is in C base _socket.socket, not in Python socket.socket.__dict__; primary novel anchor)"]
    - [dict_has_makefile,   "socket.__dict__.__contains__", ["makefile"], true,  "socket.socket.__dict__.__contains__('makefile') == True ('makefile'=8 chars; Python-defined in Lib/socket.py; socket_extra164 anchors; confirmed)"]
    - [dict_has_sendfile,   "socket.__dict__.__contains__", ["sendfile"], true,  "socket.socket.__dict__.__contains__('sendfile') == True ('sendfile'=8 chars; Python-defined; OS sendfile() or send() fallback; socket_extra164 anchors; confirmed)"]
    - [dict_len_28,         "socket.__dict__.__len__",      [],           28,    "socket.socket.__dict__.__len__() is 28 (11 dunders + 7 private helpers + 10 public = 28; novel anchor; Python 3.14.3 macOS/Darwin 25.4.0)"]

# ---------------------------------------------------------------------------
# socket.socket.__name__ and __module__ identity
#
# Wave 351 theme: socket.socket class __name__ and __module__ confirmed.
#
# socket.__name__ == 'socket' (6 chars; socket_extra159 anchors this).
# socket.__module__ == 'socket' (6 chars; socket_extra159 anchors this).
# socket.__name__.__len__() == 6 ('socket' = 6 chars).
# socket.__module__.__len__() == 6 ('socket' = 6 chars; same as __name__.__len__()).
# This spec provides fresh anchors under sockdict169. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra169.socket_class_name_and_module:
  description: "socket.socket.__name__.__eq__('socket')==True / socket.__module__.__eq__('socket')==True / socket.__name__.__len__()==6 / socket.__module__.__len__()==6 — socket.__name__ is 'socket' (6 chars; both the module name and the class name are 'socket' — same 6-char string; socket.socket.__name__(6)==socket.socket.__module__(6)=='socket'(6); socket_extra159 anchors __name__=='socket' and __module__=='socket' as table rows; socket_extra168 confirms both as table rows; this spec anchors under sockdict169 as a fresh confirmation); socket.__module__ is 'socket' (6 chars; socket.socket is defined in Lib/socket.py; __module__=='socket'(6 chars) identifies the public module; socket.__module__(6)==socket.__name__(6)=='socket'(6) — class name and module name are the same string; socket_extra168 confirms); socket.__name__.__len__() is 6 ('socket' = 6 chars; 's'+'o'+'c'+'k'+'e'+'t'=6; 'socket'(6) < 'makefile'(8) < 'sendfile'(8) < '_socket'(7) < '__dict__'(8) in lengths; socket_extra168 anchors __name__.__len__()==6 as a table row); socket.__module__.__len__() is 6 ('socket' = 6 chars; socket.__module__.__len__()==6==socket.__name__.__len__()==6 — same string so same length; 'socket'(6) is shorter than the class's C base module '_socket'(7 chars) by 1 char; first sockdict169 anchor for combined name and module identity)"
  kind: python_call_eq
  category: identity
  id_prefix: sockdict169

  columns: [id, function, args, expected, description]
  rows:
    - [sock_name_socket,     "socket.__name__.__eq__",    ["socket"], true, "socket.socket.__name__ == 'socket' (6 chars; class name; socket_extra159 and socket_extra168 anchor; confirmed under sockdict169)"]
    - [sock_module_socket,   "socket.__module__.__eq__",  ["socket"], true, "socket.socket.__module__ == 'socket' (6 chars; defined in Lib/socket.py; socket_extra159 and socket_extra168 anchor; confirmed under sockdict169)"]
    - [sock_name_len_6,      "socket.__name__.__len__",   [],         6,   "socket.socket.__name__.__len__() is 6 ('socket' = 6 chars; socket_extra168 anchors; 'socket'(6) < '_socket'(7) by 1 char)"]
    - [sock_module_len_6,    "socket.__module__.__len__", [],         6,   "socket.socket.__module__.__len__() is 6 ('socket' = 6 chars; same string as __name__ so same length; 'socket'(6) < '_socket'(7) by 1)"]

# ---------------------------------------------------------------------------
# socket.socket.__dict__ private helper membership
#
# Wave 351 theme: Python-defined private helpers in socket.socket.__dict__.
#
# socket.__dict__.__contains__('_sendfile_use_sendfile') == True (private helper).
# socket.__dict__.__contains__('_sendfile_use_send') == True (private helper).
# socket.__dict__.__contains__('_decref_socketios') == True (private helper).
# socket.__dict__.__len__() == 28 (confirmed; total dict size).
# socket_extra164 covers public method membership; these private helpers are novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra169.socket_dict_private_helpers:
  description: "socket.socket.__dict__.__contains__('_sendfile_use_sendfile')==True / socket.__dict__.__contains__('_sendfile_use_send')==True / socket.__dict__.__contains__('_decref_socketios')==True / socket.__dict__.__len__()==28 — socket.__dict__.__contains__('_sendfile_use_sendfile') is True ('_sendfile_use_sendfile' is a key in socket.socket.__dict__; it is a private helper method in Lib/socket.py that implements sendfile() using the OS-level sendfile() syscall when available; '_sendfile_use_sendfile'(22 chars) = '_sendfile_use_'=14 + 'sendfile'=8; the leading underscore marks it as private; novel anchor: socket_extra164 does not anchor this membership); socket.__dict__.__contains__('_sendfile_use_send') is True ('_sendfile_use_send' is a key in socket.socket.__dict__; it is a private helper method that implements sendfile() using the lower-level send() method as a fallback when OS sendfile() is unavailable; '_sendfile_use_send'(18 chars) = '_sendfile_use_'=14 + 'send'=4; '_sendfile_use_send'(18) < '_sendfile_use_sendfile'(22) by 4 chars (the 'file' suffix of 'sendfile' vs 'send'); novel anchor); socket.__dict__.__contains__('_decref_socketios') is True ('_decref_socketios' is a key in socket.socket.__dict__; it is a private helper that decrements the reference count for socket I/O objects (used by makefile); '_decref_socketios'(17 chars) = '_decref'=7 + '_socketios'=10; novel anchor: socket_extra164 does not anchor this membership); socket.__dict__.__len__() is 28 (confirmed; 11 dunders + 7 private helpers + 10 public = 28 total keys; first sockdict169 anchor for private helper membership)"
  kind: python_call_eq
  category: identity
  id_prefix: sockdict169

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_sfu_sendfile, "socket.__dict__.__contains__", ["_sendfile_use_sendfile"], true, "socket.socket.__dict__.__contains__('_sendfile_use_sendfile') == True ('_sendfile_use_sendfile'=22 chars; OS sendfile() impl; private helper; novel anchor)"]
    - [dict_has_sfu_send,     "socket.__dict__.__contains__", ["_sendfile_use_send"],     true, "socket.socket.__dict__.__contains__('_sendfile_use_send') == True ('_sendfile_use_send'=18 chars; send() fallback impl; '_sendfile_use_send'(18)<'_sendfile_use_sendfile'(22) by 4; novel anchor)"]
    - [dict_has_decref,       "socket.__dict__.__contains__", ["_decref_socketios"],      true, "socket.socket.__dict__.__contains__('_decref_socketios') == True ('_decref_socketios'=17 chars; makefile ref counting helper; novel anchor)"]
    - [dict_len_28_b,         "socket.__dict__.__len__",      [],                         28,   "socket.socket.__dict__.__len__() is 28 (confirmed; 11+7+10=28; Python 3.14.3 macOS/Darwin 25.4.0)"]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('connect')==False — standalone
#
# socket.socket.__dict__.__contains__('connect') is False. The connect() method is defined
# in the C base class _socket.socket (Modules/socketmodule.c), not in the Python socket.socket
# subclass. When you call socket_instance.connect(addr), Python's MRO finds it in the C base,
# not in socket.socket.__dict__. This is the primary novel anchor for this spec.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra169.socket_dict_no_connect:
  description: "socket.socket.__dict__.__contains__('connect') == False — 'connect' is NOT in socket.socket.__dict__; connect() is implemented in the C base class _socket.socket (Modules/socketmodule.c), not in the Python socket.socket subclass in Lib/socket.py; Python MRO lookup finds connect in _socket.socket, making it callable, but it is absent from socket.socket's own __dict__; this contrasts with makefile/sendfile which ARE in socket.socket.__dict__ because they are Python-defined; socket.socket.__dict__.__len__()==28 (28 keys, none named 'connect'); first sockdict169 standalone for socket.__dict__.__contains__('connect')==False"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["connect"]
  expected: false

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('makefile')==True — standalone
#
# socket.socket.__dict__.__contains__('makefile') is True. socket.socket.makefile is a
# pure Python method defined in Lib/socket.py that wraps the socket in a file-like object.
# 'makefile' (8 chars) = 'make'=4 + 'file'=4. socket_extra164 anchors makefile membership;
# this standalone anchors it under sockdict169.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra169.socket_dict_has_makefile:
  description: "socket.socket.__dict__.__contains__('makefile') == True — 'makefile' (8 chars = 'make'=4 + 'file'=4; socket.socket.makefile(mode='r', buffering=None, ...) returns a file-like object backed by the socket; it creates a SocketIO object; a pure Python method in Lib/socket.py; 'makefile'(8)=='sendfile'(8) — both 8-char Python-defined public methods in socket.socket.__dict__; socket_extra164 anchors makefile membership; socket.socket.__dict__.__len__()==28; first sockdict169 standalone for socket.__dict__.__contains__('makefile')==True"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["makefile"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('sendfile')==True — standalone
#
# socket.socket.__dict__.__contains__('sendfile') is True. socket.socket.sendfile is a
# pure Python method in Lib/socket.py. It efficiently sends a file over the socket,
# using the OS sendfile() syscall when available (via _sendfile_use_sendfile helper) and
# falling back to send() (via _sendfile_use_send helper) otherwise. 'sendfile' (8 chars) =
# 'send'=4 + 'file'=4. socket_extra164 anchors sendfile membership.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra169.socket_dict_has_sendfile:
  description: "socket.socket.__dict__.__contains__('sendfile') == True — 'sendfile' (8 chars = 'send'=4 + 'file'=4; socket.socket.sendfile(file, offset=0, count=None) efficiently sends a file over the socket; uses OS sendfile() syscall via _sendfile_use_sendfile when available, falls back to send() via _sendfile_use_send otherwise; 'sendfile'(8)=='makefile'(8) — tied 8-char public method names; socket_extra164 anchors sendfile membership; socket.socket.__dict__.__len__()==28; first sockdict169 standalone for socket.__dict__.__contains__('sendfile')==True"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["sendfile"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__len__()==28 — standalone
#
# socket.socket.__dict__.__len__() is 28. The 28 keys consist of:
# 11 dunders: __doc__/__enter__/__exit__/__firstlineno__/__getstate__/__init__/__module__/
#             __repr__/__slots__/__static_attributes__/__weakref__
# 7 private helpers: _check_sendfile_params/_closed/_decref_socketios/_io_refs/
#                    _real_close/_sendfile_use_send/_sendfile_use_sendfile
# 10 public: accept/close/detach/dup/family/get_inheritable/makefile/sendfile/
#            set_inheritable/type
# Total: 11 + 7 + 10 = 28. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra169.socket_dict_len_28:
  description: "socket.socket.__dict__.__len__() == 28 — socket.socket.__dict__ has exactly 28 keys on Python 3.14.3 macOS/Darwin 25.4.0: 11 dunders (__doc__/__enter__/__exit__/__firstlineno__/__getstate__/__init__/__module__/__repr__/__slots__/__static_attributes__/__weakref__) + 7 private helpers (_check_sendfile_params/_closed/_decref_socketios/_io_refs/_real_close/_sendfile_use_send/_sendfile_use_sendfile) + 10 public (accept/close/detach/dup/family/get_inheritable/makefile/sendfile/set_inheritable/type) = 28 total; 28 is the number of Python-defined members — C-inherited methods like connect/bind/listen/recv/send are not counted; 28 > struct.Struct.__dict__.__len__()(16) by 12; first sockdict169 standalone for socket.__dict__.__len__()==28"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__len__
  args: []
  expected: 28

# ---------------------------------------------------------------------------
# socket.socket.__name__.__eq__('socket') — standalone
#
# socket.socket.__name__ is 'socket' (6 chars). Both the class name and the module name
# are 'socket' — identical 6-char strings. socket_extra159 and socket_extra168 anchor this;
# this standalone provides a fresh anchor under sockdict169.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra169.socket_name_eq_socket:
  description: "socket.socket.__name__.__eq__('socket') == True — 'socket' (6 chars; socket.socket class name; socket.__name__(6)==socket.__module__(6)=='socket'(6) — class name and module name are the same 6-char string; socket_extra159 and socket_extra168 anchor this; socket.socket.__dict__.__len__()==28; socket.__bases__[0].__name__=='socket'(6) too (C base class name is also 'socket'); socket.__bases__[0].__module__=='_socket'(7) distinguishes the C base by module; first sockdict169 standalone for socket.socket.__name__.__eq__('socket')"
  category: identity
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__module__.__eq__('socket') — standalone
#
# socket.socket.__module__ is 'socket' (6 chars). socket.socket is defined in Lib/socket.py.
# socket.__module__(6 chars) == socket.__name__(6 chars) — both are the same 6-char string
# 'socket'. socket_extra159 and socket_extra168 anchor this; this standalone anchors under
# sockdict169. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra169.socket_module_eq_socket:
  description: "socket.socket.__module__.__eq__('socket') == True — 'socket' (6 chars; socket.socket is defined in Lib/socket.py; __module__=='socket'(6 chars; public module); socket.__module__(6)==socket.__name__(6)=='socket'(6) — same string; contrasts with C base: socket.__bases__[0].__module__=='_socket'(7 chars; private C extension, 1 char longer due to '_' prefix); socket_extra159 and socket_extra168 anchor this; socket.socket.__dict__.__len__()==28; first sockdict169 standalone for socket.socket.__module__.__eq__('socket')"
  category: identity
  kind: python_call_eq
  function: socket.__module__.__eq__
  args: ["socket"]
  expected: true
