spec: lodash_tolower
version: ">=4.0.0"
backend: node(lodash.tolower)

docs: https://lodash.com/docs/#toLower

provenance:
  derived_from:
    - "lodash.tolower README — https://www.npmjs.com/package/lodash.tolower"
    - "Test vectors verified with lodash.tolower@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.tolower exports the _.toLower function directly as module.exports."
    - "toLower(string) converts string to lower case."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns lowercased string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_tolower.tolower:
  kind: node_module_call_eq
  function: ~
  category: tolower
  id_prefix: ltolc

  columns: [id, args, expected]
  rows:
    - [upper,    ["FOO BAR"],    "foo bar"]
    - [mixed,    ["Hello World"], "hello world"]
    - [already,  ["hello"],      "hello"]

