spec: pathlib_extra281
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "pathlib.Path('/tmp').__class__.__name__ == 'PosixPath' on POSIX systems (macOS, Linux)."
    - "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — PosixPath is a direct subclass of Path."
    - "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' — WindowsPath is a direct subclass of Path."
    - "pathlib.Path.__bases__[0].__name__ == 'PurePath' — Path inherits from PurePath."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath inherits from PurePath."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — PureWindowsPath inherits from PurePath."
    - "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath is the root of the hierarchy."
    - "All __module__ values for the concrete and pure path classes are 'pathlib'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: pathlib PurePath class hierarchy __name__ and __module__
# ---------------------------------------------------------------------------

table pathlib_extra281.purepath_class_identity:
  description: "pathlib.PurePath, PurePosixPath, PureWindowsPath __name__ and __module__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: pci

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_name,       PurePath.__name__.__eq__,        ["PurePath"],        true, "pathlib.PurePath.__name__ == 'PurePath'"]
    - [purepath_module,     PurePath.__module__.__eq__,      ["pathlib"],         true, "pathlib.PurePath.__module__ == 'pathlib'"]
    - [pureposix_name,      PurePosixPath.__name__.__eq__,   ["PurePosixPath"],   true, "pathlib.PurePosixPath.__name__ == 'PurePosixPath'"]
    - [pureposix_module,    PurePosixPath.__module__.__eq__, ["pathlib"],         true, "pathlib.PurePosixPath.__module__ == 'pathlib'"]
    - [purewin_name,        PureWindowsPath.__name__.__eq__, ["PureWindowsPath"], true, "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath'"]
    - [purewin_module,      PureWindowsPath.__module__.__eq__, ["pathlib"],       true, "pathlib.PureWindowsPath.__module__ == 'pathlib'"]

# ---------------------------------------------------------------------------
# Table: pathlib concrete Path class hierarchy __name__ and __module__
# ---------------------------------------------------------------------------

table pathlib_extra281.path_class_identity:
  description: "pathlib.Path, PosixPath, WindowsPath __name__ and __module__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: pth

  columns: [id, function, args, expected, description]
  rows:
    - [path_name,     Path.__name__.__eq__,        ["Path"],        true, "pathlib.Path.__name__ == 'Path'"]
    - [path_module,   Path.__module__.__eq__,      ["pathlib"],     true, "pathlib.Path.__module__ == 'pathlib'"]
    - [posix_name,    PosixPath.__name__.__eq__,   ["PosixPath"],   true, "pathlib.PosixPath.__name__ == 'PosixPath'"]
    - [posix_module,  PosixPath.__module__.__eq__, ["pathlib"],     true, "pathlib.PosixPath.__module__ == 'pathlib'"]
    - [win_name,      WindowsPath.__name__.__eq__, ["WindowsPath"], true, "pathlib.WindowsPath.__name__ == 'WindowsPath'"]
    - [win_module,    WindowsPath.__module__.__eq__, ["pathlib"],   true, "pathlib.WindowsPath.__module__ == 'pathlib'"]

# ---------------------------------------------------------------------------
# Standalone invariants: hierarchy bases and runtime class name
# ---------------------------------------------------------------------------

invariant pathlib_extra281.PurePath.base_is_object:
  description: "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath is the root of the hierarchy"
  category: hierarchy
  kind: python_call_eq
  function: "PurePath.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant pathlib_extra281.PurePosixPath.base_is_PurePath:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath'"
  category: hierarchy
  kind: python_call_eq
  function: "PurePosixPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra281.PureWindowsPath.base_is_PurePath:
  description: "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath'"
  category: hierarchy
  kind: python_call_eq
  function: "PureWindowsPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra281.Path.base_is_PurePath:
  description: "pathlib.Path.__bases__[0].__name__ == 'PurePath' — Path adds I/O methods to PurePath"
  category: hierarchy
  kind: python_call_eq
  function: "Path.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra281.PosixPath.base_is_Path:
  description: "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — PosixPath is a direct subclass of Path"
  category: hierarchy
  kind: python_call_eq
  function: "PosixPath.__bases__[0].__name__.__eq__"
  args: ["Path"]
  expected: true

invariant pathlib_extra281.WindowsPath.base_is_Path:
  description: "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' — WindowsPath is a direct subclass of Path"
  category: hierarchy
  kind: python_call_eq
  function: "WindowsPath.__bases__[0].__name__.__eq__"
  args: ["Path"]
  expected: true

invariant pathlib_extra281.Path.runtime_class_on_posix:
  description: "pathlib.Path('/tmp').__class__.__name__ == 'PosixPath' on POSIX/macOS"
  category: identity
  kind: python_call_eq
  function: Path.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant pathlib_extra281.PosixPath.is_type:
  description: "pathlib.PosixPath.__class__.__name__ == 'type' — PosixPath is a plain Python class object"
  category: identity
  kind: python_call_eq
  function: PosixPath.__class__.__name__.__eq__
  args: ["type"]
  expected: true
