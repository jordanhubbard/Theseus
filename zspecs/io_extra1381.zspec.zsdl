spec: io_extra1381
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, FileIO documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 539 (_extra1381): focuses on __abstractmethods__ frozenset checks for io module classes."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, and io.TextIOBase are abstract base classes registered via ABCMeta machinery; each has __abstractmethods__ in its __dict__ as a frozenset (empty frozenset because the abstract methods are defined but all subclasses satisfy them)."
    - "io.BytesIO, io.StringIO, and io.FileIO are concrete classes; they do NOT have __abstractmethods__ in their own __dict__."
    - "io.IOBase.__abstractmethods__.__class__.__name__ == 'frozenset'; all four abstract io base classes return 'frozenset' for this check; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "io.IOBase.__dict__.__contains__('__abstractmethods__') == True; io.BytesIO.__dict__.__contains__('__abstractmethods__') == False; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1381.abstract_base_classes_abstractmethods_type:
  description: "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase __abstractmethods__ frozenset type checks — wave 539 theme: all four abstract io base classes have __abstractmethods__ as a frozenset (empty frozenset); the type name is 'frozenset'; checked via __class__.__name__.__eq__; verified with Python 3.12"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: io1381ab
  columns: [id, function, args, expected, description]
  rows:
    - [io1381ab001, io.IOBase.__abstractmethods__.__class__.__name__.__eq__,          ["frozenset"], true,  "io.IOBase.__abstractmethods__.__class__.__name__ == 'frozenset' (abstract base class, empty frozenset); verified with Python 3.12"]
    - [io1381ab002, io.RawIOBase.__abstractmethods__.__class__.__name__.__eq__,       ["frozenset"], true,  "io.RawIOBase.__abstractmethods__.__class__.__name__ == 'frozenset' (abstract base class, empty frozenset); verified with Python 3.12"]
    - [io1381ab003, io.BufferedIOBase.__abstractmethods__.__class__.__name__.__eq__,  ["frozenset"], true,  "io.BufferedIOBase.__abstractmethods__.__class__.__name__ == 'frozenset' (abstract base class, empty frozenset); verified with Python 3.12"]
    - [io1381ab004, io.TextIOBase.__abstractmethods__.__class__.__name__.__eq__,      ["frozenset"], true,  "io.TextIOBase.__abstractmethods__.__class__.__name__ == 'frozenset' (abstract base class, empty frozenset); verified with Python 3.12"]
    - [io1381ab005, io.IOBase.__abstractmethods__.__class__.__name__.__eq__,          ["frozenset"], true,  "io.IOBase.__abstractmethods__.__class__.__name__ == 'frozenset' (cross-check anchor: IOBase is the root abstract class); verified with Python 3.12"]
    - [io1381ab006, io.RawIOBase.__abstractmethods__.__class__.__name__.__eq__,       ["frozenset"], true,  "io.RawIOBase.__abstractmethods__.__class__.__name__ == 'frozenset' (cross-check: RawIOBase inherits from IOBase, both are abstract); verified with Python 3.12"]
    - [io1381ab007, io.BufferedIOBase.__abstractmethods__.__class__.__name__.__eq__,  ["frozenset"], true,  "io.BufferedIOBase.__abstractmethods__.__class__.__name__ == 'frozenset' (cross-check: BufferedIOBase inherits from IOBase, both are abstract); verified with Python 3.12"]
    - [io1381ab008, io.TextIOBase.__abstractmethods__.__class__.__name__.__eq__,      ["frozenset"], true,  "io.TextIOBase.__abstractmethods__.__class__.__name__ == 'frozenset' (cross-check: TextIOBase inherits from IOBase, both are abstract); verified with Python 3.12"]

table io_extra1381.abstract_base_classes_dict_contains:
  description: "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase __dict__.__contains__('__abstractmethods__') checks — wave 539 theme: all four abstract io base classes have '__abstractmethods__' in their own __dict__; this confirms each registers the frozenset directly (not via inheritance); verified with Python 3.12"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: io1381dc
  columns: [id, function, args, expected, description]
  rows:
    - [io1381dc001, io.IOBase.__dict__.__contains__,          ["__abstractmethods__"], true,  "io.IOBase.__dict__.__contains__('__abstractmethods__') == True (abstract base class has key in own __dict__); verified with Python 3.12"]
    - [io1381dc002, io.RawIOBase.__dict__.__contains__,       ["__abstractmethods__"], true,  "io.RawIOBase.__dict__.__contains__('__abstractmethods__') == True (abstract base class has key in own __dict__); verified with Python 3.12"]
    - [io1381dc003, io.BufferedIOBase.__dict__.__contains__,  ["__abstractmethods__"], true,  "io.BufferedIOBase.__dict__.__contains__('__abstractmethods__') == True (abstract base class has key in own __dict__); verified with Python 3.12"]
    - [io1381dc004, io.TextIOBase.__dict__.__contains__,      ["__abstractmethods__"], true,  "io.TextIOBase.__dict__.__contains__('__abstractmethods__') == True (abstract base class has key in own __dict__); verified with Python 3.12"]
    - [io1381dc005, io.BytesIO.__dict__.__contains__,         ["__abstractmethods__"], false, "io.BytesIO.__dict__.__contains__('__abstractmethods__') == False (concrete class does not have key in own __dict__); verified with Python 3.12"]
    - [io1381dc006, io.StringIO.__dict__.__contains__,        ["__abstractmethods__"], false, "io.StringIO.__dict__.__contains__('__abstractmethods__') == False (concrete class does not have key in own __dict__); verified with Python 3.12"]
    - [io1381dc007, io.FileIO.__dict__.__contains__,          ["__abstractmethods__"], false, "io.FileIO.__dict__.__contains__('__abstractmethods__') == False (concrete class does not have key in own __dict__); verified with Python 3.12"]

table io_extra1381.concrete_classes_no_abstractmethods:
  description: "io.BytesIO, io.StringIO, io.FileIO, io.UnsupportedOperation __dict__ lacks __abstractmethods__ — wave 539 theme: concrete io classes do not register __abstractmethods__ in their own __dict__; contrasted against the four abstract base classes which do; verified with Python 3.12"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: io1381cc
  columns: [id, function, args, expected, description]
  rows:
    - [io1381cc001, io.BytesIO.__dict__.__contains__,              ["__abstractmethods__"], false, "io.BytesIO.__dict__.__contains__('__abstractmethods__') == False (BytesIO is concrete, not abstract); verified with Python 3.12"]
    - [io1381cc002, io.StringIO.__dict__.__contains__,             ["__abstractmethods__"], false, "io.StringIO.__dict__.__contains__('__abstractmethods__') == False (StringIO is concrete, not abstract); verified with Python 3.12"]
    - [io1381cc003, io.FileIO.__dict__.__contains__,               ["__abstractmethods__"], false, "io.FileIO.__dict__.__contains__('__abstractmethods__') == False (FileIO is concrete, not abstract); verified with Python 3.12"]
    - [io1381cc004, io.UnsupportedOperation.__dict__.__contains__, ["__abstractmethods__"], false, "io.UnsupportedOperation.__dict__.__contains__('__abstractmethods__') == False (UnsupportedOperation is an exception class, not abstract); verified with Python 3.12"]
    - [io1381cc005, io.IOBase.__dict__.__contains__,               ["__abstractmethods__"], true,  "io.IOBase.__dict__.__contains__('__abstractmethods__') == True (cross-check: abstract base has it, concrete does not); verified with Python 3.12"]
    - [io1381cc006, io.RawIOBase.__dict__.__contains__,            ["__abstractmethods__"], true,  "io.RawIOBase.__dict__.__contains__('__abstractmethods__') == True (cross-check: abstract base has it, concrete does not); verified with Python 3.12"]
