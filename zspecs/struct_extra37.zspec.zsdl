spec: struct_extra37
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra36.zspec.zsdl — covers calcsize('>f')==4 and calcsize('>d')==8 (big-endian float/double); calcsize('>4H')==8 (repeated format)."
    - "struct_extra35.zspec.zsdl — covers calcsize('<Q'/'<q')==8; pack('<Q',1) and pack('>Q',1) byte encoding."
    - "struct_extra34.zspec.zsdl — covers pack/__name__.__eq__('pack') and unpack/__name__.__eq__('unpack') (module-level); pack/__module__.__eq__('_struct')."
    - "struct_extra27.zspec.zsdl — covers Struct/__mro__.__len__()==2; Struct/__bases__[0]/__name__.__len__()==6 (length only, NOT string eq)."
    - "struct_extra25.zspec.zsdl — covers __module__.__len__() for pack/unpack/calcsize/pack_into/unpack_from/iter_unpack."
    - "struct_extra18.zspec.zsdl — covers pack_into/__module__.__eq__('_struct') and unpack_from/__module__.__eq__('_struct') and iter_unpack/__module__.__eq__('_struct') in a table."
    - "struct_extra16.zspec.zsdl — covers pack_into/__name__.__eq__('pack_into') and unpack_from/__name__.__eq__('unpack_from') and iter_unpack/__name__.__eq__('iter_unpack') (module-level __name__ eq values)."
    - "struct_extra9.zspec.zsdl — covers Struct.pack_into/Struct.unpack_from/Struct.iter_unpack __name__.__eq__ and __qualname__.__eq__ as Struct METHOD attributes (not module-level function attributes)."
  notes:
    - "This spec extends struct through struct_extra36; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: struct_extra9 covers Struct.pack_into/__name__.__eq__('pack_into') as a Struct METHOD (Struct.pack_into is a method descriptor on the Struct class). struct_extra16 covers the module-level pack_into/__name__.__eq__('pack_into'). But NO prior spec checks module-level pack_into/__qualname__.__eq__, unpack_from/__qualname__.__eq__, or iter_unpack/__qualname__.__eq__ as string eq values. For C-level builtin functions, __qualname__ == __name__, so these confirm the qualname attribute chain separately from the name chain. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.pack_into.__qualname__ == 'pack_into'. C builtin function; __qualname__ equals __name__ for module-level C functions. struct_extra16 covers __name__.__eq__('pack_into'); struct_extra25 covers __qualname__.__len__(); but no prior spec checks pack_into.__qualname__.__eq__ as a string value. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__qualname__ == 'unpack_from'. Same reasoning as pack_into. No prior spec checks unpack_from.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__qualname__ == 'iter_unpack'. Same reasoning as pack_into. No prior spec checks iter_unpack.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: struct_extra27 covers Struct.__bases__[0].__name__.__len__()==6 (length only). No prior spec checks Struct.__bases__[0].__name__.__eq__('object') as a string eq value. The length check and string eq check are distinct regression vectors. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__bases__[0].__name__ == 'object'. Struct inherits directly from object; __bases__[0].__name__ is 'object' (length 6). extra27 covers the length (6) but no prior spec checks the actual string value 'object' via __eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior struct spec checks struct.calcsize('P'). The 'P' format code represents a pointer-sized unsigned integer (void*). On 64-bit platforms calcsize('P') == 8; on 32-bit platforms it would be 4. This system is 64-bit (macOS/Darwin 25.4.0). The 'P' format is distinct from 'Q' (always 8 bytes) because 'P' is explicitly architecture-dependent. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.calcsize('P') == 8. Native pointer size on 64-bit macOS/Darwin. No prior struct spec checks calcsize with the 'P' (pointer) format code. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module-level pack_into/unpack_from/iter_unpack __qualname__.__eq__
#
# struct_extra16 covers pack_into/__name__.__eq__ (not __qualname__.__eq__).
# struct_extra9 covers Struct.pack_into/__qualname__.__eq__ as a METHOD attribute.
# struct_extra25 covers pack_into/__qualname__.__len__() (length only).
# No prior spec checks the module-level __qualname__.__eq__ for pack_into,
# unpack_from, or iter_unpack. For C builtin functions, __qualname__ == __name__.
# ---------------------------------------------------------------------------

table struct_extra37.module_fn_qualname_eq:
  description: "struct.pack_into/unpack_from/iter_unpack __qualname__.__eq__ string values — module-level functions; novel: extra16 covers __name__.__eq__; extra25 covers __qualname__.__len__; extra9 covers these as Struct METHOD attributes (not module-level); no prior spec checks __qualname__.__eq__ for module-level pack_into/unpack_from/iter_unpack"
  kind: python_call_eq
  category: function_names
  id_prefix: smfqe37

  columns: [id, function, args, expected]
  rows:
    - [pack_into_qualname_eq,   pack_into.__qualname__.__eq__,   ["pack_into"],   true]
    - [unpack_from_qualname_eq, unpack_from.__qualname__.__eq__,  ["unpack_from"], true]
    - [iter_unpack_qualname_eq, iter_unpack.__qualname__.__eq__,  ["iter_unpack"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__bases__[0].__name__ string eq check
#
# struct_extra27 covers Struct.__bases__[0].__name__.__len__()==6 (length only).
# No prior spec checks Struct.__bases__[0].__name__.__eq__('object').
# Length and string eq are independent regression vectors.
# ---------------------------------------------------------------------------

invariant struct_extra37.Struct_base_name_eq:
  description: "struct.Struct.__bases__[0].__name__ == 'object' — Struct inherits from object; novel: extra27 covers __bases__[0].__name__.__len__()==6 (length only); no prior spec checks the string eq value 'object' for Struct.__bases__[0].__name__"
  category: type_structure
  kind: python_call_eq
  function: "Struct.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# struct.calcsize('P') — native pointer size
#
# No prior struct spec checks calcsize with the 'P' format code.
# 'P' yields the native pointer size (void*): 8 on 64-bit, 4 on 32-bit.
# This system is 64-bit (macOS/Darwin 25.4.0), so calcsize('P') == 8.
# 'P' is explicitly architecture-dependent, unlike 'Q' (always 8 bytes).
# ---------------------------------------------------------------------------

invariant struct_extra37.calcsize_pointer:
  description: "struct.calcsize('P') == 8 — native pointer size on 64-bit macOS/Darwin; 'P' format is pointer-sized (void*); novel: no prior struct spec checks calcsize with the 'P' format code; verified Python 3.14 macOS/Darwin 25.4.0 (64-bit)"
  category: behavioral
  kind: python_call_eq
  function: calcsize
  args: ["P"]
  expected: 8
