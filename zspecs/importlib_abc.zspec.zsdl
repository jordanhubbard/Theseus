spec: importlib_abc
version: ">=3.1"
backend: python_module(importlib.abc)

docs: https://docs.python.org/3/library/importlib.html#importlib.abc

provenance:
  derived_from:
    - "Python 3 importlib.abc documentation — https://docs.python.org/3/library/importlib.html#importlib.abc"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/abc.py"
    - "importlib_extra.zspec.zsdl — covers importlib top-level module identity, import_module __spec__.name, find_loader, abc/machinery submodule __name__ via import_module"
    - "importlib.zspec.zsdl — covers importlib top-level functions and module behavior"
    - "importlib_util.zspec.zsdl — covers importlib.util subpackage"
    - "importlib_metadata.zspec.zsdl — covers importlib.metadata subpackage"
    - "importlib_resources.zspec.zsdl — covers importlib.resources subpackage"
  notes:
    - "importlib.abc defines abstract base classes for the import system."
    - "Finder is the legacy ABC for import finders (deprecated in 3.12 but still present)."
    - "Loader is the ABC that all loaders must implement."
    - "ResourceLoader, InspectLoader, ExecutionLoader, FileLoader extend Loader with additional capabilities."
    - "SourceLoader extends ResourceLoader and ExecutionLoader for source-based loaders."
    - "MetaPathFinder is the ABC for sys.meta_path finders (replaces Finder)."
    - "PathEntryFinder is the ABC for sys.path_hooks finders."
    - "All class __name__ values verified against Python 3.12 importlib.abc on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — verify __name__ of all importlib.abc ABCs
# ---------------------------------------------------------------------------

table importlib_abc.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Finder,            Finder.__name__.__eq__,            ["Finder"],            true]
    - [Loader,            Loader.__name__.__eq__,            ["Loader"],            true]
    - [ResourceLoader,    ResourceLoader.__name__.__eq__,    ["ResourceLoader"],    true]
    - [InspectLoader,     InspectLoader.__name__.__eq__,     ["InspectLoader"],     true]
    - [ExecutionLoader,   ExecutionLoader.__name__.__eq__,   ["ExecutionLoader"],   true]
    - [FileLoader,        FileLoader.__name__.__eq__,        ["FileLoader"],        true]
    - [SourceLoader,      SourceLoader.__name__.__eq__,      ["SourceLoader"],      true]
    - [MetaPathFinder,    MetaPathFinder.__name__.__eq__,    ["MetaPathFinder"],    true]
    - [PathEntryFinder,   PathEntryFinder.__name__.__eq__,   ["PathEntryFinder"],   true]

# ---------------------------------------------------------------------------
# Module checks — verify all ABCs belong to importlib.abc
# ---------------------------------------------------------------------------

table importlib_abc.modules:
  kind: python_call_eq
  category: modules
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [Finder,          Finder.__module__.__eq__,          ["importlib.abc"], true]
    - [Loader,          Loader.__module__.__eq__,          ["importlib.abc"], true]
    - [ResourceLoader,  ResourceLoader.__module__.__eq__,  ["importlib.abc"], true]
    - [InspectLoader,   InspectLoader.__module__.__eq__,   ["importlib.abc"], true]
    - [ExecutionLoader, ExecutionLoader.__module__.__eq__,  ["importlib.abc"], true]
    - [FileLoader,      FileLoader.__module__.__eq__,      ["importlib.abc"], true]
    - [SourceLoader,    SourceLoader.__module__.__eq__,    ["importlib.abc"], true]
    - [MetaPathFinder,  MetaPathFinder.__module__.__eq__,  ["importlib.abc"], true]
    - [PathEntryFinder, PathEntryFinder.__module__.__eq__,  ["importlib.abc"], true]
