spec: threading_extra286
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading class identity for synchronization primitives"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Lock is a factory function (builtin_function_or_method), not a class"
    - "threading.Timer inherits from threading.Thread"
    - "threading.BoundedSemaphore inherits from threading.Semaphore"
    - "All user-visible threading classes are pure-Python with __module__ == 'threading'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table threading_extra286.class_names:
  description: "Verify __name__ for threading synchronization classes"
  kind: python_call_eq
  category: identity
  id_prefix: tcn

  columns: [id, function, args, expected, description]
  rows:
    - [tcn001, threading.Thread.__name__.__eq__, ["Thread"], true, "threading.Thread.__name__ is 'Thread'"]
    - [tcn002, threading.Event.__name__.__eq__, ["Event"], true, "threading.Event.__name__ is 'Event'"]
    - [tcn003, threading.Condition.__name__.__eq__, ["Condition"], true, "threading.Condition.__name__ is 'Condition'"]
    - [tcn004, threading.Semaphore.__name__.__eq__, ["Semaphore"], true, "threading.Semaphore.__name__ is 'Semaphore'"]
    - [tcn005, threading.BoundedSemaphore.__name__.__eq__, ["BoundedSemaphore"], true, "threading.BoundedSemaphore.__name__ is 'BoundedSemaphore'"]
    - [tcn006, threading.Timer.__name__.__eq__, ["Timer"], true, "threading.Timer.__name__ is 'Timer'"]
    - [tcn007, threading.Barrier.__name__.__eq__, ["Barrier"], true, "threading.Barrier.__name__ is 'Barrier'"]

table threading_extra286.class_modules:
  description: "Verify __module__ for threading synchronization classes"
  kind: python_call_eq
  category: identity
  id_prefix: tcm

  columns: [id, function, args, expected, description]
  rows:
    - [tcm001, threading.Thread.__module__.__eq__, ["threading"], true, "threading.Thread.__module__ is 'threading'"]
    - [tcm002, threading.Event.__module__.__eq__, ["threading"], true, "threading.Event.__module__ is 'threading'"]
    - [tcm003, threading.Condition.__module__.__eq__, ["threading"], true, "threading.Condition.__module__ is 'threading'"]
    - [tcm004, threading.Semaphore.__module__.__eq__, ["threading"], true, "threading.Semaphore.__module__ is 'threading'"]
    - [tcm005, threading.Barrier.__module__.__eq__, ["threading"], true, "threading.Barrier.__module__ is 'threading'"]

invariant threading_extra286.thread_base_is_object:
  description: "threading.Thread base class is object"
  category: identity
  kind: python_call_eq
  function: threading.Thread.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant threading_extra286.boundedsemaphore_base_is_semaphore:
  description: "threading.BoundedSemaphore base class is Semaphore"
  category: identity
  kind: python_call_eq
  function: threading.BoundedSemaphore.__bases__[0].__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra286.timer_base_is_thread:
  description: "threading.Timer base class is Thread"
  category: identity
  kind: python_call_eq
  function: threading.Timer.__bases__[0].__name__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra286.barrier_module:
  description: "threading.Barrier.__module__ equals 'threading'"
  category: identity
  kind: python_call_eq
  function: threading.Barrier.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra286.lock_is_builtin_function:
  description: "threading.Lock.__class__.__name__ is 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: threading.Lock.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
