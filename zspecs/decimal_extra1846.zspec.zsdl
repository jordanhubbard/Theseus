spec: decimal_extra1846
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python 3 decimal module documentation"
    - "CPython source: Lib/_pydecimal.py, Modules/_decimal/"
    - "IBM General Decimal Arithmetic specification"
  not_derived_from:
    - "Any third-party decimal or numeric library"
  notes:
    - "decimal.Decimal defines full arithmetic protocol including __add__, __sub__, __mul__, __truediv__, __floordiv__, __mod__, __pow__"
    - "decimal.Decimal defines all rich comparison operators directly"
    - "decimal.Decimal.__ne__ is not defined; Python derives it from __eq__ negation"
    - "decimal.Decimal defines __hash__ (Decimal objects are hashable)"
    - "decimal.Context does not define arithmetic or comparison operators"
  created_at: "2026-04-12"

table decimal_extra1846.arithmetic_operators:
  columns: [id, function, args, expected]
  rows:
    - ["dc1846-arith-001", "decimal.Decimal.__dict__.__contains__", ["__add__"], true]
    - ["dc1846-arith-002", "decimal.Decimal.__dict__.__contains__", ["__sub__"], true]
    - ["dc1846-arith-003", "decimal.Decimal.__dict__.__contains__", ["__mul__"], true]
    - ["dc1846-arith-004", "decimal.Decimal.__dict__.__contains__", ["__truediv__"], true]
    - ["dc1846-arith-005", "decimal.Decimal.__dict__.__contains__", ["__floordiv__"], true]
    - ["dc1846-arith-006", "decimal.Decimal.__dict__.__contains__", ["__mod__"], true]
    - ["dc1846-arith-007", "decimal.Decimal.__dict__.__contains__", ["__pow__"], true]
    - ["dc1846-arith-008", "decimal.Context.__dict__.__contains__", ["__add__"], false]

table decimal_extra1846.comparison_operators:
  columns: [id, function, args, expected]
  rows:
    - ["dc1846-cmp-001", "decimal.Decimal.__dict__.__contains__", ["__eq__"], true]
    - ["dc1846-cmp-002", "decimal.Decimal.__dict__.__contains__", ["__lt__"], true]
    - ["dc1846-cmp-003", "decimal.Decimal.__dict__.__contains__", ["__gt__"], true]
    - ["dc1846-cmp-004", "decimal.Decimal.__dict__.__contains__", ["__le__"], true]
    - ["dc1846-cmp-005", "decimal.Decimal.__dict__.__contains__", ["__ge__"], true]
    - ["dc1846-cmp-006", "decimal.Decimal.__dict__.__contains__", ["__ne__"], false]
    - ["dc1846-cmp-007", "decimal.Decimal.__dict__.__contains__", ["__hash__"], true]
    - ["dc1846-cmp-008", "decimal.Context.__dict__.__contains__", ["__eq__"], false]

table decimal_extra1846.decimal_exception_hierarchy:
  columns: [id, function, args, expected]
  rows:
    - ["dc1846-exc-001", "decimal.__dict__.__contains__", ["DecimalException"], true]
    - ["dc1846-exc-002", "decimal.__dict__.__contains__", ["Clamped"], true]
    - ["dc1846-exc-003", "decimal.__dict__.__contains__", ["InvalidOperation"], true]
    - ["dc1846-exc-004", "decimal.__dict__.__contains__", ["DivisionByZero"], true]
    - ["dc1846-exc-005", "decimal.__dict__.__contains__", ["Overflow"], true]
    - ["dc1846-exc-006", "decimal.__dict__.__contains__", ["Underflow"], true]
    - ["dc1846-exc-007", "decimal.__dict__.__contains__", ["Inexact"], true]
    - ["dc1846-exc-008", "decimal.__dict__.__contains__", ["Rounded"], true]
    - ["dc1846-exc-009", "decimal.__dict__.__contains__", ["Subnormal"], true]
    - ["dc1846-exc-010", "decimal.__dict__.__contains__", ["FloatOperation"], true]
