spec: abc_extra841
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - abc module public API
  not_derived_from:
    - any third-party library
  notes:
    - Covers abc.ABCMeta method doc class names and abc module attribute class names
  created_at: "2026-04-12"

table abc_extra841.qualnames:
  description: abc.ABCMeta method doc class names and module attribute class identity checks
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: ab841
  columns: [id, function, args, expected]
  rows:
    - [ab841xx001, abc.ABCMeta.__new__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab841xx002, abc.ABCMeta.__init__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab841xx003, abc.ABCMeta.register.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab841xx004, abc.abstractmethod.__init__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab841xx005, abc.abstractmethod.__call__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab841xx006, abc.abstractmethod.__get__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab841xx007, abc.ABC.__class__.__name__.__eq__, ["ABCMeta"], true]
    - [ab841xx008, abc.ABCMeta.__class__.__name__.__eq__, ["type"], true]
    - [ab841xx009, abc.abstractmethod.__class__.__name__.__eq__, ["type"], true]
    - [ab841xx010, abc.get_cache_token.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ab841xx011, abc.ABC.__module__.__eq__, ["abc"], true]
    - [ab841xx012, abc.ABCMeta.__qualname__.__eq__, ["ABCMeta"], true]
