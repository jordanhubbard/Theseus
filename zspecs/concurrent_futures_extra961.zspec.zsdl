spec: concurrent_futures_extra961
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures exceptions documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks concurrent.futures exception class __name__, __module__, __qualname__ and module __spec__.name"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra961.cancelled_error_attrs:
  description: "concurrent.futures.CancelledError name and module identity"
  kind: python_call_eq
  category: exception_attrs
  id_prefix: cf961ce
  columns: [id, function, args, expected]
  rows:
    - [cf961ce001, concurrent.futures.CancelledError.__name__.__eq__,   ["CancelledError"], true]
    - [cf961ce002, concurrent.futures.CancelledError.__module__.__eq__, ["builtins"],       true]

