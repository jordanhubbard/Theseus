spec: pathlib_extra130
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path method __qualname__ values and lengths."
    - "Path methods are ordinary Python functions defined in pathlib._local (or pathlib in older versions)."
    - "pathlib.Path.open.__qualname__ = 'Path.open' (length 9)."
    - "pathlib.Path.read_text.__qualname__ = 'Path.read_text' (length 14)."
    - "pathlib.Path.write_text.__qualname__ = 'Path.write_text' (length 15)."
    - "pathlib.Path.read_bytes.__qualname__ = 'Path.read_bytes' (length 15)."
    - "pathlib.Path.write_bytes.__qualname__ = 'Path.write_bytes' (length 16)."
    - "pathlib.Path.mkdir.__qualname__ = 'Path.mkdir' (length 10)."
    - "pathlib.Path.unlink.__qualname__ = 'Path.unlink' (length 11)."
    - "pathlib.Path.rename.__qualname__ = 'Path.rename' (length 11)."
    - "pathlib.Path.stat.__qualname__ = 'Path.stat' (length 9)."
    - "pathlib.Path.exists.__qualname__ = 'Path.exists' (length 11)."
    - "pathlib.Path.glob.__qualname__ = 'Path.glob' (length 9)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path I/O method __qualname__ values
# open, read_text, write_text, read_bytes, write_bytes are all defined on Path.
# Qualname format: 'Path.<method>'.
# ---------------------------------------------------------------------------

table pathlib_extra130.Path_io_method_qualnames:
  description: "pathlib.Path I/O method __qualname__ values and lengths: open, read_text, write_text, read_bytes, write_bytes"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pathlibmeth130

  columns: [id, function, args, expected, description]
  rows:
    - [open_qname_eq,        Path.open.__qualname__.__eq__,        ["Path.open"],        true,  "Path.open.__qualname__ == 'Path.open'"]
    - [open_qname_len,       Path.open.__qualname__.__len__,       [],                   9,     "Path.open.__qualname__ has 9 characters"]
    - [read_text_qname_eq,   Path.read_text.__qualname__.__eq__,   ["Path.read_text"],   true,  "Path.read_text.__qualname__ == 'Path.read_text'"]
    - [read_text_qname_len,  Path.read_text.__qualname__.__len__,  [],                   14,    "Path.read_text.__qualname__ has 14 characters"]
    - [write_text_qname_eq,  Path.write_text.__qualname__.__eq__,  ["Path.write_text"],  true,  "Path.write_text.__qualname__ == 'Path.write_text'"]
    - [write_text_qname_len, Path.write_text.__qualname__.__len__, [],                   15,    "Path.write_text.__qualname__ has 15 characters"]
    - [read_bytes_qname_eq,  Path.read_bytes.__qualname__.__eq__,  ["Path.read_bytes"],  true,  "Path.read_bytes.__qualname__ == 'Path.read_bytes'"]
    - [read_bytes_qname_len, Path.read_bytes.__qualname__.__len__, [],                   15,    "Path.read_bytes.__qualname__ has 15 characters"]
    - [write_bytes_qname_eq, Path.write_bytes.__qualname__.__eq__, ["Path.write_bytes"], true,  "Path.write_bytes.__qualname__ == 'Path.write_bytes'"]
    - [write_bytes_qname_len,Path.write_bytes.__qualname__.__len__,[],                   16,    "Path.write_bytes.__qualname__ has 16 characters"]

