spec: transliterate
version: ">=1.0.0"
backend: node(@sindresorhus/transliterate)

docs: https://github.com/sindresorhus/transliterate#readme

provenance:
  derived_from:
    - "@sindresorhus/transliterate README — https://github.com/sindresorhus/transliterate#readme"
    - "Test vectors verified with @sindresorhus/transliterate via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "@sindresorhus/transliterate source"
  notes:
    - "Replaces accented Latin and Cyrillic characters with ASCII equivalents (alternative to unidecode); does NOT romanise CJK ideographs (those pass through)."
    - "Install: npm install @sindresorhus/transliterate"
    - "v1 ESM with CJS shim; default export is the function."
    - "Distinct from `unidecode` which DOES romanise CJK (e.g. '日本' → 'Ri Ben '); this package leaves CJK untouched."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table transliterate.fn:
  kind: node_module_call_eq
  category: transliterate
  function: default
  id_prefix: tr

  columns: [id, args, expected]
  rows:
    - [latin_diacritic,        ["Café"],     "Cafe"]
    - [umlaut,                 ["Müller"],   "Mueller"]
    - [eszett,                 ["straße"],   "strasse"]
    - [cyrillic_moscow,        ["Москва"],   "Moskva"]
    - [cjk_passthrough,        ["日本"],     "日本"]
    - [emoji_passthrough,      ["🎉"],       "🎉"]
    - [pure_ascii_passthrough, ["plain"],     "plain"]
    - [empty_input,            [""],          ""]
    - [mixed_with_ascii,       ["Café shop"],"Cafe shop"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:50:20Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
