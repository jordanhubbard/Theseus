spec: io_extra1846
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python 3 io module documentation"
    - "CPython source: Lib/io.py, Modules/_io/"
  not_derived_from:
    - "Any third-party IO library"
  notes:
    - "IO types do not define arithmetic operators; they rely on object identity for equality"
    - "BufferedWriter.flush is inherited from IOBase, not defined in BufferedWriter.__dict__"
    - "TextIOWrapper exposes encoding and errors as properties in its __dict__"
  created_at: "2026-04-12"

