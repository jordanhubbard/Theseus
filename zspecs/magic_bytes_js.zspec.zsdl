spec: magic_bytes_js
version: ">=1.0.0"
backend: node(magic-bytes.js)

docs: https://github.com/LarsKoelpin/magic-bytes#readme

provenance:
  derived_from:
    - "magic-bytes.js README — https://github.com/LarsKoelpin/magic-bytes#readme"
    - "PNG signature: ISO 15948 (89 50 4E 47 0D 0A 1A 0A)"
    - "JPEG signature: ITU-T T.81 (FF D8 FF)"
    - "PDF signature: ISO 32000 (25 50 44 46 — '%PDF')"
    - "Test vectors verified with magic-bytes.js via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "magic-bytes.js source"
  notes:
    - "File-type sniffing from magic bytes — synchronous, accepts plain arrays."
    - "Install: npm install magic-bytes.js"
    - "v1 CJS; named exports filetypename / filetypeextension / filetypemime / filetypeinfo / register."
    - "Returns arrays since one byte sequence may match multiple types (e.g. PNG also matches APNG)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on byte arrays."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant magic_bytes_js.png_detected:
  description: "PNG signature [89 50 4E 47 0D 0A 1A 0A] detected as 'png'"
  category: detect
  kind: node_chain_eq
  entry: named
  function: filetypename
  entry_args: [[137, 80, 78, 71, 13, 10, 26, 10]]
  chain:
    - {method: includes, args: ["png"]}
  expected: true

invariant magic_bytes_js.jpeg_detected:
  description: "JPEG signature [FF D8 FF E0] detected as 'jpg'"
  category: detect
  kind: node_chain_eq
  entry: named
  function: filetypename
  entry_args: [[255, 216, 255, 224, 0, 16, 74, 70, 73, 70]]
  chain:
    - {method: includes, args: ["jpg"]}
  expected: true

invariant magic_bytes_js.pdf_detected:
  description: "PDF signature [25 50 44 46] detected as 'pdf'"
  category: detect
  kind: node_chain_eq
  entry: named
  function: filetypename
  entry_args: [[37, 80, 68, 70]]
  chain:
    - {method: includes, args: ["pdf"]}
  expected: true

invariant magic_bytes_js.png_mime:
  description: "PNG mime is 'image/png'"
  category: mime
  kind: node_chain_eq
  entry: named
  function: filetypemime
  entry_args: [[137, 80, 78, 71, 13, 10, 26, 10]]
  chain:
    - {method: includes, args: ["image/png"]}
  expected: true

invariant magic_bytes_js.png_extension:
  description: "PNG extension is 'png'"
  category: extension
  kind: node_chain_eq
  entry: named
  function: filetypeextension
  entry_args: [[137, 80, 78, 71, 13, 10, 26, 10]]
  chain:
    - {method: includes, args: ["png"]}
  expected: true

invariant magic_bytes_js.unknown_bytes_empty:
  description: "Plain text bytes don't match any signature → empty array"
  category: detect
  kind: node_chain_eq
  entry: named
  function: filetypename
  entry_args: [[104, 101, 108, 108, 111]]
  chain:
    - {get: length}
  expected: 0

invariant magic_bytes_js.png_includes_apng_alt:
  description: "PNG signature also matches 'apng' (animated PNG)"
  category: detect
  kind: node_chain_eq
  entry: named
  function: filetypename
  entry_args: [[137, 80, 78, 71, 13, 10, 26, 10]]
  chain:
    - {method: includes, args: ["apng"]}
  expected: true
