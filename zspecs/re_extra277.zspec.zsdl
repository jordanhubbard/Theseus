spec: re_extra277
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.compile('hello').pattern == 'hello' — pattern attribute stores the original pattern string."
    - "re.compile('hello').flags == 32 — the default flags include re.UNICODE (32) only."
    - "re.compile('hello', re.IGNORECASE).flags == 34 — UNICODE(32) | IGNORECASE(2) == 34."
    - "re.compile('hello', re.MULTILINE).flags == 40 — UNICODE(32) | MULTILINE(8) == 40."
    - "re.compile('hello', re.DOTALL).flags == 48 — UNICODE(32) | DOTALL(16) == 48."
    - "re.compile('hello').__class__.__name__ == 'Pattern' — compiled regex objects are Pattern instances."
    - "re.compile('hello').__class__.__module__ == 're' — Pattern's module is 're'."
    - "re.Pattern.__name__ == 'Pattern' and __module__ == 're'."
    - "re.Pattern.__bases__[0].__name__ == 'object' — Pattern is a direct subclass of object."
    - "re.compile('hello').groups == 0 — no capturing groups in a plain literal pattern."
    - "re.compile.__class__.__name__ == 'function' — compile is a Python function, not a C builtin."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: re.compile() flags for common flag combinations
# ---------------------------------------------------------------------------

table re_extra277.compile_function_identity:
  description: "re.compile function __name__, __module__, and __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: cfi

  columns: [id, function, args, expected, description]
  rows:
    - [compile_name,   compile.__name__.__eq__,                ["compile"],                    true, "re.compile.__name__ == 'compile'"]
    - [compile_module, compile.__module__.__eq__,              ["re"],                         true, "re.compile.__module__ == 're'"]
    - [compile_class,  compile.__class__.__name__.__eq__,      ["function"],                   true, "re.compile.__class__.__name__ == 'function' — compile is a Python function"]

# NOTE: compile() result attributes (pattern, flags, groups) are checked via standalone invariants below
# because the table backend resolves function as an attribute chain on the module.

# ---------------------------------------------------------------------------
# Table: re.Pattern class identity
# ---------------------------------------------------------------------------

table re_extra277.pattern_class_identity:
  description: "re.Pattern __name__, __module__, __bases__[0].__name__, and __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: pci

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_name,    Pattern.__name__.__eq__,                 ["Pattern"], true, "re.Pattern.__name__ == 'Pattern'"]
    - [pattern_module,  Pattern.__module__.__eq__,               ["re"],      true, "re.Pattern.__module__ == 're'"]
    - [pattern_base,    "Pattern.__bases__[0].__name__.__eq__",  ["object"],  true, "re.Pattern.__bases__[0].__name__ == 'object' — Pattern is a direct subclass of object"]
    - [pattern_meta,    Pattern.__class__.__name__.__eq__,       ["type"],    true, "re.Pattern.__class__.__name__ == 'type' — Pattern is a plain class object"]

# ---------------------------------------------------------------------------
# Standalone invariants: compile() result attributes
# ---------------------------------------------------------------------------

invariant re_extra277.compile.pattern_attr:
  description: "re.compile('hello').pattern == 'hello' — pattern stores the original source string"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["hello"]
  method: pattern
  expected: "hello"

invariant re_extra277.compile.default_flags:
  description: "re.compile('hello').flags == 32 — default includes only re.UNICODE (32)"
  category: flags
  kind: python_call_eq
  function: compile
  args: ["hello"]
  method: flags
  expected: 32

invariant re_extra277.compile.ignorecase_flags:
  description: "re.compile('hello', re.IGNORECASE).flags == 34 — UNICODE(32) | IGNORECASE(2) == 34"
  category: flags
  kind: python_call_eq
  function: compile
  args: ["hello", 2]
  method: flags
  expected: 34

invariant re_extra277.compile.multiline_flags:
  description: "re.compile('hello', re.MULTILINE).flags == 40 — UNICODE(32) | MULTILINE(8) == 40"
  category: flags
  kind: python_call_eq
  function: compile
  args: ["hello", 8]
  method: flags
  expected: 40

invariant re_extra277.compile.dotall_flags:
  description: "re.compile('hello', re.DOTALL).flags == 48 — UNICODE(32) | DOTALL(16) == 48"
  category: flags
  kind: python_call_eq
  function: compile
  args: ["hello", 16]
  method: flags
  expected: 48

invariant re_extra277.compile.groups_zero:
  description: "re.compile('hello').groups == 0 — no capturing groups in a plain literal pattern"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["hello"]
  method: groups
  expected: 0

invariant re_extra277.compile.class_name:
  description: "re.compile('hello').__class__.__name__ == 'Pattern'"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["hello"]
  method: __class__.__name__
  expected: "Pattern"

invariant re_extra277.compile.class_module:
  description: "re.compile('hello').__class__.__module__ == 're'"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["hello"]
  method: __class__.__module__
  expected: "re"

invariant re_extra277.Pattern.name:
  description: "re.Pattern.__name__ == 'Pattern'"
  category: identity
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra277.Pattern.module:
  description: "re.Pattern.__module__ == 're'"
  category: identity
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra277.Pattern.base_is_object:
  description: "re.Pattern.__bases__[0].__name__ == 'object' — Pattern is a direct subclass of object"
  category: identity
  kind: python_call_eq
  function: "Pattern.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
