spec: pathlib_extra181
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers: pathlib.Path method identity — __name__ values and lengths for open, read_text, write_text, read_bytes, write_bytes, mkdir, stat."
    - "pathlib.Path.open.__name__ == 'open' (len=4: same as 'stat' below)."
    - "pathlib.Path.read_text.__name__ == 'read_text' (len=9)."
    - "pathlib.Path.write_text.__name__ == 'write_text' (len=10)."
    - "pathlib.Path.read_bytes.__name__ == 'read_bytes' (len=10; same len as write_text: 'read_bytes' (10) == 'write_text' (10))."
    - "pathlib.Path.write_bytes.__name__ == 'write_bytes' (len=11)."
    - "pathlib.Path.mkdir.__name__ == 'mkdir' (len=5)."
    - "pathlib.Path.stat.__name__ == 'stat' (len=4; same as open: 'stat' (4) == 'open' (4))."
    - "Name length ordering: open=stat (4) < mkdir (5) < read_text (9) < write_text=read_bytes (10) < write_bytes (11)."
    - "write_bytes (11) is the longest method name among those checked."
    - "open (4) == stat (4): the two 4-character method names in this spec."
    - "write_text (10) == read_bytes (10): coincidental tie between a write method and a read method at length 10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path short method names — open (4), mkdir (5), stat (4)
# open.__name__ == 'open' (len=4)
# mkdir.__name__ == 'mkdir' (len=5)
# stat.__name__ == 'stat' (len=4; same as open)
# ---------------------------------------------------------------------------

table pathlib_extra181.short_method_names:
  description: "Short method names: open (len=4), mkdir (len=5), stat (len=4); open (4) == stat (4): a two-way tie at 4; mkdir (5) > open=stat (4) by 1; stat (4) < mkdir (5) < read_text (9) in the name-length ordering"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmethods181

  columns: [id, function, args, expected, description]
  rows:
    - [open_name,     Path.open.__name__.__eq__,   ["open"],  true, "pathlib.Path.open.__name__ == 'open' — 'open' has 4 characters; open (4) == stat (4): the shortest method names in this spec tie at 4; open (4) < mkdir (5) by 1; open (4) < read_text (9) by 5; pathlib.Path.open() opens the file pointed to by the Path, returning a file object analogous to the built-in open(); confirmed Python 3.14.3 macOS"]
    - [open_name_len, Path.open.__name__.__len__,  [],        4,    "pathlib.Path.open.__name__.__len__() == 4 — 'open' has 4 characters; open (4) == stat (4): a two-way tie at the minimum name length among the Path methods in this spec; open (4) < mkdir (5) < read_text (9) < write_text=read_bytes (10) < write_bytes (11): open is the minimum in the name-length ordering; confirmed Python 3.14.3 macOS"]
    - [mkdir_name,    Path.mkdir.__name__.__eq__,  ["mkdir"], true, "pathlib.Path.mkdir.__name__ == 'mkdir' — 'mkdir' has 5 characters: 'm' (1) + 'kdir' (4) = 5; mkdir (5) > open=stat (4) by 1; mkdir (5) < read_text (9) by 4; pathlib.Path.mkdir() creates the directory named by the Path; confirmed Python 3.14.3 macOS"]
    - [mkdir_name_len,Path.mkdir.__name__.__len__, [],        5,    "pathlib.Path.mkdir.__name__.__len__() == 5 — 'mkdir' has 5 characters; mkdir (5) is between the shortest names (open=stat at 4) and the longer names (read_text at 9); mkdir (5) > open (4) by 1; mkdir (5) < read_text (9) by 4; confirmed Python 3.14.3 macOS"]
    - [stat_name,     Path.stat.__name__.__eq__,   ["stat"],  true, "pathlib.Path.stat.__name__ == 'stat' — 'stat' has 4 characters; stat (4) == open (4): a two-way tie at the minimum name length (4) among Path methods in this spec; stat (4) < mkdir (5) by 1; pathlib.Path.stat() returns a os.stat_result object with information about the path; confirmed Python 3.14.3 macOS"]
    - [stat_name_len, Path.stat.__name__.__len__,  [],        4,    "pathlib.Path.stat.__name__.__len__() == 4 — 'stat' has 4 characters; stat (4) == open (4): both are the minimum-length method names in this spec; stat (4) < mkdir (5) < read_text (9) < write_text=read_bytes (10) < write_bytes (11): stat is co-minimum with open in the name-length ordering; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.Path text I/O method names — read_text (9), write_text (10)
# read_text.__name__ == 'read_text' (len=9)
# write_text.__name__ == 'write_text' (len=10; len(write_text) == len(read_bytes))
# ---------------------------------------------------------------------------

table pathlib_extra181.text_method_names:
  description: "Text I/O method names: read_text (len=9), write_text (len=10); write_text (10) > read_text (9) by 1 because 'write' (5) > 'read' (4) by 1; write_text (10) == read_bytes (10): coincidental cross-category tie"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmethods181

  columns: [id, function, args, expected, description]
  rows:
    - [read_text_name,     Path.read_text.__name__.__eq__,   ["read_text"],  true, "pathlib.Path.read_text.__name__ == 'read_text' — 'read_text' has 9 characters: 'read' (4) + '_' (1) + 'text' (4) = 9; read_text (9) > mkdir (5) by 4; read_text (9) < write_text (10) by 1: the 'write' prefix (5) is 1 character longer than the 'read' prefix (4); pathlib.Path.read_text() returns the decoded text contents of the file; confirmed Python 3.14.3 macOS"]
    - [read_text_name_len, Path.read_text.__name__.__len__,  [],             9,    "pathlib.Path.read_text.__name__.__len__() == 9 — 'read_text' has 9 characters; read_text (9) < write_text=read_bytes (10) by 1; read_text (9) > mkdir (5) by 4; read_text (9) > open=stat (4) by 5; in the name-length ordering: open=stat (4) < mkdir (5) < read_text (9) < write_text=read_bytes (10) < write_bytes (11); confirmed Python 3.14.3 macOS"]
    - [write_text_name,    Path.write_text.__name__.__eq__,  ["write_text"], true, "pathlib.Path.write_text.__name__ == 'write_text' — 'write_text' has 10 characters: 'write' (5) + '_' (1) + 'text' (4) = 10; write_text (10) == read_bytes (10): a coincidental tie between a text-write method and a binary-read method at length 10; write_text (10) > read_text (9) by 1; write_text (10) < write_bytes (11) by 1; pathlib.Path.write_text() writes text content to the file; confirmed Python 3.14.3 macOS"]
    - [write_text_name_len,Path.write_text.__name__.__len__, [],             10,   "pathlib.Path.write_text.__name__.__len__() == 10 — 'write_text' has 10 characters; write_text (10) == read_bytes (10): the text-write and bytes-read methods tie at 10 despite belonging to different I/O categories; write_text (10) > read_text (9) by 1; write_text (10) < write_bytes (11) by 1; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.Path bytes I/O method names — read_bytes (10), write_bytes (11)
# read_bytes.__name__ == 'read_bytes' (len=10; same as write_text)
# write_bytes.__name__ == 'write_bytes' (len=11; longest in spec)
# ---------------------------------------------------------------------------

table pathlib_extra181.bytes_method_names:
  description: "Bytes I/O method names: read_bytes (len=10), write_bytes (len=11); write_bytes (11) > read_bytes (10) by 1; write_bytes (11) is the longest method name in this spec; read_bytes (10) == write_text (10): cross-category tie"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmethods181

  columns: [id, function, args, expected, description]
  rows:
    - [read_bytes_name,      Path.read_bytes.__name__.__eq__,   ["read_bytes"],  true, "pathlib.Path.read_bytes.__name__ == 'read_bytes' — 'read_bytes' has 10 characters: 'read' (4) + '_' (1) + 'bytes' (5) = 10; read_bytes (10) == write_text (10): coincidental cross-category tie between a binary-read method and a text-write method at length 10; read_bytes (10) > read_text (9) by 1 because 'bytes' (5) > 'text' (4) by 1; read_bytes (10) < write_bytes (11) by 1; pathlib.Path.read_bytes() returns the binary contents of the file as a bytes object; confirmed Python 3.14.3 macOS"]
    - [read_bytes_name_len,  Path.read_bytes.__name__.__len__,  [],              10,   "pathlib.Path.read_bytes.__name__.__len__() == 10 — 'read_bytes' has 10 characters; read_bytes (10) == write_text (10): the tie at 10 between read_bytes and write_text reflects that 'read' (4) + 'bytes' (5) + '_' (1) == 'write' (5) + 'text' (4) + '_' (1); read_bytes (10) < write_bytes (11) by 1; confirmed Python 3.14.3 macOS"]
    - [write_bytes_name,     Path.write_bytes.__name__.__eq__,  ["write_bytes"], true, "pathlib.Path.write_bytes.__name__ == 'write_bytes' — 'write_bytes' has 11 characters: 'write' (5) + '_' (1) + 'bytes' (5) = 11; write_bytes (11) is the longest method name in this spec: open=stat (4) < mkdir (5) < read_text (9) < write_text=read_bytes (10) < write_bytes (11); write_bytes (11) > write_text (10) by 1 because 'bytes' (5) > 'text' (4) by 1; pathlib.Path.write_bytes() writes a bytes object to the file; confirmed Python 3.14.3 macOS"]
    - [write_bytes_name_len, Path.write_bytes.__name__.__len__, [],              11,   "pathlib.Path.write_bytes.__name__.__len__() == 11 — 'write_bytes' has 11 characters; write_bytes (11) is the maximum name length among all Path methods in this spec; write_bytes (11) > write_text=read_bytes (10) by 1; write_bytes (11) > read_text (9) by 2; write_bytes (11) > mkdir (5) by 6; write_bytes (11) > open=stat (4) by 7; write_bytes is the global maximum in the name-length ordering for this spec; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra181.open_name_is_open:
  description: "pathlib.Path.open.__name__ == 'open' — 'open' has 4 characters; open (4) == stat (4): the two shortest method names in this spec tie at 4; open (4) < mkdir (5) by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.open.__name__.__eq__
  args: ["open"]
  expected: true

invariant pathlib_extra181.stat_name_is_stat:
  description: "pathlib.Path.stat.__name__ == 'stat' — 'stat' has 4 characters; stat (4) == open (4): both are the shortest method names in this spec; stat (4) < mkdir (5) by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.stat.__name__.__eq__
  args: ["stat"]
  expected: true

invariant pathlib_extra181.read_text_name_len_9:
  description: "pathlib.Path.read_text.__name__.__len__() == 9 — 'read_text' has 9 characters: 'read' (4) + '_' (1) + 'text' (4) = 9; read_text (9) < write_text=read_bytes (10) by 1; read_text (9) > mkdir (5) by 4; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.read_text.__name__.__len__
  args: []
  expected: 9

invariant pathlib_extra181.write_text_name_len_10:
  description: "pathlib.Path.write_text.__name__.__len__() == 10 — 'write_text' has 10 characters: 'write' (5) + '_' (1) + 'text' (4) = 10; write_text (10) == read_bytes (10): a coincidental cross-category tie; write_text (10) > read_text (9) by 1; write_text (10) < write_bytes (11) by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.write_text.__name__.__len__
  args: []
  expected: 10

invariant pathlib_extra181.read_bytes_name_len_10:
  description: "pathlib.Path.read_bytes.__name__.__len__() == 10 — 'read_bytes' has 10 characters: 'read' (4) + '_' (1) + 'bytes' (5) = 10; read_bytes (10) == write_text (10): tie between a binary-read and a text-write method; read_bytes (10) < write_bytes (11) by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.read_bytes.__name__.__len__
  args: []
  expected: 10

invariant pathlib_extra181.write_bytes_name_len_11:
  description: "pathlib.Path.write_bytes.__name__.__len__() == 11 — 'write_bytes' has 11 characters: 'write' (5) + '_' (1) + 'bytes' (5) = 11; write_bytes (11) is the global maximum name length in this spec; write_bytes (11) > read_bytes=write_text (10) by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.write_bytes.__name__.__len__
  args: []
  expected: 11

invariant pathlib_extra181.mkdir_name_len_5:
  description: "pathlib.Path.mkdir.__name__.__len__() == 5 — 'mkdir' has 5 characters; mkdir (5) > open=stat (4) by 1; mkdir (5) < read_text (9) by 4; mkdir is between the shortest (4) and medium (9) method name lengths in this spec; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.mkdir.__name__.__len__
  args: []
  expected: 5
