spec: hashlib_extra1156
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib.md5/sha1/sha224/sha256/sha384/sha512 __module__ and __qualname__, hashlib.new __qualname__/__module__/__class__.__name__, hashlib.algorithms_guaranteed/algorithms_available __class__.__name__/__qualname__/__module__, HASH instance __class__.__module__ and block_size/digest_size for sha1/sha224/sha384"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1156.constructor_module_and_qualname:
  description: "hashlib.md5, sha1, sha224, sha256, sha384, sha512 __module__ and __qualname__ identity"
  kind: python_call_eq
  category: constructor_module_qualname
  id_prefix: hl1156cm
  columns: [id, function, args, expected]
  rows:
    - [hl1156cm001, hashlib.md5.__module__.__eq__,                              ["_hashlib"],          true]
    - [hl1156cm002, hashlib.sha1.__module__.__eq__,                             ["_hashlib"],          true]
    - [hl1156cm003, hashlib.sha224.__module__.__eq__,                           ["_hashlib"],          true]
    - [hl1156cm004, hashlib.sha256.__module__.__eq__,                           ["_hashlib"],          true]
    - [hl1156cm005, hashlib.sha384.__module__.__eq__,                           ["_hashlib"],          true]
    - [hl1156cm006, hashlib.sha512.__module__.__eq__,                           ["_hashlib"],          true]
    - [hl1156cm007, hashlib.md5.__qualname__.__eq__,                            ["openssl_md5"],       true]
    - [hl1156cm008, hashlib.sha1.__qualname__.__eq__,                           ["openssl_sha1"],      true]
    - [hl1156cm009, hashlib.sha224.__qualname__.__eq__,                         ["openssl_sha224"],    true]
    - [hl1156cm010, hashlib.sha256.__qualname__.__eq__,                         ["openssl_sha256"],    true]
    - [hl1156cm011, hashlib.sha384.__qualname__.__eq__,                         ["openssl_sha384"],    true]
    - [hl1156cm012, hashlib.sha512.__qualname__.__eq__,                         ["openssl_sha512"],    true]
    - [hl1156cm013, hashlib.md5.__module__.__class__.__name__.__eq__,           ["str"],               true]
    - [hl1156cm014, hashlib.sha256.__module__.__class__.__name__.__eq__,        ["str"],               true]

table hashlib_extra1156.new_func_and_algorithms_set_attrs:
  description: "hashlib.new __qualname__/__module__/__class__.__name__ and algorithms_guaranteed/algorithms_available set class attrs"
  kind: python_call_eq
  category: new_func_algorithms_set_attrs
  id_prefix: hl1156na
  columns: [id, function, args, expected]
  rows:
    - [hl1156na001, hashlib.new.__qualname__.__eq__,                            ["__hash_new"],        true]
    - [hl1156na002, hashlib.new.__module__.__eq__,                              ["hashlib"],           true]
    - [hl1156na003, hashlib.new.__class__.__name__.__eq__,                      ["function"],          true]
    - [hl1156na004, hashlib.new.__module__.__class__.__name__.__eq__,           ["str"],               true]
    - [hl1156na005, hashlib.algorithms_guaranteed.__class__.__name__.__eq__,    ["set"],               true]
    - [hl1156na006, hashlib.algorithms_guaranteed.__class__.__qualname__.__eq__, ["set"],              true]
    - [hl1156na007, hashlib.algorithms_guaranteed.__class__.__module__.__eq__,  ["builtins"],          true]
    - [hl1156na008, hashlib.algorithms_available.__class__.__name__.__eq__,     ["set"],               true]
    - [hl1156na009, hashlib.algorithms_available.__class__.__qualname__.__eq__, ["set"],               true]
    - [hl1156na010, hashlib.algorithms_available.__class__.__module__.__eq__,   ["builtins"],          true]

table hashlib_extra1156.hash_instance_class_and_block_digest_sizes:
  description: "HASH instance __class__.__module__ and block_size/digest_size for sha1/sha224/sha384"
  kind: python_call_eq
  category: hash_instance_class_block_digest
  id_prefix: hl1156hb
  columns: [id, function, args, expected]
  rows:
    - [hl1156hb001, hashlib.md5().__class__.__module__.__eq__,                  ["_hashlib"],          true]
    - [hl1156hb002, hashlib.sha256().__class__.__module__.__eq__,               ["_hashlib"],          true]
    - [hl1156hb003, hashlib.md5().__class__.__qualname__.__eq__,                ["HASH"],              true]
    - [hl1156hb004, hashlib.sha256().__class__.__qualname__.__eq__,             ["HASH"],              true]
    - [hl1156hb005, hashlib.sha1().block_size.__eq__,                           [64],                  true]
    - [hl1156hb006, hashlib.sha224().block_size.__eq__,                         [64],                  true]
    - [hl1156hb007, hashlib.sha384().block_size.__eq__,                         [128],                 true]
    - [hl1156hb008, hashlib.sha1().digest_size.__eq__,                          [20],                  true]
    - [hl1156hb009, hashlib.sha224().digest_size.__eq__,                        [28],                  true]
    - [hl1156hb010, hashlib.sha384().digest_size.__eq__,                        [48],                  true]
    - [hl1156hb011, hashlib.sha224().name.__eq__,                               ["sha224"],             true]
    - [hl1156hb012, hashlib.sha384().name.__eq__,                               ["sha384"],             true]
    - [hl1156hb013, hashlib.sha1().name.__class__.__name__.__eq__,              ["str"],               true]
    - [hl1156hb014, hashlib.sha224().digest_size.__class__.__name__.__eq__,     ["int"],               true]
