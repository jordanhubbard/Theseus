spec: contextlib_extra23
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
    - "contextlib_extra22.zspec.zsdl — covers ExitStack/__enter__/__exit__ and AsyncExitStack/__aenter__/__aexit__ method __name__ and __qualname__"
    - "contextlib_extra21.zspec.zsdl — covers nullcontext/__name__/__qualname__/__module__; AbstractContextManager/__name__/__qualname__; AbstractAsyncContextManager/__name__/__qualname__"
  notes:
    - "This spec extends contextlib.zspec.zsdl through contextlib_extra22.zspec.zsdl."
    - "Prior specs cover: contextmanager, asynccontextmanager, closing, suppress, redirect_stdout, redirect_stderr, ExitStack, AsyncExitStack, nullcontext __name__/__qualname__/__module__/__bases__/__mro__."
    - "NEW: AbstractContextManager.__bases__[0].__name__ == 'ABC'; AbstractAsyncContextManager.__bases__[0].__name__ == 'ABC'."
    - "NEW: AbstractContextManager.__module__ == 'contextlib'; AbstractAsyncContextManager.__module__ == 'contextlib'."
    - "NEW: nullcontext.__bases__[0].__name__ == 'AbstractContextManager' — nullcontext directly inherits from AbstractContextManager."
    - "NEW: table of __bases__[0].__name__ for AbstractContextManager, AbstractAsyncContextManager, nullcontext, closing, suppress."
    - "contextlib.AbstractContextManager.__bases__[0].__name__ == 'ABC' — both abstract base classes derive from ABC (from abc module)."
    - "contextlib.nullcontext.__bases__[0].__name__ == 'AbstractContextManager' — nullcontext is a concrete subclass of AbstractContextManager."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# AbstractContextManager and AbstractAsyncContextManager — __module__
#
# No prior contextlib spec records the __module__ attribute for
# AbstractContextManager or AbstractAsyncContextManager as standalone
# invariants in the extra23 namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra23.AbstractContextManager.module:
  description: "contextlib.AbstractContextManager.__module__ == 'contextlib'"
  category: class_attrs
  kind: python_call_eq
  function: AbstractContextManager.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra23.AbstractAsyncContextManager.module:
  description: "contextlib.AbstractAsyncContextManager.__module__ == 'contextlib'"
  category: class_attrs
  kind: python_call_eq
  function: AbstractAsyncContextManager.__module__.__eq__
  args: ["contextlib"]
  expected: true

# ---------------------------------------------------------------------------
# nullcontext — base class name (extra23 namespace)
#
# nullcontext inherits directly from AbstractContextManager. No prior spec
# covers nullcontext.__bases__[0].__name__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant contextlib_extra23.nullcontext.base_name:
  description: "contextlib.nullcontext.__bases__[0].__name__ == 'AbstractContextManager'"
  category: class_hierarchy
  kind: python_call_eq
  function: "nullcontext.__bases__[0].__name__.__eq__"
  args: ["AbstractContextManager"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy table — __bases__[0].__name__ for five contextlib classes
#
# No prior contextlib spec collects the immediate base class name for
# AbstractContextManager, AbstractAsyncContextManager, nullcontext, closing,
# and suppress together in a single table. This table provides that grouped
# coverage under the extra23 namespace.
# ---------------------------------------------------------------------------

table contextlib_extra23.base_class_names:
  description: "__bases__[0].__name__ for five contextlib classes"
  kind: python_call_eq
  category: class_hierarchy

  columns: [id, function, args, expected]
  rows:
    - [AbstractContextManager,      "AbstractContextManager.__bases__[0].__name__.__eq__",      ["ABC"],                    true]
    - [AbstractAsyncContextManager, "AbstractAsyncContextManager.__bases__[0].__name__.__eq__", ["ABC"],                    true]
    - [nullcontext,                 "nullcontext.__bases__[0].__name__.__eq__",                 ["AbstractContextManager"], true]
    - [closing,                     "closing.__bases__[0].__name__.__eq__",                     ["AbstractContextManager"], true]
    - [suppress,                    "suppress.__bases__[0].__name__.__eq__",                    ["AbstractContextManager"], true]

# ---------------------------------------------------------------------------
# contextmanager and asynccontextmanager — __module__ (extra23 namespace)
#
# No prior contextlib spec covers __module__ for contextmanager/
# asynccontextmanager as standalone invariants in the extra23 namespace.
# These re-anchor the module identity check for the decorator functions.
# ---------------------------------------------------------------------------

invariant contextlib_extra23.contextmanager.module:
  description: "contextlib.contextmanager.__module__ == 'contextlib'"
  category: function_attrs
  kind: python_call_eq
  function: contextmanager.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra23.asynccontextmanager.module:
  description: "contextlib.asynccontextmanager.__module__ == 'contextlib'"
  category: function_attrs
  kind: python_call_eq
  function: asynccontextmanager.__module__.__eq__
  args: ["contextlib"]
  expected: true
