spec: smart_buffer
version: ">=4.0.0"
backend: node(smart-buffer)

docs: https://github.com/JoshGlazebrook/smart-buffer#readme

provenance:
  derived_from:
    - "smart-buffer README — https://github.com/JoshGlazebrook/smart-buffer#readme"
    - "Test vectors verified with smart-buffer via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "smart-buffer source"
  notes:
    - "Wrapper around Node Buffer with auto-growing read/write cursors and high-level helpers (writeStringNT, readUInt32BE, ...)."
    - "Install: npm install smart-buffer"
    - "v4 CJS; named export SmartBuffer (class) plus static factories fromBuffer / fromOptions / fromSize."
    - "Spec tests static shape; instance behavior with binary state isn't a great fit for JSON-driven invariants."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws RangeError on read past end; otherwise pure within instance."
  stderr: "null"
  stickiness: "Each SmartBuffer carries internal read/write offsets."
  codes: {}

invariant smart_buffer.has_SmartBuffer:
  description: "SmartBuffer class exposed as a named export"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "SmartBuffer.constructor.name"}
  expected: "Function"

invariant smart_buffer.SmartBuffer_name:
  description: "SmartBuffer.name is 'SmartBuffer'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "SmartBuffer.name"}
  expected: "SmartBuffer"

invariant smart_buffer.has_fromBuffer_static:
  description: "SmartBuffer.fromBuffer static factory exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "SmartBuffer.fromBuffer.constructor.name"}
  expected: "Function"

invariant smart_buffer.has_fromOptions_static:
  description: "SmartBuffer.fromOptions static factory exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "SmartBuffer.fromOptions.constructor.name"}
  expected: "Function"

invariant smart_buffer.has_fromSize_static:
  description: "SmartBuffer.fromSize static factory exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "SmartBuffer.fromSize.constructor.name"}
  expected: "Function"

invariant smart_buffer.prototype_has_writeStringNT:
  description: "Instance method writeStringNT is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "SmartBuffer.prototype.writeStringNT.constructor.name"}
  expected: "Function"

invariant smart_buffer.prototype_has_readStringNT:
  description: "Instance method readStringNT is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "SmartBuffer.prototype.readStringNT.constructor.name"}
  expected: "Function"

invariant smart_buffer.prototype_has_toBuffer:
  description: "Instance method toBuffer is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "SmartBuffer.prototype.toBuffer.constructor.name"}
  expected: "Function"

