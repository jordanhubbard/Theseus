spec: math_extra18
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl and prior extras through math_extra17.zspec.zsdl."
    - "math_extra17 covers: log(1)==0.0, log(1,10)==0.0, log2(1/2/4/8), log10(1/10/100), exp(0), sqrt(0/1/4/9/16), pow(2,0), pow(2,3), pow(10,2)."
    - "No prior spec covers math.log(math.e) == 1.0 — log base e of e is exactly 1."
    - "No prior spec covers math.log10(1000) == 3.0 — log base 10 of 1000 is exactly 3."
    - "No prior spec covers math.pow(2, 10) == 1024.0 — 2 to the 10th power is 1024."
    - "No prior spec covers math.sqrt(144) == 12.0 — square root of 144 is exactly 12."
    - "No prior spec covers math.gcd with (0,5), (12,8), (100,75), or (7,0) arguments."
    - "math.log(math.e) == 1.0 — the natural log is its own inverse at e."
    - "math.log10(1000) == 3.0 — 10^3 == 1000 exactly."
    - "math.pow(2, 10) == 1024.0 — math.pow always returns float; 2**10 == 1024."
    - "math.sqrt(144) == 12.0 — 12*12 == 144, so sqrt(144) is exactly 12.0."
    - "math.gcd(0, 5) == 5 — gcd(0, n) == n by convention."
    - "math.gcd(12, 8) == 4 — 12 = 4*3, 8 = 4*2."
    - "math.gcd(100, 75) == 25 — 100 = 25*4, 75 = 25*3."
    - "math.gcd(7, 0) == 7 — gcd(n, 0) == n by convention."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# log, log10, pow, sqrt — new argument vectors not covered in prior specs
#
# math_extra17 covers log(1), log(1,10), log2(1/2/4/8), log10(1/10/100),
# exp(0), sqrt(0/1/4/9/16), pow(2,0/3), pow(10,2).
# New vectors: log(e)==1.0, log10(1000)==3.0, pow(2,10)==1024.0, sqrt(144)==12.0.
# ---------------------------------------------------------------------------

invariant math_extra18.log.log_e:
  description: "math.log(math.e) == 1.0 — natural log of e is exactly 1"
  category: logarithm
  kind: python_call_eq
  function: log
  args: [2.718281828459045]
  expected: 1.0

invariant math_extra18.log10.log10_1000:
  description: "math.log10(1000) == 3.0 — log base 10 of 1000 is exactly 3"
  category: logarithm
  kind: python_call_eq
  function: log10
  args: [1000]
  expected: 3.0

invariant math_extra18.pow.pow_2_10:
  description: "math.pow(2, 10) == 1024.0 — 2 to the 10th power returns float 1024.0"
  category: exponents
  kind: python_call_eq
  function: pow
  args: [2, 10]
  expected: 1024.0

invariant math_extra18.sqrt.sqrt_144:
  description: "math.sqrt(144) == 12.0 — square root of 144 is exactly 12.0"
  category: exponents
  kind: python_call_eq
  function: sqrt
  args: [144]
  expected: 12.0

# ---------------------------------------------------------------------------
# math.gcd — greatest common divisor
#
# math.gcd(0, n) == n and math.gcd(n, 0) == n by convention (gcd with zero).
# No prior math spec covers any gcd vectors.
# ---------------------------------------------------------------------------

table math_extra18.gcd:
  kind: python_call_eq
  category: number_theory
  id_prefix: gcd

  columns: [id, function, args, expected]
  rows:
    - [gcd_zero_five,       gcd, [0, 5],     5]
    - [gcd_twelve_eight,    gcd, [12, 8],    4]
    - [gcd_hundred_75,      gcd, [100, 75],  25]
    - [gcd_seven_zero,      gcd, [7, 0],     7]
