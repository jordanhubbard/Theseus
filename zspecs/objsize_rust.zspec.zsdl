spec: objsize_rust
version: ">=3.9"
backend: rust_module(objsize_rust)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys documentation"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
  notes:
    - "Additional sys operations not in sys_rust and sys_extra_rust."
    - "sys.getsizeof(0) returns the size of an integer in bytes."
    - "sys.getsizeof('') returns the size of an empty string."
    - "sys.getsizeof([]) returns the size of an empty list."
    - "sys.getsizeof({}) returns the size of an empty dict."
    - "sys.getsizeof(True) returns the size of a boolean."
    - "Expose getsizeof_int(n) -> int: sys.getsizeof(n)."
    - "Expose getsizeof_str(s) -> int: sys.getsizeof(s)."
    - "Expose getsizeof_list(lst) -> int: sys.getsizeof(lst)."
    - "getsizeof(0) > 0 — always positive."
    - "getsizeof('') < getsizeof('hello') — longer string uses more memory."
    - "All test vectors verified against Python 3.14.3."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# getsizeof returns positive values
table objsize_rust.getsizeof.positive:
  kind: python_call_eq
  category: positive
  id_prefix: sz_pos
  function: getsizeof_positive

  columns: [id, args, expected]
  rows:
    - [int_zero, [0],     true]
    - [str_empty, [""],   true]
    - [list_empty, [[]],  true]
    - [bool_true, [true], true]

# larger strings take more space
invariant objsize_rust.getsizeof.str_size_grows:
  description: "getsizeof('hello') > getsizeof('')"
  category: comparison
  kind: python_call_eq
  function: str_size_grows
  args: []
  expected: true

# larger lists take more space
invariant objsize_rust.getsizeof.list_size_grows:
  description: "getsizeof([1,2,3]) > getsizeof([])"
  category: comparison
  kind: python_call_eq
  function: list_size_grows
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:58:02Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
