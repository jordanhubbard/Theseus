spec: socket_extra7
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "This spec extends prior socket specs."
    - "Focus: socket function names and error hierarchy not yet covered."
    - "socket.error.__name__ == 'OSError' (alias for OSError)."
    - "socket.herror.__name__ == 'herror'."
    - "socket.gaierror.__name__ == 'gaierror'."
    - "socket.timeout.__name__ == 'timeout'."
    - "socket.gethostname.__name__ == 'gethostname'."
    - "socket.gethostbyname.__name__ == 'gethostbyname'."
    - "socket.getaddrinfo.__name__ == 'getaddrinfo'."
    - "socket.getnameinfo.__name__ == 'getnameinfo'."
    - "socket.getfqdn.__name__ == 'getfqdn'."
    - "socket.setdefaulttimeout.__name__ == 'setdefaulttimeout'."
    - "socket.getdefaulttimeout.__name__ == 'getdefaulttimeout'."
    - "socket.create_connection.__name__ == 'create_connection'."
    - "socket.create_server.__name__ == 'create_server'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table socket_extra7.exception_names:
  kind: python_call_eq
  category: exceptions
  id_prefix: exc

  columns: [id, function, args, expected]
  rows:
    - [herror,   herror.__name__.__eq__,   ["herror"],   true]
    - [gaierror, gaierror.__name__.__eq__, ["gaierror"], true]
    - [timeout,  timeout.__name__.__eq__,  ["timeout"],  true]

table socket_extra7.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [gethostname,        gethostname.__name__.__eq__,        ["gethostname"],        true]
    - [gethostbyname,      gethostbyname.__name__.__eq__,      ["gethostbyname"],      true]
    - [getaddrinfo,        getaddrinfo.__name__.__eq__,        ["getaddrinfo"],        true]
    - [getnameinfo,        getnameinfo.__name__.__eq__,        ["getnameinfo"],        true]
    - [getfqdn,            getfqdn.__name__.__eq__,            ["getfqdn"],            true]
    - [setdefaulttimeout,  setdefaulttimeout.__name__.__eq__,  ["setdefaulttimeout"],  true]
    - [getdefaulttimeout,  getdefaulttimeout.__name__.__eq__,  ["getdefaulttimeout"],  true]
    - [create_connection,  create_connection.__name__.__eq__,  ["create_connection"],  true]
    - [create_server,      create_server.__name__.__eq__,      ["create_server"],      true]

invariant socket_extra7.herror.base:
  description: "socket.herror.__bases__[0].__name__ == 'OSError'"
  category: exceptions
  kind: python_call_eq
  function: herror.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

invariant socket_extra7.gaierror.base:
  description: "socket.gaierror.__bases__[0].__name__ == 'OSError'"
  category: exceptions
  kind: python_call_eq
  function: gaierror.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

invariant socket_extra7.timeout.base:
  description: "socket.timeout.__bases__[0].__name__ == 'TimeoutError'"
  category: exceptions
  kind: python_call_eq
  function: timeout.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "TimeoutError"

invariant socket_extra7.gethostname.returns_str:
  description: "socket.gethostname().__class__.__name__ == 'str'"
  category: gethostname
  kind: python_call_eq
  function: gethostname
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

invariant socket_extra7.getdefaulttimeout.returns_none:
  description: "socket.getdefaulttimeout().__class__.__name__ == 'NoneType' (default is None)"
  category: getdefaulttimeout
  kind: python_call_eq
  function: getdefaulttimeout
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["NoneType"]
  expected: true

invariant socket_extra7.AF_INET6.value:
  description: "socket.AF_INET6 == 30 on macOS (platform-specific)"
  category: constants
  kind: python_call_eq
  function: AF_INET6.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra7.IPPROTO_UDP.value:
  description: "socket.IPPROTO_UDP == 17"
  category: constants
  kind: python_call_eq
  function: IPPROTO_UDP.__eq__
  args: [17]
  expected: true
