spec: decimal_extra277
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification, Version 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "decimal_extra276 covers Decimal comparison operator dunder methods."
    - "This spec focuses on Decimal.normalize() — trailing-zero removal and coefficient normalization."
    - "Decimal('1.00').normalize() == Decimal('1') — trailing zeros after the decimal point are stripped."
    - "str(Decimal('1.00').normalize()) == '1' — the string form of the normalized value has no decimal point."
    - "Decimal('1E+2').normalize() == Decimal('1E+2') — an already-normalized scientific form is returned unchanged."
    - "Decimal('100.0').normalize() == Decimal('1E+2') — trailing zeros before an implicit decimal convert to scientific notation."
    - "Decimal('1.50').normalize() == Decimal('1.5') — only trailing zeros are removed, significant digits are kept."
    - "Decimal('0.0').normalize() == Decimal('0') — zero normalizes to a plain zero with no decimal point."
    - "Decimal('0.0').normalize().__class__.__name__ == 'Decimal' — the result is still a Decimal, not int or float."
    - "Decimal('-1.00').normalize() == Decimal('-1') — normalize preserves the sign."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal.normalize() — trailing-zero removal
# normalize() removes trailing zeros from the coefficient, adjusting the
# exponent accordingly.  The mathematical value is unchanged.
# Decimal('1.00').normalize()  -> Decimal('1')       str -> '1'
# Decimal('1.50').normalize()  -> Decimal('1.5')     str -> '1.5'
# Decimal('100.0').normalize() -> Decimal('1E+2')    str -> '1E+2'
# Decimal('0.0').normalize()   -> Decimal('0')       str -> '0'
# Decimal('-1.00').normalize() -> Decimal('-1')      str -> '-1'
# ---------------------------------------------------------------------------

table decimal_extra277.normalize_results:
  description: "Decimal.normalize() strips trailing zeros; str() of the result confirms the canonical form"
  kind: python_call_eq
  category: normalize
  id_prefix: decnorm277

  columns: [id, function, args, expected, description]
  rows:
    - [one_pt_zero_zero, "Decimal('1.00').normalize().__str__",   [], "1",    "str(Decimal('1.00').normalize()) == '1' — trailing zeros stripped"]
    - [one_pt_five,      "Decimal('1.50').normalize().__str__",   [], "1.5",  "str(Decimal('1.50').normalize()) == '1.5' — only trailing zeros removed"]
    - [one_e2,           "Decimal('1E+2').normalize().__str__",   [], "1E+2", "str(Decimal('1E+2').normalize()) == '1E+2' — already normalized, unchanged"]
    - [hundred_pt_zero,  "Decimal('100.0').normalize().__str__",  [], "1E+2", "str(Decimal('100.0').normalize()) == '1E+2' — trailing zeros fold into exponent"]
    - [zero_pt_zero,     "Decimal('0.0').normalize().__str__",    [], "0",    "str(Decimal('0.0').normalize()) == '0' — zero normalizes to plain '0'"]
    - [neg_one_pt_zero,  "Decimal('-1.00').normalize().__str__",  [], "-1",   "str(Decimal('-1.00').normalize()) == '-1' — sign is preserved"]

# ---------------------------------------------------------------------------
# Decimal.normalize() class identity and value equality
# The return type is always Decimal; value equality holds across
# different textual representations of the same number.
# ---------------------------------------------------------------------------

table decimal_extra277.normalize_class_and_equality:
  description: "Decimal.normalize() always returns a Decimal; value equality confirms canonical equivalence"
  kind: python_call_eq
  category: normalize_identity
  id_prefix: decnormid277

  columns: [id, function, args, expected, description]
  rows:
    - [class_name,       "Decimal('0.0').normalize().__class__.__name__.__eq__",  ["Decimal"],  true, "Decimal('0.0').normalize().__class__.__name__ == 'Decimal'"]
    - [not_float,        "Decimal('0.0').normalize().__class__.__name__.__eq__",  ["float"],    false,"normalize() does not return a float"]
    - [not_int,          "Decimal('0.0').normalize().__class__.__name__.__eq__",  ["int"],      false,"normalize() does not return an int"]
    - [eq_one,           "Decimal('1.00').normalize().__eq__",                    ["Decimal('1')"], true, "Decimal('1.00').normalize() == Decimal('1')"]
    - [eq_one_e2,        "Decimal('1E+2').normalize().__eq__",                    ["Decimal('1E+2')"], true, "Decimal('1E+2').normalize() == Decimal('1E+2')"]
    - [hundred_eq_1e2,   "Decimal('100.0').normalize().__eq__",                   ["Decimal('1E+2')"], true, "Decimal('100.0').normalize() == Decimal('1E+2')"]
    - [zero_is_zero,     "Decimal('0.0').normalize().is_zero",                    [],           true, "Decimal('0.0').normalize().is_zero() is True"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra277.normalize.one_point_zero_zero_str:
  description: "str(Decimal('1.00').normalize()) == '1' — normalize() strips both trailing zeros, leaving no decimal point"
  category: normalize
  kind: python_call_eq
  function: "Decimal('1.00').normalize().__str__"
  args: []
  expected: "1"

invariant decimal_extra277.normalize.one_point_five_str:
  description: "str(Decimal('1.50').normalize()) == '1.5' — only the trailing zero is removed; the significant '5' digit is preserved"
  category: normalize
  kind: python_call_eq
  function: "Decimal('1.50').normalize().__str__"
  args: []
  expected: "1.5"

invariant decimal_extra277.normalize.hundred_point_zero_str:
  description: "str(Decimal('100.0').normalize()) == '1E+2' — trailing zeros before the implicit decimal convert to scientific notation"
  category: normalize
  kind: python_call_eq
  function: "Decimal('100.0').normalize().__str__"
  args: []
  expected: "1E+2"

invariant decimal_extra277.normalize.zero_str:
  description: "str(Decimal('0.0').normalize()) == '0' — zero with a decimal trailing zero normalizes to the bare digit '0'"
  category: normalize
  kind: python_call_eq
  function: "Decimal('0.0').normalize().__str__"
  args: []
  expected: "0"

invariant decimal_extra277.normalize.class_is_Decimal:
  description: "Decimal('0.0').normalize().__class__.__name__ == 'Decimal' — normalize() always returns a Decimal instance, never int or float"
  category: normalize_identity
  kind: python_call_eq
  function: "Decimal('0.0').normalize().__class__.__name__.__eq__"
  args: ["Decimal"]
  expected: true

invariant decimal_extra277.normalize.eq_decimal_one:
  description: "Decimal('1.00').normalize() == Decimal('1') — value equality holds; the normalized form and the integer form represent the same number"
  category: normalize_identity
  kind: python_call_eq
  function: "Decimal('1.00').normalize().__eq__"
  args: ["Decimal('1')"]
  expected: true

invariant decimal_extra277.normalize.negative_sign_preserved:
  description: "str(Decimal('-1.00').normalize()) == '-1' — normalize() preserves the negative sign while stripping trailing zeros"
  category: normalize
  kind: python_call_eq
  function: "Decimal('-1.00').normalize().__str__"
  args: []
  expected: "-1"

invariant decimal_extra277.normalize.zero_is_zero:
  description: "Decimal('0.0').normalize().is_zero() is True — the normalized form of any zero value reports as zero"
  category: normalize_identity
  kind: python_call_eq
  function: "Decimal('0.0').normalize().is_zero"
  args: []
  expected: true
