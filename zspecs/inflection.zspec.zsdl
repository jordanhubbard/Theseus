spec: inflection
version: ">=1.3.0"
backend: node(inflection)

docs: https://www.npmjs.com/package/inflection

provenance:
  derived_from:
    - "inflection README — https://www.npmjs.com/package/inflection"
    - "Test vectors verified with inflection via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "inflection source"
  notes:
    - "inflection is an npm package. Install: npm install inflection"
    - "inflection.pluralize(word) returns the plural form of an English word."
    - "inflection.singularize(word) returns the singular form of an English word."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns transformed string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table inflection.pluralize:
  kind: node_module_call_eq
  function: pluralize
  category: pluralize
  id_prefix: inflpl

  columns: [id, args, expected]
  rows:
    - [cat,    ["cat"],    "cats"]
    - [bus,    ["bus"],    "buses"]
    - [child,  ["child"],  "children"]
    - [fish,   ["fish"],   "fishes"]
    - [matrix, ["matrix"], "matrices"]

table inflection.singularize:
  kind: node_module_call_eq
  function: singularize
  category: singularize
  id_prefix: inflsg

  columns: [id, args, expected]
  rows:
    - [cats,     ["cats"],     "cat"]
    - [buses,    ["buses"],    "bus"]
    - [children, ["children"], "child"]
    - [fish,     ["fishes"],   "fish"]
    - [matrices, ["matrices"], "matrix"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:18:24Z
  iterations: 1
  pass_count: 10
  fail_count: 0
  total_invariants: 10
  notes: Synthesis succeeded in 1 iteration(s). 10 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
