spec: decimal_extra1951
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "Wave 577 (_extra1951): __contains__, __iter__, __next__, __aiter__, __anext__ dict-presence checks."
    - "decimal.Decimal is a numeric type; it does not implement any iteration or membership protocol."
    - "decimal.Context manages precision/rounding settings; it defines no iteration protocol methods."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.DivisionByZero, decimal.Overflow are exceptions."
    - "None of the decimal types define __contains__, __iter__, __next__, __aiter__, or __anext__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

table decimal_extra1951.contains_protocol:
  description: "decimal types __contains__ dict-presence checks — none define __contains__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1951

  columns: [id, function, args, expected]
  rows:
    - ["dc1951001", "decimal.Decimal.__dict__.__contains__",          ["__contains__"], false]
    - ["dc1951002", "decimal.Context.__dict__.__contains__",          ["__contains__"], false]
    - ["dc1951003", "decimal.DecimalException.__dict__.__contains__", ["__contains__"], false]
    - ["dc1951004", "decimal.InvalidOperation.__dict__.__contains__", ["__contains__"], false]
    - ["dc1951005", "decimal.DivisionByZero.__dict__.__contains__",   ["__contains__"], false]
    - ["dc1951006", "decimal.Overflow.__dict__.__contains__",         ["__contains__"], false]

