spec: as2971
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/asyncio-task.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-sync.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-eventloop.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "asyncio source: internal C-level accelerators (_asyncio extension)"
  notes:
    - "Wave 645 — theme: __floor__, __ceil__, __index__ dict-presence (floor, ceiling, integer-index)."
    - "Tests operator.contains(SomeClass.__dict__, '__floor__') etc. for asyncio classes."
    - "None of the asyncio classes (Task, Future, Queue, Event, Semaphore, BoundedSemaphore, Lock, Condition, Handle, TimerHandle, Timeout, TaskGroup) define __floor__, __ceil__, or __index__ in their own __dict__."
    - "These are concurrency/IO primitives; numeric dunder absence is the expected invariant."
    - "Task and Future are C-accelerated (_asyncio); the __dict__ check still correctly returns False for these numeric slots."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __floor__ dict-presence — operator.contains(Cls.__dict__, '__floor__')
#
# None of the asyncio classes define __floor__; all results are false.
# ---------------------------------------------------------------------------

table as2971.floor:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_floor
  id_prefix: flr

  columns: [id, function, args, expected]
  rows:
    - ["flr_Task",            operator.contains, [Task.__dict__,            "__floor__"], false]
    - ["flr_Future",          operator.contains, [Future.__dict__,          "__floor__"], false]
    - ["flr_Queue",           operator.contains, [Queue.__dict__,           "__floor__"], false]
    - ["flr_Event",           operator.contains, [Event.__dict__,           "__floor__"], false]
    - ["flr_Semaphore",       operator.contains, [Semaphore.__dict__,       "__floor__"], false]
    - ["flr_BoundedSemaphore",operator.contains, [BoundedSemaphore.__dict__,"__floor__"], false]
    - ["flr_Lock",            operator.contains, [Lock.__dict__,            "__floor__"], false]
    - ["flr_Condition",       operator.contains, [Condition.__dict__,       "__floor__"], false]
    - ["flr_Handle",          operator.contains, [Handle.__dict__,          "__floor__"], false]
    - ["flr_TimerHandle",     operator.contains, [TimerHandle.__dict__,     "__floor__"], false]
    - ["flr_Timeout",         operator.contains, [Timeout.__dict__,         "__floor__"], false]
    - ["flr_TaskGroup",       operator.contains, [TaskGroup.__dict__,       "__floor__"], false]

