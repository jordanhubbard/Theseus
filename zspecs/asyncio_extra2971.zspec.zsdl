    - ["comb_Lock_idx",       operator.contains, [Lock.__dict__,      "__index__"], false]
    - ["comb_Semaphore_flr",  operator.contains, [Semaphore.__dict__, "__floor__"], false]
    - ["comb_Semaphore_ceil", operator.contains, [Semaphore.__dict__, "__ceil__"],  false]
    - ["comb_Semaphore_idx",  operator.contains, [Semaphore.__dict__, "__index__"], false]
    - ["comb_Timeout_flr",    operator.contains, [Timeout.__dict__,   "__floor__"], false]
    - ["comb_Timeout_ceil",   operator.contains, [Timeout.__dict__,   "__ceil__"],  false]
    - ["comb_Timeout_idx",    operator.contains, [Timeout.__dict__,   "__index__"], false]
    - ["comb_TaskGroup_flr",  operator.contains, [TaskGroup.__dict__, "__floor__"], false]
    - ["comb_TaskGroup_ceil", operator.contains, [TaskGroup.__dict__, "__ceil__"],  false]
    - ["comb_TaskGroup_idx",  operator.contains, [TaskGroup.__dict__, "__index__"], false]
    - ["comb_Handle_flr",     operator.contains, [Handle.__dict__,    "__floor__"], false]
    - ["comb_Handle_ceil",    operator.contains, [Handle.__dict__,    "__ceil__"],  false]
    - ["comb_Handle_idx",     operator.contains, [Handle.__dict__,    "__index__"], false]
    - ["comb_Queue_flr",      operator.contains, [Queue.__dict__,     "__floor__"], false]
