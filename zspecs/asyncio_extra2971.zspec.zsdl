# ---------------------------------------------------------------------------
# combined — all three operators for a cross-class sample
#
# Spot-checks __floor__, __ceil__, __index__ absence across a representative
# selection of asyncio classes in a single table for concise coverage.
# ---------------------------------------------------------------------------

table as2971.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_Task_flr",       operator.contains, [Task.__dict__,      "__floor__"], false]
    - ["comb_Task_ceil",      operator.contains, [Task.__dict__,      "__ceil__"],  false]
    - ["comb_Task_idx",       operator.contains, [Task.__dict__,      "__index__"], false]
