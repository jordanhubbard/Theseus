spec: inspect_extra1501
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 547 theme: __await__, __aiter__, __anext__ async protocol checks and __aenter__/__aexit__ async context manager checks for inspect classes."
    - "inspect.Parameter: no async protocol methods in __dict__. Verified with Python 3.12."
    - "inspect.Signature: no async protocol methods in __dict__. Verified with Python 3.12."
    - "inspect.BoundArguments: no async protocol methods in __dict__. Verified with Python 3.12."
    - "All three inspect classes are synchronous introspection data containers; none implement any async protocol."
    - "Positive anchors used: __init__, __repr__, and __eq__ are present in all three classes."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter — async protocol absence checks
#
# Wave 547 theme: inspect.Parameter — describes a single function parameter.
#
# inspect.Parameter.__dict__.__contains__("__await__") == False
# inspect.Parameter.__dict__.__contains__("__aiter__") == False
# inspect.Parameter.__dict__.__contains__("__anext__") == False
# inspect.Parameter.__dict__.__contains__("__aenter__") == False
# inspect.Parameter.__dict__.__contains__("__aexit__") == False
#
# Parameter is an immutable introspection object describing a function
# parameter. It has __init__, __repr__, __eq__ in __dict__ but no async
# protocol methods. New to extra1501.
# ---------------------------------------------------------------------------

table inspect_extra1501.parameter_async_protocol_absence:
  description: "inspect.Parameter has no async protocol methods in __dict__; Parameter is an immutable introspection data container; wave 547; new to extra1501"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1501pr

  columns: [id, function, args, expected, description]
  rows:
    - [in1501pr001,
       "Parameter.__dict__.__contains__",
       ["__await__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__await__') == False — Parameter is an immutable data container describing a single function parameter (name, kind, default, annotation); it does not implement the awaitable protocol; __await__ is not in Parameter.__dict__; verified with Python 3.12; new to extra1501"]
    - [in1501pr002,
       "Parameter.__dict__.__contains__",
       ["__aiter__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__aiter__') == False — Parameter does not implement the async iterator protocol; __aiter__ is not in Parameter.__dict__; verified with Python 3.12; new to extra1501"]
    - [in1501pr003,
       "Parameter.__dict__.__contains__",
       ["__anext__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__anext__') == False — Parameter does not implement the async iterator protocol; __anext__ is not in Parameter.__dict__; verified with Python 3.12; new to extra1501"]
    - [in1501pr004,
       "Parameter.__dict__.__contains__",
       ["__aenter__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__aenter__') == False — Parameter does not implement the async context manager protocol; __aenter__ is not in Parameter.__dict__; verified with Python 3.12; new to extra1501"]
    - [in1501pr005,
       "Parameter.__dict__.__contains__",
       ["__aexit__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__aexit__') == False — Parameter does not implement the async context manager protocol; __aexit__ is not in Parameter.__dict__; verified with Python 3.12; new to extra1501"]
    - [in1501pr006,
       "Parameter.__dict__.__contains__",
       ["__init__"],
       true,
       "inspect.Parameter.__dict__.__contains__('__init__') == True — Parameter defines __init__ in its __dict__ for constructing parameter objects with name, kind, default, and annotation; this is its primary synchronous interface; verified with Python 3.12; new to extra1501"]
    - [in1501pr007,
       "Parameter.__dict__.__contains__",
       ["__eq__"],
       true,
       "inspect.Parameter.__dict__.__contains__('__eq__') == True — Parameter defines __eq__ in its __dict__ enabling equality comparison between Parameter instances; this is part of its synchronous value-comparison interface; verified with Python 3.12; new to extra1501"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature — async protocol absence checks
#
# Wave 547 theme: inspect.Signature — describes a callable's signature.
#
# inspect.Signature.__dict__.__contains__("__await__") == False
# inspect.Signature.__dict__.__contains__("__aiter__") == False
# inspect.Signature.__dict__.__contains__("__anext__") == False
# inspect.Signature.__dict__.__contains__("__aenter__") == False
# inspect.Signature.__dict__.__contains__("__aexit__") == False
#
# Signature is an introspection object describing a callable's parameters
# and return annotation. It has __init__, __repr__, __eq__ but no async
# protocol methods. New to extra1501.
# ---------------------------------------------------------------------------

table inspect_extra1501.signature_async_protocol_absence:
  description: "inspect.Signature has no async protocol methods in __dict__; Signature is a synchronous introspection container for callable signatures; wave 547; new to extra1501"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1501sg

  columns: [id, function, args, expected, description]
  rows:
    - [in1501sg001,
       "Signature.__dict__.__contains__",
       ["__await__"],
       false,
       "inspect.Signature.__dict__.__contains__('__await__') == False — Signature is a synchronous introspection container describing a callable's parameters and return annotation; it does not implement the awaitable protocol; __await__ is not in Signature.__dict__; verified with Python 3.12; new to extra1501"]
    - [in1501sg002,
       "Signature.__dict__.__contains__",
       ["__aiter__"],
       false,
       "inspect.Signature.__dict__.__contains__('__aiter__') == False — Signature does not implement the async iterator protocol; __aiter__ is not in Signature.__dict__; verified with Python 3.12; new to extra1501"]
    - [in1501sg003,
       "Signature.__dict__.__contains__",
       ["__anext__"],
       false,
       "inspect.Signature.__dict__.__contains__('__anext__') == False — Signature does not implement the async iterator protocol; __anext__ is not in Signature.__dict__; verified with Python 3.12; new to extra1501"]
    - [in1501sg004,
       "Signature.__dict__.__contains__",
       ["__aenter__"],
       false,
       "inspect.Signature.__dict__.__contains__('__aenter__') == False — Signature does not implement the async context manager protocol; __aenter__ is not in Signature.__dict__; verified with Python 3.12; new to extra1501"]
    - [in1501sg005,
       "Signature.__dict__.__contains__",
       ["__aexit__"],
       false,
       "inspect.Signature.__dict__.__contains__('__aexit__') == False — Signature does not implement the async context manager protocol; __aexit__ is not in Signature.__dict__; verified with Python 3.12; new to extra1501"]
    - [in1501sg006,
       "Signature.__dict__.__contains__",
       ["__init__"],
       true,
       "inspect.Signature.__dict__.__contains__('__init__') == True — Signature defines __init__ in its __dict__ for constructing signature objects from a sequence of Parameter objects; this is its primary synchronous interface; verified with Python 3.12; new to extra1501"]
    - [in1501sg007,
       "Signature.__dict__.__contains__",
       ["__repr__"],
       true,
       "inspect.Signature.__dict__.__contains__('__repr__') == True — Signature defines __repr__ in its __dict__ providing a human-readable string representation of the signature; part of its synchronous display interface; verified with Python 3.12; new to extra1501"]

# ---------------------------------------------------------------------------
# Table 3: inspect.BoundArguments — async protocol absence checks
#
# Wave 547 theme: inspect.BoundArguments — result of binding arguments to
# a Signature.
#
# inspect.BoundArguments.__dict__.__contains__("__await__") == False
# inspect.BoundArguments.__dict__.__contains__("__aiter__") == False
# inspect.BoundArguments.__dict__.__contains__("__anext__") == False
# inspect.BoundArguments.__dict__.__contains__("__aenter__") == False
# inspect.BoundArguments.__dict__.__contains__("__aexit__") == False
#
# BoundArguments holds the arguments bound to a Signature via bind() or
# bind_partial(). It has __init__ and __repr__ but no async protocol
# methods. New to extra1501.
# ---------------------------------------------------------------------------

table inspect_extra1501.boundarguments_async_protocol_absence:
  description: "inspect.BoundArguments has no async protocol methods in __dict__; BoundArguments is a synchronous container for arguments bound to a Signature; wave 547; new to extra1501"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1501ba

  columns: [id, function, args, expected, description]
  rows:
    - [in1501ba001,
       "BoundArguments.__dict__.__contains__",
       ["__await__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__await__') == False — BoundArguments is a synchronous container holding the result of binding positional and keyword arguments to a Signature; it does not implement the awaitable protocol; __await__ is not in BoundArguments.__dict__; verified with Python 3.12; new to extra1501"]
    - [in1501ba002,
       "BoundArguments.__dict__.__contains__",
       ["__aiter__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__aiter__') == False — BoundArguments does not implement the async iterator protocol; __aiter__ is not in BoundArguments.__dict__; verified with Python 3.12; new to extra1501"]
    - [in1501ba003,
       "BoundArguments.__dict__.__contains__",
       ["__anext__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__anext__') == False — BoundArguments does not implement the async iterator protocol; __anext__ is not in BoundArguments.__dict__; verified with Python 3.12; new to extra1501"]
    - [in1501ba004,
       "BoundArguments.__dict__.__contains__",
       ["__aenter__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__aenter__') == False — BoundArguments does not implement the async context manager protocol; __aenter__ is not in BoundArguments.__dict__; verified with Python 3.12; new to extra1501"]
    - [in1501ba005,
       "BoundArguments.__dict__.__contains__",
       ["__aexit__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__aexit__') == False — BoundArguments does not implement the async context manager protocol; __aexit__ is not in BoundArguments.__dict__; verified with Python 3.12; new to extra1501"]
    - [in1501ba006,
       "BoundArguments.__dict__.__contains__",
       ["__init__"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('__init__') == True — BoundArguments defines __init__ in its __dict__ for constructing bound argument objects; this is its primary synchronous construction interface; verified with Python 3.12; new to extra1501"]
    - [in1501ba007,
       "BoundArguments.__dict__.__contains__",
       ["__repr__"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('__repr__') == True — BoundArguments defines __repr__ in its __dict__ providing a readable representation of the bound arguments mapping; part of its synchronous display interface; verified with Python 3.12; new to extra1501"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1501
# ---------------------------------------------------------------------------

invariant inspect_extra1501.parameter_no_await:
  description: "inspect.Parameter.__dict__ does not contain '__await__' — Parameter is a synchronous introspection data container, not an awaitable; wave 547; new to extra1501"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant inspect_extra1501.parameter_no_aiter:
  description: "inspect.Parameter.__dict__ does not contain '__aiter__' — Parameter does not implement the async iterator protocol; wave 547; new to extra1501"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__aiter__"]
  expected: false

invariant inspect_extra1501.parameter_no_aenter:
  description: "inspect.Parameter.__dict__ does not contain '__aenter__' — Parameter does not implement the async context manager protocol; wave 547; new to extra1501"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__aenter__"]
  expected: false

invariant inspect_extra1501.signature_no_await:
  description: "inspect.Signature.__dict__ does not contain '__await__' — Signature is a synchronous introspection container, not an awaitable; wave 547; new to extra1501"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant inspect_extra1501.signature_no_anext:
  description: "inspect.Signature.__dict__ does not contain '__anext__' — Signature does not implement the async iterator protocol; wave 547; new to extra1501"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["__anext__"]
  expected: false

invariant inspect_extra1501.boundarguments_no_await:
  description: "inspect.BoundArguments.__dict__ does not contain '__await__' — BoundArguments is a synchronous container for bound arguments, not an awaitable; wave 547; new to extra1501"
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant inspect_extra1501.boundarguments_no_aenter:
  description: "inspect.BoundArguments.__dict__ does not contain '__aenter__' — BoundArguments does not implement the async context manager protocol; wave 547; new to extra1501"
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["__aenter__"]
  expected: false
