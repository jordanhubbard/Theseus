# Standalone invariants — extra127
# ---------------------------------------------------------------------------

invariant inspect_extra127.iscoroutine_co_varnames_0:
  description: "inspect.iscoroutine.__code__.co_varnames[0] == 'object' — parameter is named 'object'; wave 259; new to extra127"
  kind: python_call_eq
