spec: inspect_extra127
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect module functions co_varnames for iscoroutine, isawaitable, isasyncgenfunction, isgeneratorfunction (Wave 259)."
    - "inspect.iscoroutine.__code__.co_varnames[0] == 'object'. Verified with Python 3.14.3."
    - "inspect.iscoroutine.__code__.co_argcount == 1 — takes a single argument. Verified with Python 3.14.3."
    - "inspect.isawaitable.__code__.co_varnames[0] == 'object'. Verified with Python 3.14.3."
    - "inspect.isawaitable.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isasyncgenfunction.__code__.co_varnames[0] == 'obj'. Verified with Python 3.14.3."
    - "inspect.isasyncgenfunction.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isgeneratorfunction.__code__.co_varnames[0] == 'obj'. Verified with Python 3.14.3."
    - "inspect.isgeneratorfunction.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "iscoroutine and isawaitable use 'object' as the parameter name; isasyncgenfunction and isgeneratorfunction use 'obj'. Verified with Python 3.14.3."
    - "len(inspect.iscoroutine.__code__.co_varnames) == 1 — only one local (the parameter). Verified with Python 3.14.3."
    - "len(inspect.isasyncgenfunction.__code__.co_varnames) == 1. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.iscoroutine and isawaitable co_varnames and co_argcount
#
# Wave 259 theme: inspect.iscoroutine and isawaitable code object attributes.
#
# inspect.iscoroutine.__code__.co_varnames[0].__eq__('object') == True
# inspect.iscoroutine.__code__.co_argcount.__eq__(1) == True
# inspect.isawaitable.__code__.co_varnames[0].__eq__('object') == True
# inspect.isawaitable.__code__.co_argcount.__eq__(1) == True
# len(inspect.iscoroutine.__code__.co_varnames) == 1
#
# Both iscoroutine and isawaitable name their single parameter 'object',
# shadowing the built-in. Each takes one argument and has one entry in
# co_varnames. New to extra127.
# ---------------------------------------------------------------------------

table inspect_extra127.iscoroutine_isawaitable_code_attrs:
  description: "inspect.iscoroutine and isawaitable co_varnames[0]=='object', co_argcount==1, co_varnames len==1; wave 259; new to extra127"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectasync127

  columns: [id, function, args, expected, description]
  rows:
    - [iscoroutine_co_varnames_0_eq_object,
       "iscoroutine.__code__.co_varnames[0].__eq__",
       ["object"],
       true,
       "inspect.iscoroutine.__code__.co_varnames[0].__eq__('object') == True — iscoroutine is defined in Lib/inspect.py with 'def iscoroutine(object):'; the parameter name is 'object' (shadowing the built-in); co_varnames[0] is 'object'; str.__eq__('object') returns True; new to extra127"]
    - [iscoroutine_co_argcount_eq_1,
       "iscoroutine.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.iscoroutine.__code__.co_argcount.__eq__(1) == True — iscoroutine takes a single positional argument (the object to test); co_argcount is 1; int.__eq__(1) returns True; new to extra127"]
    - [iscoroutine_co_varnames_len_eq_1,
       "iscoroutine.__code__.co_varnames.__len__",
       [],
       1,
       "inspect.iscoroutine.__code__.co_varnames.__len__() == 1 — iscoroutine has only one variable in co_varnames: the single parameter 'object'; there are no additional local variables; len(co_varnames) is 1; new to extra127"]
    - [isawaitable_co_varnames_0_eq_object,
       "isawaitable.__code__.co_varnames[0].__eq__",
       ["object"],
       true,
       "inspect.isawaitable.__code__.co_varnames[0].__eq__('object') == True — isawaitable is defined with 'def isawaitable(object):' in Lib/inspect.py; the parameter is named 'object'; co_varnames[0] is 'object'; str.__eq__('object') returns True; new to extra127"]
    - [isawaitable_co_argcount_eq_1,
       "isawaitable.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isawaitable.__code__.co_argcount.__eq__(1) == True — isawaitable takes a single positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra127"]
    - [isawaitable_co_varnames_len_eq_1,
       "isawaitable.__code__.co_varnames.__len__",
       [],
       1,
       "inspect.isawaitable.__code__.co_varnames.__len__() == 1 — isawaitable has only one variable in co_varnames: the parameter 'object'; len(co_varnames) is 1; new to extra127"]

# ---------------------------------------------------------------------------
# Table 2: inspect.isasyncgenfunction and isgeneratorfunction co_varnames
#
# Wave 259 theme: inspect.isasyncgenfunction and isgeneratorfunction code attrs.
#
# inspect.isasyncgenfunction.__code__.co_varnames[0].__eq__('obj') == True
# inspect.isasyncgenfunction.__code__.co_argcount.__eq__(1) == True
# inspect.isgeneratorfunction.__code__.co_varnames[0].__eq__('obj') == True
# inspect.isgeneratorfunction.__code__.co_argcount.__eq__(1) == True
#
# isasyncgenfunction and isgeneratorfunction both use 'obj' as the parameter
# name (unlike iscoroutine/isawaitable which use 'object'). New to extra127.
# ---------------------------------------------------------------------------

table inspect_extra127.isasyncgen_isgeneratorfunction_code_attrs:
  description: "inspect.isasyncgenfunction and isgeneratorfunction co_varnames[0]=='obj', co_argcount==1; use 'obj' not 'object'; wave 259; new to extra127"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectasync127

  columns: [id, function, args, expected, description]
  rows:
    - [isasyncgenfunction_co_varnames_0_eq_obj,
       "isasyncgenfunction.__code__.co_varnames[0].__eq__",
       ["obj"],
       true,
       "inspect.isasyncgenfunction.__code__.co_varnames[0].__eq__('obj') == True — isasyncgenfunction is defined with 'def isasyncgenfunction(obj):' in Lib/inspect.py; it uses 'obj' as the parameter name, unlike iscoroutine which uses 'object'; str.__eq__('obj') returns True; new to extra127"]
    - [isasyncgenfunction_co_argcount_eq_1,
       "isasyncgenfunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isasyncgenfunction.__code__.co_argcount.__eq__(1) == True — isasyncgenfunction takes a single positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra127"]
    - [isasyncgenfunction_co_varnames_len_eq_1,
       "isasyncgenfunction.__code__.co_varnames.__len__",
       [],
       1,
       "inspect.isasyncgenfunction.__code__.co_varnames.__len__() == 1 — isasyncgenfunction has only the single parameter 'obj' in co_varnames; len(co_varnames) is 1; new to extra127"]
    - [isgeneratorfunction_co_varnames_0_eq_obj,
       "isgeneratorfunction.__code__.co_varnames[0].__eq__",
       ["obj"],
       true,
       "inspect.isgeneratorfunction.__code__.co_varnames[0].__eq__('obj') == True — isgeneratorfunction is defined with 'def isgeneratorfunction(obj):' in Lib/inspect.py; the parameter is named 'obj'; str.__eq__('obj') returns True; new to extra127"]
    - [isgeneratorfunction_co_argcount_eq_1,
       "isgeneratorfunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isgeneratorfunction.__code__.co_argcount.__eq__(1) == True — isgeneratorfunction takes a single positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra127"]
    - [isgeneratorfunction_co_varnames_len_eq_1,
       "isgeneratorfunction.__code__.co_varnames.__len__",
       [],
       1,
       "inspect.isgeneratorfunction.__code__.co_varnames.__len__() == 1 — isgeneratorfunction has only the single parameter 'obj' in co_varnames; len(co_varnames) is 1; new to extra127"]

# ---------------------------------------------------------------------------
# Table 3: inspect async/gen function co_name and __module__ identity
#
# Wave 259 theme: inspect async/gen function code name and module identity.
#
# inspect.iscoroutine.__code__.co_name.__eq__('iscoroutine') == True
# inspect.isawaitable.__code__.co_name.__eq__('isawaitable') == True
# inspect.isasyncgenfunction.__code__.co_name.__eq__('isasyncgenfunction') == True
# inspect.isgeneratorfunction.__code__.co_name.__eq__('isgeneratorfunction') == True
# inspect.iscoroutine.__module__.__eq__('inspect') == True
#
# All four functions have co_name matching the def-statement name, and
# __module__ == 'inspect'. New to extra127.
# ---------------------------------------------------------------------------

table inspect_extra127.async_gen_co_name_module:
  description: "inspect iscoroutine/isawaitable/isasyncgenfunction/isgeneratorfunction co_name and __module__=='inspect'; wave 259; new to extra127"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectasync127

  columns: [id, function, args, expected, description]
  rows:
    - [iscoroutine_co_name_eq,
       "iscoroutine.__code__.co_name.__eq__",
       ["iscoroutine"],
       true,
       "inspect.iscoroutine.__code__.co_name.__eq__('iscoroutine') == True — co_name reflects the name from the def statement; iscoroutine is defined with 'def iscoroutine(object):'; co_name is 'iscoroutine'; str.__eq__('iscoroutine') returns True; new to extra127"]
    - [isawaitable_co_name_eq,
       "isawaitable.__code__.co_name.__eq__",
       ["isawaitable"],
       true,
       "inspect.isawaitable.__code__.co_name.__eq__('isawaitable') == True — co_name is 'isawaitable', matching the def statement 'def isawaitable(object):' in Lib/inspect.py; str.__eq__('isawaitable') returns True; new to extra127"]
    - [isasyncgenfunction_co_name_eq,
       "isasyncgenfunction.__code__.co_name.__eq__",
       ["isasyncgenfunction"],
       true,
       "inspect.isasyncgenfunction.__code__.co_name.__eq__('isasyncgenfunction') == True — co_name is 'isasyncgenfunction', matching the def statement; str.__eq__('isasyncgenfunction') returns True; new to extra127"]
    - [isgeneratorfunction_co_name_eq,
       "isgeneratorfunction.__code__.co_name.__eq__",
       ["isgeneratorfunction"],
       true,
       "inspect.isgeneratorfunction.__code__.co_name.__eq__('isgeneratorfunction') == True — co_name is 'isgeneratorfunction', matching the def statement; str.__eq__('isgeneratorfunction') returns True; new to extra127"]
    - [iscoroutine_module_eq_inspect,
       "iscoroutine.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.iscoroutine.__module__.__eq__('inspect') == True — iscoroutine is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra127"]

