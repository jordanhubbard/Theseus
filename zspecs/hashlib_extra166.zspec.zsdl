table hashlib_extra166.new_function_identity:
  description: "hashlib.new.__name__.__eq__('__hash_new')==True / new.__qualname__.__eq__('__hash_new')==True / new.__module__.__eq__('hashlib')==True / new.__class__.__name__.__eq__('function')==True — new.__name__ is '__hash_new' (10 chars = '__'=2 + 'hash_new'=8; the function's true internal name; leading double-underscore indicates private implementation; public alias 'new' is set in hashlib namespace); new.__qualname__ is '__hash_new' (10 chars; same as __name__ because __hash_new is defined at module top-level, not inside any class; extra160 anchors this as a row); new.__module__ is 'hashlib' (7 chars; defined in Lib/hashlib.py; contrasts with sha256.__module__=='_hashlib' which has underscore prefix; 'hashlib' (7 chars) vs '_hashlib' (8 chars)); new.__class__.__name__ is 'function' (8 chars; pure Python function; extra160 anchors this as a row; confirmed); first hashnew166 anchor for new.__name__ and new.__module__"
  kind: python_call_eq
  category: identity
  id_prefix: hashnew166

  columns: [id, function, args, expected, description]
  rows:
    - [new_name_hash_new,    "new.__name__.__eq__",               ["__hash_new"], true, "hashlib.new.__name__ == '__hash_new' (10 chars; private name with double-underscore prefix; public alias is 'new'; first hashnew166 anchor for __name__)"]
    - [new_qualname_hash_new,"new.__qualname__.__eq__",            ["__hash_new"], true, "hashlib.new.__qualname__ == '__hash_new' (10 chars; same as __name__; top-level function; extra160 anchors as row; confirmed)"]
    - [new_module_hashlib,   "new.__module__.__eq__",              ["hashlib"],    true, "hashlib.new.__module__ == 'hashlib' (7 chars; Lib/hashlib.py; differs from sha256.__module__=='_hashlib' (8 chars) by one underscore)"]
    - [new_class_function,   "new.__class__.__name__.__eq__",      ["function"],   true, "hashlib.new.__class__.__name__ == 'function' (8 chars; Python function; extra160 anchors as row; confirmed; not 'builtin_function_or_method')"]

