    - [new_co_varnames_class_tuple,"new.__code__.co_varnames.__class__.__name__.__eq__", ["tuple"], true, "hashlib.new.__code__.co_varnames.__class__.__name__ == 'tuple' (5 chars; co_varnames is always a tuple in Python code objects)"]
    - [new_name_hash_new_b,        "new.__name__.__eq__",                            ["__hash_new"], true, "hashlib.new.__name__ == '__hash_new' (10 chars; confirmed; primary function name; double-underscore prefix)"]
    - [new_qualname_hash_new_b,    "new.__qualname__.__eq__",                        ["__hash_new"], true, "hashlib.new.__qualname__ == '__hash_new' (10 chars; confirmed; same as __name__; top-level function has no class prefix in qualname)"]

# ---------------------------------------------------------------------------
# hashlib.new.__name__.__eq__('__hash_new') — standalone
#
# hashlib.new.__name__ is '__hash_new' (10 chars = '__'=2 + 'hash_new'=8). hashlib.new
# is the public API function that users call to create hash objects by algorithm name
# (e.g., hashlib.new('sha256', b'data')). Internally, the function is called '__hash_new'
# because it wraps the raw hash constructor. The leading '__' prefix indicates it is a
# private implementation detail exposed via the public alias 'new' in the hashlib namespace.
# '__hash_new' (10 chars) = '__'=2 + 'hash'=4 + '_'=1 + 'new'=3. extra160 anchors
# new.__qualname__.__eq__('__hash_new') as a table row but NOT new.__name__ as a standalone.
# No prior hashlib spec anchors new.__name__ as a standalone under hashnew166.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra166.new_name_hash_new_standalone:
  description: "hashlib.new.__name__.__eq__('__hash_new') == True — 10 chars = '__'=2 + 'hash_new'=8; double-underscore prefix marks private implementation; public alias is 'new' in hashlib namespace; new.__qualname__=='__hash_new' (same; extra160 anchors __qualname__ as a row but NOT __name__ as standalone); new.__module__=='hashlib' (7 chars; public module); new.__class__.__name__=='function' (8 chars); co_name=='__hash_new' (same 10 chars); length: 'hashlib'(7) < 'function'(8) < '__hash_new'(10); first hashnew166 standalone for __name__"
  category: identity
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__module__.__eq__('hashlib') — standalone
#
# hashlib.new.__module__ is 'hashlib' (7 chars). The function __hash_new is defined in
# Lib/hashlib.py, so its __module__ attribute is 'hashlib'. This contrasts with the hash
# constructor functions like sha256.__module__ == '_hashlib' (8 chars; the private C
# extension). '__module__ == 'hashlib'' (without underscore prefix) confirms that hashlib.new
# is a pure Python function from the public hashlib module. 'hashlib' (7 chars) = 'h'+'a'+'s'+'h'+'l'+'i'+'b'.
# The difference between 'hashlib' (7 chars, public) and '_hashlib' (8 chars, private C
# extension) is exactly 1 char: the leading underscore. No prior hashlib spec anchors
# new.__module__ as a standalone under hashnew166. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra166.new_module_hashlib_standalone:
  description: "hashlib.new.__module__.__eq__('hashlib') == True — 'hashlib' (7 chars; public module name without underscore); __hash_new is defined in Lib/hashlib.py; contrasts with sha256.__module__=='_hashlib' (8 chars; private C extension with underscore prefix); 'hashlib'(7) vs '_hashlib'(8): difference of 1 char (the leading underscore marks private C extension); new.__name__=='__hash_new' (10 chars); new.__module__.__len__()==7; first hashnew166 standalone for __module__"
  category: identity
  kind: python_call_eq
  function: new.__module__.__eq__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__code__.co_argcount == 1 — standalone
#
# hashlib.new.__code__.co_argcount is 1. The Python code object's co_argcount attribute
# counts only the positional (non-star, non-keyword-only) arguments of a function.
# __hash_new is defined as def __hash_new(name, *args, **kwargs): — the only positional
# argument before the *args is 'name'. *args and **kwargs do not add to co_argcount.
# co_argcount == 1 indicates that hashlib.new requires exactly one positional argument
# before the variadic args. Callers use it as hashlib.new('sha256', data, usedforsecurity=True).
# co_varnames.__len__() == 3 ('name', 'args', 'kwargs'); co_argcount == 1; these differ
# because co_varnames includes all local variables including *args and **kwargs captures.
# No prior hashlib spec anchors new.__code__.co_argcount as a standalone under hashnew166.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra166.new_co_argcount_1_standalone:
  description: "hashlib.new.__code__.co_argcount.__eq__(1) == True — co_argcount==1; only 'name' is a positional arg before *args; __hash_new(name, *args, **kwargs): 'name' is the required algorithm name string (e.g. 'sha256'); *args/**kwargs pass through to the hash constructor; co_argcount counts only positional non-star args; co_varnames.__len__()==3 ('name','args','kwargs'); co_argcount(1) < co_varnames.__len__()(3); first hashnew166 standalone for co_argcount"
  category: identity
  kind: python_call_eq
  function: new.__code__.co_argcount.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__code__.co_name.__eq__('__hash_new') — standalone
#
# hashlib.new.__code__.co_name is '__hash_new' (10 chars). The code object's co_name
# attribute stores the name of the function as it was defined in the source code. For
# def __hash_new(name, *args, **kwargs): the code object's co_name is '__hash_new'.
# co_name is consistent with __name__ and __qualname__ for this function. co_name is
# part of the code object (hashlib.new.__code__) and is immutable. For functions,
# co_name and __name__ always agree on the same value. '__hash_new' (10 chars) =
# '__'=2 + 'hash'=4 + '_'=1 + 'new'=3. No prior hashlib spec anchors
# new.__code__.co_name as a standalone under hashnew166.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra166.new_co_name_hash_new_standalone:
  description: "hashlib.new.__code__.co_name.__eq__('__hash_new') == True — 10 chars; code object internal name; same as new.__name__ and new.__qualname__ (all three agree: '__hash_new'); co_name is immutable part of the code object; stored at compile time from the def statement name; '__hash_new' = '__'=2 + 'hash'=4 + '_'=1 + 'new'=3 = 10; co_name.__len__()==10; new.__code__.co_argcount==1; first hashnew166 standalone for co_name"
  category: identity
  kind: python_call_eq
  function: new.__code__.co_name.__eq__
  args: ["__hash_new"]
  expected: true

