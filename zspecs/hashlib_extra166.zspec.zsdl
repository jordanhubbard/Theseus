table hashlib_extra166.new_code_attributes_and_lengths:
  description: "hashlib.new.__code__.co_argcount==1 / new.__code__.co_name.__eq__('__hash_new')==True / new.__name__.__len__()==10 / new.__module__.__len__()==7 — new.__code__.co_argcount is 1 (co_argcount counts only positional non-starred params; __hash_new(name, *args, **kwargs) has 1 positional param 'name'; *args and **kwargs excluded from co_argcount); new.__code__.co_name is '__hash_new' (10 chars; the code object internal name; same as new.__name__ and new.__qualname__; code objects store the function name at compile time); new.__name__.__len__() is 10 ('__hash_new' = '__'=2 + 'hash'=4 + '_'=1 + 'new'=3 = 10 chars; the two leading underscores plus the descriptive name); new.__module__.__len__() is 7 ('hashlib' = 7 chars; contrasts with '_hashlib'=8 chars; public module shorter than private C extension by 1 char); length ordering: 'hashlib'(7) < 'function'(8) < '__hash_new'(10); first hashnew166 anchor for co_argcount and co_name"
  kind: python_call_eq
  category: identity
  id_prefix: hashnew166

  columns: [id, function, args, expected, description]
  rows:
    - [new_co_argcount_1,       "new.__code__.co_argcount.__eq__",    [1],             true, "hashlib.new.__code__.co_argcount == 1 (only 'name' is positional; *args/**kwargs not counted in co_argcount; def __hash_new(name, *args, **kwargs))"]
    - [new_co_name_hash_new,    "new.__code__.co_name.__eq__",        ["__hash_new"],  true, "hashlib.new.__code__.co_name == '__hash_new' (10 chars; code object internal name; same as __name__ and __qualname__; stored at compile time)"]
