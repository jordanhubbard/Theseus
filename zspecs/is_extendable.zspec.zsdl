spec: is_extendable
version: ">=1.0.0"
backend: node(is-extendable)

docs: https://github.com/jonschlinkert/is-extendable#readme

provenance:
  derived_from:
    - "is-extendable README — https://github.com/jonschlinkert/is-extendable#readme"
    - "Test vectors verified with is-extendable via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "is-extendable source"
  notes:
    - "Check if a value is extendable (object/array/function) — used by mixin-deep, defaults-deep, etc."
    - "Install: npm install is-extendable"
    - "v1 CJS; module export IS the predicate function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant is_extendable.plain_object_true:
  description: "isExtendable({}) is true"
  category: predicate
  kind: node_chain_eq
  entry: module
  entry_args: [{}]
  chain: []
  expected: true

invariant is_extendable.array_true:
  description: "isExtendable([]) is true"
  category: predicate
  kind: node_chain_eq
  entry: module
  entry_args: [[]]
  chain: []
  expected: true

invariant is_extendable.null_false:
  description: "isExtendable(null) is false"
  category: predicate
  kind: node_chain_eq
  entry: module
  entry_args: [~]
  chain: []
  expected: false

invariant is_extendable.string_false:
  description: "isExtendable('hi') is false"
  category: predicate
  kind: node_chain_eq
  entry: module
  entry_args: ["hi"]
  chain: []
  expected: false

invariant is_extendable.number_false:
  description: "isExtendable(5) is false"
  category: predicate
  kind: node_chain_eq
  entry: module
  entry_args: [5]
  chain: []
  expected: false

invariant is_extendable.boolean_false:
  description: "isExtendable(true) is false"
  category: predicate
  kind: node_chain_eq
  entry: module
  entry_args: [true]
  chain: []
  expected: false

invariant is_extendable.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"
