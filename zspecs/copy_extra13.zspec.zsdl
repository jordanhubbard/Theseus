spec: copy_extra13
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
    - "copy_extra12.zspec.zsdl — covers copy/deepcopy __name__ table; copy/deepcopy __module__ standalone; error.__qualname__; error.__bases__.__getitem__(0).__name__; copy/deepcopy of [1,2,3] behavioral"
    - "copy_extra11.zspec.zsdl — covers copy/__name__/__module__; deepcopy/__name__/__module__; Error/__name__/__module__/__bases__.__getitem__(0).__name__; copy/deepcopy of 42/'hello'/True/[1,2,3]"
    - "copy_extra6.zspec.zsdl — covers copy/__qualname__/deepcopy/__qualname__/Error/__qualname__; Error.__bases__[0].__name__; Error.__class__.__name__"
  notes:
    - "This spec extends copy.zspec.zsdl through copy_extra12.zspec.zsdl."
    - "NEW: copy.__name__ standalone; deepcopy.__name__ standalone; copy.__module__ standalone; deepcopy.__module__ standalone — all in the extra13 namespace."
    - "NEW: copy.error.__name__ standalone (== 'Error'); copy.error.__bases__[0].__name__ standalone (== 'Exception')."
    - "NEW: copy.deepcopy({'a':1}) == {'a':1} behavioral; copy.copy({'a':1}) == {'a':1} behavioral."
    - "copy.error.__name__ == 'Error' — copy.error is an alias for copy.Error; __name__ reflects the canonical class definition name."
    - "copy.error.__bases__[0].__name__ == 'Exception' — direct base class is Exception (verified: copy.error is copy.Error)."
    - "copy.deepcopy({'a':1}) == {'a':1} — deep copy of a dict equals the original by value."
    - "copy.copy({'a':1}) == {'a':1} — shallow copy of a dict equals the original by value."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# copy and deepcopy — __name__ standalone invariants (extra13 namespace)
#
# copy_extra12 covers __name__ for copy/deepcopy in a table.
# copy_extra11 covers them as standalone invariants in the extra11 namespace.
# These re-anchor under the extra13 namespace for direct reference.
# ---------------------------------------------------------------------------

invariant copy_extra13.copy.name:
  description: "copy.copy.__name__ == 'copy' — function name attribute"
  category: function_attrs
  kind: python_call_eq
  function: copy.__name__.__eq__
  args: ["copy"]
  expected: true

invariant copy_extra13.deepcopy.name:
  description: "copy.deepcopy.__name__ == 'deepcopy' — function name attribute"
  category: function_attrs
  kind: python_call_eq
  function: deepcopy.__name__.__eq__
  args: ["deepcopy"]
  expected: true

# ---------------------------------------------------------------------------
# copy and deepcopy — __module__ standalone invariants (extra13 namespace)
#
# copy_extra12 covers __module__ for copy/deepcopy as standalone invariants.
# copy_extra11 also covers them. Re-anchored here under the extra13 namespace.
# ---------------------------------------------------------------------------

invariant copy_extra13.copy.module:
  description: "copy.copy.__module__ == 'copy' — copy function defined in copy module"
  category: function_attrs
  kind: python_call_eq
  function: copy.__module__.__eq__
  args: ["copy"]
  expected: true

invariant copy_extra13.deepcopy.module:
  description: "copy.deepcopy.__module__ == 'copy' — deepcopy function defined in copy module"
  category: function_attrs
  kind: python_call_eq
  function: deepcopy.__module__.__eq__
  args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# copy.error — __name__ and base class (extra13 namespace)
#
# copy.error is an alias for copy.Error (same object, verified: copy.error is copy.Error).
# copy.error.__name__ == 'Error': __name__ reflects the canonical class definition name.
# copy.error.__bases__[0].__name__ == 'Exception': direct base is Exception.
# copy_extra11 covers Error.__name__ and Error.__bases__ via the 'Error' name.
# copy_extra12 covers error.__qualname__ and error.__bases__ in the extra12 namespace.
# These re-anchor under the extra13 namespace using error.__name__ (new angle).
# ---------------------------------------------------------------------------

invariant copy_extra13.error.name:
  description: "copy.error.__name__ == 'Error' — error alias __name__ is the canonical class name"
  category: class_attrs
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant copy_extra13.error.base_name:
  description: "copy.error.__bases__[0].__name__ == 'Exception' — direct base class of error is Exception"
  category: error_hierarchy
  kind: python_call_eq
  function: error.__bases__.__getitem__(0).__name__.__eq__
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral: copy and deepcopy of {'a': 1}
#
# copy_extra11 and copy_extra12 cover copy/deepcopy of [1,2,3].
# copy_extra11 also covers copy/deepcopy of 42, 'hello', True, [].
# No prior copy spec records copy/deepcopy of a dict {'a':1} as a behavioral
# invariant. These standalone invariants cover that new angle.
# ---------------------------------------------------------------------------

invariant copy_extra13.copy.dict_equals:
  description: "copy.copy({'a':1}) == {'a':1} — shallow copy of dict equals original by value"
  category: behavioral
  kind: python_call_eq
  function: copy
  args: [{"a": 1}]
  method: __eq__
  method_args: [{"a": 1}]
  expected: true

invariant copy_extra13.deepcopy.dict_equals:
  description: "copy.deepcopy({'a':1}) == {'a':1} — deep copy of dict equals original by value"
  category: behavioral
  kind: python_call_eq
  function: deepcopy
  args: [{"a": 1}]
  method: __eq__
  method_args: [{"a": 1}]
  expected: true
