spec: abc_extra2236
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c — C accelerator for ABCMeta"
  notes:
    - "Wave 2236 (_extra2236): __slots__ and slot descriptor protocol — __slots__, __weakref__, __dict__, __abstractmethods__, __init__, __new__ presence in abc class dicts."
    - "abc.ABCMeta is a metaclass (a subclass of type). Its __dict__ does NOT contain __slots__, __weakref__, __dict__, __abstractmethods__, or __init__. It DOES contain __new__ — ABCMeta defines __new__ to set up the abstract method tracking machinery."
    - "abc.ABC is a helper base class defined with '__slots__ = ()' in its class body. Therefore '__slots__' IS in abc.ABC.__dict__ (the tuple () is stored there). abc.ABC also carries __abstractmethods__ (an empty frozenset) in its class dict as a result of ABCMeta processing."
    - "abc.ABC does NOT have __weakref__ in its class dict — because __slots__ = () is defined, CPython suppresses the automatic __weakref__ slot descriptor."
    - "abc.ABC does NOT have __dict__ in its class dict — same reason: __slots__ = () prevents per-instance __dict__ and no __dict__ descriptor is inserted."
    - "abc.ABC does NOT define __init__ or __new__ — it relies on object.__init__ and object.__new__."
    - "abc.abstractmethod is a plain Python function (a decorator), not a class. Its __dict__ is empty. None of __slots__, __weakref__, __dict__, __abstractmethods__, __init__, or __new__ appear in abstractmethod.__dict__."
    - "__subclasshook__ is NOT in abc.ABC.__dict__ — it is defined on ABCMeta itself and accessed via the metaclass, not the class dict of ABC."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __slots__ dict-presence — ABCMeta, ABC, abstractmethod
#
# __slots__ IS in the __dict__ of abc.ABC — ABC is defined with
# '__slots__ = ()' in its class body, so the empty tuple is stored as
# '__slots__' in ABC.__dict__. __slots__ is NOT in ABCMeta.__dict__ (the
# metaclass does not define __slots__) and NOT in abstractmethod.__dict__
# (a function with an empty __dict__). ABCMeta=False, ABC=True, abstractmethod=False.
# ---------------------------------------------------------------------------

table abc_extra2236.slots_dict_presence:
  description: "__slots__ dict-presence for abc.ABCMeta/ABC/abstractmethod — ABC True, ABCMeta and abstractmethod False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2236

  columns: [id, function, args, expected]
  rows:
    - ["ab2236001", "abc.ABCMeta.__dict__.__contains__", ["__slots__"], false]
    - ["ab2236002", "abc.ABC.__dict__.__contains__", ["__slots__"], true]
    - ["ab2236003", "abc.abstractmethod.__dict__.__contains__", ["__slots__"], false]

# ---------------------------------------------------------------------------
# Table 2: __weakref__ dict-presence — ABCMeta, ABC, abstractmethod
#
# __weakref__ is NOT in the __dict__ of any of the 3. ABCMeta does not define
# __slots__ and inherits weakref support from type; no __weakref__ descriptor
# is added to ABCMeta.__dict__. abc.ABC defines '__slots__ = ()' which
# suppresses the automatic __weakref__ descriptor — so __weakref__ is NOT
# inserted into ABC.__dict__. abstractmethod is a function; its __dict__ is
# empty. All 3 return False.
# ---------------------------------------------------------------------------

table abc_extra2236.weakref_dict_presence:
  description: "__weakref__ dict-presence for abc.ABCMeta/ABC/abstractmethod — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2236

  columns: [id, function, args, expected]
  rows:
    - ["ab2236004", "abc.ABCMeta.__dict__.__contains__", ["__weakref__"], false]
    - ["ab2236005", "abc.ABC.__dict__.__contains__", ["__weakref__"], false]
    - ["ab2236006", "abc.abstractmethod.__dict__.__contains__", ["__weakref__"], false]

# ---------------------------------------------------------------------------
# Table 3: __dict__ dict-presence — ABCMeta, ABC, abstractmethod
#
# __dict__ is NOT in the __dict__ of any of the 3. ABCMeta is a type subclass;
# it does not insert a __dict__ descriptor into its own class dict. abc.ABC
# defines '__slots__ = ()' which prevents per-instance __dict__ and no __dict__
# descriptor is inserted into ABC.__dict__. abstractmethod is a function with
# an empty __dict__. All 3 return False.
# ---------------------------------------------------------------------------

table abc_extra2236.dict_dict_presence:
  description: "__dict__ dict-presence for abc.ABCMeta/ABC/abstractmethod — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2236

  columns: [id, function, args, expected]
  rows:
    - ["ab2236007", "abc.ABCMeta.__dict__.__contains__", ["__dict__"], false]
    - ["ab2236008", "abc.ABC.__dict__.__contains__", ["__dict__"], false]
    - ["ab2236009", "abc.abstractmethod.__dict__.__contains__", ["__dict__"], false]

# ---------------------------------------------------------------------------
# Table 4: __abstractmethods__ dict-presence — ABCMeta, ABC, abstractmethod
#
# __abstractmethods__ IS in the __dict__ of abc.ABC. ABCMeta sets
# __abstractmethods__ as an empty frozenset on every class it creates;
# abc.ABC is created by ABCMeta, so ABC.__dict__ contains the empty frozenset.
# ABCMeta itself does NOT have __abstractmethods__ in its own class dict —
# ABCMeta is a metaclass and the attribute is placed on classes it constructs,
# not on itself. abstractmethod is a function; __abstractmethods__ is absent
# from its empty __dict__. ABCMeta=False, ABC=True, abstractmethod=False.
# ---------------------------------------------------------------------------

table abc_extra2236.abstractmethods_dict_presence:
  description: "__abstractmethods__ dict-presence for abc.ABCMeta/ABC/abstractmethod — ABC True, ABCMeta and abstractmethod False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2236

  columns: [id, function, args, expected]
  rows:
    - ["ab2236010", "abc.ABCMeta.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["ab2236011", "abc.ABC.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["ab2236012", "abc.abstractmethod.__dict__.__contains__", ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 5: __init__ dict-presence — ABCMeta, ABC, abstractmethod
#
# __init__ is NOT in the __dict__ of any of the 3. ABCMeta does not define
# __init__ in its class body (it relies on type.__init__). abc.ABC does not
# define __init__ — it has no constructor logic of its own. abstractmethod is
# a function with an empty __dict__. All 3 return False.
# ---------------------------------------------------------------------------

table abc_extra2236.init_dict_presence:
  description: "__init__ dict-presence for abc.ABCMeta/ABC/abstractmethod — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2236

  columns: [id, function, args, expected]
  rows:
    - ["ab2236013", "abc.ABCMeta.__dict__.__contains__", ["__init__"], false]
    - ["ab2236014", "abc.ABC.__dict__.__contains__", ["__init__"], false]
    - ["ab2236015", "abc.abstractmethod.__dict__.__contains__", ["__init__"], false]

# ---------------------------------------------------------------------------
# Table 6: __new__ dict-presence — ABCMeta, ABC, abstractmethod
#
# __new__ IS in the __dict__ of abc.ABCMeta only. ABCMeta defines __new__
# to intercept class creation, extract abstract methods from the class body,
# and store them in __abstractmethods__. abc.ABC does not define __new__ —
# it is an ordinary class body with only '__slots__ = ()'. abstractmethod is
# a function with an empty __dict__. ABCMeta=True, ABC=False, abstractmethod=False.
# ---------------------------------------------------------------------------

table abc_extra2236.new_dict_presence:
  description: "__new__ dict-presence for abc.ABCMeta/ABC/abstractmethod — ABCMeta True, ABC and abstractmethod False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2236

  columns: [id, function, args, expected]
  rows:
    - ["ab2236016", "abc.ABCMeta.__dict__.__contains__", ["__new__"], true]
    - ["ab2236017", "abc.ABC.__dict__.__contains__", ["__new__"], false]
    - ["ab2236018", "abc.abstractmethod.__dict__.__contains__", ["__new__"], false]

# ---------------------------------------------------------------------------
# Table 7: __subclasshook__ dict-presence — ABCMeta and ABC
#
# __subclasshook__ is NOT in abc.ABC.__dict__ and NOT in abc.ABCMeta.__dict__.
# Although ABC inherits __subclasshook__ (it is defined on ABCMeta as a
# classmethod that returns NotImplemented), the method is stored in ABCMeta's
# class dict under the metaclass, and calling ABC.__subclasshook__ goes through
# the normal MRO — the key '__subclasshook__' does NOT appear as an entry in
# ABC.__dict__ or ABCMeta.__dict__. Both return False.
# ---------------------------------------------------------------------------

table abc_extra2236.subclasshook_dict_presence:
  description: "__subclasshook__ dict-presence for abc.ABCMeta/ABC — both False (method lives on ABCMeta class body, not in class dict)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2236

  columns: [id, function, args, expected]
  rows:
    - ["ab2236019", "abc.ABCMeta.__dict__.__contains__", ["__subclasshook__"], false]
    - ["ab2236020", "abc.ABC.__dict__.__contains__", ["__subclasshook__"], false]

# ---------------------------------------------------------------------------
# Table 8: Slot protocol cross-check — ABC's __slots__ = () signature
#
# This table confirms the full signature of abc.ABC's __slots__ = () usage:
# __slots__ IS in ABC.__dict__, __weakref__ and __dict__ are NOT (suppressed
# by __slots__ = ()), and __abstractmethods__ IS in ABC.__dict__ (placed by
# ABCMeta). This cross-check distinguishes the abc.ABC pattern from ordinary
# Python classes and from ABCMeta itself.
# ---------------------------------------------------------------------------

table abc_extra2236.abc_slots_signature:
  description: "abc.ABC slot protocol signature: __slots__ present, __weakref__/__dict__ absent (suppressed), __abstractmethods__ present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2236

  columns: [id, function, args, expected]
  rows:
    - ["ab2236021", "abc.ABC.__dict__.__contains__", ["__slots__"], true]
    - ["ab2236022", "abc.ABC.__dict__.__contains__", ["__weakref__"], false]
    - ["ab2236023", "abc.ABC.__dict__.__contains__", ["__dict__"], false]
    - ["ab2236024", "abc.ABC.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["ab2236025", "abc.ABC.__dict__.__contains__", ["__init__"], false]
    - ["ab2236026", "abc.ABC.__dict__.__contains__", ["__new__"], false]
    - ["ab2236027", "abc.ABCMeta.__dict__.__contains__", ["__new__"], true]
    - ["ab2236028", "abc.ABCMeta.__dict__.__contains__", ["__slots__"], false]
