spec: asyncio_extra435
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio class identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers Task, Future, Queue, Lock, and Event class identity via __name__ and __module__"
    - "__bases__[0] function fields are double-quoted per ZSDL rules"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra435.class_name:
  description: "asyncio class __name__ checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: AEXN

  columns: [id, function, args, expected]
  rows:
    - [id001, asyncio.Task.__name__.__eq__,   ["Task"],   true]
    - [id002, asyncio.Future.__name__.__eq__,  ["Future"], true]
    - [id003, asyncio.Queue.__name__.__eq__,   ["Queue"],  true]
    - [id004, asyncio.Lock.__name__.__eq__,    ["Lock"],   true]
    - [id005, asyncio.Event.__name__.__eq__,   ["Event"],  true]

table asyncio_extra435.class_module:
  description: "asyncio class __module__ checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: AEXM

  columns: [id, function, args, expected]
  rows:
    - [id001, asyncio.Task.__module__.__eq__,   ["asyncio.tasks"],   true]
    - [id002, asyncio.Future.__module__.__eq__,  ["asyncio.futures"], true]
    - [id003, asyncio.Queue.__module__.__eq__,   ["asyncio.queues"],  true]
    - [id004, asyncio.Lock.__module__.__eq__,    ["asyncio.locks"],   true]
    - [id005, asyncio.Event.__module__.__eq__,   ["asyncio.locks"],   true]

table asyncio_extra435.class_bases:
  description: "asyncio class __bases__[0].__name__ checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: AEXB

  columns: [id, function, args, expected]
  rows:
    - [id001, "asyncio.Task.__bases__[0].__name__.__eq__",   ["Future"], true]
    - [id002, "asyncio.Future.__bases__[0].__name__.__eq__", ["object"], true]
    - [id003, "asyncio.Queue.__bases__[0].__name__.__eq__",  ["object"], true]
