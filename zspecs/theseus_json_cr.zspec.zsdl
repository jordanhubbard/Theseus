spec: theseus_json_cr
version: ">=3.8"
backend: python_cleanroom(theseus_json_cr)
blocks: json

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/json.html"
    - "RFC 8259 — The JavaScript Object Notation (JSON) Data Interchange Format"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py (internal implementation)"
  notes:
    - "Clean-room JSON encoder/decoder. Do NOT import json."
    - "dumps(obj): serialize obj to JSON string."
    - "loads(s): deserialize JSON string to Python object."
    - "dump(obj, fp): write JSON to file."
    - "load(fp): read JSON from file."

error_model: python_exceptions

invariant theseus_json_cr.json2_dumps:
  description: "dumps({'a': 1}) produces valid JSON string"
  category: dumps
  kind: python_call_eq
  function: json2_dumps
  args: []
  expected: true

invariant theseus_json_cr.json2_loads:
  description: "loads('{\"key\": \"value\"}') returns dict"
  category: loads
  kind: python_call_eq
  function: json2_loads
  args: []
  expected: "value"

invariant theseus_json_cr.json2_round_trip:
  description: "loads(dumps(obj)) == obj for nested structure"
  category: dumps
  kind: python_call_eq
  function: json2_round_trip
  args: []
  expected: true
