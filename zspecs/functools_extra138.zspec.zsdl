spec: functools_extra138
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.reduce identity attributes, functools.total_ordering identity and code attributes, functools.singledispatch identity and code attributes, functools.lru_cache identity and code attributes (Wave 261)."
    - "functools.reduce.__module__ == '_functools' — reduce is a C builtin from _functoolsmodule.c, re-exported via functools. Verified with Python 3.14.3."
    - "functools.reduce.__qualname__ == 'reduce' (len 6) — reduce is a builtin_function_or_method with qualname 'reduce'. Verified with Python 3.14.3."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C builtin, not a Python function. Verified with Python 3.14.3."
    - "functools.total_ordering.__module__ == 'functools' — total_ordering is a pure-Python function defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.total_ordering.__qualname__ == 'total_ordering' (len 14) — defined at module scope as 'def total_ordering(cls):'. Verified with Python 3.14.3."
    - "functools.total_ordering.__class__.__name__ == 'function' — total_ordering is a plain Python function used as a class decorator. Verified with Python 3.14.3."
    - "functools.total_ordering.__code__.co_argcount == 1 — takes one argument (cls). Verified with Python 3.14.3."
    - "functools.total_ordering.__code__.co_varnames == ('cls', 'op', 'roots', 'root', 'opname', 'opfunc') — 6 local variables. Verified with Python 3.14.3."
    - "functools.singledispatch.__module__ == 'functools' — singledispatch is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.singledispatch.__qualname__ == 'singledispatch' (len 14) — defined at module scope. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_argcount == 1 — takes one argument (func). Verified with Python 3.14.3."
    - "functools.lru_cache.__module__ == 'functools' — lru_cache is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache' (len 9) — defined at module scope. Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_argcount == 2 — takes two arguments (maxsize, typed). Verified with Python 3.14.3."
    - "len(functools.lru_cache.__code__.co_varnames) == 5 — local variables: maxsize, typed, user_function, wrapper, decorating_function. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.reduce identity attributes
#
# Wave 261 theme: functools.reduce identity — C builtin re-exported via functools.
#
# functools.reduce.__module__ == '_functools'
# functools.reduce.__qualname__ == 'reduce' (len 6)
# functools.reduce.__name__ == 'reduce' (len 6)
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
#
# reduce is implemented in _functoolsmodule.c and imported into functools.
# Its __module__ is '_functools', not 'functools'. New to extra138.
# ---------------------------------------------------------------------------

table functools_extra138.reduce_identity:
  description: "functools.reduce identity: __module__=='_functools', __qualname__=='reduce' (len 6), __class__.__name__=='builtin_function_or_method'; wave 261; new to extra138"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsreduce138

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_module_eq_functools_c,
       "reduce.__module__.__eq__",
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is a C builtin implemented in Modules/_functoolsmodule.c; the module is re-exported into the functools namespace but the __module__ attribute reflects the C extension module '_functools'; str.__eq__('_functools') returns True; new to extra138"]
    - [reduce_module_len_eq_10,
       "reduce.__module__.__len__",
       [],
       10,
       "functools.reduce.__module__.__len__() == 10 — __module__ is '_functools' which has 10 characters; len('_functools') == 10; new to extra138"]
    - [reduce_qualname_eq_reduce,
       "reduce.__qualname__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — reduce is a C builtin with qualname 'reduce'; for C builtins __qualname__ equals the function name; str.__eq__('reduce') returns True; new to extra138"]
    - [reduce_qualname_len_eq_6,
       "reduce.__qualname__.__len__",
       [],
       6,
       "functools.reduce.__qualname__.__len__() == 6 — __qualname__ is 'reduce' which has 6 characters; len('reduce') == 6; new to extra138"]
    - [reduce_class_name_eq_builtin,
       "reduce.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C builtin function wrapped in _functoolsmodule.c; its Python type is builtin_function_or_method, not function; str.__eq__('builtin_function_or_method') returns True; new to extra138"]
    - [reduce_name_eq_reduce,
       "reduce.__name__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__name__.__eq__('reduce') == True — reduce.__name__ is 'reduce'; for C builtins the __name__ attribute is the function identifier; str.__eq__('reduce') returns True; new to extra138"]

