invariant functools_extra138.reduce_module_is_c:
  description: "functools.reduce.__module__ == '_functools' — reduce is a C builtin from _functoolsmodule.c, not a Python function; wave 261; new to extra138"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra138.reduce_class_is_builtin:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C builtin, not a Python function; wave 261; new to extra138"
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra138.total_ordering_is_function:
  description: "functools.total_ordering.__class__.__name__ == 'function' — total_ordering is a Python function used as a class decorator; wave 261; new to extra138"
  kind: python_call_eq
  function: total_ordering.__class__.__name__.__eq__
