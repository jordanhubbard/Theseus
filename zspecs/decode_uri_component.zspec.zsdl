spec: decode_uri_component
version: ">=0.4.1"
backend: node(decode-uri-component)

docs: https://www.npmjs.com/package/decode-uri-component

provenance:
  derived_from:
    - "decode-uri-component README — https://www.npmjs.com/package/decode-uri-component"
    - "Test vectors verified with decode-uri-component via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "decode-uri-component source"
  notes:
    - "decode-uri-component is an npm package. Install: npm install decode-uri-component"
    - "Decodes percent-encoded URI components. ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table decode_uri_component.decodeUriComponent:
  kind: node_module_call_eq
  function: "default"
  category: decode
  id_prefix: decuri

  columns: [id, args, expected]
  rows:
    - [slash,   ["%2F"],           "/"]
    - [space,   ["%20hello%20"],   " hello "]
    - [plain,   ["hello"],         "hello"]
