spec: threading_extra123
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra122.zspec.zsdl."
    - "This spec covers: threading.Condition class method __code__.co_varnames elements not previously covered — Condition.__init__ co_varnames[0]='self'(4), co_varnames[1]='lock'(4); Condition.wait co_varnames[1]='timeout'(7), co_varnames[2]='waiter'(6), co_varnames[3]='saved_state'(11), co_varnames[4]='gotit'(5); Condition.notify co_varnames[1]='n'(1), co_varnames[2]='waiters'(7), co_varnames[3]='waiter'(6); co_varnames tuple lengths; wave 273."
    - "Prior spec extra79 covered Condition.__init__.__code__.co_varnames.__class__.__name__=='tuple' and co_name=='__init__' and co_argcount==2. Prior extra104/105 covered Condition method qualnames. New here: the individual co_varnames elements (parameter and local names) for __init__, wait, and notify."
    - "threading.Condition.__init__.__code__.co_varnames[0] == 'self' (len 4). Verified with Python 3.14.3."
    - "threading.Condition.__init__.__code__.co_varnames[1] == 'lock' (len 4). Verified with Python 3.14.3."
    - "threading.Condition.__init__.__code__.co_varnames.__len__() == 2. Verified with Python 3.14.3."
    - "threading.Condition.wait.__code__.co_varnames[1] == 'timeout' (len 7). Verified with Python 3.14.3."
    - "threading.Condition.wait.__code__.co_varnames[2] == 'waiter' (len 6). Verified with Python 3.14.3."
    - "threading.Condition.wait.__code__.co_varnames[3] == 'saved_state' (len 11). Verified with Python 3.14.3."
    - "threading.Condition.wait.__code__.co_varnames[4] == 'gotit' (len 5). Verified with Python 3.14.3."
    - "threading.Condition.wait.__code__.co_varnames.__len__() == 5. Verified with Python 3.14.3."
    - "threading.Condition.notify.__code__.co_varnames[1] == 'n' (len 1). Verified with Python 3.14.3."
    - "threading.Condition.notify.__code__.co_varnames[2] == 'waiters' (len 7). Verified with Python 3.14.3."
    - "threading.Condition.notify.__code__.co_varnames[3] == 'waiter' (len 6). Verified with Python 3.14.3."
    - "threading.Condition.notify.__code__.co_varnames.__len__() == 4. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Condition.__init__ co_varnames[0] and [1]
#
# Wave 273 theme: threading.Condition.__init__(self, lock=None) is a pure-Python
# method with 2 declared parameters and no additional internal locals.
# co_varnames[0] == 'self' (4 chars) — the bound instance parameter, present in
# every Python method. co_varnames[1] == 'lock' (4 chars) — the underlying lock
# to use (if None, a new RLock is created). Both 'self' and 'lock' share length 4,
# making them the same-length pair. The co_varnames tuple has exactly 2 entries:
# 1 declared parameter (self is technically the first positional) plus 1 keyword
# parameter (lock), no internal locals. Prior spec extra79 confirmed
# co_varnames.__class__.__name__=='tuple' and co_argcount==2 for Condition.__init__.
# New here: the string values and lengths of both co_varnames entries.
#
# Condition.__init__.__code__.co_varnames[0] == 'self'   (len 4)
# Condition.__init__.__code__.co_varnames[1] == 'lock'   (len 4)
# Condition.__init__.__code__.co_varnames.__len__() == 2
#
# New to extra123.
# ---------------------------------------------------------------------------

table threading_extra123.condition_init_co_varnames:
  description: "threading.Condition.__init__ co_varnames[0]='self'(4), [1]='lock'(4); both len=4; tuple len=2; no internal locals; prior extra79 covered class name and co_argcount; wave 273; new to extra123"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingcicv123

  columns: [id, function, args, expected, description]
  rows:
    - [cond_init_cv0_eq,
       "Condition.__init__.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "threading.Condition.__init__.__code__.co_varnames[0] == 'self' — the instance parameter; always first in Python methods; Condition.__init__(self, lock=None); tuple.__getitem__(0) returns 'self'; new to extra123"]
    - [cond_init_cv0_len,
       "Condition.__init__.__code__.co_varnames.__getitem__(0).__len__",
       [],
       4,
       "threading.Condition.__init__.__code__.co_varnames[0].__len__() == 4 — 'self' has 4 chars: s-e-l-f; same length as co_varnames[1] 'lock' (4); str.__len__() returns 4; new to extra123"]
    - [cond_init_cv1_eq,
       "Condition.__init__.__code__.co_varnames.__getitem__",
       [1],
       "lock",
       "threading.Condition.__init__.__code__.co_varnames[1] == 'lock' — the underlying lock object; if None a new RLock is created internally; Condition can wrap any Lock or RLock; tuple.__getitem__(1) returns 'lock'; new to extra123"]
    - [cond_init_cv1_len,
       "Condition.__init__.__code__.co_varnames.__getitem__(1).__len__",
       [],
       4,
       "threading.Condition.__init__.__code__.co_varnames[1].__len__() == 4 — 'lock' has 4 chars: l-o-c-k; same length as 'self' (4); both parameters of Condition.__init__ share length 4; str.__len__() returns 4; new to extra123"]
    - [cond_init_cv_len,
       "Condition.__init__.__code__.co_varnames.__len__",
       [],
       2,
       "threading.Condition.__init__.__code__.co_varnames.__len__() == 2 — Condition.__init__ has exactly 2 local variable names: 'self' and 'lock'; no internal locals beyond declared parameters; prior extra79 confirmed co_argcount==2; tuple.__len__() returns 2; new to extra123"]

# ---------------------------------------------------------------------------
# Table 2: threading.Condition.wait co_varnames[1] through [4]
#
# Wave 273 theme: threading.Condition.wait(self, timeout=None) has 5 co_varnames:
# 'self'(0), 'timeout'(1), 'waiter'(2), 'saved_state'(3), 'gotit'(4).
# co_varnames[1] == 'timeout' (7 chars) — max seconds to wait; None means wait
# indefinitely. co_varnames[2] == 'waiter' (6 chars) — the internal waiter lock
# obtained from self._new_waiter(). co_varnames[3] == 'saved_state' (11 chars)
# — the lock state saved via _release_save() before blocking; it must be
# restored after waking. co_varnames[4] == 'gotit' (5 chars) — boolean
# indicating whether the waiter was successfully acquired (True) or timed out
# (False). 'saved_state' is the longest co_varnames entry at 11 chars. The
# wait method has 5 co_varnames total: 2 declared (self, timeout) + 3 locals.
#
# wait.__code__.co_varnames[1] == 'timeout'      (len 7)
# wait.__code__.co_varnames[2] == 'waiter'       (len 6)
# wait.__code__.co_varnames[3] == 'saved_state'  (len 11)
# wait.__code__.co_varnames[4] == 'gotit'        (len 5)
#
# New to extra123.
# ---------------------------------------------------------------------------

table threading_extra123.condition_wait_co_varnames_1_to_4:
  description: "threading.Condition.wait co_varnames[1]='timeout'(7), [2]='waiter'(6), [3]='saved_state'(11), [4]='gotit'(5); 'saved_state' longest; tuple len=5; 2 params + 3 locals; wave 273; new to extra123"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingcwcv123

  columns: [id, function, args, expected, description]
  rows:
    - [cond_wait_cv1_eq,
       "Condition.wait.__code__.co_varnames.__getitem__",
       [1],
       "timeout",
       "threading.Condition.wait.__code__.co_varnames[1] == 'timeout' — maximum seconds to wait; None means indefinite; Condition.wait(self, timeout=None); tuple.__getitem__(1) returns 'timeout'; new to extra123"]
    - [cond_wait_cv2_eq,
       "Condition.wait.__code__.co_varnames.__getitem__",
       [2],
       "waiter",
       "threading.Condition.wait.__code__.co_varnames[2] == 'waiter' — the internal waiter lock obtained via self._new_waiter(); used to block the calling thread until notify() releases it; tuple.__getitem__(2) returns 'waiter'; new to extra123"]
    - [cond_wait_cv2_len,
       "Condition.wait.__code__.co_varnames.__getitem__(2).__len__",
       [],
       6,
       "threading.Condition.wait.__code__.co_varnames[2].__len__() == 6 — 'waiter' has 6 chars: w-a-i-t-e-r; one less than 'timeout' (7) and 'waiters' in notify (also 7); str.__len__() returns 6; new to extra123"]
    - [cond_wait_cv3_eq,
       "Condition.wait.__code__.co_varnames.__getitem__",
       [3],
       "saved_state",
       "threading.Condition.wait.__code__.co_varnames[3] == 'saved_state' — the lock state saved before blocking via _release_save(); restored via _acquire_restore(saved_state) after waking; tuple.__getitem__(3) returns 'saved_state'; new to extra123"]
    - [cond_wait_cv3_len,
       "Condition.wait.__code__.co_varnames.__getitem__(3).__len__",
       [],
       11,
       "threading.Condition.wait.__code__.co_varnames[3].__len__() == 11 — 'saved_state' has 11 chars: s-a-v-e-d-_-s-t-a-t-e; the longest co_varnames entry in Condition.wait; str.__len__() returns 11; new to extra123"]
    - [cond_wait_cv4_eq,
       "Condition.wait.__code__.co_varnames.__getitem__",
       [4],
       "gotit",
       "threading.Condition.wait.__code__.co_varnames[4] == 'gotit' — boolean result of waiter.acquire(timeout); True if woken by notify, False if timed out; tuple.__getitem__(4) returns 'gotit'; new to extra123"]
    - [cond_wait_cv_len,
       "Condition.wait.__code__.co_varnames.__len__",
       [],
       5,
       "threading.Condition.wait.__code__.co_varnames.__len__() == 5 — Condition.wait has 5 local variable names: 2 declared parameters (self, timeout) + 3 internal locals (waiter, saved_state, gotit); tuple.__len__() returns 5; new to extra123"]

# ---------------------------------------------------------------------------
# Table 3: threading.Condition.notify co_varnames[1] through [3]
#
# Wave 273 theme: threading.Condition.notify(self, n=1) has 4 co_varnames:
# 'self'(0), 'n'(1), 'waiters'(2), 'waiter'(3). co_varnames[1] == 'n' (1 char)
# — count of threads to notify; defaults to 1. Like Semaphore.release co_varnames[1]
# (extra122), 'n' is a 1-char parameter. co_varnames[2] == 'waiters' (7 chars)
# — the list of waiting threads obtained from self._waiters, sliced to the first n.
# co_varnames[3] == 'waiter' (6 chars) — the loop variable iterating over
# waiters[:n], each waiter's lock released to wake that thread. Note: 'waiters'
# (plural, 7 chars) and 'waiter' (singular, 6 chars) differ by the trailing 's',
# making 'waiters' one char longer. Condition.notify has 4 co_varnames (1 param n
# plus 2 locals waiters, waiter) plus 'self'; simpler than Condition.wait (5).
#
# notify.__code__.co_varnames[1] == 'n'        (len 1)
# notify.__code__.co_varnames[2] == 'waiters'  (len 7)
# notify.__code__.co_varnames[3] == 'waiter'   (len 6)
# notify.__code__.co_varnames.__len__() == 4
#
# New to extra123.
# ---------------------------------------------------------------------------

table threading_extra123.condition_notify_co_varnames_1_to_3:
  description: "threading.Condition.notify co_varnames[1]='n'(1), [2]='waiters'(7), [3]='waiter'(6); 'waiters' plural vs 'waiter' singular differ by 's'; tuple len=4; n mirrors Semaphore.release cv[1] (extra122); wave 273; new to extra123"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingcncv123

  columns: [id, function, args, expected, description]
  rows:
    - [cond_notify_cv1_eq,
       "Condition.notify.__code__.co_varnames.__getitem__",
       [1],
       "n",
       "threading.Condition.notify.__code__.co_varnames[1] == 'n' — the count of threads to notify; defaults to 1; Condition.notify(self, n=1); mirrors Semaphore.release co_varnames[1]=='n' (extra122); tuple.__getitem__(1) returns 'n'; new to extra123"]
    - [cond_notify_cv1_len,
       "Condition.notify.__code__.co_varnames.__getitem__(1).__len__",
       [],
       1,
       "threading.Condition.notify.__code__.co_varnames[1].__len__() == 1 — 'n' has 1 char; shortest parameter name in the Condition method set; same length as Semaphore.release co_varnames[1] 'n' (extra122); str.__len__() returns 1; new to extra123"]
    - [cond_notify_cv2_eq,
       "Condition.notify.__code__.co_varnames.__getitem__",
       [2],
       "waiters",
       "threading.Condition.notify.__code__.co_varnames[2] == 'waiters' — the list of internal waiter locks from self._waiters; sliced to the first n entries; plural form contrasting with loop variable 'waiter' (singular); tuple.__getitem__(2) returns 'waiters'; new to extra123"]
    - [cond_notify_cv2_len,
       "Condition.notify.__code__.co_varnames.__getitem__(2).__len__",
       [],
       7,
       "threading.Condition.notify.__code__.co_varnames[2].__len__() == 7 — 'waiters' has 7 chars: w-a-i-t-e-r-s; 1 more than 'waiter' (6); plural vs singular; same length as Condition.wait co_varnames[1] 'timeout' (7); str.__len__() returns 7; new to extra123"]
    - [cond_notify_cv3_eq,
       "Condition.notify.__code__.co_varnames.__getitem__",
       [3],
       "waiter",
       "threading.Condition.notify.__code__.co_varnames[3] == 'waiter' — the loop variable iterating over waiters[:n]; each waiter lock is released to wake the corresponding thread; 6 chars; singular form of 'waiters'; tuple.__getitem__(3) returns 'waiter'; new to extra123"]
    - [cond_notify_cv3_len,
       "Condition.notify.__code__.co_varnames.__getitem__(3).__len__",
       [],
       6,
       "threading.Condition.notify.__code__.co_varnames[3].__len__() == 6 — 'waiter' has 6 chars: w-a-i-t-e-r; same length as Condition.wait co_varnames[2] 'waiter' (also 6); str.__len__() returns 6; new to extra123"]
    - [cond_notify_cv_len,
       "Condition.notify.__code__.co_varnames.__len__",
       [],
       4,
       "threading.Condition.notify.__code__.co_varnames.__len__() == 4 — Condition.notify has 4 local variable names: 2 declared parameters (self, n) + 2 internal locals (waiters, waiter); less than wait (5) because notify has no saved_state or gotit; tuple.__len__() returns 4; new to extra123"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra123
# ---------------------------------------------------------------------------

invariant threading_extra123.cond_init_cv1_lock:
  description: "threading.Condition.__init__.__code__.co_varnames[1] == 'lock' — underlying lock param; defaults to None (new RLock created); 4 chars; same length as 'self'; wave 273; new to extra123"
  kind: python_call_eq
  function: "Condition.__init__.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "lock"

invariant threading_extra123.cond_wait_cv1_timeout:
  description: "threading.Condition.wait.__code__.co_varnames[1] == 'timeout' — max wait seconds; None means indefinite; 7 chars; wave 273; new to extra123"
  kind: python_call_eq
  function: "Condition.wait.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "timeout"

invariant threading_extra123.cond_wait_cv3_saved_state:
  description: "threading.Condition.wait.__code__.co_varnames[3] == 'saved_state' — lock state saved before blocking; 11 chars; longest co_varnames entry in wait; wave 273; new to extra123"
  kind: python_call_eq
  function: "Condition.wait.__code__.co_varnames.__getitem__"
  args: [3]
  expected: "saved_state"

invariant threading_extra123.cond_notify_cv1_n:
  description: "threading.Condition.notify.__code__.co_varnames[1] == 'n' — notify count param; 1 char; shortest param in Condition methods; mirrors Semaphore.release cv[1] (extra122); wave 273; new to extra123"
  kind: python_call_eq
  function: "Condition.notify.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "n"

invariant threading_extra123.cond_notify_cv2_waiters:
  description: "threading.Condition.notify.__code__.co_varnames[2] == 'waiters' — list of internal waiter locks; 7 chars; plural form; 1 more than 'waiter' (6); wave 273; new to extra123"
  kind: python_call_eq
  function: "Condition.notify.__code__.co_varnames.__getitem__"
  args: [2]
  expected: "waiters"

