spec: theseus_hashlib_cr
version: ">=3.0"
backend: python_cleanroom(theseus_hashlib_cr)
blocks: hashlib

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/hashlib.html"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
  notes:
    - "Clean-room hashlib module. Do NOT import hashlib."

error_model: python_exceptions

invariant theseus_hashlib_cr.hash2_new:
  description: "new() creates a hash object"
  category: behavior
  kind: python_call_eq
  function: hash2_new
  args: []
  expected: true

invariant theseus_hashlib_cr.hash2_algorithms:
  description: "algorithms_available set contains common hash names"
  category: behavior
  kind: python_call_eq
  function: hash2_algorithms
  args: []
  expected: true

invariant theseus_hashlib_cr.hash2_sha256:
  description: "sha256() produces correct hash"
  category: behavior
  kind: python_call_eq
  function: hash2_sha256
  args: []
  expected: true
