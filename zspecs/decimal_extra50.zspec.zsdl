spec: decimal_extra50
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra49.zspec.zsdl — covers all 8 decimal exception __module__=='decimal' equality and __module__.__class__.__name__=='str'."
    - "decimal_extra29.zspec.zsdl — covers Context.__dict__.__class__.__name__.__len__()==12; Decimal.__dict__.__class__.__name__.__len__()==12; DecimalException.__dict__.__class__.__name__.__len__()==12 (length checks only, not equality)."
    - "decimal_extra28.zspec.zsdl — covers Decimal arithmetic method __qualname__.__len__() for __add__/__mul__/__sub__/quantize/to_eng_string/__repr__/__str__/__neg__."
    - "decimal_extra27.zspec.zsdl — covers all ROUND_* constant __module__.__len__()==7 for all decimal exceptions; getcontext/setcontext/localcontext __module__.__eq__('_decimal')."
    - "decimal_extra45.zspec.zsdl — covers ROUND_HALF_DOWN/ROUND_05UP __class__.__name__=='str'; ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN __class__.__qualname__=='str'; __class__.__module__=='builtins' for ROUND_HALF_DOWN/ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN/ROUND_05UP."
    - "decimal_extra24.zspec.zsdl — covers ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP __class__.__module__.__eq__('builtins')."
  notes:
    - "This spec extends decimal_extra49.zspec.zsdl."
    - "Prior specs collectively covered: decimal_extra29 checks __dict__.__class__.__name__.__len__()==12 for Decimal/Context/DecimalException (length only); no prior decimal spec checks __dict__.__class__.__name__.__eq__('mappingproxy') as a direct equality invariant for any decimal class; no prior decimal spec checks __dict__.__class__.__qualname__ for any decimal class; no prior decimal spec checks decimal module __dict__.__class__.__name__ or __qualname__; all 8 ROUND_* __class__.__module__=='builtins' now covered by decimal_extra24 and decimal_extra45 combined."
    - "This spec covers: decimal.Decimal.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL — decimal_extra29 checks __len__()==12 but no prior spec checks the equality directly; novel equality anchor in decdict50 namespace); decimal.Context.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL); decimal.DecimalException.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL); decimal.InvalidOperation.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL); decimal.DivisionByZero.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL); decimal.Decimal.__dict__.__class__.__qualname__.__eq__('mappingproxy') (NOVEL — no prior decimal spec checks __dict__.__class__.__qualname__ for any decimal class; mappingproxy type has __qualname__==__name__=='mappingproxy'); decimal.Context.__dict__.__class__.__qualname__.__eq__('mappingproxy') (NOVEL); decimal.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL — no prior decimal spec checks the decimal module's own __dict__.__class__.__name__); decimal.__dict__.__class__.__qualname__.__eq__('mappingproxy') (NOVEL)."
    - "decimal.Decimal.__dict__.__class__.__name__ == 'mappingproxy'. Every Python class's __dict__ is a types.MappingProxyType. The __class__.__name__ of a mappingproxy is 'mappingproxy'. decimal_extra29 verified __len__()==12 but not the string equality. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Context.__dict__.__class__.__name__ == 'mappingproxy'. Context is the arithmetic context class controlling precision, rounding, and traps. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.DecimalException.__dict__.__class__.__name__ == 'mappingproxy'. DecimalException is the base exception for all decimal exceptions. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.InvalidOperation.__dict__.__class__.__name__ == 'mappingproxy'. InvalidOperation is raised when an operation is invalid. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.DivisionByZero.__dict__.__class__.__name__ == 'mappingproxy'. DivisionByZero is raised for non-infinite results of division by zero. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Decimal.__dict__.__class__.__qualname__ == 'mappingproxy'. The builtin mappingproxy type has __qualname__==__name__=='mappingproxy' (C builtin; no enclosing class scope). No prior decimal spec checks __dict__.__class__.__qualname__ for any decimal class. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Context.__dict__.__class__.__qualname__ == 'mappingproxy'. Same reasoning as Decimal. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.__dict__.__class__.__name__ == 'mappingproxy'. The decimal module's own __dict__ is a mappingproxy. No prior decimal spec checks the module's __dict__.__class__.__name__. Novel module-level axis. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.__dict__.__class__.__qualname__ == 'mappingproxy'. Same as __name__ for the mappingproxy type. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal class __dict__ identity — __class__.__name__ equality (novel equality axis)
#
# Every Python class's __dict__ attribute is a types.MappingProxyType instance.
# The __class__.__name__ of that proxy is 'mappingproxy'.
# decimal_extra29 verified __dict__.__class__.__name__.__len__()==12 for
# Decimal/Context/DecimalException (checking the 12-character length of
# 'mappingproxy') but no prior decimal spec verifies the string equality
# directly with __eq__.
#
#   Decimal.__dict__.__class__.__name__          == 'mappingproxy'
#   Context.__dict__.__class__.__name__          == 'mappingproxy'
#   DecimalException.__dict__.__class__.__name__ == 'mappingproxy'
#   InvalidOperation.__dict__.__class__.__name__ == 'mappingproxy'
#   DivisionByZero.__dict__.__class__.__name__   == 'mappingproxy'
#
# All five equality anchors are novel in the decdict50 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra50.class_dict_name_eq:
  description: "decimal class __dict__.__class__.__name__.__eq__('mappingproxy') for Decimal/Context/DecimalException/InvalidOperation/DivisionByZero — every class __dict__ is a mappingproxy; decimal_extra29 covers __len__()==12 only; no prior decimal spec checks __dict__.__class__.__name__.__eq__(); all five novel equality anchors in decdict50 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decdict50name

  columns: [id, function, args, expected]
  rows:
    - [Decimal_dict_name,          "Decimal.__dict__.__class__.__name__.__eq__",          ["mappingproxy"], true]
    - [Context_dict_name,          "Context.__dict__.__class__.__name__.__eq__",          ["mappingproxy"], true]
    - [DecimalException_dict_name, "DecimalException.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - [InvalidOperation_dict_name, "InvalidOperation.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - [DivisionByZero_dict_name,   "DivisionByZero.__dict__.__class__.__name__.__eq__",   ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# decimal class __dict__ identity — __class__.__qualname__ equality (novel qualname axis)
#
# The builtin mappingproxy type has __qualname__ == __name__ == 'mappingproxy'
# (top-level C builtin; no enclosing class scope). No prior decimal spec
# checks __dict__.__class__.__qualname__ for any decimal class.
#
#   Decimal.__dict__.__class__.__qualname__ == 'mappingproxy'
#   Context.__dict__.__class__.__qualname__ == 'mappingproxy'
#
# Two representative __qualname__ anchors are novel in the decdict50 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra50.class_dict_qualname_eq:
  description: "decimal class __dict__.__class__.__qualname__.__eq__('mappingproxy') for Decimal/Context — mappingproxy is a top-level C builtin so __qualname__==__name__=='mappingproxy'; no prior decimal spec checks __dict__.__class__.__qualname__ for any decimal class; two novel __qualname__ anchors in decdict50 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decdict50qualname

  columns: [id, function, args, expected]
  rows:
    - [Decimal_dict_qualname, "Decimal.__dict__.__class__.__qualname__.__eq__", ["mappingproxy"], true]
    - [Context_dict_qualname, "Context.__dict__.__class__.__qualname__.__eq__", ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# decimal module __dict__ identity (novel module-level axis)
#
# The decimal module's own __dict__ attribute (the module namespace) is also a
# mappingproxy at runtime. No prior decimal spec checks the decimal module's
# __dict__.__class__.__name__ or __dict__.__class__.__qualname__.
#
#   decimal.__dict__.__class__.__name__     == 'mappingproxy'
#   decimal.__dict__.__class__.__qualname__ == 'mappingproxy'
#
# Both anchors are novel in the decdict50 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra50.module_dict_identity:
  description: "decimal module __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy') — the decimal module namespace is itself a mappingproxy; no prior decimal spec checks decimal.__dict__.__class__.__name__ or __qualname__; both novel anchors in decdict50 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decdict50mod

  columns: [id, function, args, expected]
  rows:
    - [module_dict_name,     "__dict__.__class__.__name__.__eq__",     ["mappingproxy"], true]
    - [module_dict_qualname, "__dict__.__class__.__qualname__.__eq__", ["mappingproxy"], true]
