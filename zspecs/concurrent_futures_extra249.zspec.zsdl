spec: concurrent_futures_extra249
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.ThreadPoolExecutor — ThreadPoolExecutor documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.Executor — Executor documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py (ThreadPoolExecutor implementation)"
    - "CPython source: Lib/concurrent/futures/_base.py (Executor base class implementation)"
  notes:
    - "ThreadPoolExecutor.submit.__name__ == 'submit' (len=6); __qualname__ == 'ThreadPoolExecutor.submit' (len=25); __module__ == 'concurrent.futures.thread' (len=25)."
    - "ThreadPoolExecutor.map.__name__ == 'map' (len=3); __qualname__ == 'Executor.map' (len=12) — map is inherited from Executor, not overridden in ThreadPoolExecutor."
    - "ThreadPoolExecutor.shutdown.__name__ == 'shutdown' (len=8); __qualname__ == 'ThreadPoolExecutor.shutdown' (len=27)."
    - "Executor.submit.__name__ == 'submit' (len=6); __qualname__ == 'Executor.submit' (len=15, but raises NotImplementedError); __module__ == 'concurrent.futures._base' (len=24)."
    - "Executor.map.__name__ == 'map' (len=3); __qualname__ == 'Executor.map' (len=12)."
    - "Executor.shutdown.__name__ == 'shutdown' (len=8); __qualname__ == 'Executor.shutdown' (len=17)."
    - "Executor.__enter__.__name__ == '__enter__' (len=9); __qualname__ == 'Executor.__enter__' (len=18)."
    - "Executor.__exit__.__name__ == '__exit__' (len=8); __qualname__ == 'Executor.__exit__' (len=17)."
    - "All methods are pure Python functions (__class__.__name__ == 'function')."
    - "ThreadPoolExecutor.map.__qualname__ == 'Executor.map' (not 'ThreadPoolExecutor.map') — map is defined on Executor and inherited, not overridden."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor method identity
#
# submit.__name__ == 'submit' (len=6)
# submit.__qualname__ == 'ThreadPoolExecutor.submit' (len=25)
# submit.__module__ == 'concurrent.futures.thread' (len=25)
# map.__name__ == 'map' (len=3)
# map.__qualname__ == 'Executor.map' (len=12) — inherited, not overridden
# shutdown.__name__ == 'shutdown' (len=8)
# shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' (len=27)
# ---------------------------------------------------------------------------

table concurrent_futures_extra249.threadpoolexecutor_method_identity:
  description: "concurrent.futures.ThreadPoolExecutor method identity — submit(len=6) has qualname 'ThreadPoolExecutor.submit'(len=25) and module 'concurrent.futures.thread'(len=25); map(len=3) has qualname 'Executor.map'(len=12, not 'ThreadPoolExecutor.map') because map is inherited unchanged from Executor; shutdown(len=8) has qualname 'ThreadPoolExecutor.shutdown'(len=27, longest qualname here); all are pure Python functions; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfe249tpe

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_sub_name_eq,   ThreadPoolExecutor.submit.__name__.__eq__,      ["submit"],                        true, "ThreadPoolExecutor.submit.__name__ == 'submit'; verified with Python 3.14.3"]
    - [tpe_sub_name_len,  ThreadPoolExecutor.submit.__name__.__len__,     [],                                6,    "ThreadPoolExecutor.submit.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [tpe_sub_qual_eq,   ThreadPoolExecutor.submit.__qualname__.__eq__,  ["ThreadPoolExecutor.submit"],     true, "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit'; verified with Python 3.14.3"]
    - [tpe_sub_qual_len,  ThreadPoolExecutor.submit.__qualname__.__len__, [],                                25,   "ThreadPoolExecutor.submit.__qualname__.__len__() == 25; verified with Python 3.14.3"]
    - [tpe_sub_mod_eq,    ThreadPoolExecutor.submit.__module__.__eq__,    ["concurrent.futures.thread"],     true, "ThreadPoolExecutor.submit.__module__ == 'concurrent.futures.thread'; verified with Python 3.14.3"]
    - [tpe_sub_mod_len,   ThreadPoolExecutor.submit.__module__.__len__,   [],                                25,   "ThreadPoolExecutor.submit.__module__.__len__() == 25; verified with Python 3.14.3"]
    - [tpe_sub_cls_eq,    ThreadPoolExecutor.submit.__class__.__name__.__eq__, ["function"],                 true, "ThreadPoolExecutor.submit.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]
    - [tpe_map_name_eq,   ThreadPoolExecutor.map.__name__.__eq__,         ["map"],                           true, "ThreadPoolExecutor.map.__name__ == 'map'; verified with Python 3.14.3"]
    - [tpe_map_name_len,  ThreadPoolExecutor.map.__name__.__len__,        [],                                3,    "ThreadPoolExecutor.map.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [tpe_map_qual_eq,   ThreadPoolExecutor.map.__qualname__.__eq__,     ["Executor.map"],                  true, "ThreadPoolExecutor.map.__qualname__ == 'Executor.map' (inherited, not overridden); verified with Python 3.14.3"]
    - [tpe_map_qual_len,  ThreadPoolExecutor.map.__qualname__.__len__,    [],                                12,   "ThreadPoolExecutor.map.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [tpe_sdn_name_eq,   ThreadPoolExecutor.shutdown.__name__.__eq__,    ["shutdown"],                      true, "ThreadPoolExecutor.shutdown.__name__ == 'shutdown'; verified with Python 3.14.3"]
    - [tpe_sdn_name_len,  ThreadPoolExecutor.shutdown.__name__.__len__,   [],                                8,    "ThreadPoolExecutor.shutdown.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [tpe_sdn_qual_eq,   ThreadPoolExecutor.shutdown.__qualname__.__eq__, ["ThreadPoolExecutor.shutdown"],  true, "ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'; verified with Python 3.14.3"]
    - [tpe_sdn_qual_len,  ThreadPoolExecutor.shutdown.__qualname__.__len__, [],                              27,   "ThreadPoolExecutor.shutdown.__qualname__.__len__() == 27 (longest qualname in this spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Executor method identity
#
# submit.__name__ == 'submit' (len=6); __module__ == 'concurrent.futures._base' (len=24)
# map.__name__ == 'map' (len=3); __qualname__ == 'Executor.map' (len=12)
# shutdown.__name__ == 'shutdown' (len=8); __qualname__ == 'Executor.shutdown' (len=17)
# __enter__.__name__ == '__enter__' (len=9); __qualname__ == 'Executor.__enter__' (len=18)
# __exit__.__name__ == '__exit__' (len=8); __qualname__ == 'Executor.__exit__' (len=17)
# ---------------------------------------------------------------------------

table concurrent_futures_extra249.executor_method_identity:
  description: "concurrent.futures.Executor method identity — submit(len=6), map(len=3), shutdown(len=8) are the core scheduling methods; __enter__(len=9) and __exit__(len=8) enable context manager use; all have __module__=='concurrent.futures._base'(len=24); Executor.map.__qualname__=='Executor.map'(len=12) same as ThreadPoolExecutor.map confirming single definition; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfe249ex

  columns: [id, function, args, expected, description]
  rows:
    - [ex_sub_name_eq,    Executor.submit.__name__.__eq__,      ["submit"],                      true, "Executor.submit.__name__ == 'submit'; verified with Python 3.14.3"]
    - [ex_sub_name_len,   Executor.submit.__name__.__len__,     [],                              6,    "Executor.submit.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [ex_sub_mod_eq,     Executor.submit.__module__.__eq__,    ["concurrent.futures._base"],    true, "Executor.submit.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [ex_sub_mod_len,    Executor.submit.__module__.__len__,   [],                              24,   "Executor.submit.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [ex_sub_cls_eq,     Executor.submit.__class__.__name__.__eq__, ["function"],               true, "Executor.submit.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]
    - [ex_map_name_eq,    Executor.map.__name__.__eq__,         ["map"],                         true, "Executor.map.__name__ == 'map'; verified with Python 3.14.3"]
    - [ex_map_name_len,   Executor.map.__name__.__len__,        [],                              3,    "Executor.map.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [ex_map_qual_eq,    Executor.map.__qualname__.__eq__,     ["Executor.map"],                true, "Executor.map.__qualname__ == 'Executor.map'; verified with Python 3.14.3"]
    - [ex_map_qual_len,   Executor.map.__qualname__.__len__,    [],                              12,   "Executor.map.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [ex_sdn_name_eq,    Executor.shutdown.__name__.__eq__,    ["shutdown"],                    true, "Executor.shutdown.__name__ == 'shutdown'; verified with Python 3.14.3"]
    - [ex_sdn_name_len,   Executor.shutdown.__name__.__len__,   [],                              8,    "Executor.shutdown.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [ex_sdn_qual_eq,    Executor.shutdown.__qualname__.__eq__, ["Executor.shutdown"],           true, "Executor.shutdown.__qualname__ == 'Executor.shutdown'; verified with Python 3.14.3"]
    - [ex_sdn_qual_len,   Executor.shutdown.__qualname__.__len__, [],                            17,   "Executor.shutdown.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [ex_ent_name_eq,    Executor.__enter__.__name__.__eq__,   ["__enter__"],                   true, "Executor.__enter__.__name__ == '__enter__'; verified with Python 3.14.3"]
    - [ex_ent_name_len,   Executor.__enter__.__name__.__len__,  [],                              9,    "Executor.__enter__.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [ex_ent_qual_eq,    Executor.__enter__.__qualname__.__eq__, ["Executor.__enter__"],         true, "Executor.__enter__.__qualname__ == 'Executor.__enter__'; verified with Python 3.14.3"]
    - [ex_ent_qual_len,   Executor.__enter__.__qualname__.__len__, [],                           18,   "Executor.__enter__.__qualname__.__len__() == 18; verified with Python 3.14.3"]
    - [ex_ext_name_eq,    Executor.__exit__.__name__.__eq__,    ["__exit__"],                    true, "Executor.__exit__.__name__ == '__exit__'; verified with Python 3.14.3"]
    - [ex_ext_name_len,   Executor.__exit__.__name__.__len__,   [],                              8,    "Executor.__exit__.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [ex_ext_qual_eq,    Executor.__exit__.__qualname__.__eq__, ["Executor.__exit__"],           true, "Executor.__exit__.__qualname__ == 'Executor.__exit__'; verified with Python 3.14.3"]
    - [ex_ext_qual_len,   Executor.__exit__.__qualname__.__len__, [],                            17,   "Executor.__exit__.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [ex_ext_cls_eq,     Executor.__exit__.__class__.__name__.__eq__, ["function"],             true, "Executor.__exit__.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra249
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra249.tpe_map_qualname_is_executor_map:
  description: "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__('Executor.map') returns True — ThreadPoolExecutor.map is the same function object as Executor.map (not overridden), so its __qualname__ is 'Executor.map'(len=12) not 'ThreadPoolExecutor.map'; this contrasts with ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit'(len=25) and ThreadPoolExecutor.shutdown.__qualname__=='ThreadPoolExecutor.shutdown'(len=27); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true

invariant concurrent_futures_extra249.tpe_shutdown_longest_qualname:
  description: "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__len__() == 27 — 'ThreadPoolExecutor.shutdown' (len=27) is the longest qualname in this spec; ThreadPoolExecutor.submit.__qualname__ has len=25; Executor.shutdown.__qualname__ has len=17; Executor.__enter__.__qualname__ has len=18; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.shutdown.__qualname__.__len__
  args: []
  expected: 27
