spec: threading_extra1261
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 531: checks threading.__all__ membership (contains true/false) for public names and private names; verifies __all__ is a list"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1261.all_contains_true:
  description: "threading.__all__.__contains__ returns true for public names that are in __all__"
  kind: python_call_eq
  category: all_membership_true
  id_prefix: th1261at
  columns: [id, function, args, expected]
  rows:
    - [th1261at001, threading.__all__.__contains__, ["Thread"],             true]
    - [th1261at002, threading.__all__.__contains__, ["Lock"],               true]
    - [th1261at003, threading.__all__.__contains__, ["RLock"],              true]
    - [th1261at004, threading.__all__.__contains__, ["Condition"],          true]
    - [th1261at005, threading.__all__.__contains__, ["Event"],              true]
    - [th1261at006, threading.__all__.__contains__, ["Semaphore"],          true]
    - [th1261at007, threading.__all__.__contains__, ["BoundedSemaphore"],   true]
    - [th1261at008, threading.__all__.__contains__, ["Barrier"],            true]
    - [th1261at009, threading.__all__.__contains__, ["Timer"],              true]
    - [th1261at010, threading.__all__.__contains__, ["local"],              true]
    - [th1261at011, threading.__all__.__contains__, ["current_thread"],     true]
    - [th1261at012, threading.__all__.__contains__, ["main_thread"],        true]
    - [th1261at013, threading.__all__.__contains__, ["active_count"],       true]
    - [th1261at014, threading.__all__.__contains__, ["enumerate"],          true]
    - [th1261at015, threading.__all__.__contains__, ["settrace"],           true]
    - [th1261at016, threading.__all__.__contains__, ["setprofile"],         true]
    - [th1261at017, threading.__all__.__contains__, ["stack_size"],         true]
    - [th1261at018, threading.__all__.__contains__, ["excepthook"],         true]
    - [th1261at019, threading.__all__.__contains__, ["TIMEOUT_MAX"],        true]
    - [th1261at020, threading.__all__.__contains__, ["BrokenBarrierError"], true]
    - [th1261at021, threading.__all__.__contains__, ["ExceptHookArgs"],     true]
    - [th1261at022, threading.__all__.__contains__, ["get_ident"],          true]
    - [th1261at023, threading.__all__.__contains__, ["get_native_id"],      true]
    - [th1261at024, threading.__all__.__contains__, ["getprofile"],         true]
    - [th1261at025, threading.__all__.__contains__, ["gettrace"],           true]

table threading_extra1261.all_contains_false:
  description: "threading.__all__.__contains__ returns false for private names and implementation-internal symbols"
  kind: python_call_eq
  category: all_membership_false
  id_prefix: th1261af
  columns: [id, function, args, expected]
  rows:
    - [th1261af001, threading.__all__.__contains__, ["_shutdown"],          false]
    - [th1261af002, threading.__all__.__contains__, ["_MainThread"],        false]
    - [th1261af003, threading.__all__.__contains__, ["_DummyThread"],       false]
    - [th1261af004, threading.__all__.__contains__, ["_active"],            false]
    - [th1261af005, threading.__all__.__contains__, ["_dangling"],          false]
    - [th1261af006, threading.__all__.__contains__, ["_RLock"],             false]
    - [th1261af007, threading.__all__.__contains__, ["WeakSet"],            false]
    - [th1261af008, threading.__all__.__contains__, ["_CRLock"],            false]
    - [th1261af009, threading.__all__.__contains__, ["sys"],                false]
    - [th1261af010, threading.__all__.__contains__, ["__doc__"],            false]
    - [th1261af011, threading.__all__.__contains__, ["_LockType"],          false]
    - [th1261af012, threading.__all__.__contains__, ["_PyRLock"],           false]

table threading_extra1261.all_class_and_type_checks:
  description: "threading.__all__ is a list and class name identity checks"
  kind: python_call_eq
  category: all_class_checks
  id_prefix: th1261ac
  columns: [id, function, args, expected]
  rows:
    - [th1261ac001, threading.__all__.__class__.__name__.__eq__,         ["list"],      true]
    - [th1261ac002, threading.__all__.__class__.__name__.__eq__,         ["tuple"],     false]
    - [th1261ac003, threading.__all__.__class__.__name__.__eq__,         ["set"],       false]
    - [th1261ac004, threading.__all__.__class__.__name__.__eq__,         ["frozenset"], false]
    - [th1261ac005, threading.__all__.__class__.__name__.__eq__,         ["dict"],      false]
    - [th1261ac006, threading.__all__.__class__.__qualname__.__eq__,     ["list"],      true]
    - [th1261ac007, threading.__all__.__class__.__module__.__eq__,       ["builtins"],  true]
    - [th1261ac008, threading.__name__.__eq__,                           ["threading"], true]
    - [th1261ac009, threading.__spec__.name.__eq__,                      ["threading"], true]
    - [th1261ac010, threading.__all__.__len__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
