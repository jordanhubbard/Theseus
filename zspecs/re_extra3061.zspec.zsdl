spec: re3061
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 651 (re3061): __aexit__, __await__, __anext__ dict-presence for re types."
    - "re.Pattern, re.Match, and re.RegexFlag are regex engine types; none define __aexit__ in their own __dict__."
    - "None of the re types define __await__ or __anext__ in their own __dict__; async protocols are absent from the regex interface."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __aexit__ dict-presence — operator.contains(Cls.__dict__, '__aexit__')
#
# re types do not implement the async context manager protocol;
# none define __aexit__ in their own __dict__; all false.
# ---------------------------------------------------------------------------

table re3061.aexit:
  description: "re types __aexit__ dict-presence checks; wave 651"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re3061
  columns: [id, function, args, expected]
  rows:
    - ["re3061001", operator.contains, [re.Pattern.__dict__,   __aexit__], false]
    - ["re3061002", operator.contains, [re.Match.__dict__,     __aexit__], false]
    - ["re3061003", operator.contains, [re.RegexFlag.__dict__, __aexit__], false]
    - ["re3061004", operator.contains, [re.Pattern.__dict__,   __aexit__], false]
    - ["re3061005", operator.contains, [re.Match.__dict__,     __aexit__], false]
    - ["re3061006", operator.contains, [re.RegexFlag.__dict__, __aexit__], false]

