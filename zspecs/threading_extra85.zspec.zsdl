spec: threading_extra85
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra84

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra84.zspec.zsdl."
    - "This spec covers: threading Semaphore/BoundedSemaphore/Event/Condition/Barrier __dict__ membership (Wave 248)."
    - "threading.Semaphore.__dict__.__contains__('acquire') == True — Semaphore defines acquire() in its own namespace. Verified with Python 3.14.3."
    - "threading.Semaphore.__dict__.__contains__('release') == True — Semaphore defines release() in its own namespace. Verified with Python 3.14.3."
    - "threading.Semaphore.__dict__.__contains__('__init__') == True — Semaphore defines __init__ in its own namespace. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__dict__.__contains__('release') == True — BoundedSemaphore overrides release() in its own namespace. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__dict__.__contains__('acquire') == False — BoundedSemaphore inherits acquire() from Semaphore; not in own dict. Verified with Python 3.14.3."
    - "threading.Event.__dict__.__contains__('set') == True — Event defines set() in its own namespace. Verified with Python 3.14.3."
    - "threading.Event.__dict__.__contains__('clear') == True — Event defines clear() in its own namespace. Verified with Python 3.14.3."
    - "threading.Event.__dict__.__contains__('wait') == True — Event defines wait() in its own namespace. Verified with Python 3.14.3."
    - "threading.Event.__dict__.__contains__('is_set') == True — Event defines is_set() in its own namespace. Verified with Python 3.14.3."
    - "threading.Condition.__dict__.__contains__('notify') == True — Condition defines notify() in its own namespace. Verified with Python 3.14.3."
    - "threading.Condition.__dict__.__contains__('notify_all') == True — Condition defines notify_all() in its own namespace. Verified with Python 3.14.3."
    - "threading.Condition.__dict__.__contains__('wait') == True — Condition defines wait() in its own namespace. Verified with Python 3.14.3."
    - "threading.Condition.__dict__.__contains__('__init__') == True — Condition defines __init__ in its own namespace. Verified with Python 3.14.3."
    - "threading.Barrier.__dict__.__contains__('wait') == True — Barrier defines wait() in its own namespace. Verified with Python 3.14.3."
    - "threading.Barrier.__dict__.__contains__('reset') == True — Barrier defines reset() in its own namespace. Verified with Python 3.14.3."
    - "NOTE: Condition.__dict__ does NOT contain 'acquire' or 'release' — these are delegated to the underlying lock; only present via __enter__/__exit__. Verified with Python 3.14.3."
    - "NOTE: BoundedSemaphore.__dict__ does NOT contain 'acquire' — inherited from Semaphore. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Semaphore.__dict__ membership — acquire/release/__init__ — extra85
#
# Wave 248 theme: threading.Semaphore __dict__ membership.
#
# threading.Semaphore.__dict__.__contains__('acquire')  == True
# threading.Semaphore.__dict__.__contains__('release')  == True
# threading.Semaphore.__dict__.__contains__('__init__') == True
# threading.BoundedSemaphore.__dict__.__contains__('release') == True
#
# No prior threading spec checks Semaphore.__dict__.__contains__ via threadingextra85. New to extra85.
# ---------------------------------------------------------------------------

table threading_extra85.Semaphore_dict_group1:
  description: "Semaphore.__dict__ contains acquire/release/__init__; BoundedSemaphore.__dict__ contains release; wave 248 threading Semaphore dict membership; new to extra85"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra85

  columns: [id, function, args, expected, description]
  rows:
    - [Semaphore_dict_contains_acquire,
       Semaphore.__dict__.__contains__,
       ["acquire"],
       true,
       "threading.Semaphore.__dict__.__contains__('acquire') == True — Semaphore is a pure-Python class defined in Lib/threading.py; it defines acquire() in its own namespace; acquire() decrements the semaphore counter, blocking if the counter is zero; __dict__.__contains__('acquire') returns True; no prior threading spec checks Semaphore.__dict__.__contains__('acquire') via threadingextra85; new to extra85"]
    - [Semaphore_dict_contains_release,
       Semaphore.__dict__.__contains__,
       ["release"],
       true,
       "threading.Semaphore.__dict__.__contains__('release') == True — Semaphore defines release() in its own namespace; release() increments the semaphore counter and wakes one waiting thread if present; __dict__.__contains__('release') returns True; no prior threading spec checks Semaphore.__dict__.__contains__('release') via threadingextra85; new to extra85"]
    - [Semaphore_dict_contains_init,
       Semaphore.__dict__.__contains__,
       ["__init__"],
       true,
       "threading.Semaphore.__dict__.__contains__('__init__') == True — Semaphore defines __init__ in its own namespace to initialize the semaphore with an optional value parameter; __dict__.__contains__('__init__') returns True; no prior threading spec checks Semaphore.__dict__.__contains__('__init__') via threadingextra85; new to extra85"]
    - [BoundedSemaphore_dict_contains_release,
       BoundedSemaphore.__dict__.__contains__,
       ["release"],
       true,
       "threading.BoundedSemaphore.__dict__.__contains__('release') == True — BoundedSemaphore overrides release() in its own namespace; the override adds an upper-bound check to prevent releasing more than was acquired; __dict__.__contains__('release') returns True; no prior threading spec checks BoundedSemaphore.__dict__.__contains__('release') via threadingextra85; new to extra85"]

# ---------------------------------------------------------------------------
# threading.Event.__dict__ membership — set/clear/wait/is_set — extra85
#
# Wave 248 theme: threading.Event __dict__ membership.
#
# threading.Event.__dict__.__contains__('set')    == True
# threading.Event.__dict__.__contains__('clear')  == True
# threading.Event.__dict__.__contains__('wait')   == True
# threading.Event.__dict__.__contains__('is_set') == True
#
# No prior threading spec checks Event.__dict__.__contains__ via threadingextra85. New to extra85.
# ---------------------------------------------------------------------------

table threading_extra85.Event_dict_group1:
  description: "Event.__dict__ contains set/clear/wait/is_set; wave 248 threading Event dict membership; new to extra85"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra85

  columns: [id, function, args, expected, description]
  rows:
    - [Event_dict_contains_set,
       Event.__dict__.__contains__,
       ["set"],
       true,
       "threading.Event.__dict__.__contains__('set') == True — Event is a pure-Python class defined in Lib/threading.py; it defines set() in its own namespace; set() sets the internal flag to True and wakes all waiting threads; __dict__.__contains__('set') returns True; no prior threading spec checks Event.__dict__.__contains__('set') via threadingextra85; new to extra85"]
    - [Event_dict_contains_clear,
       Event.__dict__.__contains__,
       ["clear"],
       true,
       "threading.Event.__dict__.__contains__('clear') == True — Event defines clear() in its own namespace; clear() resets the internal flag to False; threads calling wait() will then block; __dict__.__contains__('clear') returns True; no prior threading spec checks Event.__dict__.__contains__('clear') via threadingextra85; new to extra85"]
    - [Event_dict_contains_wait,
       Event.__dict__.__contains__,
       ["wait"],
       true,
       "threading.Event.__dict__.__contains__('wait') == True — Event defines wait() in its own namespace; wait() blocks until the internal flag is True or an optional timeout expires; __dict__.__contains__('wait') returns True; no prior threading spec checks Event.__dict__.__contains__('wait') via threadingextra85; new to extra85"]
    - [Event_dict_contains_is_set,
       Event.__dict__.__contains__,
       ["is_set"],
       true,
       "threading.Event.__dict__.__contains__('is_set') == True — Event defines is_set() in its own namespace; is_set() returns True if the internal flag is True; __dict__.__contains__('is_set') returns True; no prior threading spec checks Event.__dict__.__contains__('is_set') via threadingextra85; new to extra85"]

# ---------------------------------------------------------------------------
# threading.Condition.__dict__ membership — notify/notify_all/wait/__init__ — extra85
#
# Wave 248 theme: threading.Condition __dict__ membership.
#
# threading.Condition.__dict__.__contains__('notify')     == True
# threading.Condition.__dict__.__contains__('notify_all') == True
# threading.Condition.__dict__.__contains__('wait')       == True
# threading.Condition.__dict__.__contains__('__init__')   == True
#
# Note: Condition.__dict__ does NOT contain 'acquire' or 'release' (delegated to underlying lock).
# No prior threading spec checks Condition.__dict__.__contains__ via threadingextra85. New to extra85.
# ---------------------------------------------------------------------------

table threading_extra85.Condition_dict_group1:
  description: "Condition.__dict__ contains notify/notify_all/wait/__init__; wave 248 threading Condition dict membership; new to extra85"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra85

  columns: [id, function, args, expected, description]
  rows:
    - [Condition_dict_contains_notify,
       Condition.__dict__.__contains__,
       ["notify"],
       true,
       "threading.Condition.__dict__.__contains__('notify') == True — Condition is a pure-Python class defined in Lib/threading.py; it defines notify() in its own namespace; notify() wakes up one or more threads waiting on the condition; __dict__.__contains__('notify') returns True; no prior threading spec checks Condition.__dict__.__contains__('notify') via threadingextra85; new to extra85"]
    - [Condition_dict_contains_notify_all,
       Condition.__dict__.__contains__,
       ["notify_all"],
       true,
       "threading.Condition.__dict__.__contains__('notify_all') == True — Condition defines notify_all() in its own namespace; notify_all() wakes all threads waiting on the condition; __dict__.__contains__('notify_all') returns True; no prior threading spec checks Condition.__dict__.__contains__('notify_all') via threadingextra85; new to extra85"]
    - [Condition_dict_contains_wait,
       Condition.__dict__.__contains__,
       ["wait"],
       true,
       "threading.Condition.__dict__.__contains__('wait') == True — Condition defines wait() in its own namespace; wait() releases the underlying lock and blocks until notified or timeout expires; __dict__.__contains__('wait') returns True; no prior threading spec checks Condition.__dict__.__contains__('wait') via threadingextra85; new to extra85"]
    - [Condition_dict_contains_init,
       Condition.__dict__.__contains__,
       ["__init__"],
       true,
       "threading.Condition.__dict__.__contains__('__init__') == True — Condition defines __init__ in its own namespace to initialize the condition with an optional lock parameter; __dict__.__contains__('__init__') returns True; no prior threading spec checks Condition.__dict__.__contains__('__init__') via threadingextra85; new to extra85"]

# ---------------------------------------------------------------------------
# threading.Barrier.__dict__ membership — wait/reset + Semaphore class name — extra85
#
# Wave 248 theme: threading.Barrier __dict__ membership + Semaphore dict class name.
#
# threading.Barrier.__dict__.__contains__('wait')  == True
# threading.Barrier.__dict__.__contains__('reset') == True
# threading.Semaphore.__dict__.__class__.__name__  == 'mappingproxy'
# threading.Event.__dict__.__class__.__name__      == 'mappingproxy'
#
# No prior threading spec checks Barrier.__dict__.__contains__ via threadingextra85. New to extra85.
# ---------------------------------------------------------------------------

table threading_extra85.Barrier_dict_and_class_names:
  description: "Barrier.__dict__ contains wait/reset; Semaphore/__dict__ class name mappingproxy; Event/__dict__ class name mappingproxy; wave 248; new to extra85"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra85

  columns: [id, function, args, expected, description]
  rows:
    - [Barrier_dict_contains_wait,
       Barrier.__dict__.__contains__,
       ["wait"],
       true,
       "threading.Barrier.__dict__.__contains__('wait') == True — Barrier is a pure-Python class defined in Lib/threading.py; it defines wait() in its own namespace; wait() blocks until all parties have called it; __dict__.__contains__('wait') returns True; no prior threading spec checks Barrier.__dict__.__contains__('wait') via threadingextra85; new to extra85"]
    - [Barrier_dict_contains_reset,
       Barrier.__dict__.__contains__,
       ["reset"],
       true,
       "threading.Barrier.__dict__.__contains__('reset') == True — Barrier defines reset() in its own namespace; reset() returns the barrier to the default empty state; __dict__.__contains__('reset') returns True; no prior threading spec checks Barrier.__dict__.__contains__('reset') via threadingextra85; new to extra85"]
    - [Semaphore_dict_class_name_eq_mappingproxy,
       Semaphore.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "threading.Semaphore.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Semaphore.__dict__ is a types.MappingProxyType (mappingproxy) wrapping the class namespace; its __class__.__name__ is 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior threading spec checks Semaphore.__dict__.__class__.__name__ via threadingextra85; new to extra85"]
    - [Event_dict_class_name_eq_mappingproxy,
       Event.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "threading.Event.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Event.__dict__ is a types.MappingProxyType (mappingproxy) wrapping the class namespace; its __class__.__name__ is 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior threading spec checks Event.__dict__.__class__.__name__ via threadingextra85; new to extra85"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra85
# ---------------------------------------------------------------------------

invariant threading_extra85.Semaphore_dict_contains_acquire:
  description: "threading.Semaphore.__dict__.__contains__('acquire') == True — Semaphore defines acquire() in its own namespace; wave 248; new to extra85"
  kind: python_call_eq
  function: Semaphore.__dict__.__contains__
  args: ["acquire"]
  expected: true

invariant threading_extra85.Event_dict_contains_set:
  description: "threading.Event.__dict__.__contains__('set') == True — Event defines set() in its own namespace; wave 248; new to extra85"
  kind: python_call_eq
  function: Event.__dict__.__contains__
  args: ["set"]
  expected: true

invariant threading_extra85.Condition_dict_contains_notify:
  description: "threading.Condition.__dict__.__contains__('notify') == True — Condition defines notify() in its own namespace; wave 248; new to extra85"
  kind: python_call_eq
  function: Condition.__dict__.__contains__
  args: ["notify"]
  expected: true

invariant threading_extra85.Barrier_dict_contains_wait:
  description: "threading.Barrier.__dict__.__contains__('wait') == True — Barrier defines wait() in its own namespace; wave 248; new to extra85"
  kind: python_call_eq
  function: Barrier.__dict__.__contains__
  args: ["wait"]
  expected: true

invariant threading_extra85.BoundedSemaphore_dict_contains_release:
  description: "threading.BoundedSemaphore.__dict__.__contains__('release') == True — BoundedSemaphore overrides release() with upper-bound check; wave 248; new to extra85"
  kind: python_call_eq
  function: BoundedSemaphore.__dict__.__contains__
  args: ["release"]
  expected: true
