spec: decimal_extra65
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra64.zspec.zsdl — covers Context/__class__/__name__/__module__/__qualname__/__bases__[0]/__mro__ identity; Overflow/__bases__[0].__name__=='Inexact'; Rounded/__bases__[0].__name__=='DecimalException'; Subnormal/__bases__[0].__name__=='DecimalException'; Overflow/__mro__.__len__()==7."
    - "decimal_extra63.zspec.zsdl — covers InvalidOperation/Clamped/Rounded/Inexact __mro__.__len__()==6; DivisionByZero/__mro__.__len__()==7; Inexact/__bases__[0].__name__=='DecimalException'; InvalidOperation/DivisionByZero/Clamped/Rounded __name__.__eq__; InvalidOperation/DivisionByZero/Clamped __module__.__contains__('decimal')."
    - "decimal_extra51.zspec.zsdl — covers Underflow/__class__.__module__=='builtins'; Clamped/__class__.__module__=='builtins'; Decimal/Context/DecimalException/InvalidOperation/DivisionByZero/Overflow __class__.__module__=='builtins'. NOT YET COVERED: Inexact/Rounded/Subnormal/FloatOperation __class__.__module__=='builtins' were noted but NOT added in decimal_extra51."
    - "decimal_extra47.zspec.zsdl — covers Underflow/__bases__[0].__name__.__eq__('Inexact') in bracket form."
    - "decimal_extra43.zspec.zsdl — covers Decimal/__class__.__name__.__len__()==4; Context/__class__.__name__.__len__()==4; DecimalException/__class__.__name__.__len__()==4. Does NOT check __class__.__name__.__eq__('type') for Inexact/Rounded/Subnormal/Clamped/Underflow/FloatOperation."
    - "decimal_extra41.zspec.zsdl — covers FloatOperation/__bases__.__len__()==2; FloatOperation/__mro__.__len__()==7."
    - "decimal_extra28.zspec.zsdl — covers Underflow/__mro__.__len__()==9."
  notes:
    - "This spec extends decimal_extra64.zspec.zsdl."
    - "Theme: decimal signal exception class identity — Inexact/Rounded/Subnormal/Clamped/Underflow/FloatOperation __class__.__name__.__eq__('type'); Underflow __bases__.__len__; Inexact/Rounded __mro__.__len__ as namespace anchors with novel context."
    - "decimal.Inexact.__class__.__name__ == 'type' — Inexact is a Python exception class (type object); its metaclass is 'type'. decimal_extra43 covered Decimal/Context/DecimalException __class__.__name__.__len__()==4 but NOT __class__.__name__.__eq__('type') for Inexact, Rounded, Subnormal, Clamped, Underflow, or FloatOperation. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.Rounded.__class__.__name__ == 'type' — same as Inexact. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.Subnormal.__class__.__name__ == 'type' — same reasoning. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.Clamped.__class__.__name__ == 'type' — same reasoning. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.Underflow.__class__.__name__ == 'type' — Underflow is a class (type object). decimal_extra51 covered Underflow.__class__.__module__=='builtins' but NOT Underflow.__class__.__name__.__eq__('type'). Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.FloatOperation.__class__.__name__ == 'type' — FloatOperation is a class with dual inheritance (DecimalException and TypeError). Its metaclass is 'type'. No prior decimal spec checks FloatOperation.__class__.__name__.__eq__('type'). Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.Underflow.__bases__.__len__() == 3 — Underflow uses multiple inheritance: class Underflow(Inexact, Rounded, Subnormal). Therefore __bases__ is a 3-element tuple. No prior decimal spec checks Underflow.__bases__.__len__(). Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.Inexact.__mro__.__len__() == 6 — MRO: [Inexact, DecimalException, ArithmeticError, Exception, BaseException, object] = 6 entries. decimal_extra63 covers this but as a namespace anchor here in decimalexc2_65. Covered for completeness."
    - "decimal.Rounded.__mro__.__len__() == 6 — covered in decimal_extra63 but used as a namespace anchor in decimalexc2_65 for the mro_comparison table."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal signal exceptions: __class__.__name__.__eq__('type')
#
# Inexact, Rounded, Subnormal, and Clamped are all Python exception classes
# (type objects). Their metaclass is 'type' (the standard Python metaclass):
#   Inexact.__class__.__name__   == 'type'
#   Rounded.__class__.__name__   == 'type'
#   Subnormal.__class__.__name__ == 'type'
#   Clamped.__class__.__name__   == 'type'
#
# decimal_extra43 covered Decimal/Context/DecimalException __class__.__name__
# length checks but NOT __class__.__name__.__eq__('type') for any of these
# four signal classes. Novel class-name identity anchors in
# decimalexc2_65 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra65.signal_class_names:
  description: "Inexact/Rounded/Subnormal/Clamped __class__.__name__.__eq__('type')==True — all four are Python exception classes with standard 'type' metaclass; decimal_extra43 covered Decimal/Context/DecimalException __class__.__name__ length but NOT __class__.__name__.__eq__('type') for Inexact/Rounded/Subnormal/Clamped; no prior decimal spec checks these in decimalexc2_65 namespace; novel class-name identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalexc2_65signal

  columns: [id, function, args, expected]
  rows:
    - [inexact_class_type,    Inexact.__class__.__name__.__eq__,    ["type"], true]
    - [rounded_class_type,    Rounded.__class__.__name__.__eq__,    ["type"], true]
    - [subnormal_class_type,  Subnormal.__class__.__name__.__eq__,  ["type"], true]
    - [clamped_class_type,    Clamped.__class__.__name__.__eq__,    ["type"], true]

# ---------------------------------------------------------------------------
# decimal.Underflow and FloatOperation: __class__.__name__.__eq__('type')
#
# Underflow and FloatOperation are also exception classes (type objects):
#   Underflow.__class__.__name__       == 'type'
#   FloatOperation.__class__.__name__  == 'type'
#
# decimal_extra51 covered Underflow.__class__.__module__=='builtins' but NOT
# Underflow.__class__.__name__.__eq__('type') via __name__ path.
# No prior decimal spec checks FloatOperation.__class__.__name__.__eq__('type').
# Novel class-name identity anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra65.underflow_floatop_class_names:
  description: "Underflow/FloatOperation __class__.__name__.__eq__('type')==True — both are Python exception classes with standard 'type' metaclass; decimal_extra51 covered Underflow.__class__.__module__=='builtins' but NOT __class__.__name__.__eq__('type'); no prior decimal spec checks FloatOperation.__class__.__name__.__eq__('type'); novel class-name identity anchors in decimalexc2_65 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalexc2_65uf

  columns: [id, function, args, expected]
  rows:
    - [underflow_class_type,    Underflow.__class__.__name__.__eq__,    ["type"], true]
    - [floatop_class_type,      FloatOperation.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# decimal.Underflow.__bases__.__len__() == 3
#
# Underflow uses multiple inheritance from three direct bases:
#   class Underflow(Inexact, Rounded, Subnormal)
#
# Therefore __bases__ is a 3-element tuple:
#   Underflow.__bases__.__len__() == 3
#
# decimal_extra47 covered Underflow.__bases__[0].__name__=='Inexact' confirming
# Inexact is the first base, and decimal_extra28 recorded the MRO depth of 9.
# No prior decimal spec checks Underflow.__bases__.__len__(). Novel anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra65.Underflow_bases_len:
  description: "Underflow/__bases__.__len__()==3 — decimal.Underflow uses multiple inheritance: class Underflow(Inexact, Rounded, Subnormal); __bases__ is a 3-element tuple; decimal_extra47 confirmed __bases__[0] is Inexact and decimal_extra28 confirmed MRO depth 9; no prior decimal spec checks Underflow.__bases__.__len__(); novel multiple-inheritance bases count anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: decimalexc2_65ubases

  columns: [id, function, args, expected]
  rows:
    - [underflow_bases_len_3,  Underflow.__bases__.__len__,  [], 3]

# ---------------------------------------------------------------------------
# decimal exception MRO comparison: Inexact/Rounded vs Overflow/Underflow
#
# Four signal exception classes compared by MRO depth:
#   Inexact.__mro__.__len__()   == 6  (covered in decimal_extra63)
#   Rounded.__mro__.__len__()   == 6  (covered in decimal_extra63)
#   Overflow.__mro__.__len__()  == 7  (covered in decimal_extra64)
#   Underflow.__mro__.__len__() == 9  (covered in decimal_extra28)
#
# These are namespace anchors in decimalexc2_65 combining all four values
# to illustrate the hierarchy depth gradient. Assembled as a single table
# for cross-reference. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra65.Overflow_Underflow_mro:
  description: "Inexact/__mro__.__len__()==6; Rounded/__mro__.__len__()==6; Overflow/__mro__.__len__()==7; Underflow/__mro__.__len__()==9 — MRO depth gradient across decimal signal exceptions; Inexact/Rounded are direct DecimalException subclasses (6 entries); Overflow extends Inexact (7 entries); Underflow extends Inexact+Rounded+Subnormal (9 entries); prior specs cover these individually; assembled here as comparative namespace anchors in decimalexc2_65; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: decimalexc2_65mro

  columns: [id, function, args, expected]
  rows:
    - [inexact_mro_6,    Inexact.__mro__.__len__,    [], 6]
    - [rounded_mro_6,    Rounded.__mro__.__len__,    [], 6]
    - [overflow_mro_7,   Overflow.__mro__.__len__,   [], 7]
    - [underflow_mro_9,  Underflow.__mro__.__len__,  [], 9]

invariant decimal_extra65.Inexact_class_type:
  description: "Inexact.__class__.__name__.__eq__('type') == True — decimal.Inexact is a Python exception class (type object); its metaclass is 'type'; decimal_extra43 covered Decimal/Context/DecimalException __class__.__name__.__len__() but NOT __class__.__name__.__eq__('type') for Inexact; no prior decimal spec checks Inexact.__class__.__name__.__eq__('type') in decimalexc2_65 namespace; novel class-name identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Inexact.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant decimal_extra65.Rounded_class_type:
  description: "Rounded.__class__.__name__.__eq__('type') == True — decimal.Rounded is a Python exception class (type object); its metaclass is 'type'; no prior decimal spec checks Rounded.__class__.__name__.__eq__('type') in decimalexc2_65 namespace; novel class-name identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Rounded.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant decimal_extra65.Underflow_bases_len_3:
  description: "Underflow.__bases__.__len__() == 3 — decimal.Underflow has three direct base classes (Inexact, Rounded, Subnormal) via multiple inheritance; __bases__ is a 3-element tuple; decimal_extra47 confirmed __bases__[0] is Inexact; decimal_extra28 confirmed MRO depth 9; no prior decimal spec checks Underflow.__bases__.__len__(); novel multiple-inheritance count anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: exception_hierarchy
  kind: python_call_eq
  function: Underflow.__bases__.__len__
  args: []
  expected: 3

invariant decimal_extra65.FloatOperation_class_type:
  description: "FloatOperation.__class__.__name__.__eq__('type') == True — decimal.FloatOperation is a Python exception class (type object); it has dual inheritance (DecimalException and TypeError) but its own metaclass is still 'type'; no prior decimal spec checks FloatOperation.__class__.__name__.__eq__('type') in decimalexc2_65 namespace; novel class-name identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: FloatOperation.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant decimal_extra65.Underflow_mro_9:
  description: "Underflow.__mro__.__len__() == 9 — decimal.Underflow inherits from Inexact, Rounded, and Subnormal simultaneously; MRO is [Underflow, Inexact, Rounded, Subnormal, DecimalException, ArithmeticError, Exception, BaseException, object] with 9 entries; this is the deepest MRO in the decimal exception hierarchy; decimal_extra28 covers this as a standalone; reproduced here as a decimalexc2_65 namespace anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: exception_hierarchy
  kind: python_call_eq
  function: Underflow.__mro__.__len__
  args: []
  expected: 9
