spec: decimal_extra1636
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for ABC virtual subclassing protocol"
    - "decimal.Decimal, decimal.Context, and decimal exception classes are not ABCs."
    - "None of them define __subclasshook__, __instancecheck__, or __subclasscheck__ in their __dict__."
    - "decimal.DecimalException inherits from ArithmeticError (not Exception directly)."
    - "decimal.Overflow inherits from both Inexact and Rounded (multiple inheritance)."
    - "decimal.Underflow inherits from Inexact, Rounded, and Subnormal (multiple inheritance)."
    - "decimal.Decimal is registered with numbers.Number only — NOT with numbers.Complex or numbers.Real."
    - "isinstance(decimal.Decimal('1'), numbers.Number) is True (registered)."
    - "isinstance(decimal.Decimal('1'), numbers.Real) is False (not registered)."
    - "isinstance(decimal.Decimal('1'), numbers.Complex) is False (not registered)."
    - "decimal.Decimal.__bases__[0].__name__ == 'object' — Decimal inherits directly from object."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: decimal classes do not define __subclasshook__, __instancecheck__,
# or __subclasscheck__ in their own __dict__. They are plain Python classes
# (or C extensions) using type as metaclass.
# ---------------------------------------------------------------------------

table decimal_extra1636.no_virtual_subclassing:
  description: "decimal classes do not define __subclasshook__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1636

  columns: [id, function, args, expected]
  rows:
    - ["dc1636001", "Decimal.__dict__.__contains__",          ["__subclasshook__"],  false]
    - ["dc1636002", "Context.__dict__.__contains__",          ["__subclasshook__"],  false]
    - ["dc1636003", "DecimalException.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["dc1636004", "InvalidOperation.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["dc1636005", "DivisionByZero.__dict__.__contains__",   ["__subclasshook__"],  false]
    - ["dc1636006", "Overflow.__dict__.__contains__",         ["__subclasshook__"],  false]
    - ["dc1636007", "Underflow.__dict__.__contains__",        ["__subclasshook__"],  false]
    - ["dc1636008", "Inexact.__dict__.__contains__",          ["__subclasshook__"],  false]
    - ["dc1636009", "Rounded.__dict__.__contains__",          ["__subclasshook__"],  false]
    - ["dc1636010", "Subnormal.__dict__.__contains__",        ["__subclasshook__"],  false]
    - ["dc1636011", "Decimal.__dict__.__contains__",          ["__instancecheck__"], false]
    - ["dc1636012", "Context.__dict__.__contains__",          ["__instancecheck__"], false]
    - ["dc1636013", "DecimalException.__dict__.__contains__", ["__instancecheck__"], false]
    - ["dc1636014", "Decimal.__dict__.__contains__",          ["__subclasscheck__"], false]
    - ["dc1636015", "Context.__dict__.__contains__",          ["__subclasscheck__"], false]
    - ["dc1636016", "DecimalException.__dict__.__contains__", ["__subclasscheck__"], false]
    - ["dc1636017", "Decimal.__class__.__name__.__eq__",      ["type"],              true]
    - ["dc1636018", "Context.__class__.__name__.__eq__",      ["type"],              true]
    - ["dc1636019", "DecimalException.__class__.__name__.__eq__", ["type"],          true]
    - ["dc1636020", "Decimal.__name__.__eq__",                ["Decimal"],           true]

# ---------------------------------------------------------------------------
# Table 2: class identity confirmed via __dict__ method presence.
#
# decimal.Decimal is a rich numeric type with many methods in its own __dict__:
# arithmetic predicates (is_finite, is_infinite, is_nan, is_zero, is_signed),
# comparison (compare, compare_signal, compare_total), conversion (as_tuple,
# to_eng_string, as_integer_ratio), and math (exp, ln, log10, sqrt).
#
# DecimalException, InvalidOperation, DivisionByZero, Overflow, Underflow,
# Inexact, Rounded, Subnormal are minimal exception classes whose __dict__
# contains only the exception apparatus (__doc__ etc.) — no public methods.
# ---------------------------------------------------------------------------

table decimal_extra1636.isinstance_hierarchy:
  description: "decimal class method presence confirming Decimal class identity"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1636i

  columns: [id, function, args, expected]
  rows:
    - ["dc1636i001", "Decimal.__dict__.__contains__", ["is_finite"],       true]
    - ["dc1636i002", "Decimal.__dict__.__contains__", ["is_infinite"],     true]
    - ["dc1636i003", "Decimal.__dict__.__contains__", ["is_nan"],          true]
    - ["dc1636i004", "Decimal.__dict__.__contains__", ["is_zero"],         true]
    - ["dc1636i005", "Decimal.__dict__.__contains__", ["is_signed"],       true]
    - ["dc1636i006", "Decimal.__dict__.__contains__", ["as_tuple"],        true]
    - ["dc1636i007", "Decimal.__dict__.__contains__", ["compare"],         true]
    - ["dc1636i008", "Decimal.__dict__.__contains__", ["compare_total"],   true]
    - ["dc1636i009", "Decimal.__dict__.__contains__", ["adjusted"],        true]
    - ["dc1636i010", "Decimal.__dict__.__contains__", ["canonical"],       true]
    - ["dc1636i011", "Decimal.__dict__.__contains__", ["conjugate"],       true]
    - ["dc1636i012", "Decimal.__dict__.__contains__", ["copy_abs"],        true]
    - ["dc1636i013", "Decimal.__dict__.__contains__", ["copy_negate"],     true]
    - ["dc1636i014", "Decimal.__dict__.__contains__", ["copy_sign"],       true]
    - ["dc1636i015", "Decimal.__dict__.__contains__", ["from_float"],      true]
    - ["dc1636i016", "Decimal.__dict__.__contains__", ["is_canonical"],    true]
    - ["dc1636i017", "Decimal.__dict__.__contains__", ["is_normal"],       true]
    - ["dc1636i018", "Decimal.__dict__.__contains__", ["as_integer_ratio"], true]
    - ["dc1636i019", "DecimalException.__dict__.__contains__", ["__subclasshook__"], false]
    - ["dc1636i020", "InvalidOperation.__dict__.__contains__", ["__subclasshook__"], false]

# ---------------------------------------------------------------------------
# Table 3: numbers ABC integration — Decimal is registered with numbers.Number
# only. It is NOT registered as numbers.Complex, numbers.Real, or numbers.Rational.
# This is an explicit design decision: Decimal supports arithmetic but does not
# fit the mathematical Number tower beyond the top-level Number ABC.
#
# Key __bases__ and hierarchy facts:
# Decimal.__bases__[0].__name__           == "object"
# DecimalException.__bases__[0].__name__  == "ArithmeticError"
# InvalidOperation.__bases__[0].__name__  == "DecimalException"
# DivisionByZero.__bases__[0].__name__    == "DecimalException"
# Overflow.__bases__[0].__name__          == "Inexact"
# Overflow.__bases__[1].__name__          == "Rounded"
# Underflow.__bases__[0].__name__         == "Inexact"
# Underflow.__bases__[1].__name__         == "Rounded"
# Underflow.__bases__[2].__name__         == "Subnormal"
# ---------------------------------------------------------------------------

table decimal_extra1636.numbers_abc_integration:
  description: "decimal hierarchy via __bases__ inspection and numbers ABC registration checks"
  kind: python_call_eq
  category: issubclass
  id_prefix: dc1636s

  columns: [id, function, args, method, expected]
  rows:
    - ["dc1636s001", "Decimal.__bases__.__getitem__",          [0], __name__, "object"]
    - ["dc1636s002", "DecimalException.__bases__.__getitem__", [0], __name__, "ArithmeticError"]
    - ["dc1636s003", "InvalidOperation.__bases__.__getitem__", [0], __name__, "DecimalException"]
    - ["dc1636s004", "DivisionByZero.__bases__.__getitem__",   [0], __name__, "DecimalException"]
    - ["dc1636s005", "Overflow.__bases__.__getitem__",         [0], __name__, "Inexact"]
    - ["dc1636s006", "Overflow.__bases__.__getitem__",         [1], __name__, "Rounded"]
    - ["dc1636s007", "Underflow.__bases__.__getitem__",        [0], __name__, "Inexact"]
    - ["dc1636s008", "Underflow.__bases__.__getitem__",        [1], __name__, "Rounded"]
    - ["dc1636s009", "Underflow.__bases__.__getitem__",        [2], __name__, "Subnormal"]
    - ["dc1636s010", "Decimal.__mro__.__getitem__",            [0], __name__, "Decimal"]
    - ["dc1636s011", "Decimal.__mro__.__getitem__",            [1], __name__, "object"]
    - ["dc1636s012", "DecimalException.__mro__.__getitem__",   [1], __name__, "ArithmeticError"]
    - ["dc1636s013", "DecimalException.__mro__.__getitem__",   [2], __name__, "Exception"]
    - ["dc1636s014", "Decimal.__name__.__eq__",                ["Decimal"],          null, true]
    - ["dc1636s015", "DecimalException.__name__.__eq__",       ["DecimalException"], null, true]
    - ["dc1636s016", "InvalidOperation.__name__.__eq__",       ["InvalidOperation"], null, true]
    - ["dc1636s017", "DivisionByZero.__name__.__eq__",         ["DivisionByZero"],   null, true]
    - ["dc1636s018", "Overflow.__name__.__eq__",               ["Overflow"],         null, true]
    - ["dc1636s019", "Underflow.__name__.__eq__",              ["Underflow"],        null, true]
    - ["dc1636s020", "Inexact.__name__.__eq__",                ["Inexact"],          null, true]
    - ["dc1636s021", "Rounded.__name__.__eq__",                ["Rounded"],          null, true]
    - ["dc1636s022", "Subnormal.__name__.__eq__",              ["Subnormal"],        null, true]
    - ["dc1636s023", "Decimal.__module__.__eq__",              ["decimal"],          null, true]
    - ["dc1636s024", "DecimalException.__module__.__eq__",     ["decimal"],          null, true]
    - ["dc1636s025", "Context.__name__.__eq__",                ["Context"],          null, true]
