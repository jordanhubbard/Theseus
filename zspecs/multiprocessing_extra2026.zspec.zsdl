spec: multiprocessing_extra2026
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.html#synchronization-primitives"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 582 (_extra2026): __truediv__, __floordiv__, __mod__, __pow__, __divmod__ dict-presence checks."
    - "multiprocessing.Process and synchronize types are process/IPC primitives, not numeric types."
    - "multiprocessing.synchronize provides Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition."
    - "None of these types define division, floor division, modulo, power, or divmod protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table multiprocessing_extra2026.truediv_protocol:
  description: "multiprocessing.Process and synchronize types __truediv__/__rtruediv__/__itruediv__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2026

  columns: [id, function, args, expected]
  rows:
    - ["mp2026001", "multiprocessing.Process.__dict__.__contains__", ["__truediv__"], false]
    - ["mp2026002", "multiprocessing.Process.__dict__.__contains__", ["__rtruediv__"], false]
    - ["mp2026003", "multiprocessing.Process.__dict__.__contains__", ["__itruediv__"], false]
    - ["mp2026004", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__truediv__"], false]
    - ["mp2026005", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__rtruediv__"], false]
    - ["mp2026006", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__itruediv__"], false]
    - ["mp2026007", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__truediv__"], false]
    - ["mp2026008", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__rtruediv__"], false]
    - ["mp2026009", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__itruediv__"], false]
    - ["mp2026010", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__truediv__"], false]
    - ["mp2026011", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__rtruediv__"], false]
    - ["mp2026012", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__itruediv__"], false]
    - ["mp2026013", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__truediv__"], false]
    - ["mp2026014", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__rtruediv__"], false]
    - ["mp2026015", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__itruediv__"], false]

