spec: io_extra94
version: ">=3.9"
backend: python_module(io)
extends: io_extra93

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra93."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths; FileIO/BytesIO/StringIO __dict__/__class__.__name__ and membership; BufferedReader/BufferedWriter/TextIOWrapper identity and MRO; BufferedRandom/__name__/__module__/bases/MRO; BufferedRWPair identity and hierarchy; IncrementalNewlineDecoder identity; TextIOWrapper/__name__/__module__/bases/MRO; StringIO/__name__/__module__/bases/MRO; FileIO/__name__/__module__/bases/MRO; BytesIO/__name__/__module__/bases/MRO; __mro__.__len__() for all classes."
    - "This spec covers: __name__ and __module__ string equality for abstract base classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase) and concrete classes (BufferedReader, BufferedWriter, BufferedRandom, BytesIO, StringIO, TextIOWrapper, FileIO)."
    - "io.IOBase.__module__ == 'io' — IOBase is the Python-level wrapper class defined in io module (Lib/io.py), not the C-extension _IOBase."
    - "io.RawIOBase.__module__ == 'io' — Python-level wrapper over _io._RawIOBase, defined in io module."
    - "io.BufferedIOBase.__module__ == 'io' — Python-level wrapper over _io._BufferedIOBase, defined in io module."
    - "io.TextIOBase.__module__ == 'io' — Python-level wrapper over _io._TextIOBase, defined in io module."
    - "io.FileIO.__module__ == '_io' — concrete C-extension class from the _io module."
    - "io.BufferedReader.__module__ == '_io' — concrete C-extension class from the _io module."
    - "io.BufferedWriter.__module__ == '_io' — concrete C-extension class from the _io module."
    - "io.BytesIO.__module__ == '_io' — concrete C-extension class from the _io module."
    - "io.StringIO.__module__ == '_io' — concrete C-extension class from the _io module."
    - "io.TextIOWrapper.__module__ == '_io' — concrete C-extension class from the _io module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io abstract base class __name__ and __module__ string equality
# IOBase, RawIOBase, BufferedIOBase, TextIOBase are Python-level wrapper classes
# defined in the io module (Lib/io.py); their __module__ is 'io', not '_io'.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra94.abstract_bases_name_module:
  description: "io.IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__ and __module__ string equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: ionamemod94

  columns: [id, function, args, expected]
  rows:
    - [iobase_name,        IOBase.__name__.__eq__,           ["IOBase"],           true]
    - [iobase_module,      IOBase.__module__.__eq__,         ["io"],               true]
    - [rawiobase_name,     RawIOBase.__name__.__eq__,        ["RawIOBase"],        true]
    - [rawiobase_module,   RawIOBase.__module__.__eq__,      ["io"],               true]
    - [bufiobase_name,     BufferedIOBase.__name__.__eq__,   ["BufferedIOBase"],   true]
    - [bufiobase_module,   BufferedIOBase.__module__.__eq__, ["io"],               true]
    - [textiobase_name,    TextIOBase.__name__.__eq__,       ["TextIOBase"],       true]
    - [textiobase_module,  TextIOBase.__module__.__eq__,     ["io"],               true]

# ---------------------------------------------------------------------------
# io BufferedReader/BufferedWriter/BufferedRandom __name__ and __module__
# These are C-extension classes from the _io module.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra94.buffered_rw_name_module:
  description: "io.BufferedReader/BufferedWriter/BufferedRandom __name__ and __module__ string equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: ionamemod94

  columns: [id, function, args, expected]
  rows:
    - [bufreader_name,    BufferedReader.__name__.__eq__,    ["BufferedReader"],  true]
    - [bufreader_module,  BufferedReader.__module__.__eq__,  ["_io"],             true]
    - [bufwriter_name,    BufferedWriter.__name__.__eq__,    ["BufferedWriter"],  true]
    - [bufwriter_module,  BufferedWriter.__module__.__eq__,  ["_io"],             true]
    - [bufrandom_name,    BufferedRandom.__name__.__eq__,    ["BufferedRandom"],  true]
    - [bufrandom_module,  BufferedRandom.__module__.__eq__,  ["_io"],             true]

# ---------------------------------------------------------------------------
# io BytesIO/StringIO __name__ and __module__
# Both are C-extension classes from the _io module.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra94.bytes_string_io_name_module:
  description: "io.BytesIO/StringIO __name__ and __module__ string equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: ionamemod94

  columns: [id, function, args, expected]
  rows:
    - [bytesio_name,    BytesIO.__name__.__eq__,    ["BytesIO"],  true]
    - [bytesio_module,  BytesIO.__module__.__eq__,  ["_io"],      true]
    - [stringio_name,   StringIO.__name__.__eq__,   ["StringIO"], true]
    - [stringio_module, StringIO.__module__.__eq__,  ["_io"],     true]

# ---------------------------------------------------------------------------
# io TextIOWrapper/FileIO __name__ and __module__
# Both are C-extension classes from the _io module.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra94.textiowrapper_fileio_name_module:
  description: "io.TextIOWrapper/FileIO __name__ and __module__ string equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: ionamemod94

  columns: [id, function, args, expected]
  rows:
    - [textwrapper_name,    TextIOWrapper.__name__.__eq__,    ["TextIOWrapper"],  true]
    - [textwrapper_module,  TextIOWrapper.__module__.__eq__,  ["_io"],            true]
    - [fileio_name,         FileIO.__name__.__eq__,           ["FileIO"],         true]
    - [fileio_module,       FileIO.__module__.__eq__,         ["_io"],            true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra94.IOBase.name:
  description: "io.IOBase.__name__ == 'IOBase' (Python-level wrapper class; name is bare class name)"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true

invariant io_extra94.IOBase.module:
  description: "io.IOBase.__module__ == 'io' (Python-level wrapper defined in io module, not the C-extension _IOBase)"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra94.BufferedReader.module:
  description: "io.BufferedReader.__module__ == '_io' (concrete C-extension class from _io module)"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra94.BytesIO.module:
  description: "io.BytesIO.__module__ == '_io' (concrete C-extension class from _io module)"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra94.TextIOWrapper.module:
  description: "io.TextIOWrapper.__module__ == '_io' (concrete C-extension class from _io module)"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__module__.__eq__
  args: ["_io"]
  expected: true
