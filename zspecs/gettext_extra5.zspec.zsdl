spec: gettext_extra5
version: ">=3.9"
backend: python_module(gettext)

docs: https://docs.python.org/3/library/gettext.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gettext.html — Python gettext documentation"
    - "GNU gettext manual — https://www.gnu.org/software/gettext/manual/gettext.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gettext.py"
  notes:
    - "This spec extends gettext.zspec.zsdl and gettext_extra through gettext_extra4.zspec.zsdl."
    - "gettext.zspec.zsdl covers: func_names table (gettext/ngettext/dgettext/dngettext/bindtextdomain/textdomain/find/translation/install); NullTranslations/__name__; GNUTranslations/__name__/__bases__; Catalog/__name__; gettext/ngettext passthroughs."
    - "gettext_extra covers: NullTranslations/__name__/__module__; GNUTranslations/__name__/__bases__; pgettext/npgettext/bindtextdomain/textdomain/find/translation/install names."
    - "gettext_extra2 covers: NullTranslations base is object; GNUTranslations single_base len; dgettext/dngettext/pgettext/npgettext passthroughs."
    - "gettext_extra3 covers: GNUTranslations/__module__; Catalog/__module__; dpgettext __name__/__module__; func_modules table (gettext/ngettext/dgettext/dngettext); pgettext/__module__; GNUTranslations/NullTranslations __mro__ len; dpgettext passthrough."
    - "gettext_extra4 covers: __qualname__ for gettext/ngettext/bindtextdomain/textdomain/dgettext; __qualname__ for GNUTranslations/NullTranslations/Catalog; ngettext 'item'/'items' behavioral test."
    - "This spec adds: __qualname__ checks for find/translation/install/pgettext/npgettext/dpgettext (not covered in extra4); __class__.__name__ == 'function' for module-level gettext functions; gettext('world') passthrough (new string, distinct from 'hello' in gettext.zspec); ngettext('file', 'files', 0) plural at n==0."
    - "Module-level functions defined in pure Python report __class__.__name__ == 'function'."
    - "gettext.find, gettext.translation, gettext.install are module-level functions; their __qualname__ equals their simple name."
    - "gettext.pgettext, gettext.npgettext, gettext.dpgettext are module-level functions; their __qualname__ equals their simple name."
    - "gettext.ngettext('file', 'files', 0) == 'files' — n==0 uses plural form (not singular)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for find/translation/install
# gettext_extra4 covers gettext/ngettext/bindtextdomain/textdomain/dgettext.
# New: find, translation, install, pgettext, npgettext, dpgettext.
# ---------------------------------------------------------------------------

table gettext_extra5.func_qualnames_ext:
  kind: python_call_eq
  category: functions
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [find,        "find.__qualname__.__eq__",        ["find"],        true]
    - [translation, "translation.__qualname__.__eq__", ["translation"], true]
    - [install,     "install.__qualname__.__eq__",     ["install"],     true]
    - [pgettext,    "pgettext.__qualname__.__eq__",    ["pgettext"],    true]
    - [npgettext,   "npgettext.__qualname__.__eq__",   ["npgettext"],   true]
    - [dpgettext,   "dpgettext.__qualname__.__eq__",   ["dpgettext"],   true]

# ---------------------------------------------------------------------------
# __class__.__name__ == 'function' for module-level gettext functions
# Not covered in any prior gettext spec.
# ---------------------------------------------------------------------------

table gettext_extra5.func_class_names:
  kind: python_call_eq
  category: functions
  id_prefix: fclass

  columns: [id, function, args, expected]
  rows:
    - [gettext,        "gettext.__class__.__name__.__eq__",        ["function"], true]
    - [ngettext,       "ngettext.__class__.__name__.__eq__",       ["function"], true]
    - [bindtextdomain, "bindtextdomain.__class__.__name__.__eq__", ["function"], true]
    - [textdomain,     "textdomain.__class__.__name__.__eq__",     ["function"], true]
    - [find,           "find.__class__.__name__.__eq__",           ["function"], true]

# ---------------------------------------------------------------------------
# gettext('world') passthrough — new string, distinct from 'hello' in gettext.zspec
# Not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant gettext_extra5.gettext.world_passthrough:
  description: "gettext.gettext('world') == 'world' — untranslated string returned unchanged"
  category: behavior
  kind: python_call_eq
  function: gettext
  args: ["world"]
  expected: "world"

# ---------------------------------------------------------------------------
# ngettext('file', 'files', 0) — plural at n == 0
# Prior specs cover n==1 (singular) and n==2 (plural) for 'apple'/'apples' and
# 'item'/'items'. This is the first check with n==0 and new strings 'file'/'files'.
# ---------------------------------------------------------------------------

invariant gettext_extra5.ngettext.file_zero_plural:
  description: "gettext.ngettext('file', 'files', 0) == 'files' — n==0 uses plural form"
  category: behavior
  kind: python_call_eq
  function: ngettext
  args: ["file", "files", 0]
  expected: "files"

invariant gettext_extra5.ngettext.file_singular:
  description: "gettext.ngettext('file', 'files', 1) == 'file' — n==1 uses singular form"
  category: behavior
  kind: python_call_eq
  function: ngettext
  args: ["file", "files", 1]
  expected: "file"
