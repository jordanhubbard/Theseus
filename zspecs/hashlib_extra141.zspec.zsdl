spec: hashlib_extra141
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ equality / blake2b/blake2s class identity and __module__/__qualname__ / new.__class__.__name__=='function' / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers hashlib.sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership for sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512/sha3_224/sha3_384/blake2b/blake2s/shake_128/shake_256 / algorithms_available membership / new/__qualname__/__len__()."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / sha256/sha512/sha1/md5 __module__ cross-checks."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra99."
    - "Wave 280 theme: hashlib constructor __doc__ lengths / hashlib.__spec__ attribute identity / hashlib.file_digest __doc__ length / hashlib.new __doc__ length."
    - "hashlib.sha256.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__doc__.__len__() == 66. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__doc__.__len__() == 66. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__doc__.__len__() == 66. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__doc__.__len__() == 66. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__doc__.__len__() == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__doc__.__len__() == 63. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.name.__eq__('hashlib') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.name.__len__() == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.origin.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__doc__.__len__() == 147. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__doc__.__len__() == 417. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: sha256, sha224, sha384, sha512 all have 66-char docstrings (same length). sha1 is 64 chars, md5 is 63 chars — the shorter names produce shorter docstrings."
    - "Note: file_digest has the longest docstring of any hashlib object at 417 chars — it is a pure-Python function with a detailed docstring explaining the fileobj argument."
    - "Note: hashlib.__spec__ is a ModuleSpec object (importlib.machinery.ModuleSpec), distinct from the SourceFileLoader stored in hashlib.__loader__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha256.__doc__.__class__.__name__.__eq__('str')
# hashlib.sha1.__doc__.__class__.__name__.__eq__('str')
# hashlib.md5.__doc__.__class__.__name__.__eq__('str')
# hashlib.blake2b.__doc__.__class__.__name__.__eq__('str')
# hashlib.new.__doc__.__class__.__name__.__eq__('str')
# hashlib.file_digest.__doc__.__class__.__name__.__eq__('str')
#
# Wave 280 theme: hashlib callable __doc__.__class__.__name__ identity.
#
# All callable objects in hashlib (constructors, functions) have a str __doc__.
# No prior hashlib spec anchors __doc__.__class__.__name__ for any of these
# objects under hashlibdoc141. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra141.callable_doc_class_names:
  description: "hashlib.sha256/__doc__/__class__.__name__.__eq__('str')==True / sha1/__doc__/__class__.__name__.__eq__('str')==True / md5/__doc__/__class__.__name__.__eq__('str')==True / blake2b/__doc__/__class__.__name__.__eq__('str')==True / new/__doc__/__class__.__name__.__eq__('str')==True / file_digest/__doc__/__class__.__name__.__eq__('str')==True — all hashlib callable __doc__ attributes are str objects; no prior hashlib spec anchors __doc__.__class__.__name__ for these; first hashlibdoc141 anchor"
  kind: python_call_eq
  category: doc_identity
  id_prefix: hashlibdoc141

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_doc_class,      sha256.__doc__.__class__.__name__.__eq__,      ["str"], true, "hashlib.sha256.__doc__ is a str (C builtin docstring from _hashlib)"]
    - [sha1_doc_class,        sha1.__doc__.__class__.__name__.__eq__,        ["str"], true, "hashlib.sha1.__doc__ is a str (C builtin docstring from _hashlib)"]
    - [md5_doc_class,         md5.__doc__.__class__.__name__.__eq__,         ["str"], true, "hashlib.md5.__doc__ is a str (C builtin docstring from _hashlib)"]
    - [blake2b_doc_class,     blake2b.__doc__.__class__.__name__.__eq__,     ["str"], true, "hashlib.blake2b.__doc__ is a str (C extension type docstring from _blake2)"]
    - [new_doc_class,         new.__doc__.__class__.__name__.__eq__,         ["str"], true, "hashlib.new.__doc__ is a str (pure-Python function docstring from Lib/hashlib.py)"]
    - [file_digest_doc_class, file_digest.__doc__.__class__.__name__.__eq__, ["str"], true, "hashlib.file_digest.__doc__ is a str (pure-Python function docstring from Lib/hashlib.py)"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__doc__.__len__()==66
# hashlib.sha224.__doc__.__len__()==66
# hashlib.sha384.__doc__.__len__()==66
# hashlib.sha512.__doc__.__len__()==66
# hashlib.sha1.__doc__.__len__()==64
# hashlib.md5.__doc__.__len__()==63
#
# Wave 280 theme: hashlib SHA constructor docstring lengths.
#
# sha256, sha224, sha384, sha512 all produce 66-char docstrings following the
# template 'Returns a sha<N> hash object; optionally initialized with a string'.
# sha1 is 64 chars ('Returns a sha1 hash object; optionally initialized with a
# string') and md5 is 63 chars ('Returns a md5 hash object; optionally
# initialized with a string'). No prior hashlib spec anchors these __doc__
# lengths under hashlibdoc141. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra141.sha_constructor_doc_lengths:
  description: "hashlib.sha256/__doc__/__len__()==66 / sha224/__doc__/__len__()==66 / sha384/__doc__/__len__()==66 / sha512/__doc__/__len__()==66 / sha1/__doc__/__len__()==64 / md5/__doc__/__len__()==63 — sha256/sha224/sha384/sha512 share a 66-char docstring template; sha1 is 64 chars; md5 is 63 chars (shorter algorithm name in the docstring); no prior hashlib spec anchors these lengths; first hashlibdoc141 anchor"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: hashlibdoc141

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_doc_len, sha256.__doc__.__len__, [], 66, "hashlib.sha256.__doc__ is 66 chars ('Returns a sha256 hash object; optionally initialized with a string')"]
    - [sha224_doc_len, sha224.__doc__.__len__, [], 66, "hashlib.sha224.__doc__ is 66 chars (same length as sha256; 'sha224' same char count as 'sha256')"]
    - [sha384_doc_len, sha384.__doc__.__len__, [], 66, "hashlib.sha384.__doc__ is 66 chars (same length as sha256/sha224; 'sha384' same char count)"]
    - [sha512_doc_len, sha512.__doc__.__len__, [], 66, "hashlib.sha512.__doc__ is 66 chars (same length as sha256/sha224/sha384; 'sha512' same char count)"]
    - [sha1_doc_len,   sha1.__doc__.__len__,   [], 64, "hashlib.sha1.__doc__ is 64 chars ('sha1' is 4 chars vs 6 chars for sha256/sha512, 2 chars shorter)"]
    - [md5_doc_len,    md5.__doc__.__len__,     [], 63, "hashlib.md5.__doc__ is 63 chars ('md5' is 3 chars vs 6 chars for sha256, 3 chars shorter)"]

# ---------------------------------------------------------------------------
# hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec')
# hashlib.__spec__.name.__eq__('hashlib')
# hashlib.__spec__.name.__len__()==7
# hashlib.__spec__.origin.__class__.__name__.__eq__('str')
#
# Wave 280 theme: hashlib.__spec__ attribute identity.
#
# hashlib.__spec__ is a ModuleSpec object (from importlib.machinery). Its name
# is 'hashlib' (7 chars). Its origin is the path to hashlib.py as a str.
# hashlib_extra96 anchors __spec__ as a module-level attribute; no prior hashlib
# spec anchors __spec__.__class__.__name__ or __spec__.name equality and length
# under hashlibdoc141. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra141.spec_identity:
  description: "hashlib.__spec__/__class__.__name__.__eq__('ModuleSpec')==True / __spec__.name.__eq__('hashlib')==True / __spec__.name.__len__()==7 / __spec__.origin/__class__.__name__.__eq__('str')==True — hashlib.__spec__ is a ModuleSpec from importlib.machinery; name is 'hashlib' (7 chars); origin is the file path as a str; extra96 anchors __spec__ existence; first hashlibdoc141 anchor for __spec__ attribute values"
  kind: python_call_eq
  category: module_spec
  id_prefix: hashlibdoc141

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name,        __spec__.__class__.__name__.__eq__,        ["ModuleSpec"], true, "hashlib.__spec__ is a ModuleSpec (importlib.machinery.ModuleSpec)"]
    - [spec_name_eq,           __spec__.name.__eq__,                      ["hashlib"],    true, "hashlib.__spec__.name is 'hashlib' (matches the module's __name__)"]
    - [spec_name_len,          __spec__.name.__len__,                     [],             7,    "hashlib.__spec__.name.__len__() is 7 ('hashlib' = 7 chars)"]
    - [spec_origin_class_name, __spec__.origin.__class__.__name__.__eq__, ["str"],        true, "hashlib.__spec__.origin is a str (the file path to hashlib.py)"]

# ---------------------------------------------------------------------------
# hashlib.new.__doc__.__len__()==147 — standalone
#
# hashlib.new.__doc__.__len__() is 147. hashlib.new is the unified constructor
# that dispatches to OpenSSL or fallback implementations. Its docstring explains
# the name, data, and usedforsecurity parameters. At 147 chars it is longer
# than any individual SHA constructor docstring (63-66 chars) but shorter than
# file_digest (417 chars). No prior hashlib spec anchors new.__doc__.__len__()
# under hashlibdoc141. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra141.new_doc_len_147:
  description: "hashlib.new.__doc__.__len__() == 147 — new is the unified constructor dispatching to OpenSSL or fallback impls; docstring covers name/data/usedforsecurity parameters; longer than SHA constructor docstrings (63-66 chars) but shorter than file_digest (417); no prior hashlib spec anchors new.__doc__.__len__(); first standalone under hashlibdoc141"
  category: doc_lengths
  kind: python_call_eq
  function: new.__doc__.__len__
  args: []
  expected: 147

# ---------------------------------------------------------------------------
# hashlib.file_digest.__doc__.__len__()==417 — standalone
#
# hashlib.file_digest.__doc__.__len__() is 417. file_digest is a pure-Python
# function (added in Python 3.11) that reads a fileobj and returns a hash digest.
# Its docstring is the longest of any hashlib callable at 417 chars, reflecting
# the need to explain the fileobj must be in binary mode, its seekable state,
# and the hashlib-name or callable argument. No prior hashlib spec anchors
# file_digest.__doc__.__len__() under hashlibdoc141.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra141.file_digest_doc_len_417:
  description: "hashlib.file_digest.__doc__.__len__() == 417 — file_digest (added Python 3.11) reads a binary-mode fileobj and returns a hash; its docstring is 417 chars — the longest of any hashlib callable; explains fileobj binary mode requirement, seekable state, and hashlib-name/callable argument; no prior hashlib spec anchors file_digest.__doc__.__len__(); first standalone under hashlibdoc141"
  category: doc_lengths
  kind: python_call_eq
  function: file_digest.__doc__.__len__
  args: []
  expected: 417

# ---------------------------------------------------------------------------
# hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# hashlib.__spec__.__class__.__name__ is 'ModuleSpec'. The ModuleSpec class is
# defined in importlib.machinery and describes how a module should be loaded.
# hashlib uses a SourceFileLoader (the __loader__), and the __spec__ captures
# metadata including name, origin, loader, and submodule_search_locations.
# hashlib_extra96 notes __spec__ existence at module level; no prior hashlib
# spec anchors __spec__.__class__.__name__.__eq__('ModuleSpec') as a standalone
# under hashlibdoc141. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra141.spec_class_ModuleSpec:
  description: "hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — hashlib.__spec__ is a ModuleSpec from importlib.machinery; captures loader, name, origin, and submodule_search_locations for hashlib; extra96 notes __spec__ at module level; first standalone for __spec__.__class__.__name__ under hashlibdoc141"
  category: module_spec
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__spec__.name.__eq__('hashlib') — standalone
#
# hashlib.__spec__.name is 'hashlib'. The spec name matches the module's
# __name__ attribute ('hashlib'). The ModuleSpec.name attribute is set during
# import and used by the import system to identify the module. No prior hashlib
# spec anchors __spec__.name.__eq__('hashlib') as a standalone under hashlibdoc141.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra141.spec_name_hashlib:
  description: "hashlib.__spec__.name.__eq__('hashlib') == True — ModuleSpec.name is 'hashlib', matching the module's __name__; used by the import system to identify the module; first standalone for __spec__.name equality under hashlibdoc141"
  category: module_spec
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["hashlib"]
  expected: true

