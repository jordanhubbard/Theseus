spec: inspect_extra8
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect.zspec.zsdl and prior extras."
    - "inspect_extra6 covers __name__ for FrameInfo/Traceback/BlockFinder/Parameter/Signature and ParameterKind class names."
    - "inspect_extra6 covers FrameInfo.__module__ and Parameter.empty.__class__.__name__."
    - "inspect_extra7 covers __qualname__ for Parameter/Signature/BoundArguments/FrameInfo and __module__ for BoundArguments/FrameInfo."
    - "inspect_signature covers BoundArguments.__name__/__module__, Signature.__module__, Parameter.__module__."
    - "NOT yet covered: Traceback.__module__, Traceback.__qualname__."
    - "NOT yet covered: BlockFinder.__module__, BlockFinder.__qualname__."
    - "NOT yet covered: isroutine.__name__, isroutine.__module__, isroutine.__qualname__."
    - "NOT yet covered: iscoroutinefunction.__qualname__, isgeneratorfunction.__qualname__."
    - "inspect.Traceback.__module__ == 'inspect' — namedtuple-like class defined in inspect."
    - "inspect.Traceback.__qualname__ == 'Traceback' — top-level name in inspect module."
    - "inspect.BlockFinder.__module__ == 'inspect' — helper class defined in inspect."
    - "inspect.BlockFinder.__qualname__ == 'BlockFinder' — top-level name in inspect module."
    - "inspect.isroutine.__name__ == 'isroutine' — module-level predicate function."
    - "inspect.isroutine.__module__ == 'inspect'."
    - "inspect.isroutine.__qualname__ == 'isroutine'."
    - "inspect.iscoroutinefunction.__qualname__ == 'iscoroutinefunction'."
    - "inspect.isgeneratorfunction.__qualname__ == 'isgeneratorfunction'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Traceback and BlockFinder — __module__ checks
#
# inspect_extra6 covers FrameInfo.__module__ but not Traceback or BlockFinder.
# inspect_extra7 covers FrameInfo.__module__ again and BoundArguments.__module__.
# Neither covers Traceback.__module__ or BlockFinder.__module__.
# ---------------------------------------------------------------------------

invariant inspect_extra8.Traceback.module:
  description: "inspect.Traceback.__module__ == 'inspect'"
  category: class_modules
  kind: python_call_eq
  function: Traceback.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra8.BlockFinder.module:
  description: "inspect.BlockFinder.__module__ == 'inspect'"
  category: class_modules
  kind: python_call_eq
  function: BlockFinder.__module__.__eq__
  args: ["inspect"]
  expected: true

# ---------------------------------------------------------------------------
# Traceback and BlockFinder — __qualname__ checks
#
# inspect_extra7 covers __qualname__ for Parameter/Signature/BoundArguments/FrameInfo
# but not for Traceback or BlockFinder. Both are top-level names so qualname == name.
# ---------------------------------------------------------------------------

invariant inspect_extra8.Traceback.qualname:
  description: "inspect.Traceback.__qualname__ == 'Traceback'"
  category: class_qualnames
  kind: python_call_eq
  function: Traceback.__qualname__.__eq__
  args: ["Traceback"]
  expected: true

invariant inspect_extra8.BlockFinder.qualname:
  description: "inspect.BlockFinder.__qualname__ == 'BlockFinder'"
  category: class_qualnames
  kind: python_call_eq
  function: BlockFinder.__qualname__.__eq__
  args: ["BlockFinder"]
  expected: true

# ---------------------------------------------------------------------------
# isroutine — __name__, __module__, __qualname__
#
# inspect.isroutine is a module-level predicate that returns True for
# functions, lambdas, methods, builtins, and other callable objects
# that are considered routines. No prior spec covers isroutine identity.
# ---------------------------------------------------------------------------

invariant inspect_extra8.isroutine.name:
  description: "inspect.isroutine.__name__ == 'isroutine'"
  category: function_names
  kind: python_call_eq
  function: isroutine.__name__.__eq__
  args: ["isroutine"]
  expected: true

invariant inspect_extra8.isroutine.module:
  description: "inspect.isroutine.__module__ == 'inspect'"
  category: function_modules
  kind: python_call_eq
  function: isroutine.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra8.isroutine.qualname:
  description: "inspect.isroutine.__qualname__ == 'isroutine'"
  category: function_qualnames
  kind: python_call_eq
  function: isroutine.__qualname__.__eq__
  args: ["isroutine"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for predicate functions not covered by inspect_extra2
#
# inspect_extra2 covers: isfunction/ismethod/isclass/ismodule/isbuiltin qualnames.
# NOT covered: iscoroutinefunction, isgeneratorfunction.
# ---------------------------------------------------------------------------

table inspect_extra8.predicate_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [iscoroutinefunction,  iscoroutinefunction.__qualname__.__eq__,  ["iscoroutinefunction"],  true]
    - [isgeneratorfunction,  isgeneratorfunction.__qualname__.__eq__,  ["isgeneratorfunction"],  true]

# ---------------------------------------------------------------------------
# isroutine behavioral check — known true cases
#
# isroutine(len) should be True because len is a built-in function.
# isroutine(isroutine) should be True because isroutine is a Python function.
# No prior spec tests isroutine predicate behavior.
# ---------------------------------------------------------------------------

invariant inspect_extra8.isroutine.len_is_routine:
  description: "inspect.isroutine(len) == True — len is a built-in function (routine)"
  category: behavior
  kind: python_call_eq
  function: isroutine
  args: [len]
  expected: true

invariant inspect_extra8.isroutine.isroutine_is_routine:
  description: "inspect.isroutine(isroutine) == True — Python function is a routine"
  category: behavior
  kind: python_call_eq
  function: isroutine
  args: [isroutine]
  expected: true
