spec: socket_extra244
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec covers socket.AF_UNIX constant and socket.SHUT_RDWR/SHUT_RD/SHUT_WR constants; it does NOT duplicate invariants already present in socket.zspec.zsdl or earlier extras."
    - "socket.AF_UNIX is an AddressFamily IntEnum member with value 1 on macOS (POSIX standard)."
    - "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' — AF_UNIX is an IntEnum member."
    - "socket.AF_UNIX.__class__.__module__ == 'socket' — AddressFamily is defined in the socket module."
    - "socket.AF_UNIX.value == 1 — AF_UNIX value is 1 on macOS/POSIX (POSIX constant AF_UNIX = 1)."
    - "socket.AF_UNIX.name == 'AF_UNIX' — the enum member name."
    - "socket.SHUT_RD == 0 — half-close the read side of the socket."
    - "socket.SHUT_WR == 1 — half-close the write side of the socket."
    - "socket.SHUT_RDWR == 2 — close both directions of the socket."
    - "SHUT constants are plain ints on Python 3.14.3 macOS (not an enum)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "socket raises OSError (and subclasses) for I/O failures. Constant attribute accesses are stateless and never raise."
  stderr: "null"
  stickiness: "N/A — all tested invariants are module-level constant attribute accesses."
  codes: {}

# ---------------------------------------------------------------------------
# socket.AF_UNIX — AddressFamily enum identity
# AF_UNIX is an IntEnum member; value == 1 on macOS (POSIX standard)
# ---------------------------------------------------------------------------

table socket_extra244.AF_UNIX.identity:
  kind: python_call_eq
  category: af_unix
  id_prefix: socket244unix

  columns: [id, function, args, expected]
  rows:
    - [class_name,    AF_UNIX.__class__.__name__.__eq__,   ["AddressFamily"], true]
    - [class_module,  AF_UNIX.__class__.__module__.__eq__,  ["socket"],        true]
    - [value_eq_1,    AF_UNIX.value.__eq__,                 [1],               true]
    - [name_eq,       AF_UNIX.name.__eq__,                  ["AF_UNIX"],       true]

# ---------------------------------------------------------------------------
# socket.SHUT_* constants — integer values
# SHUT_RD==0, SHUT_WR==1, SHUT_RDWR==2 — plain int constants on macOS Python 3.14.3
# ---------------------------------------------------------------------------

table socket_extra244.SHUT.values:
  kind: python_call_eq
  category: shut_constants
  id_prefix: socket244shut

  columns: [id, function, args, expected]
  rows:
    - [shut_rd_eq_0,    SHUT_RD.__eq__,    [0], true]
    - [shut_wr_eq_1,    SHUT_WR.__eq__,    [1], true]
    - [shut_rdwr_eq_2,  SHUT_RDWR.__eq__,  [2], true]

# ---------------------------------------------------------------------------
# Standalone invariants: AF_UNIX identity
# ---------------------------------------------------------------------------

invariant socket_extra244.AF_UNIX.class_name:
  description: "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' — AF_UNIX is an IntEnum member of AddressFamily"
  category: af_unix
  kind: python_call_eq
  function: AF_UNIX.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra244.AF_UNIX.class_module:
  description: "socket.AF_UNIX.__class__.__module__ == 'socket' — AddressFamily is defined in the socket module"
  category: af_unix
  kind: python_call_eq
  function: AF_UNIX.__class__.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra244.AF_UNIX.value_eq_1:
  description: "socket.AF_UNIX.value == 1 — AF_UNIX has value 1 on macOS/POSIX (POSIX constant AF_UNIX = 1)"
  category: af_unix
  kind: python_call_eq
  function: AF_UNIX.value.__eq__
  args: [1]
  expected: true

invariant socket_extra244.AF_UNIX.name_eq:
  description: "socket.AF_UNIX.name == 'AF_UNIX' — the enum member name attribute"
  category: af_unix
  kind: python_call_eq
  function: AF_UNIX.name.__eq__
  args: ["AF_UNIX"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants: SHUT constants
# ---------------------------------------------------------------------------

invariant socket_extra244.SHUT_RD.value_eq_0:
  description: "socket.SHUT_RD == 0 — half-close the read side of the socket"
  category: shut_constants
  kind: python_call_eq
  function: SHUT_RD.__eq__
  args: [0]
  expected: true

invariant socket_extra244.SHUT_WR.value_eq_1:
  description: "socket.SHUT_WR == 1 — half-close the write side of the socket"
  category: shut_constants
  kind: python_call_eq
  function: SHUT_WR.__eq__
  args: [1]
  expected: true

invariant socket_extra244.SHUT_RDWR.value_eq_2:
  description: "socket.SHUT_RDWR == 2 — close both directions of the socket"
  category: shut_constants
  kind: python_call_eq
  function: SHUT_RDWR.__eq__
  args: [2]
  expected: true

invariant socket_extra244.SHUT_RDWR.class_name:
  description: "socket.SHUT_RDWR.__class__.__name__ == 'int' — SHUT constants are plain ints on macOS Python 3.14.3"
  category: shut_constants
  kind: python_call_eq
  function: SHUT_RDWR.__class__.__name__.__eq__
  args: ["int"]
  expected: true
