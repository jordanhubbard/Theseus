spec: uuid_extra2611
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 621 theme: __init_subclass__, __subclasshook__, and __class_getitem__ dict-presence checks."
    - "uuid.UUID does NOT define __init_subclass__ in its own __dict__ — inherits from object."
    - "uuid.UUID does NOT define __subclasshook__ in its own __dict__ — not an ABC; ABCMeta hook irrelevant."
    - "uuid.UUID does NOT define __class_getitem__ in its own __dict__ — no PEP 585 generic alias support."
    - "uuid.SafeUUID is an IntEnum subclass; its metaclass is EnumType. It does NOT define any of the three dunder methods in its own __dict__."
    - "enum.EnumType (the metaclass) also does NOT define __class_getitem__ in its own __dict__ (verified: False)."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# uuid.UUID — __init_subclass__, __subclasshook__, __class_getitem__
# ---------------------------------------------------------------------------

table uuid_extra2611.uuid_class_init_subclass:
  description: "__init_subclass__ is absent from uuid.UUID.__dict__ — inherited from object, not defined on UUID itself"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2611

  columns: [id, function, args, expected]
  rows:
    - ["uu2611001", "uuid.UUID.__dict__.__contains__", ["__init_subclass__"], false]

table uuid_extra2611.uuid_class_subclasshook:
  description: "__subclasshook__ is absent from uuid.UUID.__dict__ — UUID is not an ABC; hook not defined"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2611

  columns: [id, function, args, expected]
  rows:
    - ["uu2611002", "uuid.UUID.__dict__.__contains__", ["__subclasshook__"], false]

table uuid_extra2611.uuid_class_class_getitem:
  description: "__class_getitem__ is absent from uuid.UUID.__dict__ — no PEP 585 generic alias support on UUID"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2611

  columns: [id, function, args, expected]
  rows:
    - ["uu2611003", "uuid.UUID.__dict__.__contains__", ["__class_getitem__"], false]

table uuid_extra2611.safeuuid_dict_presence:
  description: "uuid.SafeUUID (IntEnum subclass) does not define __init_subclass__, __subclasshook__, or __class_getitem__ in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2611

  columns: [id, function, args, expected]
  rows:
    - ["uu2611004", "uuid.SafeUUID.__dict__.__contains__", ["__init_subclass__"],  false]
    - ["uu2611005", "uuid.SafeUUID.__dict__.__contains__", ["__subclasshook__"],   false]
    - ["uu2611006", "uuid.SafeUUID.__dict__.__contains__", ["__class_getitem__"],  false]
