spec: textwrap_extra18
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl and prior extras through textwrap_extra17.zspec.zsdl."
    - "textwrap_extra17 covers: TextWrapper.__name__; TextWrapper.__module__; TextWrapper.__bases__[0].__name__; wrap/fill/shorten/indent/dedent __qualname__; two tables for TextWrapper identity and function qualnames."
    - "textwrap_extra16 covers: wrap('hello world',5)==['hello','world']; fill/shorten/indent/dedent edge cases."
    - "textwrap_extra14 covers: TextWrapper().__qualname__; wrap/fill at various widths; dedent/indent; shorten."
    - "NOT yet covered (now covered here): textwrap.wrap.__module__ == 'textwrap' — standalone module check for wrap."
    - "NOT yet covered (now covered here): textwrap.fill.__module__ == 'textwrap' — standalone module check for fill."
    - "NOT yet covered (now covered here): textwrap.dedent.__module__ == 'textwrap' — standalone module check for dedent."
    - "NOT yet covered (now covered here): textwrap.indent.__module__ == 'textwrap' — standalone module check for indent."
    - "NOT yet covered (now covered here): textwrap.shorten.__module__ == 'textwrap' — standalone module check for shorten."
    - "NOT yet covered (now covered here): textwrap.wrap.__name__ == 'wrap' — __name__ attribute (distinct from __qualname__) for wrap."
    - "NOT yet covered (now covered here): textwrap.fill.__name__ == 'fill' — __name__ attribute for fill."
    - "NOT yet covered (now covered here): table of function __module__ attributes for wrap, fill, dedent, indent, shorten."
    - "textwrap_extra17 covers __qualname__ for these functions; __module__ and __name__ are distinct attributes not yet covered in standalone invariants."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __module__ attributes
#
# textwrap_extra17 covers __qualname__ for wrap, fill, shorten, indent, dedent.
# No prior spec verifies __module__ for these functions as standalone invariants.
# All are defined in the textwrap module; __module__ == 'textwrap' for each.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant textwrap_extra18.wrap.module:
  description: "textwrap.wrap.__module__ == 'textwrap' — wrap is defined in the textwrap module"
  category: function_identity
  kind: python_call_eq
  function: wrap.__module__.__eq__
  args: ["textwrap"]
  expected: true

invariant textwrap_extra18.fill.module:
  description: "textwrap.fill.__module__ == 'textwrap' — fill is defined in the textwrap module"
  category: function_identity
  kind: python_call_eq
  function: fill.__module__.__eq__
  args: ["textwrap"]
  expected: true

invariant textwrap_extra18.dedent.module:
  description: "textwrap.dedent.__module__ == 'textwrap' — dedent is defined in the textwrap module"
  category: function_identity
  kind: python_call_eq
  function: dedent.__module__.__eq__
  args: ["textwrap"]
  expected: true

invariant textwrap_extra18.indent.module:
  description: "textwrap.indent.__module__ == 'textwrap' — indent is defined in the textwrap module"
  category: function_identity
  kind: python_call_eq
  function: indent.__module__.__eq__
  args: ["textwrap"]
  expected: true

invariant textwrap_extra18.shorten.module:
  description: "textwrap.shorten.__module__ == 'textwrap' — shorten is defined in the textwrap module"
  category: function_identity
  kind: python_call_eq
  function: shorten.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function __name__ attributes — wrap and fill
#
# textwrap_extra17 covers __qualname__ (== __name__ for module-level functions).
# __name__ is a distinct attribute; anchored here in the extra18 namespace.
# Verified: wrap.__name__ == 'wrap'; fill.__name__ == 'fill'.
# ---------------------------------------------------------------------------

invariant textwrap_extra18.wrap.name:
  description: "textwrap.wrap.__name__ == 'wrap' — __name__ attribute of the wrap function (extra18 namespace)"
  category: function_identity
  kind: python_call_eq
  function: wrap.__name__.__eq__
  args: ["wrap"]
  expected: true

invariant textwrap_extra18.fill.name:
  description: "textwrap.fill.__name__ == 'fill' — __name__ attribute of the fill function (extra18 namespace)"
  category: function_identity
  kind: python_call_eq
  function: fill.__name__.__eq__
  args: ["fill"]
  expected: true

# ---------------------------------------------------------------------------
# Table: function __module__ attributes — wrap, fill, dedent, indent, shorten
#
# Groups all five __module__ checks in one indexed table.
# No prior table covers textwrap function __module__ attributes.
# ---------------------------------------------------------------------------

table textwrap_extra18.function_modules:
  description: "textwrap module-level function __module__ identity — all five public functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: fm18

  columns: [id, function, args, expected]
  rows:
    - [wrap,    wrap.__module__.__eq__,    ["textwrap"], true]
    - [fill,    fill.__module__.__eq__,    ["textwrap"], true]
    - [dedent,  dedent.__module__.__eq__,  ["textwrap"], true]
    - [indent,  indent.__module__.__eq__,  ["textwrap"], true]
    - [shorten, shorten.__module__.__eq__, ["textwrap"], true]
