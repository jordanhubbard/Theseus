spec: io_extra2386
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "Wave 2386 (io_extra2386): __str__ and __repr__ implementation type classification for io C types."
    - "All io classes tested are C types defined in _io; their __repr__ and __str__ slots are implemented as wrapper_descriptor objects."
    - "wrapper_descriptor is the CPython type for slot wrappers that adapt C-level slots (tp_repr, tp_str) into Python-visible descriptors."
    - "A result of 'wrapper_descriptor' for .__repr__.__class__.__name__ confirms the method is a C slot wrapper, not a Python function."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase are abstract base classes defined in _io."
    - "io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.TextIOWrapper are concrete C types."
    - "None of the io C types define __repr__ or __str__ as Python functions; all inherit the C slot wrapper from object or override at the C level."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# io.IOBase — __repr__ and __str__ implementation type
# ---------------------------------------------------------------------------

table io_extra2386.iobase_str_repr:
  description: "io.IOBase.__repr__.__class__.__name__ and io.IOBase.__str__.__class__.__name__ — both are 'wrapper_descriptor' because IOBase is a C type defined in _io and its __repr__/__str__ slots are C-level slot wrappers adapted from tp_repr/tp_str"
  kind: python_call_eq
  category: classnames
  id_prefix: io2386

  columns: [id, function, args, expected]
  rows:
    - ["io2386001", "io.IOBase.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["io2386002", "io.IOBase.__str__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]

