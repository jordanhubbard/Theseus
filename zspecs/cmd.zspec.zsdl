spec: cmd
version: ">=3.0"
backend: python_module(cmd)

docs: https://docs.python.org/3/library/cmd.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/cmd.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "cmd source: Lib/cmd.py (PSF; source inspection permitted)"
  not_derived_from:
    - "cmd source: internal cmdloop and completion implementation"
  notes:
    - "cmd.Cmd provides a framework for building line-oriented command interpreters."
    - "Subclasses implement commands as do_<name> methods; help_<name> provides help text."
    - "Cmd().prompt defaults to '(Cmd) ' — subclasses typically override this."
    - "Cmd().use_rawinput is 1 (truthy) — uses input() rather than sys.stdout.write/sys.stdin.readline."
    - "Cmd().cmdqueue is [] — commands can be pre-loaded into this list for batch processing."
    - "Cmd().intro is None — if set to a string, it is printed when cmdloop() starts."
    - "Cmd().ruler is '=' — used to draw separator lines under help section headers."
    - "IDENTCHARS contains all ASCII letters, digits, and underscore — used to split command names."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name metadata
# ---------------------------------------------------------------------------

invariant cmd.cmd_class_name:
  description: "cmd.Cmd.__name__ == 'Cmd'"
  category: class_names
  kind: python_call_eq
  function: Cmd.__name__.__eq__
  args: ["Cmd"]
  expected: true

# ---------------------------------------------------------------------------
# Module membership
# ---------------------------------------------------------------------------

invariant cmd.cmd_module:
  description: "cmd.Cmd.__module__ == 'cmd'"
  category: class_names
  kind: python_call_eq
  function: Cmd.__module__.__eq__
  args: ["cmd"]
  expected: true

# ---------------------------------------------------------------------------
# Cmd instance defaults
# ---------------------------------------------------------------------------

invariant cmd.default_prompt:
  description: "cmd.Cmd().prompt == '(Cmd) ' — default interactive prompt with trailing space"
  category: instance_attrs
  kind: python_call_eq
  function: Cmd
  args: []
  method: prompt
  expected: "(Cmd) "

invariant cmd.default_intro:
  description: "cmd.Cmd().intro is None — no intro message by default"
  category: instance_attrs
  kind: python_call_eq
  function: Cmd
  args: []
  method: intro
  expected: null

invariant cmd.default_use_rawinput:
  description: "cmd.Cmd().use_rawinput == 1 — uses input() by default"
  category: instance_attrs
  kind: python_call_eq
  function: Cmd
  args: []
  method: use_rawinput.__eq__
  method_args: [1]
  expected: true

invariant cmd.default_cmdqueue:
  description: "cmd.Cmd().cmdqueue == [] — command queue is empty on construction"
  category: instance_attrs
  kind: python_call_eq
  function: Cmd
  args: []
  method: cmdqueue.__eq__
  method_args: [[]]
  expected: true

invariant cmd.default_ruler:
  description: "cmd.Cmd().ruler == '=' — ruler character for help section separators"
  category: instance_attrs
  kind: python_call_eq
  function: Cmd
  args: []
  method: ruler.__eq__
  method_args: ["="]
  expected: true

invariant cmd.default_doc_header:
  description: "cmd.Cmd().doc_header == 'Documented commands (type help <topic>):'"
  category: instance_attrs
  kind: python_call_eq
  function: Cmd
  args: []
  method: doc_header.__eq__
  method_args: ["Documented commands (type help <topic>):"]
  expected: true

invariant cmd.default_misc_header:
  description: "cmd.Cmd().misc_header == 'Miscellaneous help topics:'"
  category: instance_attrs
  kind: python_call_eq
  function: Cmd
  args: []
  method: misc_header.__eq__
  method_args: ["Miscellaneous help topics:"]
  expected: true

invariant cmd.default_undoc_header:
  description: "cmd.Cmd().undoc_header == 'Undocumented commands:'"
  category: instance_attrs
  kind: python_call_eq
  function: Cmd
  args: []
  method: undoc_header.__eq__
  method_args: ["Undocumented commands:"]
  expected: true

# ---------------------------------------------------------------------------
# IDENTCHARS module constant — contains letters, digits, and underscore
# ---------------------------------------------------------------------------

invariant cmd.identchars_has_a:
  description: "cmd.IDENTCHARS contains 'a' — all lowercase letters are valid identifier chars"
  category: module_constants
  kind: python_call_eq
  function: IDENTCHARS.__contains__
  args: ["a"]
  expected: true

invariant cmd.identchars_has_upper:
  description: "cmd.IDENTCHARS contains 'A' — all uppercase letters are valid identifier chars"
  category: module_constants
  kind: python_call_eq
  function: IDENTCHARS.__contains__
  args: ["A"]
  expected: true

invariant cmd.identchars_has_digit:
  description: "cmd.IDENTCHARS contains '0' — digits are valid identifier chars"
  category: module_constants
  kind: python_call_eq
  function: IDENTCHARS.__contains__
  args: ["0"]
  expected: true

invariant cmd.identchars_has_underscore:
  description: "cmd.IDENTCHARS contains '_' — underscore is a valid identifier char"
  category: module_constants
  kind: python_call_eq
  function: IDENTCHARS.__contains__
  args: ["_"]
  expected: true
