spec: threading_extra259
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading.Semaphore and threading.BoundedSemaphore class identity — name, module, bases; acquire/release/__enter__/__exit__ qualnames."
    - "threading.Semaphore.__name__ == 'Semaphore' — Python class name. Verified with Python 3.14.4."
    - "threading.Semaphore.__module__ == 'threading' — defined in threading. Verified with Python 3.14.4."
    - "threading.Semaphore.__bases__[0].__name__ == 'object' — Semaphore inherits directly from object. Verified with Python 3.14.4."
    - "threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' — acquire method qualname. Verified with Python 3.14.4."
    - "threading.Semaphore.release.__qualname__ == 'Semaphore.release' — release method qualname. Verified with Python 3.14.4."
    - "threading.Semaphore.__enter__.__qualname__ == 'Semaphore.acquire' — __enter__ is an alias for acquire (context manager protocol). Verified with Python 3.14.4."
    - "threading.Semaphore.__exit__.__qualname__ == 'Semaphore.__exit__' — __exit__ is a distinct method. Verified with Python 3.14.4."
    - "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' — Python class name. Verified with Python 3.14.4."
    - "threading.BoundedSemaphore.__module__ == 'threading' — defined in threading. Verified with Python 3.14.4."
    - "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore inherits from Semaphore. Verified with Python 3.14.4."
    - "threading.BoundedSemaphore.release.__qualname__ == 'BoundedSemaphore.release' — BoundedSemaphore overrides release to enforce the upper bound. Verified with Python 3.14.4."
    - "threading.BoundedSemaphore.acquire.__qualname__ == 'Semaphore.acquire' — BoundedSemaphore inherits acquire from Semaphore without override. Verified with Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Semaphore class identity contracts
#
# threading.Semaphore.__name__              == 'Semaphore'
# threading.Semaphore.__module__            == 'threading'
# threading.Semaphore.__bases__[0].__name__ == 'object'
# threading.Semaphore.__qualname__          == 'Semaphore'
# threading.Semaphore.acquire.__qualname__  == 'Semaphore.acquire'
#
# Semaphore is a Python class implementing a counting semaphore. New to extra259.
# ---------------------------------------------------------------------------

table threading_extra259.semaphore_identity:
  description: "threading.Semaphore name, module, base, qualname, acquire qualname contracts; new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: thse259

  columns: [id, function, args, expected, description]
  rows:
    - [sem_name_eq,
       Semaphore.__name__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__.__eq__('Semaphore') == True — Python class name; new to extra259"]
    - [sem_module_eq,
       Semaphore.__module__.__eq__,
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — defined in threading; new to extra259"]
    - [sem_base_name_eq,
       "Semaphore.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Semaphore.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra259"]
    - [sem_qualname_eq,
       Semaphore.__qualname__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__qualname__.__eq__('Semaphore') == True — top-level class; qualname equals name; new to extra259"]
    - [sem_acquire_qualname_eq,
       Semaphore.acquire.__qualname__.__eq__,
       ["Semaphore.acquire"],
       true,
       "threading.Semaphore.acquire.__qualname__.__eq__('Semaphore.acquire') == True — acquire method qualname; new to extra259"]

# ---------------------------------------------------------------------------
# Table 2: threading.Semaphore release, __enter__, __exit__ qualname contracts
#
# threading.Semaphore.release.__qualname__  == 'Semaphore.release'
# threading.Semaphore.__enter__.__qualname__ == 'Semaphore.acquire'
# threading.Semaphore.__exit__.__qualname__  == 'Semaphore.__exit__'
# threading.Semaphore.acquire.__name__       == 'acquire'
# threading.Semaphore.release.__name__       == 'release'
#
# __enter__ is an alias for acquire (context manager protocol). New to extra259.
# ---------------------------------------------------------------------------

table threading_extra259.semaphore_methods:
  description: "threading.Semaphore release, __enter__, __exit__ qualname and name contracts; new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: thsm259

  columns: [id, function, args, expected, description]
  rows:
    - [sem_release_qualname_eq,
       Semaphore.release.__qualname__.__eq__,
       ["Semaphore.release"],
       true,
       "threading.Semaphore.release.__qualname__.__eq__('Semaphore.release') == True — release method qualname; new to extra259"]
    - [sem_enter_qualname_eq,
       Semaphore.__enter__.__qualname__.__eq__,
       ["Semaphore.acquire"],
       true,
       "threading.Semaphore.__enter__.__qualname__.__eq__('Semaphore.acquire') == True — __enter__ is alias for acquire; new to extra259"]
    - [sem_exit_qualname_eq,
       Semaphore.__exit__.__qualname__.__eq__,
       ["Semaphore.__exit__"],
       true,
       "threading.Semaphore.__exit__.__qualname__.__eq__('Semaphore.__exit__') == True — __exit__ is a distinct method; new to extra259"]
    - [sem_acquire_name_eq,
       Semaphore.acquire.__name__.__eq__,
       ["acquire"],
       true,
       "threading.Semaphore.acquire.__name__.__eq__('acquire') == True — acquire method name; new to extra259"]
    - [sem_release_name_eq,
       Semaphore.release.__name__.__eq__,
       ["release"],
       true,
       "threading.Semaphore.release.__name__.__eq__('release') == True — release method name; new to extra259"]

# ---------------------------------------------------------------------------
# Table 3: threading.BoundedSemaphore class identity contracts
#
# threading.BoundedSemaphore.__name__              == 'BoundedSemaphore'
# threading.BoundedSemaphore.__module__            == 'threading'
# threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'
# threading.BoundedSemaphore.__qualname__          == 'BoundedSemaphore'
# threading.BoundedSemaphore.release.__qualname__  == 'BoundedSemaphore.release'
#
# BoundedSemaphore subclasses Semaphore and overrides release. New to extra259.
# ---------------------------------------------------------------------------

table threading_extra259.boundedsemaphore_identity:
  description: "threading.BoundedSemaphore name, module, base, qualname, release qualname contracts; new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: thbs259

  columns: [id, function, args, expected, description]
  rows:
    - [bsem_name_eq,
       BoundedSemaphore.__name__.__eq__,
       ["BoundedSemaphore"],
       true,
       "threading.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') == True — Python class name; new to extra259"]
    - [bsem_module_eq,
       BoundedSemaphore.__module__.__eq__,
       ["threading"],
       true,
       "threading.BoundedSemaphore.__module__.__eq__('threading') == True — defined in threading; new to extra259"]
    - [bsem_base_name_eq,
       "BoundedSemaphore.__bases__[0].__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') == True — inherits from Semaphore; new to extra259"]
    - [bsem_qualname_eq,
       BoundedSemaphore.__qualname__.__eq__,
       ["BoundedSemaphore"],
       true,
       "threading.BoundedSemaphore.__qualname__.__eq__('BoundedSemaphore') == True — top-level class; qualname equals name; new to extra259"]
    - [bsem_release_qualname_eq,
       BoundedSemaphore.release.__qualname__.__eq__,
       ["BoundedSemaphore.release"],
       true,
       "threading.BoundedSemaphore.release.__qualname__.__eq__('BoundedSemaphore.release') == True — BoundedSemaphore overrides release; new to extra259"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra259
# ---------------------------------------------------------------------------

invariant threading_extra259.semaphore.name_eq:
  description: "threading.Semaphore.__name__ == 'Semaphore' — Python class name; new to extra259"
  category: identity
  kind: python_call_eq
  function: Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra259.semaphore.module_eq:
  description: "threading.Semaphore.__module__ == 'threading' — defined in threading; new to extra259"
  category: identity
  kind: python_call_eq
  function: Semaphore.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra259.semaphore.base_is_object:
  description: "threading.Semaphore.__bases__[0].__name__ == 'object' — inherits directly from object; new to extra259"
  category: identity
  kind: python_call_eq
  function: "Semaphore.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra259.semaphore.acquire_qualname:
  description: "threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' — acquire method qualname; new to extra259"
  category: identity
  kind: python_call_eq
  function: Semaphore.acquire.__qualname__.__eq__
  args: ["Semaphore.acquire"]
  expected: true

invariant threading_extra259.semaphore.release_qualname:
  description: "threading.Semaphore.release.__qualname__ == 'Semaphore.release' — release method qualname; new to extra259"
  category: identity
  kind: python_call_eq
  function: Semaphore.release.__qualname__.__eq__
  args: ["Semaphore.release"]
  expected: true

invariant threading_extra259.semaphore.enter_is_acquire:
  description: "threading.Semaphore.__enter__.__qualname__ == 'Semaphore.acquire' — __enter__ is alias for acquire; new to extra259"
  category: identity
  kind: python_call_eq
  function: Semaphore.__enter__.__qualname__.__eq__
  args: ["Semaphore.acquire"]
  expected: true

invariant threading_extra259.semaphore.exit_qualname:
  description: "threading.Semaphore.__exit__.__qualname__ == 'Semaphore.__exit__' — __exit__ is a distinct method; new to extra259"
  category: identity
  kind: python_call_eq
  function: Semaphore.__exit__.__qualname__.__eq__
  args: ["Semaphore.__exit__"]
  expected: true

invariant threading_extra259.boundedsemaphore.name_eq:
  description: "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' — Python class name; new to extra259"
  category: identity
  kind: python_call_eq
  function: BoundedSemaphore.__name__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

invariant threading_extra259.boundedsemaphore.module_eq:
  description: "threading.BoundedSemaphore.__module__ == 'threading' — defined in threading; new to extra259"
  category: identity
  kind: python_call_eq
  function: BoundedSemaphore.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra259.boundedsemaphore.base_is_semaphore:
  description: "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — inherits from Semaphore; new to extra259"
  category: identity
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

invariant threading_extra259.boundedsemaphore.release_qualname:
  description: "threading.BoundedSemaphore.release.__qualname__ == 'BoundedSemaphore.release' — BoundedSemaphore overrides release; new to extra259"
  category: identity
  kind: python_call_eq
  function: BoundedSemaphore.release.__qualname__.__eq__
  args: ["BoundedSemaphore.release"]
  expected: true

invariant threading_extra259.boundedsemaphore.acquire_inherits_from_semaphore:
  description: "threading.BoundedSemaphore.acquire.__qualname__ == 'Semaphore.acquire' — BoundedSemaphore inherits acquire from Semaphore without override; new to extra259"
  category: identity
  kind: python_call_eq
  function: BoundedSemaphore.acquire.__qualname__.__eq__
  args: ["Semaphore.acquire"]
  expected: true
