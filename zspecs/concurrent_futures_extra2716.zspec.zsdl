  rows:
    - ["cf2716004", "concurrent.futures.Future.__dict__.__contains__",              ["__pos__"], false]
    - ["cf2716005", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__pos__"], false]
    - ["cf2716006", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__pos__"], false]

# ---------------------------------------------------------------------------
