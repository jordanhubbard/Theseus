  rows:
    - ["cf2716007", "concurrent.futures.Future.__dict__.__contains__",              ["__abs__"], false]
    - ["cf2716008", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__abs__"], false]
    - ["cf2716009", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__abs__"], false]

# ---------------------------------------------------------------------------
# Table 4: Executor base class __neg__/__pos__/__abs__ checks
#
# Wave 628 theme: concurrent.futures.Executor is the abstract base class for
# ThreadPoolExecutor and ProcessPoolExecutor. It also does not define any
# unary arithmetic operator protocol in its own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2716.executor_base_unary:
  description: "concurrent.futures.Executor __neg__/__pos__/__abs__ dict-presence checks — abstract base class also defines none"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2716

  columns: [id, function, args, expected]
  rows:
    - ["cf2716010", "concurrent.futures.Executor.__dict__.__contains__", ["__neg__"], false]
    - ["cf2716011", "concurrent.futures.Executor.__dict__.__contains__", ["__pos__"], false]
    - ["cf2716012", "concurrent.futures.Executor.__dict__.__contains__", ["__abs__"], false]
