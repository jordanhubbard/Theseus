spec: concurrent_futures_extra2716
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 628 (_extra2716): __neg__, __pos__, __abs__ dict-presence checks (unary arithmetic operators)."
    - "concurrent.futures types (Future, ThreadPoolExecutor, ProcessPoolExecutor) are concurrency primitives, not numeric types."
    - "None of these types define unary minus, unary plus, or absolute value protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __neg__ dict-presence checks
#
# Wave 628 theme: concurrent.futures executor and future types do not
# implement the unary minus operator. __neg__ does not appear in any of
# these classes' own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2716.neg_protocol:
  description: "concurrent.futures types __neg__ dict-presence checks — none define unary minus in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2716

  columns: [id, function, args, expected]
  rows:
    - ["cf2716001", "concurrent.futures.Future.__dict__.__contains__",              ["__neg__"], false]
    - ["cf2716002", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__neg__"], false]
    - ["cf2716003", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__neg__"], false]

# ---------------------------------------------------------------------------
