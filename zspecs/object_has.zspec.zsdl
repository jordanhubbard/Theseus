spec: object_has
version: ">=1.0.2"
backend: node(object-has)

docs: https://www.npmjs.com/package/object-has

provenance:
  derived_from:
    - "object-has README — https://www.npmjs.com/package/object-has"
    - "Test vectors verified with object-has via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "object-has source"
  notes:
    - "object-has is an npm package. Install: npm install object-has"
    - "Returns true if the object has the given own property."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table object_has.check:
  kind: node_module_call_eq
  function: ~
  category: object
  id_prefix: objha

  columns: [id, args, expected]
  rows:
    - [has_key,    [{"a": 1}, "a"],        true]
    - [missing,    [{"a": 1}, "b"],        false]
    - [nested,     [{"a": {"b": 1}}, "a"], true]
