spec: stat_extra2
version: ">=3.9"
backend: python_module(stat)

docs: https://docs.python.org/3/library/stat.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/stat.html — Python stat module documentation"
    - "POSIX.1-2017 — IEEE Std 1003.1, file type and permission bits"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/stat.py"
    - "CPython source: Modules/_stat.c"
  notes:
    - "Extends stat.zspec.zsdl and stat_extra.zspec.zsdl."
    - "stat.zspec.zsdl covers: S_IFREG/S_IFDIR/S_IFLNK/S_IFSOCK values; S_IRUSR/S_IWUSR/S_IXUSR values; S_ISREG/S_ISDIR predicates; S_IMODE(33188)==420; filemode for regular file and directory."
    - "stat_extra.zspec.zsdl covers: S_ISREG/S_ISDIR/filemode/S_IFMT function names; S_IRWXU value and type; ST_MODE/ST_INO/ST_SIZE/ST_MTIME values and types; S_IFREG/S_IFDIR values; S_ISREG/S_ISDIR cross-checks."
    - "This spec adds: group/other permission constants (S_IRGRP/S_IWGRP/S_IXGRP/S_IROTH/S_IWOTH/S_IXOTH/S_IRWXG/S_IRWXO); special-mode bits (S_ISUID/S_ISGID/S_ISVTX); remaining file-type constants (S_IFIFO/S_IFBLK/S_IFCHR); additional os.stat() tuple indices (ST_DEV/ST_NLINK/ST_UID/ST_GID/ST_ATIME); filemode for symlink and FIFO; S_IFMT extracts file-type bits."
    - "S_IRGRP=32, S_IWGRP=16, S_IXGRP=8, S_IRWXG=56 (0o070 — group permission bits)."
    - "S_IROTH=4, S_IWOTH=2, S_IXOTH=1, S_IRWXO=7 (0o007 — other permission bits)."
    - "S_ISUID=2048 (0o4000), S_ISGID=1024 (0o2000), S_ISVTX=512 (0o1000) — special mode bits."
    - "S_IFIFO=4096 (0o010000 — named pipe), S_IFBLK=24576 (0o060000 — block device), S_IFCHR=8192 (0o020000 — character device)."
    - "ST_DEV=2, ST_NLINK=3, ST_UID=4, ST_GID=5, ST_ATIME=7 — os.stat() result tuple indices."
    - "stat.filemode(40960) == 'l---------' — symlink with no permissions."
    - "stat.filemode(4096) == 'p---------' — FIFO with no permissions."
    - "stat.S_IFMT(33188) == 32768 (== S_IFREG) — extracts file-type bits from a regular file mode."
    - "stat.S_IMODE(33279) == 511 (0o777) — permission bits of a mode with all bits set."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Group permission constants
# stat_extra covers S_IRWXU (owner rwx). New here: group bits.
# S_IRGRP=32 (0o040), S_IWGRP=16 (0o020), S_IXGRP=8 (0o010), S_IRWXG=56 (0o070)
# ---------------------------------------------------------------------------

table stat_extra2.group_permission_constants:
  kind: python_call_eq
  category: constants
  id_prefix: const

  columns: [id, function, args, expected]
  rows:
    - [S_IRGRP, S_IRGRP.__eq__, [32], true]
    - [S_IWGRP, S_IWGRP.__eq__, [16], true]
    - [S_IXGRP, S_IXGRP.__eq__, [8],  true]
    - [S_IRWXG, S_IRWXG.__eq__, [56], true]

# ---------------------------------------------------------------------------
# Other (world) permission constants
# S_IROTH=4 (0o004), S_IWOTH=2 (0o002), S_IXOTH=1 (0o001), S_IRWXO=7 (0o007)
# ---------------------------------------------------------------------------

table stat_extra2.other_permission_constants:
  kind: python_call_eq
  category: constants
  id_prefix: const

  columns: [id, function, args, expected]
  rows:
    - [S_IROTH, S_IROTH.__eq__, [4], true]
    - [S_IWOTH, S_IWOTH.__eq__, [2], true]
    - [S_IXOTH, S_IXOTH.__eq__, [1], true]
    - [S_IRWXO, S_IRWXO.__eq__, [7], true]

# ---------------------------------------------------------------------------
# Special mode bit constants
# S_ISUID=2048 (0o4000 — set-UID), S_ISGID=1024 (0o2000 — set-GID), S_ISVTX=512 (0o1000 — sticky)
# ---------------------------------------------------------------------------

invariant stat_extra2.S_ISUID.value:
  description: "stat.S_ISUID == 2048 (0o4000 — set-user-ID on execution)"
  category: constants
  kind: python_call_eq
  function: S_ISUID.__eq__
  args: [2048]
  expected: true

invariant stat_extra2.S_ISGID.value:
  description: "stat.S_ISGID == 1024 (0o2000 — set-group-ID on execution)"
  category: constants
  kind: python_call_eq
  function: S_ISGID.__eq__
  args: [1024]
  expected: true

invariant stat_extra2.S_ISVTX.value:
  description: "stat.S_ISVTX == 512 (0o1000 — sticky bit)"
  category: constants
  kind: python_call_eq
  function: S_ISVTX.__eq__
  args: [512]
  expected: true

# ---------------------------------------------------------------------------
# Additional file-type constants
# stat.zspec covers S_IFREG/S_IFDIR/S_IFLNK/S_IFSOCK.
# New here: S_IFIFO, S_IFBLK, S_IFCHR.
# ---------------------------------------------------------------------------

invariant stat_extra2.S_IFIFO.value:
  description: "stat.S_IFIFO == 4096 (0o010000 — named pipe / FIFO)"
  category: constants
  kind: python_call_eq
  function: S_IFIFO.__eq__
  args: [4096]
  expected: true

invariant stat_extra2.S_IFBLK.value:
  description: "stat.S_IFBLK == 24576 (0o060000 — block device)"
  category: constants
  kind: python_call_eq
  function: S_IFBLK.__eq__
  args: [24576]
  expected: true

invariant stat_extra2.S_IFCHR.value:
  description: "stat.S_IFCHR == 8192 (0o020000 — character device)"
  category: constants
  kind: python_call_eq
  function: S_IFCHR.__eq__
  args: [8192]
  expected: true

# ---------------------------------------------------------------------------
# os.stat() result tuple indices — ST_DEV, ST_NLINK, ST_UID, ST_GID, ST_ATIME
# stat_extra covers ST_MODE=0, ST_INO=1, ST_SIZE=6, ST_MTIME=8.
# New here: ST_DEV=2, ST_NLINK=3, ST_UID=4, ST_GID=5, ST_ATIME=7.
# ---------------------------------------------------------------------------

table stat_extra2.st_tuple_indices:
  kind: python_call_eq
  category: constants
  id_prefix: st_idx

  columns: [id, function, args, expected]
  rows:
    - [ST_DEV,   ST_DEV.__eq__,   [2], true]
    - [ST_NLINK, ST_NLINK.__eq__, [3], true]
    - [ST_UID,   ST_UID.__eq__,   [4], true]
    - [ST_GID,   ST_GID.__eq__,   [5], true]
    - [ST_ATIME, ST_ATIME.__eq__, [7], true]

# ---------------------------------------------------------------------------
# filemode — additional file types
# stat.zspec covers regular file (33188) and directory (16877).
# New here: symlink (40960) and FIFO (4096).
# ---------------------------------------------------------------------------

invariant stat_extra2.filemode.symlink:
  description: "stat.filemode(40960) == 'l---------' — symlink with no permission bits"
  category: filemode
  kind: python_call_eq
  function: filemode
  args: [40960]
  expected: "l---------"

invariant stat_extra2.filemode.fifo:
  description: "stat.filemode(4096) == 'p---------' — FIFO with no permission bits"
  category: filemode
  kind: python_call_eq
  function: filemode
  args: [4096]
  expected: "p---------"

# ---------------------------------------------------------------------------
# S_IFMT — extract file-type bits from a mode integer
# stat_extra confirms S_IFMT.__name__ == 'S_IFMT' but never calls it.
# New here: S_IFMT(33188) == 32768 (S_IFREG) and S_IMODE(33279) == 511 (0o777).
# ---------------------------------------------------------------------------

invariant stat_extra2.S_IFMT.regular_file:
  description: "stat.S_IFMT(33188) == 32768 — extracts S_IFREG from a regular-file mode"
  category: functions
  kind: python_call_eq
  function: S_IFMT
  args: [33188]
  expected: 32768

invariant stat_extra2.S_IMODE.all_perms:
  description: "stat.S_IMODE(33279) == 511 — 0o100777 stripped to 0o777 (511 decimal)"
  category: functions
  kind: python_call_eq
  function: S_IMODE
  args: [33279]
  expected: 511
