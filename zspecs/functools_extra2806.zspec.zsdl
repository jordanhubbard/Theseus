spec: functools_extra2806
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "any proprietary source"
  notes:
    - "Wave 634 (_extra2806): __ilshift__, __irshift__, and __ipow__ dict-presence checks (in-place left-shift <<=, right-shift >>=, power **=)."
    - "functools.partial is a C-level type — no in-place shift or power operators defined."
    - "functools.partialmethod is a pure-Python class — no in-place shift or power operators defined."
    - "functools.cached_property is a pure-Python descriptor class — no in-place shift or power operators defined."
    - "functools.singledispatchmethod is a pure-Python class — no in-place shift or power operators defined."
    - "None of the functools utility types implement numeric shift or power protocols; __ilshift__, __irshift__, __ipow__ are all absent."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __ilshift__ dict-presence (in-place left-shift <<=)
#
# functools.partial, partialmethod, cached_property, singledispatchmethod
# are utility wrappers — none define __ilshift__ in their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra2806.ilshift_protocol:
  description: "functools types __ilshift__ dict-presence checks — all False (no in-place left-shift protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2806
  columns: [id, function, args, expected]
  rows:
    - ["ft2806001", "functools.partial.__dict__.__contains__",              ["__ilshift__"], false]
    - ["ft2806002", "functools.partialmethod.__dict__.__contains__",        ["__ilshift__"], false]
    - ["ft2806003", "functools.cached_property.__dict__.__contains__",      ["__ilshift__"], false]
    - ["ft2806004", "functools.singledispatchmethod.__dict__.__contains__",  ["__ilshift__"], false]

# ---------------------------------------------------------------------------
# Table 2: __irshift__ dict-presence (in-place right-shift >>=)
#
# None of the functools types define __irshift__ — these classes wrap
# callables and have no numeric shift semantics.
# ---------------------------------------------------------------------------

table functools_extra2806.irshift_protocol:
  description: "functools types __irshift__ dict-presence checks — all False (no in-place right-shift protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2806
  columns: [id, function, args, expected]
  rows:
    - ["ft2806005", "functools.partial.__dict__.__contains__",              ["__irshift__"], false]
    - ["ft2806006", "functools.partialmethod.__dict__.__contains__",        ["__irshift__"], false]
    - ["ft2806007", "functools.cached_property.__dict__.__contains__",      ["__irshift__"], false]
    - ["ft2806008", "functools.singledispatchmethod.__dict__.__contains__",  ["__irshift__"], false]

# ---------------------------------------------------------------------------
# Table 3: __ipow__ dict-presence (in-place power **=)
#
# None of the functools types define __ipow__ — higher-order function
# utilities have no exponentiation or numeric power semantics.
# ---------------------------------------------------------------------------

table functools_extra2806.ipow_protocol:
  description: "functools types __ipow__ dict-presence checks — all False (no in-place power protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2806
  columns: [id, function, args, expected]
  rows:
    - ["ft2806009", "functools.partial.__dict__.__contains__",              ["__ipow__"], false]
    - ["ft2806010", "functools.partialmethod.__dict__.__contains__",        ["__ipow__"], false]
    - ["ft2806011", "functools.cached_property.__dict__.__contains__",      ["__ipow__"], false]
    - ["ft2806012", "functools.singledispatchmethod.__dict__.__contains__",  ["__ipow__"], false]

# ---------------------------------------------------------------------------
# Table 4: combined in-place shift/power operator absence — all three ops
#
# Cross-check: each type lacks all three in-place shift/power operators.
# Confirms that the functools API surface is strictly about higher-order
# function utilities, not numeric shift or power in-place mutation.
# ---------------------------------------------------------------------------

table functools_extra2806.inplace_shift_pow_absent:
  description: "functools types full __ilshift__/__irshift__/__ipow__ absence cross-check — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2806
  columns: [id, function, args, expected]
  rows:
    - ["ft2806013", "functools.partial.__dict__.__contains__",              ["__ilshift__"], false]
    - ["ft2806014", "functools.partial.__dict__.__contains__",              ["__irshift__"], false]
    - ["ft2806015", "functools.partial.__dict__.__contains__",              ["__ipow__"],    false]
    - ["ft2806016", "functools.partialmethod.__dict__.__contains__",        ["__ilshift__"], false]
    - ["ft2806017", "functools.partialmethod.__dict__.__contains__",        ["__irshift__"], false]
    - ["ft2806018", "functools.partialmethod.__dict__.__contains__",        ["__ipow__"],    false]
    - ["ft2806019", "functools.cached_property.__dict__.__contains__",      ["__ilshift__"], false]
    - ["ft2806020", "functools.cached_property.__dict__.__contains__",      ["__irshift__"], false]
    - ["ft2806021", "functools.cached_property.__dict__.__contains__",      ["__ipow__"],    false]
    - ["ft2806022", "functools.singledispatchmethod.__dict__.__contains__",  ["__ilshift__"], false]
    - ["ft2806023", "functools.singledispatchmethod.__dict__.__contains__",  ["__irshift__"], false]
    - ["ft2806024", "functools.singledispatchmethod.__dict__.__contains__",  ["__ipow__"],    false]
