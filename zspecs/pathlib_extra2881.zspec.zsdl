spec: pp2881
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/pathlib_extra2866.zspec.zsdl — wave 638 predecessor (covered __rand__, __ror__, __rxor__)"
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "Wave 639 theme: __iadd__, __isub__, __imul__ dict-presence checks (in-place augmented assignment operators)."
    - "pathlib classes represent filesystem paths — they do not define any arithmetic operators, in-place or otherwise."
    - "pathlib.PurePath, PurePosixPath, PureWindowsPath, and Path do NOT define __iadd__, __isub__, or __imul__."
    - "The path division operator (/) is implemented via __truediv__/__rtruediv__, NOT via any arithmetic in-place ops."
    - "Absence is consistent across all four pathlib classes tested — path objects have no arithmetic semantics."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __iadd__ dict-presence — absent from all pathlib path classes
# ---------------------------------------------------------------------------

table pp2881.iadd:
  description: "__iadd__ is absent from all pathlib class __dict__s — path objects are not in-place addition operands"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2881

  columns: [id, function, args, expected]
  rows:
    - ["pp2881001", "pathlib.PurePath.__dict__.__contains__",        ["__iadd__"], false]
    - ["pp2881002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__iadd__"], false]
    - ["pp2881003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__iadd__"], false]
    - ["pp2881004", "pathlib.Path.__dict__.__contains__",            ["__iadd__"], false]
    - ["pp2881005", "pathlib.PurePath.__dict__.__contains__",        ["__add__"],  false]
    - ["pp2881006", "pathlib.Path.__dict__.__contains__",            ["__add__"],  false]

