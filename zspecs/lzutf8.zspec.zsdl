spec: lzutf8
version: ">=0.6.0"
backend: node(lzutf8)

docs: https://github.com/rotemdan/lzutf8.js#readme

provenance:
  derived_from:
    - "lzutf8.js README — https://github.com/rotemdan/lzutf8.js#readme"
    - "Test vectors verified with lzutf8 via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "lzutf8 source"
  notes:
    - "lzutf8 is a UTF-8-optimized LZ-based string compressor — produces compact output for small text."
    - "Install: npm install lzutf8"
    - "compress(s, {outputEncoding: 'Base64'}) returns a base64 string — equality-comparable in tests."
    - "decompress(c, {inputEncoding, outputEncoding: 'String'}) recovers the original."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; throws on malformed compressed input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# Compress -> Base64 string equality
table lzutf8.compress_base64:
  kind: node_chain_eq
  category: compress_base64
  entry: named
  function: compress
  id_prefix: comp_b64

  columns: [id, entry_args, chain, expected]
  rows:
    - [hello_repeated,
       ["hello hello hello", {outputEncoding: "Base64"}],
       [],
       "aGVsbG8gywY="]

    - [single_word_hello,
       ["hello", {outputEncoding: "Base64"}],
       [],
       "aGVsbG8="]

# Round-trip via decompress with explicit encoding
table lzutf8.decompress_string:
  kind: node_chain_eq
  category: decompress_string
  entry: named
  function: decompress
  id_prefix: decomp

  columns: [id, entry_args, chain, expected]
  rows:
    - [hello_repeated_rt,
       ["aGVsbG8gywY=", {inputEncoding: "Base64", outputEncoding: "String"}],
       [],
       "hello hello hello"]

    - [single_word_rt,
       ["aGVsbG8=", {inputEncoding: "Base64", outputEncoding: "String"}],
       [],
       "hello"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:00:12Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
