spec: abc_extra676
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from: ["CPython source code"]
  notes: ["Covers abc.ABC, ABCMeta, and decorator class/function identity attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra676.abc_class_identity:
  description: "Identity checks for abc.ABC and abc.ABCMeta attributes"
  kind: python_call_eq
  category: class_identity
  id_prefix: ab676ai
  columns: [id, function, args, expected]
  rows:
    - [ab676ai001, abc.ABC.__init_subclass__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ab676ai002, abc.ABC.__subclasshook__.__class__.__name__.__eq__, ["function"], true]
    - [ab676ai003, abc.ABCMeta.__abstractmethods__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [ab676ai004, abc.ABCMeta.__abstractmethods__.__qualname__.__eq__, ["type.__abstractmethods__"], true]
    - [ab676ai005, abc.ABCMeta.register.__class__.__name__.__eq__, ["function"], true]
    - [ab676ai006, abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__, ["function"], true]
    - [ab676ai007, abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__, ["function"], true]

table abc_extra676.abc_decorator_identity:
  description: "Identity checks for abc decorator and utility function types"
  kind: python_call_eq
  category: class_identity
  id_prefix: ab676di
  columns: [id, function, args, expected]
  rows:
    - [ab676di001, abc.abstractmethod.__class__.__name__.__eq__, ["function"], true]
    - [ab676di002, abc.abstractclassmethod.__class__.__name__.__eq__, ["type"], true]
    - [ab676di003, abc.abstractstaticmethod.__class__.__name__.__eq__, ["type"], true]
    - [ab676di004, abc.abstractproperty.__class__.__name__.__eq__, ["type"], true]
    - [ab676di005, abc.get_cache_token.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
