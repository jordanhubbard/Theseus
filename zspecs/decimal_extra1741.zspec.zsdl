spec: decimal_extra1741
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra1681.zspec.zsdl — covers __call__, arithmetic operators, __hash__/__eq__, __iter__/__contains__"
    - "decimal_extra1666.zspec.zsdl — covers __new__ and __init__ construction protocol"
    - "decimal_extra1651.zspec.zsdl — covers __init_subclass__, __class_getitem__, module attr presence"
  notes:
    - "Wave 563 (_extra1741): descriptor protocol — which decimal types define __get__, __set__, __delete__, __set_name__ in their own __dict__."
    - "decimal.Decimal is a C extension type; it does NOT define __get__, __set__, __delete__, or __set_name__ in its own __dict__."
    - "decimal.Context is a C extension type; it does NOT define descriptor protocol methods in its own __dict__."
    - "decimal.Decimal defines __round__ in its own __dict__ — supports round() built-in."
    - "decimal.Decimal defines __floor__ in its own __dict__ — supports math.floor()."
    - "decimal.Decimal defines __ceil__ in its own __dict__ — supports math.ceil()."
    - "decimal.Decimal defines __trunc__ in its own __dict__ — supports math.trunc()."
    - "decimal.Decimal defines __mod__ and __divmod__ in its own __dict__ — supports % and divmod()."
    - "decimal.Context does NOT define __round__, __floor__, __ceil__, or __trunc__ in its own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table decimal_extra1741.descriptor_protocol
# __get__, __set__, __delete__, __set_name__ are absent from every decimal
# type's own __dict__. Decimal and Context are not descriptors.
# ---------------------------------------------------------------------------

table decimal_extra1741.descriptor_protocol:
  description: "decimal types descriptor protocol (__get__/__set__/__delete__/__set_name__) dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1741

  columns: [id, function, args, expected]
  rows:
    - ["dc1741001", Decimal.__dict__.__contains__,          ["__get__"],      false]
    - ["dc1741002", Decimal.__dict__.__contains__,          ["__set__"],      false]
    - ["dc1741003", Decimal.__dict__.__contains__,          ["__delete__"],   false]
    - ["dc1741004", Decimal.__dict__.__contains__,          ["__set_name__"], false]
    - ["dc1741005", Context.__dict__.__contains__,          ["__get__"],      false]
    - ["dc1741006", Context.__dict__.__contains__,          ["__set__"],      false]
    - ["dc1741007", Context.__dict__.__contains__,          ["__delete__"],   false]
    - ["dc1741008", Context.__dict__.__contains__,          ["__set_name__"], false]
    - ["dc1741009", DecimalException.__dict__.__contains__,  ["__get__"],      false]
    - ["dc1741010", DecimalException.__dict__.__contains__,  ["__set__"],      false]
    - ["dc1741011", DecimalException.__dict__.__contains__,  ["__delete__"],   false]
    - ["dc1741012", InvalidOperation.__dict__.__contains__,  ["__get__"],      false]
    - ["dc1741013", DivisionByZero.__dict__.__contains__,    ["__get__"],      false]

# ---------------------------------------------------------------------------
# Table decimal_extra1741.rounding_protocol
# decimal.Decimal defines the extended rounding protocol methods in its own
# __dict__: __round__, __floor__, __ceil__, __trunc__, __mod__, __divmod__.
# These enable Decimal to integrate with round(), math.floor(), math.ceil(),
# math.trunc(), and the % / divmod() operators respectively.
# decimal.Context does NOT define any of these in its own __dict__.
# ---------------------------------------------------------------------------

table decimal_extra1741.rounding_protocol:
  description: "Rounding protocol (__round__/__floor__/__ceil__/__trunc__/__mod__/__divmod__) dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1741

  columns: [id, function, args, expected]
  rows:
    - ["dc1741014", Decimal.__dict__.__contains__,  ["__round__"],   true]
    - ["dc1741015", Decimal.__dict__.__contains__,  ["__floor__"],   true]
    - ["dc1741016", Decimal.__dict__.__contains__,  ["__ceil__"],    true]
    - ["dc1741017", Decimal.__dict__.__contains__,  ["__trunc__"],   true]
    - ["dc1741018", Decimal.__dict__.__contains__,  ["__mod__"],     true]
    - ["dc1741019", Decimal.__dict__.__contains__,  ["__divmod__"],  true]
    - ["dc1741020", Context.__dict__.__contains__,  ["__round__"],   false]
    - ["dc1741021", Context.__dict__.__contains__,  ["__floor__"],   false]
    - ["dc1741022", Context.__dict__.__contains__,  ["__ceil__"],    false]
    - ["dc1741023", Context.__dict__.__contains__,  ["__trunc__"],   false]
    - ["dc1741024", Context.__dict__.__contains__,  ["__mod__"],     false]
    - ["dc1741025", Context.__dict__.__contains__,  ["__divmod__"],  false]
