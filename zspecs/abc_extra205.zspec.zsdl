spec: abc_extra205
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "abc.abstractmethod.__doc__.__class__.__name__ == 'str' — abstractmethod.__doc__ is a plain str; it reads: 'A decorator indicating abstract methods. Requires that the metaclass is ABCMeta or derived from it.'"
    - "abc.abstractmethod.__doc__.__contains__('abstract') returns True — the word 'abstract' appears in the docstring: 'A decorator indicating abstract methods.'."
    - "abc.ABCMeta.__doc__.__class__.__name__ == 'str' — ABCMeta.__doc__ is a plain str; it reads: 'Metaclass for defining Abstract Base Classes (ABCs)...'."
    - "abc.ABCMeta.__doc__.__contains__('Abstract') returns True — 'Abstract' (capital A) appears in: 'Metaclass for defining Abstract Base Classes (ABCs).'."
    - "abc.ABCMeta.__doc__.__contains__('abstract') returns False — the word 'abstract' (lowercase a) does NOT appear in ABCMeta.__doc__; the doc uses 'Abstract' capitalized only."
    - "abc.ABC.__doc__.__class__.__name__ == 'str' — ABC.__doc__ is a plain str; it reads: 'Helper class that provides a standard way to create an ABC using inheritance.'."
    - "abc.ABC.__doc__.__contains__('ABC') returns True — 'ABC' appears in: 'Helper class that provides a standard way to create an ABC using inheritance.'."
    - "abc.ABC.__doc__.__contains__('abstract') returns False — 'abstract' (lowercase) does NOT appear in ABC.__doc__; the docstring says 'ABC' not 'abstract base class'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

