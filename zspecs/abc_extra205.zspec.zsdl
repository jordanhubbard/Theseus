invariant abc_extra205.abstractmethod_doc_class_name_str:
  description: "abc.abstractmethod.__doc__.__class__.__name__.__eq__('str') returns True — abc.abstractmethod.__doc__ is a plain str object; the docstring reads: 'A decorator indicating abstract methods. Requires that the metaclass is ABCMeta or derived from it.'; __class__.__name__ is 'str' confirming it is not None; abstractmethod is a class (a decorator factory); NEW in extra205; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_content
  kind: python_call_eq
  function: abc.abstractmethod.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra205.abstractmethod_doc_contains_abstract:
  description: "abc.abstractmethod.__doc__.__contains__('abstract') returns True — abc.abstractmethod.__doc__ contains the word 'abstract' (lowercase); the full docstring is: 'A decorator indicating abstract methods. Requires that the metaclass is ABCMeta or derived from it.'; 'abstract' appears in 'abstract methods'; NEW in extra205; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_content
  kind: python_call_eq
  function: abc.abstractmethod.__doc__.__contains__
  args: ["abstract"]
  expected: true

invariant abc_extra205.abcmeta_doc_class_name_str:
  description: "abc.ABCMeta.__doc__.__class__.__name__.__eq__('str') returns True — abc.ABCMeta.__doc__ is a plain str object; the docstring begins: 'Metaclass for defining Abstract Base Classes (ABCs).'; __class__.__name__ is 'str' confirming it is not None; ABCMeta is the metaclass that enables abstract base class functionality; NEW in extra205; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_content
  kind: python_call_eq
  function: abc.ABCMeta.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra205.abcmeta_doc_contains_Abstract:
  description: "abc.ABCMeta.__doc__.__contains__('Abstract') returns True — abc.ABCMeta.__doc__ contains the word 'Abstract' (capital A); the docstring reads: 'Metaclass for defining Abstract Base Classes (ABCs).'; 'Abstract' appears as the first word of 'Abstract Base Classes'; note: lowercase 'abstract' is NOT in the doc (False); only 'Abstract' capitalized; NEW in extra205; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_content
  kind: python_call_eq
  function: abc.ABCMeta.__doc__.__contains__
  args: ["Abstract"]
  expected: true

invariant abc_extra205.abcmeta_doc_no_abstract_lower:
  description: "abc.ABCMeta.__doc__.__contains__('abstract') returns False — abc.ABCMeta.__doc__ does NOT contain the word 'abstract' (lowercase a); the docstring uses 'Abstract' (capital A) in 'Abstract Base Classes' and elsewhere uses 'ABC'; no lowercase 'abstract' appears anywhere in ABCMeta.__doc__; note the contrast with abstractmethod.__doc__ which does contain lowercase 'abstract'; NEW in extra205; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_content
  kind: python_call_eq
  function: abc.ABCMeta.__doc__.__contains__
  args: ["abstract"]
  expected: false

invariant abc_extra205.abc_doc_class_name_str:
  description: "abc.ABC.__doc__.__class__.__name__.__eq__('str') returns True — abc.ABC.__doc__ is a plain str object; the docstring reads: 'Helper class that provides a standard way to create an ABC using inheritance.'; __class__.__name__ is 'str' confirming it is not None; ABC is a helper class that can be used as a base class to make defining abstract base classes easier; NEW in extra205; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_content
  kind: python_call_eq
  function: abc.ABC.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra205.abc_doc_contains_ABC:
  description: "abc.ABC.__doc__.__contains__('ABC') returns True — abc.ABC.__doc__ contains 'ABC'; the full docstring is: 'Helper class that provides a standard way to create an ABC using inheritance.'; 'ABC' appears in 'create an ABC using inheritance'; NEW in extra205; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_content
  kind: python_call_eq
  function: abc.ABC.__doc__.__contains__
  args: ["ABC"]
  expected: true

invariant abc_extra205.abc_doc_no_abstract_lower:
  description: "abc.ABC.__doc__.__contains__('abstract') returns False — abc.ABC.__doc__ does NOT contain the word 'abstract' (lowercase); the docstring is: 'Helper class that provides a standard way to create an ABC using inheritance.'; no lowercase 'abstract' appears; the doc uses 'ABC' as an acronym rather than spelling out 'abstract base class'; NEW in extra205; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_content
  kind: python_call_eq
  function: abc.ABC.__doc__.__contains__
  args: ["abstract"]
  expected: false

