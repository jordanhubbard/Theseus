  description: "abc.abstractmethod.__doc__ type and content checks in abcrepr205 namespace — abstractmethod.__doc__.__class__.__name__.__eq__('str')==True (abstractmethod.__doc__ is a plain str not None); abstractmethod.__doc__.__contains__('abstract')==True ('abstract' appears in the first sentence: 'A decorator indicating abstract methods.'); abstractmethod.__doc__.__class__.__name__.__eq__('NoneType')==False (doc is not None); abstractmethod.__doc__.__contains__('ABCMeta')==True ('ABCMeta' appears in: 'Requires that the metaclass is ABCMeta or derived from it.'); verified with Python 3.14.3"
  kind: python_call_eq
  category: doc_content
  id_prefix: abcrepr205

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_doc_type_str,        "abc.abstractmethod.__doc__.__class__.__name__.__eq__",   ["str"],      true,  "abc.abstractmethod.__doc__.__class__.__name__.__eq__('str') == True; verified Python 3.14.3"]
    - [abstractmethod_doc_has_abstract,    "abc.abstractmethod.__doc__.__contains__",                ["abstract"], true,  "abc.abstractmethod.__doc__.__contains__('abstract') == True; verified Python 3.14.3"]
    - [abstractmethod_doc_not_nonetype,    "abc.abstractmethod.__doc__.__class__.__name__.__eq__",   ["NoneType"], false, "abc.abstractmethod.__doc__.__class__.__name__.__eq__('NoneType') == False; verified Python 3.14.3"]
    - [abstractmethod_doc_has_abcmeta,     "abc.abstractmethod.__doc__.__contains__",                ["ABCMeta"],  true,  "abc.abstractmethod.__doc__.__contains__('ABCMeta') == True; verified Python 3.14.3"]

