spec: socket_extra238
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "Python 3 socket module documentation — https://docs.python.org/3/library/socket.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec extends socket.zspec.zsdl, socket_extra.zspec.zsdl, and socket_extra2.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "socket.zspec.zsdl covers: AF_INET/AF_INET6/AF_UNIX constants; SOCK_STREAM/DGRAM/RAW; IPPROTO_*; gethostname/getdefaulttimeout/inet_aton/inet_ntoa/htonl/ntohl function names; getdefaulttimeout()==None; inet_aton vectors; htonl(0)==0."
    - "socket_extra.zspec.zsdl covers: create_connection/create_server/setdefaulttimeout/htons/ntohs names; setdefaulttimeout(None); inet_aton broadcast/len; inet_ntoa loopback/broadcast/zero; htons/ntohs/ntohl zero; htonl(1) little-endian."
    - "socket_extra2.zspec.zsdl covers: AddressFamily/SocketKind enum class names; AF_INET/SOCK_STREAM/SOCK_DGRAM integer values; gethostname() return type; getfqdn() return type; socket.error alias name; socket.timeout alias name and base."
    - "This spec focuses on: getfqdn/gethostname function identity (__name__/__module__/__qualname__); has_ipv6 capability (bool, True on macOS)."
    - "socket.getfqdn is a pure-Python function; its __module__ == 'socket'."
    - "socket.gethostname is a built-in function from _socket; its __module__ == '_socket'."
    - "socket.has_ipv6 is True on macOS/Darwin (verified Python 3.14.3 on macOS/Darwin 25.4.0)."
    - "socket.has_ipv6.__class__.__name__ == 'bool' — it is a plain Python bool constant."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "All invariants in this spec are attribute/name lookups and do not raise."
  stderr: "null"
  stickiness: "N/A — all tested invariants are pure attribute accesses."
  codes: {}

# ---------------------------------------------------------------------------
# getfqdn — function identity contracts
# socket.getfqdn is defined in Lib/socket.py (pure Python)
# ---------------------------------------------------------------------------

table socket_extra238.getfqdn.identity:
  kind: python_call_eq
  category: function_names
  id_prefix: socket238fn

  columns: [id, function, args, expected]
  rows:
    - [name,     getfqdn.__name__.__eq__,     ["getfqdn"], true]
    - [module,   getfqdn.__module__.__eq__,   ["socket"],  true]
    - [qualname, getfqdn.__qualname__.__eq__, ["getfqdn"], true]

# ---------------------------------------------------------------------------
# gethostname — function identity contracts
# socket.gethostname is a built-in from _socket (C extension)
# ---------------------------------------------------------------------------

table socket_extra238.gethostname.identity:
  kind: python_call_eq
  category: function_names
  id_prefix: socket238fn

  columns: [id, function, args, expected]
  rows:
    - [name,   gethostname.__name__.__eq__,   ["gethostname"], true]
    - [module, gethostname.__module__.__eq__, ["_socket"],     true]

# ---------------------------------------------------------------------------
# has_ipv6 — capability flag: class name and value on macOS
# ---------------------------------------------------------------------------

invariant socket_extra238.has_ipv6.class_name:
  description: "socket.has_ipv6.__class__.__name__ == 'bool' — has_ipv6 is a plain Python bool"
  category: capabilities
  kind: python_call_eq
  function: has_ipv6.__class__.__name__.__eq__
  args: ["bool"]
  expected: true

invariant socket_extra238.has_ipv6.is_true:
  description: "socket.has_ipv6 == True on macOS/Darwin (IPv6 is always available)"
  category: capabilities
  kind: python_call_eq
  function: has_ipv6.__eq__
  args: [true]
  expected: true

# ---------------------------------------------------------------------------
# getfqdn — return type is str (function-level identity, not network I/O)
# socket_extra2.zspec.zsdl already tested return type via method_chain;
# this spec tests via a different invariant id.
# ---------------------------------------------------------------------------

invariant socket_extra238.getfqdn.name_is_string:
  description: "socket.getfqdn.__name__.__class__.__name__ == 'str' — __name__ attribute is a str"
  category: function_names
  kind: python_call_eq
  function: getfqdn.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant socket_extra238.gethostname.name_is_string:
  description: "socket.gethostname.__name__.__class__.__name__ == 'str' — __name__ attribute is a str"
  category: function_names
  kind: python_call_eq
  function: gethostname.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# has_ipv6 — class is bool, which inherits from int
# ---------------------------------------------------------------------------

invariant socket_extra238.has_ipv6.bases_int:
  description: "socket.has_ipv6.__class__.__bases__[0].__name__ == 'int' — bool inherits from int"
  category: capabilities
  kind: python_call_eq
  function: has_ipv6.__class__.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "int"

# ---------------------------------------------------------------------------
# getfqdn and gethostname are callable (have __call__ via being functions)
# We test via __class__.__name__ of the function object itself.
# ---------------------------------------------------------------------------

invariant socket_extra238.getfqdn.callable_class:
  description: "socket.getfqdn.__class__.__name__ == 'function' — getfqdn is a Python function"
  category: function_names
  kind: python_call_eq
  function: getfqdn.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant socket_extra238.gethostname.callable_class:
  description: "socket.gethostname.__class__.__name__ == 'builtin_function_or_method'"
  category: function_names
  kind: python_call_eq
  function: gethostname.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
