spec: bit_twiddle
version: ">=1.0.0"
backend: node(bit-twiddle)

docs: https://github.com/mikolalysenko/bit-twiddle#readme

provenance:
  derived_from:
    - "bit-twiddle README — https://github.com/mikolalysenko/bit-twiddle#readme"
    - "Bit Twiddling Hacks — https://graphics.stanford.edu/~seander/bithacks.html"
    - "Test vectors verified with bit-twiddle via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "bit-twiddle source"
  notes:
    - "Bit-manipulation utilities ported from Sean Eron Anderson's classic 'Bit Twiddling Hacks'."
    - "Install: npm install bit-twiddle"
    - "All operations are pure 32-bit integer arithmetic."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; defined for 32-bit integer inputs."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# popCount (Hamming weight)
table bit_twiddle.popCount:
  kind: node_module_call_eq
  category: popCount
  function: popCount
  id_prefix: pop

  columns: [id, args, expected]
  rows:
    - [zero,            [0],         0]
    - [one,             [1],         1]
    - [seven,           [7],         3]
    - [byte_all_ones,   [0xff],      8]
    - [word_all_ones,   [0xffff],    16]

# log2 — integer logarithm base 2
table bit_twiddle.log2:
  kind: node_module_call_eq
  category: log2
  function: log2
  id_prefix: log2

  columns: [id, args, expected]
  rows:
    - [one,    [1],     0]
    - [two,    [2],     1]
    - [eight,  [8],     3]
    - [k1024,  [1024],  10]
    - [m1m,    [1048576], 20]

# isPow2 / nextPow2 / prevPow2
table bit_twiddle.isPow2:
  kind: node_module_call_eq
  category: isPow2
  function: isPow2
  id_prefix: isPow2

  columns: [id, args, expected]
  rows:
    - [one,        [1],   true]
    - [two,        [2],   true]
    - [four,       [4],   true]
    - [five,       [5],   false]
    - [seven,      [7],   false]
    - [k1024,      [1024], true]

# nextPow2 — next power of 2 >= n
table bit_twiddle.nextPow2:
  kind: node_module_call_eq
  category: nextPow2
  function: nextPow2
  id_prefix: nextPow2

  columns: [id, args, expected]
  rows:
    - [one,    [1],   1]
    - [five,   [5],   8]
    - [hundred,[100], 128]

# countTrailingZeros
table bit_twiddle.countTrailingZeros:
  kind: node_module_call_eq
  category: countTrailingZeros
  function: countTrailingZeros
  id_prefix: ctz

  columns: [id, args, expected]
  rows:
    - [one,         [1],     0]
    - [two,         [2],     1]
    - [eight,       [8],     3]
    - [thirty_two,  [32],    5]
    - [k256,        [256],   8]
