spec: contextlib_extra19
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib.zspec.zsdl through contextlib_extra18.zspec.zsdl."
    - "contextlib_extra18 covers: __qualname__ for contextmanager/asynccontextmanager/nullcontext/AsyncExitStack/redirect_stdout/redirect_stderr/aclosing; redirect_stdout/__module__; AsyncExitStack/__module__; nullcontext/__module__; aclosing/__module__."
    - "contextlib_extra17 covers: closing MRO[0..3]; ExitStack MRO[4]; aclosing MRO[0] and MRO[3]; AsyncExitStack MRO[4]; suppress MRO[0] and MRO[3]."
    - "contextlib_extra16 covers: suppress/closing/ExitStack __qualname__; suppress MRO[1]/[2]; nullcontext MRO[3]/[4]; redirect_stderr.__module__."
    - "contextlib_extra15 covers: redirect_stdout/redirect_stderr MRO[1]/[2]; nullcontext MRO[1]/[2]; AsyncExitStack MRO len/[1]/[2]/[3]; aclosing MRO[2]; suppress.__name__ standalone."
    - "contextlib_extra13 covers: AbstractContextManager MRO len(3) and MRO[1]('ABC'); AbstractAsyncContextManager MRO len(3) and MRO[1]('ABC')."
    - "contextlib_extra12 covers: standalone __name__ for all major contextlib classes/functions."
    - "NOT yet covered: nullcontext.__mro__[0].__name__ == 'nullcontext' — MRO head confirming class identity."
    - "NOT yet covered: ExitStack.__mro__[0].__name__ == 'ExitStack' — MRO head."
    - "NOT yet covered: AsyncExitStack.__mro__[0].__name__ == 'AsyncExitStack' — MRO head."
    - "NOT yet covered: redirect_stdout.__mro__[0].__name__ == 'redirect_stdout' — MRO head."
    - "NOT yet covered: redirect_stderr.__mro__[0].__name__ == 'redirect_stderr' — MRO head."
    - "NOT yet covered: AbstractContextManager.__mro__[0].__name__ == 'AbstractContextManager' — MRO head."
    - "NOT yet covered: AbstractContextManager.__mro__[2].__name__ == 'object' — MRO tail."
    - "NOT yet covered: AbstractAsyncContextManager.__mro__[0].__name__ == 'AbstractAsyncContextManager' — MRO head."
    - "NOT yet covered: AbstractAsyncContextManager.__mro__[2].__name__ == 'object' — MRO tail."
    - "All contextlib classes have themselves as MRO[0]; object is always the MRO tail."
    - "AbstractContextManager MRO: [AbstractContextManager, ABC, object] — MRO[0] is the class itself, MRO[2] is object."
    - "AbstractAsyncContextManager MRO: [AbstractAsyncContextManager, ABC, object] — same pattern."
    - "ExitStack MRO: [ExitStack, _BaseExitStack, AbstractContextManager, ABC, object] — MRO[0] is ExitStack."
    - "AsyncExitStack MRO: [AsyncExitStack, _BaseExitStack, AbstractAsyncContextManager, ABC, object] — MRO[0] is AsyncExitStack."
    - "nullcontext MRO: [nullcontext, AbstractContextManager, AbstractAsyncContextManager, ABC, object] — MRO[0] is nullcontext."
    - "redirect_stdout and redirect_stderr MRO starts with themselves; extra15 confirms MRO[1] and MRO[2]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# MRO[0] entries — class is always its own first MRO entry
#
# All prior contextlib specs cover intermediate and tail MRO entries but no
# prior spec records MRO[0] for nullcontext, ExitStack, AsyncExitStack,
# redirect_stdout, or redirect_stderr as standalone invariants. MRO[0] is
# always the class itself — this confirms the identity invariant.
# ---------------------------------------------------------------------------

invariant contextlib_extra19.nullcontext.mro_0:
  description: "contextlib.nullcontext.__mro__[0].__name__ == 'nullcontext' — class is its own MRO head"
  category: mro_head
  kind: python_call_eq
  function: nullcontext.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "nullcontext"

invariant contextlib_extra19.ExitStack.mro_0:
  description: "contextlib.ExitStack.__mro__[0].__name__ == 'ExitStack' — class is its own MRO head"
  category: mro_head
  kind: python_call_eq
  function: ExitStack.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "ExitStack"

invariant contextlib_extra19.AsyncExitStack.mro_0:
  description: "contextlib.AsyncExitStack.__mro__[0].__name__ == 'AsyncExitStack' — class is its own MRO head"
  category: mro_head
  kind: python_call_eq
  function: AsyncExitStack.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "AsyncExitStack"

invariant contextlib_extra19.redirect_stdout.mro_0:
  description: "contextlib.redirect_stdout.__mro__[0].__name__ == 'redirect_stdout' — class is its own MRO head"
  category: mro_head
  kind: python_call_eq
  function: redirect_stdout.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "redirect_stdout"

invariant contextlib_extra19.redirect_stderr.mro_0:
  description: "contextlib.redirect_stderr.__mro__[0].__name__ == 'redirect_stderr' — class is its own MRO head"
  category: mro_head
  kind: python_call_eq
  function: redirect_stderr.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "redirect_stderr"

# ---------------------------------------------------------------------------
# AbstractContextManager — MRO[0] and MRO[2]
#
# contextlib_extra13 confirms AbstractContextManager MRO length (3) and
# MRO[1] ('ABC'). No prior spec records MRO[0] ('AbstractContextManager'
# itself) or MRO[2] ('object', the tail) as standalone invariants.
# ---------------------------------------------------------------------------

invariant contextlib_extra19.AbstractContextManager.mro_0:
  description: "contextlib.AbstractContextManager.__mro__[0].__name__ == 'AbstractContextManager'"
  category: mro_head
  kind: python_call_eq
  function: AbstractContextManager.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "AbstractContextManager"

invariant contextlib_extra19.AbstractContextManager.mro_2:
  description: "contextlib.AbstractContextManager.__mro__[2].__name__ == 'object' — MRO tail"
  category: mro_tail
  kind: python_call_eq
  function: AbstractContextManager.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# AbstractAsyncContextManager — MRO[0] and MRO[2]
#
# contextlib_extra13 confirms AbstractAsyncContextManager MRO length (3) and
# MRO[1] ('ABC'). No prior spec records MRO[0] or MRO[2] for this class.
# ---------------------------------------------------------------------------

invariant contextlib_extra19.AbstractAsyncContextManager.mro_0:
  description: "contextlib.AbstractAsyncContextManager.__mro__[0].__name__ == 'AbstractAsyncContextManager'"
  category: mro_head
  kind: python_call_eq
  function: AbstractAsyncContextManager.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "AbstractAsyncContextManager"

invariant contextlib_extra19.AbstractAsyncContextManager.mro_2:
  description: "contextlib.AbstractAsyncContextManager.__mro__[2].__name__ == 'object' — MRO tail"
  category: mro_tail
  kind: python_call_eq
  function: AbstractAsyncContextManager.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# suppress and aclosing — MRO[0] not yet verified
#
# contextlib_extra17 records suppress MRO[0] and aclosing MRO[0]. Wait — extra17
# covers suppress.mro_0 and aclosing.mro_0. Adding ExitStack MRO tail (object)
# and AsyncExitStack MRO tail for completeness instead.
#
# ExitStack MRO: [ExitStack, _BaseExitStack, AbstractContextManager, ABC, object]
# extra17 confirms MRO[4] == 'object'. AsyncExitStack MRO[4] also confirmed.
# Add redirect_stdout and redirect_stderr MRO tail (object) — extra15 covers [1][2];
# extra16/17 cover nullcontext [3][4] and ExitStack/AsyncExitStack [4].
# redirect_stdout MRO: [redirect_stdout, _RedirectStream, AbstractContextManager, ABC, object]
# redirect_stderr has the same shape. MRO[3] (ABC) and MRO[4] (object) not yet covered.
# ---------------------------------------------------------------------------

invariant contextlib_extra19.redirect_stdout.mro_3:
  description: "contextlib.redirect_stdout.__mro__[3].__name__ == 'ABC' — ABC in MRO"
  category: redirect_mro
  kind: python_call_eq
  function: redirect_stdout.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "ABC"

invariant contextlib_extra19.redirect_stdout.mro_4:
  description: "contextlib.redirect_stdout.__mro__[4].__name__ == 'object' — MRO tail"
  category: redirect_mro
  kind: python_call_eq
  function: redirect_stdout.__mro__.__getitem__
  args: [4]
  method: __name__
  expected: "object"

invariant contextlib_extra19.redirect_stderr.mro_3:
  description: "contextlib.redirect_stderr.__mro__[3].__name__ == 'ABC' — ABC in MRO"
  category: redirect_mro
  kind: python_call_eq
  function: redirect_stderr.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "ABC"

invariant contextlib_extra19.redirect_stderr.mro_4:
  description: "contextlib.redirect_stderr.__mro__[4].__name__ == 'object' — MRO tail"
  category: redirect_mro
  kind: python_call_eq
  function: redirect_stderr.__mro__.__getitem__
  args: [4]
  method: __name__
  expected: "object"
