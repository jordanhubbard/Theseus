spec: socket_extra2416
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/socket.html"
    - "CPython source — Modules/_socket.c and Lib/socket.py"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 608 (_extra2416): __iter__ and __next__ dict-presence and type classification."
    - "socket.socket is a Python class (Lib/socket.py); it does NOT define __iter__ or __next__ in its class __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntFlag/IntEnum subclasses managed by EnumType metaclass."
    - "Neither socket.AddressFamily nor socket.SocketKind define __iter__ or __next__ in their own __dict__."
    - "The EnumType metaclass (type of AddressFamily, SocketKind, MsgFlag, AddressInfo) defines __iter__ as a Python function."
    - "EnumType does NOT define __next__ — enum classes are iterable but not iterators themselves."
    - "socket.MsgFlag and socket.AddressInfo are also EnumType-managed; same pattern holds."
    - "socket.error, socket.gaierror, socket.herror, socket.timeout are exception subclasses lacking __iter__ and __next__."
    - "socket.SocketIO wraps a socket for use with io.RawIOBase; it defines neither __iter__ nor __next__ in its own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
# Table 1: __iter__ in class __dict__ for socket types
# ===

table socket_extra2416.iter_in_dict:
  description: "Core socket classes do not define __iter__ in their own __dict__; EnumType metaclass does"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2416
  columns: [id, function, args, expected]
  rows:
    - ["sk2416001", "socket.socket.__dict__.__contains__", ["__iter__"], false]
    - ["sk2416002", "socket.AddressFamily.__dict__.__contains__", ["__iter__"], false]
    - ["sk2416003", "socket.SocketKind.__dict__.__contains__", ["__iter__"], false]
    - ["sk2416004", "socket.MsgFlag.__dict__.__contains__", ["__iter__"], false]
    - ["sk2416005", "socket.AddressInfo.__dict__.__contains__", ["__iter__"], false]
    - ["sk2416006", "socket.SocketIO.__dict__.__contains__", ["__iter__"], false]
    - ["sk2416007", "socket.AddressFamily.__class__.__dict__.__contains__", ["__iter__"], true]
    - ["sk2416008", "socket.SocketKind.__class__.__dict__.__contains__", ["__iter__"], true]

# ===
# Table 2: __next__ in class __dict__ for socket types
# ===

table socket_extra2416.next_in_dict:
  description: "No socket class defines __next__ in its own __dict__; EnumType metaclass also lacks __next__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2416
  columns: [id, function, args, expected]
  rows:
    - ["sk2416009", "socket.socket.__dict__.__contains__", ["__next__"], false]
    - ["sk2416010", "socket.AddressFamily.__dict__.__contains__", ["__next__"], false]
    - ["sk2416011", "socket.SocketKind.__dict__.__contains__", ["__next__"], false]
    - ["sk2416012", "socket.MsgFlag.__dict__.__contains__", ["__next__"], false]
    - ["sk2416013", "socket.AddressInfo.__dict__.__contains__", ["__next__"], false]
    - ["sk2416014", "socket.SocketIO.__dict__.__contains__", ["__next__"], false]
    - ["sk2416015", "socket.AddressFamily.__class__.__dict__.__contains__", ["__next__"], false]
    - ["sk2416016", "socket.SocketKind.__class__.__dict__.__contains__", ["__next__"], false]

# ===
# Table 3: metaclass name and __iter__ descriptor type for enum classes
# ===

table socket_extra2416.type_identity:
  description: "Metaclass names and the class of EnumType.__iter__ for socket enum types"
  kind: python_call_eq
  category: type_identity
  id_prefix: sk2416
  columns: [id, function, args, expected]
  rows:
    - ["sk2416017", "socket.socket.__class__.__name__", [], "type"]
    - ["sk2416018", "socket.AddressFamily.__class__.__name__", [], "EnumType"]
    - ["sk2416019", "socket.SocketKind.__class__.__name__", [], "EnumType"]
    - ["sk2416020", "socket.MsgFlag.__class__.__name__", [], "EnumType"]
    - ["sk2416021", "socket.AddressFamily.__class__.__iter__.__class__.__name__", [], "function"]
    - ["sk2416022", "socket.SocketKind.__class__.__iter__.__class__.__name__", [], "function"]
