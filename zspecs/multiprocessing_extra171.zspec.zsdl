spec: multiprocessing_extra171
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.managers.html — multiprocessing managers documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "This spec covers: multiprocessing.pool.Pool.__mro__.__len__()==2 (Pool > object); multiprocessing.process.BaseProcess.__mro__.__len__()==2 (BaseProcess > object); multiprocessing.managers.BaseManager.__mro__.__len__()==2 (BaseManager > object); multiprocessing.managers.SyncManager.__mro__.__len__()==3 (SyncManager > BaseManager > object); multiprocessing.pool.AsyncResult.__name__=='ApplyResult' (the alias resolves to ApplyResult) and AsyncResult.__mro__.__len__()==2 (ApplyResult > object). KEY FINDINGS: all three root classes (Pool, BaseProcess, BaseManager) have minimal 2-entry MROs; SyncManager adds 1 entry as a subclass of BaseManager (MRO len=3); multiprocessing.pool.AsyncResult is an alias for multiprocessing.pool.ApplyResult — its __name__ is 'ApplyResult' not 'AsyncResult'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.pool.Pool.__mro__.__len__()==2: Pool (in multiprocessing.pool) inherits directly from object; MRO: [multiprocessing.pool.Pool, object]. Verified with Python 3.14.3."
    - "multiprocessing.process.BaseProcess.__mro__.__len__()==2: BaseProcess (in multiprocessing.process) inherits directly from object; MRO: [multiprocessing.process.BaseProcess, object]. Verified with Python 3.14.3."
    - "multiprocessing.managers.BaseManager.__mro__.__len__()==2: BaseManager inherits directly from object; MRO: [multiprocessing.managers.BaseManager, object]. Verified with Python 3.14.3."
    - "multiprocessing.managers.SyncManager.__mro__.__len__()==3: SyncManager inherits from BaseManager; MRO: [multiprocessing.managers.SyncManager, multiprocessing.managers.BaseManager, object]. Verified with Python 3.14.3."
    - "multiprocessing.pool.AsyncResult.__name__=='ApplyResult' (NOT 'AsyncResult'); AsyncResult is an alias for ApplyResult; __mro__.__len__()==2: [multiprocessing.pool.ApplyResult, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool and process.BaseProcess MRO lengths — extra171
#
# multiprocessing.pool.Pool.__mro__.__len__()            == 2
# multiprocessing.process.BaseProcess.__mro__.__len__()  == 2
# ---------------------------------------------------------------------------

table multiprocessing_extra171.mp_pool_and_baseprocess_mro_len:
  description: "multiprocessing.pool.Pool and process.BaseProcess MRO length checks in mppoolbpmro171 namespace — multiprocessing.pool.Pool.__mro__.__len__()==2 (Pool is a Python class defined in multiprocessing.pool; it inherits directly from object with no intermediate base classes; MRO: [multiprocessing.pool.Pool, object]; Pool.__mro__[0].__name__=='Pool' and Pool.__mro__[1].__name__=='object'; despite Pool's rich API (42 methods in __dict__ from extra170), its inheritance chain is minimal — all Pool functionality is defined directly on Pool itself without mixin composition); multiprocessing.process.BaseProcess.__mro__.__len__()==2 (BaseProcess inherits directly from object; MRO: [multiprocessing.process.BaseProcess, object]; BaseProcess is the abstract root for all process types; COMPARISON: Pool.__mro__.__len__()==2 == BaseProcess.__mro__.__len__()==2 — both multiprocessing root classes have the minimal 2-entry MRO; this contrasts with asyncio which uses mixins (Queue and Lock have 3- and 4-entry MROs from extra173); multiprocessing's design prefers direct class definition over mixin composition; multiprocessing.managers.SyncManager.__mro__.__len__()==3 (cross-check: SyncManager > BaseManager > object — the only 3-entry chain in this spec); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppoolbpmro171

  columns: [id, function, args, expected, description]
  rows:
    - [pool_mro_len,  multiprocessing.pool.Pool.__mro__.__len__,             [],        2,  "Pool.__mro__.__len__() == 2 (Pool > object; no mixin bases despite 42-method dict); verified with Python 3.14.3"]
    - [bp_mro_len,    multiprocessing.process.BaseProcess.__mro__.__len__,   [],        2,  "BaseProcess.__mro__.__len__() == 2 (BaseProcess > object; minimal root class MRO); verified with Python 3.14.3"]
    - [pool_mro0_name, "multiprocessing.pool.Pool.__mro__[0].__name__.__eq__", ["Pool"],  true, "Pool.__mro__[0].__name__ == 'Pool' (Pool itself at index 0 of 2); verified with Python 3.14.3"]
    - [sm_mro_xchk,   multiprocessing.managers.SyncManager.__mro__.__len__,  [],        3,  "SyncManager.__mro__.__len__() == 3 (cross-check; SyncManager > BaseManager > object; only 3-entry chain in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.managers.BaseManager and SyncManager MRO lengths — extra171
#
# multiprocessing.managers.BaseManager.__mro__.__len__() == 2
# multiprocessing.managers.SyncManager.__mro__.__len__() == 3
# ---------------------------------------------------------------------------

table multiprocessing_extra171.mp_managers_mro_len:
  description: "multiprocessing.managers.BaseManager and SyncManager MRO length checks in mpmanagersmro171 namespace — multiprocessing.managers.BaseManager.__mro__.__len__()==2 (BaseManager is defined in multiprocessing.managers and inherits directly from object; MRO: [multiprocessing.managers.BaseManager, object]; BaseManager provides the base for creating shared-state servers; it starts a server process that holds managed objects; clients connect via proxies); multiprocessing.managers.BaseManager.__mro__[0].__name__.__eq__('BaseManager')==True (entry 0: 'BaseManager'=11: 'Base'=4+'Manager'=7=11); multiprocessing.managers.BaseManager.__mro__[1].__name__.__eq__('object')==True (entry 1: universal base); multiprocessing.managers.SyncManager.__mro__.__len__()==3 (SyncManager inherits from BaseManager; MRO: [multiprocessing.managers.SyncManager, multiprocessing.managers.BaseManager, object]; SyncManager is the most commonly used manager — it provides managed versions of list, dict, Namespace, Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Queue, Value, Array); multiprocessing.managers.SyncManager.__mro__[0].__name__=='SyncManager'; __mro__[1].__name__=='BaseManager'; __mro__[2].__name__=='object'; MRO ORDERING: Pool(2)==BaseProcess(2)==BaseManager(2) < SyncManager(3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmanagersmro171

  columns: [id, function, args, expected, description]
  rows:
    - [bm_mro_len,    multiprocessing.managers.BaseManager.__mro__.__len__,              [],               2,     "BaseManager.__mro__.__len__() == 2 (BaseManager > object; root manager class); verified with Python 3.14.3"]
    - [bm_mro0_name,  "multiprocessing.managers.BaseManager.__mro__[0].__name__.__eq__",   ["BaseManager"],  true,  "BaseManager.__mro__[0].__name__ == 'BaseManager' (len=11: 'Base'=4+'Manager'=7=11; entry 0 of 2); verified with Python 3.14.3"]
    - [sm_mro_len,    multiprocessing.managers.SyncManager.__mro__.__len__,               [],               3,     "SyncManager.__mro__.__len__() == 3 (SyncManager > BaseManager > object; the only 3-entry MRO in spec); verified with Python 3.14.3"]
    - [sm_mro1_name,  "multiprocessing.managers.SyncManager.__mro__[1].__name__.__eq__",   ["BaseManager"],  true,  "SyncManager.__mro__[1].__name__ == 'BaseManager' (SyncManager's base at index 1 of 3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.AsyncResult alias and MRO — extra171
#
# multiprocessing.pool.AsyncResult.__name__ == 'ApplyResult'  (NOT 'AsyncResult')
# multiprocessing.pool.AsyncResult.__mro__.__len__() == 2
# ---------------------------------------------------------------------------

table multiprocessing_extra171.mp_asyncresult_alias_and_mro:
  description: "multiprocessing.pool.AsyncResult alias and MRO checks in mpasyncresult171 namespace — multiprocessing.pool.AsyncResult.__name__.__eq__('ApplyResult')==True (KEY FINDING: multiprocessing.pool.AsyncResult.__name__=='ApplyResult' NOT 'AsyncResult'; AsyncResult is an ALIAS pointing to the ApplyResult class; the class's actual __name__ attribute reports its canonical name 'ApplyResult'; Pool.apply_async() returns an ApplyResult object; AsyncResult was introduced as an alias for the same class to provide a more generic name (since imap_async and starmap_async also return the same type); the alias mechanism means type(pool.apply_async(fn)).__name__=='ApplyResult' not 'AsyncResult'); multiprocessing.pool.AsyncResult.__name__.__len__()==11 ('ApplyResult'=11: 'Apply'=5+'Result'=6=11); multiprocessing.pool.AsyncResult.__mro__.__len__()==2 (the underlying ApplyResult class inherits directly from object; MRO: [multiprocessing.pool.ApplyResult, object]; len=2 consistent with the other multiprocessing root classes in this spec: Pool=2, BaseProcess=2, BaseManager=2); multiprocessing.pool.AsyncResult.__mro__[0].__name__.__eq__('ApplyResult')==True (entry 0 is ApplyResult not AsyncResult — confirms the alias); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpasyncresult171

  columns: [id, function, args, expected, description]
  rows:
    - [ar_name_eq,     multiprocessing.pool.AsyncResult.__name__.__eq__,             ["ApplyResult"],  true,  "AsyncResult.__name__ == 'ApplyResult' (KEY: AsyncResult is an alias for ApplyResult); verified with Python 3.14.3"]
    - [ar_name_len,    multiprocessing.pool.AsyncResult.__name__.__len__,             [],               11,    "AsyncResult.__name__.__len__() == 11 ('ApplyResult'=11: 'Apply'=5+'Result'=6=11); verified with Python 3.14.3"]
    - [ar_mro_len,     multiprocessing.pool.AsyncResult.__mro__.__len__,              [],               2,     "AsyncResult.__mro__.__len__() == 2 (ApplyResult > object; minimal 2-entry MRO; alias resolves to ApplyResult); verified with Python 3.14.3"]
    - [ar_mro0_name,   "multiprocessing.pool.AsyncResult.__mro__[0].__name__.__eq__",  ["ApplyResult"],  true,  "AsyncResult.__mro__[0].__name__ == 'ApplyResult' (confirms alias; canonical class name at index 0); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# MRO cross-comparison — extra171
# Pool(2), BaseProcess(2), BaseManager(2), SyncManager(3), AsyncResult/ApplyResult(2)
# ---------------------------------------------------------------------------

table multiprocessing_extra171.mp_mro_cross_comparison:
  description: "Cross-comparison of multiprocessing class MRO lengths in mpmroxcmp171 namespace — all root classes (Pool, BaseProcess, BaseManager, ApplyResult[via AsyncResult]) have MRO length 2; only SyncManager has length 3; multiprocessing.pool.Pool.__mro__.__len__()==2 (Pool > object); multiprocessing.process.BaseProcess.__mro__.__len__()==2 (BaseProcess > object); multiprocessing.managers.BaseManager.__mro__.__len__()==2 (BaseManager > object); multiprocessing.managers.SyncManager.__mro__.__len__()==3 (SyncManager > BaseManager > object; the one subclass in this spec); multiprocessing.pool.AsyncResult.__mro__.__len__()==2 (ApplyResult > object; alias resolves to 2-entry MRO); KEY PATTERN: multiprocessing's design philosophy uses DIRECT inheritance — root classes inherit only from object, and most classes add their functionality directly rather than through mixin composition; CONTRAST: asyncio uses mixins heavily (Lock has 4-entry MRO via _ContextManagerMixin and _LoopBoundMixin from extra173); multiprocessing prefers flat class hierarchies with all logic on the class itself; SIZE ORDERING in this spec: Pool(2)==BaseProcess(2)==BaseManager(2)==AsyncResult(2) < SyncManager(3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmroxcmp171

  columns: [id, function, args, expected, description]
  rows:
    - [pool_mro_xchk,  multiprocessing.pool.Pool.__mro__.__len__,             [],  2,  "Pool.__mro__.__len__() == 2 (Pool > object; no mixins despite 42 methods); verified with Python 3.14.3"]
    - [bp_mro_xchk,    multiprocessing.process.BaseProcess.__mro__.__len__,   [],  2,  "BaseProcess.__mro__.__len__() == 2 (BaseProcess > object); verified with Python 3.14.3"]
    - [bm_mro_xchk,    multiprocessing.managers.BaseManager.__mro__.__len__,  [],  2,  "BaseManager.__mro__.__len__() == 2 (BaseManager > object); verified with Python 3.14.3"]
    - [sm_mro_xchk,    multiprocessing.managers.SyncManager.__mro__.__len__,  [],  3,  "SyncManager.__mro__.__len__() == 3 (SyncManager > BaseManager > object; only 3 in spec); verified with Python 3.14.3"]
    - [ar_mro_xchk,    multiprocessing.pool.AsyncResult.__mro__.__len__,      [],  2,  "AsyncResult.__mro__.__len__() == 2 (ApplyResult alias > object); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra171
# ---------------------------------------------------------------------------

invariant multiprocessing_extra171.mp_Pool_mro_len:
  description: "multiprocessing.pool.Pool.__mro__.__len__() returns 2 — multiprocessing.pool.Pool.__mro__.__len__()==2; Pool inherits directly from object; MRO: [multiprocessing.pool.Pool, object]; this minimal 2-entry MRO is notable given that Pool has 42 entries in its __dict__ (from extra170 — the largest class dict in the entire spec series); Pool achieves all its functionality through direct class definition rather than mixin inheritance; COMPARISON WITHIN multiprocessing: Pool(2), BaseProcess(2), BaseManager(2), ApplyResult(2) — all root multiprocessing classes have the same minimal MRO; only SyncManager(3) has a longer chain; CROSS-MODULE COMPARISON: cf.Future(2), cf.Executor(2) from extra170; asyncio.Future(2) from extra173 — the 2-entry MRO is common to all root classes across these concurrency modules; NEW in extra171: first standalone Pool.__mro__.__len__ invariant in mppoolbpmro171 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__mro__.__len__
  args: []
  expected: 2

invariant multiprocessing_extra171.mp_BaseProcess_mro_len:
  description: "multiprocessing.process.BaseProcess.__mro__.__len__() returns 2 — multiprocessing.process.BaseProcess.__mro__.__len__()==2; MRO: [multiprocessing.process.BaseProcess, object]; BaseProcess is the abstract root for all process types (ForkProcess, SpawnProcess, etc.) yet inherits only from object; all process lifecycle management (start, join, terminate, kill, is_alive, close — from extra169) is defined directly on BaseProcess with no mixin delegation; CONTRAST: asyncio.Lock uses _ContextManagerMixin and _LoopBoundMixin (4-entry MRO from extra173) to compose 'async with' and loop-binding behavior; BaseProcess manually defines everything including __enter__/__exit__ directly; BaseProcess.__dict__.__len__()==27 (from extra169) — 27 direct entries all on BaseProcess itself; the flat 2-entry MRO is consistent with multiprocessing's general design philosophy of direct class definition; NEW in extra171: first standalone BaseProcess.__mro__.__len__ invariant in mppoolbpmro171 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__mro__.__len__
  args: []
  expected: 2

invariant multiprocessing_extra171.mp_BaseManager_mro_len:
  description: "multiprocessing.managers.BaseManager.__mro__.__len__() returns 2 — multiprocessing.managers.BaseManager.__mro__.__len__()==2; MRO: [multiprocessing.managers.BaseManager, object]; BaseManager provides the infrastructure for shared-state management across processes via proxy objects; the server process hosts the actual managed objects; clients access them through AutoProxy objects that forward attribute access across process boundaries; despite this complex architecture, BaseManager's inheritance chain is minimal — object is its only base class; COMPARISON: multiprocessing.managers.SyncManager.__mro__.__len__()==3 (SyncManager extends BaseManager by 1 entry; SyncManager adds register() calls for the standard synchronized types: list, dict, Lock, RLock, Queue, etc.); BaseManager.__module__=='multiprocessing.managers' (len=24: 'multiprocessing'=15+'.'=1+'managers'=8=24 — verified separately; 24 is the longest module path in the mp spec series alongside 'concurrent.futures._base'=24 from extra169); NEW in extra171: first standalone BaseManager.__mro__.__len__ invariant in mpmanagersmro171 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.__mro__.__len__
  args: []
  expected: 2

invariant multiprocessing_extra171.mp_SyncManager_mro_len:
  description: "multiprocessing.managers.SyncManager.__mro__.__len__() returns 3 — multiprocessing.managers.SyncManager.__mro__.__len__()==3; MRO: [multiprocessing.managers.SyncManager, multiprocessing.managers.BaseManager, object]; SyncManager is the canonical manager for sharing synchronized primitives across processes; it pre-registers: list, dict, Namespace, Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Queue, Value, and Array; SyncManager's 3-entry MRO makes it the only class in this spec with a non-minimal MRO chain (all others are 2-entry root classes); SyncManager.__mro__[1].__name__=='BaseManager' confirms the inheritance from the base manager; DESIGN NOTE: multiprocessing.Manager() returns an instance of SyncManager (started as a managed server process); this is the standard high-level API for shared state in multiprocessing; SyncManager(3) is structurally parallel to SyncManager's concurrent.futures analog: ThreadPoolExecutor and ProcessPoolExecutor also have 3-entry MROs (both from extra170); NEW in extra171: first standalone SyncManager.__mro__.__len__ invariant in mpmanagersmro171 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.SyncManager.__mro__.__len__
  args: []
  expected: 3

invariant multiprocessing_extra171.mp_AsyncResult_name_is_ApplyResult:
  description: "multiprocessing.pool.AsyncResult.__name__.__eq__('ApplyResult') returns True — KEY FINDING: multiprocessing.pool.AsyncResult.__name__=='ApplyResult' (NOT 'AsyncResult'); multiprocessing.pool.AsyncResult is an alias defined as AsyncResult = ApplyResult at the end of Lib/multiprocessing/pool.py; the class itself was originally named ApplyResult (because Pool.apply_async() returns it); AsyncResult was added as a more generic alias since the same result object is returned by apply_async(), map_async(), and starmap_async() — not just apply_async; the class's canonical __name__ is 'ApplyResult' because __name__ reflects the class's actual definition name, not any alias pointing to it; 'ApplyResult'=11: 'Apply'=5+'Result'=6=11; COMPARE: 'AsyncResult'=11 too ('Async'=5+'Result'=6=11 — both the alias name and the real name are 11 characters; coincidence!); NEW in extra171: first standalone AsyncResult.__name__ alias-resolution invariant in mpasyncresult171 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.AsyncResult.__name__.__eq__
  args: ["ApplyResult"]
  expected: true

invariant multiprocessing_extra171.mp_AsyncResult_mro_len:
  description: "multiprocessing.pool.AsyncResult.__mro__.__len__() returns 2 — multiprocessing.pool.AsyncResult.__mro__.__len__()==2; AsyncResult (actually ApplyResult) inherits directly from object; MRO: [multiprocessing.pool.ApplyResult, object]; the MRO shows 'ApplyResult' at index 0 (confirming the alias resolution — the canonical class name is ApplyResult); len=2 is consistent with all other multiprocessing root classes in this spec (Pool=2, BaseProcess=2, BaseManager=2, ApplyResult=2; only SyncManager=3); USAGE: Pool.apply_async(fn, args=()) returns an AsyncResult/ApplyResult; calling .get(timeout=None) on the result blocks until the computation completes and returns the result or raises the exception; .ready() checks if the call has completed; .successful() checks if it completed without raising; .get() is the primary method — all four methods (get, ready, successful, wait) are defined directly on ApplyResult in its 2-entry flat hierarchy; NEW in extra171: first standalone AsyncResult.__mro__.__len__ invariant in mpasyncresult171 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.AsyncResult.__mro__.__len__
  args: []
  expected: 2
