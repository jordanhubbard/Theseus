spec: os_extra6
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "CPython source: Lib/os.py"
  notes:
    - "This spec extends prior os specs."
    - "Focus: __module__ and __name__ for os functions not yet covered; os constants."
    - "os.sep == '/' on POSIX systems."
    - "os.linesep == '\\n' on POSIX systems."
    - "os.devnull == '/dev/null' on POSIX systems."
    - "os.curdir == '.'."
    - "os.pardir == '..'."
    - "os.extsep == '.'."
    - "os.F_OK == 0, os.R_OK == 4, os.W_OK == 2, os.X_OK == 1."
    - "os.SEEK_SET == 0, os.SEEK_CUR == 1, os.SEEK_END == 2."
    - "os.getenv.__name__ == 'getenv'."
    - "os.putenv.__name__ == 'putenv'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table os_extra6.access_constants:
  kind: python_call_eq
  category: constants
  id_prefix: access

  columns: [id, function, args, expected]
  rows:
    - [F_OK, F_OK.__eq__, [0], true]
    - [R_OK, R_OK.__eq__, [4], true]
    - [W_OK, W_OK.__eq__, [2], true]
    - [X_OK, X_OK.__eq__, [1], true]

table os_extra6.seek_constants:
  kind: python_call_eq
  category: constants
  id_prefix: seek

  columns: [id, function, args, expected]
  rows:
    - [SEEK_SET, SEEK_SET.__eq__, [0], true]
    - [SEEK_CUR, SEEK_CUR.__eq__, [1], true]
    - [SEEK_END, SEEK_END.__eq__, [2], true]

table os_extra6.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [getenv,   getenv.__name__.__eq__,   ["getenv"],   true]
    - [scandir,  scandir.__name__.__eq__,  ["scandir"],  true]
    - [listdir,  listdir.__name__.__eq__,  ["listdir"],  true]
    - [makedirs, makedirs.__name__.__eq__, ["makedirs"], true]
    - [removedirs, removedirs.__name__.__eq__, ["removedirs"], true]
    - [renames,  renames.__name__.__eq__,  ["renames"],  true]
    - [walk,     walk.__name__.__eq__,     ["walk"],     true]

invariant os_extra6.sep.posix_value:
  description: "os.sep == '/' on POSIX"
  category: constants
  kind: python_call_eq
  function: sep.__eq__
  args: ["/"]
  expected: true

invariant os_extra6.linesep.posix_value:
  description: "os.linesep == '\\n' on POSIX"
  category: constants
  kind: python_call_eq
  function: linesep.__eq__
  args: ["\n"]
  expected: true

invariant os_extra6.devnull.posix_value:
  description: "os.devnull == '/dev/null' on POSIX"
  category: constants
  kind: python_call_eq
  function: devnull.__eq__
  args: ["/dev/null"]
  expected: true

invariant os_extra6.curdir.value:
  description: "os.curdir == '.'"
  category: constants
  kind: python_call_eq
  function: curdir.__eq__
  args: ["."]
  expected: true

invariant os_extra6.pardir.value:
  description: "os.pardir == '..'"
  category: constants
  kind: python_call_eq
  function: pardir.__eq__
  args: [".."]
  expected: true

invariant os_extra6.extsep.value:
  description: "os.extsep == '.'"
  category: constants
  kind: python_call_eq
  function: extsep.__eq__
  args: ["."]
  expected: true

invariant os_extra6.error.class_name:
  description: "os.error.__name__ == 'OSError'"
  category: exceptions
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

invariant os_extra6.PathLike.class_name:
  description: "os.PathLike.__name__ == 'PathLike'"
  category: class_names
  kind: python_call_eq
  function: PathLike.__name__.__eq__
  args: ["PathLike"]
  expected: true
