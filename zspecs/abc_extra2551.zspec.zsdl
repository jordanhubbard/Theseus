spec: abc_extra2551
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Theme: __reduce__, __reduce_ex__, and __getnewargs__ dict-presence — checking whether abc classes define their own pickling/serialization protocol in their class __dict__."
    - "abc.ABC is a convenience base class whose only purpose is to carry ABCMeta as its metaclass. It holds no data that would warrant a custom pickling protocol. No __reduce__, __reduce_ex__, or __getnewargs__ defined in its class __dict__. Verified with Python 3.14."
    - "abc.ABCMeta is the metaclass that tracks abstract methods via __abstractmethods__ and manages virtual subclass registration. As a metaclass it is a type object; custom pickling dunders are not needed or defined. Verified with Python 3.14."
    - "Neither abc.ABC nor abc.ABCMeta carries application-level state that would require a custom serialization protocol; both rely on the default object pickling machinery inherited from object and type respectively. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABC — __reduce__/__reduce_ex__/__getnewargs__ absence
#
# Theme: pickling/serialization protocol absent from abc.ABC __dict__.
# ABC is a structural convenience class; it carries no instance data and
# therefore has no reason to define a custom pickling protocol.
# ---------------------------------------------------------------------------

table abc_extra2551.abc_pickle_protocol:
  description: "__reduce__, __reduce_ex__, __getnewargs__ absent from abc.ABC __dict__; wave 2551"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: ab2551

  columns: [id, function, args, expected]
  rows:
    - ["ab2551-001", abc.ABC.__dict__.__contains__, ["__reduce__"],     false]
    - ["ab2551-002", abc.ABC.__dict__.__contains__, ["__reduce_ex__"],  false]
    - ["ab2551-003", abc.ABC.__dict__.__contains__, ["__getnewargs__"], false]

# ---------------------------------------------------------------------------
# Table 2: abc.ABCMeta — __reduce__/__reduce_ex__/__getnewargs__ absence
#
# Theme: pickling/serialization protocol absent from abc.ABCMeta __dict__.
# ABCMeta is a metaclass (a subclass of type); it tracks abstract method sets
# and registered virtual subclasses, but defines no custom pickling dunders.
# ---------------------------------------------------------------------------

table abc_extra2551.abcmeta_pickle_protocol:
  description: "__reduce__, __reduce_ex__, __getnewargs__ absent from abc.ABCMeta __dict__; wave 2551"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: ab2551

  columns: [id, function, args, expected]
  rows:
    - ["ab2551-004", abc.ABCMeta.__dict__.__contains__, ["__reduce__"],     false]
    - ["ab2551-005", abc.ABCMeta.__dict__.__contains__, ["__reduce_ex__"],  false]
    - ["ab2551-006", abc.ABCMeta.__dict__.__contains__, ["__getnewargs__"], false]

# ---------------------------------------------------------------------------
# Table 3: cross-check — ABC and ABCMeta both absent for all three pickling dunders
#
# Symmetric cross-check: both abc.ABC and abc.ABCMeta lack __reduce__,
# __reduce_ex__, and __getnewargs__ in their own __dict__.
# This documents the full absence of custom pickling dispatch across
# the entire public abc class surface.
# ---------------------------------------------------------------------------

table abc_extra2551.cross_check_abc_abcmeta_pickle_absent:
  description: "__reduce__, __reduce_ex__, __getnewargs__ absent from both abc.ABC and abc.ABCMeta; wave 2551"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: ab2551

  columns: [id, function, args, expected]
  rows:
    - ["ab2551-007", abc.ABC.__dict__.__contains__,    ["__reduce__"],     false]
    - ["ab2551-008", abc.ABC.__dict__.__contains__,    ["__reduce_ex__"],  false]
    - ["ab2551-009", abc.ABC.__dict__.__contains__,    ["__getnewargs__"], false]
    - ["ab2551-010", abc.ABCMeta.__dict__.__contains__, ["__reduce__"],     false]
    - ["ab2551-011", abc.ABCMeta.__dict__.__contains__, ["__reduce_ex__"],  false]
    - ["ab2551-012", abc.ABCMeta.__dict__.__contains__, ["__getnewargs__"], false]

# ---------------------------------------------------------------------------
# Table 4: abc.ABC and abc.ABCMeta — __reduce__ parity note
#
# __reduce__ is the primary pickle dispatch hook. Neither ABC (a plain class)
# nor ABCMeta (a metaclass) overrides __reduce__ — both rely entirely on the
# default pickle machinery provided by object and type respectively.
# Documented as a standalone table to explicitly capture the __reduce__
# non-override as a design property of the abc module.
# ---------------------------------------------------------------------------

table abc_extra2551.reduce_parity:
  description: "__reduce__ absent from abc.ABC and abc.ABCMeta; both rely on default pickle machinery; wave 2551"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: ab2551

  columns: [id, function, args, expected]
  rows:
    - ["ab2551-013", abc.ABC.__dict__.__contains__,    ["__reduce__"], false]
    - ["ab2551-014", abc.ABCMeta.__dict__.__contains__, ["__reduce__"], false]

# ---------------------------------------------------------------------------
# Table 5: abc.ABC and abc.ABCMeta — __getnewargs__ parity note
#
# __getnewargs__ provides positional arguments to __new__ during unpickling.
# ABC has no constructor arguments that would need to be preserved this way.
# ABCMeta as a metaclass is reconstructed by type pickling, not __getnewargs__.
# Documented as a standalone table to make the __getnewargs__ non-definition
# explicit alongside the __reduce__ non-override above.
# ---------------------------------------------------------------------------

table abc_extra2551.getnewargs_parity:
  description: "__getnewargs__ absent from abc.ABC and abc.ABCMeta; neither uses __new__-based pickling reconstruction; wave 2551"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: ab2551

  columns: [id, function, args, expected]
  rows:
    - ["ab2551-015", abc.ABC.__dict__.__contains__,    ["__getnewargs__"], false]
    - ["ab2551-016", abc.ABCMeta.__dict__.__contains__, ["__getnewargs__"], false]
