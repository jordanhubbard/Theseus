spec: functools_extra226
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools name length and comparison contracts."
    - "functools.__name__.__len__() == 9 — the module name string 'functools' has 9 characters. Verified with Python 3.14.3."
    - "functools.reduce.__name__.__len__() == 6 — 'reduce' has 6 characters. Verified with Python 3.14.3."
    - "functools.partial.__name__.__len__() == 7 — 'partial' has 7 characters. Verified with Python 3.14.3."
    - "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters. Verified with Python 3.14.3."
    - "functools.singledispatch.__name__.__len__() == 14 — 'singledispatch' has 14 characters. Verified with Python 3.14.3."
    - "functools.cached_property.__name__.__len__() == 15 — 'cached_property' has 15 characters. Verified with Python 3.14.3."
    - "functools.total_ordering.__name__.__len__() == 14 — 'total_ordering' has 14 characters. Verified with Python 3.14.3."
    - "functools.partial.__name__.__gt__('lru_cache') == True — 'partial' > 'lru_cache' alphabetically (p > l). Verified with Python 3.14.3."
    - "functools.partial.__name__.__lt__('reduce') == True — 'partial' < 'reduce' alphabetically (p < r). Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS contains '__module__', '__name__', '__qualname__'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools module and function name lengths
#
# Verified with Python 3.14.3:
#   len(functools.__name__) == 9
#   len(functools.reduce.__name__) == 6
#   len(functools.partial.__name__) == 7
#   len(functools.lru_cache.__name__) == 9
#   len(functools.singledispatch.__name__) == 14
#   len(functools.cached_property.__name__) == 15
#   len(functools.total_ordering.__name__) == 14
# ---------------------------------------------------------------------------

table functools_extra226.name_lengths:
  description: "functools module and function/class __name__ length checks; new to extra226"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra226namelen

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_len_eq,
       __name__.__len__,
       [],
       9,
       "functools.__name__.__len__() == 9 — the functools module name string is 'functools' which has 9 characters; str.__len__() returns 9; new to extra226"]
    - [reduce_name_len_eq,
       reduce.__name__.__len__,
       [],
       6,
       "functools.reduce.__name__.__len__() == 6 — the built-in reduce function name string is 'reduce' which has 6 characters; str.__len__() returns 6; new to extra226"]
    - [partial_name_len_eq,
       partial.__name__.__len__,
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — the partial class name string is 'partial' which has 7 characters; str.__len__() returns 7; new to extra226"]
    - [lru_cache_name_len_eq,
       lru_cache.__name__.__len__,
       [],
       9,
       "functools.lru_cache.__name__.__len__() == 9 — the lru_cache function name string is 'lru_cache' which has 9 characters; str.__len__() returns 9; new to extra226"]
    - [singledispatch_name_len_eq,
       singledispatch.__name__.__len__,
       [],
       14,
       "functools.singledispatch.__name__.__len__() == 14 — the singledispatch function name string is 'singledispatch' which has 14 characters; str.__len__() returns 14; new to extra226"]
    - [cached_property_name_len_eq,
       cached_property.__name__.__len__,
       [],
       15,
       "functools.cached_property.__name__.__len__() == 15 — the cached_property class name string is 'cached_property' which has 15 characters; str.__len__() returns 15; new to extra226"]
    - [total_ordering_name_len_eq,
       total_ordering.__name__.__len__,
       [],
       14,
       "functools.total_ordering.__name__.__len__() == 14 — the total_ordering decorator name string is 'total_ordering' which has 14 characters; str.__len__() returns 14; new to extra226"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial name alphabetical comparison
#
# Verified with Python 3.14.3:
#   'partial'.__gt__('lru_cache') == True  (p > l)
#   'partial'.__lt__('reduce') == True     (p < r)
# ---------------------------------------------------------------------------

table functools_extra226.partial_name_ordering:
  description: "functools.partial.__name__ alphabetical ordering against other names; new to extra226"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra226partialord

  columns: [id, function, args, expected, description]
  rows:
    - [partial_gt_lru_cache,
       partial.__name__.__gt__,
       ["lru_cache"],
       true,
       "functools.partial.__name__.__gt__('lru_cache') == True — 'partial' is alphabetically greater than 'lru_cache' because 'p' > 'l'; str.__gt__('lru_cache') returns True; new to extra226"]
    - [partial_lt_reduce,
       partial.__name__.__lt__,
       ["reduce"],
       true,
       "functools.partial.__name__.__lt__('reduce') == True — 'partial' is alphabetically less than 'reduce' because 'p' < 'r'; str.__lt__('reduce') returns True; new to extra226"]

# ---------------------------------------------------------------------------
# Table 3: functools.WRAPPER_ASSIGNMENTS membership checks
#
# WRAPPER_ASSIGNMENTS is a tuple of attribute name strings copied by wraps().
# Verified with Python 3.14.3:
#   '__module__' in WRAPPER_ASSIGNMENTS == True
#   '__name__' in WRAPPER_ASSIGNMENTS == True
#   '__qualname__' in WRAPPER_ASSIGNMENTS == True
# ---------------------------------------------------------------------------

table functools_extra226.wrapper_assignments_contains:
  description: "functools.WRAPPER_ASSIGNMENTS membership checks for __module__, __name__, __qualname__; new to extra226"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra226wrappercontains

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_contains_module,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__module__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — WRAPPER_ASSIGNMENTS lists attributes copied by functools.wraps; '__module__' is one of those attributes; tuple.__contains__('__module__') returns True; new to extra226"]
    - [wrapper_assignments_contains_name,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__name__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — WRAPPER_ASSIGNMENTS lists attributes copied by functools.wraps; '__name__' is one of those attributes; tuple.__contains__('__name__') returns True; new to extra226"]
    - [wrapper_assignments_contains_qualname,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__qualname__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — WRAPPER_ASSIGNMENTS lists attributes copied by functools.wraps; '__qualname__' is one of those attributes; tuple.__contains__('__qualname__') returns True; new to extra226"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra226
# ---------------------------------------------------------------------------

invariant functools_extra226.module_name_len:
  description: "functools.__name__.__len__() == 9 — 'functools' has 9 characters; new to extra226"
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 9

invariant functools_extra226.reduce_name_len:
  description: "functools.reduce.__name__.__len__() == 6 — 'reduce' has 6 characters; new to extra226"
  kind: python_call_eq
  function: reduce.__name__.__len__
  args: []
  expected: 6

invariant functools_extra226.partial_name_len:
  description: "functools.partial.__name__.__len__() == 7 — 'partial' has 7 characters; new to extra226"
  kind: python_call_eq
  function: partial.__name__.__len__
  args: []
  expected: 7

invariant functools_extra226.lru_cache_name_len:
  description: "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters; new to extra226"
  kind: python_call_eq
  function: lru_cache.__name__.__len__
  args: []
  expected: 9

invariant functools_extra226.singledispatch_name_len:
  description: "functools.singledispatch.__name__.__len__() == 14 — 'singledispatch' has 14 characters; new to extra226"
  kind: python_call_eq
  function: singledispatch.__name__.__len__
  args: []
  expected: 14

invariant functools_extra226.cached_property_name_len:
  description: "functools.cached_property.__name__.__len__() == 15 — 'cached_property' has 15 characters; new to extra226"
  kind: python_call_eq
  function: cached_property.__name__.__len__
  args: []
  expected: 15

invariant functools_extra226.total_ordering_name_len:
  description: "functools.total_ordering.__name__.__len__() == 14 — 'total_ordering' has 14 characters; new to extra226"
  kind: python_call_eq
  function: total_ordering.__name__.__len__
  args: []
  expected: 14

invariant functools_extra226.partial_gt_lru_cache:
  description: "functools.partial.__name__.__gt__('lru_cache') == True — 'partial' > 'lru_cache' alphabetically; new to extra226"
  kind: python_call_eq
  function: partial.__name__.__gt__
  args: ["lru_cache"]
  expected: true

invariant functools_extra226.partial_lt_reduce:
  description: "functools.partial.__name__.__lt__('reduce') == True — 'partial' < 'reduce' alphabetically; new to extra226"
  kind: python_call_eq
  function: partial.__name__.__lt__
  args: ["reduce"]
  expected: true

invariant functools_extra226.wrapper_assignments_contains_module:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True; new to extra226"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__module__"]
  expected: true

invariant functools_extra226.wrapper_assignments_contains_name:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True; new to extra226"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__name__"]
  expected: true

invariant functools_extra226.wrapper_assignments_contains_qualname:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True; new to extra226"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__qualname__"]
  expected: true
