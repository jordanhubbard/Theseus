spec: socket_extra2326
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
    - "POSIX.1-2017"
    - "IANA protocol number registry"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2326 (_extra2326): numeric constants and fixed-size attribute checks."
    - "Covers AF_, SOCK_, SOL_, SO_, and IPPROTO_ integer constants on macOS/Darwin."
    - "AF_INET=2 and AF_UNIX=1 are universally stable POSIX constants."
    - "AF_INET6=30 on macOS/Darwin (10 on Linux) — platform-specific, verified on Darwin 25.4.0."
    - "SOL_SOCKET=65535 on macOS/Darwin (1 on Linux) — platform-specific, verified on Darwin 25.4.0."
    - "SO_REUSEADDR=4 on macOS/Darwin (2 on Linux) — platform-specific, verified on Darwin 25.4.0."
    - "SOCK_STREAM=1, SOCK_DGRAM=2, SOCK_RAW=3 are stable POSIX constants."
    - "IPPROTO_TCP=6, IPPROTO_UDP=17, IPPROTO_IP=0 are IANA-assigned and universally stable."
    - "AF_INET and AF_INET6 are AddressFamily IntEnum members; SOCK_* are SocketKind IntEnum members."
    - "SOL_SOCKET, SO_REUSEADDR, and IPPROTO_* are plain int constants in the socket module."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: Address family integer values
#
# AF_INET6 value is Darwin-specific (30).  AF_INET and AF_UNIX are POSIX.
# Values accessed via the IntEnum .value attribute since AF_* are IntEnum.
# ---------------------------------------------------------------------------

table socket_extra2326.address_family_values:
  description: "socket address family enum integer values (macOS/Darwin platform)"
  kind: python_call_eq
  category: constants
  id_prefix: sk2326

  columns: [id, function, args, expected]
  rows:
    - ["sk2326001", "socket.AF_INET.__eq__",  [2],  true]
    - ["sk2326002", "socket.AF_INET6.__eq__", [30], true]
    - ["sk2326003", "socket.AF_UNIX.__eq__",  [1],  true]

# ---------------------------------------------------------------------------
# Table 2: Address family class names
# ---------------------------------------------------------------------------

table socket_extra2326.address_family_class_names:
  description: "socket address family enum member class names"
  kind: python_call_eq
  category: constants
  id_prefix: sk2326

  columns: [id, function, args, expected]
  rows:
    - ["sk2326004", "socket.AF_INET.__class__.__name__",  [], "AddressFamily"]
    - ["sk2326005", "socket.AF_INET6.__class__.__name__", [], "AddressFamily"]
    - ["sk2326006", "socket.AF_UNIX.__class__.__name__",  [], "AddressFamily"]

# ---------------------------------------------------------------------------
# Table 3: Socket type integer values
# ---------------------------------------------------------------------------

table socket_extra2326.socket_type_values:
  description: "socket type enum integer values (stable POSIX constants)"
  kind: python_call_eq
  category: constants
  id_prefix: sk2326

  columns: [id, function, args, expected]
  rows:
    - ["sk2326007", "socket.SOCK_STREAM.__eq__", [1], true]
    - ["sk2326008", "socket.SOCK_DGRAM.__eq__",  [2], true]
    - ["sk2326009", "socket.SOCK_RAW.__eq__",    [3], true]

# ---------------------------------------------------------------------------
# Table 4: Socket type class names
# ---------------------------------------------------------------------------

table socket_extra2326.socket_type_class_names:
  description: "socket type enum member class names"
  kind: python_call_eq
  category: constants
  id_prefix: sk2326

  columns: [id, function, args, expected]
  rows:
    - ["sk2326010", "socket.SOCK_STREAM.__class__.__name__", [], "SocketKind"]
    - ["sk2326011", "socket.SOCK_DGRAM.__class__.__name__",  [], "SocketKind"]
    - ["sk2326012", "socket.SOCK_RAW.__class__.__name__",    [], "SocketKind"]

# ---------------------------------------------------------------------------
# Table 5: SOL_SOCKET and SO_REUSEADDR integer values
#
# Both are plain int constants (not enum members) on macOS.
# SOL_SOCKET=65535 on macOS (0xFFFF); SO_REUSEADDR=4 on macOS.
# ---------------------------------------------------------------------------

table socket_extra2326.sol_and_so_values:
  description: "socket SOL_SOCKET and SO_REUSEADDR integer values (macOS/Darwin platform)"
  kind: python_call_eq
  category: constants
  id_prefix: sk2326

  columns: [id, function, args, expected]
  rows:
    - ["sk2326013", "socket.SOL_SOCKET.__eq__",   [65535], true]
    - ["sk2326014", "socket.SO_REUSEADDR.__eq__",  [4],    true]
    - ["sk2326015", "socket.SOL_SOCKET.__class__.__name__",   [], "int"]
    - ["sk2326016", "socket.SO_REUSEADDR.__class__.__name__", [], "int"]

# ---------------------------------------------------------------------------
# Table 6: IPPROTO_ protocol number constants
#
# IANA-assigned protocol numbers — universally stable across platforms.
# These are plain int constants in the socket module.
# ---------------------------------------------------------------------------

table socket_extra2326.ipproto_values:
  description: "socket IPPROTO_ protocol number constants (IANA-assigned, platform-stable)"
  kind: python_call_eq
  category: constants
  id_prefix: sk2326

  columns: [id, function, args, expected]
  rows:
    - ["sk2326017", "socket.IPPROTO_IP.__eq__",  [0],  true]
    - ["sk2326018", "socket.IPPROTO_TCP.__eq__", [6],  true]
    - ["sk2326019", "socket.IPPROTO_UDP.__eq__", [17], true]
    - ["sk2326020", "socket.IPPROTO_TCP.__class__.__name__", [], "int"]
    - ["sk2326021", "socket.IPPROTO_UDP.__class__.__name__", [], "int"]
    - ["sk2326022", "socket.IPPROTO_IP.__class__.__name__",  [], "int"]
