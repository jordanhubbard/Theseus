spec: abc_extra961
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module ABCMeta and ABC class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __dict__, __weakref__, and __builtins__ class name identity for abc.ABCMeta, abc.ABC, and abc.abstractmethod"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra961.dict_class_name_attrs:
  description: "abc.ABCMeta, abc.ABC, abc.abstractmethod __dict__.__class__.__name__ identity"
  kind: python_call_eq
  category: dict_attrs
  id_prefix: ab961dc
  columns: [id, function, args, expected]
  rows:
    - [ab961dc001, abc.ABCMeta.__dict__.__class__.__name__.__eq__,        ["mappingproxy"], true]
    - [ab961dc002, abc.ABC.__dict__.__class__.__name__.__eq__,            ["mappingproxy"], true]
    - [ab961dc003, abc.abstractmethod.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

table abc_extra961.weakref_descriptor_attrs:
  description: "abc.ABCMeta and abc.ABC __weakref__.__class__.__name__ identity"
  kind: python_call_eq
  category: weakref_attrs
  id_prefix: ab961wr
  columns: [id, function, args, expected]
  rows:
    - [ab961wr001, abc.ABCMeta.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [ab961wr002, abc.ABC.__weakref__.__class__.__name__.__eq__,     ["getset_descriptor"], true]

table abc_extra961.builtins_class_name_attrs:
  description: "abc module __builtins__.__class__.__name__ identity"
  kind: python_call_eq
  category: builtins_attrs
  id_prefix: ab961bi
  columns: [id, function, args, expected]
  rows:
    - [ab961bi001, abc.__builtins__.__class__.__name__.__eq__, ["dict"],   true]

table abc_extra961.abcmeta_class_identity:
  description: "abc.ABCMeta and abc.ABC additional class identity checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: ab961ci
  columns: [id, function, args, expected]
  rows:
    - [ab961ci001, abc.ABCMeta.__name__.__eq__,            ["ABCMeta"],     true]
    - [ab961ci002, abc.ABCMeta.__module__.__eq__,          ["abc"],         true]
    - [ab961ci003, abc.ABCMeta.__qualname__.__eq__,        ["ABCMeta"],     true]
    - [ab961ci004, abc.ABC.__name__.__eq__,                ["ABC"],         true]
    - [ab961ci005, abc.ABC.__module__.__eq__,              ["abc"],         true]
    - [ab961ci006, abc.ABC.__qualname__.__eq__,            ["ABC"],         true]
    - [ab961ci007, abc.abstractmethod.__name__.__eq__,     ["abstractmethod"], true]
    - [ab961ci008, abc.abstractmethod.__module__.__eq__,   ["abc"],            true]
    - [ab961ci009, abc.abstractmethod.__qualname__.__eq__, ["abstractmethod"], true]
    - [ab961ci010, abc.__name__.__eq__,                    ["abc"],            true]
    - [ab961ci011, abc.__spec__.name.__eq__,               ["abc"],            true]
    - [ab961ci012, abc.__package__.__eq__,                 [""],               true]
