spec: pathlib_extra81
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra80."
    - "Prior specs covered: PurePath/Path class identity; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes for open/read_text/write_text/iterdir/mkdir/exists/unlink/stat/rename; PurePath/__dict__ membership; Path/__dict__ membership."
    - "pathlib_extra80 covers Path.mkdir/exists/unlink/stat/rename __code__.co_name and co_argcount."
    - "This spec covers: Path.read_bytes/write_bytes/touch/rmdir/resolve __code__.co_name and co_argcount."
    - "pathlib.Path.read_bytes.__code__.co_name == 'read_bytes' — verified by code object attribute."
    - "pathlib.Path.read_bytes.__code__.co_argcount == 1 — read_bytes(self): only self, no other positional-or-keyword parameters."
    - "pathlib.Path.write_bytes.__code__.co_name == 'write_bytes' — verified by code object attribute."
    - "pathlib.Path.write_bytes.__code__.co_argcount == 2 — write_bytes(self, data): self + data."
    - "pathlib.Path.touch.__code__.co_name == 'touch' — verified by code object attribute."
    - "pathlib.Path.touch.__code__.co_argcount == 3 — touch(self, mode=438, exist_ok=True): self + mode + exist_ok, all positional-or-keyword."
    - "pathlib.Path.rmdir.__code__.co_name == 'rmdir' — verified by code object attribute."
    - "pathlib.Path.rmdir.__code__.co_argcount == 1 — rmdir(self): only self, no other positional-or-keyword parameters."
    - "pathlib.Path.resolve.__code__.co_name == 'resolve' — verified by code object attribute."
    - "pathlib.Path.resolve.__code__.co_argcount == 2 — resolve(self, strict=False): self + strict, both positional-or-keyword (strict is NOT keyword-only in Python 3.14.3)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.read_bytes and Path.write_bytes __code__ attributes
# read_bytes(self): co_argcount == 1 (no parameters beyond self).
# write_bytes(self, data): co_argcount == 2 (self + data).
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra81.read_bytes_write_bytes_code:
  description: "Path.read_bytes and Path.write_bytes __code__ co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore81

  columns: [id, function, args, expected]
  rows:
    - [read_bytes_co_name,  Path.read_bytes.__code__.co_name.__eq__,     ["read_bytes"],  true]
    - [read_bytes_co_argc,  Path.read_bytes.__code__.co_argcount.__eq__,  [1],            true]
    - [write_bytes_co_name, Path.write_bytes.__code__.co_name.__eq__,    ["write_bytes"], true]
    - [write_bytes_co_argc, Path.write_bytes.__code__.co_argcount.__eq__, [2],            true]

# ---------------------------------------------------------------------------
# Path.touch and Path.rmdir __code__ attributes
# touch(self, mode=438, exist_ok=True): co_argcount == 3 (all positional-or-keyword).
# rmdir(self): co_argcount == 1 (only self).
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra81.touch_rmdir_code:
  description: "Path.touch and Path.rmdir __code__ co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore81

  columns: [id, function, args, expected]
  rows:
    - [touch_co_name, Path.touch.__code__.co_name.__eq__,    ["touch"], true]
    - [touch_co_argc, Path.touch.__code__.co_argcount.__eq__, [3],      true]
    - [rmdir_co_name, Path.rmdir.__code__.co_name.__eq__,    ["rmdir"], true]
    - [rmdir_co_argc, Path.rmdir.__code__.co_argcount.__eq__, [1],      true]

# ---------------------------------------------------------------------------
# Path.resolve __code__ attributes
# resolve(self, strict=False): co_argcount == 2 in Python 3.14.3.
# strict is positional-or-keyword (not keyword-only) in this version.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra81.resolve_code:
  description: "Path.resolve __code__ co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore81

  columns: [id, function, args, expected]
  rows:
    - [resolve_co_name, Path.resolve.__code__.co_name.__eq__,    ["resolve"], true]
    - [resolve_co_argc, Path.resolve.__code__.co_argcount.__eq__, [2],        true]

# ---------------------------------------------------------------------------
# Combined co_name identity for read_bytes/write_bytes/touch/rmdir/resolve
# Confirms that all five method code objects carry the correct co_name.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra81.method_code_names:
  description: "Path method __code__.co_name values match their method names"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore81

  columns: [id, function, args, expected]
  rows:
    - [read_bytes_name,  Path.read_bytes.__code__.co_name.__eq__,  ["read_bytes"],  true]
    - [write_bytes_name, Path.write_bytes.__code__.co_name.__eq__, ["write_bytes"], true]
    - [touch_name,       Path.touch.__code__.co_name.__eq__,       ["touch"],       true]
    - [rmdir_name,       Path.rmdir.__code__.co_name.__eq__,       ["rmdir"],       true]
    - [resolve_name,     Path.resolve.__code__.co_name.__eq__,     ["resolve"],     true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra81.read_bytes_code.co_name:
  description: "pathlib.Path.read_bytes.__code__.co_name == 'read_bytes'"
  category: code_attrs
  kind: python_call_eq
  function: Path.read_bytes.__code__.co_name.__eq__
  args: ["read_bytes"]
  expected: true

invariant pathlib_extra81.read_bytes_code.co_argcount:
  description: "pathlib.Path.read_bytes.__code__.co_argcount == 1 (only self)"
  category: code_attrs
  kind: python_call_eq
  function: Path.read_bytes.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant pathlib_extra81.write_bytes_code.co_argcount:
  description: "pathlib.Path.write_bytes.__code__.co_argcount == 2 (self + data)"
  category: code_attrs
  kind: python_call_eq
  function: Path.write_bytes.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant pathlib_extra81.touch_code.co_argcount:
  description: "pathlib.Path.touch.__code__.co_argcount == 3 (self, mode, exist_ok)"
  category: code_attrs
  kind: python_call_eq
  function: Path.touch.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant pathlib_extra81.resolve_code.co_argcount:
  description: "pathlib.Path.resolve.__code__.co_argcount == 2 (self + strict; strict is positional-or-keyword)"
  category: code_attrs
  kind: python_call_eq
  function: Path.resolve.__code__.co_argcount.__eq__
  args: [2]
  expected: true
