spec: functools_extra46
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra45.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps/partial/lru_cache/total_ordering/singledispatch/cached_property/reduce/cmp_to_key/partialmethod/singledispatchmethod/update_wrapper; __qualname__.__len__() for update_wrapper/partialmethod/singledispatchmethod/cache/total_ordering/singledispatch/cmp_to_key/cached_property/lru_cache/wraps/reduce/partial; WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES lengths; __all__ lengths and indexed elements; partial/__class__.__name__; cached_property.__set_name__/__get__/__init__.__qualname__; total_ordering.__dict__.__class__.__name__; partial/__new__.__qualname__; class __dict__.__class__.__name__.__len__ for partial/partialmethod/singledispatchmethod/cached_property; partial/__doc__/reduce/__doc__; reduce with initial value; lru_cache(128).__ne__(None)==True; C-extension vs pure-Python __module__ lengths; lru_cache(maxsize=2) behavioral; reduce.__qualname__=='reduce'; lru_cache.__qualname__=='lru_cache'; cache.__name__=='cache'; cache.__qualname__=='cache'; cache.__module__=='functools'; cached_property.__name__=='cached_property'; cached_property.__module__=='functools'."
    - "This spec covers: functools.cached_property.__qualname__ == 'cached_property' (string equality, 15 chars — same as __name__ because cached_property is a top-level class with no enclosing scope); functools.cached_property.__qualname__.__len__() == 15; functools.cached_property.__bases__[0].__name__ == 'object' (cached_property inherits directly from object); functools.total_ordering.__name__ == 'total_ordering'; functools.total_ordering.__module__ == 'functools'; functools.total_ordering.__qualname__ == 'total_ordering'; functools.singledispatch.__name__ == 'singledispatch'; functools.singledispatch.__module__ == 'functools'; functools.singledispatch.__qualname__ == 'singledispatch'."
    - "Key findings: functools.cached_property.__qualname__ is 'cached_property' (15 chars) — same as __name__ because cached_property is defined at module level in Lib/functools.py with no enclosing class scope, so __qualname__ == __name__. functools.cached_property.__bases__[0].__name__ is 'object' — cached_property is a pure-Python descriptor class that inherits directly from object (single-level inheritance). functools.total_ordering.__name__ and __qualname__ are both 'total_ordering' (14 chars) and __module__ is 'functools' (9 chars). functools.singledispatch.__name__ and __qualname__ are both 'singledispatch' (14 chars) and __module__ is 'functools' (9 chars). total_ordering and singledispatch share the same __name__ and __qualname__ length (14 chars). Prior specs recorded __qualname__.__len__() for total_ordering and singledispatch but not the string equality invariants for __name__, __module__, or __qualname__; the cached_property __qualname__ string equality and __bases__[0].__name__ are new to this namespace."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.cached_property __qualname__ and __bases__ — extra46 namespace
#
# functools.cached_property.__qualname__ is 'cached_property' (15 chars) —
# same as __name__ because cached_property is a module-level class definition
# in Lib/functools.py with no enclosing class scope (__qualname__ == __name__
# for top-level classes). functools.cached_property.__bases__[0].__name__ is
# 'object' — cached_property inherits directly from object (no intermediate
# base class). Prior specs recorded __name__ == 'cached_property' (extra45)
# and __qualname__.__len__() but not the __qualname__ string equality nor
# the __bases__[0].__name__ equality. These three invariants are new to the
# extra46 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra46.cached_property_qualname:
  description: "functools.cached_property.__qualname__ == 'cached_property' — module-level class; __qualname__ == __name__ (no enclosing class scope); 15 chars; same value as __name__"
  category: identity
  kind: python_call_eq
  function: cached_property.__qualname__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra46.cached_property_qualname_len:
  description: "len(functools.cached_property.__qualname__) == 15 — 'cached_property'; same length as __name__.__len__() == 15; longest qualname/name among the major functools objects"
  category: string_properties
  kind: python_call_eq
  function: cached_property.__qualname__.__len__
  args: []
  expected: 15

invariant functools_extra46.cached_property_bases_name:
  description: "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property inherits directly from object; no intermediate base class; single-level inheritance"
  category: class_hierarchy
  kind: python_call_eq
  function: "cached_property.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# functools.total_ordering identity metadata — extra46 namespace
#
# functools.total_ordering.__name__ is 'total_ordering' (14 chars),
# functools.total_ordering.__module__ is 'functools' (9 chars), and
# functools.total_ordering.__qualname__ is 'total_ordering' (14 chars).
# total_ordering is a class decorator defined at module level in
# Lib/functools.py; as a top-level class, __qualname__ == __name__. Prior
# specs recorded __name__.__len__()==14 and __qualname__.__len__()==14 but
# not the string equality invariants for __name__, __module__, or __qualname__.
# These three equality invariants are new to the extra46 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra46.total_ordering_name:
  description: "functools.total_ordering.__name__ == 'total_ordering' — class decorator; pure-Python class defined at module level; 14-char name; same length as singledispatch.__name__"
  category: identity
  kind: python_call_eq
  function: total_ordering.__name__.__eq__
  args: ["total_ordering"]
  expected: true

invariant functools_extra46.total_ordering_module:
  description: "functools.total_ordering.__module__ == 'functools' — pure-Python class defined in Lib/functools.py; 9-char module name"
  category: module_metadata
  kind: python_call_eq
  function: total_ordering.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra46.total_ordering_qualname:
  description: "functools.total_ordering.__qualname__ == 'total_ordering' — module-level class; __qualname__ == __name__ (no enclosing class scope); 14 chars; same as singledispatch.__qualname__"
  category: identity
  kind: python_call_eq
  function: total_ordering.__qualname__.__eq__
  args: ["total_ordering"]
  expected: true

# ---------------------------------------------------------------------------
# functools.singledispatch identity metadata — extra46 namespace
#
# functools.singledispatch.__name__ is 'singledispatch' (14 chars),
# functools.singledispatch.__module__ is 'functools' (9 chars), and
# functools.singledispatch.__qualname__ is 'singledispatch' (14 chars).
# singledispatch is a function decorator defined at module level in
# Lib/functools.py; as a top-level function, __qualname__ == __name__.
# total_ordering and singledispatch share the same 14-char __name__ and
# __qualname__ lengths. Prior specs recorded __name__.__len__()==14 and
# __qualname__.__len__()==14 but not the string equality invariants.
# These three equality invariants are new to the extra46 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra46.singledispatch_name:
  description: "functools.singledispatch.__name__ == 'singledispatch' — function decorator enabling single-dispatch generic functions; pure-Python; 14-char name; same length as total_ordering.__name__"
  category: identity
  kind: python_call_eq
  function: singledispatch.__name__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra46.singledispatch_module:
  description: "functools.singledispatch.__module__ == 'functools' — pure-Python function defined in Lib/functools.py; 9-char module name; same as total_ordering.__module__"
  category: module_metadata
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra46.singledispatch_qualname:
  description: "functools.singledispatch.__qualname__ == 'singledispatch' — module-level function; __qualname__ == __name__ (no enclosing class scope); 14 chars; same as total_ordering.__qualname__"
  category: identity
  kind: python_call_eq
  function: singledispatch.__qualname__.__eq__
  args: ["singledispatch"]
  expected: true
