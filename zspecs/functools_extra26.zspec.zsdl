spec: functools_extra26
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools.zspec.zsdl and prior extras through functools_extra25.zspec.zsdl."
    - "functools_extra25 covers: __bases__[0].__name__.__eq__ for partial/partialmethod/cached_property; qualname for same three; WRAPPER_UPDATES len; reduce/__module__ and singledispatch/__module__."
    - "functools_extra24 covers: __name__.__eq__ for cache/cached_property/singledispatch/total_ordering/wraps; WRAPPER_ASSIGNMENTS class name and len; reduce.__qualname__ anchor."
    - "No prior functools spec records __qualname__.__eq__ for reduce/lru_cache/cache/wraps/total_ordering/singledispatch/cached_property/partialmethod together in the extra26 namespace."
    - "All eight functools callables have a simple qualname equal to their attribute name on the module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — eight functools callables
#
# Verifies that each callable has a simple (non-nested) qualname equal to
# its name. All eight are defined at module level with no enclosing class.
# No prior functools spec records all eight qualnames together in one table
# in the extra26 namespace.
# ---------------------------------------------------------------------------

table functools_extra26.qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra26.qualnames.reduce,
       reduce.__qualname__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__qualname__ == 'reduce'"]
    - [functools_extra26.qualnames.lru_cache,
       lru_cache.__qualname__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__ == 'lru_cache'"]
    - [functools_extra26.qualnames.cache,
       cache.__qualname__.__eq__,
       ["cache"],
       true,
       "functools.cache.__qualname__ == 'cache'"]
    - [functools_extra26.qualnames.wraps,
       wraps.__qualname__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__qualname__ == 'wraps'"]
    - [functools_extra26.qualnames.total_ordering,
       total_ordering.__qualname__.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__ == 'total_ordering'"]
    - [functools_extra26.qualnames.singledispatch,
       singledispatch.__qualname__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__qualname__ == 'singledispatch'"]
    - [functools_extra26.qualnames.cached_property,
       cached_property.__qualname__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__qualname__ == 'cached_property'"]
    - [functools_extra26.qualnames.partialmethod,
       partialmethod.__qualname__.__eq__,
       ["partialmethod"],
       true,
       "functools.partialmethod.__qualname__ == 'partialmethod'"]

# ---------------------------------------------------------------------------
# reduce.__qualname__.__eq__ — standalone invariant
#
# functools.reduce is a C builtin in _functools. Its qualname is 'reduce',
# matching its attribute name on the functools module. This standalone
# invariant anchors the reduce qualname check outside the table.
# No prior functools spec records this in the extra26 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra26.reduce.qualname:
  description: "functools.reduce.__qualname__ == 'reduce' — simple qualname for C builtin"
  category: qualnames
  kind: python_call_eq
  function: reduce.__qualname__.__eq__
  args: ["reduce"]
  expected: true

# ---------------------------------------------------------------------------
# lru_cache.__qualname__.__eq__ — standalone invariant
#
# functools.lru_cache is a pure Python decorator factory. Its qualname is
# 'lru_cache', matching its attribute name. This standalone invariant anchors
# the lru_cache qualname check outside the table.
# No prior functools spec records this in the extra26 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra26.lru_cache.qualname:
  description: "functools.lru_cache.__qualname__ == 'lru_cache' — simple qualname, no nesting"
  category: qualnames
  kind: python_call_eq
  function: lru_cache.__qualname__.__eq__
  args: ["lru_cache"]
  expected: true

# ---------------------------------------------------------------------------
# cache.__qualname__.__eq__ — standalone invariant
#
# functools.cache is a pure Python function (introduced in 3.9) that wraps
# lru_cache(maxsize=None). Its qualname is 'cache'.
# No prior functools spec records this in the extra26 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra26.cache.qualname:
  description: "functools.cache.__qualname__ == 'cache' — simple qualname, no nesting"
  category: qualnames
  kind: python_call_eq
  function: cache.__qualname__.__eq__
  args: ["cache"]
  expected: true

# ---------------------------------------------------------------------------
# wraps.__qualname__.__eq__ — standalone invariant
#
# functools.wraps is a pure Python decorator factory. Its qualname is 'wraps'.
# No prior functools spec records this in the extra26 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra26.wraps.qualname:
  description: "functools.wraps.__qualname__ == 'wraps' — simple qualname, no nesting"
  category: qualnames
  kind: python_call_eq
  function: wraps.__qualname__.__eq__
  args: ["wraps"]
  expected: true

# ---------------------------------------------------------------------------
# total_ordering.__qualname__.__eq__ — standalone invariant
#
# functools.total_ordering is a pure Python class decorator. Its qualname is
# 'total_ordering'. No prior functools spec records this in the extra26 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra26.total_ordering.qualname:
  description: "functools.total_ordering.__qualname__ == 'total_ordering' — simple qualname, no nesting"
  category: qualnames
  kind: python_call_eq
  function: total_ordering.__qualname__.__eq__
  args: ["total_ordering"]
  expected: true
