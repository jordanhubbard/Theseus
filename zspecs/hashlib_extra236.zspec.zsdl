spec: hashlib_extra236
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hashlib_extra235.zspec.zsdl — covers prior hashlib invariants"
    - "hmac_extra32.zspec.zsdl — covers HMAC.__qualname__.__len__()==4; HMAC.__slots__.__len__()==5; module/class doc class name lengths; module function qualname lengths; slot descriptor class name lengths"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hmac.HMAC.__name__ == 'HMAC' — class identity."
    - "hmac.HMAC.__module__ == 'hmac' — class lives in the hmac module."
    - "hmac.HMAC.__qualname__ == 'HMAC' — flat qualname (not nested)."
    - "hmac.HMAC.__bases__[0].__name__ == 'object' — HMAC inherits directly from object."
    - "hmac.HMAC.update.__name__ == 'update' — instance method name."
    - "hmac.HMAC.digest.__name__ == 'digest' — instance method name."
    - "hmac.HMAC.hexdigest.__name__ == 'hexdigest' — instance method name."
    - "hmac.HMAC.copy.__name__ == 'copy' — instance method name."
    - "hmac.HMAC.update.__qualname__ == 'HMAC.update' — method qualname has class prefix."
    - "hmac.HMAC.digest.__qualname__ == 'HMAC.digest' — method qualname."
    - "hmac.HMAC.hexdigest.__qualname__ == 'HMAC.hexdigest' — method qualname."
    - "hmac.HMAC.copy.__qualname__ == 'HMAC.copy' — method qualname."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hmac.HMAC class identity contracts
#
# hmac.HMAC.__name__    == 'HMAC'
# hmac.HMAC.__module__  == 'hmac'
# hmac.HMAC.__qualname__ == 'HMAC'
# hmac.HMAC.__bases__[0].__name__ == 'object'
#
# HMAC is defined in Lib/hmac.py as a top-level class inheriting directly
# from object. Its qualname is flat ('HMAC', not nested). The module is
# 'hmac' — the pure-Python wrapper module.
# ---------------------------------------------------------------------------

table hashlib_extra236.hmac_class_identity:
  description: "HMAC.__name__=='HMAC'; HMAC.__module__=='hmac'; HMAC.__qualname__=='HMAC'; hmac.HMAC class identity contracts; new to hashlib_extra236"
  kind: python_call_eq
  category: class_identity
  id_prefix: hlhmac236

  columns: [id, function, args, expected, description]
  rows:
    - [hmac_class_name_eq,
       "HMAC.__name__.__eq__",
       ["HMAC"],
       true,
       "hmac.HMAC.__name__.__eq__('HMAC') == True — HMAC is the main class in the hmac module; __name__ is 'HMAC' (4 uppercase characters); new anchor in hashlib_extra236 namespace; verified Python 3.14.3"]
    - [hmac_class_module_eq,
       "HMAC.__module__.__eq__",
       ["hmac"],
       true,
       "hmac.HMAC.__module__.__eq__('hmac') == True — HMAC is defined in Lib/hmac.py so __module__ is 'hmac'; new anchor in hashlib_extra236 namespace; verified Python 3.14.3"]
    - [hmac_class_qualname_eq,
       "HMAC.__qualname__.__eq__",
       ["HMAC"],
       true,
       "hmac.HMAC.__qualname__.__eq__('HMAC') == True — HMAC is a top-level class so its qualname is flat 'HMAC' not 'outer.HMAC'; new anchor in hashlib_extra236 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# hmac.HMAC.__bases__[0].__name__ — base class identity
#
# HMAC inherits directly from object with no intermediate ABC or mixin.
# __bases__ is a 1-tuple containing only object.
# ---------------------------------------------------------------------------

invariant hashlib_extra236.hmac_base_is_object:
  description: "hmac.HMAC.__bases__[0].__name__ == 'object' — HMAC inherits directly from object; no intermediate base class"
  category: class_identity
  kind: python_call_eq
  function: "HMAC.__bases__.__getitem__"
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# hmac.HMAC instance method __name__ contracts
#
# hmac.HMAC.update.__name__    == 'update'
# hmac.HMAC.digest.__name__    == 'digest'
# hmac.HMAC.hexdigest.__name__ == 'hexdigest'
# hmac.HMAC.copy.__name__      == 'copy'
#
# The four public instance methods of HMAC have plain single-word names.
# Their __name__ attributes equal the unqualified method name.
# ---------------------------------------------------------------------------

table hashlib_extra236.hmac_method_names:
  description: "HMAC.update.__name__=='update'; HMAC.digest.__name__=='digest'; HMAC.hexdigest.__name__=='hexdigest'; HMAC.copy.__name__=='copy'; HMAC instance method __name__ contracts; new to hashlib_extra236"
  kind: python_call_eq
  category: method_identity
  id_prefix: hlhmac236a

  columns: [id, function, args, expected, description]
  rows:
    - [update_name_eq,
       "HMAC.update.__name__.__eq__",
       ["update"],
       true,
       "hmac.HMAC.update.__name__.__eq__('update') == True — update feeds data into the HMAC computation; __name__ is 'update' (6 characters); new anchor in hashlib_extra236 namespace; verified Python 3.14.3"]
    - [digest_name_eq,
       "HMAC.digest.__name__.__eq__",
       ["digest"],
       true,
       "hmac.HMAC.digest.__name__.__eq__('digest') == True — digest returns the HMAC value as raw bytes; __name__ is 'digest' (6 characters); new anchor in hashlib_extra236 namespace; verified Python 3.14.3"]
    - [hexdigest_name_eq,
       "HMAC.hexdigest.__name__.__eq__",
       ["hexdigest"],
       true,
       "hmac.HMAC.hexdigest.__name__.__eq__('hexdigest') == True — hexdigest returns the HMAC value as a hex string; __name__ is 'hexdigest' (9 characters); new anchor in hashlib_extra236 namespace; verified Python 3.14.3"]
    - [copy_name_eq,
       "HMAC.copy.__name__.__eq__",
       ["copy"],
       true,
       "hmac.HMAC.copy.__name__.__eq__('copy') == True — copy returns a copy of the HMAC object; __name__ is 'copy' (4 characters); new anchor in hashlib_extra236 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# hmac.HMAC instance method __qualname__ contracts
#
# hmac.HMAC.update.__qualname__    == 'HMAC.update'
# hmac.HMAC.digest.__qualname__    == 'HMAC.digest'
# hmac.HMAC.hexdigest.__qualname__ == 'HMAC.hexdigest'
# hmac.HMAC.copy.__qualname__      == 'HMAC.copy'
#
# Method qualnames include the class prefix 'HMAC.' (5 characters), followed
# by the method name. This confirms the methods are defined directly on HMAC.
# ---------------------------------------------------------------------------

table hashlib_extra236.hmac_method_qualnames:
  description: "HMAC.update.__qualname__=='HMAC.update'; HMAC.digest.__qualname__=='HMAC.digest'; HMAC.hexdigest.__qualname__=='HMAC.hexdigest'; HMAC.copy.__qualname__=='HMAC.copy'; HMAC instance method __qualname__ contracts; new to hashlib_extra236"
  kind: python_call_eq
  category: method_identity
  id_prefix: hlhmac236b

  columns: [id, function, args, expected, description]
  rows:
    - [update_qualname_eq,
       "HMAC.update.__qualname__.__eq__",
       ["HMAC.update"],
       true,
       "hmac.HMAC.update.__qualname__.__eq__('HMAC.update') == True — method qualname is 'HMAC.update' (11 characters: 'HMAC.' (5) + 'update' (6)); new anchor in hashlib_extra236 namespace; verified Python 3.14.3"]
    - [digest_qualname_eq,
       "HMAC.digest.__qualname__.__eq__",
       ["HMAC.digest"],
       true,
       "hmac.HMAC.digest.__qualname__.__eq__('HMAC.digest') == True — method qualname is 'HMAC.digest' (11 characters: 'HMAC.' (5) + 'digest' (6)); same length as 'HMAC.update'; new anchor in hashlib_extra236 namespace; verified Python 3.14.3"]
    - [hexdigest_qualname_eq,
       "HMAC.hexdigest.__qualname__.__eq__",
       ["HMAC.hexdigest"],
       true,
       "hmac.HMAC.hexdigest.__qualname__.__eq__('HMAC.hexdigest') == True — method qualname is 'HMAC.hexdigest' (14 characters: 'HMAC.' (5) + 'hexdigest' (9)); longest of the four method qualnames; new anchor in hashlib_extra236 namespace; verified Python 3.14.3"]
    - [copy_qualname_eq,
       "HMAC.copy.__qualname__.__eq__",
       ["HMAC.copy"],
       true,
       "hmac.HMAC.copy.__qualname__.__eq__('HMAC.copy') == True — method qualname is 'HMAC.copy' (9 characters: 'HMAC.' (5) + 'copy' (4)); new anchor in hashlib_extra236 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra236.hmac_class_name_eq:
  description: "hmac.HMAC.__name__.__eq__('HMAC') == True — the HMAC class is the core class of the hmac module, providing keyed-hashing for message authentication as specified in RFC 2104; it is defined in Lib/hmac.py as a top-level class; its __name__ is 'HMAC' (4 uppercase characters standing for Hash-based Message Authentication Code); hashlib_extra236 is the first namespace to anchor HMAC.__name__ as a standalone in the hashlib_extra namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: "HMAC.__name__.__eq__"
  args: ["HMAC"]
  expected: true

invariant hashlib_extra236.hmac_update_qualname_eq:
  description: "hmac.HMAC.update.__qualname__.__eq__('HMAC.update') == True — HMAC.update accepts a bytes-like object and feeds it into the HMAC computation (analogous to hashlib update()); its __qualname__ is 'HMAC.update' (11 characters: 'HMAC.' (5) + 'update' (6)); the 'HMAC.' prefix confirms it is defined directly on the HMAC class body; hashlib_extra236 is the first namespace to anchor HMAC.update.__qualname__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_identity
  kind: python_call_eq
  function: "HMAC.update.__qualname__.__eq__"
  args: ["HMAC.update"]
  expected: true

invariant hashlib_extra236.hmac_hexdigest_qualname_eq:
  description: "hmac.HMAC.hexdigest.__qualname__.__eq__('HMAC.hexdigest') == True — HMAC.hexdigest returns the HMAC authentication code as a lowercase hexadecimal string (analogous to hashlib hexdigest()); its __qualname__ is 'HMAC.hexdigest' (14 characters: 'HMAC.' (5) + 'hexdigest' (9)); this is the longest of the four primary HMAC method qualnames; hashlib_extra236 is the first namespace to anchor HMAC.hexdigest.__qualname__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_identity
  kind: python_call_eq
  function: "HMAC.hexdigest.__qualname__.__eq__"
  args: ["HMAC.hexdigest"]
  expected: true
