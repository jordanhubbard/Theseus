spec: array_extra29
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
    - "array_extra28.zspec.zsdl — covers array.array method __qualname__.__len__() for append/extend/pop/reverse/tolist/frombytes/tobytes/insert/remove."
    - "array_extra27.zspec.zsdl — covers array.array class __module__/__name__/__qualname__ lengths (all 5); __name__.__len__() for append/extend/pop/reverse/tolist/frombytes/tobytes."
    - "array_extra26.zspec.zsdl — covers __name__.__len__() for append/extend/pop/reverse/tolist/frombytes; array.__init__.__qualname__."
    - "array_extra21.zspec.zsdl — covers __qualname__ for append/extend/pop/insert/remove/reverse/tolist/tobytes/frombytes."
  notes:
    - "This spec extends array_extra28.zspec.zsdl."
    - "Prior specs covered: all array.array method __name__ and __qualname__ strings and their lengths; array.array class __module__/__name__/__qualname__ all length 5."
    - "This spec covers: array.__spec__.__class__.__name__ ('ModuleSpec'); array.typecodes.__class__.__name__ ('str') and __len__() (14); array.ArrayType.__name__.__len__() (5) and __module__.__len__() (5); array.array.__reduce_ex__.__qualname__.__len__() (19); array.array.__class_getitem__.__qualname__.__len__() (23)."
    - "array.__spec__.__class__.__name__ == 'ModuleSpec'. Verified."
    - "array.typecodes.__class__.__name__ == 'str'. Verified."
    - "array.typecodes.__len__() == 14 — typecodes string is 'bBuwhHiIlLqQfd' (14 chars). Verified."
    - "array.ArrayType.__name__ == 'array', __name__.__len__() == 5. Verified."
    - "array.ArrayType.__module__ == 'array', __module__.__len__() == 5. Verified."
    - "array.array.__reduce_ex__.__qualname__ == 'array.__reduce_ex__', __qualname__.__len__() == 19. Verified."
    - "array.array.__class_getitem__.__qualname__ == 'array.__class_getitem__', __qualname__.__len__() == 23. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: array.typecodes identity — class name and length
#
# No prior array spec covers __class__.__name__ or __len__() for the
# typecodes string constant. typecodes is a str (not a list) whose length
# equals the number of supported type codes.
# Verified: __class__.__name__ == 'str', __len__() == 14.
# ---------------------------------------------------------------------------

table array_extra29.typecodes_identity:
  description: "array.typecodes.__class__.__name__ == 'str' and __len__() == 14 — 14 supported type codes"
  kind: python_call_eq
  category: module_constants
  id_prefix: tcid29

  columns: [id, function, args, expected]
  rows:
    - [class_name, "typecodes.__class__.__name__.__len__", [], 3]
    - [length,     "typecodes.__len__",                    [], 14]

# ---------------------------------------------------------------------------
# Table: array.array pickling/generics support — __reduce_ex__ and __class_getitem__ qualname lengths
#
# No prior array spec covers __reduce_ex__ or __class_getitem__ on array.array.
# array.array.__reduce_ex__.__qualname__ == 'array.__reduce_ex__' (19 chars).
# array.array.__class_getitem__.__qualname__ == 'array.__class_getitem__' (23 chars).
# Verified: reduce_ex_qualname_len=19, class_getitem_qualname_len=23.
# ---------------------------------------------------------------------------

table array_extra29.special_method_qualname_lengths:
  description: "array.array.__reduce_ex__ and __class_getitem__ __qualname__.__len__() — 19 and 23"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: smqlen29

  columns: [id, function, args, expected]
  rows:
    - [reduce_ex_qlen,       "array.__reduce_ex__.__qualname__.__len__",    [], 19]
    - [class_getitem_qlen,   "array.__class_getitem__.__qualname__.__len__", [], 23]

# ---------------------------------------------------------------------------
# Standalone: array.__spec__.__class__.__name__ length == 10
#
# array.__spec__ is a ModuleSpec instance. 'ModuleSpec' has 10 characters.
# No prior array spec covers __spec__.__class__.__name__ or its length.
# Verified: array.__spec__.__class__.__name__ == 'ModuleSpec', len=10.
# ---------------------------------------------------------------------------

invariant array_extra29.spec_class_name_len:
  description: "array.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Standalone: array.ArrayType.__name__.__len__() == 5
#
# array.ArrayType is an alias for array.array. Its __name__ is 'array' (5 chars).
# No prior array spec covers ArrayType.__name__.__len__().
# Verified: array.ArrayType.__name__ == 'array', len=5.
# ---------------------------------------------------------------------------

invariant array_extra29.ArrayType.name_len:
  description: "array.ArrayType.__name__.__len__() == 5 — 'array' has 5 characters"
  category: class_identity
  kind: python_call_eq
  function: "ArrayType.__name__.__len__"
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# Standalone: array.ArrayType.__module__.__len__() == 5
#
# ArrayType.__module__ is 'array' (5 chars), matching __name__.
# No prior array spec covers ArrayType.__module__.__len__().
# Verified: array.ArrayType.__module__ == 'array', len=5.
# ---------------------------------------------------------------------------

invariant array_extra29.ArrayType.module_len:
  description: "array.ArrayType.__module__.__len__() == 5 — module 'array' has 5 characters"
  category: class_identity
  kind: python_call_eq
  function: "ArrayType.__module__.__len__"
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# Standalone: array.array.__class_getitem__.__qualname__.__len__() == 23
#
# 'array.__class_getitem__' has 23 characters — the longest qualname among
# array.array special methods checked so far. Supports generic syntax like
# array.array[int]. No prior array spec covers this as a standalone invariant.
# Verified: len('array.__class_getitem__') == 23.
# ---------------------------------------------------------------------------

invariant array_extra29.class_getitem_qualname_len:
  description: "array.array.__class_getitem__.__qualname__.__len__() == 23 — 'array.__class_getitem__' has 23 characters"
  category: method_qualnames
  kind: python_call_eq
  function: "array.__class_getitem__.__qualname__.__len__"
  args: []
  expected: 23
