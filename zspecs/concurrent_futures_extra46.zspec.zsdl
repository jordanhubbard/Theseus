spec: concurrent_futures_extra46
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra45.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens for all methods, class __dict__.__class__.__name__.__len__() tables, as_completed/wait __module__.__len__(), __all__.__len__()==14, __mro__.__len__() tables, __bases__[0].__name__.__len__() for all classes, Executor context manager qualname lens, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, map/__qualname__.__len__() for both executors, Future method __name__/__qualname__.__len__() tables, ThreadPoolExecutor submit/shutdown __name__/__qualname__.__len__() tables, InvalidStateError/__name__.__len__()==17, CancelledError/__qualname__.__len__()==14, BrokenExecutor/__name__/__qualname__.__len__()==14, BrokenExecutor/__module__.__len__()==24, CancelledError/__module__.__len__()==24, TimeoutError/__name__/__module__.__len__(), concurrent.futures.__package__.__len__()==18, ThreadPoolExecutor/__name__=='ThreadPoolExecutor', ProcessPoolExecutor/__name__=='ProcessPoolExecutor', executor __module__ string equality, wait/__name__=='wait', function __module__ string equality, Executor/__name__=='Executor'/__module__==concurrent.futures._base, Executor map/submit qualname lengths, InvalidStateError/BrokenExecutor __name__/__module__ string equality, ProcessPoolExecutor/ThreadPoolExecutor/__bases__[0].__name__=='Executor', Future/__bases__[0].__name__=='object', exception MRO depths, ProcessPoolExecutor/ThreadPoolExecutor/__mro__.__len__()==3, Future/__mro__.__len__()==2, Executor/__mro__.__len__()==2, ThreadPoolExecutor/__qualname__=='ThreadPoolExecutor', ProcessPoolExecutor/__qualname__=='ProcessPoolExecutor', Future/__qualname__=='Future', Executor/__qualname__=='Executor', CancelledError/__qualname__=='CancelledError', BrokenExecutor/__qualname__=='BrokenExecutor', all class __qualname__.__len__() tables (extra41), InvalidStateError/__qualname__=='InvalidStateError', TimeoutError/__qualname__=='TimeoutError', ThreadPoolExecutor/ProcessPoolExecutor/InvalidStateError/TimeoutError __module__.__len__(), module string equality for thread/process/builtins modules (extra42), Future method __module__ string equality and __module__.__len__()==24, Executor.map __module__ string equality and length (extra43), ThreadPoolExecutor/__class__.__name__=='type', ProcessPoolExecutor/__class__.__name__=='type', Future/__class__.__name__=='type', Executor/__class__.__name__=='type', CancelledError/__class__.__name__=='type', BrokenExecutor/__class__.__name__=='type', wait/__class__.__name__=='function', as_completed/__class__.__name__=='function', class __class__.__name__.__len__()==4, function __class__.__name__.__len__()==8 (extra44), ThreadPoolExecutor/__class__.__qualname__=='type', ProcessPoolExecutor/__class__.__qualname__=='type', Future/__class__.__qualname__=='type', Executor/__class__.__qualname__=='type', CancelledError/__class__.__qualname__=='type', BrokenExecutor/__class__.__qualname__=='type', wait/__class__.__qualname__=='function', as_completed/__class__.__qualname__=='function', class __class__.__qualname__.__len__()==4, function __class__.__qualname__.__len__()==8, wait/__class__.__module__=='builtins', ThreadPoolExecutor/__class__.__module__=='builtins' (extra45)."
    - "This spec covers: FIRST_COMPLETED/__class__.__name__=='str'; FIRST_EXCEPTION/__class__.__name__=='str'; ALL_COMPLETED/__class__.__name__=='str'; FIRST_COMPLETED/__class__.__qualname__=='str'; FIRST_EXCEPTION/__class__.__qualname__=='str'; ALL_COMPLETED/__class__.__qualname__=='str'; FIRST_COMPLETED/__len__()==15; FIRST_EXCEPTION/__len__()==15; ALL_COMPLETED/__len__()==13; FIRST_COMPLETED string equality; FIRST_EXCEPTION string equality; ALL_COMPLETED string equality."
    - "concurrent.futures.FIRST_COMPLETED is a string constant with value 'FIRST_COMPLETED'. Its __class__.__name__ == 'str' and __class__.__qualname__ == 'str'. len('FIRST_COMPLETED') == 15. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.FIRST_EXCEPTION is a string constant with value 'FIRST_EXCEPTION'. Its __class__.__name__ == 'str' and __class__.__qualname__ == 'str'. len('FIRST_EXCEPTION') == 15. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ALL_COMPLETED is a string constant with value 'ALL_COMPLETED'. Its __class__.__name__ == 'str' and __class__.__qualname__ == 'str'. len('ALL_COMPLETED') == 13. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "FIRST_COMPLETED and FIRST_EXCEPTION both have length 15 (seven letters + underscore + seven letters). ALL_COMPLETED has length 13 (three letters + underscore + nine letters). The sentinel strings serve as wait() return-set discriminators. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures sentinel constant __class__.__name__ — extra46
#
# All three wait() sentinel strings are instances of the built-in str type:
#   FIRST_COMPLETED.__class__.__name__ == 'str'
#   FIRST_EXCEPTION.__class__.__name__ == 'str'
#   ALL_COMPLETED.__class__.__name__   == 'str'
# These sentinels are simple Python string constants defined in _base.py.
# Prior specs captured their __len__() (extra40). Extra46 captures
# __class__.__name__ and __class__.__qualname__ for the first time.
# ---------------------------------------------------------------------------

table concurrent_futures_extra46.sentinel_class_name_eq:
  description: "concurrent.futures sentinel constant __class__.__name__ string equality in extra46 namespace — FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED all have __class__.__name__ == 'str'"
  kind: python_call_eq
  category: class_names
  id_prefix: cfconst46clsname

  columns: [id, function, args, expected, description]
  rows:
    - [FIRST_COMPLETED, FIRST_COMPLETED.__class__.__name__.__eq__, ["str"], true, "FIRST_COMPLETED.__class__.__name__ == 'str' — sentinel is a plain Python string; __class__ is built-in str type"]
    - [FIRST_EXCEPTION, FIRST_EXCEPTION.__class__.__name__.__eq__, ["str"], true, "FIRST_EXCEPTION.__class__.__name__ == 'str' — sentinel is a plain Python string; __class__ is built-in str type"]
    - [ALL_COMPLETED,   ALL_COMPLETED.__class__.__name__.__eq__,   ["str"], true, "ALL_COMPLETED.__class__.__name__ == 'str' — sentinel is a plain Python string; __class__ is built-in str type"]

# ---------------------------------------------------------------------------
# concurrent.futures sentinel constant __class__.__qualname__ — extra46
#
# The built-in str type has __qualname__ == __name__ == 'str' (no enclosing scope):
#   FIRST_COMPLETED.__class__.__qualname__ == 'str'
#   FIRST_EXCEPTION.__class__.__qualname__ == 'str'
#   ALL_COMPLETED.__class__.__qualname__   == 'str'
# For all built-in types, __qualname__ and __name__ are identical.
# ---------------------------------------------------------------------------

table concurrent_futures_extra46.sentinel_class_qualname_eq:
  description: "concurrent.futures sentinel constant __class__.__qualname__ string equality in extra46 namespace — all three sentinels have __class__.__qualname__ == 'str'"
  kind: python_call_eq
  category: class_names
  id_prefix: cfconst46clsqual

  columns: [id, function, args, expected, description]
  rows:
    - [FIRST_COMPLETED, FIRST_COMPLETED.__class__.__qualname__.__eq__, ["str"], true, "FIRST_COMPLETED.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str'"]
    - [FIRST_EXCEPTION, FIRST_EXCEPTION.__class__.__qualname__.__eq__, ["str"], true, "FIRST_EXCEPTION.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str'"]
    - [ALL_COMPLETED,   ALL_COMPLETED.__class__.__qualname__.__eq__,   ["str"], true, "ALL_COMPLETED.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str'"]

# ---------------------------------------------------------------------------
# concurrent.futures sentinel constant __len__() — extra46
#
# String lengths of the three sentinels:
#   FIRST_COMPLETED.__len__() == 15  (len('FIRST_COMPLETED') == 15)
#   FIRST_EXCEPTION.__len__() == 15  (len('FIRST_EXCEPTION') == 15)
#   ALL_COMPLETED.__len__()   == 13  (len('ALL_COMPLETED') == 13)
# FIRST_COMPLETED and FIRST_EXCEPTION share the same length (15 chars).
# ALL_COMPLETED is 2 chars shorter (13 chars).
# ---------------------------------------------------------------------------

table concurrent_futures_extra46.sentinel_len:
  description: "concurrent.futures sentinel constant __len__() in extra46 namespace — FIRST_COMPLETED==15, FIRST_EXCEPTION==15, ALL_COMPLETED==13"
  kind: python_call_eq
  category: string_lengths
  id_prefix: cfconst46len

  columns: [id, function, args, expected, description]
  rows:
    - [FIRST_COMPLETED, FIRST_COMPLETED.__len__, [], 15, "FIRST_COMPLETED.__len__() == 15 — len('FIRST_COMPLETED') == 15; seven-letter prefix + underscore + seven-letter suffix"]
    - [FIRST_EXCEPTION, FIRST_EXCEPTION.__len__, [], 15, "FIRST_EXCEPTION.__len__() == 15 — len('FIRST_EXCEPTION') == 15; same length as FIRST_COMPLETED"]
    - [ALL_COMPLETED,   ALL_COMPLETED.__len__,   [], 13, "ALL_COMPLETED.__len__() == 13 — len('ALL_COMPLETED') == 13; two chars shorter than the FIRST_* sentinels"]

# ---------------------------------------------------------------------------
# concurrent.futures sentinel constant string value equality — extra46
#
# The sentinels are self-referential: each string's value is its own name:
#   FIRST_COMPLETED == 'FIRST_COMPLETED'
#   FIRST_EXCEPTION == 'FIRST_EXCEPTION'
#   ALL_COMPLETED   == 'ALL_COMPLETED'
# This allows user code to compare against the module attribute or the literal.
# ---------------------------------------------------------------------------

table concurrent_futures_extra46.sentinel_value_eq:
  description: "concurrent.futures sentinel constant string value equality in extra46 namespace — each sentinel's value equals its own name as a string"
  kind: python_call_eq
  category: string_values
  id_prefix: cfconst46val

  columns: [id, function, args, expected, description]
  rows:
    - [FIRST_COMPLETED, FIRST_COMPLETED.__eq__, ["FIRST_COMPLETED"], true, "FIRST_COMPLETED == 'FIRST_COMPLETED' — sentinel string is self-named; returned by wait() when all FIRST_COMPLETED futures are done"]
    - [FIRST_EXCEPTION, FIRST_EXCEPTION.__eq__, ["FIRST_EXCEPTION"], true, "FIRST_EXCEPTION == 'FIRST_EXCEPTION' — sentinel string is self-named; returned by wait() when the first exception occurs"]
    - [ALL_COMPLETED,   ALL_COMPLETED.__eq__,   ["ALL_COMPLETED"],   true, "ALL_COMPLETED == 'ALL_COMPLETED' — sentinel string is self-named; returned by wait() when all futures complete"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra46
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra46.FIRST_COMPLETED_class_name_eq:
  description: "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str' — sentinel is a plain Python string; __class__ is built-in str type"
  category: class_names
  kind: python_call_eq
  function: FIRST_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra46.FIRST_EXCEPTION_class_name_eq:
  description: "concurrent.futures.FIRST_EXCEPTION.__class__.__name__ == 'str' — sentinel is a plain Python string; __class__ is built-in str type"
  category: class_names
  kind: python_call_eq
  function: FIRST_EXCEPTION.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra46.ALL_COMPLETED_class_name_eq:
  description: "concurrent.futures.ALL_COMPLETED.__class__.__name__ == 'str' — sentinel is a plain Python string; __class__ is built-in str type"
  category: class_names
  kind: python_call_eq
  function: ALL_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra46.FIRST_COMPLETED_class_qualname_eq:
  description: "concurrent.futures.FIRST_COMPLETED.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str'"
  category: class_names
  kind: python_call_eq
  function: FIRST_COMPLETED.__class__.__qualname__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra46.FIRST_EXCEPTION_class_qualname_eq:
  description: "concurrent.futures.FIRST_EXCEPTION.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str'"
  category: class_names
  kind: python_call_eq
  function: FIRST_EXCEPTION.__class__.__qualname__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra46.ALL_COMPLETED_class_qualname_eq:
  description: "concurrent.futures.ALL_COMPLETED.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str'"
  category: class_names
  kind: python_call_eq
  function: ALL_COMPLETED.__class__.__qualname__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra46.FIRST_COMPLETED_len:
  description: "concurrent.futures.FIRST_COMPLETED.__len__() == 15 — len('FIRST_COMPLETED') == 15"
  category: string_lengths
  kind: python_call_eq
  function: FIRST_COMPLETED.__len__
  args: []
  expected: 15

invariant concurrent_futures_extra46.FIRST_EXCEPTION_len:
  description: "concurrent.futures.FIRST_EXCEPTION.__len__() == 15 — len('FIRST_EXCEPTION') == 15; same length as FIRST_COMPLETED"
  category: string_lengths
  kind: python_call_eq
  function: FIRST_EXCEPTION.__len__
  args: []
  expected: 15

invariant concurrent_futures_extra46.ALL_COMPLETED_len:
  description: "concurrent.futures.ALL_COMPLETED.__len__() == 13 — len('ALL_COMPLETED') == 13; two chars shorter than the FIRST_* sentinels"
  category: string_lengths
  kind: python_call_eq
  function: ALL_COMPLETED.__len__
  args: []
  expected: 13

invariant concurrent_futures_extra46.FIRST_COMPLETED_value_eq:
  description: "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED' — sentinel string value matches its own name"
  category: string_values
  kind: python_call_eq
  function: FIRST_COMPLETED.__eq__
  args: ["FIRST_COMPLETED"]
  expected: true

invariant concurrent_futures_extra46.FIRST_EXCEPTION_value_eq:
  description: "concurrent.futures.FIRST_EXCEPTION == 'FIRST_EXCEPTION' — sentinel string value matches its own name"
  category: string_values
  kind: python_call_eq
  function: FIRST_EXCEPTION.__eq__
  args: ["FIRST_EXCEPTION"]
  expected: true

invariant concurrent_futures_extra46.ALL_COMPLETED_value_eq:
  description: "concurrent.futures.ALL_COMPLETED == 'ALL_COMPLETED' — sentinel string value matches its own name"
  category: string_values
  kind: python_call_eq
  function: ALL_COMPLETED.__eq__
  args: ["ALL_COMPLETED"]
  expected: true
