spec: textwrap_extra12
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl and prior extras through textwrap_extra11.zspec.zsdl."
    - "textwrap_extra11 covers: dedent tab-based indent; fill empty and fits-in-width; wrap single-word; TextWrapper tabsize=4 and max_lines truncation; indent asterisk and predicate-skip-blank."
    - "textwrap_extra8 covers: function __module__ standalones; TextWrapper __module__/__name__; TextWrapper width=40/80; TextWrapper initial_indent/subsequent_indent/break_long_words/break_on_hyphens defaults."
    - "textwrap_extra5 covers: TextWrapper drop_whitespace/fix_sentence_endings/placeholder defaults."
    - "NOT yet covered in any prior spec: TextWrapper().replace_whitespace == True."
    - "NOT yet covered: TextWrapper(width=30).width == 30 as an attribute-access invariant (extra7 uses width=30 only in a behavioral wrap test)."
    - "NOT yet covered: textwrap.dedent('    hello') == 'hello' — single-line single-indent strip."
    - "NOT yet covered: textwrap.indent('hello\\nworld', '! ') == '! hello\\n! world' — exclamation prefix."
    - "NOT yet covered: textwrap.shorten('the quick brown fox', width=15) == 'the quick [...]' — lowercase input (prior specs use 'The' with capital T)."
    - "NOT yet covered: textwrap.wrap('the quick brown fox jumps', width=10) == ['the quick', 'brown fox', 'jumps'] — three-line wrap at width=10."
    - "TextWrapper().replace_whitespace == True — tabs/newlines in input are converted to spaces before wrapping."
    - "TextWrapper(width=30).width == 30 — constructor correctly stores non-default width."
    - "textwrap.dedent('    hello') == 'hello' — four leading spaces stripped from a single-line string."
    - "textwrap.indent('hello\\nworld', '! ') == '! hello\\n! world' — both non-blank lines receive '! ' prefix."
    - "textwrap.shorten('the quick brown fox', width=15) == 'the quick [...]' — lowercase four-word input."
    - "textwrap.wrap('the quick brown fox jumps', width=10) == ['the quick', 'brown fox', 'jumps'] — five words split into three lines."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TextWrapper().replace_whitespace — default True
#
# replace_whitespace controls whether each whitespace character in the input
# (including tabs and embedded newlines) is replaced with a single space
# before wrapping. No prior textwrap spec records this attribute default.
# textwrap_extra5 covers drop_whitespace, fix_sentence_endings, and placeholder;
# textwrap_extra8 covers initial_indent, subsequent_indent, break_long_words,
# break_on_hyphens. replace_whitespace has never been tested.
# ---------------------------------------------------------------------------

invariant textwrap_extra12.TextWrapper.replace_whitespace_default:
  description: "textwrap.TextWrapper().replace_whitespace == True — default is True"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: replace_whitespace.__eq__
  method_args: [true]
  expected: true

# ---------------------------------------------------------------------------
# TextWrapper(width=30).width — attribute access with non-default width
#
# textwrap_extra7 uses TextWrapper(width=30, initial_indent='> ').wrap(...)
# to test a behavioral vector, but never reads the .width attribute directly.
# textwrap_extra8 records width=40 and width=80 as attribute-access invariants.
# This is the first standalone invariant for width=30 via .width access.
# ---------------------------------------------------------------------------

invariant textwrap_extra12.TextWrapper.width_30:
  description: "textwrap.TextWrapper(width=30).width == 30 — constructor stores width"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  kwargs: {width: 30}
  method: width.__eq__
  method_args: [30]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.dedent — single-line with four-space indent
#
# Prior specs cover dedent on multi-line strings (two or more lines) with
# space or tab indents. No prior spec tests dedent on a single-line string.
# dedent('    hello') strips the four-space common indent from the one line
# and returns 'hello'.
# ---------------------------------------------------------------------------

invariant textwrap_extra12.dedent.single_line_four_spaces:
  description: "textwrap.dedent('    hello') == 'hello' — four-space indent stripped from single line"
  category: dedent
  kind: python_call_eq
  function: dedent
  args: ["    hello"]
  expected: "hello"

# ---------------------------------------------------------------------------
# textwrap.indent — exclamation-space prefix
#
# textwrap_extra3 covers indent with '  ' (two spaces).
# textwrap_extra7 covers indent with '# ' (hash-space) including trailing newline.
# textwrap_extra11 covers indent with '* ' (asterisk-space) and predicate.
# No prior spec uses '! ' (exclamation-space) as the prefix.
# indent('hello\nworld', '! ') == '! hello\n! world'.
# ---------------------------------------------------------------------------

invariant textwrap_extra12.indent.exclamation_prefix:
  description: "textwrap.indent('hello\\nworld', '! ') == '! hello\\n! world' — exclamation prefix"
  category: indent
  kind: python_call_eq
  function: indent
  args: ["hello\nworld", "! "]
  expected: "! hello\n! world"

# ---------------------------------------------------------------------------
# textwrap.shorten — lowercase four-word input at width=15
#
# textwrap.zspec.zsdl covers shorten('The quick brown fox', 15) == 'The quick [...]'
# (capital T). textwrap_extra9 covers shorten('The quick brown fox', width=15)
# as an extra9 anchor. No prior spec tests the identical text with lowercase 't'.
# shorten('the quick brown fox', width=15) == 'the quick [...]'.
# ---------------------------------------------------------------------------

invariant textwrap_extra12.shorten.lowercase_four_words:
  description: "textwrap.shorten('the quick brown fox', width=15) == 'the quick [...]' — lowercase input"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["the quick brown fox", 15]
  expected: "the quick [...]"

# ---------------------------------------------------------------------------
# textwrap.wrap — five words into three lines at width=10
#
# textwrap_extra11 covers wrap('hello', width=10) == ['hello'] (single word).
# textwrap_extra10 covers wrap at width=15 with subsequent_indent.
# No prior spec uses width=10 with five-word input that splits into three lines.
# wrap('the quick brown fox jumps', width=10) == ['the quick', 'brown fox', 'jumps'].
# ---------------------------------------------------------------------------

invariant textwrap_extra12.wrap.five_words_width10:
  description: "textwrap.wrap('the quick brown fox jumps', width=10) == ['the quick', 'brown fox', 'jumps']"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["the quick brown fox jumps", 10]
  expected: ["the quick", "brown fox", "jumps"]

# ---------------------------------------------------------------------------
# textwrap.fill — five words at width=10
#
# textwrap_extra3 covers fill('hello world', width=5) == 'hello\nworld'.
# textwrap_extra10 covers fill('The quick brown fox jumps', width=15).
# No prior spec uses fill with width=10 and five words producing three lines.
# fill('the quick brown fox jumps', width=10) == 'the quick\nbrown fox\njumps'.
# ---------------------------------------------------------------------------

invariant textwrap_extra12.fill.five_words_width10:
  description: "textwrap.fill('the quick brown fox jumps', width=10) == 'the quick\\nbrown fox\\njumps'"
  category: fill
  kind: python_call_eq
  function: fill
  args: ["the quick brown fox jumps", 10]
  expected: "the quick\nbrown fox\njumps"

# ---------------------------------------------------------------------------
# textwrap.indent — three-line input with plus prefix
#
# Prior specs cover indent with two-line input and various prefixes
# ('  ', '  ', '# ', '* ', '> ', '! ').
# No prior spec tests a three-line input string 'a\nb\nc' with '+' prefix.
# indent('a\nb\nc', '+ ') == '+ a\n+ b\n+ c'.
# ---------------------------------------------------------------------------

invariant textwrap_extra12.indent.plus_prefix_three_lines:
  description: "textwrap.indent('a\\nb\\nc', '+ ') == '+ a\\n+ b\\n+ c' — three-line plus prefix"
  category: indent
  kind: python_call_eq
  function: indent
  args: ["a\nb\nc", "+ "]
  expected: "+ a\n+ b\n+ c"

# ---------------------------------------------------------------------------
# textwrap.shorten — custom space-prefixed placeholder
#
# textwrap_extra.zspec.zsdl covers shorten('hello world', 8, placeholder='...').
# textwrap_extra3 covers shorten with placeholder='...'.
# textwrap_extra7 covers shorten with placeholder='...' (unicode ellipsis).
# No prior spec uses ' ...' (space-dot-dot-dot) as the placeholder.
# shorten('the quick brown fox jumps', width=15, placeholder=' ...') == 'the quick ...'.
# ---------------------------------------------------------------------------

invariant textwrap_extra12.shorten.space_dot_placeholder:
  description: "textwrap.shorten('the quick brown fox jumps', width=15, placeholder=' ...') == 'the quick ...'"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["the quick brown fox jumps", 15]
  kwargs: {placeholder: " ..."}
  expected: "the quick ..."

# ---------------------------------------------------------------------------
# Table: TextWrapper default attribute checks — extra12 anchors
#
# Groups replace_whitespace and width=30 in one table.
# ---------------------------------------------------------------------------

table textwrap_extra12.TextWrapper_extra12_defaults:
  description: "TextWrapper default and constructor attribute checks — extra12 namespace"
  kind: python_call_eq
  category: TextWrapper_defaults
  id_prefix: td

  columns: [id, function, method, method_args, expected]
  rows:
    - [replace_whitespace, TextWrapper, replace_whitespace.__eq__, [true],  true]
    - [width_30,           TextWrapper, width.__eq__,             [30],    true]
