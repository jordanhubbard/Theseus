spec: asyncio_extra1666
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio: Asynchronous I/O"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
  notes:
    - "Theme: __new__ — object construction protocol; which asyncio classes define custom __new__."
    - "asyncio synchronization primitives (Lock, Event, Queue, Semaphore, Condition, Barrier) are pure-Python classes; they define __init__ but NOT __new__ in their own __dict__."
    - "asyncio.Future is implemented in C (_asyncio module) on CPython; Future.__dict__.__contains__('__new__') is False because the C type uses tp_new, not a Python-level __new__ slot accessible through __dict__."
    - "asyncio.Task is also implemented in C on CPython; Task.__dict__.__contains__('__new__') is False for the same reason."
    - "asyncio.Lock.__dict__.__contains__('__new__') is False — Lock inherits __new__ from object without overriding it."
    - "asyncio.Event.__dict__.__contains__('__new__') is False — same as Lock; pure Python, no custom __new__."
    - "asyncio.Queue.__dict__.__contains__('__new__') is False — Queue is a pure-Python class with a custom __init__ but no __new__."
    - "asyncio.Semaphore.__dict__.__contains__('__new__') is False — no custom __new__."
    - "asyncio.Condition.__dict__.__contains__('__new__') is False — no custom __new__."
    - "asyncio.Barrier.__dict__.__contains__('__new__') is False — no custom __new__; Barrier added in 3.11."
    - "asyncio.Lock.__dict__.__contains__('__init__') is True — Lock.__init__ sets _locked=False and _waiters=None."
    - "asyncio.Event.__dict__.__contains__('__init__') is True — Event.__init__ sets _value=False and _waiters=None."
    - "asyncio.Queue.__dict__.__contains__('__init__') is True — Queue.__init__ sets maxsize, _queue, _getters, _putters."
    - "asyncio.Semaphore.__dict__.__contains__('__init__') is True — Semaphore.__init__ sets _value and _waiters."
    - "asyncio.Condition.__dict__.__contains__('__init__') is True — Condition.__init__ sets _lock, _waiters, etc."
    - "asyncio.Barrier.__dict__.__contains__('__init__') is True — Barrier.__init__ sets _parties, _state, _count."
    - "asyncio.Future.__dict__.__contains__('__init__') is True on C implementations — Future has its own __init__."
    - "asyncio.Task.__dict__.__contains__('__init__') is True on C implementations — Task.__init__ initialises task bookkeeping."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio_extra1666.no_custom_new
#
# Checks that Lock, Event, Queue, Semaphore, Condition, Barrier, Future, Task
# all have __new__ ABSENT from their own __dict__ — they rely on object.__new__.
# ---------------------------------------------------------------------------

table asyncio_extra1666.no_custom_new:
  description: "asyncio synchronization and task classes have no custom __new__ in their own __dict__: Lock, Event, Queue, Semaphore, Condition, Barrier each inherit __new__ from object without overriding it; Future and Task are C types whose tp_new is not exposed as a Python __new__ attribute in the class __dict__; all return False for __dict__.__contains__('__new__'); verified with Python 3.14.4"
  kind: python_call_eq
  category: new_absent
  id_prefix: as1666nn

  columns: [id, function, args, expected]
  rows:
    - ["as1666nn001", asyncio.Lock.__dict__.__contains__,       ["__new__"], false]
    - ["as1666nn002", asyncio.Event.__dict__.__contains__,      ["__new__"], false]
    - ["as1666nn003", asyncio.Queue.__dict__.__contains__,      ["__new__"], false]
    - ["as1666nn004", asyncio.Semaphore.__dict__.__contains__,  ["__new__"], false]
    - ["as1666nn005", asyncio.Condition.__dict__.__contains__,  ["__new__"], false]
    - ["as1666nn006", asyncio.Barrier.__dict__.__contains__,    ["__new__"], false]
    - ["as1666nn007", asyncio.Future.__dict__.__contains__,     ["__new__"], false]
    - ["as1666nn008", asyncio.Task.__dict__.__contains__,       ["__new__"], false]

# ---------------------------------------------------------------------------
# Table 2: asyncio_extra1666.init_present
#
# Checks that Lock, Event, Queue, Semaphore, Condition, Barrier each define
# their own __init__ directly in their class __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra1666.init_present:
  description: "asyncio synchronization primitives all define __init__ in their own __dict__: Lock, Event, Queue, Semaphore, Condition, Barrier each have a custom __init__ that sets internal state; none use the default object.__init__; __dict__.__contains__('__init__') is True for all six; verified with Python 3.14.4"
  kind: python_call_eq
  category: init_present
  id_prefix: as1666ip

  columns: [id, function, args, expected]
  rows:
    - ["as1666ip001", asyncio.Lock.__dict__.__contains__,       ["__init__"], true]
    - ["as1666ip002", asyncio.Event.__dict__.__contains__,      ["__init__"], true]
    - ["as1666ip003", asyncio.Queue.__dict__.__contains__,      ["__init__"], true]
    - ["as1666ip004", asyncio.Semaphore.__dict__.__contains__,  ["__init__"], true]
    - ["as1666ip005", asyncio.Condition.__dict__.__contains__,  ["__init__"], true]
    - ["as1666ip006", asyncio.Barrier.__dict__.__contains__,    ["__init__"], true]
    - ["as1666ip007", asyncio.Queue.__dict__.__contains__,      ["__doc__"],  true]
    - ["as1666ip008", asyncio.Lock.__dict__.__contains__,       ["__repr__"], true]
    - ["as1666ip009", asyncio.Event.__dict__.__contains__,      ["__repr__"], true]
    - ["as1666ip010", asyncio.Semaphore.__dict__.__contains__,  ["__repr__"], true]
    - ["as1666ip011", asyncio.Condition.__dict__.__contains__,  ["__repr__"], true]
    - ["as1666ip012", asyncio.Barrier.__dict__.__contains__,    ["__repr__"], true]

# ---------------------------------------------------------------------------
# Table 3: asyncio_extra1666.future_task_new_init
#
# asyncio.Future and asyncio.Task are C-accelerated types.
# Checks both __new__ (absent) and __init__ (present) for both, plus
# class name and module identity to confirm these are the C types.
# ---------------------------------------------------------------------------

table asyncio_extra1666.future_task_new_init:
  description: "asyncio.Future and asyncio.Task C-type __new__ and __init__ checks: __new__ is absent from __dict__ (C types expose tp_new via the type slot, not via a Python-level __new__ in __dict__); __init__ is present in __dict__ (both Future and Task define their own __init__); class names are 'Future' and 'Task'; modules confirm the asyncio package; verified with Python 3.14.4"
  kind: python_call_eq
  category: future_task
  id_prefix: as1666ft

  columns: [id, function, args, expected]
  rows:
    - ["as1666ft001", asyncio.Future.__dict__.__contains__,           ["__new__"],  false]
    - ["as1666ft002", asyncio.Future.__dict__.__contains__,           ["__init__"], true]
    - ["as1666ft003", asyncio.Task.__dict__.__contains__,             ["__new__"],  false]
    - ["as1666ft004", asyncio.Task.__dict__.__contains__,             ["__init__"], true]
    - ["as1666ft005", asyncio.Future.__name__.__eq__,                 ["Future"],   true]
    - ["as1666ft006", asyncio.Task.__name__.__eq__,                   ["Task"],     true]
    - ["as1666ft007", asyncio.Future.__name__.__len__,                [],           6]
    - ["as1666ft008", asyncio.Task.__name__.__len__,                  [],           4]
    - ["as1666ft009", asyncio.Future.__dict__.__contains__,           ["cancel"],   true]
    - ["as1666ft010", asyncio.Future.__dict__.__contains__,           ["result"],   true]
    - ["as1666ft011", asyncio.Future.__dict__.__contains__,           ["done"],     true]
    - ["as1666ft012", asyncio.Task.__dict__.__contains__,             ["cancel"],   true]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra1666
# ---------------------------------------------------------------------------

invariant asyncio_extra1666.lock_no_custom_new:
  description: "asyncio.Lock.__dict__.__contains__('__new__') returns False — asyncio.Lock is a pure-Python class defined in Lib/asyncio/locks.py; it inherits __new__ from object without overriding it; the object construction protocol for Lock proceeds through object.__new__(Lock) followed by Lock.__init__(); Lock.__init__ sets _locked=False and _waiters=None; confirmed: no custom __new__ in Lock.__dict__ on Python 3.14.4"
  category: new_absent
  kind: python_call_eq
  function: asyncio.Lock.__dict__.__contains__
  args: ["__new__"]
  expected: false

invariant asyncio_extra1666.queue_no_custom_new:
  description: "asyncio.Queue.__dict__.__contains__('__new__') returns False — asyncio.Queue is a pure-Python class with a maxsize parameter accepted in __init__; Queue does not override __new__; PriorityQueue and LifoQueue are subclasses of Queue and likewise have no custom __new__; all asyncio queue classes rely on object.__new__ for allocation; verified with Python 3.14.4"
  category: new_absent
  kind: python_call_eq
  function: asyncio.Queue.__dict__.__contains__
  args: ["__new__"]
  expected: false

invariant asyncio_extra1666.queue_has_custom_init:
  description: "asyncio.Queue.__dict__.__contains__('__init__') returns True — Queue.__init__(self, maxsize=0) initialises the queue's maxsize, the internal deque (_queue), and the sets of coroutines waiting to get (_getters) or put (_putters); __init__ is where all mutable state is established; no state is initialised in __new__; verified with Python 3.14.4"
  category: init_present
  kind: python_call_eq
  function: asyncio.Queue.__dict__.__contains__
  args: ["__init__"]
  expected: true

invariant asyncio_extra1666.barrier_no_custom_new:
  description: "asyncio.Barrier.__dict__.__contains__('__new__') returns False — asyncio.Barrier (added in Python 3.11) is a pure-Python class; it inherits __new__ from object; Barrier.__init__(self, parties) sets _parties, _state (FILLING), _count (0), and _loop_waiters; the two-phase construction (allocate via object.__new__, then initialise via Barrier.__init__) follows the standard Python pattern; verified with Python 3.14.4"
  category: new_absent
  kind: python_call_eq
  function: asyncio.Barrier.__dict__.__contains__
  args: ["__new__"]
  expected: false

invariant asyncio_extra1666.semaphore_has_init_not_new:
  description: "asyncio.Semaphore.__dict__.__contains__('__init__') returns True and __dict__.__contains__('__new__') returns False — Semaphore is a pure-Python class; Semaphore.__init__(self, value=1) sets _value and _waiters; no custom allocation is needed so __new__ is not overridden; asyncio.BoundedSemaphore is a subclass that adds an upper-bound check in __init__; verified with Python 3.14.4"
  category: init_present
  kind: python_call_eq
  function: asyncio.Semaphore.__dict__.__contains__
  args: ["__init__"]
  expected: true
