spec: re2926
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/re_extra2911.zspec.zsdl — wave 641 predecessor (covered __ilshift__, __irshift__, __ipow__)"
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "Wave 642 theme: __iand__, __ior__, __ixor__ dict-presence checks (in-place bitwise AND, OR, XOR operators)."
    - "re.RegexFlag is an IntFlag subclass — in wave 638 it was confirmed to define __and__, __or__, __xor__, __rand__, __ror__, __rxor__ (all True)."
    - "Despite owning non-inplace and reflected bitwise ops, re.RegexFlag does NOT define __iand__, __ior__, or __ixor__ — IntFlag delegates in-place ops to its metaclass (EnumType), which does not install them directly in the subclass __dict__."
    - "re.Pattern (type(re.compile(''))) does NOT define any bitwise operators — compiled pattern objects are not numeric operands."
    - "re.Match (type(re.match('',''))) does NOT define any bitwise operators — match objects carry match state, not arithmetic values."
    - "The non-inplace bitwise ops (__and__, __or__, __xor__) ARE present in re.RegexFlag.__dict__ (True) — the in-place variants are the notable absences here."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __iand__ dict-presence
# RegexFlag: False (despite __and__ being True); Pattern and Match: False
# ---------------------------------------------------------------------------

table re2926.iand:
  description: "__iand__ is absent from re.RegexFlag (IntFlag defines __and__ but not __iand__ directly), Pattern, and Match"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2926

  columns: [id, function, args, expected]
  rows:
    - ["re2926001", "re.RegexFlag.__dict__.__contains__",                    ["__iand__"], false]
    - ["re2926002", "type(re.compile('')).__dict__.__contains__",            ["__iand__"], false]
    - ["re2926003", "type(re.match('', '')).__dict__.__contains__",          ["__iand__"], false]
    - ["re2926004", "re.RegexFlag.__dict__.__contains__",                    ["__and__"],  true]
    - ["re2926005", "type(re.compile('')).__dict__.__contains__",            ["__and__"],  false]
    - ["re2926006", "type(re.match('', '')).__dict__.__contains__",          ["__and__"],  false]

