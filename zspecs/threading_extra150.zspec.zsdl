spec: threading_extra150
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.__dict__.__class__.__name__ 'dict' len 81; threading.Condition.__dict__.__class__.__name__ 'mappingproxy' len 19; threading.Lock.__dict__.__class__.__name__ 'mappingproxy' len 13; threading.Thread.__dict__.__class__.__name__ 'mappingproxy' len 28; threading.Barrier.__dict__.__class__.__name__ 'mappingproxy' len 19 (Wave 278)."
    - "threading.__dict__.__class__.__name__ == 'dict' — the module __dict__ of a Python source module is a plain dict. len(threading.__dict__) == 81. Verified with Python 3.14.3."
    - "threading.Condition.__dict__.__class__.__name__ == 'mappingproxy'; len == 19. Verified with Python 3.14.3."
    - "threading.Lock.__dict__.__class__.__name__ == 'mappingproxy'; len == 13 — threading.Lock is actually _thread.lock, a C extension type. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__class__.__name__ == 'mappingproxy'; len == 28. Verified with Python 3.14.3."
    - "threading.Barrier.__dict__.__class__.__name__ == 'mappingproxy'; len == 19. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.__dict__ — module dict is a plain dict
#
# Wave 278 theme: threading.__dict__.__class__.__name__ and len.
#
# threading.__dict__.__class__.__name__ == 'dict'
# len(threading.__dict__) == 81
#
# threading is a pure-Python source module; its module __dict__ is a plain
# Python dict (not a mappingproxy). In Python 3.14.3 it has 81 entries,
# reflecting the full threading public API plus internal names.
# New to extra150.
# ---------------------------------------------------------------------------

table threading_extra150.module_dict_identity:
  description: "threading.__dict__: plain dict (not mappingproxy), len 81; module-level dict for a Python source module; wave 278; new to extra150"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmoddict150

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_class_eq_dict,
       "__dict__.__class__.__name__.__eq__",
       ["dict"],
       true,
       "threading.__dict__.__class__.__name__.__eq__('dict') == True — threading is a pure-Python source module; its module __dict__ is a plain Python dict (not a mappingproxy); __class__.__name__ is 'dict'; str.__eq__('dict') returns True; new to extra150"]
    - [module_dict_len_eq_81,
       "__dict__.__len__",
       [],
       81,
       "threading.__dict__.__len__() == 81 — threading has 81 entries in its module __dict__ in Python 3.14.3; these include Thread, Lock, RLock, Condition, Semaphore, Event, Timer, Barrier, local, current_thread, main_thread, active_count, enumerate, settrace, setprofile, excepthook, and many more; len == 81; verified with Python 3.14.3; new to extra150"]

# ---------------------------------------------------------------------------
# Table 2: threading.Condition and threading.Lock __dict__
#
# Wave 278 theme: class __dict__ mappingproxy identity for Condition and Lock.
#
# threading.Condition.__dict__.__class__.__name__ == 'mappingproxy'
# len(threading.Condition.__dict__) == 19
# threading.Lock.__dict__.__class__.__name__ == 'mappingproxy'
# len(threading.Lock.__dict__) == 13
#
# Condition is a pure-Python class; Lock is actually the C extension type
# _thread.lock. Both have class dicts exposed as mappingproxy. New to extra150.
# ---------------------------------------------------------------------------

table threading_extra150.condition_lock_dict_identity:
  description: "threading.Condition.__dict__: mappingproxy len 19; threading.Lock.__dict__: mappingproxy len 13 (Lock is C extension _thread.lock); wave 278; new to extra150"
  kind: python_call_eq
  category: identity
  id_prefix: threadingcondlock150

  columns: [id, function, args, expected, description]
  rows:
    - [condition_dict_class_eq_mappingproxy,
       "Condition.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Condition.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Condition is a pure-Python class but its class __dict__ is still exposed as a read-only mappingproxy; str.__eq__('mappingproxy') returns True; new to extra150"]
    - [condition_dict_len_eq_19,
       "Condition.__dict__.__len__",
       [],
       19,
       "threading.Condition.__dict__.__len__() == 19 — Condition has 19 entries in its class dict in Python 3.14.3 including acquire, release, wait, wait_for, notify, notify_all, and various dunders; len == 19; verified with Python 3.14.3; new to extra150"]
    - [lock_dict_class_eq_mappingproxy,
       "Lock.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Lock.__dict__.__class__.__name__.__eq__('mappingproxy') == True — threading.Lock is actually the C extension type _thread.lock; its class __dict__ is a read-only mappingproxy of its tp_dict; str.__eq__('mappingproxy') returns True; new to extra150"]
    - [lock_dict_len_eq_13,
       "Lock.__dict__.__len__",
       [],
       13,
       "threading.Lock.__dict__.__len__() == 13 — threading.Lock (_thread.lock) has 13 entries in its class dict in Python 3.14.3; len == 13; verified with Python 3.14.3; new to extra150"]
    - [lock_name_eq_lock,
       "Lock.__name__.__eq__",
       ["lock"],
       true,
       "threading.Lock.__name__.__eq__('lock') == True — threading.Lock is the C extension type _thread.lock; its internal __name__ is 'lock' (lowercase); str.__eq__('lock') returns True; new to extra150"]
    - [lock_module_eq__thread,
       "Lock.__module__.__eq__",
       ["_thread"],
       true,
       "threading.Lock.__module__.__eq__('_thread') == True — threading.Lock is the C extension type _thread.lock defined in Modules/_threadmodule.c; __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra150"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread and threading.Barrier __dict__
#
# Wave 278 theme: class __dict__ mappingproxy identity for Thread and Barrier.
#
# threading.Thread.__dict__.__class__.__name__ == 'mappingproxy'
# len(threading.Thread.__dict__) == 28
# threading.Barrier.__dict__.__class__.__name__ == 'mappingproxy'
# len(threading.Barrier.__dict__) == 19
#
# Both are pure-Python classes defined in Lib/threading.py; their class
# __dict__ is exposed as a mappingproxy. New to extra150.
# ---------------------------------------------------------------------------

table threading_extra150.thread_barrier_dict_identity:
  description: "threading.Thread.__dict__: mappingproxy len 28; threading.Barrier.__dict__: mappingproxy len 19; pure-Python class dicts; wave 278; new to extra150"
  kind: python_call_eq
  category: identity
  id_prefix: threadingthrbr150

  columns: [id, function, args, expected, description]
  rows:
    - [thread_dict_class_eq_mappingproxy,
       "Thread.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Thread.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Thread is a pure-Python class; its class __dict__ is exposed as a read-only mappingproxy; str.__eq__('mappingproxy') returns True; new to extra150"]
    - [thread_dict_len_eq_28,
       "Thread.__dict__.__len__",
       [],
       28,
       "threading.Thread.__dict__.__len__() == 28 — Thread has 28 entries in its class dict in Python 3.14.3 including start, run, join, name, ident, daemon, is_alive, and various dunders and properties; len == 28; verified with Python 3.14.3; new to extra150"]
    - [barrier_dict_class_eq_mappingproxy,
       "Barrier.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Barrier.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Barrier is a pure-Python class; its class __dict__ is exposed as a read-only mappingproxy; str.__eq__('mappingproxy') returns True; new to extra150"]
    - [barrier_dict_len_eq_19,
       "Barrier.__dict__.__len__",
       [],
       19,
       "threading.Barrier.__dict__.__len__() == 19 — Barrier has 19 entries in its class dict in Python 3.14.3 including wait, reset, abort, parties, n_waiting, broken, and various dunders and properties; len == 19; verified with Python 3.14.3; new to extra150"]
    - [condition_name_eq_condition,
       "Condition.__name__.__eq__",
       ["Condition"],
       true,
       "threading.Condition.__name__.__eq__('Condition') == True — Condition is a pure-Python class defined in Lib/threading.py; __name__ is 'Condition'; str.__eq__('Condition') returns True; new to extra150"]
    - [barrier_name_eq_barrier,
       "Barrier.__name__.__eq__",
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — Barrier is a pure-Python class defined in Lib/threading.py; __name__ is 'Barrier'; str.__eq__('Barrier') returns True; new to extra150"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra150
# ---------------------------------------------------------------------------

invariant threading_extra150.module_dict_class_dict:
  description: "threading.__dict__.__class__.__name__ == 'dict' — module __dict__ of a Python source module is a plain dict; wave 278; new to extra150"
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant threading_extra150.module_dict_len:
  description: "len(threading.__dict__) == 81 — threading module dict has 81 entries; wave 278; new to extra150"
  kind: python_call_eq
  function: __dict__.__len__
  args: []
  expected: 81

invariant threading_extra150.condition_dict_class_mappingproxy:
  description: "threading.Condition.__dict__.__class__.__name__ == 'mappingproxy' — Python class dict is a mappingproxy; wave 278; new to extra150"
  kind: python_call_eq
  function: Condition.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant threading_extra150.condition_dict_len:
  description: "len(threading.Condition.__dict__) == 19 — Condition class dict has 19 entries; wave 278; new to extra150"
  kind: python_call_eq
  function: Condition.__dict__.__len__
  args: []
  expected: 19

invariant threading_extra150.lock_dict_len:
  description: "len(threading.Lock.__dict__) == 13 — Lock (_thread.lock) class dict has 13 entries; wave 278; new to extra150"
  kind: python_call_eq
  function: Lock.__dict__.__len__
  args: []
  expected: 13

invariant threading_extra150.lock_name_eq_lock:
  description: "threading.Lock.__name__ == 'lock' — threading.Lock is _thread.lock; internal name is lowercase 'lock'; wave 278; new to extra150"
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra150.lock_module_eq__thread:
  description: "threading.Lock.__module__ == '_thread' — Lock is a C extension type from _threadmodule.c; wave 278; new to extra150"
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra150.thread_dict_len:
  description: "len(threading.Thread.__dict__) == 28 — Thread class dict has 28 entries; wave 278; new to extra150"
  kind: python_call_eq
  function: Thread.__dict__.__len__
  args: []
  expected: 28

invariant threading_extra150.barrier_dict_len:
  description: "len(threading.Barrier.__dict__) == 19 — Barrier class dict has 19 entries; wave 278; new to extra150"
  kind: python_call_eq
  function: Barrier.__dict__.__len__
  args: []
  expected: 19

invariant threading_extra150.condition_module_eq_threading:
  description: "threading.Condition.__module__ == 'threading' — Condition is defined in Lib/threading.py; wave 278; new to extra150"
  kind: python_call_eq
  function: Condition.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra150.barrier_module_eq_threading:
  description: "threading.Barrier.__module__ == 'threading' — Barrier is defined in Lib/threading.py; wave 278; new to extra150"
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["threading"]
  expected: true
