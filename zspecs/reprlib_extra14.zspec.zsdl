spec: reprlib_extra14
version: ">=3.9"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html — Python reprlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec extends reprlib.zspec.zsdl through reprlib_extra13.zspec.zsdl."
    - "reprlib_extra13 covers: repr([1]*100) truncation; repr return type; Repr.__name__; Repr.__module__; aRepr.__class__.__name__=='Repr'."
    - "reprlib_extra12 covers: repr.__name__ standalone; Repr.__qualname__ standalone; Repr.__module__ standalone; Repr.__bases__[0].__name__=='object'; repr([1,2,3])/repr('hello'); Repr.__init__.__name__; __module__ table for repr."
    - "reprlib_extra11 covers: repr.__name__/Repr.__name__; repr.__module__/Repr.__module__; repr_values table; truncation and class name checks."
    - "reprlib_extra9 covers: repr('hello')/repr(42)/repr((1,2,3)); Repr().__class__.__name__; Repr.__bases__[0].__name__; recursive_repr.__qualname__; aRepr.maxarray."
    - "This spec covers: Repr.__bases__[0].__name__=='object'; recursive_repr.__name__=='recursive_repr'; recursive_repr.__qualname__=='recursive_repr'; recursive_repr.__module__=='reprlib'; aRepr.__class__.__qualname__=='Repr'; Repr.__module__=='reprlib'."
    - "reprlib.Repr.__bases__[0].__name__ == 'object' — Repr has no custom base class. Verified at runtime."
    - "reprlib.recursive_repr.__name__ == 'recursive_repr' — module-level function. Verified at runtime."
    - "reprlib.recursive_repr.__qualname__ == 'recursive_repr' — module-level function qualname equals name. Verified at runtime."
    - "reprlib.recursive_repr.__module__ == 'reprlib' — recursive_repr defined in reprlib module. Verified at runtime."
    - "reprlib.aRepr.__class__.__qualname__ == 'Repr' — Repr is not a nested class so qualname equals name. Verified at runtime."
    - "reprlib.Repr.__module__ == 'reprlib' — Repr class defined in reprlib module. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Repr base class — __bases__[0].__name__
#
# reprlib_extra12 covers Repr.__bases__[0].__name__ == 'object'.
# reprlib_extra9 also covers Repr.__bases__[0].__name__ == 'object'.
# This re-anchors the vector under the extra14 namespace as a standalone
# invariant complementing the recursive_repr and aRepr vectors below.
# Verified: reprlib.Repr.__bases__[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant reprlib_extra14.Repr.bases_object:
  description: "reprlib.Repr.__bases__[0].__name__ == 'object' — Repr inherits from object"
  category: class_identity
  kind: python_call_eq
  function: "Repr.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# recursive_repr function identity — __name__, __qualname__, __module__
#
# reprlib_extra9 covers recursive_repr.__qualname__ == 'recursive_repr'.
# No prior spec verifies recursive_repr.__name__ or recursive_repr.__module__
# as standalone invariants. This spec anchors all three under extra14.
# recursive_repr is a decorator defined at module level in reprlib.
# Verified: __name__=='recursive_repr', __qualname__=='recursive_repr',
#           __module__=='reprlib'.
# ---------------------------------------------------------------------------

invariant reprlib_extra14.recursive_repr.name:
  description: "reprlib.recursive_repr.__name__ == 'recursive_repr' — function name attribute"
  category: function_identity
  kind: python_call_eq
  function: recursive_repr.__name__.__eq__
  args: ["recursive_repr"]
  expected: true

invariant reprlib_extra14.recursive_repr.qualname:
  description: "reprlib.recursive_repr.__qualname__ == 'recursive_repr' — module-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: recursive_repr.__qualname__.__eq__
  args: ["recursive_repr"]
  expected: true

invariant reprlib_extra14.recursive_repr.module:
  description: "reprlib.recursive_repr.__module__ == 'reprlib' — recursive_repr defined in reprlib module"
  category: function_identity
  kind: python_call_eq
  function: recursive_repr.__module__.__eq__
  args: ["reprlib"]
  expected: true

# ---------------------------------------------------------------------------
# aRepr.__class__.__qualname__
#
# reprlib_extra13 covers aRepr.__class__.__name__ == 'Repr'.
# No prior spec verifies aRepr.__class__.__qualname__ as a standalone
# invariant. For a non-nested class, __qualname__ equals __name__.
# Verified: reprlib.aRepr.__class__.__qualname__ == 'Repr'.
# ---------------------------------------------------------------------------

invariant reprlib_extra14.aRepr.class_qualname:
  description: "reprlib.aRepr.__class__.__qualname__ == 'Repr' — Repr is a top-level class so qualname equals name"
  category: class_identity
  kind: python_call_eq
  function: aRepr.__class__.__qualname__.__eq__
  args: ["Repr"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.__module__
#
# reprlib_extra12 and reprlib_extra11 cover Repr.__module__ == 'reprlib'.
# reprlib_extra13 also covers Repr.__module__ as a standalone.
# This re-anchors the vector under the extra14 namespace to form a complete
# class identity set alongside __bases__, __qualname__, and aRepr qualname.
# Verified: reprlib.Repr.__module__ == 'reprlib'.
# ---------------------------------------------------------------------------

invariant reprlib_extra14.Repr.module:
  description: "reprlib.Repr.__module__ == 'reprlib' — Repr class defined in reprlib module"
  category: class_identity
  kind: python_call_eq
  function: Repr.__module__.__eq__
  args: ["reprlib"]
  expected: true

# ---------------------------------------------------------------------------
# Table: recursive_repr function identity — name, qualname, module
#
# Groups the three recursive_repr identity checks in one indexed table.
# ---------------------------------------------------------------------------

table reprlib_extra14.recursive_repr_identity:
  description: "reprlib.recursive_repr function identity — __name__, __qualname__, __module__"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [reprlib_extra14.recursive_repr_identity.name,
       recursive_repr.__name__.__eq__,
       ["recursive_repr"],
       true,
       "recursive_repr.__name__ == 'recursive_repr'"]
    - [reprlib_extra14.recursive_repr_identity.qualname,
       recursive_repr.__qualname__.__eq__,
       ["recursive_repr"],
       true,
       "recursive_repr.__qualname__ == 'recursive_repr'"]
    - [reprlib_extra14.recursive_repr_identity.module,
       recursive_repr.__module__.__eq__,
       ["reprlib"],
       true,
       "recursive_repr.__module__ == 'reprlib'"]

# ---------------------------------------------------------------------------
# Table: Repr class and aRepr instance identity
#
# Groups the Repr base class, Repr module, and aRepr qualname checks together.
# ---------------------------------------------------------------------------

table reprlib_extra14.Repr_and_aRepr_identity:
  description: "reprlib.Repr class and aRepr instance identity — base class, module, qualname"
  kind: python_call_eq
  category: class_identity
  columns: [id, function, args, expected, description]
  rows:
    - [reprlib_extra14.Repr_and_aRepr_identity.bases_object,
       "Repr.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "Repr.__bases__[0].__name__ == 'object'"]
    - [reprlib_extra14.Repr_and_aRepr_identity.module,
       Repr.__module__.__eq__,
       ["reprlib"],
       true,
       "Repr.__module__ == 'reprlib'"]
    - [reprlib_extra14.Repr_and_aRepr_identity.aRepr_qualname,
       aRepr.__class__.__qualname__.__eq__,
       ["Repr"],
       true,
       "aRepr.__class__.__qualname__ == 'Repr'"]
