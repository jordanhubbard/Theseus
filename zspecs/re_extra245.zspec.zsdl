spec: re_extra245
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Lib/re/_constants.py"
    - "re_extra244.zspec.zsdl — covers re.IGNORECASE, re.MULTILINE, re.DOTALL, re.VERBOSE flag constants and re.compile"
  notes:
    - "This spec covers: re.A/re.ASCII, re.I/re.IGNORECASE, re.M/re.MULTILINE, re.S/re.DOTALL alias identity."
    - "re.A == re.ASCII == 256 — re.A is the short alias for re.ASCII; both are the same RegexFlag object; int value 256; verified Python 3.14.3 macOS."
    - "re.I == re.IGNORECASE == 2 — re.I is the short alias for re.IGNORECASE; both are the same RegexFlag object; int value 2; verified Python 3.14.3 macOS."
    - "re.M == re.MULTILINE == 8 — re.M is the short alias for re.MULTILINE; both are the same RegexFlag object; int value 8; verified Python 3.14.3 macOS."
    - "re.S == re.DOTALL == 16 — re.S is the short alias for re.DOTALL; both are the same RegexFlag object; int value 16; verified Python 3.14.3 macOS."
    - "re.A is re.ASCII evaluates True — they are literally the same Python object; verified Python 3.14.3 macOS."
    - "re.A.__int__() == 256 — ASCII flag value is 256 in Python 3.14.3 macOS (not 32); verified Python 3.14.3 macOS."
    - "All flag aliases are instances of re.RegexFlag (IntFlag subclass); __class__.__name__ == 'RegexFlag'; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.A/re.ASCII alias integer values
# re.A == re.ASCII == 256; re.I == re.IGNORECASE == 2;
# re.M == re.MULTILINE == 8; re.S == re.DOTALL == 16.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra245.alias_integer_values:
  description: "re flag alias integer values: A/ASCII=256, I/IGNORECASE=2, M/MULTILINE=8, S/DOTALL=16; verified Python 3.14.3"
  kind: python_call_eq
  category: flag_aliases
  id_prefix: realiases245

  columns: [id, function, args, expected]
  rows:
    - [a_int_eq,         A.__eq__,         [256], true]
    - [ascii_int_eq,     ASCII.__eq__,     [256], true]
    - [i_int_eq,         I.__eq__,         [2],   true]
    - [ignorecase_int,   IGNORECASE.__eq__, [2],  true]
    - [a_not_two,        A.__eq__,         [2],   false]

# ---------------------------------------------------------------------------
# re.M/MULTILINE and re.S/DOTALL integer values
# MULTILINE=8, DOTALL=16. All verified with Python 3.14.3 macOS.
# ---------------------------------------------------------------------------

table re_extra245.ms_alias_integer_values:
  description: "re flag alias integer values: M/MULTILINE=8, S/DOTALL=16; verified Python 3.14.3"
  kind: python_call_eq
  category: flag_aliases
  id_prefix: realiases245

  columns: [id, function, args, expected]
  rows:
    - [m_int_eq,         M.__eq__,         [8],   true]
    - [multiline_int,    MULTILINE.__eq__, [8],   true]
    - [s_int_eq,         S.__eq__,         [16],  true]
    - [dotall_int,       DOTALL.__eq__,    [16],  true]
    - [m_not_sixteen,    M.__eq__,         [16],  false]

# ---------------------------------------------------------------------------
# re flag alias __int__() values
# A.__int__()==256, I.__int__()==2, M.__int__()==8, S.__int__()==16.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra245.alias_int_method_values:
  description: "re flag alias __int__() values: A=256, I=2, M=8, S=16; verified Python 3.14.3"
  kind: python_call_eq
  category: flag_aliases
  id_prefix: realiases245

  columns: [id, function, args, expected]
  rows:
    - [a_int_method,       A.__int__,       [], 256]
    - [ascii_int_method,   ASCII.__int__,   [], 256]
    - [i_int_method,       I.__int__,       [], 2]
    - [m_int_method,       M.__int__,       [], 8]
    - [s_int_method,       S.__int__,       [], 16]

# ---------------------------------------------------------------------------
# re flag alias __class__.__name__ == 'RegexFlag'
# All flag aliases are RegexFlag (IntFlag) instances.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra245.alias_class_names:
  description: "re flag aliases __class__.__name__ == 'RegexFlag' for A, I, M, S; verified Python 3.14.3"
  kind: python_call_eq
  category: flag_aliases
  id_prefix: realiases245

  columns: [id, function, args, expected]
  rows:
    - [a_class_eq,      A.__class__.__name__.__eq__,         ["RegexFlag"], true]
    - [i_class_eq,      I.__class__.__name__.__eq__,         ["RegexFlag"], true]
    - [m_class_eq,      M.__class__.__name__.__eq__,         ["RegexFlag"], true]
    - [s_class_eq,      S.__class__.__name__.__eq__,         ["RegexFlag"], true]
    - [a_class_not_int, A.__class__.__name__.__eq__,         ["int"],       false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra245.A.int_eq:
  description: "re.A == 256 — the ASCII flag short alias integer value; verified Python 3.14.3 macOS"
  category: flag_aliases
  kind: python_call_eq
  function: A.__eq__
  args: [256]
  expected: true

invariant re_extra245.ASCII.int_eq:
  description: "re.ASCII == 256 — the full ASCII flag name integer value equals the short alias re.A; verified Python 3.14.3 macOS"
  category: flag_aliases
  kind: python_call_eq
  function: ASCII.__eq__
  args: [256]
  expected: true

invariant re_extra245.A.eq_ascii_int:
  description: "re.A.__eq__(re.ASCII.__int__()) == True — short alias A and long name ASCII share the same integer value 256; verified Python 3.14.3 macOS"
  category: flag_aliases
  kind: python_call_eq
  function: A.__eq__
  args: [256]
  expected: true

invariant re_extra245.I.int_eq:
  description: "re.I == 2 — the IGNORECASE flag short alias integer value; verified Python 3.14.3 macOS"
  category: flag_aliases
  kind: python_call_eq
  function: I.__eq__
  args: [2]
  expected: true

invariant re_extra245.IGNORECASE.int_eq:
  description: "re.IGNORECASE == 2 — the full IGNORECASE flag name integer value equals the short alias re.I; verified Python 3.14.3 macOS"
  category: flag_aliases
  kind: python_call_eq
  function: IGNORECASE.__eq__
  args: [2]
  expected: true

invariant re_extra245.M.int_eq:
  description: "re.M == 8 — the MULTILINE flag short alias integer value; verified Python 3.14.3 macOS"
  category: flag_aliases
  kind: python_call_eq
  function: M.__eq__
  args: [8]
  expected: true

invariant re_extra245.MULTILINE.int_eq:
  description: "re.MULTILINE == 8 — the full MULTILINE flag name integer value equals the short alias re.M; verified Python 3.14.3 macOS"
  category: flag_aliases
  kind: python_call_eq
  function: MULTILINE.__eq__
  args: [8]
  expected: true

invariant re_extra245.S.int_eq:
  description: "re.S == 16 — the DOTALL flag short alias integer value; verified Python 3.14.3 macOS"
  category: flag_aliases
  kind: python_call_eq
  function: S.__eq__
  args: [16]
  expected: true

invariant re_extra245.DOTALL.int_eq:
  description: "re.DOTALL == 16 — the full DOTALL flag name integer value equals the short alias re.S; verified Python 3.14.3 macOS"
  category: flag_aliases
  kind: python_call_eq
  function: DOTALL.__eq__
  args: [16]
  expected: true

invariant re_extra245.A.class_name_eq:
  description: "re.A.__class__.__name__ == 'RegexFlag' — A is an IntFlag subclass instance; verified Python 3.14.3 macOS"
  category: flag_aliases
  kind: python_call_eq
  function: A.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra245.A.int_method:
  description: "re.A.__int__() == 256 — calling __int__() on the ASCII alias returns 256; verified Python 3.14.3 macOS"
  category: flag_aliases
  kind: python_call_eq
  function: A.__int__
  args: []
  expected: 256

invariant re_extra245.I.int_method:
  description: "re.I.__int__() == 2 — calling __int__() on the IGNORECASE alias returns 2; verified Python 3.14.3 macOS"
  category: flag_aliases
  kind: python_call_eq
  function: I.__int__
  args: []
  expected: 2
