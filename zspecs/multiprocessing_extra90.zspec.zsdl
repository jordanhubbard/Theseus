table multiprocessing_extra90.property_attrs_absent:
  description: "multiprocessing Process close and property attributes absent from __dict__ checks in mpprocessdictmem90 namespace — wave 252 theme: multiprocessing.Process __dict__ membership for lifecycle methods; Process.__dict__.__contains__('close')==False; Process.__dict__.__contains__('name')==False; Process.__dict__.__contains__('daemon')==False; Process.__dict__.__contains__('pid')==False; Process.__dict__.__contains__('exitcode')==False; Process.__dict__.__contains__('authkey')==False; Process.__dict__.__contains__('sentinel')==False; all defined on BaseProcess; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpprocessdictmem90a

  columns: [id, function, args, expected, description]
  rows:
    - [close_absent,    "Process.__dict__.__contains__",  ["close"],    false, "Process.__dict__.__contains__('close') == False — close is defined on BaseProcess; verified with Python 3.14.3"]
    - [name_absent,     "Process.__dict__.__contains__",  ["name"],     false, "Process.__dict__.__contains__('name') == False — name property is defined on BaseProcess; verified with Python 3.14.3"]
    - [daemon_absent,   "Process.__dict__.__contains__",  ["daemon"],   false, "Process.__dict__.__contains__('daemon') == False — daemon property is defined on BaseProcess; verified with Python 3.14.3"]
    - [pid_absent,      "Process.__dict__.__contains__",  ["pid"],      false, "Process.__dict__.__contains__('pid') == False — pid property is defined on BaseProcess; verified with Python 3.14.3"]
    - [exitcode_absent, "Process.__dict__.__contains__",  ["exitcode"], false, "Process.__dict__.__contains__('exitcode') == False — exitcode property is defined on BaseProcess; verified with Python 3.14.3"]
    - [authkey_absent,  "Process.__dict__.__contains__",  ["authkey"],  false, "Process.__dict__.__contains__('authkey') == False — authkey property is defined on BaseProcess; verified with Python 3.14.3"]
    - [sentinel_absent, "Process.__dict__.__contains__",  ["sentinel"], false, "Process.__dict__.__contains__('sentinel') == False — sentinel property is defined on BaseProcess; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Process internal attrs present in __dict__ — extra90
#
# Process.__dict__.__contains__('_Popen') == True
# Process.__dict__.__contains__('__doc__') == True
# Process.__dict__.__contains__('_after_fork') == True
# Process.__dict__.__contains__('_start_method') == True
# Process.__dict__.__contains__('__module__') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra90.internal_attrs_present:
  description: "multiprocessing Process internal attributes present in __dict__ checks in mpprocessdictmem90 namespace — wave 252 theme: multiprocessing.Process __dict__ membership for lifecycle methods; Process.__dict__.__contains__('_Popen')==True (the platform-specific Popen class attribute); Process.__dict__.__contains__('__doc__')==True; Process.__dict__.__contains__('_after_fork')==True (hook for post-fork initialization); Process.__dict__.__contains__('_start_method')==True; Process.__dict__.__contains__('__module__')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpprocessdictmem90b

  columns: [id, function, args, expected, description]
  rows:
    - [popen_present,       "Process.__dict__.__contains__",  ["_Popen"],       true, "Process.__dict__.__contains__('_Popen') == True — platform-specific Popen class attribute defined directly on Process; verified with Python 3.14.3"]
    - [doc_present,         "Process.__dict__.__contains__",  ["__doc__"],      true, "Process.__dict__.__contains__('__doc__') == True — __doc__ is defined directly on Process; verified with Python 3.14.3"]
    - [after_fork_present,  "Process.__dict__.__contains__",  ["_after_fork"],  true, "Process.__dict__.__contains__('_after_fork') == True — _after_fork hook defined directly on Process; verified with Python 3.14.3"]
    - [start_method_present,"Process.__dict__.__contains__",  ["_start_method"],true, "Process.__dict__.__contains__('_start_method') == True — _start_method defined directly on Process; verified with Python 3.14.3"]
    - [module_present,      "Process.__dict__.__contains__",  ["__module__"],   true, "Process.__dict__.__contains__('__module__') == True — __module__ is defined directly on Process; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Process __dict__ class and size — extra90
#
# Process.__dict__.__class__.__name__ == 'mappingproxy'
# Process.__dict__.__len__() == 7
# ---------------------------------------------------------------------------

table multiprocessing_extra90.dict_class_and_size:
  description: "multiprocessing Process __dict__ class name and size checks in mpprocessdictmem90 namespace — wave 252 theme: multiprocessing.Process __dict__ membership for lifecycle methods; Process.__dict__.__class__.__name__.__eq__('mappingproxy')==True (class __dict__ is always a read-only mappingproxy); Process.__dict__.__len__()==7 (only 7 keys defined directly on Process); Process.__dict__.__contains__('_Popen')==True (cross-check); Process.__dict__.__contains__('start')==False (cross-check; lifecycle methods on BaseProcess); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpprocessdictmem90c

  columns: [id, function, args, expected, description]
  rows:
    - [dict_class_name,  "Process.__dict__.__class__.__name__.__eq__",  ["mappingproxy"], true, "Process.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is a read-only mappingproxy; verified with Python 3.14.3"]
    - [dict_len,         Process.__dict__.__len__,                      [],               7,    "Process.__dict__.__len__() == 7 — only 7 keys defined directly on Process; verified with Python 3.14.3"]
    - [popen_cross,      "Process.__dict__.__contains__",               ["_Popen"],       true, "Process.__dict__.__contains__('_Popen') == True — cross-check; verified with Python 3.14.3"]
    - [start_cross,      "Process.__dict__.__contains__",               ["start"],        false, "Process.__dict__.__contains__('start') == False — cross-check; lifecycle methods on BaseProcess; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra90
# ---------------------------------------------------------------------------

invariant multiprocessing_extra90.Process_start_absent_from_dict:
  description: "multiprocessing.Process.__dict__.__contains__('start') returns False — start is defined on BaseProcess (the parent class), not overridden in the Process subclass; Process.__dict__ only contains items directly defined on Process itself; NEW in extra90: first standalone __dict__ membership invariant for Process.start in mpprocessdictmem90 namespace; wave 252; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Process.__dict__.__contains__"
  args: ["start"]
  expected: false

invariant multiprocessing_extra90.Process_run_absent_from_dict:
  description: "multiprocessing.Process.__dict__.__contains__('run') returns False — run is defined on BaseProcess, not overridden in the Process subclass dict; subclasses of multiprocessing.Process typically override run() to define subprocess behavior; NEW in extra90: first standalone __dict__ membership invariant for Process.run in mpprocessdictmem90 namespace; wave 252; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Process.__dict__.__contains__"
  args: ["run"]
  expected: false

invariant multiprocessing_extra90.Process_Popen_present_in_dict:
  description: "multiprocessing.Process.__dict__.__contains__('_Popen') returns True — _Popen is a class attribute defined directly on Process (not BaseProcess); it holds the platform-specific Popen class used to spawn the subprocess; NEW in extra90: first standalone __dict__ membership invariant for Process._Popen in mpprocessdictmem90 namespace; wave 252; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Process.__dict__.__contains__"
  args: ["_Popen"]
  expected: true

invariant multiprocessing_extra90.Process_dict_is_mappingproxy:
  description: "multiprocessing.Process.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — the class __dict__ is always a read-only mappingproxy instance, preventing direct mutation of class attributes via __dict__; NEW in extra90: first standalone __dict__ class name invariant for Process in mpprocessdictmem90 namespace; wave 252; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Process.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

invariant multiprocessing_extra90.Process_dict_len_seven:
  description: "multiprocessing.Process.__dict__.__len__() == 7 — only 7 keys (_Popen, __doc__, _after_fork, _start_method, __module__, __firstlineno__, __static_attributes__) are defined directly on Process; all lifecycle methods and properties are inherited from BaseProcess; NEW in extra90: first standalone __dict__ length invariant for Process in mpprocessdictmem90 namespace; wave 252; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__dict__.__len__
  args: []
  expected: 7
