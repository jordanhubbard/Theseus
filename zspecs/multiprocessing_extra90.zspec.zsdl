spec: multiprocessing_extra90
version: ">=3.9"
backend: python_module(multiprocessing)
extends: multiprocessing_extra89

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/__init__.py"
  notes:
    - "This spec extends multiprocessing_extra89.zspec.zsdl."
    - "This spec covers: wave 252 theme — multiprocessing.Process __dict__ membership for lifecycle methods and internal attrs. NEW in extra90: Process.__dict__.__contains__('start')==False; Process.__dict__.__contains__('run')==False; Process.__dict__.__contains__('join')==False; Process.__dict__.__contains__('is_alive')==False; Process.__dict__.__contains__('terminate')==False; Process.__dict__.__contains__('kill')==False; Process.__dict__.__contains__('close')==False; Process.__dict__.__contains__('name')==False; Process.__dict__.__contains__('daemon')==False; Process.__dict__.__contains__('pid')==False; Process.__dict__.__contains__('exitcode')==False; Process.__dict__.__contains__('authkey')==False; Process.__dict__.__contains__('sentinel')==False; Process.__dict__.__contains__('__init__')==False; Process.__dict__.__contains__('__repr__')==False; Process.__dict__.__contains__('_Popen')==True; Process.__dict__.__contains__('__doc__')==True; Process.__dict__.__contains__('_after_fork')==True; Process.__dict__.__contains__('_start_method')==True; Process.__dict__.__contains__('__module__')==True; Process.__dict__.__class__.__name__=='mappingproxy'; Process.__dict__.__len__()==7. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process lifecycle methods (start, run, join, is_alive, terminate, kill, close) are NOT in Process.__dict__. They are defined on a parent class (BaseProcess) and not overridden in the Process subclass dict. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process property attrs (name, daemon, pid, exitcode, authkey, sentinel) are NOT in Process.__dict__. They are defined on BaseProcess. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__ contains '_Popen', '__doc__', '_after_fork', '_start_method', '__module__', '__firstlineno__', '__static_attributes__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__.__class__.__name__ == 'mappingproxy'. The class __dict__ is always a mappingproxy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__.__len__() == 7. Only 7 keys are defined directly on Process. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process lifecycle methods absent from __dict__ — extra90
#
# Wave 252 theme: multiprocessing.Process __dict__ membership for lifecycle methods.
#
# Process.__dict__.__contains__('start') == False
# Process.__dict__.__contains__('run') == False
# Process.__dict__.__contains__('join') == False
# Process.__dict__.__contains__('is_alive') == False
# Process.__dict__.__contains__('terminate') == False
# Process.__dict__.__contains__('kill') == False
# ---------------------------------------------------------------------------

table multiprocessing_extra90.lifecycle_methods_absent:
  description: "multiprocessing Process lifecycle methods absent from __dict__ checks in mpprocessdictmem90 namespace — wave 252 theme: multiprocessing.Process __dict__ membership for lifecycle methods; Process.__dict__.__contains__('start')==False (start is defined on BaseProcess, not overridden on Process); Process.__dict__.__contains__('run')==False; Process.__dict__.__contains__('join')==False; Process.__dict__.__contains__('is_alive')==False; Process.__dict__.__contains__('terminate')==False; Process.__dict__.__contains__('kill')==False; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpprocessdictmem90

  columns: [id, function, args, expected, description]
  rows:
    - [start_absent,     "Process.__dict__.__contains__",  ["start"],    false, "Process.__dict__.__contains__('start') == False — start is defined on BaseProcess, not overridden on Process; verified with Python 3.14.3"]
    - [run_absent,       "Process.__dict__.__contains__",  ["run"],      false, "Process.__dict__.__contains__('run') == False — run is defined on BaseProcess, not overridden on Process; verified with Python 3.14.3"]
    - [join_absent,      "Process.__dict__.__contains__",  ["join"],     false, "Process.__dict__.__contains__('join') == False — join is defined on BaseProcess; verified with Python 3.14.3"]
    - [is_alive_absent,  "Process.__dict__.__contains__",  ["is_alive"], false, "Process.__dict__.__contains__('is_alive') == False — is_alive is defined on BaseProcess; verified with Python 3.14.3"]
    - [terminate_absent, "Process.__dict__.__contains__",  ["terminate"], false, "Process.__dict__.__contains__('terminate') == False — terminate is defined on BaseProcess; verified with Python 3.14.3"]
    - [kill_absent,      "Process.__dict__.__contains__",  ["kill"],     false, "Process.__dict__.__contains__('kill') == False — kill is defined on BaseProcess; verified with Python 3.14.3"]

