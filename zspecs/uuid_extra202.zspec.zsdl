spec: uuid_extra202
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "This spec extends uuid_extra.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "uuid_extra.zspec.zsdl covers: UUID.__name__, UUID.__module__, uuid1/3/4/5 __name__, uuid4 return type and version, NAMESPACE_DNS/URL/OID/X500 class names, UUID .int and .hex class names."
    - "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID' — all NAMESPACE_* constants are UUID instances."
    - "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID' — X500 namespace is also a UUID instance."
    - "uuid.UUID.__dict__.__contains__('bytes_le') == True — bytes_le is a property on UUID."
    - "uuid.UUID.__dict__.__contains__('variant') == True — variant is a property on UUID."
    - "uuid.UUID.__dict__.__contains__('version') == True — version is a property on UUID."
    - "uuid.UUID.__dict__.__len__() == 37 — the class dict has 37 entries as of Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NAMESPACE_OID and NAMESPACE_X500 — class name checks
# These are pre-defined UUID constants in the uuid module.
# ---------------------------------------------------------------------------

table uuid_extra202.namespace_oid_x500_class:
  description: "uuid.NAMESPACE_OID and NAMESPACE_X500 class name checks in uuidns202 namespace — wave 257 theme: all NAMESPACE_* constants are UUID instances; NAMESPACE_OID.__class__.__name__=='UUID'; NAMESPACE_X500.__class__.__name__=='UUID'; both are module-level constants defined in Lib/uuid.py; NAMESPACE_OID is the OID namespace UUID (6ba7b812-9dad-11d1-80b4-00c04fd430c8); NAMESPACE_X500 is the X.500 namespace UUID (6ba7b814-9dad-11d1-80b4-00c04fd430c8); verified with Python 3.14.3"
  kind: python_call_eq
  category: namespaces
  id_prefix: uuidns202

  columns: [id, function, args, expected, description]
  rows:
    - [oid_class_name,   NAMESPACE_OID.__class__.__name__.__eq__,   ["UUID"], true, "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID' — OID namespace is a UUID instance; verified with Python 3.14.3"]
    - [x500_class_name,  NAMESPACE_X500.__class__.__name__.__eq__,  ["UUID"], true, "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID' — X500 namespace is a UUID instance; verified with Python 3.14.3"]
    - [oid_module_name,  NAMESPACE_OID.__class__.__module__.__eq__,  ["uuid"], true, "uuid.NAMESPACE_OID.__class__.__module__ == 'uuid' — class is defined in the uuid module; verified with Python 3.14.3"]
    - [x500_module_name, NAMESPACE_X500.__class__.__module__.__eq__, ["uuid"], true, "uuid.NAMESPACE_X500.__class__.__module__ == 'uuid' — class is defined in the uuid module; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# UUID.__dict__ — descriptor presence checks for bytes_le, variant, version
#
# uuid.UUID.__dict__.__len__() == 37
# ---------------------------------------------------------------------------

table uuid_extra202.UUID_dict_descriptors:
  description: "uuid.UUID.__dict__ descriptor presence checks in uuidns202 namespace — wave 257 theme: UUID.__dict__.__contains__('bytes_le')==True; UUID.__dict__.__contains__('variant')==True; UUID.__dict__.__contains__('version')==True; UUID.__dict__.__contains__('time_low')==True; UUID.__dict__.__contains__('node')==True; UUID.__dict__.__len__()==37; bytes_le, variant, version are property descriptors providing computed views of the UUID's internal integer representation; time_low and node are additional field accessors; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_dict
  id_prefix: uuidns202a

  columns: [id, function, args, expected, description]
  rows:
    - [has_bytes_le,  UUID.__dict__.__contains__, ["bytes_le"], true, "uuid.UUID.__dict__.__contains__('bytes_le') == True — bytes_le property is in UUID class dict; verified with Python 3.14.3"]
    - [has_variant,   UUID.__dict__.__contains__, ["variant"],  true, "uuid.UUID.__dict__.__contains__('variant') == True — variant property is in UUID class dict; verified with Python 3.14.3"]
    - [has_version,   UUID.__dict__.__contains__, ["version"],  true, "uuid.UUID.__dict__.__contains__('version') == True — version property is in UUID class dict; verified with Python 3.14.3"]
    - [has_time_low,  UUID.__dict__.__contains__, ["time_low"], true, "uuid.UUID.__dict__.__contains__('time_low') == True — time_low property is in UUID class dict; verified with Python 3.14.3"]
    - [has_node,      UUID.__dict__.__contains__, ["node"],     true, "uuid.UUID.__dict__.__contains__('node') == True — node property is in UUID class dict; verified with Python 3.14.3"]
    - [dict_len,      UUID.__dict__.__len__,       [],          37,   "uuid.UUID.__dict__.__len__() == 37 — 37 entries in class dict as of Python 3.14.3; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# UUID.__dict__ — additional field accessor presence
#
# Checks for time_mid, time_hi_version, clock_seq, fields, hex, urn
# ---------------------------------------------------------------------------

table uuid_extra202.UUID_dict_extra_fields:
  description: "uuid.UUID.__dict__ additional field accessor presence checks in uuidns202 namespace — wave 257 theme: UUID.__dict__.__contains__('time_mid')==True; UUID.__dict__.__contains__('time_hi_version')==True; UUID.__dict__.__contains__('clock_seq')==True; UUID.__dict__.__contains__('fields')==True; UUID.__dict__.__contains__('hex')==True; UUID.__dict__.__contains__('urn')==True; these are all property descriptors providing named access to the sub-fields of the UUID's 128-bit integer; per RFC 9562 section 4, the UUID is composed of time_low, time_mid, time_hi_version, clock_seq_hi_variant, clock_seq_low, and node; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_dict
  id_prefix: uuidns202b

  columns: [id, function, args, expected, description]
  rows:
    - [has_time_mid,       UUID.__dict__.__contains__, ["time_mid"],       true, "uuid.UUID.__dict__.__contains__('time_mid') == True — time_mid field accessor; verified with Python 3.14.3"]
    - [has_time_hi_ver,    UUID.__dict__.__contains__, ["time_hi_version"], true, "uuid.UUID.__dict__.__contains__('time_hi_version') == True — time_hi_version field accessor; verified with Python 3.14.3"]
    - [has_clock_seq,      UUID.__dict__.__contains__, ["clock_seq"],      true, "uuid.UUID.__dict__.__contains__('clock_seq') == True — clock_seq composite field accessor; verified with Python 3.14.3"]
    - [has_fields,         UUID.__dict__.__contains__, ["fields"],         true, "uuid.UUID.__dict__.__contains__('fields') == True — fields tuple accessor; verified with Python 3.14.3"]
    - [has_hex,            UUID.__dict__.__contains__, ["hex"],            true, "uuid.UUID.__dict__.__contains__('hex') == True — hex string property; verified with Python 3.14.3"]
    - [has_urn,            UUID.__dict__.__contains__, ["urn"],            true, "uuid.UUID.__dict__.__contains__('urn') == True — URN string property (urn:uuid:...); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — uuid_extra202
# ---------------------------------------------------------------------------

invariant uuid_extra202.NAMESPACE_OID_class_is_UUID:
  description: "uuid.NAMESPACE_OID.__class__.__name__.__eq__('UUID') returns True — NAMESPACE_OID is a UUID constant defined in Lib/uuid.py representing the ISO OID namespace; its hex value is '6ba7b8129dad11d180b400c04fd430c8'; the OID namespace is used with uuid3/uuid5 to generate name-based UUIDs in the OID namespace; type(NAMESPACE_OID).__name__ == 'UUID' because type() and .__class__ are equivalent for pure-Python classes; compare: all four NAMESPACE_* constants share the same class; NEW in uuid_extra202: first standalone NAMESPACE_OID class invariant in uuidns202 namespace; wave 257; verified with Python 3.14.3"
  category: namespaces
  kind: python_call_eq
  function: NAMESPACE_OID.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra202.NAMESPACE_X500_class_is_UUID:
  description: "uuid.NAMESPACE_X500.__class__.__name__.__eq__('UUID') returns True — NAMESPACE_X500 is a UUID constant defined in Lib/uuid.py representing the X.500 DN namespace; its hex value is '6ba7b8149dad11d180b400c04fd430c8'; the X.500 namespace is used with uuid3/uuid5 for distinguished name (DN) based UUIDs; all four NAMESPACE_* constants (DNS, URL, OID, X500) are UUID instances and share the same class 'UUID'; NEW in uuid_extra202: first standalone NAMESPACE_X500 class invariant in uuidns202 namespace; wave 257; verified with Python 3.14.3"
  category: namespaces
  kind: python_call_eq
  function: NAMESPACE_X500.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra202.UUID_dict_len_37:
  description: "uuid.UUID.__dict__.__len__() == 37 — the UUID class dict contains 37 entries as of Python 3.14.3 on macOS; these include: __doc__, __eq__, __firstlineno__, __ge__, __getstate__, __gt__, __hash__, __init__, __int__, __le__, __lt__, __module__, __repr__, __setattr__, __setstate__, __slots__, __static_attributes__, __str__, __weakref__, _from_int, bytes, bytes_le, clock_seq, clock_seq_hi_variant, clock_seq_low, fields, hex, int, is_safe, node, time, time_hi_version, time_low, time_mid, urn, variant, version (37 total); NEW in uuid_extra202: first standalone UUID dict length invariant in uuidns202 namespace; wave 257; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__len__
  args: []
  expected: 37

invariant uuid_extra202.UUID_dict_contains_bytes_le:
  description: "uuid.UUID.__dict__.__contains__('bytes_le') returns True — bytes_le is a property descriptor on the UUID class providing the UUID as a bytes object in little-endian byte order (RFC 4122 'mixed-endian'); bytes_le differs from bytes in that time_low and time_mid are stored as little-endian 32-bit and 16-bit integers while time_hi_version and the rest use big-endian; this ordering is required for Microsoft COM/DCOM GUIDs; bytes_le was present since uuid was added to the stdlib; compare: UUID.__dict__.__contains__('bytes')==True (big-endian RFC 4122 form); NEW in uuid_extra202: first standalone bytes_le dict-contains invariant; wave 257; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["bytes_le"]
  expected: true

invariant uuid_extra202.UUID_dict_contains_variant:
  description: "uuid.UUID.__dict__.__contains__('variant') returns True — variant is a property descriptor on the UUID class that returns the RFC 4122 variant field value (an instance of uuid.RFC_4122, uuid.RESERVED_NCS, uuid.RESERVED_MICROSOFT, or uuid.RESERVED_FUTURE); the variant field occupies the upper bits of clock_seq_hi_variant; variant is used to distinguish UUID versions from non-standard formats; NEW in uuid_extra202: first standalone variant dict-contains invariant; wave 257; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["variant"]
  expected: true

invariant uuid_extra202.UUID_dict_contains_version:
  description: "uuid.UUID.__dict__.__contains__('version') returns True — version is a property descriptor on the UUID class that returns the UUID version number (1, 2, 3, 4, or 5) if the variant is RFC_4122, otherwise returns None; for uuid4() the version property returns 4; for uuid1() it returns 1; version is encoded in bits 12-15 of time_hi_version; NEW in uuid_extra202: first standalone version dict-contains invariant; wave 257; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["version"]
  expected: true

invariant uuid_extra202.UUID_dict_contains_time_low:
  description: "uuid.UUID.__dict__.__contains__('time_low') returns True — time_low is a property descriptor on the UUID class that returns the low 32 bits of the 60-bit time value in a version-1 UUID (bits 0-31 of the UUID's 128-bit integer, i.e. the first 8 hex digits); for non-time-based UUIDs (v3/v4/v5) time_low is still accessible as a field but its value has no temporal meaning; this follows the RFC 9562 field structure where time_low occupies octets 0-3; NEW in uuid_extra202: first standalone time_low dict-contains invariant; wave 257; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["time_low"]
  expected: true

invariant uuid_extra202.UUID_dict_contains_node:
  description: "uuid.UUID.__dict__.__contains__('node') returns True — node is a property descriptor on the UUID class that returns the 48-bit node field (MAC address or random value for v4); in version-1 UUIDs the node is typically derived from the host MAC address; in version-4 UUIDs the node field contains random bits; node occupies the last 6 octets of the UUID (bits 80-127); uuid.getnode() returns the current system's MAC address which is used as the node field in uuid1(); NEW in uuid_extra202: first standalone node dict-contains invariant; wave 257; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["node"]
  expected: true
