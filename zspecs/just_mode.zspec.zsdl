spec: just_mode
version: ">=2.2.0"
backend: node(just-mode)

docs: https://www.npmjs.com/package/just-mode

provenance:
  derived_from:
    - "just-mode README — https://www.npmjs.com/package/just-mode"
    - "Test vectors verified with just-mode via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "just-mode source"
  notes:
    - "just-mode is an npm package. Install: npm install just-mode"
    - "Returns the most frequently occurring value in an array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a value."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_mode.mode:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: jmode

  columns: [id, args, expected]
  rows:
    - [most_freq,  [[1, 2, 2, 3, 3, 3]],  3]
    - [single,     [[5, 5, 5]],            5]
    - [two_vals,   [[1, 1, 2, 2, 2]],     2]
