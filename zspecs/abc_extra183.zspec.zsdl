spec: abc_extra183
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "abc.ABCMeta.__mro__ == (ABCMeta, type, object) — length 3; ABCMeta extends type (the metaclass)."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta directly subclasses type."
    - "abc.ABCMeta.__name__ == 'ABCMeta' (len=7); ABCMeta.__doc__.__class__.__name__ == 'str'."
    - "abc.ABC.__mro__ == (ABC, object) — length 2; ABC is a simple helper class."
    - "abc.ABC.__bases__[0].__name__ == 'object' — ABC directly subclasses object."
    - "abc.ABC.__name__ == 'ABC' (len=3)."
    - "MRO length ordering: ABC(2) < ABCMeta(3)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABCMeta MRO and inheritance chain
#
# abc.ABCMeta.__mro__.__len__().__eq__(3) == True (ABCMeta, type, object)
# abc.ABCMeta.__bases__[0].__name__.__eq__('type') == True
# abc.ABCMeta.__name__.__len__().__eq__(7) == True
# abc.ABCMeta.__doc__.__class__.__name__.__eq__('str') == True
# ---------------------------------------------------------------------------

table abc_extra183.abcmeta_mro:
  description: "abc.ABCMeta MRO length (3), base class (type), name length (7), and docstring class identity; new to abc_extra183"
  kind: python_call_eq
  category: identity
  id_prefix: abcmro183

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_mro_len_3,
       ABCMeta.__mro__.__len__,
       [],
       3,
       "abc.ABCMeta.__mro__.__len__() == 3 — MRO is (ABCMeta, type, object); tuple.__len__() returns 3; new to abc_extra183"]
    - [abcmeta_bases0_type,
       "ABCMeta.__bases__[0].__name__.__eq__",
       ["type"],
       true,
       "abc.ABCMeta.__bases__[0].__name__.__eq__('type') == True — ABCMeta directly subclasses type (the metaclass); str.__eq__ returns True; new to abc_extra183"]
    - [abcmeta_name_len_7,
       ABCMeta.__name__.__len__,
       [],
       7,
       "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters: A-B-C-M-e-t-a; str.__len__() returns 7; new to abc_extra183"]
    - [abcmeta_name_eq,
       ABCMeta.__name__.__eq__,
       ["ABCMeta"],
       true,
       "abc.ABCMeta.__name__.__eq__('ABCMeta') == True — class name string identity; str.__eq__ returns True; new to abc_extra183"]
    - [abcmeta_doc_class_name_eq,
       "ABCMeta.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "abc.ABCMeta.__doc__.__class__.__name__.__eq__('str') == True — ABCMeta has a string docstring; str.__eq__ returns True; new to abc_extra183"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABC MRO and inheritance chain
#
# abc.ABC.__mro__.__len__().__eq__(2) == True (ABC, object)
# abc.ABC.__bases__[0].__name__.__eq__('object') == True
# abc.ABC.__name__.__len__().__eq__(3) == True
# ---------------------------------------------------------------------------

table abc_extra183.abc_mro:
  description: "abc.ABC MRO length (2), base class (object), and name length (3) identity; new to abc_extra183"
  kind: python_call_eq
  category: identity
  id_prefix: abcmro183

  columns: [id, function, args, expected, description]
  rows:
    - [abc_mro_len_2,
       ABC.__mro__.__len__,
       [],
       2,
       "abc.ABC.__mro__.__len__() == 2 — MRO is (ABC, object); tuple.__len__() returns 2; new to abc_extra183"]
    - [abc_bases0_object,
       "ABC.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "abc.ABC.__bases__[0].__name__.__eq__('object') == True — ABC directly subclasses object; str.__eq__ returns True; new to abc_extra183"]
    - [abc_name_len_3,
       ABC.__name__.__len__,
       [],
       3,
       "abc.ABC.__name__.__len__() == 3 — 'ABC' has 3 characters: A-B-C; str.__len__() returns 3; new to abc_extra183"]
    - [abc_name_eq,
       ABC.__name__.__eq__,
       ["ABC"],
       true,
       "abc.ABC.__name__.__eq__('ABC') == True — class name string identity; str.__eq__ returns True; new to abc_extra183"]
    - [abc_mro_len_2b,
       ABC.__mro__.__len__,
       [],
       2,
       "abc.ABC.__mro__.__len__() == 2 — MRO length ordering anchor: ABC(2) < ABCMeta(3); tuple.__len__() returns 2; new to abc_extra183"]

# ---------------------------------------------------------------------------
# Table 3: ABCMeta vs ABC MRO length ordering
#
# ABC(2) < ABCMeta(3) — MRO length ordering
# ---------------------------------------------------------------------------

table abc_extra183.mro_length_ordering:
  description: "abc.ABC and abc.ABCMeta MRO length ordering: ABC(2) < ABCMeta(3); new to abc_extra183"
  kind: python_call_eq
  category: identity
  id_prefix: abcmro183

  columns: [id, function, args, expected, description]
  rows:
    - [abc_mro_len_ordering,
       ABC.__mro__.__len__,
       [],
       2,
       "abc.ABC.__mro__.__len__() == 2 — ordering anchor: ABC MRO is shorter than ABCMeta MRO; tuple.__len__() returns 2; new to abc_extra183"]
    - [abcmeta_mro_len_ordering,
       ABCMeta.__mro__.__len__,
       [],
       3,
       "abc.ABCMeta.__mro__.__len__() == 3 — ordering ceiling: ABC(2) < ABCMeta(3); tuple.__len__() returns 3; new to abc_extra183"]
    - [abc_name_len_ordering,
       ABC.__name__.__len__,
       [],
       3,
       "abc.ABC.__name__.__len__() == 3 — name length: 'ABC' has 3 characters; str.__len__() returns 3; new to abc_extra183"]
    - [abcmeta_name_len_ordering,
       ABCMeta.__name__.__len__,
       [],
       7,
       "abc.ABCMeta.__name__.__len__() == 7 — name length: 'ABCMeta' has 7 characters; str.__len__() returns 7; new to abc_extra183"]
    - [abcmeta_bases0_type_ordering,
       "ABCMeta.__bases__[0].__name__.__eq__",
       ["type"],
       true,
       "abc.ABCMeta.__bases__[0].__name__.__eq__('type') == True — ABCMeta subclasses type, giving it its longer MRO; str.__eq__ returns True; new to abc_extra183"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra183
# ---------------------------------------------------------------------------

invariant abc_extra183.abcmeta_mro_len_3:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — MRO is (ABCMeta, type, object); new to abc_extra183"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra183.abcmeta_bases0_type:
  description: "abc.ABCMeta.__bases__[0].__name__.__eq__('type') == True — ABCMeta directly subclasses type; new to abc_extra183"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra183.abcmeta_name_len_7:
  description: "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters; new to abc_extra183"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__name__.__len__
  args: []
  expected: 7

invariant abc_extra183.abc_mro_len_2:
  description: "abc.ABC.__mro__.__len__() == 2 — MRO is (ABC, object); new to abc_extra183"
  category: identity
  kind: python_call_eq
  function: ABC.__mro__.__len__
  args: []
  expected: 2

invariant abc_extra183.abc_bases0_object:
  description: "abc.ABC.__bases__[0].__name__.__eq__('object') == True — ABC directly subclasses object; new to abc_extra183"
  category: identity
  kind: python_call_eq
  function: "ABC.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant abc_extra183.abc_name_len_3:
  description: "abc.ABC.__name__.__len__() == 3 — 'ABC' has 3 characters; new to abc_extra183"
  category: identity
  kind: python_call_eq
  function: ABC.__name__.__len__
  args: []
  expected: 3

invariant abc_extra183.abcmeta_doc_class_str:
  description: "abc.ABCMeta.__doc__.__class__.__name__.__eq__('str') == True — ABCMeta has a string docstring; new to abc_extra183"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__doc__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

invariant abc_extra183.abc_name_eq:
  description: "abc.ABC.__name__.__eq__('ABC') == True — class name identity; len=3; new to abc_extra183"
  category: identity
  kind: python_call_eq
  function: ABC.__name__.__eq__
  args: ["ABC"]
  expected: true
