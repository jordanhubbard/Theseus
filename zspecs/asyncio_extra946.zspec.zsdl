spec: asyncio_extra946
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes:
    - "Checks __module__ attribute for core asyncio coroutine and task functions"
    - "asyncio.timeout added in Python 3.11; rows for it require version >=3.11"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra946.sleep_gather_wait_modules:
  description: "asyncio.sleep, asyncio.gather, asyncio.wait __module__ identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: as946sgw
  columns: [id, function, args, expected]
  rows:
    - [as946sgw001, asyncio.sleep.__module__.__eq__,         ["asyncio"],         true]
    - [as946sgw002, asyncio.gather.__module__.__eq__,        ["asyncio"],         true]
    - [as946sgw003, asyncio.wait.__module__.__eq__,          ["asyncio"],         true]
    - [as946sgw004, asyncio.wait_for.__module__.__eq__,      ["asyncio"],         true]
    - [as946sgw005, asyncio.shield.__module__.__eq__,        ["asyncio"],         true]
    - [as946sgw006, asyncio.run.__module__.__eq__,           ["asyncio"],         true]

table asyncio_extra946.task_functions_modules:
  description: "asyncio.create_task, asyncio.current_task, asyncio.all_tasks __module__ identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: as946tfm
  columns: [id, function, args, expected]
  rows:
    - [as946tfm001, asyncio.create_task.__module__.__eq__,   ["asyncio"],         true]
    - [as946tfm002, asyncio.current_task.__module__.__eq__,  ["asyncio"],         true]
    - [as946tfm003, asyncio.all_tasks.__module__.__eq__,     ["asyncio"],         true]
    - [as946tfm004, asyncio.create_task.__qualname__.__eq__, ["create_task"],     true]
    - [as946tfm005, asyncio.current_task.__qualname__.__eq__, ["current_task"],   true]
    - [as946tfm006, asyncio.all_tasks.__qualname__.__eq__,   ["all_tasks"],       true]

table asyncio_extra946.qualnames_and_class:
  description: "asyncio function __qualname__ and class name checks"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: as946qnc
  columns: [id, function, args, expected]
  rows:
    - [as946qnc001, asyncio.sleep.__qualname__.__eq__,       ["sleep"],           true]
    - [as946qnc002, asyncio.gather.__qualname__.__eq__,      ["gather"],          true]
    - [as946qnc003, asyncio.wait.__qualname__.__eq__,        ["wait"],            true]
    - [as946qnc004, asyncio.wait_for.__qualname__.__eq__,    ["wait_for"],        true]
    - [as946qnc005, asyncio.shield.__qualname__.__eq__,      ["shield"],          true]
    - [as946qnc006, asyncio.run.__qualname__.__eq__,         ["run"],             true]
    - [as946qnc007, asyncio.sleep.__class__.__name__.__eq__, ["function"],        true]
