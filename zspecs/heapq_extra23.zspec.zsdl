spec: heapq_extra23
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
  notes:
    - "This spec extends heapq_extra22.zspec.zsdl."
    - "Prior specs covered: heapq.__name__/__package__, heappush/heappop/heapify/heapreplace/heappushpop/nlargest/nsmallest/merge __name__/__module__, name length table, __qualname__ checks, __qualname__.__eq__ table, __module__.__len__() for all 8, __name__.__len__() for all 8 (extra22)."
    - "This spec covers: heapq.__all__.__len__() (13 exports in Python 3.14); __qualname__.__len__() table for the 8 classic callables; __name__.__len__() and __module__.__len__() for the 5 new max-heap variants (heappush_max, heappop_max, heapify_max, heapreplace_max, heappushpop_max); heapq.__spec__.__class__.__name__.__len__() and heapq.__loader__.__class__.__name__.__len__()."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "heapq.__all__.__len__() == 13. Verified."
    - "heapq.heappush.__qualname__.__len__() == 8. Verified."
    - "heapq.heappop.__qualname__.__len__() == 7. Verified."
    - "heapq.heapify.__qualname__.__len__() == 7. Verified."
    - "heapq.heapreplace.__qualname__.__len__() == 11. Verified."
    - "heapq.heappushpop.__qualname__.__len__() == 11. Verified."
    - "heapq.nlargest.__qualname__.__len__() == 8. Verified."
    - "heapq.nsmallest.__qualname__.__len__() == 9. Verified."
    - "heapq.merge.__qualname__.__len__() == 5. Verified."
    - "heapq.heappush_max.__name__.__len__() == 12; __module__ == '_heapq' (len 6). Verified."
    - "heapq.heappop_max.__name__.__len__() == 11; __module__ == '_heapq' (len 6). Verified."
    - "heapq.heapify_max.__name__.__len__() == 11; __module__ == '_heapq' (len 6). Verified."
    - "heapq.heapreplace_max.__name__.__len__() == 15; __module__ == '_heapq' (len 6). Verified."
    - "heapq.heappushpop_max.__name__.__len__() == 15; __module__ == '_heapq' (len 6). Verified."
    - "heapq.__spec__.__class__.__name__.__len__() == 10. Verified."
    - "heapq.__loader__.__class__.__name__.__len__() == 16. Verified."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# heapq.__all__.__len__() — 13 public names in Python 3.14
#
# In Python 3.14 heapq.__all__ contains 13 entries: the 8 classic heap
# operations (heappush, heappop, heapify, heapreplace, heappushpop, nlargest,
# nsmallest, merge) plus 5 max-heap variants added in later CPython releases
# (heappush_max, heappop_max, heapify_max, heapreplace_max, heappushpop_max).
# No prior heapq spec checks __all__.__len__() as a standalone invariant.
# ---------------------------------------------------------------------------

invariant heapq_extra23.all.len:
  description: "heapq.__all__.__len__() == 13 — 8 classic operations plus 5 max-heap variants"
  category: module_all
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# heapq.__spec__.__class__.__name__.__len__() — length of 'ModuleSpec' (10)
#
# heapq.__spec__ is an importlib.machinery.ModuleSpec. Its class name is
# 'ModuleSpec', length 10. Mirrors the analogous copy_extra22 invariant and
# confirms that the heapq module uses the same spec class.
# ---------------------------------------------------------------------------

invariant heapq_extra23.spec.class_name_len:
  description: "heapq.__spec__.__class__.__name__.__len__() == 10 — len('ModuleSpec') == 10"
  category: module_metadata
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# heapq.__loader__.__class__.__name__.__len__() — length of 'SourceFileLoader' (16)
#
# heapq is a pure-Python module (Lib/heapq.py imports from _heapq but is
# itself a .py file). Its loader is a SourceFileLoader; the class name has
# length 16. Confirms the same loader class as the copy module.
# ---------------------------------------------------------------------------

invariant heapq_extra23.loader.class_name_len:
  description: "heapq.__loader__.__class__.__name__.__len__() == 16 — len('SourceFileLoader') == 16"
  category: module_metadata
  kind: python_call_eq
  function: "__loader__.__class__.__name__.__len__"
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for the 8 classic heapq callables — extra23
#
# For all 8 classic functions __qualname__ == __name__ (top-level definitions).
# Therefore __qualname__.__len__() == __name__.__len__() for each. This table
# confirms the qualname==name invariant via length measurement. It complements
# the name_lens and module_lens tables from heapq_extra22. id_prefix hqql23.
# ---------------------------------------------------------------------------

table heapq_extra23.qualname_lens:
  description: "__qualname__.__len__() for 8 classic heapq callables — equals __name__.__len__() for all (top-level definitions)"
  kind: python_call_eq
  category: function_qualname
  id_prefix: hqql23

  columns: [id, function, method, method_args, expected]
  rows:
    - [heappush_ql,    heappush.__qualname__,    __len__, [], 8]
    - [heappop_ql,     heappop.__qualname__,     __len__, [], 7]
    - [heapify_ql,     heapify.__qualname__,     __len__, [], 7]
    - [heapreplace_ql, heapreplace.__qualname__, __len__, [], 11]
    - [heappushpop_ql, heappushpop.__qualname__, __len__, [], 11]
    - [nlargest_ql,    nlargest.__qualname__,    __len__, [], 8]
    - [nsmallest_ql,   nsmallest.__qualname__,   __len__, [], 9]
    - [merge_ql,       merge.__qualname__,       __len__, [], 5]

# ---------------------------------------------------------------------------
# Table: max-heap variants __name__.__len__() — added in Python 3.14
#
# Python 3.14 adds 5 max-heap analogues of the classic min-heap operations.
# All 5 are C builtins from _heapq. Their names append '_max' to the classic
# names: heappush_max(12), heappop_max(11), heapify_max(11),
# heapreplace_max(15), heappushpop_max(15). No prior heapq spec covers these
# functions. id_prefix hqmx23 is novel.
# ---------------------------------------------------------------------------

table heapq_extra23.max_heap_name_lens:
  description: "__name__.__len__() for the 5 max-heap variant functions added in Python 3.14"
  kind: python_call_eq
  category: function_name
  id_prefix: hqmx23

  columns: [id, function, method, method_args, expected]
  rows:
    - [heappush_max_nl,    heappush_max.__name__,    __len__, [], 12]
    - [heappop_max_nl,     heappop_max.__name__,     __len__, [], 11]
    - [heapify_max_nl,     heapify_max.__name__,     __len__, [], 11]
    - [heapreplace_max_nl, heapreplace_max.__name__, __len__, [], 15]
    - [heappushpop_max_nl, heappushpop_max.__name__, __len__, [], 15]
