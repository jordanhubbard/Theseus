spec: inspect_extra2836
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "any proprietary source"
    - "zspecs/inspect_extra2821.zspec.zsdl — wave 635 predecessor (__radd__, __rsub__, __rmul__)"
  notes:
    - "Wave 636 (_extra2836): __rtruediv__, __rfloordiv__, and __rmod__ dict-presence checks (reflected true division, floor division, modulo)."
    - "inspect.Parameter is a pure-Python class modeling a callable parameter — no reflected arithmetic operators."
    - "inspect.BoundArguments is a pure-Python class holding bound argument mappings — no reflected arithmetic operators."
    - "inspect.Signature is a pure-Python class representing a callable's signature — no reflected arithmetic operators."
    - "inspect.FullArgSpec is a named-tuple subclass holding argument specification data — no reflected arithmetic operators."
    - "Introspection data containers have no numeric arithmetic semantics; reflected operators (__rtruediv__, __rfloordiv__, __rmod__) are entirely absent."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __rtruediv__ dict-presence (reflected true division)
#
# inspect.Parameter, BoundArguments, Signature, FullArgSpec are introspection
# data containers — none define __rtruediv__ in their own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra2836.rtruediv_protocol:
  description: "inspect types __rtruediv__ dict-presence checks — all False (no reflected true division protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2836
  columns: [id, function, args, expected]
  rows:
    - ["in2836001", "inspect.Parameter.__dict__.__contains__",      ["__rtruediv__"], false]
    - ["in2836002", "inspect.BoundArguments.__dict__.__contains__", ["__rtruediv__"], false]
    - ["in2836003", "inspect.Signature.__dict__.__contains__",      ["__rtruediv__"], false]
    - ["in2836004", "inspect.FullArgSpec.__dict__.__contains__",    ["__rtruediv__"], false]

# ---------------------------------------------------------------------------
# Table 2: __rfloordiv__ dict-presence (reflected floor division)
#
# None of the inspect introspection types define __rfloordiv__ — they model
# callable metadata and have no numeric floor division semantics.
# ---------------------------------------------------------------------------

table inspect_extra2836.rfloordiv_protocol:
  description: "inspect types __rfloordiv__ dict-presence checks — all False (no reflected floor division protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2836
  columns: [id, function, args, expected]
  rows:
    - ["in2836005", "inspect.Parameter.__dict__.__contains__",      ["__rfloordiv__"], false]
    - ["in2836006", "inspect.BoundArguments.__dict__.__contains__", ["__rfloordiv__"], false]
    - ["in2836007", "inspect.Signature.__dict__.__contains__",      ["__rfloordiv__"], false]
    - ["in2836008", "inspect.FullArgSpec.__dict__.__contains__",    ["__rfloordiv__"], false]

# ---------------------------------------------------------------------------
# Table 3: __rmod__ dict-presence (reflected modulo)
#
# None of the inspect types define __rmod__ — signature and argument
# introspection objects have no modulo or remainder semantics.
# ---------------------------------------------------------------------------

table inspect_extra2836.rmod_protocol:
  description: "inspect types __rmod__ dict-presence checks — all False (no reflected modulo protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2836
  columns: [id, function, args, expected]
  rows:
    - ["in2836009", "inspect.Parameter.__dict__.__contains__",      ["__rmod__"], false]
    - ["in2836010", "inspect.BoundArguments.__dict__.__contains__", ["__rmod__"], false]
    - ["in2836011", "inspect.Signature.__dict__.__contains__",      ["__rmod__"], false]
    - ["in2836012", "inspect.FullArgSpec.__dict__.__contains__",    ["__rmod__"], false]

# ---------------------------------------------------------------------------
# Table 4: combined reflected division/modulo operator absence — all types, all ops
#
# Cross-check: each inspect type lacks all three reflected division/modulo operators.
# Confirms that the inspect API is strictly an introspection surface with
# no numeric true division, floor division, or modulo semantics.
# ---------------------------------------------------------------------------

table inspect_extra2836.reflected_divmod_absent:
  description: "inspect types full __rtruediv__/__rfloordiv__/__rmod__ absence cross-check — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2836
  columns: [id, function, args, expected]
  rows:
    - ["in2836013", "inspect.Parameter.__dict__.__contains__",      ["__rtruediv__"],  false]
    - ["in2836014", "inspect.Parameter.__dict__.__contains__",      ["__rfloordiv__"], false]
    - ["in2836015", "inspect.Parameter.__dict__.__contains__",      ["__rmod__"],      false]
    - ["in2836016", "inspect.BoundArguments.__dict__.__contains__", ["__rtruediv__"],  false]
    - ["in2836017", "inspect.BoundArguments.__dict__.__contains__", ["__rfloordiv__"], false]
    - ["in2836018", "inspect.BoundArguments.__dict__.__contains__", ["__rmod__"],      false]
    - ["in2836019", "inspect.Signature.__dict__.__contains__",      ["__rtruediv__"],  false]
    - ["in2836020", "inspect.Signature.__dict__.__contains__",      ["__rfloordiv__"], false]
    - ["in2836021", "inspect.Signature.__dict__.__contains__",      ["__rmod__"],      false]
    - ["in2836022", "inspect.FullArgSpec.__dict__.__contains__",    ["__rtruediv__"],  false]
