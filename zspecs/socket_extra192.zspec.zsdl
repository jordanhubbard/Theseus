    - [gethostname_module,     gethostname.__module__.__eq__,         ["_socket"],                   true, "socket.gethostname.__module__ == '_socket'"]
    - [gethostname_class_name, gethostname.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "socket.gethostname.__class__.__name__ == 'builtin_function_or_method'"]

