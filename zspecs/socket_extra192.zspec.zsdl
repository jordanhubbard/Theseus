spec: socket_extra192
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "socket.gethostname is a C-level builtin (from _socket); its __module__ == '_socket' and __class__.__name__ == 'builtin_function_or_method'."
    - "socket.getaddrinfo is also a C-level builtin; __module__ == 'socket' on Python 3.14 (module-level re-export attribution)."
    - "socket.getfqdn is a pure-Python function defined in socket.py; its __module__ == 'socket' and __class__.__name__ == 'function'."
    - "socket.gethostbyname is a C-level builtin from _socket; __module__ == '_socket'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

