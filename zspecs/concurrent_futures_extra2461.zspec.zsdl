spec: concurrent_futures_extra2461
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified by running Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "Theme: __len__ and __length_hint__ dict-presence — checking whether concurrent.futures classes define the length protocol in their class __dict__."
    - "concurrent.futures.Future represents the result of an async computation — not a collection; no __len__ in __dict__."
    - "concurrent.futures.Executor, ThreadPoolExecutor, ProcessPoolExecutor are worker-pool abstractions; they define no __len__."
    - "All expected values verified by running Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future — result container; not a collection
# ---------------------------------------------------------------------------

table concurrent_futures_extra2461.Future.len_protocol:
  description: "concurrent.futures.Future class __dict__ does NOT contain __len__ or __length_hint__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: cf2461

  columns: [id, function, args, expected]
  rows:
    - ["cf2461-001", concurrent.futures.Future.__dict__.__contains__, ["__len__"],         false]
    - ["cf2461-002", concurrent.futures.Future.__dict__.__contains__, ["__length_hint__"], false]

table concurrent_futures_extra2461.Future.method_presence:
  description: "concurrent.futures.Future class __dict__ contains result-inspection methods"
  kind: python_call_eq
  category: dict_presence
  id_prefix: cf2461

  columns: [id, function, args, expected]
  rows:
    - ["cf2461-010", concurrent.futures.Future.__dict__.__contains__, ["cancel"],    true]
    - ["cf2461-011", concurrent.futures.Future.__dict__.__contains__, ["cancelled"], true]
    - ["cf2461-012", concurrent.futures.Future.__dict__.__contains__, ["done"],      true]
    - ["cf2461-013", concurrent.futures.Future.__dict__.__contains__, ["result"],    true]
    - ["cf2461-014", concurrent.futures.Future.__dict__.__contains__, ["running"],   true]

