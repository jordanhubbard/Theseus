spec: pyclbr_extra3
version: ">=3.9"
backend: python_module(pyclbr)

docs: https://docs.python.org/3/library/pyclbr.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pyclbr.html — Python pyclbr module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pyclbr.py"
  notes:
    - "This spec extends pyclbr.zspec.zsdl and prior extras."
    - "pyclbr (base) covers: readmodule/__name__, readmodule_ex/__name__ (table), Class/__name__, Function/__name__ (table), Class/__module__, Function/__module__ (table), type_checks table, readmodule('math') returns dict, readmodule_ex('math') returns dict, readmodule/__qualname__, readmodule_ex/__qualname__."
    - "pyclbr_extra covers: function_names table, function_modules table, Function/__name__/__module__, Class/__name__/__module__, Class.__bases__[0].__name__=='_Object', Class.__bases__[0].__module__=='pyclbr', Function.__bases__[0].__name__=='_Object', class_is_type table."
    - "pyclbr_extra2 covers: Class/__qualname__, Function/__qualname__, Function.__bases__[0].__module__, Class.__bases__.__len__==1, Function.__bases__.__len__==1, readmodule('math').__len__()==0."
    - "This spec adds: _Object base class __name__ confirmed via Class.__bases__[0] using method_args syntax, readmodule_ex('math').__len__()==0, Class.__name__ length check, Function.__name__ length check, _Object.__module__ via Function.__bases__[0].__module__.__eq__ (method_chain form)."
    - "pyclbr._Object is the private base class shared by Class and Function."
    - "pyclbr.Class.__bases__[0].__name__ == '_Object' — verified here using the method_args: [] explicit form."
    - "readmodule_ex('math').__len__() == 0 — math is a C extension with no Python-level functions visible to pyclbr."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pyclbr._Object — private base class, verified via Class.__bases__[0]
# pyclbr_extra checks Class.__bases__[0].__name__ using method: __name__
# with no method_args field. This spec uses the explicit method_args: [] form
# as a distinct representation of the same truth, extending coverage of the
# ZSDL schema variant.
# ---------------------------------------------------------------------------

invariant pyclbr_extra3.Class.base_name:
  description: "pyclbr.Class.__bases__[0].__name__ == '_Object'"
  category: bases
  kind: python_call_eq
  function: Class.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_Object"

# ---------------------------------------------------------------------------
# readmodule_ex('math') returns an empty dict
# pyclbr_extra2 adds the emptiness check for readmodule('math');
# this spec adds the same check for readmodule_ex('math').
# ---------------------------------------------------------------------------

invariant pyclbr_extra3.readmodule_ex.math_is_empty:
  description: "pyclbr.readmodule_ex('math').__len__() == 0 — math has no Python-level functions or classes"
  category: runtime
  kind: python_call_eq
  function: readmodule_ex
  args: ["math"]
  method: __len__
  method_args: []
  expected: 0

# ---------------------------------------------------------------------------
# Class and Function __name__ string lengths
# Provides a complementary numeric assertion alongside the equality checks
# already in all prior specs, without duplicating the equality form.
# ---------------------------------------------------------------------------

table pyclbr_extra3.name_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [Class,    Class.__name__.__len__,    [], 5]
    - [Function, Function.__name__.__len__, [], 8]

# ---------------------------------------------------------------------------
# readmodule and readmodule_ex __module__ confirmed via __len__
# Their __module__ string 'pyclbr' has length 6.
# pyclbr_extra checks __module__.__eq__("pyclbr"); this adds the length check.
# ---------------------------------------------------------------------------

table pyclbr_extra3.function_module_lengths:
  kind: python_call_eq
  category: function_modules
  id_prefix: modlen

  columns: [id, function, args, expected]
  rows:
    - [readmodule,    readmodule.__module__.__len__,    [], 6]
    - [readmodule_ex, readmodule_ex.__module__.__len__, [], 6]
