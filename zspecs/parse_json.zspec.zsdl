spec: parse_json
version: ">=8.0.0"
backend: node(parse-json)

docs: https://github.com/sindresorhus/parse-json#readme

provenance:
  derived_from:
    - "parse-json README — https://github.com/sindresorhus/parse-json#readme"
    - "Test vectors verified with parse-json via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "parse-json source"
  notes:
    - "parse-json is JSON.parse with friendlier errors (location info, code frames)."
    - "Install: npm install parse-json"
    - "v8 is ESM but exposes a CJS shim; the default export is the parser function."
    - "Spec uses entry: named, function: default to access the CJS-exposed default export."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Returns the parsed value; throws JSONError on malformed input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table parse_json.parse:
  kind: node_chain_eq
  category: parse
  entry: named
  function: default
  id_prefix: parse

  columns: [id, entry_args, chain, expected]
  rows:
    - [object,             ["{\"a\":1}"],            [], {a: 1}]
    - [array,              ["[1,2,3]"],              [], [1, 2, 3]]
    - [string,             ["\"hello\""],            [], "hello"]
    - [number,             ["42"],                    [], 42]
    - [boolean_true,       ["true"],                  [], true]
    - [null_value,         ["null"],                  [], ~]
    - [nested_object,      ["{\"x\":{\"y\":[1,2]}}"], [], {x: {y: [1, 2]}}]
    - [empty_object,       ["{}"],                    [], {}]
    - [empty_array,        ["[]"],                    [], []]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:36:18Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
