spec: st3031
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct: Interpret bytes as packed binary data"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 649 (st3031): __missing__, __init_subclass__, __class_getitem__ dict-presence checks for struct types."
    - "struct.Struct is a C extension type for packing/unpacking binary data — not a mapping or generic alias; it does not define __missing__, __init_subclass__, or __class_getitem__ in its own __dict__."
    - "type(struct.Struct('!I')) is identical to struct.Struct — verified on Python 3.14.4."
    - "None of the struct types define __missing__, __init_subclass__, or __class_getitem__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table st3031.missing:
  description: "struct types __missing__ dict-presence checks; wave 649"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st3031
  columns: [id, function, args, expected]
  rows:
    - ["st3031001", operator.contains, [struct.Struct.__dict__,             "__missing__"], false]
    - ["st3031002", operator.contains, [type(struct.Struct('!I')).__dict__, "__missing__"], false]

