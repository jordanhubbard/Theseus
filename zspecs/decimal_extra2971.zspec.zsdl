spec: dc2971
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal class __dict__ floor / ceil / index presence"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "decimal.Decimal is a full numeric type. It defines __floor__ and __ceil__ in its own __dict__ for math.floor()/math.ceil() support."
    - "operator.contains(decimal.Decimal.__dict__, '__floor__') is True — Decimal owns __floor__."
    - "operator.contains(decimal.Decimal.__dict__, '__ceil__') is True — Decimal owns __ceil__."
    - "operator.contains(decimal.Decimal.__dict__, '__index__') is False — Decimal does not support __index__; operator.index(d) raises TypeError because Decimal is not an exact integer type."
    - "decimal.Context is a configuration object; it defines none of these operators."
    - "DecimalException and all subclasses are exception types derived from ArithmeticError; none define these operators."
    - "Subclasses verified: InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded, Subnormal, FloatOperation, Clamped."
    - "All values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __floor__ dict-presence — math.floor() protocol in own __dict__
#
# decimal.Decimal defines __floor__ directly in its own __dict__ (True) —
# math.floor(Decimal('1.9')) returns 1. Context and all exception subclasses
# do not define __floor__ (False).
# ---------------------------------------------------------------------------

table dc2971.floor:
  description: "operator.contains(cls.__dict__, '__floor__'): True for Decimal, False for all others"
  kind: python_call_eq
  category: dict_presence
  id_prefix: dcf2971

  columns: [id, function, args, expected]
  rows:
    - ["dcf2971_001", operator.contains, [decimal.Decimal.__dict__,           "__floor__"], true]
    - ["dcf2971_002", operator.contains, [decimal.Context.__dict__,           "__floor__"], false]
    - ["dcf2971_003", operator.contains, [decimal.DecimalException.__dict__,  "__floor__"], false]
    - ["dcf2971_004", operator.contains, [decimal.InvalidOperation.__dict__,  "__floor__"], false]
    - ["dcf2971_005", operator.contains, [decimal.DivisionByZero.__dict__,    "__floor__"], false]
    - ["dcf2971_006", operator.contains, [decimal.Overflow.__dict__,          "__floor__"], false]
    - ["dcf2971_007", operator.contains, [decimal.Underflow.__dict__,         "__floor__"], false]
    - ["dcf2971_008", operator.contains, [decimal.Inexact.__dict__,           "__floor__"], false]
    - ["dcf2971_009", operator.contains, [decimal.Rounded.__dict__,           "__floor__"], false]
    - ["dcf2971_010", operator.contains, [decimal.Subnormal.__dict__,         "__floor__"], false]
    - ["dcf2971_011", operator.contains, [decimal.FloatOperation.__dict__,    "__floor__"], false]
    - ["dcf2971_012", operator.contains, [decimal.Clamped.__dict__,           "__floor__"], false]

# ---------------------------------------------------------------------------
# __ceil__ dict-presence — math.ceil() protocol in own __dict__
#
# decimal.Decimal defines __ceil__ directly in its own __dict__ (True) —
# math.ceil(Decimal('1.1')) returns 2. Context and all exception subclasses
# do not define __ceil__ (False).
# ---------------------------------------------------------------------------

table dc2971.ceil:
  description: "operator.contains(cls.__dict__, '__ceil__'): True for Decimal, False for all others"
  kind: python_call_eq
  category: dict_presence
  id_prefix: dcc2971

  columns: [id, function, args, expected]
  rows:
    - ["dcc2971_001", operator.contains, [decimal.Decimal.__dict__,           "__ceil__"], true]
    - ["dcc2971_002", operator.contains, [decimal.Context.__dict__,           "__ceil__"], false]
    - ["dcc2971_003", operator.contains, [decimal.DecimalException.__dict__,  "__ceil__"], false]
    - ["dcc2971_004", operator.contains, [decimal.InvalidOperation.__dict__,  "__ceil__"], false]
    - ["dcc2971_005", operator.contains, [decimal.DivisionByZero.__dict__,    "__ceil__"], false]
    - ["dcc2971_006", operator.contains, [decimal.Overflow.__dict__,          "__ceil__"], false]
    - ["dcc2971_007", operator.contains, [decimal.Underflow.__dict__,         "__ceil__"], false]
    - ["dcc2971_008", operator.contains, [decimal.Inexact.__dict__,           "__ceil__"], false]
    - ["dcc2971_009", operator.contains, [decimal.Rounded.__dict__,           "__ceil__"], false]
    - ["dcc2971_010", operator.contains, [decimal.Subnormal.__dict__,         "__ceil__"], false]
    - ["dcc2971_011", operator.contains, [decimal.FloatOperation.__dict__,    "__ceil__"], false]
    - ["dcc2971_012", operator.contains, [decimal.Clamped.__dict__,           "__ceil__"], false]

# ---------------------------------------------------------------------------
# __index__ dict-presence — operator.index() protocol in own __dict__
#
# decimal.Decimal does NOT define __index__ (False) — Decimal is not an
# exact integer type and operator.index(d) raises TypeError. Context and
# all exception subclasses also do not define __index__ (False).
# ---------------------------------------------------------------------------

table dc2971.index:
  description: "operator.contains(cls.__dict__, '__index__') is False for all decimal classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: dci2971

  columns: [id, function, args, expected]
  rows:
    - ["dci2971_001", operator.contains, [decimal.Decimal.__dict__,           "__index__"], false]
    - ["dci2971_002", operator.contains, [decimal.Context.__dict__,           "__index__"], false]
    - ["dci2971_003", operator.contains, [decimal.DecimalException.__dict__,  "__index__"], false]
    - ["dci2971_004", operator.contains, [decimal.InvalidOperation.__dict__,  "__index__"], false]
    - ["dci2971_005", operator.contains, [decimal.DivisionByZero.__dict__,    "__index__"], false]
    - ["dci2971_006", operator.contains, [decimal.Overflow.__dict__,          "__index__"], false]
    - ["dci2971_007", operator.contains, [decimal.Underflow.__dict__,         "__index__"], false]
    - ["dci2971_008", operator.contains, [decimal.Inexact.__dict__,           "__index__"], false]
    - ["dci2971_009", operator.contains, [decimal.Rounded.__dict__,           "__index__"], false]
    - ["dci2971_010", operator.contains, [decimal.Subnormal.__dict__,         "__index__"], false]
    - ["dci2971_011", operator.contains, [decimal.FloatOperation.__dict__,    "__index__"], false]
    - ["dci2971_012", operator.contains, [decimal.Clamped.__dict__,           "__index__"], false]

# ---------------------------------------------------------------------------
# combined — full cross-check focusing on the True/False split
#
# Decimal: __floor__=True, __ceil__=True, __index__=False.
# Context: all False. DecimalException: all False.
# Also includes a representative sample of exception subclasses.
# ---------------------------------------------------------------------------

table dc2971.combined:
  description: "Combined: Decimal owns __floor__ and __ceil__ but not __index__; Context and exceptions own none"
  kind: python_call_eq
  category: dict_presence
  id_prefix: dcx2971

