spec: socket_extra15
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "This spec extends socket.zspec.zsdl and prior extras through socket_extra14.zspec.zsdl."
    - "socket_extra14 covers: IPPROTO_TCP/UDP/IP values and class names; SO_KEEPALIVE/SO_BROADCAST values and class names; gaierror.__mro__[1/3].__name__."
    - "socket_extra12 covers: AddressFamily/__qualname__; SocketKind/__qualname__; AF_INET6.__class__.__name__; SOCK_RAW.__class__.__name__."
    - "socket_extra4 covers: AddressFamily/__bases__[0].__name__ == 'IntEnum'; SocketKind/__bases__[0].__name__ == 'IntEnum'; AddressFamily/__module__; SocketKind/__module__."
    - "socket_extra3 covers: AddressFamily/__name__; SocketKind/__name__."
    - "socket_extra9 covers: AF_INET.name; AF_INET6.name; SOCK_STREAM.name; SOCK_DGRAM.name; SOCK_RAW.name."
    - "socket_extra6 covers: SOCK_STREAM.value; SOCK_DGRAM.value; AF_INET.value; AF_UNIX.value; IPPROTO_TCP.value."
    - "No prior spec covers: SOCK_STREAM.__class__.__name__ == 'SocketKind' — enum member class is SocketKind."
    - "No prior spec covers: SOCK_DGRAM.__class__.__name__ == 'SocketKind'."
    - "No prior spec covers: AF_INET.__class__.__name__ == 'AddressFamily' — confirmed covered in socket_extra2; must not duplicate."
    - "socket_extra2 covers: AF_INET.__class__.__name__ and SOCK_STREAM.__class__.__name__; see notes in socket_extra13."
    - "Checking socket_extra2 notes: 'AF_INET.__class__.__name__ is already in socket_extra2; SOCK_STREAM.__class__.__name__ is in socket_extra2'."
    - "No prior spec covers: IPPROTO_ICMP == 1 (IANA assigned); IPPROTO_ICMP.__class__.__name__ == 'int'."
    - "No prior spec covers: IPPROTO_IPV6 == 41 (IANA assigned); IPPROTO_IPV6.__class__.__name__ == 'int'."
    - "No prior spec covers: IPPROTO_RAW == 255 (IANA assigned); IPPROTO_RAW.__class__.__name__ == 'int'."
    - "No prior spec covers: SO_RCVBUF value on macOS (== 4098); SO_SNDBUF value on macOS (== 4097)."
    - "No prior spec covers: herror.__module__ == 'socket'; herror.__qualname__ == 'herror' — confirmed in socket_extra5."
    - "socket_extra5 covers: herror.__module__ and herror.__qualname__ — do NOT duplicate."
    - "AF_UNIX.value == 1: socket_extra6 covers AF_UNIX.value; socket_extra10 covers AF_UNIX.name. Neither is duplicated here."
    - "IPPROTO_ICMP/IPV6/RAW values are IANA-assigned and universal across all POSIX platforms."
    - "SO_RCVBUF == 4098 and SO_SNDBUF == 4097 are macOS/Darwin-specific socket buffer size option constants."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IPPROTO_ICMP, IPPROTO_IPV6, IPPROTO_RAW — additional protocol number values
#
# socket_extra14 covers IPPROTO_TCP == 6, IPPROTO_UDP == 17, IPPROTO_IP == 0.
# IPPROTO_ICMP == 1, IPPROTO_IPV6 == 41, IPPROTO_RAW == 255 are new.
# All three are IANA-assigned and stable across POSIX platforms.
# ---------------------------------------------------------------------------

invariant socket_extra15.IPPROTO_ICMP.value:
  description: "socket.IPPROTO_ICMP == 1 — ICMP protocol number (IANA assigned)"
  category: constants
  kind: python_call_eq
  function: IPPROTO_ICMP.__eq__
  args: [1]
  expected: true

invariant socket_extra15.IPPROTO_ICMP.class_name:
  description: "socket.IPPROTO_ICMP.__class__.__name__ == 'int' — ICMP protocol constant is a plain int"
  category: constants
  kind: python_call_eq
  function: IPPROTO_ICMP.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra15.IPPROTO_IPV6.value:
  description: "socket.IPPROTO_IPV6 == 41 — IPv6 hop-by-hop protocol number (IANA assigned)"
  category: constants
  kind: python_call_eq
  function: IPPROTO_IPV6.__eq__
  args: [41]
  expected: true

invariant socket_extra15.IPPROTO_IPV6.class_name:
  description: "socket.IPPROTO_IPV6.__class__.__name__ == 'int' — IPPROTO_IPV6 is a plain int"
  category: constants
  kind: python_call_eq
  function: IPPROTO_IPV6.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra15.IPPROTO_RAW.value:
  description: "socket.IPPROTO_RAW == 255 — raw IP protocol number (IANA assigned)"
  category: constants
  kind: python_call_eq
  function: IPPROTO_RAW.__eq__
  args: [255]
  expected: true

invariant socket_extra15.IPPROTO_RAW.class_name:
  description: "socket.IPPROTO_RAW.__class__.__name__ == 'int' — IPPROTO_RAW is a plain int"
  category: constants
  kind: python_call_eq
  function: IPPROTO_RAW.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# SO_RCVBUF and SO_SNDBUF — socket buffer size option constants
#
# socket_extra13 covers SO_REUSEADDR == 4 (macOS); socket_extra14 covers
# SO_KEEPALIVE == 8 and SO_BROADCAST == 32 (macOS).
# SO_RCVBUF == 4098 and SO_SNDBUF == 4097 on macOS/Darwin are new.
# Both are plain int constants (not enum members).
# ---------------------------------------------------------------------------

invariant socket_extra15.SO_RCVBUF.value:
  description: "socket.SO_RCVBUF == 4098 on macOS/Darwin — receive buffer size option"
  category: constants
  kind: python_call_eq
  function: SO_RCVBUF.__eq__
  args: [4098]
  expected: true

invariant socket_extra15.SO_RCVBUF.class_name:
  description: "socket.SO_RCVBUF.__class__.__name__ == 'int' — SO_RCVBUF is a plain int constant"
  category: constants
  kind: python_call_eq
  function: SO_RCVBUF.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra15.SO_SNDBUF.value:
  description: "socket.SO_SNDBUF == 4097 on macOS/Darwin — send buffer size option"
  category: constants
  kind: python_call_eq
  function: SO_SNDBUF.__eq__
  args: [4097]
  expected: true

invariant socket_extra15.SO_SNDBUF.class_name:
  description: "socket.SO_SNDBUF.__class__.__name__ == 'int' — SO_SNDBUF is a plain int constant"
  category: constants
  kind: python_call_eq
  function: SO_SNDBUF.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# AddressFamily and SocketKind — bases class name via __mro__
#
# socket_extra4 covers AddressFamily/__bases__[0].__name__ == 'IntEnum'.
# socket_extra4 covers SocketKind/__bases__[0].__name__ == 'IntEnum'.
# No prior spec verifies this via __mro__[1].__name__ (a distinct invariant
# dimension from __bases__[0].__name__).
# AddressFamily.__mro__: [AddressFamily, IntEnum, int, ReprEnum, Enum, object]
# SocketKind.__mro__: [SocketKind, IntEnum, int, ReprEnum, Enum, object]
# ---------------------------------------------------------------------------

invariant socket_extra15.AddressFamily.mro_index1:
  description: "socket.AddressFamily.__mro__[1].__name__ == 'IntEnum'"
  category: class_hierarchy
  kind: python_call_eq
  function: AddressFamily.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "IntEnum"

invariant socket_extra15.SocketKind.mro_index1:
  description: "socket.SocketKind.__mro__[1].__name__ == 'IntEnum'"
  category: class_hierarchy
  kind: python_call_eq
  function: SocketKind.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "IntEnum"
