spec: cryptography_rust
version: ">=3.9"
backend: rust_module(cryptography_rust)

docs: https://cryptography.io/en/latest/

provenance:
  derived_from:
    - "https://cryptography.io/en/latest/ — cryptography library docs"
  not_derived_from:
    - "cryptography source: src/cryptography/__init__.py"
  notes:
    - "cryptography provides cryptographic recipes for Python."
    - "from cryptography.fernet import Fernet; k = Fernet.generate_key(); len(k) == 44."
    - "Fernet(k).encrypt(b'hello') is bytes."
    - "Fernet(k).decrypt(Fernet(k).encrypt(b'hello')) == b'hello'."
    - "from cryptography.hazmat.primitives import hashes; hashes.SHA256.digest_size == 32."
    - "Expose fernet_key_len() -> int: len(Fernet.generate_key())."
    - "Expose fernet_roundtrip(plaintext) -> str: Fernet(k).decrypt(Fernet(k).encrypt(p.encode())).decode()."
    - "Expose sha256_digest_size() -> int: hashes.SHA256.digest_size."
    - "All test vectors verified against cryptography 44.0.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# fernet_key_len — Fernet key is 44 bytes (base64url-encoded 32-byte key)
invariant cryptography_rust.fernet.key_len:
  description: "Fernet.generate_key() has len 44"
  category: fernet
  kind: python_call_eq
  function: fernet_key_len
  args: []
  expected: 44

# fernet_roundtrip — encrypt then decrypt returns original
table cryptography_rust.fernet.roundtrip:
  kind: python_call_eq
  category: roundtrip
  id_prefix: fer_rt
  function: fernet_roundtrip

  columns: [id, args, expected]
  rows:
    - [hello,   ["hello"],   "hello"]
    - [world,   ["world"],   "world"]
    - [secret,  ["secret"],  "secret"]

# sha256_digest_size — SHA256 digest is 32 bytes
invariant cryptography_rust.hashes.sha256_size:
  description: "SHA256.digest_size == 32"
  category: hashes
  kind: python_call_eq
  function: sha256_digest_size
  args: []
  expected: 32

