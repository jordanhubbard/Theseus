spec: proxy_addr
version: ">=2.0.0"
backend: node(proxy-addr)

docs: https://github.com/jshttp/proxy-addr#readme

provenance:
  derived_from:
    - "proxy-addr README — https://github.com/jshttp/proxy-addr#readme"
    - "RFC 7239 — Forwarded HTTP Extension"
    - "Test vectors verified with proxy-addr via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "proxy-addr source"
  notes:
    - "Resolve the originating client address from a request, given a trust function — used by Express's 'trust proxy' setting."
    - "Install: npm install proxy-addr"
    - "v2 CJS; module export IS the resolver (req, trust). Has .all(req, [trust]) and .compile(value) helpers."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws TypeError on missing req or non-function trust."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant proxy_addr.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant proxy_addr.module_arity:
  description: "Module function takes 2 args (req, trust)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 2

invariant proxy_addr.has_all:
  description: ".all() helper exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "all.constructor.name"}
  expected: "Function"

invariant proxy_addr.has_compile:
  description: ".compile() helper exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "compile.constructor.name"}
  expected: "Function"

invariant proxy_addr.compile_returns_function:
  description: "compile('127.0.0.1') returns a Function (the trust predicate)"
  category: compile
  kind: node_chain_eq
  entry: named
  function: compile
  entry_args: ["127.0.0.1"]
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant proxy_addr.all_returns_array:
  description: "all() with synthetic req returns an Array"
  category: shape
  kind: node_chain_eq
  entry: named
  function: all
  entry_args: [{"headers": {"x-forwarded-for": "5.5.5.5"}, "connection": {"remoteAddress": "127.0.0.1"}}]
  chain:
    - {get: "constructor.name"}
  expected: "Array"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:02:38Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
