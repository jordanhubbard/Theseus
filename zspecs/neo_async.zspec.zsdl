spec: neo_async
version: ">=2.0.0"
backend: node(neo-async)

docs: https://github.com/suguru03/neo-async#readme

provenance:
  derived_from:
    - "neo-async README — https://github.com/suguru03/neo-async#readme"
    - "Test vectors verified with neo-async via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "neo-async source"
  notes:
    - "Drop-in replacement for the 'async' library — 117 named exports covering each / map / series / parallel / waterfall / reduce / queue / retry / etc."
    - "Install: npm install neo-async"
    - "v2 CJS; both default export (object of helpers) and named exports."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Each helper accepts a callback; errors are passed through node-style (err, result)."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant neo_async.VERSION_present:
  description: "Module exposes a VERSION string"
  category: meta
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "VERSION.constructor.name"}
  expected: "String"

invariant neo_async.has_each:
  description: ".each is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "each.constructor.name"}
  expected: "Function"

invariant neo_async.has_map:
  description: ".map is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "map.constructor.name"}
  expected: "Function"

invariant neo_async.has_series:
  description: ".series is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "series.constructor.name"}
  expected: "Function"

invariant neo_async.has_parallel:
  description: ".parallel is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "parallel.constructor.name"}
  expected: "Function"

invariant neo_async.has_waterfall:
  description: ".waterfall is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "waterfall.constructor.name"}
  expected: "Function"

invariant neo_async.has_reduce:
  description: ".reduce is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "reduce.constructor.name"}
  expected: "Function"

invariant neo_async.has_retry:
  description: ".retry is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "retry.constructor.name"}
  expected: "Function"

invariant neo_async.has_eachSeries:
  description: ".eachSeries variant exposed (sequential each)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "eachSeries.constructor.name"}
  expected: "Function"

invariant neo_async.has_eachLimit:
  description: ".eachLimit variant exposed (concurrency-limited each)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "eachLimit.constructor.name"}
  expected: "Function"

