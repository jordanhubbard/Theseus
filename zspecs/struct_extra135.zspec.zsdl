spec: struct_extra135
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra134.zspec.zsdl — covers struct.__spec__ and __loader__ attribute identity / Struct method __doc__ lengths (pack/unpack/pack_into/unpack_from/iter_unpack) / Struct class __doc__ identity (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths (pack/unpack/calcsize/pack_into/unpack_from/iter_unpack) / Struct.size and Struct.format __doc__ equality and lengths / struct module __doc__ length (1278)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / Struct.__doc__ length (40) and equality."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__/__len__() and error.__name__/__len__()."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth / module-level function __qualname__.__len__()."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2."
    - "struct_extra92.zspec.zsdl — covers struct module-level function __class__.__name__ / Struct method __class__.__name__ / struct.error inheritance and __module__/__qualname__."
    - "struct_extra91.zspec.zsdl — covers struct.calcsize return values / struct.pack/__qualname__ / struct.Struct.__doc__/__class__.__name__ / struct.error/__class__.__name__."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra91 through struct_extra134."
    - "Wave 285 theme: struct.Struct.__eq__ inherited from object (qualname/class) / struct.error MRO member names / struct module-level function __doc__ lengths (pack/unpack/calcsize) / struct.__doc__.__len__() and __class__.__name__."
    - "struct.Struct.__eq__.__qualname__ == 'object.__eq__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__eq__.__qualname__.__len__() == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__eq__.__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[0].__name__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[1].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[2].__name__ == 'BaseException'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[3].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__doc__ is None. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__doc__.__len__() == 176. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__doc__.__len__() == 173. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__doc__.__len__() == 66. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__doc__.__len__() == 1278. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__name__.__eq__('error') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__name__.__len__() == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.__eq__ is inherited from object (qualname 'object.__eq__', class 'wrapper_descriptor'). Struct does not define its own __eq__ — two Struct instances compare equal only if they are the same object. The wrapper_descriptor class is used for slots defined in C types."
    - "Note: struct.error.__doc__ is None (not a str). Unlike most exception classes, struct.error has no docstring — it is defined as a bare exception subclass in _struct.c without a docstring."
    - "Note: struct.error MRO is [error, Exception, BaseException, object] (length 4). struct_extra94 anchors the length; this spec anchors the member names under structmro135."
    - "Note: struct.pack.__doc__ (176 chars) is slightly longer than struct.unpack.__doc__ (173 chars); both are shorter than their Struct-method counterparts (Struct.pack 175, Struct.unpack 190) in an interesting inversion for unpack."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__eq__.__qualname__.__eq__('object.__eq__')
# struct.Struct.__eq__.__qualname__.__len__()==13
# struct.Struct.__eq__.__class__.__name__.__eq__('wrapper_descriptor')
#
# Wave 285 theme: Struct.__eq__ is inherited from object.
#
# struct.Struct does not define its own __eq__, so Struct.__eq__ is
# object.__eq__ (a wrapper_descriptor). The qualname 'object.__eq__' is 13
# chars. struct_extra93 anchors Struct.__bases__; no prior struct spec anchors
# Struct.__eq__.__qualname__ or __class__.__name__ under structmro135.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra135.Struct_eq_inherited:
  description: "struct.Struct.__eq__/__qualname__.__eq__('object.__eq__')==True / Struct.__eq__/__qualname__/__len__()==13 / Struct.__eq__/__class__.__name__.__eq__('wrapper_descriptor')==True — Struct.__eq__ is inherited from object (not overridden in _struct.c); qualname is 'object.__eq__' (13 chars); class is wrapper_descriptor (C-level slot wrapper); extra93 anchors Struct.__bases__; first structmro135 anchor for Struct.__eq__ identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmro135

  columns: [id, function, args, expected, description]
  rows:
    - [eq_qualname_eq,    Struct.__eq__.__qualname__.__eq__,             ["object.__eq__"],       true, "struct.Struct.__eq__.__qualname__ is 'object.__eq__' (inherited from object, not overridden)"]
    - [eq_qualname_len,   Struct.__eq__.__qualname__.__len__,            [],                      13,   "struct.Struct.__eq__.__qualname__.__len__() is 13 ('object.__eq__' = 13 chars)"]
    - [eq_class_name_eq,  Struct.__eq__.__class__.__name__.__eq__,       ["wrapper_descriptor"],  true, "struct.Struct.__eq__.__class__.__name__ is 'wrapper_descriptor' (C-level slot wrapper for inherited __eq__)"]

# ---------------------------------------------------------------------------
# struct.error.__mro__[0].__name__.__eq__('error')
# struct.error.__mro__[1].__name__.__eq__('Exception')
# struct.error.__mro__[2].__name__.__eq__('BaseException')
# struct.error.__mro__[3].__name__.__eq__('object')
#
# Wave 285 theme: struct.error MRO member names.
#
# struct.error.__mro__ is [error, Exception, BaseException, object] — length 4.
# struct_extra94 anchors the MRO depth (4); no prior struct spec anchors
# the individual MRO member names under structmro135.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra135.error_mro_member_names:
  description: "struct.error/__mro__[0]/__name__.__eq__('error')==True / mro[1]/__name__.__eq__('Exception')==True / mro[2]/__name__.__eq__('BaseException')==True / mro[3]/__name__.__eq__('object')==True — struct.error MRO is [error, Exception, BaseException, object]; extra94 anchors the MRO depth (4); first structmro135 anchor for individual MRO member names"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmro135

  columns: [id, function, args, expected, description]
  rows:
    - [mro0_name, "error.__mro__[0].__name__.__eq__", ["error"],          true, "struct.error.__mro__[0] is error itself"]
    - [mro1_name, "error.__mro__[1].__name__.__eq__", ["Exception"],      true, "struct.error.__mro__[1] is Exception (direct base of struct.error)"]
    - [mro2_name, "error.__mro__[2].__name__.__eq__", ["BaseException"],  true, "struct.error.__mro__[2] is BaseException"]
    - [mro3_name, "error.__mro__[3].__name__.__eq__", ["object"],         true, "struct.error.__mro__[3] is object (root of all classes)"]

# ---------------------------------------------------------------------------
# struct.pack.__doc__.__len__()==176
# struct.unpack.__doc__.__len__()==173
# struct.calcsize.__doc__.__len__()==66
# struct.__doc__.__class__.__name__.__eq__('str')
# struct.__doc__.__len__()==1278
#
# Wave 285 theme: struct module-level function __doc__ lengths and module __doc__.
#
# struct.pack.__doc__ is 176 chars and struct.unpack.__doc__ is 173 chars.
# struct.calcsize.__doc__ is 66 chars — the shortest module-level function
# docstring. struct.__doc__ (1278 chars) covers the full module including byte
# order, size, and alignment characters. struct_extra99 anchors these lengths
# at table level; no prior struct spec anchors them as cross-check table rows
# together under structmro135. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra135.module_function_doc_lengths:
  description: "struct.pack/__doc__/__len__()==176 / unpack/__doc__/__len__()==173 / calcsize/__doc__/__len__()==66 / struct/__doc__/__class__.__name__.__eq__('str')==True / struct/__doc__/__len__()==1278 — module-level function doc lengths; calcsize (66) shortest; pack (176) and unpack (173) similar; module __doc__ is 1278 chars covering byte order/size/alignment; extra99 anchors these lengths at table; cross-check table under structmro135"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: structmro135

  columns: [id, function, args, expected, description]
  rows:
    - [pack_doc_len,       pack.__doc__.__len__,                    [], 176,  "struct.pack.__doc__.__len__() is 176 chars (module-level pack documents format, v1, v2, ... arguments)"]
    - [unpack_doc_len,     unpack.__doc__.__len__,                  [], 173,  "struct.unpack.__doc__.__len__() is 173 chars (module-level unpack documents format and buffer)"]
    - [calcsize_doc_len,   calcsize.__doc__.__len__,                [], 66,   "struct.calcsize.__doc__.__len__() is 66 chars (shortest module-level function docstring)"]
    - [module_doc_class,   __doc__.__class__.__name__.__eq__,       ["str"], true, "struct.__doc__ is a str (module-level docstring from Lib/struct.py)"]
    - [module_doc_len,     __doc__.__len__,                         [], 1278, "struct.__doc__.__len__() is 1278 chars (covers format characters, byte order, size, alignment)"]

# ---------------------------------------------------------------------------
# struct.Struct.__eq__.__qualname__.__eq__('object.__eq__') — standalone
#
# struct.Struct.__eq__.__qualname__ is 'object.__eq__'. Struct does not override
# __eq__, so it inherits the default identity-based comparison from object. The
# qualname 'object.__eq__' (13 chars) confirms the descriptor is defined on
# object, not on Struct. No prior struct spec anchors Struct.__eq__.__qualname__
# equality as a standalone under structmro135. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra135.Struct_eq_qualname_object:
  description: "struct.Struct.__eq__.__qualname__.__eq__('object.__eq__') == True — Struct.__eq__ is not overridden in _struct.c; identity-based comparison inherited from object; qualname 'object.__eq__' (13 chars); no prior struct spec anchors Struct.__eq__.__qualname__ equality as a standalone; first standalone under structmro135"
  category: type_identity
  kind: python_call_eq
  function: Struct.__eq__.__qualname__.__eq__
  args: ["object.__eq__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error') — standalone
#
# struct.error.__name__ is 'error'. The struct.error exception class has a
# 5-char simple name. It is defined in _struct.c as a C-level type object.
# Unlike Python-level exceptions which can have long names (ValueError,
# TypeError), struct.error uses the lowercase 'error' following the pattern
# of socket.error (now an alias for OSError). No prior struct spec anchors
# error.__name__.__eq__('error') as a standalone under structmro135.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra135.error_name_eq:
  description: "struct.error.__name__.__eq__('error') == True — struct.error is a C-level exception type defined in _struct.c; lowercase 5-char name 'error'; inherits from Exception; no prior struct spec anchors error.__name__ equality as a standalone; first standalone under structmro135"
  category: type_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__eq__.__class__.__name__.__eq__('wrapper_descriptor') — standalone
#
# struct.Struct.__eq__.__class__.__name__ is 'wrapper_descriptor'. The
# wrapper_descriptor type is used for C-level slot methods that are inherited
# by Python classes. When Struct inherits __eq__ from object, the descriptor
# accessed via Struct.__eq__ is of type wrapper_descriptor (not slot_wrapper,
# which is what you get via the instance). No prior struct spec anchors
# Struct.__eq__.__class__.__name__.__eq__('wrapper_descriptor') as a standalone
# under structmro135. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra135.Struct_eq_class_wrapper_descriptor:
  description: "struct.Struct.__eq__.__class__.__name__.__eq__('wrapper_descriptor') == True — Struct.__eq__ is a wrapper_descriptor (C-level slot method inherited from object); wrapper_descriptor is the type for slot methods accessed via a class (not instance); no prior struct spec anchors this as a standalone; first standalone under structmro135"
  category: type_identity
  kind: python_call_eq
  function: Struct.__eq__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__mro__[1].__name__.__eq__('Exception') — standalone
#
# struct.error.__mro__[1].__name__ is 'Exception'. struct.error inherits
# directly from Exception (not from a more specific subclass like ValueError
# or TypeError). This means struct.error can be caught by 'except Exception'
# or 'except struct.error'. struct_extra94 anchors the MRO depth (4); no prior
# struct spec anchors error.__mro__[1].__name__ equality as a standalone
# under structmro135. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra135.error_mro1_Exception:
  description: "struct.error.__mro__[1].__name__.__eq__('Exception') == True — struct.error inherits directly from Exception (not ValueError/TypeError/etc.); catchable via 'except Exception'; extra94 anchors MRO depth (4); first standalone for error.__mro__[1].__name__ under structmro135"
  category: type_identity
  kind: python_call_eq
  function: "error.__mro__[1].__name__.__eq__"
  args: ["Exception"]
  expected: true
