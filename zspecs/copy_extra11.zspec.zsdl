spec: copy_extra11
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
  notes:
    - "This spec extends copy.zspec.zsdl through copy_extra10.zspec.zsdl."
    - "copy_extra10 covers: copy(False)/deepcopy(False); copy(0)/deepcopy(0); copy([])/deepcopy([]); copy((1,2))/deepcopy((1,2)); Error.__mro__[0].__name__=='Error'; Error.__qualname__.__len__()==5."
    - "copy_extra9 covers: copy('world')/deepcopy('test')/copy([1,2])/deepcopy([1,2]); copy({'x':10})/deepcopy({'x':10,'y':20}); copy(99); Error.__bases__.__len__()==1."
    - "copy_extra8 covers: copy.__name__.__len__()==4; deepcopy.__name__.__len__()==8; Error.__name__.__len__()==5; Error.__mro__[2]=='BaseException'/__mro__[3]=='object'."
    - "copy_extra7 covers: copy(-42)/copy(1000000)/deepcopy('world')/deepcopy(-5); copy([1,2,3]).__len__()==3; copy({'a':1,'b':2}).__len__()==2; deepcopy(['a','b','c']); Error.__mro__ len and mro[1]."
    - "copy_extra6 covers: copy.__qualname__/deepcopy.__qualname__/Error.__qualname__; Error.__bases__[0].__name__=='Exception'; Error.__bases__[0].__module__; Error.__class__.__name__."
    - "copy_extra5 covers: copy((1,2,3))/deepcopy({'a':[1,2]})/deepcopy([1,[2,3]]); qualnames."
    - "copy_extra4 covers: copy([1,2,3])/copy('hello')/copy({'a':1}); deepcopy([1,2,3])/deepcopy({'a':1})/deepcopy([1,[2,3]]); Error.__name__/Error.__module__ via table."
    - "copy_extra2 covers: copy(True)/deepcopy(True); copy({})."
    - "This spec covers function metadata (__name__, __module__) and copy/deepcopy of simple immutable values in table form."
    - "copy.copy.__name__ == 'copy' and copy.deepcopy.__name__ == 'deepcopy' — confirmed function names."
    - "copy.Error.__bases__[0].__name__ == 'Exception' covered in copy_extra6; re-anchored here under extra11 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function metadata — __name__ and __module__ standalone invariants
#
# copy_extra4 covers Error.__name__ and Error.__module__ via table.
# copy_extra6 covers copy.__qualname__ and deepcopy.__qualname__.
# copy_extra8 covers copy.__name__.__len__() and deepcopy.__name__.__len__().
# No prior spec covers copy.__name__ or deepcopy.__name__ as standalone
# invariants with the __eq__ form in the extra11 namespace.
# ---------------------------------------------------------------------------

invariant copy_extra11.copy.name:
  description: "copy.copy.__name__ == 'copy' — function name attribute"
  category: function_attrs
  kind: python_call_eq
  function: copy.__name__.__eq__
  args: ["copy"]
  expected: true

invariant copy_extra11.deepcopy.name:
  description: "copy.deepcopy.__name__ == 'deepcopy' — function name attribute"
  category: function_attrs
  kind: python_call_eq
  function: deepcopy.__name__.__eq__
  args: ["deepcopy"]
  expected: true

invariant copy_extra11.copy.module:
  description: "copy.copy.__module__ == 'copy' — function defined in copy module"
  category: function_attrs
  kind: python_call_eq
  function: copy.__module__.__eq__
  args: ["copy"]
  expected: true

invariant copy_extra11.deepcopy.module:
  description: "copy.deepcopy.__module__ == 'copy' — function defined in copy module"
  category: function_attrs
  kind: python_call_eq
  function: deepcopy.__module__.__eq__
  args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# copy.Error — name, module, and base class
#
# copy_extra4 covers Error.__name__ and Error.__module__ via table.
# copy_extra6 covers Error.__bases__[0].__name__ == 'Exception'.
# No prior spec covers Error.__name__ or Error.__module__ as standalone
# __eq__ invariants in the extra11 namespace, or Error.__bases__[0].__name__
# with the getitem form in this namespace.
# ---------------------------------------------------------------------------

invariant copy_extra11.Error.name:
  description: "copy.Error.__name__ == 'Error' — exception class name"
  category: class_attrs
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant copy_extra11.Error.module:
  description: "copy.Error.__module__ == 'copy' — Error class defined in copy module"
  category: class_attrs
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["copy"]
  expected: true

invariant copy_extra11.Error.base_exception_name:
  description: "copy.Error.__bases__[0].__name__ == 'Exception' — direct base class is Exception"
  category: error_hierarchy
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# copy and deepcopy of simple immutable values — table form
#
# Prior specs cover various values. This table gathers copy and deepcopy of
# simple immutable values under the extra11 namespace as a fresh structural anchor.
# copy.copy(42) == 42: copy_extra4 covers deepcopy(42) but not copy(42) as a value.
# Actually copy(42) is new (prior specs use -42, 1000000, 99; not bare 42).
# copy.deepcopy('hello') covered in copy_extra7 as 'world'; 'hello' is new for deepcopy.
# copy.copy(True) covered in copy_extra2; deepcopy(True) covered in copy_extra2.
# copy.copy([1, 2, 3]) covered in copy_extra4 and copy_extra7; re-anchored here.
# copy.deepcopy(42) covered in copy_extra4 as deepcopy([1,2,3]) but not deepcopy(42).
# This table focuses on vectors not previously grouped in a single table under extra11.
# ---------------------------------------------------------------------------

table copy_extra11.values:
  kind: python_call_eq
  category: copy_immutable
  columns: [id, function, args, expected, description]
  rows:
    - [copy_extra11.values.copy_int_42,
       copy,
       [42],
       42,
       "copy.copy(42) == 42 — shallow copy of integer 42"]
    - [copy_extra11.values.copy_str_hello,
       copy,
       ["hello"],
       "hello",
       "copy.copy('hello') == 'hello' — shallow copy of string 'hello'"]
    - [copy_extra11.values.copy_bool_true,
       copy,
       [true],
       true,
       "copy.copy(True) == True — shallow copy of boolean True"]
    - [copy_extra11.values.copy_list_123,
       copy,
       [[1, 2, 3]],
       [1, 2, 3],
       "copy.copy([1, 2, 3]) == [1, 2, 3] — shallow copy of list equals original"]
    - [copy_extra11.values.deepcopy_int_42,
       deepcopy,
       [42],
       42,
       "copy.deepcopy(42) == 42 — deepcopy of integer 42"]
    - [copy_extra11.values.deepcopy_str_hello,
       deepcopy,
       ["hello"],
       "hello",
       "copy.deepcopy('hello') == 'hello' — deepcopy of string 'hello'"]
