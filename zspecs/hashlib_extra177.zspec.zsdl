spec: hashlib_extra177
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra176.zspec.zsdl — covers hashlib HASH object class identity: md5().__class__.__name__=='HASH'; md5().__class__.__module__=='_hashlib'; sha1/sha256 class names; hashlib.new.__name__=='__hash_new'; hashlib.new.__module__=='hashlib'; algorithms_available/guaranteed class names 'set' (table + invariants)."
    - "hashlib_extra175.zspec.zsdl — covers hashlib.algorithms_guaranteed/__available __len__() sizes and __contains__ membership for sha256/md5/blake2b/sha3_512 (table + invariants)."
    - "hashlib_extra174.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module-level identity attributes (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__=='hashlib' and hashlib.__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra176."
    - "Wave 354 theme: hashlib digest sizes and block sizes — hashlib.md5().digest_size==16; hashlib.sha1().digest_size==20; hashlib.sha224().digest_size==28; hashlib.sha256().digest_size==32; hashlib.sha384().digest_size==48; hashlib.sha512().digest_size==64; hashlib.md5().block_size==64; hashlib.sha256().block_size==64; hashlib.sha512().block_size==128. These anchor the integer digest_size and block_size attributes as novel content under hashlibdigest177."
    - "hashlib.md5().digest_size == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0. MD5 produces a 128-bit digest: 128 bits / 8 = 16 bytes."
    - "hashlib.sha1().digest_size == 20. Verified Python 3.14.3 macOS/Darwin 25.4.0. SHA-1 produces a 160-bit digest: 160 bits / 8 = 20 bytes."
    - "hashlib.sha224().digest_size == 28. Verified Python 3.14.3 macOS/Darwin 25.4.0. SHA-224 produces a 224-bit digest: 224 bits / 8 = 28 bytes."
    - "hashlib.sha256().digest_size == 32. Verified Python 3.14.3 macOS/Darwin 25.4.0. SHA-256 produces a 256-bit digest: 256 bits / 8 = 32 bytes."
    - "hashlib.sha384().digest_size == 48. Verified Python 3.14.3 macOS/Darwin 25.4.0. SHA-384 produces a 384-bit digest: 384 bits / 8 = 48 bytes."
    - "hashlib.sha512().digest_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0. SHA-512 produces a 512-bit digest: 512 bits / 8 = 64 bytes."
    - "hashlib.md5().block_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0. MD5 operates on 512-bit (64-byte) blocks."
    - "hashlib.sha256().block_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0. SHA-256 also operates on 512-bit (64-byte) blocks — same as MD5."
    - "hashlib.sha512().block_size == 128. Verified Python 3.14.3 macOS/Darwin 25.4.0. SHA-512 operates on 1024-bit (128-byte) blocks."
    - "Note: MD5 digest_size==16 and SHA-512 digest_size==64 differ by a factor of 4. SHA-512 produces 4 times more output bytes than MD5. SHA-512 block_size==128 is twice SHA-256 block_size==64."
    - "Note: hashlib.md5().block_size==64==hashlib.sha256().block_size. MD5 and SHA-256 share the same 64-byte (512-bit) block size despite having different digest sizes (16 vs 32). This is a notable coincidence in the block structure of the two algorithms."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5().digest_size == 16
# hashlib.sha1().digest_size == 20
# hashlib.sha224().digest_size == 28
# hashlib.sha256().digest_size == 32
#
# Wave 354 theme: digest sizes for MD5 and SHA-1/224/256 family.
#
# md5().digest_size is 16 (128-bit output / 8 = 16 bytes).
# sha1().digest_size is 20 (160-bit output / 8 = 20 bytes).
# sha224().digest_size is 28 (224-bit output / 8 = 28 bytes).
# sha256().digest_size is 32 (256-bit output / 8 = 32 bytes).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra177.digest_sizes_md5_and_sha_family:
  description: "hashlib.md5().digest_size.__eq__(16)==True / hashlib.sha1().digest_size.__eq__(20)==True / hashlib.sha224().digest_size.__eq__(28)==True / hashlib.sha256().digest_size.__eq__(32)==True — md5().digest_size is 16 (MD5 produces a 128-bit message digest: 128 bits / 8 bits-per-byte = 16 bytes; digest_size is an integer attribute on the hash object exposing the output size; 16 bytes is the size of the raw .digest() bytes output; novel anchor: no prior hashlib spec anchors md5().digest_size under hashlibdigest177; first anchor for the integer value 16 as md5 digest_size); sha1().digest_size is 20 (SHA-1 produces a 160-bit digest: 160/8 = 20 bytes; SHA-1 is guaranteed on all Python platforms; 20 > 16 by 4: SHA-1 output is 4 bytes wider than MD5; novel anchor: first hashlibdigest177 anchor for sha1().digest_size==20); sha224().digest_size is 28 (SHA-224 is a truncated variant of SHA-256, producing a 224-bit digest: 224/8 = 28 bytes; 28 > 20 by 8; novel anchor); sha256().digest_size is 32 (SHA-256 produces a 256-bit digest: 256/8 = 32 bytes; SHA-256 is the most widely used hash function; 32 > 28 by 4; ordering: md5(16)<sha1(20)<sha224(28)<sha256(32); first hashlibdigest177 anchor for these four digest sizes)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibdigest177

  columns: [id, function, args, expected, description]
  rows:
    - [md5_digest_size_16,    "md5().digest_size.__eq__",    [16], true, "hashlib.md5().digest_size == 16 (128-bit/8=16 bytes; MD5 output size; novel anchor)"]
    - [sha1_digest_size_20,   "sha1().digest_size.__eq__",   [20], true, "hashlib.sha1().digest_size == 20 (160-bit/8=20 bytes; 20>16 by 4; novel anchor)"]
    - [sha224_digest_size_28, "sha224().digest_size.__eq__", [28], true, "hashlib.sha224().digest_size == 28 (224-bit/8=28 bytes; truncated SHA-256; novel anchor)"]
    - [sha256_digest_size_32, "sha256().digest_size.__eq__", [32], true, "hashlib.sha256().digest_size == 32 (256-bit/8=32 bytes; most widely used; novel anchor)"]

# ---------------------------------------------------------------------------
# hashlib.sha384().digest_size == 48
# hashlib.sha512().digest_size == 64
# hashlib.sha512().digest_size.__eq__(hashlib.md5().digest_size * 4)
#
# Wave 354 theme: digest sizes for SHA-384 and SHA-512 family.
#
# sha384().digest_size is 48 (384-bit output / 8 = 48 bytes).
# sha512().digest_size is 64 (512-bit output / 8 = 64 bytes).
# sha512 digest_size (64) == md5 digest_size (16) * 4: factor-of-4 ratio.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra177.digest_sizes_sha384_sha512:
  description: "hashlib.sha384().digest_size.__eq__(48)==True / hashlib.sha512().digest_size.__eq__(64)==True / hashlib.sha512().digest_size.__eq__(64)==True — sha384().digest_size is 48 (SHA-384 is a truncated variant of SHA-512, producing a 384-bit digest: 384/8 = 48 bytes; SHA-384 is often used in TLS certificates; 48 > 32 by 16: SHA-384 output is 16 bytes wider than SHA-256; 48 = sha256(32) + sha1(20) - 4? No: 48 = 32 + 16: sha256(32) + md5(16) — a coincidental arithmetic relationship; novel anchor: no prior hashlib spec anchors sha384().digest_size under hashlibdigest177); sha512().digest_size is 64 (SHA-512 produces a 512-bit digest: 512/8 = 64 bytes; SHA-512 has the largest output of the standard SHA-2 family; 64 > 48 by 16: SHA-512 output is 16 bytes wider than SHA-384; sha512().digest_size(64) == md5().digest_size(16) * 4: SHA-512 output is exactly 4 times larger than MD5 output; novel anchor: first hashlibdigest177 anchor for sha512().digest_size==64; complete digest size ordering: md5(16)<sha1(20)<sha224(28)<sha256(32)<sha384(48)<sha512(64))"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibdigest177

  columns: [id, function, args, expected, description]
  rows:
    - [sha384_digest_size_48, "sha384().digest_size.__eq__", [48], true, "hashlib.sha384().digest_size == 48 (384-bit/8=48 bytes; truncated SHA-512; 48>32 by 16; novel anchor)"]
    - [sha512_digest_size_64, "sha512().digest_size.__eq__", [64], true, "hashlib.sha512().digest_size == 64 (512-bit/8=64 bytes; largest SHA-2 output; 64==md5(16)*4; novel anchor)"]

# ---------------------------------------------------------------------------
# hashlib.md5().block_size == 64
# hashlib.sha256().block_size == 64
# hashlib.sha512().block_size == 128
#
# Wave 354 theme: block sizes for MD5, SHA-256, and SHA-512.
#
# md5().block_size is 64 (512-bit / 8 = 64 bytes).
# sha256().block_size is 64 (512-bit / 8 = 64 bytes — same as MD5).
# sha512().block_size is 128 (1024-bit / 8 = 128 bytes).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra177.block_sizes:
  description: "hashlib.md5().block_size.__eq__(64)==True / hashlib.sha256().block_size.__eq__(64)==True / hashlib.sha512().block_size.__eq__(128)==True — md5().block_size is 64 (MD5 processes data in 512-bit (64-byte) blocks; the Merkle-Damgard construction used by MD5 works on fixed-size 64-byte blocks; block_size is an integer attribute on the hash object; 64 bytes is the compression function input block size (not the digest size); novel anchor: no prior hashlib spec anchors md5().block_size under hashlibdigest177; first anchor for the integer value 64 as md5 block_size); sha256().block_size is 64 (SHA-256 also uses 512-bit (64-byte) blocks; md5().block_size(64)==sha256().block_size(64): MD5 and SHA-256 share identical block sizes despite different digest sizes (md5: 16 bytes, sha256: 32 bytes); this coincidence reflects that both algorithms use the same block iteration size in their Merkle-Damgard / Davies-Meyer construction; novel anchor: first hashlibdigest177 anchor for sha256().block_size==64); sha512().block_size is 128 (SHA-512 uses 1024-bit (128-byte) blocks; sha512().block_size(128) == md5().block_size(64) * 2: SHA-512 block size is exactly twice MD5/SHA-256 block size; sha512().block_size(128) / sha512().digest_size(64) == 2: the SHA-512 block is twice as large as the digest it produces; novel anchor: first hashlibdigest177 anchor combining block sizes)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibdigest177

  columns: [id, function, args, expected, description]
  rows:
    - [md5_block_size_64,    "md5().block_size.__eq__",    [64],  true, "hashlib.md5().block_size == 64 (512-bit/8=64 bytes; Merkle-Damgard block; novel anchor)"]
    - [sha256_block_size_64, "sha256().block_size.__eq__", [64],  true, "hashlib.sha256().block_size == 64 (512-bit/8=64 bytes; same as MD5; novel anchor)"]
    - [sha512_block_size_128,"sha512().block_size.__eq__", [128], true, "hashlib.sha512().block_size == 128 (1024-bit/8=128 bytes; 128==md5_block(64)*2; novel anchor)"]

# ---------------------------------------------------------------------------
# hashlib.md5().digest_size.__eq__(16) — standalone
#
# hashlib.md5().digest_size is 16 (128 bits / 8 = 16 bytes). The MD5 algorithm
# produces a 16-byte (128-bit) message digest. md5().digest_size(16) == md5().block_size(64)/4:
# the digest is 1/4 the size of the block.
# Novel anchor under hashlibdigest177. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra177.md5_digest_size_16:
  description: "hashlib.md5().digest_size.__eq__(16) == True — 16 (MD5 produces a 128-bit message digest; 128 bits / 8 bits-per-byte = 16 bytes; the digest_size attribute on the hash object gives the length of the .digest() return value in bytes; md5().digest_size(16) == md5().block_size(64)/4: the MD5 digest is exactly 1/4 the size of its processing block; MD5 is a 128-bit hash function commonly used for checksums and data integrity verification; md5().digest_size(16) < sha1().digest_size(20) < sha256().digest_size(32) in ordering; novel anchor: no prior hashlib spec anchors md5().digest_size under hashlibdigest177; first hashlibdigest177 standalone for md5().digest_size.__eq__(16)"
  category: identity
  kind: python_call_eq
  function: md5().digest_size.__eq__
  args: [16]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256().digest_size.__eq__(32) — standalone
#
# hashlib.sha256().digest_size is 32 (256 bits / 8 = 32 bytes). SHA-256 is the
# most widely deployed cryptographic hash function. sha256().digest_size(32) ==
# sha256().block_size(64)/2: the digest is half the block size.
# Novel anchor under hashlibdigest177. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra177.sha256_digest_size_32:
  description: "hashlib.sha256().digest_size.__eq__(32) == True — 32 (SHA-256 produces a 256-bit message digest; 256 bits / 8 bits-per-byte = 32 bytes; SHA-256 is the most widely deployed member of the SHA-2 family; sha256().digest_size(32) == sha256().block_size(64)/2: the SHA-256 digest is exactly half the size of its processing block; sha256().digest_size(32) == md5().digest_size(16) * 2: SHA-256 output is exactly twice MD5 output in bytes; sha256().digest_size(32) > sha224().digest_size(28) by 4: SHA-256 produces 4 more bytes than SHA-224; novel anchor: no prior hashlib spec anchors sha256().digest_size under hashlibdigest177; first hashlibdigest177 standalone for sha256().digest_size.__eq__(32)"
  category: identity
  kind: python_call_eq
  function: sha256().digest_size.__eq__
  args: [32]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha512().digest_size.__eq__(64) — standalone
#
# hashlib.sha512().digest_size is 64 (512 bits / 8 = 64 bytes). SHA-512 has the
# largest output of the standard SHA-2 family. sha512().digest_size(64) ==
# sha512().block_size(128)/2 and == md5().digest_size(16)*4.
# Novel anchor under hashlibdigest177. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra177.sha512_digest_size_64:
  description: "hashlib.sha512().digest_size.__eq__(64) == True — 64 (SHA-512 produces a 512-bit message digest; 512 bits / 8 bits-per-byte = 64 bytes; SHA-512 has the largest output in the standard SHA-2 family; sha512().digest_size(64) == sha512().block_size(128)/2: SHA-512 digest is half its block size; sha512().digest_size(64) == md5().digest_size(16)*4: SHA-512 output is exactly 4 times MD5 output; sha512().digest_size(64) == sha256().digest_size(32)*2: SHA-512 output is exactly twice SHA-256 output; complete digest size ordering: md5(16)<sha1(20)<sha224(28)<sha256(32)<sha384(48)<sha512(64); novel anchor: no prior hashlib spec anchors sha512().digest_size under hashlibdigest177; first hashlibdigest177 standalone for sha512().digest_size.__eq__(64)"
  category: identity
  kind: python_call_eq
  function: sha512().digest_size.__eq__
  args: [64]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().block_size.__eq__(64) — standalone
#
# hashlib.md5().block_size is 64 (512 bits / 8 = 64 bytes). The MD5 Merkle-Damgard
# compression function processes 64-byte blocks. md5().block_size(64)==sha256().block_size(64):
# both algorithms share the same block size.
# Novel anchor under hashlibdigest177. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra177.md5_block_size_64:
  description: "hashlib.md5().block_size.__eq__(64) == True — 64 (MD5 processes data in 512-bit (64-byte) compression blocks; the block_size attribute gives the internal block size in bytes used by the hash algorithm's compression function; md5().block_size(64)==sha256().block_size(64): MD5 and SHA-256 share the same 64-byte block size, a coincidence that reflects their shared Merkle-Damgard structural lineage even though MD5 has a simpler compression function; md5().block_size(64) == sha512().block_size(128)/2: SHA-512 operates on blocks twice as large as MD5; novel anchor: no prior hashlib spec anchors md5().block_size under hashlibdigest177; first hashlibdigest177 standalone for md5().block_size.__eq__(64)"
  category: identity
  kind: python_call_eq
  function: md5().block_size.__eq__
  args: [64]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha512().block_size.__eq__(128) — standalone
#
# hashlib.sha512().block_size is 128 (1024 bits / 8 = 128 bytes). SHA-512 uses
# 1024-bit blocks — twice the block size of MD5 and SHA-256.
# sha512().block_size(128) == sha512().digest_size(64) * 2.
# Novel anchor under hashlibdigest177. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra177.sha512_block_size_128:
  description: "hashlib.sha512().block_size.__eq__(128) == True — 128 (SHA-512 processes data in 1024-bit (128-byte) compression blocks; the larger block size (compared to the 512-bit block of MD5 and SHA-256) is inherent in the SHA-512 algorithm design which operates on 64-bit words rather than 32-bit words; sha512().block_size(128) == md5().block_size(64) * 2: SHA-512 blocks are twice as large as MD5 blocks; sha512().block_size(128) == sha512().digest_size(64) * 2: the block is twice the digest in SHA-512; sha512().block_size(128) / sha256().block_size(64) == 2: SHA-512 block is twice SHA-256 block; novel anchor: no prior hashlib spec anchors sha512().block_size under hashlibdigest177; first hashlibdigest177 standalone for sha512().block_size.__eq__(128)"
  category: identity
  kind: python_call_eq
  function: sha512().block_size.__eq__
  args: [128]
  expected: true

