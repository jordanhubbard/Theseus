spec: pathlib_extra290
version: ">=3.4"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra289.zspec.zsdl — covers PurePath boundary cases, suffix/stem, FileNotFoundError on stat"
    - "pathlib_extra288.zspec.zsdl — covers PurePath division via __truediv__"
  notes:
    - "This spec focuses on PurePosixPath and PurePath rich comparison operators."
    - "Path and PurePosixPath support __lt__, __le__, __eq__, __ne__, __gt__, __ge__ based on lexicographic path string ordering."
    - "PurePosixPath('/a') < PurePosixPath('/b') is True — '/a' sorts before '/b' lexicographically."
    - "PurePosixPath('/a') == PurePosixPath('/a') is True — equal paths compare equal."
    - "PurePosixPath('/a') != PurePosixPath('/b') is True — unequal paths compare not-equal."
    - "PurePosixPath('/z') > PurePosixPath('/a') is True — '/z' sorts after '/a'."
    - "PurePosixPath('/a') <= PurePosixPath('/a') is True — a path is less-than-or-equal to itself."
    - "PurePosixPath('/a') >= PurePosixPath('/a') is True — a path is greater-than-or-equal to itself."
    - "PurePosixPath('/c/d') < PurePosixPath('/c/e') is True — ordering is lexicographic per path string."
    - "Path('/a').__lt__(Path('/b')) is True — the concrete Path class inherits PurePath ordering."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePosixPath rich comparison operators
#
# PurePosixPath paths are compared lexicographically by their string form.
# __lt__, __le__, __eq__, __ne__, __gt__, __ge__ are all supported.
# The comparison uses the string representation of the path.
# ---------------------------------------------------------------------------

table pathlib_extra290.PurePosixPath_comparison_lt_gt:
  description: "PurePosixPath __lt__ and __gt__: lexicographic ordering of path strings"
  kind: python_call_eq
  category: comparison
  id_prefix: pcmp290

  columns: [id, function, args, expected, description]
  rows:
    - [a_lt_b,     "PurePosixPath('/a').__lt__",   ["PurePosixPath('/b')"],   true,  "PurePosixPath('/a') < PurePosixPath('/b') — '/a' sorts before '/b'"]
    - [b_gt_a,     "PurePosixPath('/b').__gt__",   ["PurePosixPath('/a')"],   true,  "PurePosixPath('/b') > PurePosixPath('/a') — '/b' sorts after '/a'"]
    - [a_lt_z,     "PurePosixPath('/a').__lt__",   ["PurePosixPath('/z')"],   true,  "PurePosixPath('/a') < PurePosixPath('/z') — first letter ordering"]
    - [cd_lt_ce,   "PurePosixPath('/c/d').__lt__", ["PurePosixPath('/c/e')"], true,  "PurePosixPath('/c/d') < PurePosixPath('/c/e') — same parent, different name"]
    - [a_not_lt_a, "PurePosixPath('/a').__lt__",   ["PurePosixPath('/a')"],   false, "PurePosixPath('/a') < PurePosixPath('/a') is False — equal paths are not strictly less"]
    - [b_not_lt_a, "PurePosixPath('/b').__lt__",   ["PurePosixPath('/a')"],   false, "PurePosixPath('/b') < PurePosixPath('/a') is False — greater path is not less"]

# ---------------------------------------------------------------------------
# PurePosixPath equality and inequality operators
#
# __eq__ compares path strings exactly; __ne__ is the inverse.
# ---------------------------------------------------------------------------

table pathlib_extra290.PurePosixPath_comparison_eq_ne:
  description: "PurePosixPath __eq__ and __ne__: equality and inequality by path string"
  kind: python_call_eq
  category: comparison
  id_prefix: peq290

  columns: [id, function, args, expected, description]
  rows:
    - [eq_same,    "PurePosixPath('/a').__eq__",  ["PurePosixPath('/a')"],  true,  "PurePosixPath('/a') == PurePosixPath('/a') — identical paths are equal"]
    - [eq_diff,    "PurePosixPath('/a').__eq__",  ["PurePosixPath('/b')"],  false, "PurePosixPath('/a') == PurePosixPath('/b') is False — different paths are not equal"]
    - [ne_diff,    "PurePosixPath('/a').__ne__",  ["PurePosixPath('/b')"],  true,  "PurePosixPath('/a') != PurePosixPath('/b') — different paths are not-equal"]
    - [ne_same,    "PurePosixPath('/a').__ne__",  ["PurePosixPath('/a')"],  false, "PurePosixPath('/a') != PurePosixPath('/a') is False — identical paths are not not-equal"]
    - [eq_deep,    "PurePosixPath('/a/b/c').__eq__", ["PurePosixPath('/a/b/c')"], true, "multi-segment path equals itself"]
    - [ne_deep,    "PurePosixPath('/a/b/c').__ne__", ["PurePosixPath('/a/b/d')"], true, "multi-segment paths with differing last segment are not-equal"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra290.PurePosixPath.a_lt_b:
  description: "PurePosixPath('/a') < PurePosixPath('/b') is True — paths are ordered lexicographically"
  category: comparison
  kind: python_call_eq
  function: "PurePosixPath('/a').__lt__"
  args: ["PurePosixPath('/b')"]
  expected: true

invariant pathlib_extra290.PurePosixPath.a_eq_a:
  description: "PurePosixPath('/a') == PurePosixPath('/a') is True — a path is equal to itself"
  category: comparison
  kind: python_call_eq
  function: "PurePosixPath('/a').__eq__"
  args: ["PurePosixPath('/a')"]
  expected: true

invariant pathlib_extra290.PurePosixPath.a_ne_b:
  description: "PurePosixPath('/a') != PurePosixPath('/b') is True — paths with different names are not equal"
  category: comparison
  kind: python_call_eq
  function: "PurePosixPath('/a').__ne__"
  args: ["PurePosixPath('/b')"]
  expected: true

invariant pathlib_extra290.PurePosixPath.a_le_a:
  description: "PurePosixPath('/a') <= PurePosixPath('/a') is True — a path is less-than-or-equal to itself"
  category: comparison
  kind: python_call_eq
  function: "PurePosixPath('/a').__le__"
  args: ["PurePosixPath('/a')"]
  expected: true

invariant pathlib_extra290.PurePosixPath.a_ge_a:
  description: "PurePosixPath('/a') >= PurePosixPath('/a') is True — a path is greater-than-or-equal to itself"
  category: comparison
  kind: python_call_eq
  function: "PurePosixPath('/a').__ge__"
  args: ["PurePosixPath('/a')"]
  expected: true

invariant pathlib_extra290.PurePosixPath.b_gt_a:
  description: "PurePosixPath('/b') > PurePosixPath('/a') is True — '/b' sorts after '/a'"
  category: comparison
  kind: python_call_eq
  function: "PurePosixPath('/b').__gt__"
  args: ["PurePosixPath('/a')"]
  expected: true

invariant pathlib_extra290.PurePosixPath.cd_lt_ce:
  description: "PurePosixPath('/c/d') < PurePosixPath('/c/e') is True — same parent, differing final segment is compared lexicographically"
  category: comparison
  kind: python_call_eq
  function: "PurePosixPath('/c/d').__lt__"
  args: ["PurePosixPath('/c/e')"]
  expected: true
