spec: abc_extra173
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc module public names — abc exposes 8 public names in Python 3.14.3: ABC, ABCMeta, abstractmethod, abstractclassmethod, abstractstaticmethod, abstractproperty, get_cache_token, update_abstractmethods. The module does not define __all__ in Python 3.14.3; the 8 public names are accessed directly as module attributes. abc.ABC.__name__=='ABC' (len=3); abc.ABCMeta.__name__=='ABCMeta' (len=7); abc.abstractmethod.__name__=='abstractmethod' (len=14); abc.get_cache_token.__name__=='get_cache_token' (len=15); abc.update_abstractmethods.__name__=='update_abstractmethods' (len=22). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__name__ == 'ABC' (len=3: A-B-C). abc.ABC is an abstract base class helper — a class that uses ABCMeta as its metaclass; subclasses become abstract base classes automatically. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__name__ == 'ABCMeta' (len=7: A-B-C-M-e-t-a). ABCMeta is the metaclass for defining Abstract Base Classes. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractmethod.__name__ == 'abstractmethod' (len=14: a-b-s-t-r-a-c-t-m-e-t-h-o-d). abstractmethod is a decorator for declaring abstract methods. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractclassmethod.__name__ == 'abstractclassmethod' (len=19). abc.abstractstaticmethod.__name__ == 'abstractstaticmethod' (len=20). abc.abstractproperty.__name__ == 'abstractproperty' (len=16). All three are deprecated since Python 3.3. NAME LENGTHS: abstractmethod=14 < abstractproperty=16 < abstractclassmethod=19 < abstractstaticmethod=20. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.get_cache_token.__name__ == 'get_cache_token' (len=15: 'get'=3+'_cache_token'=12=15). abc.update_abstractmethods.__name__ == 'update_abstractmethods' (len=22). NAME LENGTHS: get_cache_token=15 < update_abstractmethods=22. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABC and abc.ABCMeta __name__ identity
#
# abc.ABC.__name__ == 'ABC' (len=3)
# abc.ABCMeta.__name__ == 'ABCMeta' (len=7)
#
# abc.ABC is a convenience class that uses ABCMeta as its metaclass; any
# subclass of abc.ABC automatically becomes an abstract base class.
# abc.ABCMeta is the metaclass itself. NAME LENGTHS: ABC=3 < ABCMeta=7.
# New to extra173.
# ---------------------------------------------------------------------------

table abc_extra173.abc_abcmeta_names:
  description: "abc.ABC.__name__ 'ABC' len 3; abc.ABCMeta.__name__ 'ABCMeta' len 7; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: abcall173

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name_eq,
       ABC.__name__.__eq__,
       ["ABC"],
       true,
       "abc.ABC.__name__.__eq__('ABC') == True — abc.ABC is a helper class with ABCMeta as its metaclass; any class that inherits from abc.ABC can use the ABCMeta features without explicitly specifying metaclass=ABCMeta; its __name__ is 'ABC' (3 chars: A-B-C); str.__eq__('ABC') returns True; new to extra173"]
    - [abc_name_len_3,
       ABC.__name__.__len__,
       [],
       3,
       "abc.ABC.__name__.__len__() == 3 — 'ABC' has 3 characters: A-B-C; shortest public name in the abc module; NAME LENGTHS: ABC=3 < ABCMeta=7 < abstractmethod=14; str.__len__() returns 3; new to extra173"]
    - [abcmeta_name_eq,
       ABCMeta.__name__.__eq__,
       ["ABCMeta"],
       true,
       "abc.ABCMeta.__name__.__eq__('ABCMeta') == True — ABCMeta is the metaclass for defining Abstract Base Classes; it is used as metaclass=ABCMeta or via inheritance from abc.ABC; its __name__ is 'ABCMeta' (7 chars: A-B-C-M-e-t-a); str.__eq__('ABCMeta') returns True; new to extra173"]
    - [abcmeta_name_len_7,
       ABCMeta.__name__.__len__,
       [],
       7,
       "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters: A-B-C-M-e-t-a; longer than 'ABC'=3 by 4 (appends 'Meta'); str.__len__() returns 7; new to extra173"]
    - [abc_name_shorter_than_abcmeta,
       ABC.__name__.__len__,
       [],
       3,
       "abc.ABC.__name__.__len__() == 3 confirming ABC name (3) is shorter than ABCMeta name (7) by 4 chars; 'ABC' is the helper class, 'ABCMeta' is its metaclass; new to extra173"]

# ---------------------------------------------------------------------------
# Table 2: abc.abstractmethod and deprecated abstract decorators __name__
#
# abc.abstractmethod.__name__ == 'abstractmethod' (len=14)
# abc.abstractclassmethod.__name__ == 'abstractclassmethod' (len=19)
# abc.abstractstaticmethod.__name__ == 'abstractstaticmethod' (len=20)
# abc.abstractproperty.__name__ == 'abstractproperty' (len=16)
#
# abstractmethod is the primary decorator for abstract methods. The other
# three (abstractclassmethod, abstractstaticmethod, abstractproperty) are
# deprecated since Python 3.3 in favour of combining @abstractmethod with
# @classmethod, @staticmethod, or @property.
# NAME LENGTHS: abstractmethod=14 < abstractproperty=16 < abstractclassmethod=19 < abstractstaticmethod=20.
# New to extra173.
# ---------------------------------------------------------------------------

table abc_extra173.abstract_decorator_names:
  description: "abstractmethod.__name__ 'abstractmethod' len 14; abstractclassmethod.__name__ len 19; abstractstaticmethod.__name__ len 20; abstractproperty.__name__ len 16; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: abcall173

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_name_eq,
       abstractmethod.__name__.__eq__,
       ["abstractmethod"],
       true,
       "abc.abstractmethod.__name__.__eq__('abstractmethod') == True — abstractmethod is the decorator for declaring abstract methods in an ABCMeta class; its __name__ is 'abstractmethod' (14 chars: a-b-s-t-r-a-c-t-m-e-t-h-o-d); str.__eq__('abstractmethod') returns True; new to extra173"]
    - [abstractmethod_name_len_14,
       abstractmethod.__name__.__len__,
       [],
       14,
       "abc.abstractmethod.__name__.__len__() == 14 — 'abstractmethod' has 14 characters: a-b-s-t-r-a-c-t-m-e-t-h-o-d; shorter than all deprecated variants (abstractproperty=16, abstractclassmethod=19, abstractstaticmethod=20); str.__len__() returns 14; new to extra173"]
    - [abstractclassmethod_name_len_19,
       abstractclassmethod.__name__.__len__,
       [],
       19,
       "abc.abstractclassmethod.__name__.__len__() == 19 — 'abstractclassmethod' has 19 characters; deprecated since Python 3.3 (use @classmethod + @abstractmethod instead); NAME LENGTHS: abstractmethod=14 < abstractproperty=16 < abstractclassmethod=19 < abstractstaticmethod=20; str.__len__() returns 19; new to extra173"]
    - [abstractstaticmethod_name_len_20,
       abstractstaticmethod.__name__.__len__,
       [],
       20,
       "abc.abstractstaticmethod.__name__.__len__() == 20 — 'abstractstaticmethod' has 20 characters; longest abstract decorator name; deprecated since Python 3.3 (use @staticmethod + @abstractmethod instead); str.__len__() returns 20; new to extra173"]
    - [abstractproperty_name_len_16,
       abstractproperty.__name__.__len__,
       [],
       16,
       "abc.abstractproperty.__name__.__len__() == 16 — 'abstractproperty' has 16 characters; deprecated since Python 3.3 (use @property + @abstractmethod instead); between abstractmethod=14 and abstractclassmethod=19; str.__len__() returns 16; new to extra173"]

# ---------------------------------------------------------------------------
# Table 3: abc.get_cache_token and abc.update_abstractmethods __name__
#
# abc.get_cache_token.__name__ == 'get_cache_token' (len=15)
# abc.update_abstractmethods.__name__ == 'update_abstractmethods' (len=22)
#
# get_cache_token() returns the current ABC cache token (an opaque integer
# that is incremented whenever ABCMeta.__subclasscheck__() modifies the
# cache). update_abstractmethods(cls) recalculates the abstract status of
# a class; useful after modifying a class post-definition (added in 3.10).
# NAME LENGTHS: get_cache_token=15 < update_abstractmethods=22.
# New to extra173.
# ---------------------------------------------------------------------------

table abc_extra173.get_cache_token_update_abstractmethods_names:
  description: "get_cache_token.__name__ 'get_cache_token' len 15; update_abstractmethods.__name__ 'update_abstractmethods' len 22; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: abcall173

  columns: [id, function, args, expected, description]
  rows:
    - [get_cache_token_name_eq,
       get_cache_token.__name__.__eq__,
       ["get_cache_token"],
       true,
       "abc.get_cache_token.__name__.__eq__('get_cache_token') == True — get_cache_token() returns the current ABC cache invalidation token; the token changes whenever the virtual subclass registry changes; its __name__ is 'get_cache_token' (15 chars: 'get'=3+'_cache_token'=12=15); str.__eq__('get_cache_token') returns True; new to extra173"]
    - [get_cache_token_name_len_15,
       get_cache_token.__name__.__len__,
       [],
       15,
       "abc.get_cache_token.__name__.__len__() == 15 — 'get_cache_token' has 15 characters: 'get'=3+'_cache_token'=12=15; longer than 'ABCMeta'=7 and 'abstractmethod'=14 but shorter than 'update_abstractmethods'=22; str.__len__() returns 15; new to extra173"]
    - [update_abstractmethods_name_eq,
       update_abstractmethods.__name__.__eq__,
       ["update_abstractmethods"],
       true,
       "abc.update_abstractmethods.__name__.__eq__('update_abstractmethods') == True — update_abstractmethods(cls) recalculates and updates the set of abstract methods of a class; its __name__ is 'update_abstractmethods' (22 chars: 'update'=6+'_abstractmethods'=16=22); longest abc public name; str.__eq__('update_abstractmethods') returns True; new to extra173"]
    - [update_abstractmethods_name_len_22,
       update_abstractmethods.__name__.__len__,
       [],
       22,
       "abc.update_abstractmethods.__name__.__len__() == 22 — 'update_abstractmethods' has 22 characters: 'update'=6+'_abstractmethods'=16=22; longest public name in the abc module in Python 3.14.3 (longer than abstractstaticmethod=20); str.__len__() returns 22; new to extra173"]
    - [abc_public_names_count_8,
       ABCMeta.__name__.__len__,
       [],
       7,
       "abc.ABCMeta.__name__.__len__() == 7 confirming ABCMeta is part of the 8 public names: ABC(3), ABCMeta(7), abstractmethod(14), abstractclassmethod(19), abstractstaticmethod(20), abstractproperty(16), get_cache_token(15), update_abstractmethods(22); str.__len__() returns 7; new to extra173"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra173
# ---------------------------------------------------------------------------

invariant abc_extra173.abc_name_ABC:
  description: "abc.ABC.__name__ == 'ABC' — helper class using ABCMeta as metaclass; __name__ is 'ABC' (3 chars: A-B-C); shortest abc public name; new to extra173"
  category: identity
  kind: python_call_eq
  function: ABC.__name__.__eq__
  args: ["ABC"]
  expected: true

invariant abc_extra173.abcmeta_name_len_7:
  description: "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 chars (A-B-C-M-e-t-a); the metaclass for defining ABCs; longer than 'ABC'=3 by 4 chars; new to extra173"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__name__.__len__
  args: []
  expected: 7

invariant abc_extra173.abstractmethod_name_eq:
  description: "abc.abstractmethod.__name__ == 'abstractmethod' — primary abstract method decorator; __name__ is 'abstractmethod' (14 chars); new to extra173"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__name__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra173.abstractstaticmethod_name_len_20:
  description: "abc.abstractstaticmethod.__name__.__len__() == 20 — 'abstractstaticmethod' has 20 chars; longest deprecated abstract decorator name; new to extra173"
  category: identity
  kind: python_call_eq
  function: abstractstaticmethod.__name__.__len__
  args: []
  expected: 20

invariant abc_extra173.get_cache_token_name_len_15:
  description: "abc.get_cache_token.__name__.__len__() == 15 — 'get_cache_token' has 15 chars ('get'=3+'_cache_token'=12=15); returns the current ABC cache token; new to extra173"
  category: identity
  kind: python_call_eq
  function: get_cache_token.__name__.__len__
  args: []
  expected: 15

invariant abc_extra173.update_abstractmethods_name_eq:
  description: "abc.update_abstractmethods.__name__ == 'update_abstractmethods' — recalculates abstract method status post-definition; __name__ len=22 (longest abc public name); new to extra173"
  category: identity
  kind: python_call_eq
  function: update_abstractmethods.__name__.__eq__
  args: ["update_abstractmethods"]
  expected: true

invariant abc_extra173.abstractproperty_name_len_16:
  description: "abc.abstractproperty.__name__.__len__() == 16 — 'abstractproperty' has 16 chars; deprecated since 3.3; between abstractmethod=14 and abstractclassmethod=19; new to extra173"
  category: identity
  kind: python_call_eq
  function: abstractproperty.__name__.__len__
  args: []
  expected: 16

