spec: inspect_extra186
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Traceback and inspect.FrameInfo named tuple identity — in Python 3.14.3, Traceback and FrameInfo are NamedTuple subclasses with an intermediate private base (_Traceback, _FrameInfo) rather than inheriting directly from tuple. inspect.Traceback.__name__=='Traceback' (len 9); inspect.Traceback.__module__=='inspect'; inspect.Traceback.__bases__[0].__name__=='_Traceback' (not 'tuple' — private intermediate); inspect.FrameInfo.__name__=='FrameInfo' (len 9); inspect.FrameInfo.__module__=='inspect'; inspect.FrameInfo.__bases__[0].__name__=='_FrameInfo'; inspect.ArgInfo.__name__=='ArgInfo' (len 7); inspect.ArgInfo.__bases__[0].__name__=='tuple' (direct tuple inheritance, simpler NamedTuple)."
    - "inspect.Traceback.__bases__[0].__name__ == '_Traceback' — in Python 3.14.3 Traceback is a typed NamedTuple with an intermediate private _Traceback base class; __bases__[0].__name__ is '_Traceback', not 'tuple' directly; verified with Python 3.14.3 on macOS/Darwin 25.4.0."
    - "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo' — similarly FrameInfo has an intermediate _FrameInfo base; __bases__[0].__name__ is '_FrameInfo'; verified with Python 3.14.3."
    - "inspect.ArgInfo.__bases__[0].__name__ == 'tuple' — ArgInfo is a simpler NamedTuple with direct tuple inheritance; __bases__[0].__name__ is 'tuple'; verified with Python 3.14.3."
    - "inspect.ArgSpec does not exist in Python 3.14.3 — it was removed in Python 3.11; this spec does not include ArgSpec invariants."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Traceback identity — __name__, __module__, __bases__
#
# inspect.Traceback.__name__ == 'Traceback'  (len 9)
# inspect.Traceback.__module__ == 'inspect'
# inspect.Traceback.__bases__[0].__name__ == '_Traceback'
#
# In Python 3.14.3, inspect.Traceback is a typed NamedTuple. Its __bases__[0]
# is the private _Traceback intermediate class (not 'tuple' directly).
# New to extra186.
# ---------------------------------------------------------------------------

table inspect_extra186.traceback_identity:
  description: "inspect.Traceback.__name__=='Traceback' (len 9); __module__=='inspect'; __bases__[0].__name__=='_Traceback' (private intermediate in Python 3.14.3); new to extra186"
  kind: python_call_eq
  category: identity
  id_prefix: inspectnamedtuple186

  columns: [id, function, args, expected, description]
  rows:
    - [traceback_name_eq,
       Traceback.__name__.__eq__,
       ["Traceback"],
       true,
       "inspect.Traceback.__name__.__eq__('Traceback') == True — the named tuple class for representing tracebacks has __name__ 'Traceback' (9 chars); str.__eq__('Traceback') returns True; new to extra186"]
    - [traceback_name_len_9,
       Traceback.__name__.__len__,
       [],
       9,
       "inspect.Traceback.__name__.__len__() == 9 — the name 'Traceback' has exactly 9 characters: T-r-a-c-e-b-a-c-k; str.__len__() returns 9; new to extra186"]
    - [traceback_module_eq,
       Traceback.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Traceback.__module__.__eq__('inspect') == True — Traceback is defined in the inspect module (Lib/inspect.py); __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra186"]
    - ["traceback_bases0_name_eq",
       "Traceback.__bases__[0].__name__.__eq__",
       ["_Traceback"],
       true,
       "inspect.Traceback.__bases__[0].__name__.__eq__('_Traceback') == True — in Python 3.14.3, Traceback is a typed NamedTuple with private intermediate base _Traceback; __bases__[0].__name__ is '_Traceback' (not 'tuple' directly); str.__eq__('_Traceback') returns True; new to extra186"]

# ---------------------------------------------------------------------------
# Table 2: inspect.FrameInfo identity — __name__, __module__, __bases__
#
# inspect.FrameInfo.__name__ == 'FrameInfo'  (len 9)
# inspect.FrameInfo.__module__ == 'inspect'
# inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo'
#
# FrameInfo follows the same pattern as Traceback: typed NamedTuple with a
# private _FrameInfo intermediate base. New to extra186.
# ---------------------------------------------------------------------------

table inspect_extra186.frameinfo_identity:
  description: "inspect.FrameInfo.__name__=='FrameInfo' (len 9); __module__=='inspect'; __bases__[0].__name__=='_FrameInfo' (private intermediate in Python 3.14.3); new to extra186"
  kind: python_call_eq
  category: identity
  id_prefix: inspectnamedtuple186

  columns: [id, function, args, expected, description]
  rows:
    - [frameinfo_name_eq,
       FrameInfo.__name__.__eq__,
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__name__.__eq__('FrameInfo') == True — the named tuple class representing a frame in the call stack has __name__ 'FrameInfo' (9 chars); str.__eq__('FrameInfo') returns True; new to extra186"]
    - [frameinfo_name_len_9,
       FrameInfo.__name__.__len__,
       [],
       9,
       "inspect.FrameInfo.__name__.__len__() == 9 — the name 'FrameInfo' has exactly 9 characters: F-r-a-m-e-I-n-f-o; str.__len__() returns 9; new to extra186"]
    - [frameinfo_module_eq,
       FrameInfo.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FrameInfo.__module__.__eq__('inspect') == True — FrameInfo is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra186"]
    - ["frameinfo_bases0_name_eq",
       "FrameInfo.__bases__[0].__name__.__eq__",
       ["_FrameInfo"],
       true,
       "inspect.FrameInfo.__bases__[0].__name__.__eq__('_FrameInfo') == True — in Python 3.14.3, FrameInfo is a typed NamedTuple with private intermediate base _FrameInfo; __bases__[0].__name__ is '_FrameInfo'; str.__eq__('_FrameInfo') returns True; new to extra186"]

# ---------------------------------------------------------------------------
# Table 3: inspect.ArgInfo identity — __name__, __module__, __bases__
#
# inspect.ArgInfo.__name__ == 'ArgInfo'  (len 7)
# inspect.ArgInfo.__module__ == 'inspect'
# inspect.ArgInfo.__qualname__ == 'ArgInfo'
# inspect.ArgInfo.__bases__[0].__name__ == 'tuple'
#
# ArgInfo is a simpler NamedTuple that inherits directly from tuple (no private
# intermediate base). Note: ArgSpec was removed in Python 3.11; not included.
# New to extra186.
# ---------------------------------------------------------------------------

table inspect_extra186.arginfo_identity:
  description: "inspect.ArgInfo.__name__=='ArgInfo' (len 7); __module__=='inspect'; __qualname__=='ArgInfo'; __bases__[0].__name__=='tuple' (direct tuple inheritance); new to extra186"
  kind: python_call_eq
  category: identity
  id_prefix: inspectnamedtuple186

  columns: [id, function, args, expected, description]
  rows:
    - [arginfo_name_eq,
       ArgInfo.__name__.__eq__,
       ["ArgInfo"],
       true,
       "inspect.ArgInfo.__name__.__eq__('ArgInfo') == True — the named tuple for argument information has __name__ 'ArgInfo' (7 chars); str.__eq__('ArgInfo') returns True; new to extra186"]
    - [arginfo_name_len_7,
       ArgInfo.__name__.__len__,
       [],
       7,
       "inspect.ArgInfo.__name__.__len__() == 7 — the name 'ArgInfo' has exactly 7 characters: A-r-g-I-n-f-o; str.__len__() returns 7; new to extra186"]
    - [arginfo_module_eq,
       ArgInfo.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ArgInfo.__module__.__eq__('inspect') == True — ArgInfo is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra186"]
    - ["arginfo_bases0_name_eq",
       "ArgInfo.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.ArgInfo.__bases__[0].__name__.__eq__('tuple') == True — ArgInfo is a simpler NamedTuple with direct inheritance from tuple (no private intermediate base); __bases__[0].__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra186"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra186
# ---------------------------------------------------------------------------

invariant inspect_extra186.traceback_name_is_traceback:
  description: "inspect.Traceback.__name__ == 'Traceback' — the named tuple class has __name__ 'Traceback' (9 chars); verified with Python 3.14.3; new to extra186"
  category: identity
  kind: python_call_eq
  function: Traceback.__name__.__eq__
  args: ["Traceback"]
  expected: true

invariant inspect_extra186.traceback_module_is_inspect:
  description: "inspect.Traceback.__module__ == 'inspect' — Traceback is defined in Lib/inspect.py; __module__ is 'inspect'; verified with Python 3.14.3; new to extra186"
  category: identity
  kind: python_call_eq
  function: Traceback.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra186.traceback_bases0_is_private_traceback:
  description: "inspect.Traceback.__bases__[0].__name__ == '_Traceback' — in Python 3.14.3, Traceback is a typed NamedTuple with private intermediate _Traceback base (not 'tuple' directly); verified with Python 3.14.3; new to extra186"
  category: identity
  kind: python_call_eq
  function: "Traceback.__bases__[0].__name__.__eq__"
  args: ["_Traceback"]
  expected: true

invariant inspect_extra186.frameinfo_name_is_frameinfo:
  description: "inspect.FrameInfo.__name__ == 'FrameInfo' — the named tuple class has __name__ 'FrameInfo' (9 chars); verified with Python 3.14.3; new to extra186"
  category: identity
  kind: python_call_eq
  function: FrameInfo.__name__.__eq__
  args: ["FrameInfo"]
  expected: true

invariant inspect_extra186.frameinfo_module_is_inspect:
  description: "inspect.FrameInfo.__module__ == 'inspect' — FrameInfo is defined in Lib/inspect.py; __module__ is 'inspect'; verified with Python 3.14.3; new to extra186"
  category: identity
  kind: python_call_eq
  function: FrameInfo.__module__.__eq__
  args: ["inspect"]
