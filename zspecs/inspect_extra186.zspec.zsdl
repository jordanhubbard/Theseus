invariant inspect_extra186.frameinfo_bases0_is_private_frameinfo:
  description: "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo' — in Python 3.14.3, FrameInfo is a typed NamedTuple with private intermediate _FrameInfo base; __bases__[0].__name__ is '_FrameInfo'; verified with Python 3.14.3; new to extra186"
  category: identity
  kind: python_call_eq
  function: "FrameInfo.__bases__[0].__name__.__eq__"
