invariant inspect_extra186.arginfo_name_is_arginfo:
  description: "inspect.ArgInfo.__name__ == 'ArgInfo' — the named tuple for argument info has __name__ 'ArgInfo' (7 chars); verified with Python 3.14.3; new to extra186"
  category: identity
  kind: python_call_eq
  function: ArgInfo.__name__.__eq__
  args: ["ArgInfo"]
  expected: true

invariant inspect_extra186.arginfo_bases0_is_tuple:
  description: "inspect.ArgInfo.__bases__[0].__name__ == 'tuple' — ArgInfo is a simple NamedTuple with direct inheritance from tuple (no private intermediate base, unlike Traceback/FrameInfo); verified with Python 3.14.3; new to extra186"
  category: identity
  kind: python_call_eq
  function: "ArgInfo.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true

