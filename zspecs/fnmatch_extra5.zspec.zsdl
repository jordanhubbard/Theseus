spec: fnmatch_extra5
version: ">=3.9"
backend: python_module(fnmatch)

docs: https://docs.python.org/3/library/fnmatch.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fnmatch.html — Python fnmatch module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fnmatch.py"
  notes:
    - "This spec extends fnmatch.zspec.zsdl and prior extras."
    - "fnmatch.zspec.zsdl covers: fnmatch star/question/charclass/empty tables; fnmatchcase case table; filter lists table; translate patterns table."
    - "fnmatch_extra.zspec.zsdl covers: module checks (__module__ for all 4); function kind checks; filter_returns_list; filter overlap table; translate_returns_str; fnmatchcase bracket table; fnmatch compound table."
    - "fnmatch_extra2.zspec.zsdl covers: function_names table; function_qualnames table; translate invariants (star_py value, question_mark, literal_string, not_equal_to_input, nonempty); fnmatch/fnmatchcase callable checks."
    - "fnmatch_extra3.zspec.zsdl covers: function_names_direct table; fnmatch.module standalone; translate.returns_str; fnmatch hello.py match; fnmatch HELLO.PY no-match; fnmatchcase uppercase vectors; filter two_py_one_txt."
    - "fnmatch_extra4.zspec.zsdl covers: fnmatch py_vs_txt no-match; fnmatch mixed_case_py_match; fnmatchcase lowercase_vs_upper_pattern; filter hello_world_foo."
    - "This spec adds: translate('*') == '(?s:.*)\\z'; translate('') == '(?s:)\\z'; fnmatch('file.txt', '*.txt') == True (extension match, distinct from prior vectors); fnmatch('', '') == True (empty string matches empty pattern); filter([], '*.py') == [] (empty list input); fnmatchcase('abc', 'abc') == True (exact case-sensitive match)."
    - "translate('*') on Python 3.12 == '(?s:.*)\\z' — the Kleene star becomes '.*' in the regex."
    - "translate('') on Python 3.12 == '(?s:)\\z' — empty pattern becomes an anchored empty regex."
    - "fnmatch('', '') == True — empty filename matches empty pattern via normcase identity on POSIX."
    - "filter([], '*.py') == [] — filtering an empty list always returns an empty list."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# translate('*') and translate('')
# fnmatch_extra2 covers translate('*.py'), translate('?'), translate('hello').
# These two new vectors extend coverage with the pure-wildcard and empty cases.
# ---------------------------------------------------------------------------

invariant fnmatch_extra5.translate.star_only:
  description: "translate('*') == '(?s:.*)\\\\z' — star alone becomes greedy dot-star"
  category: translate
  kind: python_call_eq
  function: translate
  args: ["*"]
  expected: "(?s:.*)\\z"

invariant fnmatch_extra5.translate.empty_pattern:
  description: "translate('') == '(?s:)\\\\z' — empty pattern becomes anchored empty regex"
  category: translate
  kind: python_call_eq
  function: translate
  args: [""]
  expected: "(?s:)\\z"

# ---------------------------------------------------------------------------
# fnmatch('file.txt', '*.txt') == True
# A straightforward extension-match vector using .txt extension.
# fnmatch_extra4 covers py_vs_txt (no-match); this is the corresponding match.
# No prior spec uses 'file.txt' as the filename.
# ---------------------------------------------------------------------------

invariant fnmatch_extra5.fnmatch.txt_extension_match:
  description: "fnmatch('file.txt', '*.txt') == True — star matches any prefix"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["file.txt", "*.txt"]
  expected: true

# ---------------------------------------------------------------------------
# fnmatch('', '') == True
# The empty string matches the empty pattern. No prior spec covers this vector.
# On POSIX, os.path.normcase('') == ''; translate('') anchors both ends; '' matches.
# ---------------------------------------------------------------------------

invariant fnmatch_extra5.fnmatch.empty_matches_empty:
  description: "fnmatch('', '') == True — empty filename matches empty pattern"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["", ""]
  expected: true

# ---------------------------------------------------------------------------
# filter([], '*.py') == []
# Filtering an empty list always returns an empty list regardless of pattern.
# No prior spec passes an empty list to filter.
# ---------------------------------------------------------------------------

invariant fnmatch_extra5.filter.empty_list:
  description: "filter([], '*.py') == [] — empty input always produces empty output"
  category: filter
  kind: python_call_eq
  function: filter
  args: [[], "*.py"]
  expected: []

# ---------------------------------------------------------------------------
# fnmatchcase('abc', 'abc') == True
# Exact case-sensitive match with no wildcards.
# Prior fnmatchcase vectors use mixed-case inputs; this adds the all-lowercase
# exact-match case as a baseline assertion.
# ---------------------------------------------------------------------------

invariant fnmatch_extra5.fnmatchcase.exact_lowercase_match:
  description: "fnmatchcase('abc', 'abc') == True — exact literal case-sensitive match"
  category: fnmatchcase
  kind: python_call_eq
  function: fnmatchcase
  args: ["abc", "abc"]
  expected: true

# ---------------------------------------------------------------------------
# fnmatchcase('abc', 'ABC') == False
# Pattern is all-uppercase; name is all-lowercase; case-sensitive so no match.
# Distinct from prior vectors (those use *.py / *.PY patterns with filenames).
# ---------------------------------------------------------------------------

invariant fnmatch_extra5.fnmatchcase.lower_name_upper_literal_pattern:
  description: "fnmatchcase('abc', 'ABC') == False — case-sensitive exact mismatch"
  category: fnmatchcase
  kind: python_call_eq
  function: fnmatchcase
  args: ["abc", "ABC"]
  expected: false
