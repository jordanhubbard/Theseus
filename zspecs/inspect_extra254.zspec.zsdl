spec: inspect_extra254
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getmembers, inspect.classify_class_attrs, inspect.getattr_static utility function identity and inspect predicate function identity behavioral contracts."
    - "inspect.getmembers.__name__ == 'getmembers' — pure Python utility function; __name__ is 'getmembers'. Verified with Python 3.14.3."
    - "inspect.getmembers.__module__ == 'inspect' — defined in the inspect module; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.getmembers.__class__.__name__ == 'function' — plain Python function; __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__name__ == 'classify_class_attrs' — pure Python utility function; __name__ is 'classify_class_attrs'. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__module__ == 'inspect' — defined in the inspect module; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__class__.__name__ == 'function' — plain Python function. Verified with Python 3.14.3."
    - "inspect.getattr_static.__name__ == 'getattr_static' — pure Python utility; __name__ is 'getattr_static'. Verified with Python 3.14.3."
    - "inspect.getattr_static.__module__ == 'inspect' — defined in the inspect module; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.getattr_static.__class__.__name__ == 'function' — plain Python function. Verified with Python 3.14.3."
    - "All predicate functions (ismethoddescriptor, isdatadescriptor, isgetsetdescriptor, ismemberdescriptor, isroutine) have __name__ and __module__ == 'inspect'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect utility functions identity
#
# inspect.getmembers.__name__ == 'getmembers'
# inspect.getmembers.__module__ == 'inspect'
# inspect.getmembers.__class__.__name__ == 'function'
# inspect.classify_class_attrs.__name__ == 'classify_class_attrs'
# inspect.classify_class_attrs.__module__ == 'inspect'
# inspect.getattr_static.__name__ == 'getattr_static'
# inspect.getattr_static.__module__ == 'inspect'
#
# All three are pure Python functions in the inspect module. New to extra254.
# ---------------------------------------------------------------------------

table inspect_extra254.utility_functions_identity:
  description: "inspect.getmembers, classify_class_attrs, getattr_static __name__, __module__, __class__.__name__ identity contracts; new to extra254"
  kind: python_call_eq
  category: identity
  id_prefix: insputil254

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_name_eq,
       getmembers.__name__.__eq__,
       ["getmembers"],
       true,
       "inspect.getmembers.__name__.__eq__('getmembers') == True — pure Python utility function; __name__ is 'getmembers'; new to extra254"]
    - [getmembers_module_eq,
       getmembers.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getmembers.__module__.__eq__('inspect') == True — defined in the inspect module; __module__ is 'inspect'; new to extra254"]
    - [getmembers_class_eq,
       getmembers.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getmembers.__class__.__name__.__eq__('function') == True — plain Python function; __class__.__name__ is 'function'; new to extra254"]
    - [classify_class_attrs_name_eq,
       classify_class_attrs.__name__.__eq__,
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__name__.__eq__('classify_class_attrs') == True — pure Python utility function; __name__ is 'classify_class_attrs'; new to extra254"]
    - [classify_class_attrs_module_eq,
       classify_class_attrs.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.classify_class_attrs.__module__.__eq__('inspect') == True — defined in the inspect module; __module__ is 'inspect'; new to extra254"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getattr_static identity and classify_class_attrs class name
#
# inspect.getattr_static.__name__ == 'getattr_static'
# inspect.getattr_static.__module__ == 'inspect'
# inspect.getattr_static.__class__.__name__ == 'function'
# inspect.classify_class_attrs.__class__.__name__ == 'function'
#
# New to extra254.
# ---------------------------------------------------------------------------

table inspect_extra254.getattr_static_identity:
  description: "inspect.getattr_static and classify_class_attrs class identity contracts; new to extra254"
  kind: python_call_eq
  category: identity
  id_prefix: inspgas254

  columns: [id, function, args, expected, description]
  rows:
    - [getattr_static_name_eq,
       getattr_static.__name__.__eq__,
       ["getattr_static"],
       true,
       "inspect.getattr_static.__name__.__eq__('getattr_static') == True — pure Python utility; __name__ is 'getattr_static'; new to extra254"]
    - [getattr_static_module_eq,
       getattr_static.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getattr_static.__module__.__eq__('inspect') == True — defined in the inspect module; __module__ is 'inspect'; new to extra254"]
    - [getattr_static_class_eq,
       getattr_static.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getattr_static.__class__.__name__.__eq__('function') == True — plain Python function; __class__.__name__ is 'function'; new to extra254"]
    - [classify_class_attrs_class_eq,
       classify_class_attrs.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.classify_class_attrs.__class__.__name__.__eq__('function') == True — plain Python function; __class__.__name__ is 'function'; new to extra254"]
    - [getmembers_name_len_10,
       getmembers.__name__.__len__,
       [],
       10,
       "inspect.getmembers.__name__.__len__() == 10 — 'getmembers' has 10 characters; new to extra254"]

# ---------------------------------------------------------------------------
# Table 3: inspect predicate functions identity
#
# inspect.ismethoddescriptor.__name__ == 'ismethoddescriptor'
# inspect.ismethoddescriptor.__module__ == 'inspect'
# inspect.isdatadescriptor.__name__ == 'isdatadescriptor'
# inspect.isdatadescriptor.__module__ == 'inspect'
# inspect.isgetsetdescriptor.__name__ == 'isgetsetdescriptor'
# inspect.isgetsetdescriptor.__module__ == 'inspect'
# inspect.ismemberdescriptor.__name__ == 'ismemberdescriptor'
# inspect.ismemberdescriptor.__module__ == 'inspect'
# inspect.isroutine.__name__ == 'isroutine'
# inspect.isroutine.__module__ == 'inspect'
#
# All are pure Python predicate functions in the inspect module. New to extra254.
# ---------------------------------------------------------------------------

table inspect_extra254.predicate_functions_identity:
  description: "inspect descriptor and routine predicate functions __name__ and __module__ identity contracts; new to extra254"
  kind: python_call_eq
  category: identity
  id_prefix: insppred254

  columns: [id, function, args, expected, description]
  rows:
    - [ismethoddescriptor_name_eq,
       ismethoddescriptor.__name__.__eq__,
       ["ismethoddescriptor"],
       true,
       "inspect.ismethoddescriptor.__name__.__eq__('ismethoddescriptor') == True — pure Python predicate; __name__ is 'ismethoddescriptor'; new to extra254"]
    - [ismethoddescriptor_module_eq,
       ismethoddescriptor.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ismethoddescriptor.__module__.__eq__('inspect') == True — defined in the inspect module; __module__ is 'inspect'; new to extra254"]
    - [isdatadescriptor_name_eq,
       isdatadescriptor.__name__.__eq__,
       ["isdatadescriptor"],
       true,
       "inspect.isdatadescriptor.__name__.__eq__('isdatadescriptor') == True — pure Python predicate; __name__ is 'isdatadescriptor'; new to extra254"]
    - [isdatadescriptor_module_eq,
       isdatadescriptor.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isdatadescriptor.__module__.__eq__('inspect') == True — defined in the inspect module; __module__ is 'inspect'; new to extra254"]
    - [isgetsetdescriptor_name_eq,
       isgetsetdescriptor.__name__.__eq__,
       ["isgetsetdescriptor"],
       true,
       "inspect.isgetsetdescriptor.__name__.__eq__('isgetsetdescriptor') == True — pure Python predicate; __name__ is 'isgetsetdescriptor'; new to extra254"]

# ---------------------------------------------------------------------------
