table inspect_extra254.ismemberdescriptor_isroutine_identity:
  description: "inspect.ismemberdescriptor and isroutine __name__, __module__ identity contracts; new to extra254"
  kind: python_call_eq
  category: identity
  id_prefix: inspmr254

  columns: [id, function, args, expected, description]
  rows:
    - [ismemberdescriptor_name_eq,
       ismemberdescriptor.__name__.__eq__,
       ["ismemberdescriptor"],
       true,
       "inspect.ismemberdescriptor.__name__.__eq__('ismemberdescriptor') == True — pure Python predicate; __name__ is 'ismemberdescriptor'; new to extra254"]
    - [ismemberdescriptor_module_eq,
       ismemberdescriptor.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ismemberdescriptor.__module__.__eq__('inspect') == True — defined in the inspect module; __module__ is 'inspect'; new to extra254"]
    - [isroutine_name_eq,
       isroutine.__name__.__eq__,
       ["isroutine"],
       true,
       "inspect.isroutine.__name__.__eq__('isroutine') == True — pure Python predicate; __name__ is 'isroutine'; new to extra254"]
    - [isroutine_module_eq,
       isroutine.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isroutine.__module__.__eq__('inspect') == True — defined in the inspect module; __module__ is 'inspect'; new to extra254"]
    - [isgetsetdescriptor_module_eq,
       isgetsetdescriptor.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isgetsetdescriptor.__module__.__eq__('inspect') == True — defined in the inspect module; __module__ is 'inspect'; new to extra254"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra254
# ---------------------------------------------------------------------------

invariant inspect_extra254.getmembers.name_eq:
  description: "inspect.getmembers.__name__ == 'getmembers' — pure Python utility function; new to extra254"
  category: identity
  kind: python_call_eq
  function: getmembers.__name__.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra254.getmembers.module_eq:
  description: "inspect.getmembers.__module__ == 'inspect' — defined in the inspect module; new to extra254"
  category: identity
  kind: python_call_eq
  function: getmembers.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra254.getmembers.class_is_function:
  description: "inspect.getmembers.__class__.__name__ == 'function' — plain Python function; new to extra254"
  category: identity
  kind: python_call_eq
  function: getmembers.__class__.__name__.__eq__
  args: ["function"]
  expected: true

