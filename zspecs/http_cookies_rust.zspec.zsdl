spec: http_cookies_rust
version: ">=3.9"
backend: rust_module(http_cookies_rust)

docs: https://docs.python.org/3/library/http.cookies.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.cookies.html — Python http.cookies documentation"
  not_derived_from:
    - "CPython source: Lib/http/cookies.py"
  notes:
    - "Clean-room Rust reimplementation of Python http.cookies.SimpleCookie, exposed via PyO3."
    - "SimpleCookie(string) parses an HTTP cookie string into a dict-like object."
    - "SimpleCookie('k=v').__len__() == 1 — one cookie in the string."
    - "SimpleCookie('k=v').__contains__('k') == True — key present."
    - "SimpleCookie('k=v').__contains__('z') == False — missing key."
    - "SimpleCookie('a=1; b=2').__len__() == 2 — two cookies."
    - "SimpleCookie('').__len__() == 0 — empty string parses to empty cookie."
    - "All test vectors verified against Python 3.14.3 http.cookies module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# SimpleCookie — construction and length
invariant http_cookies_rust.SimpleCookie.len_single:
  description: "SimpleCookie('k=v').__len__() == 1"
  category: SimpleCookie
  kind: python_call_eq
  function: SimpleCookie
  args: ["k=v"]
  method: __len__
  expected: 1

invariant http_cookies_rust.SimpleCookie.len_two:
  description: "SimpleCookie('a=1; b=2').__len__() == 2"
  category: SimpleCookie
  kind: python_call_eq
  function: SimpleCookie
  args: ["a=1; b=2"]
  method: __len__
  expected: 2

invariant http_cookies_rust.SimpleCookie.len_empty:
  description: "SimpleCookie('').__len__() == 0"
  category: SimpleCookie
  kind: python_call_eq
  function: SimpleCookie
  args: [""]
  method: __len__
  expected: 0

# SimpleCookie — key presence tests
invariant http_cookies_rust.SimpleCookie.contains_key:
  description: "SimpleCookie('k=v').__contains__('k') == True"
  category: SimpleCookie
  kind: python_call_eq
  function: SimpleCookie
  args: ["k=v"]
  method: __contains__
  method_args: ["k"]
  expected: true

invariant http_cookies_rust.SimpleCookie.contains_missing:
  description: "SimpleCookie('k=v').__contains__('z') == False"
  category: SimpleCookie
  kind: python_call_eq
  function: SimpleCookie
  args: ["k=v"]
  method: __contains__
  method_args: ["z"]
  expected: false

invariant http_cookies_rust.SimpleCookie.contains_second_key:
  description: "SimpleCookie('a=1; b=2').__contains__('b') == True"
  category: SimpleCookie
  kind: python_call_eq
  function: SimpleCookie
  args: ["a=1; b=2"]
  method: __contains__
  method_args: ["b"]
  expected: true

