spec: urllib_parse_extra3
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
  notes:
    - "This spec extends prior urllib_parse specs."
    - "Focus: ParseResult, SplitResult class names; urlencode, urljoin, urldefrag, parse_qs behavior."
    - "urllib.parse.urlparse('http://example.com/path?q=1#frag').__class__.__name__ == 'ParseResult'."
    - "urllib.parse.ParseResult.__name__ == 'ParseResult'."
    - "urllib.parse.SplitResult.__name__ == 'SplitResult'."
    - "urllib.parse.urljoin('http://base.com/', 'path') == 'http://base.com/path'."
    - "urllib.parse.urldefrag('http://example.com#frag').url == 'http://example.com'."
    - "urllib.parse.urldefrag('http://example.com#frag').fragment == 'frag'."
    - "urllib.parse.parse_qs('a=1&b=2') == {'a': ['1'], 'b': ['2']}."
    - "urllib.parse.parse_qsl('a=1&b=2') == [('a', '1'), ('b', '2')]."
    - "urllib.parse.urlencode({'a': 1}) == 'a=1'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table urllib_parse_extra3.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [ParseResult, ParseResult.__name__.__eq__, ["ParseResult"], true]
    - [SplitResult, SplitResult.__name__.__eq__, ["SplitResult"], true]

table urllib_parse_extra3.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [urljoin,    urljoin.__name__.__eq__,    ["urljoin"],    true]
    - [urldefrag,  urldefrag.__name__.__eq__,  ["urldefrag"],  true]
    - [parse_qs,   parse_qs.__name__.__eq__,   ["parse_qs"],   true]
    - [parse_qsl,  parse_qsl.__name__.__eq__,  ["parse_qsl"],  true]
    - [urlencode,  urlencode.__name__.__eq__,  ["urlencode"],  true]
    - [urlunsplit, urlunsplit.__name__.__eq__, ["urlunsplit"], true]
    - [urlunparse, urlunparse.__name__.__eq__, ["urlunparse"], true]

invariant urllib_parse_extra3.urlparse.class_name:
  description: "urllib.parse.urlparse('http://example.com/path').__class__.__name__ == 'ParseResult'"
  category: urlparse
  kind: python_call_eq
  function: urlparse
  args: ["http://example.com/path"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["ParseResult"]
  expected: true

invariant urllib_parse_extra3.urlparse.scheme:
  description: "urllib.parse.urlparse('http://example.com/path').scheme == 'http'"
  category: urlparse
  kind: python_call_eq
  function: urlparse
  args: ["http://example.com/path"]
  method: scheme.__eq__
  method_args: ["http"]
  expected: true

invariant urllib_parse_extra3.urlparse.netloc:
  description: "urllib.parse.urlparse('http://example.com/path').netloc == 'example.com'"
  category: urlparse
  kind: python_call_eq
  function: urlparse
  args: ["http://example.com/path"]
  method: netloc.__eq__
  method_args: ["example.com"]
  expected: true

invariant urllib_parse_extra3.urlparse.path:
  description: "urllib.parse.urlparse('http://example.com/path').path == '/path'"
  category: urlparse
  kind: python_call_eq
  function: urlparse
  args: ["http://example.com/path"]
  method: path.__eq__
  method_args: ["/path"]
  expected: true

invariant urllib_parse_extra3.urljoin.basic:
  description: "urllib.parse.urljoin('http://base.com/', 'path') == 'http://base.com/path'"
  category: urljoin
  kind: python_call_eq
  function: urljoin
  args: ["http://base.com/", "path"]
  expected: "http://base.com/path"

invariant urllib_parse_extra3.urlencode.single:
  description: "urllib.parse.urlencode({'a': 1}) == 'a=1'"
  category: urlencode
  kind: python_call_eq
  function: urlencode
  args: [{a: 1}]
  expected: "a=1"

invariant urllib_parse_extra3.quote.basic:
  description: "urllib.parse.quote('hello world') == 'hello%20world'"
  category: quote
  kind: python_call_eq
  function: quote
  args: ["hello world"]
  expected: "hello%20world"

invariant urllib_parse_extra3.unquote.basic:
  description: "urllib.parse.unquote('hello%20world') == 'hello world'"
  category: unquote
  kind: python_call_eq
  function: unquote
  args: ["hello%20world"]
  expected: "hello world"
