spec: abc_extra2041
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2041): __lshift__, __rshift__, __and__, __or__, __xor__, __invert__ dict-presence checks."
    - "abc.ABCMeta is a metaclass; abc.ABC is a helper base class; abc.abstractmethod is a decorator."
    - "None of these abc constructs define bit-shift, bitwise AND/OR/XOR, or bitwise NOT protocols in their own __dict__."
    - "ABCMeta does define some special methods but none related to bitwise arithmetic."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra2041.lshift_protocol:
  description: "abc.ABCMeta, abc.ABC, abc.abstractmethod __lshift__/__rlshift__/__ilshift__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2041

  columns: [id, function, args, expected]
  rows:
    - ["ab2041001", "abc.ABCMeta.__dict__.__contains__", ["__lshift__"], false]
    - ["ab2041002", "abc.ABCMeta.__dict__.__contains__", ["__rlshift__"], false]
    - ["ab2041003", "abc.ABCMeta.__dict__.__contains__", ["__ilshift__"], false]
    - ["ab2041004", "abc.ABC.__dict__.__contains__", ["__lshift__"], false]
    - ["ab2041005", "abc.ABC.__dict__.__contains__", ["__rlshift__"], false]
    - ["ab2041006", "abc.ABC.__dict__.__contains__", ["__ilshift__"], false]
    - ["ab2041007", "abc.abstractmethod.__dict__.__contains__", ["__lshift__"], false]
    - ["ab2041008", "abc.abstractmethod.__dict__.__contains__", ["__rlshift__"], false]
    - ["ab2041009", "abc.abstractmethod.__dict__.__contains__", ["__ilshift__"], false]

