spec: concurrent_futures_extra3
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Extends concurrent_futures.zspec.zsdl, concurrent_futures_extra.zspec.zsdl, concurrent_futures_extra2.zspec.zsdl."
    - "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor' (Python >= 3.9 added it as a public name)."
    - "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'."
    - "concurrent.futures.CancelledError.__name__ == 'CancelledError'."
    - "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base'."
    - "concurrent.futures.TimeoutError.__name__ == 'TimeoutError'."
    - "concurrent.futures.TimeoutError.__module__ == 'concurrent.futures._base'."
    - "concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError'."
    - "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'."
    - "concurrent.futures.Executor.__name__ == 'Executor'."
    - "concurrent.futures.Executor.__module__ == 'concurrent.futures._base'."
    - "concurrent.futures.Executor.submit.__name__ == 'submit' — abstract method on Executor."
    - "BrokenExecutor is a subclass of RuntimeError."
    - "CancelledError is a subclass of concurrent.futures base error hierarchy."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BrokenExecutor — class name and module (Python >= 3.9)
#
# concurrent.futures.BrokenExecutor is a RuntimeError subclass raised when
# a worker pool becomes non-functional. It is defined in _base.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra3.BrokenExecutor.name:
  description: "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor'"
  category: exception_classes
  kind: python_call_eq
  function: BrokenExecutor.__name__.__eq__
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra3.BrokenExecutor.module:
  description: "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'"
  category: exception_classes
  kind: python_call_eq
  function: BrokenExecutor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra3.BrokenExecutor.base_is_RuntimeError:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: BrokenExecutor.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "RuntimeError"

# ---------------------------------------------------------------------------
# CancelledError — class name and module
#
# concurrent.futures.CancelledError is re-exported from _base. It represents
# a future that was cancelled before completing.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra3.CancelledError.name:
  description: "concurrent.futures.CancelledError.__name__ == 'CancelledError'"
  category: exception_classes
  kind: python_call_eq
  function: CancelledError.__name__.__eq__
  args: ["CancelledError"]
  expected: true

invariant concurrent_futures_extra3.CancelledError.module:
  description: "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base'"
  category: exception_classes
  kind: python_call_eq
  function: CancelledError.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

# ---------------------------------------------------------------------------
# TimeoutError — class name and module
#
# concurrent.futures.TimeoutError is re-exported from _base. It is raised
# when a future does not complete within the specified timeout.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra3.TimeoutError.name:
  description: "concurrent.futures.TimeoutError.__name__ == 'TimeoutError'"
  category: exception_classes
  kind: python_call_eq
  function: TimeoutError.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant concurrent_futures_extra3.TimeoutError.module:
  description: "concurrent.futures.TimeoutError.__module__ == 'concurrent.futures._base'"
  category: exception_classes
  kind: python_call_eq
  function: TimeoutError.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

# ---------------------------------------------------------------------------
# InvalidStateError — class name and module
#
# concurrent.futures.InvalidStateError is raised when a Future is put into
# an invalid state (e.g., setting a result on an already-finished future).
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra3.InvalidStateError.name:
  description: "concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError'"
  category: exception_classes
  kind: python_call_eq
  function: InvalidStateError.__name__.__eq__
  args: ["InvalidStateError"]
  expected: true

invariant concurrent_futures_extra3.InvalidStateError.module:
  description: "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'"
  category: exception_classes
  kind: python_call_eq
  function: InvalidStateError.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

# ---------------------------------------------------------------------------
# Executor — class name and module
#
# concurrent.futures.Executor is the abstract base class for all executor
# types. It is defined in concurrent.futures._base.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra3.Executor.name:
  description: "concurrent.futures.Executor.__name__ == 'Executor'"
  category: executor_class
  kind: python_call_eq
  function: Executor.__name__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra3.Executor.module:
  description: "concurrent.futures.Executor.__module__ == 'concurrent.futures._base'"
  category: executor_class
  kind: python_call_eq
  function: Executor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra3.Executor.qualname:
  description: "concurrent.futures.Executor.__qualname__ == 'Executor' — top-level class"
  category: executor_class
  kind: python_call_eq
  function: Executor.__qualname__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra3.Executor.base_is_object:
  description: "concurrent.futures.Executor.__bases__[0].__name__ == 'object' — Executor inherits from object"
  category: executor_class
  kind: python_call_eq
  function: Executor.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# Executor.submit — method name
#
# Executor.submit is an abstract method that subclasses must implement.
# We confirm its __name__ is 'submit'.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra3.Executor.submit_name:
  description: "concurrent.futures.Executor.submit.__name__ == 'submit'"
  category: executor_methods
  kind: python_call_eq
  function: Executor.submit.__name__.__eq__
  args: ["submit"]
  expected: true

# ---------------------------------------------------------------------------
# Executor.map and Executor.shutdown — additional method names
#
# Executor defines map() and shutdown() as concrete methods with default
# implementations that rely on submit().
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra3.Executor.map_name:
  description: "concurrent.futures.Executor.map.__name__ == 'map'"
  category: executor_methods
  kind: python_call_eq
  function: Executor.map.__name__.__eq__
  args: ["map"]
  expected: true

invariant concurrent_futures_extra3.Executor.shutdown_name:
  description: "concurrent.futures.Executor.shutdown.__name__ == 'shutdown'"
  category: executor_methods
  kind: python_call_eq
  function: Executor.shutdown.__name__.__eq__
  args: ["shutdown"]
  expected: true
