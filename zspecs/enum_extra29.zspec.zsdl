spec: enum_extra29
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum_extra28.zspec.zsdl."
    - "Focus: combined __module__ table for Enum/IntEnum/StrEnum; base class names for IntEnum and StrEnum; Enum.__init_subclass__.__qualname__; unique.__qualname__ and __module__ in the extra29 namespace."
    - "enum_extra28 covers EnumMeta.__qualname__ == 'EnumType'; member/nonmember __qualname__ table; combined __module__ table for Flag/auto/member/nonmember; EnumMeta.__bases__[0].__name__ == 'type'."
    - "enum_extra27 covers Enum._generate_next_value_/__qualname__, Enum._missing_/__qualname__, and combined class qualnames for IntEnum/IntFlag/Flag/StrEnum/auto/unique/EnumType."
    - "enum_extra21 covers combined __qualname__.__eq__ table for Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique and EnumMeta.__qualname__ standalone."
    - "No prior enum spec records a combined __module__.__eq__ table for Enum/IntEnum/StrEnum together in the extra29 namespace."
    - "No prior enum spec records IntEnum.__bases__[0].__name__ == 'int' and IntEnum.__bases__[1].__name__ == 'ReprEnum' in a combined table."
    - "No prior enum spec records StrEnum.__bases__[0].__name__ == 'str' and StrEnum.__bases__[1].__name__ == 'ReprEnum' in a combined table."
    - "No prior enum spec records Enum.__init_subclass__.__qualname__ == 'Enum.__init_subclass__' in any invariant or table."
    - "No prior enum spec records unique.__qualname__ == 'unique' or unique.__module__ == 'enum' as standalone invariants in the extra29 namespace."
    - "IntEnum inherits from (int, ReprEnum); StrEnum inherits from (str, ReprEnum); Enum inherits from (object,)."
    - "Enum.__init_subclass__.__qualname__ == 'Enum.__init_subclass__' — len 22."
    - "unique is a decorator function with __qualname__ == 'unique' and __module__ == 'enum'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# enum.Enum, IntEnum, StrEnum __module__ values — combined table
#
# Enum, IntEnum, and StrEnum are all defined in the 'enum' module.
# No prior enum spec has all three together in a combined __module__ table
# in the extra29 namespace.
# ---------------------------------------------------------------------------

table enum_extra29.class_modules:
  description: "__module__.__eq__ for enum.Enum, IntEnum, StrEnum — Python 3.11+"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Enum,    Enum.__module__.__eq__,    ["enum"], true]
    - [IntEnum, IntEnum.__module__.__eq__, ["enum"], true]
    - [StrEnum, StrEnum.__module__.__eq__, ["enum"], true]

# ---------------------------------------------------------------------------
# enum.Enum, IntEnum, StrEnum __module__.__len__() — combined table
#
# All three __module__ strings equal 'enum' which has length 4.
# No prior enum spec collects these three module name lengths together
# in a single combined table in the extra29 namespace.
# ---------------------------------------------------------------------------

table enum_extra29.class_module_lens:
  description: "__module__.__len__() for enum.Enum, IntEnum, StrEnum — Python 3.11+"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [Enum,    Enum.__module__.__len__,    [], 4]
    - [IntEnum, IntEnum.__module__.__len__, [], 4]
    - [StrEnum, StrEnum.__module__.__len__, [], 4]

# ---------------------------------------------------------------------------
# enum.IntEnum base class names — combined table
#
# IntEnum.__bases__ == (int, ReprEnum).
# No prior enum spec records IntEnum.__bases__[0].__name__ or
# IntEnum.__bases__[1].__name__ in any invariant or combined table.
# ---------------------------------------------------------------------------

table enum_extra29.IntEnum_base_names:
  description: "IntEnum.__bases__ base class names — int and ReprEnum"
  kind: python_call_eq
  category: class_attrs
  id_prefix: base_name

  columns: [id, function, args, expected]
  rows:
    - [base0, "IntEnum.__bases__[0].__name__.__eq__", ["int"],      true]
    - [base1, "IntEnum.__bases__[1].__name__.__eq__", ["ReprEnum"], true]

# ---------------------------------------------------------------------------
# enum.StrEnum base class names — combined table
#
# StrEnum.__bases__ == (str, ReprEnum).
# No prior enum spec records StrEnum.__bases__[0].__name__ or
# StrEnum.__bases__[1].__name__ in any invariant or combined table.
# ---------------------------------------------------------------------------

table enum_extra29.StrEnum_base_names:
  description: "StrEnum.__bases__ base class names — str and ReprEnum"
  kind: python_call_eq
  category: class_attrs
  id_prefix: base_name

  columns: [id, function, args, expected]
  rows:
    - [base0, "StrEnum.__bases__[0].__name__.__eq__", ["str"],      true]
    - [base1, "StrEnum.__bases__[1].__name__.__eq__", ["ReprEnum"], true]

# ---------------------------------------------------------------------------
# enum.Enum.__init_subclass__.__qualname__ == 'Enum.__init_subclass__'
#
# Enum defines __init_subclass__ as a classmethod; its __qualname__ is
# 'Enum.__init_subclass__'. No prior enum spec records this attribute in
# any invariant or table.
# ---------------------------------------------------------------------------

invariant enum_extra29.Enum.init_subclass_qualname:
  description: "enum.Enum.__init_subclass__.__qualname__ == 'Enum.__init_subclass__' — classmethod qualname includes class prefix"
  category: method_qualnames
  kind: python_call_eq
  function: Enum.__init_subclass__.__qualname__.__eq__
  args: ["Enum.__init_subclass__"]
  expected: true

# ---------------------------------------------------------------------------
# len(enum.Enum.__init_subclass__.__qualname__) == 22 — standalone invariant
#
# len('Enum.__init_subclass__') == 22.
# No prior enum spec records this length in any invariant.
# ---------------------------------------------------------------------------

invariant enum_extra29.Enum.init_subclass_qualname_len:
  description: "len(enum.Enum.__init_subclass__.__qualname__) == 22 — len('Enum.__init_subclass__') == 22"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Enum.__init_subclass__.__qualname__.__len__
  args: []
  expected: 22

# ---------------------------------------------------------------------------
# enum.unique.__qualname__ == 'unique' — standalone invariant
#
# unique is a module-level decorator function; its __qualname__ equals 'unique'.
# No prior enum spec records unique.__qualname__ as a standalone invariant
# in the extra29 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra29.unique.qualname:
  description: "enum.unique.__qualname__ == 'unique' — decorator defined at module level"
  category: function_qualnames
  kind: python_call_eq
  function: unique.__qualname__.__eq__
  args: ["unique"]
  expected: true

# ---------------------------------------------------------------------------
# enum.unique.__module__ == 'enum' — standalone invariant
#
# No prior enum spec records unique.__module__ as a standalone invariant
# in the extra29 namespace (enum_extra27 covers unique in qualname tables only).
# ---------------------------------------------------------------------------

invariant enum_extra29.unique.module:
  description: "enum.unique.__module__ == 'enum' — unique decorator is defined in the enum module"
  category: module_attrs
  kind: python_call_eq
  function: unique.__module__.__eq__
  args: ["enum"]
  expected: true
