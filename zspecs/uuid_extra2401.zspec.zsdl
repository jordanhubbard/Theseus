spec: uuid_extra2401
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid_extra2401: __hash__ and __eq__ implementation type classification for uuid.UUID and uuid.SafeUUID."
    - "uuid.UUID defines its own __hash__ and __eq__ as pure-Python functions — both are 'function' at the class level."
    - "uuid.UUID.__dict__.__contains__('__hash__') and '__eq__' are both True — UUID overrides both in its class body."
    - "uuid.SafeUUID is a plain Enum (not IntEnum). It inherits __hash__ from Enum.__hash__ which is a 'function'; its __eq__ is a 'wrapper_descriptor' inherited from object."
    - "uuid.SafeUUID does NOT define __hash__ or __eq__ in its own __dict__ — both SafeUUID.__dict__.__contains__ checks return False."
    - "All expected values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra2401.uuid_hash_eq_class_name:
  description: "uuid.UUID.__hash__ and uuid.UUID.__eq__ are pure-Python functions — class name is 'function', not 'wrapper_descriptor'"
  kind: python_call_eq
  category: hash_eq_classification
  id_prefix: uu2401uh

  columns: [id, function, args, expected]
  rows:
    - ["uu2401001", "uuid.UUID.__hash__.__class__.__name__.__eq__", ["function"],           true]
    - ["uu2401002", "uuid.UUID.__eq__.__class__.__name__.__eq__",   ["function"],           true]
    - ["uu2401003", "uuid.UUID.__hash__.__class__.__name__.__eq__", ["wrapper_descriptor"], false]
    - ["uu2401004", "uuid.UUID.__eq__.__class__.__name__.__eq__",   ["wrapper_descriptor"], false]
    - ["uu2401005", "uuid.UUID.__hash__.__class__.__name__.__eq__", ["method-wrapper"],     false]
    - ["uu2401006", "uuid.UUID.__eq__.__class__.__name__.__eq__",   ["method-wrapper"],     false]

table uuid_extra2401.uuid_dict_contains:
  description: "uuid.UUID.__dict__.__contains__ returns true for __hash__ and __eq__ — UUID defines both in its own class body"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2401ud

  columns: [id, function, args, expected]
  rows:
    - ["uu2401007", "uuid.UUID.__dict__.__contains__", ["__hash__"],  true]
    - ["uu2401008", "uuid.UUID.__dict__.__contains__", ["__eq__"],    true]
    - ["uu2401009", "uuid.UUID.__dict__.__contains__", ["__init__"],  true]
    - ["uu2401010", "uuid.UUID.__dict__.__contains__", ["__str__"],   true]

table uuid_extra2401.safeuuid_hash_eq_class_name:
  description: "uuid.SafeUUID inherits __hash__ from Enum (a 'function') and __eq__ from object (a 'wrapper_descriptor')"
  kind: python_call_eq
  category: hash_eq_classification
  id_prefix: uu2401sh

  columns: [id, function, args, expected]
  rows:
    - ["uu2401011", "uuid.SafeUUID.__hash__.__class__.__name__.__eq__", ["function"],           true]
    - ["uu2401012", "uuid.SafeUUID.__eq__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true]
    - ["uu2401013", "uuid.SafeUUID.__hash__.__class__.__name__.__eq__", ["wrapper_descriptor"], false]
    - ["uu2401014", "uuid.SafeUUID.__eq__.__class__.__name__.__eq__",   ["function"],           false]

table uuid_extra2401.safeuuid_dict_contains:
  description: "uuid.SafeUUID.__dict__.__contains__ returns false for __hash__ and __eq__ — SafeUUID does not define either in its own class body"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2401sd

  columns: [id, function, args, expected]
  rows:
    - ["uu2401015", "uuid.SafeUUID.__dict__.__contains__", ["__hash__"], false]
    - ["uu2401016", "uuid.SafeUUID.__dict__.__contains__", ["__eq__"],   false]

table uuid_extra2401.uuid_dict_class_name:
  description: "uuid.UUID.__dict__ is a mappingproxy — its __class__.__name__ is 'mappingproxy'"
  kind: python_call_eq
  category: dict_type
  id_prefix: uu2401dc

  columns: [id, function, args, expected]
  rows:
    - ["uu2401017", "uuid.UUID.__dict__.__class__.__name__.__eq__",     ["mappingproxy"], true]
    - ["uu2401018", "uuid.UUID.__dict__.__contains__",                  ["int"],          false]
    - ["uu2401019", "uuid.UUID.__dict__.__contains__",                  ["__repr__"],     true]
    - ["uu2401020", "uuid.SafeUUID.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
