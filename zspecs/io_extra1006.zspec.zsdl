spec: io_extra1006
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module TextIOWrapper, BufferedReader, BufferedWriter documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks io.TextIOWrapper, io.BufferedReader, and io.BufferedWriter method qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1006.textiowrapper_qualnames:
  description: "io.TextIOWrapper method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: io1006x
  columns: [id, function, args, expected]
  rows:
    - [io1006x001, io.TextIOWrapper.read.__qualname__.__eq__,     ["TextIOWrapper.read"],     true]
    - [io1006x002, io.TextIOWrapper.write.__qualname__.__eq__,    ["TextIOWrapper.write"],    true]
    - [io1006x003, io.TextIOWrapper.readline.__qualname__.__eq__,  ["TextIOWrapper.readline"], true]
    - [io1006x004, io.TextIOWrapper.seek.__qualname__.__eq__,     ["TextIOWrapper.seek"],     true]
    - [io1006x005, io.TextIOWrapper.tell.__qualname__.__eq__,     ["TextIOWrapper.tell"],     true]
    - [io1006x006, io.TextIOWrapper.flush.__qualname__.__eq__,    ["TextIOWrapper.flush"],    true]
    - [io1006x007, io.TextIOWrapper.close.__qualname__.__eq__,    ["TextIOWrapper.close"],    true]

table io_extra1006.bufferedreader_qualnames:
