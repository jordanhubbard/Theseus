  rows:
    - [io1006w001, io.BufferedWriter.write.__qualname__.__eq__,    ["BufferedWriter.write"],    true]
    - [io1006w002, io.BufferedWriter.flush.__qualname__.__eq__,    ["BufferedWriter.flush"],    true]
