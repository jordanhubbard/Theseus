  rows:
    - [io1006r001, io.BufferedReader.read.__qualname__.__eq__,     ["BufferedReader.read"],     true]
    - [io1006r002, io.BufferedReader.readline.__qualname__.__eq__,  ["BufferedReader.readline"], true]
    - [io1006r003, io.BufferedReader.read1.__qualname__.__eq__,    ["BufferedReader.read1"],    true]
    - [io1006r004, io.BufferedReader.peek.__qualname__.__eq__,     ["BufferedReader.peek"],     true]
    - [io1006r005, io.BufferedReader.seek.__qualname__.__eq__,     ["BufferedReader.seek"],     true]

table io_extra1006.bufferedwriter_qualnames:
  description: "io.BufferedWriter method __qualname__ identity"
  kind: python_call_eq
