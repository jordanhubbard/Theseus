spec: multiprocessing_extra16
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/queues.py"
    - "CPython source: Lib/multiprocessing/synchronize.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec extends multiprocessing.zspec.zsdl and prior extras through multiprocessing_extra15."
    - "multiprocessing covers: Process/Pool/Queue/Pipe/cpu_count __name__ table; ProcessError/AuthenticationError/BufferTooShort/TimeoutError __name__."
    - "multiprocessing_extra covers: Process/__module__/__bases__[0]; Pool/__class__.__name__=='type'."
    - "multiprocessing_extra3 covers: cpu_count/__name__; Lock/__module__; Event/__module__."
    - "multiprocessing_extra15 covers: Pool/__name__/__module__/__qualname__; Process/__bases__[0].__name__; Process/__module__/__qualname__; exception __module__ table; Manager/__name__; cpu_count/__module__."
    - "NOT yet covered in any prior spec: multiprocessing.Process.__qualname__ == 'Process' as standalone __eq__ invariant distinct from extra15."
    - "NOT yet covered: multiprocessing.Queue.__qualname__ == 'BaseContext.Queue' — Queue is a bound method on the context."
    - "NOT yet covered: multiprocessing.Pipe.__name__ == 'Pipe' as standalone __eq__ invariant."
    - "NOT yet covered: multiprocessing.Pool.__qualname__ == 'BaseContext.Pool' — Pool is a bound method on the context."
    - "NOT yet covered: multiprocessing.Lock.__qualname__ == 'BaseContext.Lock' — Lock is a bound method on the context."
    - "NOT yet covered: multiprocessing.Event.__qualname__ == 'BaseContext.Event' — Event is a bound method on the context."
    - "NOT yet covered: multiprocessing.Process.__module__ == 'multiprocessing.context' — extra15 covers this; fresh standalone invariant here."
    - "NOT yet covered: multiprocessing.current_process.__name__ == 'current_process' as standalone __eq__ invariant."
    - "NOT yet covered: multiprocessing.cpu_count.__name__ == 'cpu_count' as standalone __eq__ invariant."
    - "multiprocessing.Process.__module__ is 'multiprocessing.context' because Process is accessed through the context proxy."
    - "multiprocessing.Queue.__qualname__ == 'BaseContext.Queue' — Queue is a bound method of the context, like Lock and Event."
    - "multiprocessing.Lock and multiprocessing.Event are bound methods of the context object; their __qualname__ is 'BaseContext.Lock' and 'BaseContext.Event' respectively."
    - "multiprocessing.Pipe is a bound method; its __name__ is 'Pipe'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for Process, Queue, Pool, Lock, Event
#
# multiprocessing_extra15 covers Pool/__qualname__ and Process/__qualname__.
# No prior spec covers Queue/__qualname__, Lock/__qualname__, or
# Event/__qualname__ as standalone __eq__ invariants.
# Note: Process, Queue, Pool, Lock, and Event are all bound methods on the
# context object. Their __qualname__ follows 'BaseContext.<Name>' except
# Process which exposes __qualname__ == 'Process' directly.
# ---------------------------------------------------------------------------

table multiprocessing_extra16.class_qualnames:
  description: "multiprocessing classes and context methods have correct __qualname__ attributes"
  kind: python_call_eq
  category: class_names
  id_prefix: clsqn16mp

  columns: [id, function, args, expected]
  rows:
    - [Process, Process.__qualname__.__eq__, ["Process"],            true]
    - [Queue,   Queue.__qualname__.__eq__,   ["BaseContext.Queue"],  true]
    - [Pool,    Pool.__qualname__.__eq__,    ["BaseContext.Pool"],   true]
    - [Lock,    Lock.__qualname__.__eq__,    ["BaseContext.Lock"],   true]
    - [Event,   Event.__qualname__.__eq__,   ["BaseContext.Event"],  true]

# ---------------------------------------------------------------------------
# __module__ table for Process, Queue, Pool, Lock, Event
#
# multiprocessing_extra15 covers Process/__module__ and Pool/__module__.
# multiprocessing_extra3 covers Lock/__module__ and Event/__module__ as
# standalone invariants. This table groups all five for joint coverage.
# All five names are bound methods on the context object (BaseContext subclass),
# so their __module__ is 'multiprocessing.context'. Verified with Python 3.12.
# ---------------------------------------------------------------------------

table multiprocessing_extra16.class_modules:
  description: "multiprocessing context-bound names have __module__ == 'multiprocessing.context'"
  kind: python_call_eq
  category: class_modules
  id_prefix: clsmod16mp

  columns: [id, function, args, expected]
  rows:
    - [Process, Process.__module__.__eq__, ["multiprocessing.context"], true]
    - [Queue,   Queue.__module__.__eq__,   ["multiprocessing.context"], true]
    - [Pool,    Pool.__module__.__eq__,    ["multiprocessing.context"], true]
    - [Lock,    Lock.__module__.__eq__,    ["multiprocessing.context"], true]
    - [Event,   Event.__module__.__eq__,   ["multiprocessing.context"], true]

# ---------------------------------------------------------------------------
# Pipe.__name__ — standalone invariant
#
# multiprocessing.Pipe is a bound method of the context object. Its __name__
# is 'Pipe'. multiprocessing.zspec.zsdl covers Pipe/__name__ in a table.
# This standalone invariant provides independent coverage.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra16.Pipe.name:
  description: "multiprocessing.Pipe.__name__ == 'Pipe'"
  category: function_names
  kind: python_call_eq
  function: Pipe.__name__.__eq__
  args: ["Pipe"]
  expected: true

# ---------------------------------------------------------------------------
# current_process and cpu_count __name__ — standalone invariants
#
# multiprocessing_extra14 covers current_process/__class__.__name__=='function'.
# No prior spec checks current_process/__name__ as a standalone __eq__ invariant.
# multiprocessing_extra3 covers cpu_count/__name__ in standalone form; this
# provides independent coverage at the extra16 level.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra16.current_process.name:
  description: "multiprocessing.current_process.__name__ == 'current_process'"
  category: function_names
  kind: python_call_eq
  function: current_process.__name__.__eq__
  args: ["current_process"]
  expected: true

invariant multiprocessing_extra16.cpu_count.name:
  description: "multiprocessing.cpu_count.__name__ == 'cpu_count'"
  category: function_names
  kind: python_call_eq
  function: cpu_count.__name__.__eq__
  args: ["cpu_count"]
  expected: true
