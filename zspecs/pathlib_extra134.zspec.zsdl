spec: pathlib_extra134
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path method __code__.co_varnames[1] (second parameter names) for chmod, rename, replace, symlink_to, hardlink_to, touch, and unlink."
    - "pathlib.Path.chmod.__code__.co_varnames[1] = 'mode' (len=4); co_argcount=2 (self, mode; follow_symlinks is keyword-only)."
    - "pathlib.Path.rename.__code__.co_varnames[1] = 'target' (len=6); co_argcount=2 (self, target)."
    - "pathlib.Path.replace.__code__.co_varnames[1] = 'target' (len=6); co_argcount=2 (self, target)."
    - "pathlib.Path.symlink_to.__code__.co_varnames[1] = 'target' (len=6); co_argcount=3 (self, target, target_is_directory)."
    - "pathlib.Path.hardlink_to.__code__.co_varnames[1] = 'target' (len=6); co_argcount=2 (self, target)."
    - "pathlib.Path.touch.__code__.co_varnames[1] = 'mode' (len=4); co_argcount=3 (self, mode, exist_ok)."
    - "pathlib.Path.unlink.__code__.co_varnames[1] = 'missing_ok' (len=10); co_argcount=2 (self, missing_ok)."
    - "rename, replace, symlink_to, and hardlink_to all use 'target' as their second parameter name (len=6)."
    - "chmod and touch both use 'mode' as their second parameter name (len=4)."
    - "unlink is the outlier with 'missing_ok' (len=10), the longest second-parameter name in this spec."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.chmod and pathlib.Path.touch co_varnames[1]
# chmod.__code__.co_varnames[1] == 'mode' (len 4); co_argcount == 2.
# touch.__code__.co_varnames[1] == 'mode' (len 4); co_argcount == 3.
# Both use 'mode' as the second parameter.
# ---------------------------------------------------------------------------

table pathlib_extra134.Path_chmod_touch_co_varnames1:
  description: "pathlib.Path.chmod and .touch __code__.co_varnames[1]: both == 'mode' (len 4)"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibcv1_134

  columns: [id, function, args, expected, description]
  rows:
    - [chmod_cv1_eq,    "Path.chmod.__code__.co_varnames[1].__eq__",    ["mode"],  true,  "Path.chmod.__code__.co_varnames[1] == 'mode' (len=4; the permission mode bits to set on the file)"]
    - [chmod_cv1_len,   "Path.chmod.__code__.co_varnames[1].__len__",   [],        4,     "Path.chmod.__code__.co_varnames[1].__len__() == 4 ('mode' has 4 characters)"]
    - [chmod_argc,      Path.chmod.__code__.co_argcount.__eq__,         [2], true,        "Path.chmod.__code__.co_argcount == 2 (self, mode; follow_symlinks is keyword-only)"]
    - [touch_cv1_eq,    "Path.touch.__code__.co_varnames[1].__eq__",    ["mode"],  true,  "Path.touch.__code__.co_varnames[1] == 'mode' (len=4; the permission mode for newly created files)"]
    - [touch_cv1_len,   "Path.touch.__code__.co_varnames[1].__len__",   [],        4,     "Path.touch.__code__.co_varnames[1].__len__() == 4 ('mode' has 4 characters; same as chmod co_varnames[1])"]
    - [touch_argc,      Path.touch.__code__.co_argcount.__eq__,         [3], true,        "Path.touch.__code__.co_argcount == 3 (self, mode, exist_ok)"]
    - [chmod_touch_match, "Path.chmod.__code__.co_varnames[1].__eq__",  ["mode"],  true,  "Path.chmod co_varnames[1] == Path.touch co_varnames[1] == 'mode' (both use the same second param name)"]

# ---------------------------------------------------------------------------
# pathlib.Path.rename, .replace, .symlink_to, .hardlink_to co_varnames[1]
# All four methods use 'target' as the second parameter (len 6).
# rename co_argcount==2, replace co_argcount==2, symlink_to co_argcount==3,
# hardlink_to co_argcount==2.
# ---------------------------------------------------------------------------

table pathlib_extra134.Path_target_methods_co_varnames1:
  description: "pathlib.Path rename, replace, symlink_to, hardlink_to all have co_varnames[1] == 'target' (len 6)"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibcv1_134

  columns: [id, function, args, expected, description]
  rows:
    - [rename_cv1_eq,    "Path.rename.__code__.co_varnames[1].__eq__",      ["target"], true, "Path.rename.__code__.co_varnames[1] == 'target' (len=6; the destination path to rename to)"]
    - [rename_cv1_len,   "Path.rename.__code__.co_varnames[1].__len__",     [],         6,    "Path.rename.__code__.co_varnames[1].__len__() == 6 ('target' has 6 characters)"]
    - [rename_argc,      Path.rename.__code__.co_argcount.__eq__,           [2], true,        "Path.rename.__code__.co_argcount == 2 (self, target)"]
    - [replace_cv1_eq,   "Path.replace.__code__.co_varnames[1].__eq__",     ["target"], true, "Path.replace.__code__.co_varnames[1] == 'target' (len=6; same as rename; replace() atomically replaces the destination)"]
    - [replace_cv1_len,  "Path.replace.__code__.co_varnames[1].__len__",    [],         6,    "Path.replace.__code__.co_varnames[1].__len__() == 6 ('target' has 6 characters; tied with rename)"]
    - [symlink_cv1_eq,   "Path.symlink_to.__code__.co_varnames[1].__eq__",  ["target"], true, "Path.symlink_to.__code__.co_varnames[1] == 'target' (len=6; the path the symlink should point to)"]
    - [symlink_cv1_len,  "Path.symlink_to.__code__.co_varnames[1].__len__", [],         6,    "Path.symlink_to.__code__.co_varnames[1].__len__() == 6 ('target' has 6 characters)"]
    - [hardlink_cv1_eq,  "Path.hardlink_to.__code__.co_varnames[1].__eq__", ["target"], true, "Path.hardlink_to.__code__.co_varnames[1] == 'target' (len=6; the existing path to hard-link to)"]
    - [hardlink_cv1_len, "Path.hardlink_to.__code__.co_varnames[1].__len__",[], 6,            "Path.hardlink_to.__code__.co_varnames[1].__len__() == 6 ('target' has 6 characters; all four target-methods tied at 6)"]

# ---------------------------------------------------------------------------
# pathlib.Path.unlink co_varnames[1] and comparison across methods
# unlink.__code__.co_varnames[1] == 'missing_ok' (len 10).
# 'missing_ok' is the longest second-parameter name among Path methods in this spec.
# ---------------------------------------------------------------------------

table pathlib_extra134.Path_unlink_co_varnames1_and_comparisons:
  description: "pathlib.Path.unlink co_varnames[1] == 'missing_ok' (len 10) — the longest second-parameter name in this spec"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibcv1_134

  columns: [id, function, args, expected, description]
  rows:
    - [unlink_cv1_eq,    "Path.unlink.__code__.co_varnames[1].__eq__",  ["missing_ok"], true,  "Path.unlink.__code__.co_varnames[1] == 'missing_ok' (len=10; if True, do not raise if file does not exist)"]
    - [unlink_cv1_len,   "Path.unlink.__code__.co_varnames[1].__len__", [],             10,    "Path.unlink.__code__.co_varnames[1].__len__() == 10 ('missing_ok' has 10 characters; longest second-param in spec)"]
    - [unlink_argc,      Path.unlink.__code__.co_argcount.__eq__,       [2], true,             "Path.unlink.__code__.co_argcount == 2 (self, missing_ok)"]
    - [unlink_not_mode,  "Path.unlink.__code__.co_varnames[1].__eq__",  ["mode"],       false, "Path.unlink co_varnames[1] != 'mode' (unlink has no mode; it uses 'missing_ok' instead)"]
    - [unlink_not_target,"Path.unlink.__code__.co_varnames[1].__eq__",  ["target"],     false, "Path.unlink co_varnames[1] != 'target' (unlink does not take a target path)"]
    - [mode_len_4,       "Path.chmod.__code__.co_varnames[1].__len__",  [],             4,     "Path.chmod co_varnames[1] len==4 ('mode') < rename co_varnames[1] len==6 ('target') < unlink co_varnames[1] len==10 ('missing_ok')"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra134.Path.chmod_co_varnames1_is_mode:
  description: "pathlib.Path.chmod.__code__.co_varnames[1] == 'mode' (the second parameter of chmod is 'mode', representing the integer permission bits to apply to the file)"
  category: code_attrs
  kind: python_call_eq
  function: Path.chmod.__code__.co_varnames.__getitem__
  args: [1]
  expected: "mode"

invariant pathlib_extra134.Path.rename_co_varnames1_is_target:
  description: "pathlib.Path.rename.__code__.co_varnames[1] == 'target' (the second parameter of rename is 'target', the destination path; rename, replace, symlink_to, and hardlink_to all use 'target' as their second parameter)"
  category: code_attrs
  kind: python_call_eq
  function: Path.rename.__code__.co_varnames.__getitem__
  args: [1]
  expected: "target"

invariant pathlib_extra134.Path.replace_co_varnames1_is_target:
  description: "pathlib.Path.replace.__code__.co_varnames[1] == 'target' (the second parameter of replace is 'target'; replace() differs from rename() in that it atomically overwrites the destination if it already exists)"
  category: code_attrs
  kind: python_call_eq
  function: Path.replace.__code__.co_varnames.__getitem__
  args: [1]
  expected: "target"

invariant pathlib_extra134.Path.unlink_co_varnames1_is_missing_ok:
  description: "pathlib.Path.unlink.__code__.co_varnames[1] == 'missing_ok' (the second parameter of unlink; if True, no error is raised when the file does not exist; 'missing_ok' has 10 characters, the longest second-parameter name among Path methods in this spec)"
  category: code_attrs
  kind: python_call_eq
  function: Path.unlink.__code__.co_varnames.__getitem__
  args: [1]
  expected: "missing_ok"

invariant pathlib_extra134.Path.symlink_to_co_varnames1_is_target:
  description: "pathlib.Path.symlink_to.__code__.co_varnames[1] == 'target' (the path the symlink should point to; symlink_to has co_argcount==3 because it also has target_is_directory at position 2)"
  category: code_attrs
  kind: python_call_eq
  function: Path.symlink_to.__code__.co_varnames.__getitem__
  args: [1]
  expected: "target"

