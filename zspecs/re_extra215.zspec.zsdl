spec: re_extra215
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "re_extra214.zspec.zsdl — covers re class __qualname__ attribute checks"
  notes:
    - "re.compile.__doc__ == 'Compile a regular expression pattern, returning a Pattern object.'; confirmed Python 3.14.3 macOS."
    - "re.match.__doc__ starts with 'Try to apply the pattern at the start of the string'; confirmed Python 3.14.3 macOS."
    - "re.search.__doc__ starts with 'Scan through string looking for a match to the pattern'; confirmed Python 3.14.3 macOS."
    - "re.findall.__doc__ starts with 'Return a list of all non-overlapping matches in the string.'; confirmed Python 3.14.3 macOS."
    - "re.sub.__doc__ starts with 'Return the string obtained by replacing the leftmost'; confirmed Python 3.14.3 macOS."
    - "re.Pattern.__doc__ == 'Compiled regular expression object.'; confirmed Python 3.14.3 macOS."
    - "re.Match.__doc__ starts with 'The result of re.match() and re.search().'; confirmed Python 3.14.3 macOS."
    - "re.search.__doc__.__contains__('search') == False; the word 'search' does not appear in search's doc text; confirmed Python 3.14.3 macOS."
    - "re.sub.__doc__.__contains__('sub') == False; the word 'sub' does not appear in sub's doc text; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __doc__ contains checks for re.compile, re.match, re.Pattern
# compile, match, and Pattern __doc__ string substring membership checks
# ---------------------------------------------------------------------------

table re_extra215.compile_match_pattern_doc_contains:
  description: "re.compile, re.match, and re.Pattern __doc__ string contains expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: redoccontains215

  columns: [id, function, args, expected, description]
  rows:
    - [compile_doc_contains_pattern,   re.compile.__doc__.__contains__,  ["pattern"],          true,  "re.compile.__doc__.__contains__('pattern') == True; doc says 'Compile a regular expression pattern'; confirmed Python 3.14.3 macOS"]
    - [compile_doc_contains_Pattern,   re.compile.__doc__.__contains__,  ["Pattern"],          true,  "re.compile.__doc__.__contains__('Pattern') == True; doc says 'returning a Pattern object'; confirmed Python 3.14.3 macOS"]
    - [match_doc_contains_match,       re.match.__doc__.__contains__,    ["match"],            true,  "re.match.__doc__.__contains__('match') == True; doc mentions 'a Match object'; confirmed Python 3.14.3 macOS"]
    - [match_doc_contains_string,      re.match.__doc__.__contains__,    ["string"],           true,  "re.match.__doc__.__contains__('string') == True; doc mentions applying pattern at start of the string; confirmed Python 3.14.3 macOS"]
    - [pattern_doc_contains_Compiled,  re.Pattern.__doc__.__contains__,  ["Compiled"],         true,  "re.Pattern.__doc__.__contains__('Compiled') == True; doc says 'Compiled regular expression object'; confirmed Python 3.14.3 macOS"]
    - [pattern_doc_contains_regular_expression, re.Pattern.__doc__.__contains__, ["regular expression"], true, "re.Pattern.__doc__.__contains__('regular expression') == True; doc describes it as a compiled regular expression; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: __doc__ contains checks for re.search, re.findall, re.sub
# search, findall, and sub __doc__ string substring membership checks
# ---------------------------------------------------------------------------

table re_extra215.search_findall_sub_doc_contains:
  description: "re.search, re.findall, and re.sub __doc__ string contains expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: redoccontains215

  columns: [id, function, args, expected, description]
  rows:
    - [search_doc_contains_Scan,          re.search.__doc__.__contains__,  ["Scan"],           true,  "re.search.__doc__.__contains__('Scan') == True; doc starts with 'Scan through string'; confirmed Python 3.14.3 macOS"]
    - [search_doc_contains_string,        re.search.__doc__.__contains__,  ["string"],         true,  "re.search.__doc__.__contains__('string') == True; doc mentions scanning through string; confirmed Python 3.14.3 macOS"]
    - [search_doc_contains_Match,         re.search.__doc__.__contains__,  ["Match"],          true,  "re.search.__doc__.__contains__('Match') == True; doc says 'returning a Match object'; confirmed Python 3.14.3 macOS"]
    - [findall_doc_contains_list,         re.findall.__doc__.__contains__,  ["list"],           true,  "re.findall.__doc__.__contains__('list') == True; doc says 'Return a list of all non-overlapping matches'; confirmed Python 3.14.3 macOS"]
    - [findall_doc_contains_non_overlapping, re.findall.__doc__.__contains__, ["non-overlapping"], true, "re.findall.__doc__.__contains__('non-overlapping') == True; doc mentions non-overlapping matches; confirmed Python 3.14.3 macOS"]
    - [sub_doc_contains_string,           re.sub.__doc__.__contains__,     ["string"],         true,  "re.sub.__doc__.__contains__('string') == True; doc describes returning a modified string; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: __doc__ contains checks for re.sub and re.Match
# sub (repl keyword) and Match class __doc__ substring membership checks
# ---------------------------------------------------------------------------

table re_extra215.sub_match_doc_contains:
  description: "re.sub and re.Match __doc__ string contains expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: redoccontains215

  columns: [id, function, args, expected, description]
  rows:
    - [sub_doc_contains_pattern,   re.sub.__doc__.__contains__,   ["pattern"],  true,  "re.sub.__doc__.__contains__('pattern') == True; doc mentions the pattern parameter; confirmed Python 3.14.3 macOS"]
    - [sub_doc_contains_repl,      re.sub.__doc__.__contains__,   ["repl"],     true,  "re.sub.__doc__.__contains__('repl') == True; doc describes replacing occurrences using repl; confirmed Python 3.14.3 macOS"]
    - [sub_doc_contains_Return,    re.sub.__doc__.__contains__,   ["Return"],   true,  "re.sub.__doc__.__contains__('Return') == True; doc starts with 'Return the string obtained by replacing'; confirmed Python 3.14.3 macOS"]
    - [match_doc_contains_Match,   re.Match.__doc__.__contains__,  ["Match"],   true,  "re.Match.__doc__.__contains__('Match') == True; doc says 'The result of re.match() and re.search()'; confirmed Python 3.14.3 macOS"]
    - [match_doc_contains_boolean, re.Match.__doc__.__contains__,  ["boolean"], true,  "re.Match.__doc__.__contains__('boolean') == True; doc says 'always have a boolean value of True'; confirmed Python 3.14.3 macOS"]
    - [findall_doc_contains_Return, re.findall.__doc__.__contains__, ["Return"], true, "re.findall.__doc__.__contains__('Return') == True; doc starts with 'Return a list'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra215.compile_doc_contains_pattern:
  description: "re.compile.__doc__.__contains__('pattern') == True — compile doc says 'Compile a regular expression pattern'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.compile.__doc__.__contains__
  args: ["pattern"]
  expected: true

invariant re_extra215.compile_doc_contains_Pattern:
  description: "re.compile.__doc__.__contains__('Pattern') == True — compile doc says 'returning a Pattern object'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.compile.__doc__.__contains__
  args: ["Pattern"]
  expected: true

invariant re_extra215.match_doc_contains_match:
  description: "re.match.__doc__.__contains__('match') == True — match doc mentions 'a Match object'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.match.__doc__.__contains__
  args: ["match"]
  expected: true

invariant re_extra215.search_doc_contains_Scan:
  description: "re.search.__doc__.__contains__('Scan') == True — search doc starts with 'Scan through string'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.search.__doc__.__contains__
  args: ["Scan"]
  expected: true

invariant re_extra215.findall_doc_contains_non_overlapping:
  description: "re.findall.__doc__.__contains__('non-overlapping') == True — findall doc mentions non-overlapping matches; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.findall.__doc__.__contains__
  args: ["non-overlapping"]
  expected: true

invariant re_extra215.sub_doc_contains_repl:
  description: "re.sub.__doc__.__contains__('repl') == True — sub doc describes replacing occurrences using repl; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.sub.__doc__.__contains__
  args: ["repl"]
  expected: true

invariant re_extra215.pattern_doc_contains_Compiled:
  description: "re.Pattern.__doc__.__contains__('Compiled') == True — Pattern doc says 'Compiled regular expression object'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__doc__.__contains__
  args: ["Compiled"]
  expected: true

invariant re_extra215.match_doc_contains_boolean:
  description: "re.Match.__doc__.__contains__('boolean') == True — Match doc says 'always have a boolean value of True'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Match.__doc__.__contains__
  args: ["boolean"]
  expected: true
