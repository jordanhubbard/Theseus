spec: inspect_extra209
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra.zspec.zsdl — covers __name__ checks for ismethod/isgenerator/iscoroutine/getsourcefile; __module__ checks for public inspect functions; isclass/isbuiltin/isfunction behavioral checks; Parameter and Signature __name__ checks"
    - "inspect_extra2.zspec.zsdl — covers earlier __annotations__ and __dict__ checks"
  notes:
    - "inspect.signature.__annotations__.__class__.__name__ == 'dict' — signature is a Python function; its __annotations__ attribute is an empty dict. Verified with Python 3.14.3."
    - "inspect.getmembers.__annotations__.__class__.__name__ == 'dict' — getmembers is a Python function; its __annotations__ attribute is an empty dict. Verified with Python 3.14.3."
    - "inspect.Signature.__dict__.__contains__('parameters') == True — Signature defines 'parameters' as a property descriptor in its class dict. Verified with Python 3.14.3."
    - "inspect.Signature.__dict__.__contains__('return_annotation') == True — Signature defines 'return_annotation' as a property descriptor. Verified with Python 3.14.3."
    - "inspect.Signature.__dict__.__contains__('bind') == True — Signature defines 'bind' as a method in its class dict. Verified with Python 3.14.3."
    - "inspect.Parameter.__dict__.__contains__('default') == True — Parameter defines 'default' as a property descriptor in its class dict. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __annotations__.__class__.__name__ for signature and getmembers
#
# Both are Python-level functions whose __annotations__ is an empty dict.
#
# inspect.signature.__annotations__.__class__.__name__   == 'dict'
# inspect.getmembers.__annotations__.__class__.__name__  == 'dict'
# ---------------------------------------------------------------------------

table inspect_extra209.annotations_class_names:
  description: "inspect signature/getmembers __annotations__.__class__.__name__ checks in inspectannotations209 namespace — signature is a Python function whose __annotations__ is an empty dict (class 'dict'); getmembers is a Python function whose __annotations__ is also an empty dict; both functions lack type annotations on their parameters; __annotations__.__class__.__name__.__eq__('dict')==True for each; negative cross-checks confirm not 'set' or 'list'; verified with Python 3.14.3"
  kind: python_call_eq
  category: annotations
  id_prefix: inspectannotations209

  columns: [id, function, args, expected, description]
  rows:
    - [signature_ann_cls,
       signature.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "inspect.signature.__annotations__.__class__.__name__ == 'dict' — signature is a Python-defined function; its __annotations__ is an empty dict; __class__.__name__ is 'dict'; __eq__('dict') returns True; verified with Python 3.14.3"]
    - [getmembers_ann_cls,
       getmembers.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "inspect.getmembers.__annotations__.__class__.__name__ == 'dict' — getmembers is a Python-defined function; its __annotations__ is an empty dict; __class__.__name__ is 'dict'; __eq__('dict') returns True; verified with Python 3.14.3"]
    - [signature_ann_not_set,
       signature.__annotations__.__class__.__name__.__eq__,
       ["set"],
       false,
       "inspect.signature.__annotations__.__class__.__name__.__eq__('set') == False — __annotations__ is a dict, not a set; __eq__('set') returns False; negative cross-check; verified with Python 3.14.3"]
    - [getmembers_ann_not_list,
       getmembers.__annotations__.__class__.__name__.__eq__,
       ["list"],
       false,
       "inspect.getmembers.__annotations__.__class__.__name__.__eq__('list') == False — __annotations__ is a dict, not a list; __eq__('list') returns False; negative cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature.__dict__ membership checks
#
# Signature defines 'parameters', 'return_annotation', and 'bind' as
# entries in its class dict.
#
# inspect.Signature.__dict__.__contains__('parameters')        == True
# inspect.Signature.__dict__.__contains__('return_annotation') == True
# inspect.Signature.__dict__.__contains__('bind')              == True
# ---------------------------------------------------------------------------

table inspect_extra209.signature_dict_contains:
  description: "inspect.Signature.__dict__ membership checks in inspectannotations209 namespace — Signature defines 'parameters' as a property descriptor; 'return_annotation' as a property descriptor; 'bind' as a method; all three are present in Signature.__dict__; __dict__.__contains__('parameters')==True; __dict__.__contains__('return_annotation')==True; __dict__.__contains__('bind')==True; negative: __dict__.__contains__('nonexistent')==False; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: inspectannotations209s

  columns: [id, function, args, expected, description]
  rows:
    - [sig_dict_has_parameters,
       "Signature.__dict__.__contains__",
       ["parameters"],
       true,
       "inspect.Signature.__dict__.__contains__('parameters') == True — Signature defines 'parameters' as a property descriptor in its class dict; 'parameters' gives the ordered mapping of parameter names to Parameter objects; __contains__('parameters') returns True; verified with Python 3.14.3"]
    - [sig_dict_has_return_annotation,
       "Signature.__dict__.__contains__",
       ["return_annotation"],
       true,
       "inspect.Signature.__dict__.__contains__('return_annotation') == True — Signature defines 'return_annotation' as a property descriptor in its class dict; it holds the annotation for the function's return value; __contains__('return_annotation') returns True; verified with Python 3.14.3"]
    - [sig_dict_has_bind,
       "Signature.__dict__.__contains__",
       ["bind"],
       true,
       "inspect.Signature.__dict__.__contains__('bind') == True — Signature defines 'bind' as a method in its class dict; bind() maps *args and **kwargs to the signature's parameters; __contains__('bind') returns True; verified with Python 3.14.3"]
    - [sig_dict_no_nonexistent,
       "Signature.__dict__.__contains__",
       ["nonexistent"],
       false,
       "inspect.Signature.__dict__.__contains__('nonexistent') == False — 'nonexistent' is not defined on Signature; __contains__('nonexistent') returns False; negative cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter.__dict__ membership checks
#
# Parameter defines 'default' as a property in its class dict.
# Also checks for other well-known Parameter attributes.
#
# inspect.Parameter.__dict__.__contains__('default')     == True
# inspect.Parameter.__dict__.__contains__('kind')        == True
# inspect.Parameter.__dict__.__contains__('annotation')  == True
# ---------------------------------------------------------------------------

table inspect_extra209.parameter_dict_contains:
  description: "inspect.Parameter.__dict__ membership checks in inspectannotations209 namespace — Parameter defines 'default' as a property descriptor (holds the parameter's default value or Parameter.empty); 'kind' as a property descriptor (one of the POSITIONAL_ONLY/POSITIONAL_OR_KEYWORD/etc constants); 'annotation' as a property descriptor; all present in Parameter.__dict__; negative: 'bind' is a Signature method, not a Parameter attribute; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: inspectannotations209p

  columns: [id, function, args, expected, description]
  rows:
    - [param_dict_has_default,
       "Parameter.__dict__.__contains__",
       ["default"],
       true,
       "inspect.Parameter.__dict__.__contains__('default') == True — Parameter defines 'default' as a property descriptor in its class dict; default holds the parameter's default value or Parameter.empty if there is none; __contains__('default') returns True; verified with Python 3.14.3"]
    - [param_dict_has_kind,
       "Parameter.__dict__.__contains__",
       ["kind"],
       true,
       "inspect.Parameter.__dict__.__contains__('kind') == True — Parameter defines 'kind' as a property descriptor in its class dict; kind indicates the parameter's category (POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD); __contains__('kind') returns True; verified with Python 3.14.3"]
    - [param_dict_has_annotation,
       "Parameter.__dict__.__contains__",
       ["annotation"],
       true,
       "inspect.Parameter.__dict__.__contains__('annotation') == True — Parameter defines 'annotation' as a property descriptor in its class dict; annotation holds the type annotation for the parameter or Parameter.empty; __contains__('annotation') returns True; verified with Python 3.14.3"]
    - [param_dict_no_bind,
       "Parameter.__dict__.__contains__",
       ["bind"],
       false,
       "inspect.Parameter.__dict__.__contains__('bind') == False — 'bind' is a method on Signature, not on Parameter; Parameter.__dict__ does not contain 'bind'; __contains__('bind') returns False; negative cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra209
# ---------------------------------------------------------------------------

invariant inspect_extra209.signature_annotations_class_dict:
  description: "inspect.signature.__annotations__.__class__.__name__ == 'dict' — signature is a Python-defined function; its __annotations__ attribute is an empty dict; __class__.__name__ is 'dict'; new to extra209; verified with Python 3.14.3"
  category: annotations
  kind: python_call_eq
  function: signature.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant inspect_extra209.getmembers_annotations_class_dict:
  description: "inspect.getmembers.__annotations__.__class__.__name__ == 'dict' — getmembers is a Python-defined function; its __annotations__ attribute is an empty dict; __class__.__name__ is 'dict'; new to extra209; verified with Python 3.14.3"
  category: annotations
  kind: python_call_eq
  function: getmembers.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant inspect_extra209.Signature_dict_has_parameters:
  description: "inspect.Signature.__dict__.__contains__('parameters') == True — Signature defines 'parameters' as a property descriptor in its class dict; __contains__('parameters') returns True; new to extra209; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Signature.__dict__.__contains__"
  args: ["parameters"]
  expected: true

invariant inspect_extra209.Signature_dict_has_return_annotation:
  description: "inspect.Signature.__dict__.__contains__('return_annotation') == True — Signature defines 'return_annotation' as a property descriptor in its class dict; __contains__('return_annotation') returns True; new to extra209; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Signature.__dict__.__contains__"
  args: ["return_annotation"]
  expected: true

invariant inspect_extra209.Signature_dict_has_bind:
  description: "inspect.Signature.__dict__.__contains__('bind') == True — Signature defines 'bind' as a method in its class dict; bind() performs parameter binding for *args/**kwargs; __contains__('bind') returns True; new to extra209; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Signature.__dict__.__contains__"
  args: ["bind"]
  expected: true

invariant inspect_extra209.Parameter_dict_has_default:
  description: "inspect.Parameter.__dict__.__contains__('default') == True — Parameter defines 'default' as a property descriptor; 'default' holds the parameter's default value or Parameter.empty; __contains__('default') returns True; new to extra209; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Parameter.__dict__.__contains__"
  args: ["default"]
  expected: true

invariant inspect_extra209.signature_ann_not_none:
  description: "inspect.signature.__annotations__.__class__.__name__ != 'NoneType' — __annotations__ is always a dict (never None) on Python functions; __eq__('NoneType') returns False; cross-check; new to extra209; verified with Python 3.14.3"
  category: annotations
  kind: python_call_eq
  function: signature.__annotations__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: false

invariant inspect_extra209.Parameter_dict_no_bind:
  description: "inspect.Parameter.__dict__.__contains__('bind') == False — 'bind' is a Signature method, not a Parameter attribute; Parameter.__dict__ does not contain 'bind'; __contains__('bind') returns False; negative cross-check; new to extra209; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Parameter.__dict__.__contains__"
  args: ["bind"]
  expected: false

