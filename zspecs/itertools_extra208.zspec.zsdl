spec: itertools_extra208
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "Python itertools documentation — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools_extra207.zspec.zsdl — covers co_flags, co_stacksize, and co_filename checks for itertools classes"
    - "itertools_extra.zspec.zsdl — covers filterfalse, chain, repeat, and islice length hints and first elements"
  notes:
    - "itertools.islice.__doc__.__contains__('None') == False — the islice docstring does not contain the string 'None'; it uses 'zero' and 'stop' rather than None. Verified with Python 3.14.3."
    - "itertools.product.__doc__.__len__() == 681 — the product docstring is 681 characters long. Verified with Python 3.14.3."
    - "itertools.combinations.__doc__.__len__() == 134 — the combinations docstring is 134 characters long. Verified with Python 3.14.3."
    - "itertools.permutations.__doc__.__len__() == 140 — the permutations docstring is 140 characters long. Verified with Python 3.14.3."
    - "itertools.accumulate.__doc__.__len__() == 69 — the accumulate docstring is 69 characters long. Verified with Python 3.14.3."
    - "itertools.groupby.__doc__.__len__() == 323 — the groupby docstring is 323 characters long. Verified with Python 3.14.3."
    - "itertools.dropwhile.__doc__.__len__() == 126 — the dropwhile docstring is 126 characters long. Verified with Python 3.14.3."
    - "itertools.takewhile.__doc__.__len__() == 101 — the takewhile docstring is 101 characters long. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __doc__.__len__() for itertools classes — combinations/permutations group
#
# These four itertools types have short docstrings describing their purpose.
# combinations doc length == 134
# permutations doc length == 140
# accumulate doc length == 69
# groupby doc length == 323
# ---------------------------------------------------------------------------

table itertools_extra208.doc_len_combinatoric:
  description: "__doc__.__len__() exact character counts for combinatoric and aggregating itertools classes; combinations=134, permutations=140, accumulate=69, groupby=323; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc_content
  id_prefix: iterdoc208

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_doc_len,
       "combinations.__doc__.__len__",
       [],
       134,
       "itertools.combinations.__doc__.__len__() == 134 — the combinations docstring is 134 characters long describing r-length tuples from the input iterable; str.__len__() returns 134; new to extra208"]
    - [permutations_doc_len,
       "permutations.__doc__.__len__",
       [],
       140,
       "itertools.permutations.__doc__.__len__() == 140 — the permutations docstring is 140 characters long describing r-length permutations from the input iterable; str.__len__() returns 140; new to extra208"]
    - [accumulate_doc_len,
       "accumulate.__doc__.__len__",
       [],
       69,
       "itertools.accumulate.__doc__.__len__() == 69 — the accumulate docstring is 69 characters long describing the return of accumulated sums or binary function results; str.__len__() returns 69; new to extra208"]
    - [groupby_doc_len,
       "groupby.__doc__.__len__",
       [],
       323,
       "itertools.groupby.__doc__.__len__() == 323 — the groupby docstring is 323 characters long describing consecutive grouping of elements by a key function; str.__len__() returns 323; new to extra208"]

# ---------------------------------------------------------------------------
# Table 2: __doc__.__len__() for filter-style itertools classes
#
# dropwhile and takewhile have short docstrings describing predicate-based
# iteration behavior.
# dropwhile doc length == 126
# takewhile doc length == 101
# product doc length == 681
# ---------------------------------------------------------------------------

table itertools_extra208.doc_len_filter:
  description: "__doc__.__len__() exact character counts for filter-style itertools classes and product; dropwhile=126, takewhile=101, product=681; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc_content
  id_prefix: iterdoc208

  columns: [id, function, args, expected, description]
  rows:
    - [dropwhile_doc_len,
       "dropwhile.__doc__.__len__",
       [],
       126,
       "itertools.dropwhile.__doc__.__len__() == 126 — the dropwhile docstring is 126 characters long describing dropping elements while a predicate is true; str.__len__() returns 126; new to extra208"]
    - [takewhile_doc_len,
       "takewhile.__doc__.__len__",
       [],
       101,
       "itertools.takewhile.__doc__.__len__() == 101 — the takewhile docstring is 101 characters long describing yielding elements while a predicate is true; str.__len__() returns 101; new to extra208"]
    - [product_doc_len,
       "product.__doc__.__len__",
       [],
       681,
       "itertools.product.__doc__.__len__() == 681 — the product docstring is 681 characters long, the longest of the itertools docstrings checked here, describing Cartesian product behavior; str.__len__() returns 681; new to extra208"]
    - [islice_doc_not_contains_None,
       "islice.__doc__.__contains__",
       ["None"],
       false,
       "itertools.islice.__doc__.__contains__('None') == False — the islice docstring uses 'zero' for the default start value rather than the string 'None'; str.__contains__('None') returns False; new to extra208"]

# ---------------------------------------------------------------------------
# Table 3: __doc__.__contains__ content checks for itertools classes
#
# These checks verify that specific keywords appear (or do not appear) in
# the docstrings of itertools classes.
# islice doc contains 'zero' == True (describes default start value)
# accumulate doc contains 'sums' == True
# groupby doc contains 'key' == True
# combinations doc contains 'sorted' == True
# ---------------------------------------------------------------------------

table itertools_extra208.doc_contains:
  description: "__doc__.__contains__ keyword presence checks for itertools classes; islice contains 'zero', accumulate contains 'sums', groupby contains 'key', combinations contains 'sorted'; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc_content
  id_prefix: iterdoc208

  columns: [id, function, args, expected, description]
  rows:
    - [islice_doc_contains_zero,
       "islice.__doc__.__contains__",
       ["zero"],
       true,
       "itertools.islice.__doc__.__contains__('zero') == True — the islice docstring says 'start defaults to zero' describing the default start index; str.__contains__('zero') returns True; new to extra208"]
    - [accumulate_doc_contains_sums,
       "accumulate.__doc__.__contains__",
       ["sums"],
       true,
       "itertools.accumulate.__doc__.__contains__('sums') == True — the accumulate docstring says 'Return series of accumulated sums'; str.__contains__('sums') returns True; new to extra208"]
    - [groupby_doc_contains_key,
       "groupby.__doc__.__contains__",
       ["key"],
       true,
       "itertools.groupby.__doc__.__contains__('key') == True — the groupby docstring references a key function for grouping consecutive elements; str.__contains__('key') returns True; new to extra208"]
    - [combinations_doc_contains_iterable,
       "combinations.__doc__.__contains__",
       ["iterable"],
       true,
       "itertools.combinations.__doc__.__contains__('iterable') == True — the combinations docstring says 'Return successive r-length combinations of elements in the iterable'; str.__contains__('iterable') returns True; new to extra208"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra208
# ---------------------------------------------------------------------------

invariant itertools_extra208.product_doc_len_681:
  description: "itertools.product.__doc__.__len__() == 681 — the product docstring is 681 characters long, the longest of the itertools docstrings in this spec; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: product.__doc__.__len__
  args: []
  expected: 681

invariant itertools_extra208.combinations_doc_len_134:
  description: "itertools.combinations.__doc__.__len__() == 134 — the combinations docstring is 134 characters long; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: combinations.__doc__.__len__
  args: []
  expected: 134

invariant itertools_extra208.permutations_doc_len_140:
  description: "itertools.permutations.__doc__.__len__() == 140 — the permutations docstring is 140 characters long; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: permutations.__doc__.__len__
  args: []
  expected: 140

invariant itertools_extra208.accumulate_doc_len_69:
  description: "itertools.accumulate.__doc__.__len__() == 69 — the accumulate docstring is 69 characters long, the shortest of the itertools docstrings in this spec; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: accumulate.__doc__.__len__
  args: []
  expected: 69

invariant itertools_extra208.groupby_doc_len_323:
  description: "itertools.groupby.__doc__.__len__() == 323 — the groupby docstring is 323 characters long; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: groupby.__doc__.__len__
  args: []
  expected: 323

invariant itertools_extra208.dropwhile_doc_len_126:
  description: "itertools.dropwhile.__doc__.__len__() == 126 — the dropwhile docstring is 126 characters long; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: dropwhile.__doc__.__len__
  args: []
  expected: 126

invariant itertools_extra208.takewhile_doc_len_101:
  description: "itertools.takewhile.__doc__.__len__() == 101 — the takewhile docstring is 101 characters long; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: takewhile.__doc__.__len__
  args: []
  expected: 101

invariant itertools_extra208.islice_doc_not_contains_None:
  description: "itertools.islice.__doc__.__contains__('None') == False — the islice docstring does not contain the string 'None'; the default start value is described as 'zero' not None; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: islice.__doc__.__contains__
  args: ["None"]
  expected: false
