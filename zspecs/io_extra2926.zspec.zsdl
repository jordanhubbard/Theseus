    - ["io2926042", "io.RawIOBase.__dict__.__contains__",      ["__ixor__"], false]
    - ["io2926043", "io.BufferedIOBase.__dict__.__contains__", ["__iand__"], false]
    - ["io2926044", "io.BufferedIOBase.__dict__.__contains__", ["__ior__"],  false]
    - ["io2926045", "io.BufferedIOBase.__dict__.__contains__", ["__ixor__"], false]
    - ["io2926046", "io.TextIOBase.__dict__.__contains__",     ["__iand__"], false]
    - ["io2926047", "io.TextIOBase.__dict__.__contains__",     ["__ior__"],  false]
    - ["io2926048", "io.TextIOBase.__dict__.__contains__",     ["__ixor__"], false]
