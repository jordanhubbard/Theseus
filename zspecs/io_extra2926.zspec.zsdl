spec: io2926
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/io_extra2911.zspec.zsdl — wave 641 predecessor (covered __ilshift__, __irshift__, __ipow__)"
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "Wave 642 theme: __iand__, __ior__, __ixor__ dict-presence checks (in-place bitwise AND, OR, XOR operators)."
    - "io classes are I/O stream objects with no bitwise semantics of any kind — none define __iand__, __ior__, or __ixor__."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, and io.TextIOBase are abstract base classes that also omit all three in-place bitwise operators."
    - "io.BytesIO, io.StringIO, io.FileIO do NOT define any of these operators — they are byte/string/file streams, not integer-like operands."
    - "io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper also absent for all three operators."
    - "The non-inplace counterparts (__and__, __or__, __xor__) are also absent from all io classes — absence of bitwise support is total."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __iand__ dict-presence — absent from all io ABC and concrete classes
# ---------------------------------------------------------------------------

table io2926.iand:
  description: "__iand__ is absent from all io class __dict__s — io streams have no bitwise AND semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2926

  columns: [id, function, args, expected]
  rows:
    - ["io2926001", "io.IOBase.__dict__.__contains__",              ["__iand__"], false]
    - ["io2926002", "io.RawIOBase.__dict__.__contains__",           ["__iand__"], false]
    - ["io2926003", "io.BufferedIOBase.__dict__.__contains__",      ["__iand__"], false]
    - ["io2926004", "io.TextIOBase.__dict__.__contains__",          ["__iand__"], false]
    - ["io2926005", "io.BytesIO.__dict__.__contains__",             ["__iand__"], false]
    - ["io2926006", "io.StringIO.__dict__.__contains__",            ["__iand__"], false]
    - ["io2926007", "io.FileIO.__dict__.__contains__",              ["__iand__"], false]
    - ["io2926008", "io.BufferedReader.__dict__.__contains__",      ["__iand__"], false]
    - ["io2926009", "io.BufferedWriter.__dict__.__contains__",      ["__iand__"], false]
    - ["io2926010", "io.BufferedRandom.__dict__.__contains__",      ["__iand__"], false]
    - ["io2926011", "io.TextIOWrapper.__dict__.__contains__",       ["__iand__"], false]
    - ["io2926012", "io.IncrementalNewlineDecoder.__dict__.__contains__", ["__iand__"], false]

