# ---------------------------------------------------------------------------
# Table: ABC-layer combined — all three in-place bitwise ops absent from ABCs
# Confirms absence is established at the ABC level, not per-concrete-class
# ---------------------------------------------------------------------------

table io2926.combined:
  description: "In-place bitwise AND/OR/XOR ops absent from all four io ABC layers — io streams have no numeric or bitwise semantics at any level"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2926

  columns: [id, function, args, expected]
  rows:
    - ["io2926037", "io.IOBase.__dict__.__contains__",         ["__iand__"], false]
    - ["io2926038", "io.IOBase.__dict__.__contains__",         ["__ior__"],  false]
