spec: random_extra13
version: ">=3.9"
backend: python_module(random)

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/random.html — Python random module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/random.py"
  notes:
    - "This spec extends random.zspec.zsdl and prior extras through random_extra12.zspec.zsdl."
    - "random_extra4 covers BPF==53 and RECIP_BPF; random_extra6 covers distribution __qualname__; random_extra12 covers LOG4 and seeded distribution draws."
    - "No prior spec covers random.Random.__qualname__ == 'Random'."
    - "No prior spec covers random.SystemRandom.__qualname__ == 'SystemRandom'."
    - "No prior spec covers random.Random.__module__ == 'random'."
    - "No prior spec covers random.SystemRandom.__module__ == 'random'."
    - "No prior spec covers __name__ attributes of randint, uniform, shuffle, sample, choices, randrange, or seed."
    - "No prior spec covers __module__ attributes of randint, uniform, shuffle, sample, or choices in a table."
    - "random.Random.__qualname__ == 'Random' — class qualname for the Mersenne Twister PRNG class."
    - "random.SystemRandom.__qualname__ == 'SystemRandom' — class qualname for the OS-level PRNG class."
    - "random.Random.__module__ == 'random' — both PRNG classes are defined in the random module."
    - "randint/uniform/shuffle/sample/choices/randrange/seed all have __name__ equal to their identifier."
    - "All module-level convenience functions have __module__ == 'random'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Random and SystemRandom class metadata — __qualname__ and __module__
#
# No prior spec covers __qualname__ for either class. __qualname__ for a
# top-level class equals its simple name. Both classes are defined in the
# 'random' module.
# ---------------------------------------------------------------------------

invariant random_extra13.Random.qualname:
  description: "random.Random.__qualname__ == 'Random' — top-level class qualname equals simple name"
  category: class_metadata
  kind: python_call_eq
  function: Random.__qualname__.__eq__
  args: ["Random"]
  expected: true

invariant random_extra13.SystemRandom.qualname:
  description: "random.SystemRandom.__qualname__ == 'SystemRandom' — top-level class qualname equals simple name"
  category: class_metadata
  kind: python_call_eq
  function: SystemRandom.__qualname__.__eq__
  args: ["SystemRandom"]
  expected: true

invariant random_extra13.Random.module:
  description: "random.Random.__module__ == 'random' — Random class is defined in the random module"
  category: class_metadata
  kind: python_call_eq
  function: Random.__module__.__eq__
  args: ["random"]
  expected: true

invariant random_extra13.SystemRandom.module:
  description: "random.SystemRandom.__module__ == 'random' — SystemRandom class is defined in the random module"
  category: class_metadata
  kind: python_call_eq
  function: SystemRandom.__module__.__eq__
  args: ["random"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ attributes — convenience functions
#
# No prior spec covers __name__ for randint, uniform, shuffle, sample,
# choices, randrange, or seed. Each function's __name__ equals its identifier.
# ---------------------------------------------------------------------------

invariant random_extra13.randint.name:
  description: "random.randint.__name__ == 'randint'"
  category: function_metadata
  kind: python_call_eq
  function: randint.__name__.__eq__
  args: ["randint"]
  expected: true

invariant random_extra13.uniform.name:
  description: "random.uniform.__name__ == 'uniform'"
  category: function_metadata
  kind: python_call_eq
  function: uniform.__name__.__eq__
  args: ["uniform"]
  expected: true

invariant random_extra13.shuffle.name:
  description: "random.shuffle.__name__ == 'shuffle'"
  category: function_metadata
  kind: python_call_eq
  function: shuffle.__name__.__eq__
  args: ["shuffle"]
  expected: true

invariant random_extra13.sample.name:
  description: "random.sample.__name__ == 'sample'"
  category: function_metadata
  kind: python_call_eq
  function: sample.__name__.__eq__
  args: ["sample"]
  expected: true

invariant random_extra13.choices.name:
  description: "random.choices.__name__ == 'choices'"
  category: function_metadata
  kind: python_call_eq
  function: choices.__name__.__eq__
  args: ["choices"]
  expected: true

invariant random_extra13.randrange.name:
  description: "random.randrange.__name__ == 'randrange'"
  category: function_metadata
  kind: python_call_eq
  function: randrange.__name__.__eq__
  args: ["randrange"]
  expected: true

invariant random_extra13.seed.name:
  description: "random.seed.__name__ == 'seed'"
  category: function_metadata
  kind: python_call_eq
  function: seed.__name__.__eq__
  args: ["seed"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ attributes — all 'random'
#
# All module-level convenience functions in the random module have
# __module__ == 'random'. No prior spec records this for any of these.
# ---------------------------------------------------------------------------

table random_extra13.function_modules:
  kind: python_call_eq
  category: function_metadata
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [randint_mod,   randint.__module__.__eq__,   ["random"], true]
    - [uniform_mod,   uniform.__module__.__eq__,   ["random"], true]
    - [shuffle_mod,   shuffle.__module__.__eq__,   ["random"], true]
    - [sample_mod,    sample.__module__.__eq__,    ["random"], true]
    - [choices_mod,   choices.__module__.__eq__,   ["random"], true]
