spec: hashlib_extra259
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_hashlib.c"
  notes:
    - "Wave 259 theme: hashlib.sha256() hash object method identity — update/digest/hexdigest/copy __name__, __qualname__, __class__.__name__."
    - "hashlib.sha256().__class__.__name__ == 'HASH'. The hash object type is the internal HASH type from _hashlib C extension on OpenSSL-backed builds. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().__class__.__module__ == '_hashlib'. The HASH type is defined in the _hashlib C extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hash.update.__name__ == 'update'. The update method is a builtin_function_or_method. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hash.update.__qualname__ == 'HASH.update'. The qualname includes the owning class HASH. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hash.update.__class__.__name__ == 'builtin_function_or_method'. C extension methods appear as builtin_function_or_method. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hash.digest.__name__ == 'digest'. The digest method name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hash.digest.__qualname__ == 'HASH.digest'. The qualname includes the owning class HASH. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hash.hexdigest.__name__ == 'hexdigest'. The hexdigest method name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hash.hexdigest.__qualname__ == 'HASH.hexdigest'. The qualname includes the owning class HASH. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hash.copy.__name__ == 'copy'. The copy method name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hash.copy.__qualname__ == 'HASH.copy'. The qualname includes the owning class HASH. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.sha256()).__bases__[0].__name__ == 'object'. HASH directly inherits from object. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sha256() hash object instance class identity
#
# Wave 259 theme: hashlib.sha256() hash object instance class identity.
#
# On OpenSSL-backed CPython builds (macOS/Linux), hashlib.sha256() returns a
# HASH instance from the _hashlib C extension. The type name is 'HASH' and its
# module is '_hashlib'. HASH directly inherits from object.
# hashlib_extra256 covers sha3_256.__name__=='openssl_sha3_256' and sha3_256
# instance class name; no prior spec anchors sha256() instance class name,
# module, and base class together under hashlibhash259.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra259.sha256.instance_class_name:
  description: "hashlib.sha256().__class__.__name__ == 'HASH' — OpenSSL-backed sha256 returns internal HASH type from _hashlib C extension; HASH is the underlying type for all OpenSSL-backed hash objects; wave 259 theme; first standalone for sha256 instance class name under hashlibhash259; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: sha256
  args: []
  method: __class__.__name__.__eq__
  method_args: ["HASH"]
  expected: true

invariant hashlib_extra259.sha256.instance_module:
  description: "hashlib.sha256().__class__.__module__ == '_hashlib' — the HASH type is defined in the _hashlib C extension (wrapping OpenSSL EVP interface); wave 259 theme; first standalone for sha256 instance __class__.__module__ under hashlibhash259; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: sha256
  args: []
  method: __class__.__module__.__eq__
  method_args: ["_hashlib"]
  expected: true

invariant hashlib_extra259.sha256.base_class_name:
  description: "type(hashlib.sha256()).__bases__[0].__name__ == 'object' — HASH directly inherits from object (no intermediate base classes); wave 259 theme; first standalone for sha256 instance base class name under hashlibhash259; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: sha256
  args: []
  method: __class__.__bases__.__getitem__
  method_args: [0]
  expected: "object"

# ---------------------------------------------------------------------------
# sha256() hash object method __name__ identity
#
# Wave 259 theme: update/digest/hexdigest/copy __name__ attributes.
#
# The four primary HASH methods are update (add data), digest (return bytes),
# hexdigest (return hex string), and copy (return independent copy). All four
# are builtin_function_or_method instances from the _hashlib C extension.
# Each method's __name__ equals its function name string. The __qualname__
# includes the owning HASH class. No prior spec anchors these four method
# __name__ and __qualname__ values together under hashlibhash259.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra259.sha256.update_name:
  description: "hashlib.sha256().update.__name__ == 'update' — update appends data to the hash; __name__ is the bare method name 'update'; builtin_function_or_method from _hashlib C extension; wave 259 theme; first standalone for update.__name__ under hashlibhash259; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: sha256
  args: []
  method: update.__name__.__eq__
  method_args: ["update"]
  expected: true

invariant hashlib_extra259.sha256.update_qualname:
  description: "hashlib.sha256().update.__qualname__ == 'HASH.update' — qualname includes the owning class HASH; distinguishes the C-level method from any Python wrapper; wave 259 theme; first standalone for update.__qualname__ under hashlibhash259; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: sha256
  args: []
  method: update.__qualname__.__eq__
  method_args: ["HASH.update"]
  expected: true

invariant hashlib_extra259.sha256.update_class_name:
  description: "hashlib.sha256().update.__class__.__name__ == 'builtin_function_or_method' — C extension methods bound to an instance appear as builtin_function_or_method; wave 259 theme; first standalone for update __class__.__name__ under hashlibhash259; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: sha256
  args: []
  method: update.__class__.__name__.__eq__
  method_args: ["builtin_function_or_method"]
  expected: true

invariant hashlib_extra259.sha256.digest_name:
  description: "hashlib.sha256().digest.__name__ == 'digest' — digest returns the hash value as bytes; __name__ is the bare method name 'digest'; wave 259 theme; first standalone for digest.__name__ under hashlibhash259; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: sha256
  args: []
  method: digest.__name__.__eq__
  method_args: ["digest"]
  expected: true

invariant hashlib_extra259.sha256.digest_qualname:
  description: "hashlib.sha256().digest.__qualname__ == 'HASH.digest' — qualname includes the owning class HASH; wave 259 theme; first standalone for digest.__qualname__ under hashlibhash259; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: sha256
  args: []
  method: digest.__qualname__.__eq__
  method_args: ["HASH.digest"]
  expected: true

invariant hashlib_extra259.sha256.digest_class_name:
  description: "hashlib.sha256().digest.__class__.__name__ == 'builtin_function_or_method' — digest is a C extension method; wave 259 theme; first standalone for digest __class__.__name__ under hashlibhash259; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: sha256
  args: []
  method: digest.__class__.__name__.__eq__
  method_args: ["builtin_function_or_method"]
  expected: true

invariant hashlib_extra259.sha256.hexdigest_name:
  description: "hashlib.sha256().hexdigest.__name__ == 'hexdigest' — hexdigest returns the hash value as a hex string; __name__ is the bare method name 'hexdigest'; wave 259 theme; first standalone for hexdigest.__name__ under hashlibhash259; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: sha256
  args: []
  method: hexdigest.__name__.__eq__
  method_args: ["hexdigest"]
  expected: true

invariant hashlib_extra259.sha256.hexdigest_qualname:
  description: "hashlib.sha256().hexdigest.__qualname__ == 'HASH.hexdigest' — qualname includes the owning class HASH; wave 259 theme; first standalone for hexdigest.__qualname__ under hashlibhash259; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: sha256
  args: []
  method: hexdigest.__qualname__.__eq__
  method_args: ["HASH.hexdigest"]
  expected: true

invariant hashlib_extra259.sha256.hexdigest_class_name:
  description: "hashlib.sha256().hexdigest.__class__.__name__ == 'builtin_function_or_method' — hexdigest is a C extension method; wave 259 theme; first standalone for hexdigest __class__.__name__ under hashlibhash259; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: sha256
  args: []
  method: hexdigest.__class__.__name__.__eq__
  method_args: ["builtin_function_or_method"]
  expected: true

invariant hashlib_extra259.sha256.copy_name:
  description: "hashlib.sha256().copy.__name__ == 'copy' — copy returns an independent hash object in the current state; __name__ is the bare method name 'copy'; wave 259 theme; first standalone for copy.__name__ under hashlibhash259; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: sha256
  args: []
  method: copy.__name__.__eq__
  method_args: ["copy"]
  expected: true

invariant hashlib_extra259.sha256.copy_qualname:
  description: "hashlib.sha256().copy.__qualname__ == 'HASH.copy' — qualname includes the owning class HASH; wave 259 theme; first standalone for copy.__qualname__ under hashlibhash259; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: sha256
  args: []
  method: copy.__qualname__.__eq__
  method_args: ["HASH.copy"]
  expected: true

invariant hashlib_extra259.sha256.copy_class_name:
  description: "hashlib.sha256().copy.__class__.__name__ == 'builtin_function_or_method' — copy is a C extension method bound to a HASH instance; wave 259 theme; first standalone for copy __class__.__name__ under hashlibhash259; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: sha256
  args: []
  method: copy.__class__.__name__.__eq__
  method_args: ["builtin_function_or_method"]
  expected: true
