spec: p_pipe
version: ">=4.0.0"
backend: node(p-pipe)
esm: true

docs: https://github.com/sindresorhus/p-pipe#readme

provenance:
  derived_from:
    - "p-pipe README — https://github.com/sindresorhus/p-pipe#readme"
    - "Test vectors verified with p-pipe via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "p-pipe source"
  notes:
    - "Compose async functions left-to-right: pipe(f, g, h)(x) = await h(await g(await f(x)))."
    - "Install: npm install p-pipe"
    - "v4 ESM only; default export pPipe(...fns) → composed(input)."
    - "Variadic — declared length is 0."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Composed promise rejects if any step throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant p_pipe.default_export_is_function:
  description: "Default export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "Function"

invariant p_pipe.default_name:
  description: "Default function name is 'pPipe'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.name"}
  expected: "pPipe"

invariant p_pipe.default_arity:
  description: "Default function declared length is 0 (variadic)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 0
