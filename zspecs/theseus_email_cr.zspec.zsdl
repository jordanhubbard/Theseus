spec: theseus_email_cr
version: ">=3.9"
backend: python_cleanroom(theseus_email_cr)
blocks: email

docs: https://docs.python.org/3/library/email.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/email.html"
    - "RFC 5322 — Internet Message Format"
  notes:
    - "Clean-room email message parser. Do NOT import email or email.message."
    - "message_from_string(s): parse RFC 5322 email message string into Message object."
    - "Message.__getitem__(name): return header value by name (case-insensitive)."
    - "Message.get_payload(): return message body as string."
    - "email_parse_from(): parse 'From: user@host\\n\\nbody'; msg['From'] == 'user@host'."
    - "email_parse_subject(): parse email with Subject header; msg['Subject'] == 'Hello'."
    - "email_payload(): parse email with body; get_payload() returns the body text."
    - "Zero-arg invariant signatures — def email_parse_from(): return hardcoded_result"
    - "RFC 5322 format: headers are 'Name: value' lines; blank line separates headers from body."
    - "Header lookup is case-insensitive: msg['from'] == msg['From']."
    - "get_payload(): return the text after the blank line separating headers from body."
    - "Export: message_from_string(s) -> Message, Message class with __getitem__, get_payload."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_email_cr.parse_from:
  description: "parse RFC 5322 message; msg['From'] == 'user@host'"
  category: parse
  kind: python_call_eq
  function: email_parse_from
  args: []
  expected: "user@host"

invariant theseus_email_cr.parse_subject:
  description: "parse message with Subject header; msg['Subject'] == 'Hello'"
  category: parse
  kind: python_call_eq
  function: email_parse_subject
  args: []
  expected: "Hello"

invariant theseus_email_cr.payload:
  description: "get_payload() returns message body"
  category: payload
  kind: python_call_eq
  function: email_payload
  args: []
  expected: "body text"
