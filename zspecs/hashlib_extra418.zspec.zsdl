spec: hashlib_extra418
version: ">=3.9"
backend: python_module(_hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "_hashlib.HASH.update.__name__ == 'update'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_hashlib.HASH.digest.__name__ == 'digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_hashlib.HASH.hexdigest.__name__ == 'hexdigest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_hashlib.HASH.copy.__name__ == 'copy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_hashlib.HASH.update.__qualname__ == 'HASH.update'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_hashlib.HASH.digest.__qualname__ == 'HASH.digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_hashlib.HASH.hexdigest.__qualname__ == 'HASH.hexdigest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_hashlib.HASH.copy.__qualname__ == 'HASH.copy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: _hashlib.HASH is the C extension type returned by _hashlib.new(). Its methods (update, digest, hexdigest, copy) are method_descriptor objects. Each method's __name__ is the bare method name and __qualname__ is 'HASH.<method_name>', reflecting the standard CPython convention for C extension type methods. type(_hashlib.new('sha256')).__name__ == 'HASH' and __module__ == '_hashlib'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _hashlib.HASH method __name__ values
#
# Wave 418 theme: _hashlib.HASH instance method name identity.
#
# _hashlib.HASH is the C extension type returned by _hashlib.new() for
# OpenSSL-backed hash algorithms. Its core instance methods — update,
# digest, hexdigest, and copy — are method_descriptor objects when accessed
# on the class. Each method's __name__ is the bare method name (identical
# to the attribute name used to access it on an instance).
#
# Covered methods:
#   update    — feed data into the hash object
#   digest    — return the digest as bytes
#   hexdigest — return the digest as a hex string
#   copy      — return a copy of the hash object
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra418.hash_method_names:
  description: "_hashlib.HASH.update, digest, hexdigest, copy method __name__ values — each C-level method_descriptor's __name__ is the bare method name; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibhm418

  columns: [id, function, args, expected]
  rows:
    - [update_name,    HASH.update.__name__.__eq__,    ["update"],    true]
    - [digest_name,    HASH.digest.__name__.__eq__,    ["digest"],    true]
    - [hexdigest_name, HASH.hexdigest.__name__.__eq__, ["hexdigest"], true]
    - [copy_name,      HASH.copy.__name__.__eq__,      ["copy"],      true]

# ---------------------------------------------------------------------------
# _hashlib.HASH method __qualname__ values
#
# For C extension type methods, __qualname__ is '<TypeName>.<method_name>'.
# This follows the same convention as pure-Python class methods. For HASH,
# each method's __qualname__ is 'HASH.<method_name>', confirming that the
# method is scoped to the HASH type rather than being a module-level function.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra418.hash_method_qualnames:
  description: "_hashlib.HASH.update, digest, hexdigest, copy method __qualname__ values — qualname is 'HASH.<method>' for each C extension method_descriptor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibhq418

  columns: [id, function, args, expected]
  rows:
    - [update_qualname,    HASH.update.__qualname__.__eq__,    ["HASH.update"],    true]
    - [digest_qualname,    HASH.digest.__qualname__.__eq__,    ["HASH.digest"],    true]
    - [hexdigest_qualname, HASH.hexdigest.__qualname__.__eq__, ["HASH.hexdigest"], true]
    - [copy_qualname,      HASH.copy.__qualname__.__eq__,      ["HASH.copy"],      true]
