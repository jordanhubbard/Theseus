spec: threading_extra48
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra47.zspec.zsdl."
    - "Prior specs covered: Thread/__name__/__qualname__/__module__; Thread/__qualname__.__len__()==6; Thread/__mro__.__len__()==2; Thread/__bases__[0].__name__=='object'; Thread/__bases__[0].__qualname__=='object'; Event/__qualname__=='Event'; Event/__qualname__.__len__()==5; Event/__mro__.__len__()==2; Event/__bases__[0].__name__=='object'; Event/__bases__[0].__qualname__=='object'; Semaphore/__name__/__qualname__/__module__; Semaphore/__qualname__.__len__()==9; Semaphore/__mro__.__len__()==2; Semaphore/__bases__[0].__qualname__=='object'; BoundedSemaphore/__name__/__qualname__/__module__; BoundedSemaphore/__qualname__.__len__()==16; BoundedSemaphore/__mro__.__len__()==3; BoundedSemaphore/__bases__[0].__name__=='Semaphore'; BoundedSemaphore/__bases__[0].__qualname__=='Semaphore'; Condition/__name__/__module__; Condition/__qualname__=='Condition'; Condition/__qualname__.__len__()==9; Condition/__mro__.__len__()==2; Condition/__bases__[0].__name__=='object'; Condition/__bases__[0].__qualname__=='object'; Barrier/__name__/__qualname__/__module__; Barrier/__mro__.__len__()==2; Barrier/__bases__[0].__name__=='object'; Barrier/__bases__[0].__qualname__=='object'; Timer/__name__/__qualname__/__module__; Timer/__mro__.__len__()==3; Timer/__bases__[0].__name__=='Thread'; Timer/__bases__[0].__qualname__=='Thread'; Lock/__name__=='lock'; Lock/__qualname__=='lock'; Lock/__qualname__.__len__()==4; Lock/__module__=='_thread'; Lock/__module__.__len__()==7; local/__name__=='_local'; TIMEOUT_MAX; threading.__all__.__len__()==28; current_thread/__name__/__qualname__/__module__; main_thread/__name__/__qualname__/__module__; active_count/__name__/__qualname__/__module__; enumerate/__name__/__qualname__/__module__; settrace/__name__/__qualname__; setprofile/__name__/__qualname__; stack_size/__name__/__qualname__; RLock/__name__/__qualname__/__module__."
    - "This spec covers: threading.Thread.__class__.__name__ == 'type'; threading.Event.__class__.__name__ == 'type'; threading.Semaphore.__class__.__name__ == 'type'; threading.BoundedSemaphore.__class__.__name__ == 'type'; threading.Condition.__class__.__name__ == 'type'; threading.Barrier.__class__.__name__ == 'type'; threading.Timer.__class__.__name__ == 'type'; threading.main_thread.__class__.__name__ == 'function'; threading.current_thread.__class__.__name__ == 'function'."
    - "Key findings: The threading module exposes two distinct runtime categories of module-level objects. Class objects (Thread, Event, Semaphore, BoundedSemaphore, Condition, Barrier, Timer) are all pure-Python classes defined with class statements in Lib/threading.py; their __class__ is the built-in 'type' metaclass, so __class__.__name__ == 'type' (4 chars). Note that Timer inherits from Thread (__mro__.__len__()==3) and BoundedSemaphore inherits from Semaphore (__mro__.__len__()==3), but both are still class objects with __class__.__name__ == 'type'. Function objects (main_thread, current_thread) are pure-Python functions defined with def statements in Lib/threading.py; their __class__ is the built-in function type, so __class__.__name__ == 'function' (8 chars). No prior spec recorded __class__.__name__ string equality for any threading module-level object; prior specs recorded the objects' own __name__/__qualname__ (the classes' and functions' names) but not the metaclass/type-class names. All nine invariants are new to extra48."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading synchronization primitive classes __class__.__name__ — extra48
#
# threading.Thread, Event, Semaphore, BoundedSemaphore, and Condition are all
# pure-Python classes defined with class statements in Lib/threading.py. Their
# __class__.__name__ is 'type' (4 chars) — the built-in metaclass for all class
# objects. BoundedSemaphore inherits from Semaphore (so __mro__.__len__()==3),
# but this does not change its __class__.__name__; the metaclass is still 'type'.
# Prior specs recorded __name__/__qualname__/__module__/__mro__.__len__() and
# __bases__[0].__qualname__ for all five, but no prior spec recorded
# __class__.__name__ string equality for any of them. All five are new to extra48.
# ---------------------------------------------------------------------------

table threading_extra48.synchronization_class_names:
  description: "threading Thread/Event/Semaphore/BoundedSemaphore/Condition __class__.__name__ == 'type' — pure-Python synchronization classes in Lib/threading.py; __class__ is the built-in 'type' metaclass; 4-char metaclass name"
  kind: python_call_eq
  category: identity
  id_prefix: sync48

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_class_name,
       Thread.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Thread.__class__.__name__ == 'type' — pure-Python class in Lib/threading.py; represents a thread of control; inherits directly from object (__mro__.__len__()==2); class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
    - [Event_class_name,
       Event.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Event.__class__.__name__ == 'type' — pure-Python class in Lib/threading.py; simple synchronization object; a flag that threads can wait on or set; inherits directly from object; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
    - [Semaphore_class_name,
       Semaphore.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Semaphore.__class__.__name__ == 'type' — pure-Python class in Lib/threading.py; counting semaphore; releases up to a maximum count; inherits directly from object; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
    - [BoundedSemaphore_class_name,
       BoundedSemaphore.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.BoundedSemaphore.__class__.__name__ == 'type' — pure-Python class in Lib/threading.py; semaphore that raises ValueError if released more times than acquired; inherits from Semaphore (__mro__.__len__()==3); class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
    - [Condition_class_name,
       Condition.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Condition.__class__.__name__ == 'type' — pure-Python class in Lib/threading.py; wait/notify-based synchronization primitive wrapping a lock; inherits directly from object; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]

# ---------------------------------------------------------------------------
# threading Barrier and Timer classes __class__.__name__ — extra48 namespace
#
# threading.Barrier and threading.Timer are both pure-Python classes defined
# in Lib/threading.py. Barrier is a synchronization primitive that makes a
# group of threads wait until they have all reached the barrier point. Timer
# is a subclass of Thread that calls a function after a specified interval
# (so Timer.__bases__[0].__name__ == 'Thread' and __mro__.__len__()==3).
# Despite having different base classes, both have __class__.__name__ == 'type'
# because all class objects are instances of the 'type' metaclass. Prior specs
# recorded __name__/__qualname__/__module__/__mro__.__len__() and __bases__[0]
# attributes for both, but no prior spec recorded __class__.__name__ for either.
# Both are new to extra48.
# ---------------------------------------------------------------------------

table threading_extra48.barrier_timer_class_names:
  description: "threading Barrier/Timer __class__.__name__ == 'type' — pure-Python classes in Lib/threading.py; Barrier inherits from object, Timer inherits from Thread; both are instances of the 'type' metaclass; 4-char metaclass name"
  kind: python_call_eq
  category: identity
  id_prefix: bt48

  columns: [id, function, args, expected, description]
  rows:
    - [Barrier_class_name,
       Barrier.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Barrier.__class__.__name__ == 'type' — pure-Python class in Lib/threading.py; synchronization primitive that blocks threads until a fixed number of threads have called wait(); inherits directly from object; __class__.__name__ is 'type' (4 chars)"]
    - [Timer_class_name,
       Timer.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Timer.__class__.__name__ == 'type' — pure-Python class in Lib/threading.py; subclass of Thread that runs a function after a delay; __bases__[0].__name__=='Thread'; __mro__.__len__()==3; class objects are instances of 'type' metaclass regardless of inheritance depth; __class__.__name__ is 'type' (4 chars)"]

# ---------------------------------------------------------------------------
# threading module-level functions __class__.__name__ — extra48 namespace
#
# threading.main_thread and threading.current_thread are pure-Python functions
# defined with def statements in Lib/threading.py. Their __class__.__name__ is
# 'function' (8 chars) — the standard CPython type for Python-level function
# objects. These are distinct from the threading class objects above; functions
# have __class__.__name__ == 'function' while class objects have 'type'. Prior
# specs recorded __name__/__qualname__/__module__ for both (extra45 and extra47
# notes), but no prior spec recorded __class__.__name__ string equality for either.
# Both are new to extra48.
# ---------------------------------------------------------------------------

table threading_extra48.thread_functions_class_names:
  description: "threading main_thread/current_thread __class__.__name__ == 'function' — pure-Python module-level functions in Lib/threading.py; __class__ is the standard Python function type; 8-char type name"
  kind: python_call_eq
  category: identity
  id_prefix: tfcn48

  columns: [id, function, args, expected, description]
  rows:
    - [main_thread_class_name,
       main_thread.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.main_thread.__class__.__name__ == 'function' — pure-Python function at module level in Lib/threading.py; returns the Thread object for the main thread (the thread that started the Python interpreter); __class__.__name__ is 'function' (8 chars)"]
    - [current_thread_class_name,
       current_thread.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.current_thread.__class__.__name__ == 'function' — pure-Python function at module level in Lib/threading.py; returns the Thread object for the current thread of execution; __class__.__name__ is 'function' (8 chars)"]
