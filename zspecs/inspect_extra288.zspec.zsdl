spec: inspect_extra288
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module __all__ list membership and metadata"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.__all__ has exactly 107 members in Python 3.14.3"
    - "inspect.__all__ is a list (not a tuple or set)"
    - "FullArgSpec is in __all__ confirming it was not removed in 3.14"
    - "BoundArguments and Signature are core introspection types present since Python 3.3"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table inspect_extra288.all_membership:
  description: "Key public names are present in inspect.__all__"
  kind: python_call_eq
  category: identity
  id_prefix: insex288

  columns: [id, function, args, expected, description]
  rows:
    - [insex288_001, inspect.__all__.__contains__, ["ismodule"], true, "ismodule is in __all__"]
    - [insex288_002, inspect.__all__.__contains__, ["getmembers"], true, "getmembers is in __all__"]
    - [insex288_003, inspect.__all__.__contains__, ["signature"], true, "signature is in __all__"]
    - [insex288_004, inspect.__all__.__contains__, ["Parameter"], true, "Parameter class is in __all__"]
    - [insex288_005, inspect.__all__.__contains__, ["Signature"], true, "Signature class is in __all__"]
    - [insex288_006, inspect.__all__.__contains__, ["getsource"], true, "getsource is in __all__"]
    - [insex288_007, inspect.__all__.__contains__, ["getfile"], true, "getfile is in __all__"]
    - [insex288_008, inspect.__all__.__contains__, ["currentframe"], true, "currentframe is in __all__"]
    - [insex288_009, inspect.__all__.__contains__, ["stack"], true, "stack is in __all__"]
    - [insex288_010, inspect.__all__.__contains__, ["FrameInfo"], true, "FrameInfo namedtuple is in __all__"]
    - [insex288_011, inspect.__all__.__contains__, ["Traceback"], true, "Traceback namedtuple is in __all__"]
    - [insex288_012, inspect.__all__.__contains__, ["BoundArguments"], true, "BoundArguments class is in __all__"]
    - [insex288_013, inspect.__all__.__contains__, ["FullArgSpec"], true, "FullArgSpec namedtuple is in __all__"]
    - [insex288_014, inspect.__all__.__contains__, ["isclass"], true, "isclass is in __all__"]

table inspect_extra288.all_metadata:
  description: "Metadata checks for inspect.__all__: type and length"
  kind: python_call_eq
  category: identity
  id_prefix: insex288m

  columns: [id, function, args, expected, description]
  rows:
    - [insex288m_001, inspect.__all__.__class__.__name__.__eq__, ["list"], true, "__all__ is a list"]
    - [insex288m_002, inspect.__all__.__len__, [], 107, "__all__ has exactly 107 members"]

invariant inspect_extra288.inv_ismodule_in_all:
  description: "ismodule is exported in inspect.__all__"
  category: identity
  kind: python_call_eq
  function: inspect.__all__.__contains__
  args: ["ismodule"]
  expected: true

invariant inspect_extra288.inv_signature_in_all:
  description: "signature is exported in inspect.__all__"
  category: identity
  kind: python_call_eq
  function: inspect.__all__.__contains__
  args: ["signature"]
  expected: true

invariant inspect_extra288.inv_all_len:
  description: "inspect.__all__ has exactly 107 members"
  category: identity
  kind: python_call_eq
  function: inspect.__all__.__len__
  args: []
  expected: 107

invariant inspect_extra288.inv_parameter_in_all:
  description: "Parameter class is exported in inspect.__all__"
  category: identity
  kind: python_call_eq
  function: inspect.__all__.__contains__
  args: ["Parameter"]
  expected: true
