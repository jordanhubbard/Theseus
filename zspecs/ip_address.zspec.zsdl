spec: ip_address
version: ">=10.0.0"
backend: node(ip-address)

docs: https://github.com/beaugunderson/ip-address#readme

provenance:
  derived_from:
    - "ip-address README — https://github.com/beaugunderson/ip-address#readme"
    - "RFC 791 — Internet Protocol (IPv4)"
    - "RFC 4291 — IP Version 6 Addressing Architecture"
    - "Test vectors verified with ip-address via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "ip-address source"
  notes:
    - "Comprehensive IPv4/IPv6 address library with subnet/multicast/reverse-form support."
    - "Install: npm install ip-address"
    - "Pattern: const {Address4, Address6} = require('ip-address'); new Address4(s).method()"
  rfcs:
    - "RFC 791 — Internet Protocol — https://www.rfc-editor.org/rfc/rfc791"
    - "RFC 4291 — IP Version 6 Addressing Architecture — https://www.rfc-editor.org/rfc/rfc4291"
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Constructor throws on invalid addresses; methods on valid instances are pure."
  stderr: "null"
  stickiness: "N/A — Address instances are immutable."
  codes: {}

# IPv4 properties
invariant ip_address.v4_is_correct:
  description: "Valid IPv4 address has isCorrect() == true"
  category: v4_validation
  kind: node_chain_eq
  entry: constructor
  class: Address4
  entry_args: ["192.168.1.1"]
  chain:
    - {method: isCorrect, args: []}
  expected: true

invariant ip_address.v4_correct_form:
  description: "Address4.correctForm() returns canonical IPv4 string"
  category: v4_format
  kind: node_chain_eq
  entry: constructor
  class: Address4
  entry_args: ["192.168.1.1"]
  chain:
    - {method: correctForm, args: []}
  expected: "192.168.1.1"

invariant ip_address.v4_to_array:
  description: "Address4.toArray() returns [a, b, c, d] octets"
  category: v4_format
  kind: node_chain_eq
  entry: constructor
  class: Address4
  entry_args: ["192.168.1.1"]
  chain:
    - {method: toArray, args: []}
  expected: [192, 168, 1, 1]

invariant ip_address.v4_subnet_mask_default:
  description: "Bare IPv4 address (no /N suffix) has subnetMask 32"
  category: v4_subnet
  kind: node_chain_eq
  entry: constructor
  class: Address4
  entry_args: ["192.168.1.1"]
  chain:
    - {get: subnetMask}
  expected: 32

# Multicast detection
invariant ip_address.v4_multicast_yes:
  description: "224.0.0.1 is detected as IPv4 multicast"
  category: v4_predicates
  kind: node_chain_eq
  entry: constructor
  class: Address4
  entry_args: ["224.0.0.1"]
  chain:
    - {method: isMulticast, args: []}
  expected: true

invariant ip_address.v4_multicast_no:
  description: "192.168.1.1 is NOT multicast"
  category: v4_predicates
  kind: node_chain_eq
  entry: constructor
  class: Address4
  entry_args: ["192.168.1.1"]
  chain:
    - {method: isMulticast, args: []}
  expected: false

# Reverse-DNS form
invariant ip_address.v4_reverse_form:
  description: "192.168.1.1 reverse form is '1.1.168.192.in-addr.arpa.'"
  category: v4_format
  kind: node_chain_eq
  entry: constructor
  class: Address4
  entry_args: ["192.168.1.1"]
  chain:
    - {method: reverseForm, args: []}
  expected: "1.1.168.192.in-addr.arpa."

# IPv6 canonical form
invariant ip_address.v6_canonical_loopback:
  description: "Address6('::1').correctForm() == '::1'"
  category: v6_format
  kind: node_chain_eq
  entry: constructor
  class: Address6
  entry_args: ["::1"]
  chain:
    - {method: correctForm, args: []}
  expected: "::1"

invariant ip_address.v6_canonical_full:
  description: "Address6('2001:0db8::1').correctForm() == '2001:db8::1' (compressed)"
  category: v6_format
  kind: node_chain_eq
  entry: constructor
  class: Address6
  entry_args: ["2001:0db8::1"]
  chain:
    - {method: correctForm, args: []}
  expected: "2001:db8::1"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:20:30Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
