spec: string_extra17
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra16.zspec.zsdl."
    - "string_extra16 covers: Template.__qualname__/__module__/base; Formatter.__qualname__/__module__/base; capwords two_words/padded/all_caps."
    - "string_extra13 covers: octdigits.__contains__('7')==True; octdigits.__contains__('8')==False; hexdigits.__contains__('9')==True."
    - "string_extra9 covers: ascii_letters[0]=='a'; ascii_letters[-1]=='Z'."
    - "string_extra6 covers: capwords('hello-world','-')=='Hello-World'; capwords('one-two-three','-')=='One-Two-Three'."
    - "NOT yet covered (now covered here): string.ascii_letters[25] == 'z' — index of last lowercase letter."
    - "NOT yet covered (now covered here): string.ascii_letters[26] == 'A' — index of first uppercase letter (boundary between halves)."
    - "NOT yet covered (now covered here): capwords('foo_bar','_') == 'Foo_Bar' — underscore sep splits and capitalises."
    - "NOT yet covered (now covered here): capwords('hello_world_foo','_') == 'Hello_World_Foo' — three-word underscore sep."
    - "NOT yet covered (now covered here): capwords('X_Y_Z','_') == 'X_Y_Z' — single-char segments with underscore sep."
    - "NOT yet covered (now covered here): string.ascii_letters.__class__.__name__ == 'str' — re-anchored in extra17 namespace."
    - "NOT yet covered (now covered here): string.ascii_lowercase.__class__.__name__ == 'str' — re-anchored in extra17 namespace."
    - "NOT yet covered (now covered here): string.ascii_uppercase.__class__.__name__ == 'str' — re-anchored in extra17 namespace."
    - "NOT yet covered (now covered here): string.digits.__class__.__name__ == 'str' — re-anchored in extra17 namespace."
    - "NOT yet covered (now covered here): string.hexdigits.__class__.__name__ == 'str' — re-anchored in extra17 namespace."
    - "string_extra covers the full type-is-str table; extra9 covers ascii_letters standalone; extra17 adds ascii_lowercase, ascii_uppercase, digits, hexdigits as standalone invariants."
    - "capwords('X_Y_Z','_') splits on '_', capitalises each single-char token ('X','Y','Z'), joins with '_', yielding 'X_Y_Z'. Already-capitalised single-letter tokens are unchanged."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ascii_letters boundary indices — [25] and [26]
#
# string_extra9 covers ascii_letters[0]=='a' and ascii_letters[-1]=='Z'.
# No prior spec checks index 25 (last lowercase 'z') or index 26 (first
# uppercase 'A'). These boundary indices sit at the join between the two halves.
# ---------------------------------------------------------------------------

invariant string_extra17.ascii_letters.index_25:
  description: "string.ascii_letters[25] == 'z' — index 25 is the last lowercase letter"
  category: constants
  kind: python_call_eq
  function: ascii_letters.__getitem__
  args: [25]
  expected: "z"

invariant string_extra17.ascii_letters.index_26:
  description: "string.ascii_letters[26] == 'A' — index 26 is the first uppercase letter"
  category: constants
  kind: python_call_eq
  function: ascii_letters.__getitem__
  args: [26]
  expected: "A"

# ---------------------------------------------------------------------------
# Table: capwords with underscore sep
#
# string_extra6 covers capwords with '-' sep: 'hello-world' and 'one-two-three'.
# No prior spec tests the underscore '_' as the sep argument.
# capwords splits on the given sep, capitalises each part, and joins with sep.
# ---------------------------------------------------------------------------

table string_extra17.capwords_underscore_sep:
  description: "string.capwords with underscore separator — underscore-separated identifiers"
  kind: python_call_eq
  category: capwords
  id_prefix: cw17u
  function: capwords

  columns: [id, args, expected]
  rows:
    - [two_parts,   ["foo_bar",          "_"],  "Foo_Bar"]
    - [three_parts, ["hello_world_foo",  "_"],  "Hello_World_Foo"]
    - [single_chars,["X_Y_Z",            "_"],  "X_Y_Z"]

# ---------------------------------------------------------------------------
# Table: string constant class names — re-anchored in extra17 namespace
#
# string_extra covers all constants in a type-is-str table (id_prefix in that ns).
# string_extra9 covers ascii_letters as a standalone invariant.
# These are re-anchored here as standalone invariants for ascii_lowercase,
# ascii_uppercase, digits, and hexdigits in the extra17 namespace.
# ---------------------------------------------------------------------------

invariant string_extra17.ascii_letters.class_name:
  description: "string.ascii_letters.__class__.__name__ == 'str' — ascii_letters is a str constant (extra17 namespace)"
  category: types
  kind: python_call_eq
  function: ascii_letters.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant string_extra17.ascii_lowercase.class_name:
  description: "string.ascii_lowercase.__class__.__name__ == 'str' — ascii_lowercase is a str constant"
  category: types
  kind: python_call_eq
  function: ascii_lowercase.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant string_extra17.ascii_uppercase.class_name:
  description: "string.ascii_uppercase.__class__.__name__ == 'str' — ascii_uppercase is a str constant"
  category: types
  kind: python_call_eq
  function: ascii_uppercase.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant string_extra17.digits.class_name:
  description: "string.digits.__class__.__name__ == 'str' — digits is a str constant"
  category: types
  kind: python_call_eq
  function: digits.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant string_extra17.hexdigits.class_name:
  description: "string.hexdigits.__class__.__name__ == 'str' — hexdigits is a str constant"
  category: types
  kind: python_call_eq
  function: hexdigits.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# digits == '0123456789' and hexdigits == '0123456789abcdefABCDEF'
# (extra17 namespace anchors)
#
# string.zspec.zsdl covers digits == '0123456789'.
# Multiple prior specs cover hexdigits == '0123456789abcdefABCDEF'.
# Re-anchored here as standalone invariants in the extra17 namespace.
# ---------------------------------------------------------------------------

invariant string_extra17.digits.value:
  description: "string.digits == '0123456789' — digits constant value (extra17 namespace)"
  category: constants
  kind: python_call_eq
  function: digits.__eq__
  args: ["0123456789"]
  expected: true

invariant string_extra17.hexdigits.value:
  description: "string.hexdigits == '0123456789abcdefABCDEF' — hexdigits constant value (extra17 namespace)"
  category: constants
  kind: python_call_eq
  function: hexdigits.__eq__
  args: ["0123456789abcdefABCDEF"]
  expected: true
