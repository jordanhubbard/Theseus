spec: asyncio_extra310
version: ">=3.10"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "On Python 3.14, asyncio.Task and asyncio.Future are C-extension types defined in _asyncio."
    - "asyncio.Task.__module__ == '_asyncio' (not 'asyncio.tasks') — C extension takes precedence."
    - "asyncio.Future.__module__ == '_asyncio' (not 'asyncio.futures') — C extension takes precedence."
    - "asyncio.Handle and asyncio.TimerHandle are pure-Python and live in asyncio.events."
    - "asyncio.AbstractEventLoop.__module__ == 'asyncio.events' — defined in the events submodule."
    - "asyncio.AbstractEventLoopPolicy.__name__ == '_AbstractEventLoopPolicy' — the name attribute reflects the C-extension alias."
    - "asyncio.AbstractEventLoopPolicy is deprecated since Python 3.14 and slated for removal in 3.16."
    - "asyncio.Task.__bases__[0].__name__ == 'Future' — Task inherits directly from Future."
    - "asyncio.Future.__bases__[0].__name__ == 'object' — Future is a base class."
    - "asyncio.TimerHandle.__bases__[0].__name__ == 'Handle' — TimerHandle inherits from Handle."
    - "asyncio.Handle.__bases__[0].__name__ == 'object' — Handle is a base class."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Task — C-extension type identity and inheritance
#
# On Python 3.14, asyncio.Task is the C-extension type from _asyncio.
# Task.__module__ == '_asyncio', not 'asyncio.tasks'.
# Task inherits directly from Future.
# ---------------------------------------------------------------------------

invariant asyncio_extra310.Task.name:
  description: "asyncio.Task.__name__ == 'Task'"
  category: task_identity
  kind: python_call_eq
  function: Task.__name__.__eq__
  args: ["Task"]
  expected: true

invariant asyncio_extra310.Task.module:
  description: "asyncio.Task.__module__ == '_asyncio' — C-extension type on Python 3.14"
  category: task_identity
  kind: python_call_eq
  function: Task.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra310.Task.base_is_Future:
  description: "asyncio.Task.__bases__[0].__name__ == 'Future' — Task inherits from Future"
  category: task_identity
  kind: python_call_eq
  function: Task.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Future"

# ---------------------------------------------------------------------------
# asyncio.Future — C-extension type identity and inheritance
#
# On Python 3.14, asyncio.Future is the C-extension type from _asyncio.
# Future.__module__ == '_asyncio', not 'asyncio.futures'.
# Future inherits directly from object.
# ---------------------------------------------------------------------------

invariant asyncio_extra310.Future.name:
  description: "asyncio.Future.__name__ == 'Future'"
  category: future_identity
  kind: python_call_eq
  function: Future.__name__.__eq__
  args: ["Future"]
  expected: true

invariant asyncio_extra310.Future.module:
  description: "asyncio.Future.__module__ == '_asyncio' — C-extension type on Python 3.14"
  category: future_identity
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra310.Future.base_is_object:
  description: "asyncio.Future.__bases__[0].__name__ == 'object' — Future inherits from object"
  category: future_identity
  kind: python_call_eq
  function: Future.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# asyncio.Handle — pure-Python class identity and inheritance
#
# asyncio.Handle is defined in asyncio.events (pure Python).
# Handle inherits from object.
# ---------------------------------------------------------------------------

invariant asyncio_extra310.Handle.name:
  description: "asyncio.Handle.__name__ == 'Handle'"
  category: handle_identity
  kind: python_call_eq
  function: Handle.__name__.__eq__
  args: ["Handle"]
  expected: true

invariant asyncio_extra310.Handle.module:
  description: "asyncio.Handle.__module__ == 'asyncio.events'"
  category: handle_identity
  kind: python_call_eq
  function: Handle.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra310.Handle.base_is_object:
  description: "asyncio.Handle.__bases__[0].__name__ == 'object' — Handle inherits from object"
  category: handle_identity
  kind: python_call_eq
  function: Handle.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# asyncio.TimerHandle — pure-Python class identity and inheritance
#
# asyncio.TimerHandle is defined in asyncio.events (pure Python).
# TimerHandle inherits from Handle.
# ---------------------------------------------------------------------------

invariant asyncio_extra310.TimerHandle.name:
  description: "asyncio.TimerHandle.__name__ == 'TimerHandle'"
  category: timerhandle_identity
  kind: python_call_eq
  function: TimerHandle.__name__.__eq__
  args: ["TimerHandle"]
  expected: true

invariant asyncio_extra310.TimerHandle.module:
  description: "asyncio.TimerHandle.__module__ == 'asyncio.events'"
  category: timerhandle_identity
  kind: python_call_eq
  function: TimerHandle.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra310.TimerHandle.base_is_Handle:
  description: "asyncio.TimerHandle.__bases__[0].__name__ == 'Handle' — TimerHandle inherits from Handle"
  category: timerhandle_identity
  kind: python_call_eq
  function: TimerHandle.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Handle"

# ---------------------------------------------------------------------------
# asyncio.AbstractEventLoop — pure-Python abstract base class
#
# asyncio.AbstractEventLoop is defined in asyncio.events.
# It inherits from object.
# ---------------------------------------------------------------------------

invariant asyncio_extra310.AbstractEventLoop.name:
  description: "asyncio.AbstractEventLoop.__name__ == 'AbstractEventLoop'"
  category: abstract_event_loop
  kind: python_call_eq
  function: AbstractEventLoop.__name__.__eq__
  args: ["AbstractEventLoop"]
  expected: true

invariant asyncio_extra310.AbstractEventLoop.module:
  description: "asyncio.AbstractEventLoop.__module__ == 'asyncio.events'"
  category: abstract_event_loop
  kind: python_call_eq
  function: AbstractEventLoop.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.AbstractEventLoopPolicy — deprecated alias, actual name differs
#
# asyncio.AbstractEventLoopPolicy.__name__ == '_AbstractEventLoopPolicy'
# because the attribute in the asyncio namespace points to the internal class.
# Deprecated since Python 3.14, slated for removal in 3.16.
# ---------------------------------------------------------------------------

invariant asyncio_extra310.AbstractEventLoopPolicy.name:
  description: "asyncio.AbstractEventLoopPolicy.__name__ == '_AbstractEventLoopPolicy' — internal name of deprecated alias"
  category: abstract_event_loop_policy
  kind: python_call_eq
  function: AbstractEventLoopPolicy.__name__.__eq__
  args: ["_AbstractEventLoopPolicy"]
  expected: true

invariant asyncio_extra310.AbstractEventLoopPolicy.module:
  description: "asyncio.AbstractEventLoopPolicy.__module__ == 'asyncio.events'"
  category: abstract_event_loop_policy
  kind: python_call_eq
  function: AbstractEventLoopPolicy.__module__.__eq__
  args: ["asyncio.events"]
  expected: true
