{
  "schema_version": "0.1",

  "identity": {
    "canonical_name": "ajv",
    "spec_for_versions": ">=8.0.0",
    "api_header": "N/A — Node.js npm package",
    "public_docs_url": "https://ajv.js.org/",
    "rfc_references": [
      {
        "rfc": "JSON Schema draft-07",
        "title": "JSON Schema: A Media Type for Describing JSON Documents",
        "url": "https://json-schema.org/draft-07/schema"
      }
    ]
  },

  "provenance": {
    "derived_from": [
      "Ajv documentation — https://ajv.js.org/",
      "JSON Schema draft-07 specification",
      "Test vectors verified with ajv@8.x via Node.js 22.20.0 on macOS/Darwin 25.3.0, 2026-04-02"
    ],
    "not_derived_from": ["ajv package source"],
    "spec_authors": ["Theseus Z-layer"],
    "created_at": "2026-04-02T00:00:00Z",
    "notes": [
      "Ajv v8 exports the class as both 'Ajv' and 'default'. Invariants use class: 'default'.",
      "The typical pattern is: new Ajv() → instance; instance.compile(schema) → validateFn; validateFn(data) → boolean.",
      "node_constructor_call_eq with then_call: true handles the compile+validate two-step.",
      "validateSchema() is a single-step method call (no then_call).",
      "allErrors option makes Ajv collect all errors rather than stopping at the first."
    ]
  },

  "library": {
    "backend": "cli",
    "command": "node",
    "module_name": "ajv",
    "soname_patterns": [],
    "notes": "node must be in PATH and the ajv npm package (v8+) must be installed."
  },

  "constants": {},
  "types": {},
  "wire_formats": {},

  "functions": {
    "compile": {
      "description": "Compile a JSON Schema into a validate function. Returns a function that takes data and returns boolean.",
      "parameters": [{"name": "schema", "type": "object", "direction": "in"}],
      "return_type": "function"
    },
    "validateSchema": {
      "description": "Validate that the argument is itself a valid JSON Schema. Returns boolean.",
      "parameters": [{"name": "schema", "type": "object", "direction": "in"}],
      "return_type": "boolean"
    }
  },

  "invariants": [
    {
      "id": "ajv.object_schema.valid_object",
      "description": "Object with required integer field validates successfully",
      "category": "object_schema",
      "kind": "node_constructor_call_eq",
      "rfc_reference": "JSON Schema draft-07 §6.5",
      "spec": {
        "class": "default",
        "ctor_args": [{}],
        "method": "compile",
        "args": [{"type": "object", "properties": {"foo": {"type": "integer"}}, "required": ["foo"], "additionalProperties": false}],
        "then_call": true,
        "then_args": [{"foo": 1}],
        "expected": true
      }
    },
    {
      "id": "ajv.object_schema.missing_required",
      "description": "Object missing required field fails validation",
      "category": "object_schema",
      "kind": "node_constructor_call_eq",
      "rfc_reference": "JSON Schema draft-07 §6.5.3",
      "spec": {
        "class": "default",
        "ctor_args": [{}],
        "method": "compile",
        "args": [{"type": "object", "properties": {"foo": {"type": "integer"}}, "required": ["foo"]}],
        "then_call": true,
        "then_args": [{}],
        "expected": false
      }
    },
    {
      "id": "ajv.object_schema.wrong_type",
      "description": "Object with wrong type for required field fails validation",
      "category": "object_schema",
      "kind": "node_constructor_call_eq",
      "rfc_reference": "JSON Schema draft-07 §6.1.1",
      "spec": {
        "class": "default",
        "ctor_args": [{}],
        "method": "compile",
        "args": [{"type": "object", "properties": {"foo": {"type": "integer"}}, "required": ["foo"]}],
        "then_call": true,
        "then_args": [{"foo": "not an integer"}],
        "expected": false
      }
    },
    {
      "id": "ajv.object_schema.additional_properties_rejected",
      "description": "Object with disallowed additional property fails when additionalProperties: false",
      "category": "object_schema",
      "kind": "node_constructor_call_eq",
      "rfc_reference": "JSON Schema draft-07 §6.5.6",
      "spec": {
        "class": "default",
        "ctor_args": [{}],
        "method": "compile",
        "args": [{"type": "object", "properties": {"foo": {"type": "integer"}}, "required": ["foo"], "additionalProperties": false}],
        "then_call": true,
        "then_args": [{"foo": 1, "extra": true}],
        "expected": false
      }
    },
    {
      "id": "ajv.number_schema.valid_number",
      "description": "Number validates against type:number schema",
      "category": "primitive_schema",
      "kind": "node_constructor_call_eq",
      "spec": {
        "class": "default",
        "ctor_args": [{}],
        "method": "compile",
        "args": [{"type": "number"}],
        "then_call": true,
        "then_args": [42],
        "expected": true
      }
    },
    {
      "id": "ajv.number_schema.string_rejected",
      "description": "String fails against type:number schema",
      "category": "primitive_schema",
      "kind": "node_constructor_call_eq",
      "spec": {
        "class": "default",
        "ctor_args": [{}],
        "method": "compile",
        "args": [{"type": "number"}],
        "then_call": true,
        "then_args": ["hello"],
        "expected": false
      }
    },
    {
      "id": "ajv.string_schema.valid_string",
      "description": "String validates against type:string schema",
      "category": "primitive_schema",
      "kind": "node_constructor_call_eq",
      "spec": {
        "class": "default",
        "ctor_args": [{}],
        "method": "compile",
        "args": [{"type": "string"}],
        "then_call": true,
        "then_args": ["hello"],
        "expected": true
      }
    },
    {
      "id": "ajv.string_schema.minLength_pass",
      "description": "String meeting minLength constraint passes",
      "category": "string_schema",
      "kind": "node_constructor_call_eq",
      "rfc_reference": "JSON Schema draft-07 §6.3.2",
      "spec": {
        "class": "default",
        "ctor_args": [{}],
        "method": "compile",
        "args": [{"type": "string", "minLength": 3}],
        "then_call": true,
        "then_args": ["abc"],
        "expected": true
      }
    },
    {
      "id": "ajv.string_schema.minLength_fail",
      "description": "String below minLength constraint fails",
      "category": "string_schema",
      "kind": "node_constructor_call_eq",
      "rfc_reference": "JSON Schema draft-07 §6.3.2",
      "spec": {
        "class": "default",
        "ctor_args": [{}],
        "method": "compile",
        "args": [{"type": "string", "minLength": 3}],
        "then_call": true,
        "then_args": ["ab"],
        "expected": false
      }
    },
    {
      "id": "ajv.array_schema.valid_array",
      "description": "Array of strings validates against array schema",
      "category": "array_schema",
      "kind": "node_constructor_call_eq",
      "spec": {
        "class": "default",
        "ctor_args": [{}],
        "method": "compile",
        "args": [{"type": "array", "items": {"type": "string"}, "minItems": 1}],
        "then_call": true,
        "then_args": [["a", "b"]],
        "expected": true
      }
    },
    {
      "id": "ajv.array_schema.empty_fails_minItems",
      "description": "Empty array fails minItems: 1 constraint",
      "category": "array_schema",
      "kind": "node_constructor_call_eq",
      "rfc_reference": "JSON Schema draft-07 §6.4.4",
      "spec": {
        "class": "default",
        "ctor_args": [{}],
        "method": "compile",
        "args": [{"type": "array", "items": {"type": "string"}, "minItems": 1}],
        "then_call": true,
        "then_args": [[]],
        "expected": false
      }
    },
    {
      "id": "ajv.validateSchema.valid_schema",
      "description": "validateSchema returns true for a well-formed JSON Schema",
      "category": "meta_validation",
      "kind": "node_constructor_call_eq",
      "spec": {
        "class": "default",
        "ctor_args": [{}],
        "method": "validateSchema",
        "args": [{"type": "string"}],
        "then_call": false,
        "expected": true
      }
    }
  ],

  "error_model": {
    "return_code_semantics": "compile().validate() returns boolean; never throws for type mismatches. node exits 0 for all invariants in this spec.",
    "stream_error_field": "null",
    "error_stickiness": "N/A — each Ajv instance and compile call is independent.",
    "error_codes": []
  }
}
