spec: array_differ
version: ">=4.0.0"
backend: node(array-differ)

docs: https://www.npmjs.com/package/array-differ

provenance:
  derived_from:
    - "array-differ README — https://www.npmjs.com/package/array-differ"
    - "Test vectors verified with array-differ via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "array-differ source"
  notes:
    - "array-differ is an npm package. Install: npm install array-differ"
    - "Returns elements in the first array that are not in the second. ESM; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new array of elements in arr1 not present in arr2."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_differ.differ:
  kind: node_module_call_eq
  function: "default"
  category: set
  id_prefix: arrdiffer

  columns: [id, args, expected]
  rows:
    - [partial,  [[1, 2, 3], [2]], [1, 3]]
    - [all_same, [[1, 2, 3], [1, 2, 3]], []]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:35:59Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
