spec: decimal_extra83
version: ">=3.9"
backend: python_module(decimal)
extends: decimal_extra82

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra82."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy __bases__ and MRO; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity; Decimal.__dict__.__contains__ for various dunders; Decimal comparison/equality/hash wrapper_descriptor identity; Context/__dict__ class and membership; getcontext/setcontext __class__.__name__ and __module__; Decimal division/power operator wrapper_descriptor identity and __dict__ membership; Context arithmetic method __class__.__name__; Decimal arithmetic/string/conversion dunder __qualname__ values and lengths; Decimal comparison operator __qualname__ lengths; Decimal to_*/normalize/quantize/sqrt/compare __qualname__ lengths; Decimal.__dict__.__contains__ for arithmetic/comparison/math operators; Decimal/__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__(); Context/__name__/__module__/__qualname__; ROUND_* constants; Decimal operator __doc__.__class__.__name__; decimal exception class identity (InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, DecimalException)."
    - "This spec covers: decimal.Decimal method __qualname__ string equality for quantize, normalize, to_integral_value, as_tuple, sqrt, compare, conjugate, copy_abs, fma. Decimal is implemented in C (_decimal module); its methods are method_descriptor objects that do carry __qualname__ (e.g. 'Decimal.quantize')."
    - "decimal.Decimal.quantize.__qualname__ == 'Decimal.quantize' — C method_descriptor; qualname has 'Decimal.' prefix."
    - "decimal.Decimal.normalize.__qualname__ == 'Decimal.normalize' — C method_descriptor."
    - "decimal.Decimal.to_integral_value.__qualname__ == 'Decimal.to_integral_value' — C method_descriptor."
    - "decimal.Decimal.as_tuple.__qualname__ == 'Decimal.as_tuple' — C method_descriptor."
    - "decimal.Decimal.sqrt.__qualname__ == 'Decimal.sqrt' — C method_descriptor."
    - "decimal.Decimal.compare.__qualname__ == 'Decimal.compare' — C method_descriptor."
    - "decimal.Decimal.conjugate.__qualname__ == 'Decimal.conjugate' — C method_descriptor."
    - "decimal.Decimal.copy_abs.__qualname__ == 'Decimal.copy_abs' — C method_descriptor."
    - "decimal.Decimal.fma.__qualname__ == 'Decimal.fma' — C method_descriptor (fused multiply-add)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.quantize/normalize/to_integral_value/as_tuple __qualname__
# Decimal is a C type (_decimal module); its methods are method_descriptor objects.
# They do carry __qualname__ in the form 'Decimal.<method>'.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra83.Decimal_method_qualnames_math:
  description: "decimal.Decimal quantize/normalize/to_integral_value/as_tuple __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: decimalclsid83

  columns: [id, function, args, expected]
  rows:
    - [quantize_qualname,        Decimal.quantize.__qualname__.__eq__,        ["Decimal.quantize"],        true]
    - [normalize_qualname,       Decimal.normalize.__qualname__.__eq__,       ["Decimal.normalize"],       true]
    - [to_integral_qualname,     Decimal.to_integral_value.__qualname__.__eq__, ["Decimal.to_integral_value"], true]
    - [as_tuple_qualname,        Decimal.as_tuple.__qualname__.__eq__,        ["Decimal.as_tuple"],        true]

# ---------------------------------------------------------------------------
# decimal.Decimal.sqrt/compare __qualname__
# sqrt and compare are fundamental math methods on Decimal (C level).
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra83.Decimal_method_qualnames_sqrt_compare:
  description: "decimal.Decimal sqrt/compare __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: decimalclsid83

  columns: [id, function, args, expected]
  rows:
    - [sqrt_qualname,    Decimal.sqrt.__qualname__.__eq__,    ["Decimal.sqrt"],    true]
    - [compare_qualname, Decimal.compare.__qualname__.__eq__, ["Decimal.compare"], true]

# ---------------------------------------------------------------------------
# decimal.Decimal.conjugate/copy_abs/fma __qualname__
# conjugate, copy_abs, and fma (fused multiply-add) are C-level method_descriptors.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra83.Decimal_method_qualnames_copy_fma:
  description: "decimal.Decimal conjugate/copy_abs/fma __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: decimalclsid83

  columns: [id, function, args, expected]
  rows:
    - [conjugate_qualname, Decimal.conjugate.__qualname__.__eq__, ["Decimal.conjugate"], true]
    - [copy_abs_qualname,  Decimal.copy_abs.__qualname__.__eq__,  ["Decimal.copy_abs"],  true]
    - [fma_qualname,       Decimal.fma.__qualname__.__eq__,       ["Decimal.fma"],       true]

# ---------------------------------------------------------------------------
# decimal.Decimal class-level identity attributes
# Decimal.__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__()
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra83.Decimal_class_identity:
  description: "decimal.Decimal __name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalclsid83

  columns: [id, function, args, expected]
  rows:
    - [dec_name,    Decimal.__name__.__eq__,                       ["Decimal"], true]
    - [dec_module,  Decimal.__module__.__eq__,                     ["decimal"], true]
    - [dec_qualname, Decimal.__qualname__.__eq__,                  ["Decimal"], true]
    - [dec_base0,   "Decimal.__bases__[0].__name__.__eq__",        ["object"],  true]
    - [dec_mrolen,  Decimal.__mro__.__len__,                       [],          2]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra83.Decimal.quantize_qualname:
  description: "decimal.Decimal.quantize.__qualname__ == 'Decimal.quantize' (C method_descriptor with class-prefixed qualname)"
  category: qualname
  kind: python_call_eq
  function: Decimal.quantize.__qualname__.__eq__
  args: ["Decimal.quantize"]
  expected: true

invariant decimal_extra83.Decimal.sqrt_qualname:
  description: "decimal.Decimal.sqrt.__qualname__ == 'Decimal.sqrt' (C method_descriptor with class-prefixed qualname)"
  category: qualname
  kind: python_call_eq
  function: Decimal.sqrt.__qualname__.__eq__
  args: ["Decimal.sqrt"]
  expected: true

invariant decimal_extra83.Decimal.fma_qualname:
  description: "decimal.Decimal.fma.__qualname__ == 'Decimal.fma' (fused multiply-add; C method_descriptor)"
  category: qualname
  kind: python_call_eq
  function: Decimal.fma.__qualname__.__eq__
  args: ["Decimal.fma"]
  expected: true

invariant decimal_extra83.Decimal.name:
  description: "decimal.Decimal.__name__ == 'Decimal' (top-level C type; name is the bare class name)"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra83.Decimal.mro_len:
  description: "decimal.Decimal.__mro__.__len__() == 2 (MRO: Decimal, object; C type with no intermediate base)"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__mro__.__len__
  args: []
  expected: 2
