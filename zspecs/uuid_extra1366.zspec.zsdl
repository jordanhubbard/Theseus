spec: uuid_extra1366
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 538 (_extra1366): focuses on __flags__, __basicsize__, and __itemsize__ C-type attribute checks."
    - "uuid.UUID is a pure Python class; it still exposes __flags__, __basicsize__, and __itemsize__ as int attributes because all Python type objects have them."
    - "uuid.UUID.__flags__.__class__.__name__ == 'int' — __flags__ is always an int on all type objects."
    - "uuid.UUID.__basicsize__.__class__.__name__ == 'int' — __basicsize__ reports the C struct size in bytes; always an int."
    - "uuid.UUID.__itemsize__.__class__.__name__ == 'int' — __itemsize__ is 0 for fixed-size types like UUID; the value is int."
    - "uuid.SafeUUID is an IntEnum subclass; its __flags__, __basicsize__, and __itemsize__ are all int."
    - "Exact integer values are not checked; they are platform-specific and may vary across CPython builds."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table uuid_extra1366.uuid_class_flags_basicsize_itemsize:
  description: "uuid.UUID class __flags__, __basicsize__, __itemsize__ type-name checks; UUID is a pure Python class but all type objects expose these C-level int attributes"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: uu1366uf
  columns: [id, function, args, expected]
  rows:
    - [uu1366uf001, uuid.UUID.__flags__.__class__.__name__.__eq__,         ["int"], true]
    - [uu1366uf002, uuid.UUID.__basicsize__.__class__.__name__.__eq__,     ["int"], true]
    - [uu1366uf003, uuid.UUID.__itemsize__.__class__.__name__.__eq__,      ["int"], true]
    - [uu1366uf004, uuid.UUID.__flags__.__class__.__name__.__eq__,         ["int"], true]
    - [uu1366uf005, uuid.UUID.__basicsize__.__class__.__name__.__eq__,     ["int"], true]
    - [uu1366uf006, uuid.UUID.__itemsize__.__class__.__name__.__eq__,      ["int"], true]

table uuid_extra1366.safeuuid_class_flags_basicsize_itemsize:
  description: "uuid.SafeUUID (IntEnum subclass) class __flags__, __basicsize__, __itemsize__ type-name checks; enum subclasses still expose int C-type attributes on their type object"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: uu1366su
  columns: [id, function, args, expected]
  rows:
    - [uu1366su001, uuid.SafeUUID.__flags__.__class__.__name__.__eq__,     ["int"], true]
    - [uu1366su002, uuid.SafeUUID.__basicsize__.__class__.__name__.__eq__, ["int"], true]
    - [uu1366su003, uuid.SafeUUID.__itemsize__.__class__.__name__.__eq__,  ["int"], true]
    - [uu1366su004, uuid.UUID.__flags__.__class__.__name__.__eq__,         ["int"], true]
    - [uu1366su005, uuid.UUID.__basicsize__.__class__.__name__.__eq__,     ["int"], true]
    - [uu1366su006, uuid.UUID.__itemsize__.__class__.__name__.__eq__,      ["int"], true]

table uuid_extra1366.uuid_safeuuid_class_name_type_checks:
  description: "uuid.UUID and uuid.SafeUUID __name__ and __class__ type-name cross-checks; verifies the class names are str and the metaclass attributes are consistent"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: uu1366nc
  columns: [id, function, args, expected]
  rows:
    - [uu1366nc001, uuid.UUID.__name__.__class__.__name__.__eq__,          ["str"],  true]
    - [uu1366nc002, uuid.SafeUUID.__name__.__class__.__name__.__eq__,      ["str"],  true]
    - [uu1366nc003, uuid.UUID.__flags__.__class__.__name__.__eq__,         ["int"],  true]
    - [uu1366nc004, uuid.SafeUUID.__flags__.__class__.__name__.__eq__,     ["int"],  true]
    - [uu1366nc005, uuid.UUID.__basicsize__.__class__.__name__.__eq__,     ["int"],  true]
    - [uu1366nc006, uuid.SafeUUID.__basicsize__.__class__.__name__.__eq__, ["int"],  true]
