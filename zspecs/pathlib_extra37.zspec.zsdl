spec: pathlib_extra37
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra31.zspec.zsdl — covers PurePosixPath/__qualname__/__module__; PureWindowsPath/__qualname__/__module__; PosixPath/__qualname__/__module__; PurePath/__bases__[0].__name__; PurePath properties fget.__qualname__"
    - "pathlib_extra32.zspec.zsdl — covers PurePath.parent/parents/suffixes/drive/root/anchor fget.__qualname__/__module__"
    - "pathlib_extra33.zspec.zsdl — covers PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__; PosixPath/WindowsPath __bases__[0].__name__; Path/__init__/__qualname__; PurePath/__init__/__name__/__qualname__; Path/__truediv__/__name__/__qualname__"
    - "pathlib_extra34.zspec.zsdl — covers __module__.__len__() for Path/PurePath/PurePosixPath/PureWindowsPath; __name__.__len__() for all six classes; __qualname__.__len__() for Path/PurePath"
    - "pathlib_extra35.zspec.zsdl — covers __qualname__.__len__() for PosixPath/PurePosixPath/PureWindowsPath/WindowsPath; Path.open/read_text/write_text/mkdir/exists/stat __qualname__.__len__(); PosixPath/WindowsPath __module__.__len__()"
    - "pathlib_extra36.zspec.zsdl — covers __mro__.__len__() for PurePath/Path/PurePosixPath/PosixPath; __bases__[0].__name__.__len__() for Path/PurePosixPath; Path.rename/unlink/rmdir/chmod/symlink_to __qualname__.__len__()"
  notes:
    - "This spec extends pathlib_extra36.zspec.zsdl."
    - "Prior specs covered: Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __name__/__module__/__qualname__ and lengths, bases, MRO depths for four classes, Path method qualname lengths for open/read_text/write_text/mkdir/exists/stat/rename/unlink/rmdir/chmod/symlink_to."
    - "This spec covers: pathlib.__all__.__len__() and __class__.__name__; pathlib.__all__.__class__.__name__.__len__(); __dict__.__class__.__name__.__len__() (mappingproxy, always 12) for Path/PurePath/PurePosixPath/PureWindowsPath; PurePath.__reduce__.__qualname__ and its length; WindowsPath.__mro__.__len__(); Path.iterdir/glob/rglob/resolve/absolute __qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.__all__.__len__()."
    - "No prior pathlib spec checks pathlib.__all__.__class__.__name__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.__dict__.__class__.__name__.__len__()."
    - "No prior pathlib spec checks pathlib.PurePath.__dict__.__class__.__name__.__len__()."
    - "No prior pathlib spec checks pathlib.PurePosixPath.__dict__.__class__.__name__.__len__()."
    - "No prior pathlib spec checks pathlib.PureWindowsPath.__dict__.__class__.__name__.__len__()."
    - "No prior pathlib spec checks pathlib.PurePath.__reduce__.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.WindowsPath.__mro__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.iterdir.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.glob.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.rglob.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.resolve.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.absolute.__qualname__.__len__()."
    - "pathlib.__all__ is a list with 7 elements: UnsupportedOperation, PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath."
    - "pathlib.__all__.__class__.__name__ == 'list' — len 4."
    - "All __dict__.__class__.__name__ values are 'mappingproxy' — len 12 (universal for class __dict__)."
    - "PurePath.__reduce__.__qualname__ == 'PurePath.__reduce__' — len 19."
    - "WindowsPath.__mro__ == [WindowsPath, Path, PureWindowsPath, PurePath, object] — len 5."
    - "Path.iterdir.__qualname__ == 'Path.iterdir' — len 12."
    - "Path.glob.__qualname__ == 'Path.glob' — len 9."
    - "Path.rglob.__qualname__ == 'Path.rglob' — len 10."
    - "Path.resolve.__qualname__ == 'Path.resolve' — len 12."
    - "Path.absolute.__qualname__ == 'Path.absolute' — len 13."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.__all__ membership and type
#
# pathlib.__all__ is a plain Python list containing 7 exported names:
# UnsupportedOperation, PurePath, PurePosixPath, PureWindowsPath, Path,
# PosixPath, WindowsPath. Its __class__.__name__ is 'list' (len 4).
# No prior pathlib spec checks __all__.__len__() or the type of __all__.
# ---------------------------------------------------------------------------

invariant pathlib_extra37.all_len:
  description: "pathlib.__all__.__len__() == 7 — seven public names exported: UnsupportedOperation, PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath"
  category: module_structure
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 7

invariant pathlib_extra37.all_class_name_len:
  description: "pathlib.__all__.__class__.__name__.__len__() == 4 — __all__ is a 'list' (4 chars)"
  category: module_structure
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() for pathlib classes
#
# Every Python class's __dict__ is a mappingproxy object. Its type name
# 'mappingproxy' has exactly 12 characters. This holds universally for
# Path, PurePath, PurePosixPath, and PureWindowsPath.
# No prior pathlib spec verifies the mappingproxy name length for any class.
# ---------------------------------------------------------------------------

invariant pathlib_extra37.Path.dict_class_name_len:
  description: "pathlib.Path.__dict__.__class__.__name__.__len__() == 12 — class __dict__ is always a 'mappingproxy' (12 chars)"
  category: class_introspection
  kind: python_call_eq
  function: Path.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant pathlib_extra37.PurePath.dict_class_name_len:
  description: "pathlib.PurePath.__dict__.__class__.__name__.__len__() == 12 — class __dict__ is always a 'mappingproxy' (12 chars)"
  category: class_introspection
  kind: python_call_eq
  function: PurePath.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# PurePath.__reduce__.__qualname__ length
#
# All pathlib classes inherit __reduce__ from PurePath, which defines it
# directly. Its __qualname__ is 'PurePath.__reduce__' (19 characters).
# PureWindowsPath and PurePosixPath also resolve to this same method.
# No prior pathlib spec checks any class's __reduce__.__qualname__ length.
# ---------------------------------------------------------------------------

invariant pathlib_extra37.PurePath.reduce_qualname_len:
  description: "pathlib.PurePath.__reduce__.__qualname__.__len__() == 19 — 'PurePath.__reduce__' has 19 characters"
  category: function_identity
  kind: python_call_eq
  function: "PurePath.__reduce__.__qualname__.__len__"
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# WindowsPath.__mro__.__len__()
#
# WindowsPath sits at the bottom of a five-class MRO:
#   WindowsPath -> Path -> PureWindowsPath -> PurePath -> object
# pathlib_extra36 covered PosixPath (len 5) but not WindowsPath, which
# is also 5 (symmetric with PosixPath in the Windows hierarchy).
# ---------------------------------------------------------------------------

invariant pathlib_extra37.WindowsPath.mro_len:
  description: "pathlib.WindowsPath.__mro__.__len__() == 5 — WindowsPath -> Path -> PureWindowsPath -> PurePath -> object"
  category: class_hierarchy
  kind: python_call_eq
  function: WindowsPath.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() table — PurePosixPath, PureWindowsPath
#
# Extends the mappingproxy checks for two more pathlib classes.
# ---------------------------------------------------------------------------

table pathlib_extra37.dict_class_name_lengths:
  description: "pathlib class __dict__.__class__.__name__.__len__() — always 12 ('mappingproxy') for PurePosixPath and PureWindowsPath"
  kind: python_call_eq
  category: class_introspection
  id_prefix: ple37a

  columns: [id, function, args, expected]
  rows:
    - [PurePosixPath_dict_cls_name_len,  PurePosixPath.__dict__.__class__.__name__.__len__,  [], 12]
    - [PureWindowsPath_dict_cls_name_len, PureWindowsPath.__dict__.__class__.__name__.__len__, [], 12]

# ---------------------------------------------------------------------------
# Path method __qualname__.__len__() — iterdir, glob, rglob, resolve, absolute
#
# These five traversal and resolution methods extend qualname coverage beyond
# the open/read_text/write_text/mkdir/exists/stat/rename/unlink/rmdir/chmod/
# symlink_to methods covered in prior specs.
#   Path.iterdir  -> 'Path.iterdir'  -> 12
#   Path.glob     -> 'Path.glob'     -> 9
#   Path.rglob    -> 'Path.rglob'    -> 10
#   Path.resolve  -> 'Path.resolve'  -> 12
#   Path.absolute -> 'Path.absolute' -> 13
# ---------------------------------------------------------------------------

table pathlib_extra37.path_method_qualname_lengths:
  description: "pathlib.Path traversal/resolution method __qualname__.__len__() — iterdir (12), glob (9), rglob (10), resolve (12), absolute (13)"
  kind: python_call_eq
  category: string_lengths
  id_prefix: ple37b

  columns: [id, function, args, expected]
  rows:
    - [iterdir_qualname_len,  "Path.iterdir.__qualname__.__len__",  [], 12]
    - [glob_qualname_len,     "Path.glob.__qualname__.__len__",     [],  9]
    - [rglob_qualname_len,    "Path.rglob.__qualname__.__len__",    [], 10]
    - [resolve_qualname_len,  "Path.resolve.__qualname__.__len__",  [], 12]
    - [absolute_qualname_len, "Path.absolute.__qualname__.__len__", [], 13]
