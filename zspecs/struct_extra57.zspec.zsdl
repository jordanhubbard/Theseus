spec: struct_extra57
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra56.zspec.zsdl — covers Struct.__init_subclass__/__subclasshook__/__getattribute__/__delattr__/__setattr__ __qualname__.__eq__ string values (table + invariants)."
    - "struct_extra55.zspec.zsdl — covers struct.__spec__.origin.__class__.__name__.__eq__('str') / submodule_search_locations.__class__.__name__.__eq__('NoneType') / has_location==True / __loader__.__class__.__name__.__len__()==16 (table + invariants)."
    - "struct_extra54.zspec.zsdl — covers struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "struct_extra41.zspec.zsdl — covers Struct.size/__name__.__eq__('size') and Struct.format.__name__/__qualname__.__eq__; Struct.size/format __class__.__name__.__eq__('getset_descriptor')."
    - "struct_extra39.zspec.zsdl — covers Struct.__mro__[1]/__name__.__eq__('object'); Struct.size.__qualname__.__eq__('Struct.size') and Struct.size.__qualname__.__len__()==11."
    - "struct_extra28.zspec.zsdl — covers Struct.__init_subclass__.__qualname__.__len__()==24 and error.__init_subclass__.__qualname__.__len__()==23 (length axis only)."
    - "struct_extra23.zspec.zsdl — covers Struct.__new__/__sizeof__ __qualname__.__eq__."
    - "struct_extra21.zspec.zsdl — covers Struct.__init__/__repr__ __qualname__.__eq__ and __qualname__.__len__()."
    - "struct_extra9.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__eq__ and __name__.__eq__."
    - "struct.zspec — covers struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra56; it does NOT duplicate invariants present in those files."
    - "Wave 228 theme: __annotations__ class identity + __globals__ dict keys + __doc__.__contains__ content checks."
    - "struct module-level functions (pack, unpack, pack_into, unpack_from, iter_unpack, calcsize) are all C builtin_function_or_method objects from _struct — they do NOT have __annotations__ attributes. struct.Struct is a C extension type, so its methods are method_descriptors without __annotations__. Lib/struct.py is a thin Python wrapper that re-exports everything from _struct; it defines no Python-level functions with __annotations__."
    - "struct.__doc__ is a Python str (module docstring). No prior struct spec checks struct.__doc__.__class__.__name__.__eq__('str') (the module-level docstring type identity) — prior specs check __spec__, __loader__, __file__, __cached__ axes. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__ is a short C extension type docstring: 'Struct(fmt) --> compiled struct object\n\n'. It contains both 'Struct' (the class name) and 'fmt' (the format argument abbreviation). No prior struct spec checks Struct.__doc__.__contains__ for any keyword. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__doc__ is None (confirmed in wave 223d via struct_extra specs; re-confirmed Python 3.14.3 macOS/Darwin 25.4.0). struct.error is an exception subclass; its docstring is None rather than a string. The chain struct.error.__doc__.__class__.__name__ resolves to 'NoneType' (None.__class__.__name__). struct_extra28 confirms error.__init_subclass__.__qualname__.__len__()==23, but no prior struct spec checks error.__doc__.__class__.__name__.__len__(). 'NoneType' has exactly 8 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__doc__ contains 'format' — the pack C function docstring is 'pack(format, v1, v2, ...) -> bytes\n\nReturn a bytes object containing the values v1, v2, ... packed according to the format string fmt. ...'. The word 'format' appears in the very first line. No prior struct spec checks pack.__doc__.__contains__ for any keyword. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module __doc__ class identity
#
# Wave 228 theme: __doc__.__contains__ content checks; module docstring type.
#
# struct.__doc__ is the module-level docstring, a Python str. No prior struct
# spec checks struct.__doc__.__class__.__name__.__eq__('str') — prior specs
# cover __spec__, __loader__, __file__, __cached__, and __all__ axes.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra57.module_doc_class_name:
  description: "struct.__doc__.__class__.__name__.__eq__('str') — module docstring is a Python str; no prior struct spec checks struct.__doc__.__class__.__name__.__eq__('str'); prior specs cover __spec__/__loader__/__file__/__cached__ axes only; first module docstring type identity check for struct"
  kind: python_call_eq
  category: docstrings
  id_prefix: structann57

  columns: [id, function, args, expected]
  rows:
    - [module_doc_class_name_eq, __doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__doc__ content checks
#
# struct.Struct.__doc__ == 'Struct(fmt) --> compiled struct object\n\n'
# The string contains both 'Struct' (the type name) and 'fmt' (the format
# argument abbreviation used in the Struct C type docstring). No prior struct
# spec checks Struct.__doc__.__contains__ for any keyword. Verified Python
# 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra57.Struct_doc_contains:
  description: "struct.Struct.__doc__.__contains__('Struct') and __contains__('fmt') — C extension type docstring is 'Struct(fmt) --> compiled struct object'; 'Struct' and 'fmt' both appear; no prior struct spec checks Struct.__doc__.__contains__ for any keyword; first doc content checks for Struct"
  kind: python_call_eq
  category: docstrings
  id_prefix: structann57

  columns: [id, function, args, expected]
  rows:
    - [Struct_doc_contains_Struct, "Struct.__doc__.__contains__", ["Struct"], true]
    - [Struct_doc_contains_fmt,    "Struct.__doc__.__contains__", ["fmt"],    true]

# ---------------------------------------------------------------------------
# struct.error.__doc__.__class__.__name__.__len__() == 8
#
# struct.error.__doc__ is None (confirmed in wave 223d). When __doc__ is None,
# the chain None.__class__.__name__ resolves to 'NoneType'. 'NoneType' has
# exactly 8 characters: N-o-n-e-T-y-p-e. This is a novel length check on the
# class name of the None type — orthogonal to any prior struct error checks.
# struct_extra28 confirms error.__init_subclass__.__qualname__.__len__()==23
# (a qualname length check on a method), but no prior struct spec checks
# error.__doc__.__class__.__name__.__len__(). Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table struct_extra57.error_doc_class_name_len:
  description: "struct.error.__doc__.__class__.__name__.__len__()==8 — struct.error.__doc__ is None; None.__class__.__name__ == 'NoneType'; 'NoneType' has 8 characters; struct_extra28 covers error.__init_subclass__.__qualname__.__len__ (qualname axis); no prior struct spec checks error.__doc__.__class__.__name__.__len__(); novel NoneType name length cross-check"
  kind: python_call_eq
  category: docstrings
  id_prefix: structann57

  columns: [id, function, args, expected]
  rows:
    - [error_doc_class_name_len, "error.__doc__.__class__.__name__.__len__", [], 8]

# ---------------------------------------------------------------------------
# struct.pack.__doc__ content check
#
# struct.pack is a C builtin_function_or_method from _struct. Its docstring
# begins 'pack(format, v1, v2, ...) -> bytes'. The word 'format' appears in
# the first line of the docstring. No prior struct spec checks
# pack.__doc__.__contains__ for any keyword. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table struct_extra57.pack_doc_contains:
  description: "struct.pack.__doc__.__contains__('format') — C builtin_function_or_method docstring begins 'pack(format, v1, v2, ...) -> bytes'; 'format' appears in the first line; no prior struct spec checks pack.__doc__.__contains__ for any keyword; first doc content check for struct.pack"
  kind: python_call_eq
  category: docstrings
  id_prefix: structann57

  columns: [id, function, args, expected]
  rows:
    - [pack_doc_contains_format, pack.__doc__.__contains__, ["format"], true]

# ---------------------------------------------------------------------------
# struct.__doc__.__class__.__name__.__eq__('str') — standalone
#
# The struct module docstring describes its purpose: converting between Python
# values and C structs. This docstring is a Python str. No prior struct spec
# checks struct.__doc__.__class__.__name__.__eq__('str') in any form — prior
# specs focus on the __spec__, __loader__, __file__, and __cached__ axes.
# This is the first module docstring type identity anchor for struct.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra57.module_doc_class_name_str:
  description: "struct.__doc__.__class__.__name__.__eq__('str') == True — module docstring is a Python str; no prior struct spec checks struct.__doc__.__class__.__name__.__eq__('str'); prior specs cover __spec__/__loader__/__file__/__cached__ axes; first module docstring type identity anchor for struct"
  category: docstrings
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__doc__.__class__.__name__.__len__() == 8 — standalone
#
# struct.error.__doc__ is None. None.__class__.__name__ is 'NoneType', which
# has 8 characters. This cross-check confirms the NoneType class name length,
# providing a secondary constraint orthogonal to the __eq__ equality check
# pattern used elsewhere. struct_extra28 established error.__init_subclass__
# __qualname__.__len__()==23 (qualname axis on a method); this invariant
# anchors the doc chain's NoneType name length on the exception class itself.
# No prior struct spec checks error.__doc__.__class__.__name__.__len__().
# ---------------------------------------------------------------------------

invariant struct_extra57.error_doc_class_name_nonetype_len:
  description: "struct.error.__doc__.__class__.__name__.__len__() == 8 — struct.error.__doc__ is None; None.__class__.__name__ == 'NoneType'; 'NoneType' has 8 characters; novel length cross-check on the NoneType class name string; no prior struct spec checks error.__doc__.__class__.__name__.__len__()"
  category: docstrings
  kind: python_call_eq
  function: "error.__doc__.__class__.__name__.__len__"
  args: []
  expected: 8
