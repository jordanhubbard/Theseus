spec: zlib_extra13
version: ">=3.9"
backend: python_module(zlib)

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
    - "zlib_extra12.zspec.zsdl — covers Compress.compress/flush/copy __qualname__ (extra12); Decompress.decompress/flush/copy __qualname__ (extra12); Z_BEST_COMPRESSION/__class__.__name__ == 'int' (extra12); Z_BEST_SPEED/__class__.__name__ == 'int' (extra12)."
    - "zlib_extra11.zspec.zsdl — covers compress/decompress/compressobj/decompressobj/crc32/adler32 __qualname__ standalone (extra11); error.__qualname__ standalone (extra11); zlib.__package__ (extra11); zlib._ZlibDecompressor.__qualname__ (extra11)."
    - "zlib_extra10.zspec.zsdl — covers compress/decompress/compressobj/decompressobj/crc32/adler32 __qualname__ standalone (extra10); error.__qualname__ standalone (extra10); zlib.__name__ standalone (extra10)."
    - "zlib_extra7.zspec.zsdl — covers Z_DEFAULT_COMPRESSION.__class__.__name__ == 'int' (extra7 anchor)."
    - "zlib_extra3.zspec.zsdl — covers DEF_BUF_SIZE.__class__.__name__ == 'int'; DEF_BUF_SIZE value == 16384; DEFLATED value == 8."
    - "zlib_extra2.zspec.zsdl — covers Compress/Decompress type __name__; Z_DEFAULT_COMPRESSION.__class__.__name__ == 'int'; Z_BEST_COMPRESSION value == 9; Z_BEST_SPEED value == 1."
    - "zlib_extra.zspec.zsdl — covers DEFLATED.__class__.__name__ == 'int'; Z_DEFAULT_COMPRESSION.__class__.__name__ == 'int'; function __name__ attrs; roundtrip."
  notes:
    - "This spec extends zlib through zlib_extra12; it does NOT duplicate invariants present in those files."
    - "Focus: error.__bases__[0].__name__ and error.__module__; compress.__module__ and decompress.__module__ (both 'zlib', not '_zlib'); novel int-type checks for Z_NO_COMPRESSION, Z_DEFAULT_STRATEGY, MAX_WBITS, Z_NO_FLUSH, Z_SYNC_FLUSH, and Z_FULL_FLUSH."
    - "zlib.compress.__module__ == 'zlib': zlib.compress is a C builtin whose __module__ is 'zlib' (not '_zlib'). Not covered in any prior zlib spec. Verified 2026-04-09."
    - "zlib.decompress.__module__ == 'zlib': same as compress. Verified 2026-04-09."
    - "zlib.error.__module__ == 'zlib': the error exception class lives in the zlib C extension module, reported as 'zlib'. Not covered in any prior zlib spec. Verified 2026-04-09."
    - "zlib.error.__bases__[0].__name__ == 'Exception': error is a direct subclass of Exception. Not covered in any prior zlib spec. Verified 2026-04-09."
    - "Z_NO_COMPRESSION, Z_DEFAULT_STRATEGY, MAX_WBITS, Z_NO_FLUSH, Z_SYNC_FLUSH, Z_FULL_FLUSH __class__.__name__ == 'int': no prior zlib spec checks these constants as int-typed. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# compress.__module__ == 'zlib' — novel, extra13 anchor
#
# No prior zlib spec checks compress.__module__. zlib.compress is a C builtin
# function; its __module__ is 'zlib'. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra13.compress.module:
  description: "zlib.compress.__module__ == 'zlib' — C builtin function's __module__ is 'zlib' (extra13)"
  category: module_affiliation
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["zlib"]
  expected: true

# ---------------------------------------------------------------------------
# decompress.__module__ == 'zlib' — novel, extra13 anchor
#
# No prior zlib spec checks decompress.__module__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra13.decompress.module:
  description: "zlib.decompress.__module__ == 'zlib' — C builtin function's __module__ is 'zlib' (extra13)"
  category: module_affiliation
  kind: python_call_eq
  function: decompress.__module__.__eq__
  args: ["zlib"]
  expected: true

# ---------------------------------------------------------------------------
# error.__module__ == 'zlib' — novel, extra13 anchor
#
# No prior zlib spec checks error.__module__. The error exception class is
# defined in the zlib C extension; its __module__ is 'zlib'. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra13.error.module:
  description: "zlib.error.__module__ == 'zlib' — exception class __module__ is 'zlib' (extra13)"
  category: module_affiliation
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["zlib"]
  expected: true

# ---------------------------------------------------------------------------
# error.__bases__[0].__name__ == 'Exception' — novel, extra13 anchor
#
# No prior zlib spec checks error.__bases__[0].__name__. zlib.error is a
# direct subclass of Exception. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra13.error.base_name:
  description: "zlib.error.__bases__[0].__name__ == 'Exception' — error is a direct subclass of Exception (extra13)"
  category: hierarchy
  kind: python_call_eq
  function: "error.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# Z_NO_COMPRESSION.__class__.__name__ == 'int' — novel, extra13 anchor
#
# No prior zlib spec checks Z_NO_COMPRESSION.__class__.__name__. This constant
# (value 0) is a plain Python int. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra13.Z_NO_COMPRESSION.class_is_int:
  description: "zlib.Z_NO_COMPRESSION.__class__.__name__ == 'int' — constant is a plain Python int (extra13)"
  category: type_identity
  kind: python_call_eq
  function: Z_NO_COMPRESSION.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Z_DEFAULT_STRATEGY.__class__.__name__ == 'int' — novel, extra13 anchor
#
# No prior zlib spec checks Z_DEFAULT_STRATEGY.__class__.__name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra13.Z_DEFAULT_STRATEGY.class_is_int:
  description: "zlib.Z_DEFAULT_STRATEGY.__class__.__name__ == 'int' — constant is a plain Python int (extra13)"
  category: type_identity
  kind: python_call_eq
  function: Z_DEFAULT_STRATEGY.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# MAX_WBITS.__class__.__name__ == 'int' — novel, extra13 anchor
#
# No prior zlib spec checks MAX_WBITS.__class__.__name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra13.MAX_WBITS.class_is_int:
  description: "zlib.MAX_WBITS.__class__.__name__ == 'int' — constant is a plain Python int (extra13)"
  category: type_identity
  kind: python_call_eq
  function: MAX_WBITS.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Z_NO_FLUSH.__class__.__name__ == 'int' — novel, extra13 anchor
#
# No prior zlib spec checks Z_NO_FLUSH.__class__.__name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra13.Z_NO_FLUSH.class_is_int:
  description: "zlib.Z_NO_FLUSH.__class__.__name__ == 'int' — flush constant is a plain Python int (extra13)"
  category: type_identity
  kind: python_call_eq
  function: Z_NO_FLUSH.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Z_SYNC_FLUSH.__class__.__name__ == 'int' — novel, extra13 anchor
#
# No prior zlib spec checks Z_SYNC_FLUSH.__class__.__name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra13.Z_SYNC_FLUSH.class_is_int:
  description: "zlib.Z_SYNC_FLUSH.__class__.__name__ == 'int' — flush constant is a plain Python int (extra13)"
  category: type_identity
  kind: python_call_eq
  function: Z_SYNC_FLUSH.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Z_FULL_FLUSH.__class__.__name__ == 'int' — novel, extra13 anchor
#
# No prior zlib spec checks Z_FULL_FLUSH.__class__.__name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra13.Z_FULL_FLUSH.class_is_int:
  description: "zlib.Z_FULL_FLUSH.__class__.__name__ == 'int' — flush constant is a plain Python int (extra13)"
  category: type_identity
  kind: python_call_eq
  function: Z_FULL_FLUSH.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table — compress + decompress + error (extra13)
#
# No prior zlib spec presents function/class __module__ values in a table.
# This table anchors all three module_affiliation checks from extra13.
# ---------------------------------------------------------------------------

table zlib_extra13.module_affiliations:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: mod13

  columns: [id, function, args, expected]
  rows:
    - [compress,   compress.__module__.__eq__,   ["zlib"], true]
    - [decompress, decompress.__module__.__eq__, ["zlib"], true]
    - [error,      error.__module__.__eq__,      ["zlib"], true]

# ---------------------------------------------------------------------------
# int type identity table — flush and strategy constants (extra13)
#
# No prior zlib spec presents these six constants as int-type-identity checks
# in a table. This table anchors all six from the extra13 namespace.
# ---------------------------------------------------------------------------

table zlib_extra13.constant_int_types:
  kind: python_call_eq
  category: type_identity
  id_prefix: ci13

  columns: [id, function, args, expected]
  rows:
    - [Z_NO_COMPRESSION,  Z_NO_COMPRESSION.__class__.__name__.__eq__,  ["int"], true]
    - [Z_DEFAULT_STRATEGY, Z_DEFAULT_STRATEGY.__class__.__name__.__eq__, ["int"], true]
    - [MAX_WBITS,         MAX_WBITS.__class__.__name__.__eq__,         ["int"], true]
    - [Z_NO_FLUSH,        Z_NO_FLUSH.__class__.__name__.__eq__,        ["int"], true]
    - [Z_SYNC_FLUSH,      Z_SYNC_FLUSH.__class__.__name__.__eq__,      ["int"], true]
    - [Z_FULL_FLUSH,      Z_FULL_FLUSH.__class__.__name__.__eq__,      ["int"], true]
