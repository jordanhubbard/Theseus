spec: functools_extra54
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra53.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps/partial/lru_cache/total_ordering/singledispatch/cached_property/reduce/cmp_to_key/partialmethod/singledispatchmethod/update_wrapper; __qualname__.__len__() for all major functools objects; WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES lengths; __all__ lengths; partial/__class__.__name__; cached_property/__set_name__/__get__/__init__.__qualname__; partial/__new__.__qualname__; class __dict__.__class__.__name__.__len__ for partial/partialmethod/singledispatchmethod/cached_property; reduce with initial value; lru_cache(128).__ne__(None)==True; lru_cache(maxsize=2) behavioral; reduce/__qualname__=='reduce'; lru_cache/__qualname__=='lru_cache'; cache/__name__/__qualname__/__module__; cached_property/__name__/__qualname__/__module__/__bases__[0].__name__; total_ordering/__name__/__qualname__/__module__; singledispatch/__name__/__qualname__/__module__; wraps/__name__/__qualname__/__module__; update_wrapper/__name__/__qualname__/__module__; partial/__bases__[0].__name__=='object'; partial/__name__/__qualname__/__module__; lru_cache/__name__/__module__; cmp_to_key/__name__=='cmp_to_key'/__qualname__/'_functools'; partialmethod/__name__/__qualname__/__module__/__bases__[0].__name__; singledispatchmethod/__name__/__module__/__qualname__; singledispatchmethod/__mro__.__len__()==2; partial/__mro__.__len__()==2; partialmethod/__mro__.__len__()==2; cached_property/__mro__.__len__()==2; reduce/__module__.__len__()==10; cached_property/__bases__[0].__qualname__=='object'; partialmethod/__bases__[0].__qualname__=='object'; partial/__bases__[0].__qualname__=='object'; singledispatchmethod/__bases__[0].__qualname__=='object'; reduce/__class__.__name__=='builtin_function_or_method'; cmp_to_key/__class__.__name__=='builtin_function_or_method'; wraps/__class__.__name__=='function'; lru_cache/__class__.__name__=='function'; update_wrapper/__class__.__name__=='function'; singledispatch/__class__.__name__=='function'; total_ordering/__class__.__name__=='function'; cache/__class__.__name__=='function'; partial/__class__.__name__=='type'; cached_property/__class__.__name__=='type'; partialmethod/__class__.__name__=='type'; singledispatchmethod/__class__.__name__=='type'; reduce/__class__.__qualname__=='builtin_function_or_method'; wraps/__class__.__qualname__=='function'; lru_cache/__class__.__qualname__=='function'; singledispatch/__class__.__qualname__=='function'; total_ordering/__class__.__qualname__=='function'; partial/__class__.__qualname__=='type'; cached_property/__class__.__qualname__=='type'; reduce/__class__.__module__=='builtins'; wraps/__class__.__module__=='builtins'; lru_cache/__class__.__module__=='builtins'; partial/__class__.__module__=='_functools'; cached_property/__class__.__module__=='builtins'; total_ordering/__class__.__module__=='builtins'; singledispatch/__class__.__module__=='builtins'."
    - "This spec covers: method qualname lengths for functools.partial methods (__call__/__repr__/__reduce__/__setstate__/__new__) and functools.cached_property methods (__set_name__/__get__/__init__)."
    - "Key findings: functools.partial is a C-extension type defined in Modules/_functoolsmodule.c. Its method qualnames follow the 'partial.<method>' pattern: __call__ (16 chars), __repr__ (16 chars), __reduce__ (18 chars), __setstate__ (20 chars), __new__ (15 chars). functools.cached_property is a pure-Python class in Lib/functools.py. Its own methods (not inherited from object) have qualnames following 'cached_property.<method>': __set_name__ (28 chars), __get__ (23 chars), __init__ (24 chars). Note that cached_property.__set__ does not exist as cached_property is a non-data descriptor (it only defines __get__ and __set_name__, not __set__ or __delete__). All qualname lengths verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10. All invariants are new to extra54."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.partial method qualname lengths — extra54 namespace
#
# functools.partial is a C-extension type from Modules/_functoolsmodule.c.
# Its methods carry qualnames of the form 'partial.<method>', where the
# prefix 'partial.' (8 chars) is prepended to each method name. The resulting
# qualname lengths are:
#   __call__    -> 'partial.__call__'    = 16 chars
#   __repr__    -> 'partial.__repr__'    = 16 chars
#   __reduce__  -> 'partial.__reduce__'  = 18 chars
#   __setstate__ -> 'partial.__setstate__' = 20 chars
#   __new__     -> 'partial.__new__'     = 15 chars
# No prior spec recorded qualname length for any method of functools.partial.
# All five invariants are new to extra54.
# ---------------------------------------------------------------------------

table functools_extra54.partial_method_qualname_lengths:
  description: "functools.partial method qualname lengths — C-extension type; methods carry 'partial.<method>' qualnames; __call__/__repr__==16, __reduce__==18, __setstate__==20, __new__==15"
  kind: python_call_eq
  category: identity
  id_prefix: partialmlen54

  columns: [id, function, args, expected, description]
  rows:
    - [partial_call_qualname_len,
       partial.__call__.__qualname__.__len__,
       [],
       16,
       "functools.partial.__call__.__qualname__.__len__() == 16 — C-extension method; qualname is 'partial.__call__' (8-char prefix 'partial.' + 8-char '__call__' = 16 chars total); verifies the dotted-prefix qualname convention for methods of C-extension types"]
    - [partial_repr_qualname_len,
       partial.__repr__.__qualname__.__len__,
       [],
       16,
       "functools.partial.__repr__.__qualname__.__len__() == 16 — C-extension method; qualname is 'partial.__repr__' (8-char prefix 'partial.' + 8-char '__repr__' = 16 chars total); same length as __call__ because both method names have 8 characters"]
    - [partial_reduce_qualname_len,
       partial.__reduce__.__qualname__.__len__,
       [],
       18,
       "functools.partial.__reduce__.__qualname__.__len__() == 18 — C-extension method; qualname is 'partial.__reduce__' (8-char prefix 'partial.' + 10-char '__reduce__' = 18 chars total); used by pickle to serialize partial objects"]
    - [partial_setstate_qualname_len,
       partial.__setstate__.__qualname__.__len__,
       [],
       20,
       "functools.partial.__setstate__.__qualname__.__len__() == 20 — C-extension method; qualname is 'partial.__setstate__' (8-char prefix 'partial.' + 12-char '__setstate__' = 20 chars total); counterpart to __reduce__ used by pickle to restore partial objects"]
    - [partial_new_qualname_len,
       partial.__new__.__qualname__.__len__,
       [],
       15,
       "functools.partial.__new__.__qualname__.__len__() == 15 — C-extension method; qualname is 'partial.__new__' (8-char prefix 'partial.' + 7-char '__new__' = 15 chars total); the constructor for the partial C-extension type"]

# ---------------------------------------------------------------------------
# functools.cached_property method qualname lengths — extra54 namespace
#
# functools.cached_property is a pure-Python class in Lib/functools.py.
# Its own methods (those not inherited from object) carry qualnames of the
# form 'cached_property.<method>', where the 16-char prefix
# 'cached_property.' is prepended to each method name. The lengths are:
#   __set_name__ -> 'cached_property.__set_name__' = 28 chars
#   __get__      -> 'cached_property.__get__'      = 23 chars
#   __init__     -> 'cached_property.__init__'     = 24 chars
# Note: cached_property does NOT define __set__; it is a non-data descriptor
# (defines only __get__ and __set_name__, not __set__ or __delete__).
# No prior spec recorded qualname length for any method of cached_property.
# All three invariants are new to extra54.
# ---------------------------------------------------------------------------

table functools_extra54.cached_property_method_qualname_lengths:
  description: "functools.cached_property method qualname lengths — pure-Python non-data descriptor; methods carry 'cached_property.<method>' qualnames; __set_name__==28, __get__==23, __init__==24"
  kind: python_call_eq
  category: identity
  id_prefix: partialmlen54

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_set_name_qualname_len,
       cached_property.__set_name__.__qualname__.__len__,
       [],
       28,
       "functools.cached_property.__set_name__.__qualname__.__len__() == 28 — pure-Python method in Lib/functools.py; qualname is 'cached_property.__set_name__' (16-char prefix 'cached_property.' + 12-char '__set_name__' = 28 chars total); called by type.__init_subclass__ when the class is defined to record the attribute name"]
    - [cached_property_get_qualname_len,
       cached_property.__get__.__qualname__.__len__,
       [],
       23,
       "functools.cached_property.__get__.__qualname__.__len__() == 23 — pure-Python descriptor method in Lib/functools.py; qualname is 'cached_property.__get__' (16-char prefix 'cached_property.' + 7-char '__get__' = 23 chars total); computes and caches the property value on first access; cached_property is a non-data descriptor (no __set__)"]
    - [cached_property_init_qualname_len,
       cached_property.__init__.__qualname__.__len__,
       [],
       24,
       "functools.cached_property.__init__.__qualname__.__len__() == 24 — pure-Python initializer in Lib/functools.py; qualname is 'cached_property.__init__' (16-char prefix 'cached_property.' + 8-char '__init__' = 24 chars total); stores the wrapped function and copies its docstring"]
