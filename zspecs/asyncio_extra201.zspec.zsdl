spec: asyncio_extra201
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec covers __class__.__name__ (metaclass) values for eight asyncio classes: Task, Future, Queue, Lock, Event, Semaphore, Condition, Handle."
    - "asyncio.Task.__class__.__name__ == 'type' — Task is a plain class whose metaclass is the built-in type. Verified with Python 3.14.3."
    - "asyncio.Future.__class__.__name__ == 'type' — Future is a plain class whose metaclass is the built-in type. Verified with Python 3.14.3."
    - "asyncio.Queue.__class__.__name__ == 'type' — Queue is a plain class whose metaclass is the built-in type. Verified with Python 3.14.3."
    - "asyncio.Lock.__class__.__name__ == 'type' — Lock is a plain class whose metaclass is the built-in type. Verified with Python 3.14.3."
    - "asyncio.Event.__class__.__name__ == 'type' — Event is a plain class whose metaclass is the built-in type. Verified with Python 3.14.3."
    - "asyncio.Semaphore.__class__.__name__ == 'type' — Semaphore is a plain class whose metaclass is the built-in type. Verified with Python 3.14.3."
    - "asyncio.Condition.__class__.__name__ == 'type' — Condition is a plain class whose metaclass is the built-in type. Verified with Python 3.14.3."
    - "asyncio.Handle.__class__.__name__ == 'type' — Handle is a plain class whose metaclass is the built-in type. Verified with Python 3.14.3."
    - "All eight asyncio classes use the standard built-in type as their metaclass; __class__.__name__ == 'type' for all of them."
    - "The string 'type' has length 4; __class__.__name__.__len__() == 4 for all eight classes."
    - "Prior asyncio specs cover __doc__.__class__.__name__, __name__, __qualname__, __module__, and __bases__ checks. No prior spec covers __class__.__name__ (metaclass) identity."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio Task and Future __class__.__name__ metaclass identity
#
# asyncio.Task.__class__.__name__ == 'type'
# asyncio.Future.__class__.__name__ == 'type'
#
# Task and Future are the two primary awaitable types in asyncio. Both are
# standard Python classes with the built-in type as metaclass.
# New to asyncio_extra201.
# ---------------------------------------------------------------------------

table asyncio_extra201.task_future_class_names:
  description: "asyncio.Task and asyncio.Future __class__.__name__ == 'type'; both use built-in type as metaclass; new to asyncio_extra201"
  kind: python_call_eq
  category: metaclass_identity
  id_prefix: asyncioclasses201

  columns: [id, function, args, expected, description]
  rows:
    - [task_class_name_eq_type,
       "Task.__class__.__name__.__eq__",
       ["type"],
       true,
       "asyncio.Task.__class__.__name__.__eq__('type') == True — Task is a plain class; __class__ is the built-in type; new to asyncio_extra201"]
    - [task_class_name_len_eq_4,
       "Task.__class__.__name__.__len__",
       [],
       4,
       "asyncio.Task.__class__.__name__.__len__() == 4 — 'type' has 4 characters; new to asyncio_extra201"]
    - [future_class_name_eq_type,
       "Future.__class__.__name__.__eq__",
       ["type"],
       true,
       "asyncio.Future.__class__.__name__.__eq__('type') == True — Future is a plain class; __class__ is the built-in type; new to asyncio_extra201"]
    - [future_class_name_len_eq_4,
       "Future.__class__.__name__.__len__",
       [],
       4,
       "asyncio.Future.__class__.__name__.__len__() == 4 — 'type' has 4 characters; new to asyncio_extra201"]

