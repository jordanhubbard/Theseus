spec: is_obj
version: ">=3.0.0"
backend: node(is-obj)

docs: https://www.npmjs.com/package/is-obj

provenance:
  derived_from:
    - "is-obj README — https://www.npmjs.com/package/is-obj"
    - "Test vectors verified with is-obj via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-obj source"
  notes:
    - "is-obj is an npm package. Install: npm install is-obj"
    - "Returns true if the value is an object (including arrays), false for null, numbers, strings, and booleans."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_obj.isObj:
  kind: node_module_call_eq
  function: "default"
  category: type
  id_prefix: isobj2

  columns: [id, args, expected]
  rows:
    - [plain_obj,  [{}],         true]
    - [array,      [[1, 2, 3]],  true]
    - [null_v,     [null],       false]
    - [number,     [42],         false]
    - [string,     ["hello"],    false]
