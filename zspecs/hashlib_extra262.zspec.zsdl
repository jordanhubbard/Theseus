spec: hashlib_extra262
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/_sha512module.c"
    - "CPython source: Modules/md5module.c"
    - "hashlib_extra261.zspec.zsdl — covers sha3_256/blake2b/blake2s/pbkdf2_hmac/scrypt function identity (name, qualname, module, class)."
    - "hashlib.zspec — covers hash_object_attr for sha256 digest_size/block_size; sha1/md5/sha512 digest_size via hash_object_attr table; sha256.name_attr invariant; no python_call_eq coverage of sha256()/md5()/sha1()/sha512() digest_size/block_size/name via python_call_eq kind."
  notes:
    - "hashlib.sha256() returns a HASH object (CPython OpenSSL backend); digest_size==32, block_size==64, name=='sha256'."
    - "hashlib.md5() returns a HASH object; digest_size==16, block_size==64, name=='md5'."
    - "hashlib.sha1() returns a HASH object; digest_size==20, block_size==64, name=='sha1'."
    - "hashlib.sha512() returns a HASH object; digest_size==64, block_size==128, name=='sha512'."
    - "hashlib.sha256.__name__ == 'openssl_sha256'; hashlib.md5.__name__ == 'openssl_md5'; hashlib.sha1.__name__ == 'openssl_sha1'; hashlib.sha512.__name__ == 'openssl_sha512' — all are builtin_function_or_method from _hashlib."
    - "hashlib.sha256.__module__ == '_hashlib'; same for md5, sha1, sha512 — all backed by _hashlib C extension."
    - "This spec provides python_call_eq coverage of digest_size/block_size/name properties on sha256()/md5()/sha1()/sha512() instances, and function identity (name, module, class) for the four constructors. All values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sha256/md5/sha1/sha512 constructor function identity
#
# All four constructors are builtin_function_or_method from the _hashlib
# C extension, exposed under their openssl_* names.
# ---------------------------------------------------------------------------

table hashlib_extra262.constructors_identity:
  description: "hashlib sha256/md5/sha1/sha512 constructor function identity — all are builtin_function_or_method from _hashlib; __name__ uses openssl_* prefix; __module__ == '_hashlib'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibctr262

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_name,   sha256.__name__.__eq__,              ["openssl_sha256"],             true, "hashlib.sha256.__name__ == 'openssl_sha256' (CPython OpenSSL backend)"]
    - [sha256_module, sha256.__module__.__eq__,            ["_hashlib"],                   true, "hashlib.sha256.__module__ == '_hashlib'"]
    - [sha256_class,  sha256.__class__.__name__.__eq__,    ["builtin_function_or_method"], true, "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method'"]
    - [md5_name,      md5.__name__.__eq__,                 ["openssl_md5"],                true, "hashlib.md5.__name__ == 'openssl_md5'"]
    - [md5_module,    md5.__module__.__eq__,               ["_hashlib"],                   true, "hashlib.md5.__module__ == '_hashlib'"]
    - [md5_class,     md5.__class__.__name__.__eq__,       ["builtin_function_or_method"], true, "hashlib.md5.__class__.__name__ == 'builtin_function_or_method'"]
    - [sha1_name,     sha1.__name__.__eq__,                ["openssl_sha1"],               true, "hashlib.sha1.__name__ == 'openssl_sha1'"]
    - [sha1_module,   sha1.__module__.__eq__,              ["_hashlib"],                   true, "hashlib.sha1.__module__ == '_hashlib'"]
    - [sha1_class,    sha1.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "hashlib.sha1.__class__.__name__ == 'builtin_function_or_method'"]
    - [sha512_name,   sha512.__name__.__eq__,              ["openssl_sha512"],             true, "hashlib.sha512.__name__ == 'openssl_sha512'"]
    - [sha512_module, sha512.__module__.__eq__,            ["_hashlib"],                   true, "hashlib.sha512.__module__ == '_hashlib'"]
    - [sha512_class,  sha512.__class__.__name__.__eq__,    ["builtin_function_or_method"], true, "hashlib.sha512.__class__.__name__ == 'builtin_function_or_method'"]

# ---------------------------------------------------------------------------
# sha256() instance digest_size, block_size, name via python_call_eq
#
# hashlib.sha256() returns a HASH object.
# digest_size == 32 (256-bit output), block_size == 64 (512-bit block),
# name == 'sha256'.
# ---------------------------------------------------------------------------

invariant hashlib_extra262.sha256.digest_size:
  description: "hashlib.sha256().digest_size == 32 — SHA-256 produces 256-bit (32-byte) digests; FIPS 180-4"
  category: properties
  kind: python_call_eq
  function: sha256
  args: []
  method: digest_size.__eq__
  method_args: [32]
  expected: true

invariant hashlib_extra262.sha256.block_size:
  description: "hashlib.sha256().block_size == 64 — SHA-256 uses a 512-bit (64-byte) compression block; FIPS 180-4"
  category: properties
  kind: python_call_eq
  function: sha256
  args: []
  method: block_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra262.sha256.name:
  description: "hashlib.sha256().name == 'sha256' — the HASH object .name attribute identifies the algorithm"
  category: properties
  kind: python_call_eq
  function: sha256
  args: []
  method: name.__eq__
  method_args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# md5() instance digest_size, block_size, name via python_call_eq
# ---------------------------------------------------------------------------

invariant hashlib_extra262.md5.digest_size:
  description: "hashlib.md5().digest_size == 16 — MD5 produces 128-bit (16-byte) digests; RFC 1321"
  category: properties
  kind: python_call_eq
  function: md5
  args: []
  method: digest_size.__eq__
  method_args: [16]
  expected: true

invariant hashlib_extra262.md5.block_size:
  description: "hashlib.md5().block_size == 64 — MD5 uses a 512-bit (64-byte) compression block; RFC 1321"
  category: properties
  kind: python_call_eq
  function: md5
  args: []
  method: block_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra262.md5.name:
  description: "hashlib.md5().name == 'md5'"
  category: properties
  kind: python_call_eq
  function: md5
  args: []
  method: name.__eq__
  method_args: ["md5"]
  expected: true

# ---------------------------------------------------------------------------
# sha1() instance digest_size, block_size, name via python_call_eq
# ---------------------------------------------------------------------------

invariant hashlib_extra262.sha1.digest_size:
  description: "hashlib.sha1().digest_size == 20 — SHA-1 produces 160-bit (20-byte) digests; FIPS 180-4"
  category: properties
  kind: python_call_eq
  function: sha1
  args: []
  method: digest_size.__eq__
  method_args: [20]
  expected: true

invariant hashlib_extra262.sha1.block_size:
  description: "hashlib.sha1().block_size == 64 — SHA-1 uses a 512-bit (64-byte) compression block; FIPS 180-4"
  category: properties
  kind: python_call_eq
  function: sha1
  args: []
  method: block_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra262.sha1.name:
  description: "hashlib.sha1().name == 'sha1'"
  category: properties
  kind: python_call_eq
  function: sha1
  args: []
  method: name.__eq__
  method_args: ["sha1"]
  expected: true

# ---------------------------------------------------------------------------
# sha512() instance digest_size, block_size, name via python_call_eq
# ---------------------------------------------------------------------------

invariant hashlib_extra262.sha512.digest_size:
  description: "hashlib.sha512().digest_size == 64 — SHA-512 produces 512-bit (64-byte) digests; FIPS 180-4"
  category: properties
  kind: python_call_eq
  function: sha512
  args: []
  method: digest_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra262.sha512.block_size:
  description: "hashlib.sha512().block_size == 128 — SHA-512 uses a 1024-bit (128-byte) compression block; FIPS 180-4"
  category: properties
  kind: python_call_eq
  function: sha512
  args: []
  method: block_size.__eq__
  method_args: [128]
  expected: true

invariant hashlib_extra262.sha512.name:
  description: "hashlib.sha512().name == 'sha512'"
  category: properties
  kind: python_call_eq
  function: sha512
  args: []
  method: name.__eq__
  method_args: ["sha512"]
  expected: true
