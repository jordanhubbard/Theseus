spec: multiprocessing_extra45
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.context.BaseContext — BaseContext documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra44.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__ tables, DefaultContext method qualname lengths, BaseProcess metadata, function __name__.__len__() tables, pool result class tables, Process/__name__=='Process', Process/__module__=='multiprocessing.context', Queue/__name__=='Queue', Pipe/__name__=='Pipe', Process method qualname lens for start/join/run, Process.__bases__[0].__name__=='BaseProcess'/__mro__.__len__()==3/Manager.__name__=='Manager', function __name__/__module__ string equality for cpu_count/current_process/active_children, AuthenticationError/__name__/__module__/__bases__[0].__name__, ProcessError/__name__/__bases__[0].__name__, BufferTooShort/__name__, TimeoutError/__name__/__bases__[0].__name__, all four exception __module__ string equality, ProcessError/__mro__.__len__()==4, exception subclass MRO depths, Process/__qualname__=='Process', Process/__qualname__.__len__()==7, context.BaseContext/__name__=='BaseContext', Queue/__qualname__=='BaseContext.Queue', Pipe/__qualname__=='BaseContext.Pipe', cpu_count/__qualname__=='BaseContext.cpu_count', current_process/__qualname__=='current_process', active_children/__qualname__=='active_children', get_start_method/__qualname__=='DefaultContext.get_start_method', set_start_method/__name__=='set_start_method', ProcessError/__qualname__=='ProcessError', AuthenticationError/__qualname__=='AuthenticationError', TimeoutError/__qualname__=='TimeoutError', BufferTooShort/__qualname__=='BufferTooShort', BaseContext/__qualname__/__module__/__mro__.__len__(), SpawnContext/ForkContext/ForkServerContext/DefaultContext __name__ equality, context subclass __qualname__.__len__() tables, context subclass __mro__.__len__()==3 (extra43), SpawnContext/ForkContext/ForkServerContext/DefaultContext __qualname__ string equality, all four context subclass __module__ string equality and __module__.__len__()==23 (extra44)."
    - "This spec covers: Process/__class__.__name__=='type'; cpu_count/__class__.__name__=='method' (bound method of DefaultContext instance); current_process/__class__.__name__=='function'; active_children/__class__.__name__=='function'; ProcessError/__class__.__name__=='type'; AuthenticationError/__class__.__name__=='type'; context.SpawnContext/__class__.__name__=='type'; context.BaseContext/__class__.__name__=='type'; __class__.__name__.__len__() for all eight objects."
    - "multiprocessing.Process.__class__.__name__ == 'type'. Process is a plain Python class in multiprocessing.process; its metaclass is the built-in 'type'. __class__.__name__ == 'type' (4 chars). Verified with Python 3.14.3."
    - "multiprocessing.cpu_count.__class__.__name__ == 'method'. cpu_count is exposed from the multiprocessing namespace as a bound method of the DefaultContext instance (the default context singleton). The module-level name multiprocessing.cpu_count is thus an instance of 'method' (a bound method), not 'function'. len('method') == 6. Verified with Python 3.14.3."
    - "multiprocessing.current_process.__class__.__name__ == 'function'. current_process is a standalone function in multiprocessing.process (not a context method bound to the singleton); its __class__.__name__ == 'function' (8 chars). Verified with Python 3.14.3."
    - "multiprocessing.active_children.__class__.__name__ == 'function'. active_children is a standalone function in multiprocessing.process; its __class__.__name__ == 'function' (8 chars). Verified with Python 3.14.3."
    - "multiprocessing.ProcessError.__class__.__name__ == 'type'. ProcessError is an exception class; its metaclass is the built-in 'type'. __class__.__name__ == 'type' (4 chars). Verified with Python 3.14.3."
    - "multiprocessing.AuthenticationError.__class__.__name__ == 'type'. AuthenticationError is an exception class; its metaclass is the built-in 'type'. __class__.__name__ == 'type' (4 chars). Verified with Python 3.14.3."
    - "multiprocessing.context.SpawnContext.__class__.__name__ == 'type'. SpawnContext is a plain Python class in context.py; its metaclass is the built-in 'type'. __class__.__name__ == 'type' (4 chars). Verified with Python 3.14.3."
    - "multiprocessing.context.BaseContext.__class__.__name__ == 'type'. BaseContext is a plain Python abstract base class in context.py; its metaclass is the built-in 'type'. __class__.__name__ == 'type' (4 chars). Verified with Python 3.14.3."
    - "cpu_count is a notable exception among the multiprocessing callables: it resolves as a bound method ('method', 6 chars) rather than a plain function ('function', 8 chars). This is because multiprocessing uses a DefaultContext singleton and exposes most of its public API (including cpu_count) as bound methods of that singleton. current_process and active_children are defined directly in multiprocessing.process and are not delegated through the context, so they remain plain functions. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing class __class__.__name__ string equality — extra45
#
# All six class-type objects have __class__.__name__ == 'type':
#   Process.__class__.__name__                   == 'type'
#   ProcessError.__class__.__name__              == 'type'
#   AuthenticationError.__class__.__name__       == 'type'
#   context.SpawnContext.__class__.__name__      == 'type'
#   context.BaseContext.__class__.__name__       == 'type'
# Prior specs captured __name__/__module__/__qualname__ string equality for
# these classes. Extra45 captures the metaclass identity via __class__.__name__.
# ---------------------------------------------------------------------------

table multiprocessing_extra45.class_metaclass_name_eq:
  description: "multiprocessing class __class__.__name__ string equality in extra45 namespace — classes all have metaclass 'type'"
  kind: python_call_eq
  category: class_names
  id_prefix: mpClsMetaNameEq45

  columns: [id, function, args, expected, description]
  rows:
    - [Process,             Process.__class__.__name__.__eq__,                       ["type"], true, "Process.__class__.__name__ == 'type' — plain Python class; metaclass is built-in type (4 chars)"]
    - [ProcessError,        ProcessError.__class__.__name__.__eq__,                  ["type"], true, "ProcessError.__class__.__name__ == 'type' — exception class; metaclass is built-in type (4 chars)"]
    - [AuthenticationError, AuthenticationError.__class__.__name__.__eq__,           ["type"], true, "AuthenticationError.__class__.__name__ == 'type' — exception class; metaclass is built-in type (4 chars)"]
    - [SpawnContext,        "context.SpawnContext.__class__.__name__.__eq__",         ["type"], true, "SpawnContext.__class__.__name__ == 'type' — plain Python class in context.py; metaclass is built-in type (4 chars)"]
    - [BaseContext,         "context.BaseContext.__class__.__name__.__eq__",          ["type"], true, "BaseContext.__class__.__name__ == 'type' — abstract base class in context.py; metaclass is built-in type (4 chars)"]

# ---------------------------------------------------------------------------
# multiprocessing callable __class__.__name__ — extra45
#
# cpu_count is a bound method (not a plain function):
#   cpu_count.__class__.__name__      == 'method'    (6 chars)
# current_process and active_children are plain functions:
#   current_process.__class__.__name__ == 'function' (8 chars)
#   active_children.__class__.__name__ == 'function' (8 chars)
#
# cpu_count is exposed as a bound method of the DefaultContext singleton;
# current_process and active_children are defined directly in process.py
# and not delegated through the context object.
# ---------------------------------------------------------------------------

table multiprocessing_extra45.callable_class_name_eq:
  description: "multiprocessing callable __class__.__name__ string equality in extra45 namespace — cpu_count is 'method', others are 'function'"
  kind: python_call_eq
  category: class_names
  id_prefix: mpCallClsNameEq45

  columns: [id, function, args, expected, description]
  rows:
    - [cpu_count,        cpu_count.__class__.__name__.__eq__,        ["method"],   true, "cpu_count.__class__.__name__ == 'method' — bound method of DefaultContext singleton; not a plain function (6 chars)"]
    - [current_process,  current_process.__class__.__name__.__eq__,  ["function"], true, "current_process.__class__.__name__ == 'function' — standalone function in process.py (8 chars)"]
    - [active_children,  active_children.__class__.__name__.__eq__,  ["function"], true, "active_children.__class__.__name__ == 'function' — standalone function in process.py (8 chars)"]

# ---------------------------------------------------------------------------
# multiprocessing object __class__.__name__.__len__() — extra45
#
# Classes (__class__.__name__ == 'type'):
#   Process/ProcessError/AuthenticationError/SpawnContext/BaseContext == 4
# Callables:
#   cpu_count.__class__.__name__.__len__()       == 6  ('method')
#   current_process.__class__.__name__.__len__() == 8  ('function')
#   active_children.__class__.__name__.__len__() == 8  ('function')
# ---------------------------------------------------------------------------

table multiprocessing_extra45.object_class_name_lengths:
  description: "multiprocessing object __class__.__name__.__len__() in extra45 namespace — classes == 4, method == 6, functions == 8"
  kind: python_call_eq
  category: class_names
  id_prefix: mpObjClsNameLen45

  columns: [id, function, args, expected, description]
  rows:
    - [Process,             Process.__class__.__name__.__len__,                      [], 4, "Process.__class__.__name__.__len__() == 4 — 'type' has 4 characters"]
    - [ProcessError,        ProcessError.__class__.__name__.__len__,                 [], 4, "ProcessError.__class__.__name__.__len__() == 4 — 'type' has 4 characters"]
    - [AuthenticationError, AuthenticationError.__class__.__name__.__len__,          [], 4, "AuthenticationError.__class__.__name__.__len__() == 4 — 'type' has 4 characters"]
    - [SpawnContext,        "context.SpawnContext.__class__.__name__.__len__",        [], 4, "SpawnContext.__class__.__name__.__len__() == 4 — 'type' has 4 characters"]
    - [BaseContext,         "context.BaseContext.__class__.__name__.__len__",         [], 4, "BaseContext.__class__.__name__.__len__() == 4 — 'type' has 4 characters"]
    - [cpu_count,           cpu_count.__class__.__name__.__len__,                    [], 6, "cpu_count.__class__.__name__.__len__() == 6 — 'method' has 6 characters; cpu_count is a bound method"]
    - [current_process,     current_process.__class__.__name__.__len__,              [], 8, "current_process.__class__.__name__.__len__() == 8 — 'function' has 8 characters"]
    - [active_children,     active_children.__class__.__name__.__len__,              [], 8, "active_children.__class__.__name__.__len__() == 8 — 'function' has 8 characters"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra45
# ---------------------------------------------------------------------------

invariant multiprocessing_extra45.Process_class_name_eq:
  description: "multiprocessing.Process.__class__.__name__ == 'type' — plain Python class in process.py; metaclass is built-in type (4 chars)"
  category: class_names
  kind: python_call_eq
  function: Process.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant multiprocessing_extra45.cpu_count_class_name_eq:
  description: "multiprocessing.cpu_count.__class__.__name__ == 'method' — bound method of DefaultContext singleton; not a plain function (6 chars)"
  category: class_names
  kind: python_call_eq
  function: cpu_count.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra45.current_process_class_name_eq:
  description: "multiprocessing.current_process.__class__.__name__ == 'function' — standalone function defined directly in process.py (8 chars)"
  category: class_names
  kind: python_call_eq
  function: current_process.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant multiprocessing_extra45.active_children_class_name_eq:
  description: "multiprocessing.active_children.__class__.__name__ == 'function' — standalone function defined directly in process.py (8 chars)"
  category: class_names
  kind: python_call_eq
  function: active_children.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant multiprocessing_extra45.ProcessError_class_name_eq:
  description: "multiprocessing.ProcessError.__class__.__name__ == 'type' — exception class; metaclass is built-in type (4 chars)"
  category: class_names
  kind: python_call_eq
  function: ProcessError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant multiprocessing_extra45.AuthenticationError_class_name_eq:
  description: "multiprocessing.AuthenticationError.__class__.__name__ == 'type' — exception class; metaclass is built-in type (4 chars)"
  category: class_names
  kind: python_call_eq
  function: AuthenticationError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant multiprocessing_extra45.SpawnContext_class_name_eq:
  description: "multiprocessing.context.SpawnContext.__class__.__name__ == 'type' — plain Python class in context.py; metaclass is built-in type (4 chars)"
  category: class_names
  kind: python_call_eq
  function: "context.SpawnContext.__class__.__name__.__eq__"
  args: ["type"]
  expected: true

invariant multiprocessing_extra45.BaseContext_class_name_eq:
  description: "multiprocessing.context.BaseContext.__class__.__name__ == 'type' — abstract base class in context.py; metaclass is built-in type (4 chars)"
  category: class_names
  kind: python_call_eq
  function: "context.BaseContext.__class__.__name__.__eq__"
  args: ["type"]
  expected: true

invariant multiprocessing_extra45.cpu_count_class_name_len:
  description: "multiprocessing.cpu_count.__class__.__name__.__len__() == 6 — 'method' has 6 characters; cpu_count is a bound method of DefaultContext"
  category: class_names
  kind: python_call_eq
  function: cpu_count.__class__.__name__.__len__
  args: []
  expected: 6

invariant multiprocessing_extra45.current_process_class_name_len:
  description: "multiprocessing.current_process.__class__.__name__.__len__() == 8 — 'function' has 8 characters"
  category: class_names
  kind: python_call_eq
  function: current_process.__class__.__name__.__len__
  args: []
  expected: 8

invariant multiprocessing_extra45.Process_class_name_len:
  description: "multiprocessing.Process.__class__.__name__.__len__() == 4 — 'type' has 4 characters"
  category: class_names
  kind: python_call_eq
  function: Process.__class__.__name__.__len__
  args: []
  expected: 4
