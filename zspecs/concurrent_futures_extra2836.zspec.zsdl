spec: concurrent_futures_extra2836
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "concurrent_futures_extra.zspec.zsdl — covers class names, module checks, function names, constant type checks"
    - "concurrent_futures_extra2.zspec.zsdl — covers module checks, constant values, method names"
    - "concurrent_futures_extra2806.zspec.zsdl — covers __ilshift__, __irshift__, __ipow__ dict-presence checks"
    - "concurrent_futures_extra2821.zspec.zsdl — covers __radd__, __rsub__, __rmul__ dict-presence checks"
  notes:
    - "Wave 636 theme: __rtruediv__, __rfloordiv__, and __rmod__ dict-presence checks (reflected true division, floor division, modulo operators)."
    - "None of the concurrent.futures public classes define __rtruediv__, __rfloordiv__, or __rmod__ in their __dict__."
    - "Future is a pure-Python result container; ThreadPoolExecutor and ProcessPoolExecutor are executor pool classes."
    - "'__rtruediv__' in Future.__dict__ == False; likewise for __rfloordiv__ and __rmod__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future — __rtruediv__/__rfloordiv__/__rmod__
# dict-presence checks
#
# Future is a pure-Python result container (Lib/concurrent/futures/_base.py).
# It wraps the result of an async computation. It does not define reflected
# division or modulo operator dunders: __rtruediv__, __rfloordiv__, or __rmod__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2836.future_operator_dict:
  description: "concurrent.futures.Future __rtruediv__, __rfloordiv__, __rmod__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2836f

  columns: [id, function, args, expected]
  rows:
    - ["cf2836f_rtd",  Future.__dict__.__contains__, ["__rtruediv__"],   false]
    - ["cf2836f_rfd",  Future.__dict__.__contains__, ["__rfloordiv__"],  false]
    - ["cf2836f_rmd",  Future.__dict__.__contains__, ["__rmod__"],       false]

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor — __rtruediv__/__rfloordiv__/__rmod__
# dict-presence checks
#
# ThreadPoolExecutor manages a pool of threads and dispatches callables to them.
# It does not implement reflected division or modulo operator dunders.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2836.threadpoolexecutor_operator_dict:
  description: "concurrent.futures.ThreadPoolExecutor __rtruediv__, __rfloordiv__, __rmod__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2836tpe

  columns: [id, function, args, expected]
  rows:
    - ["cf2836tpe_rtd",  ThreadPoolExecutor.__dict__.__contains__, ["__rtruediv__"],   false]
    - ["cf2836tpe_rfd",  ThreadPoolExecutor.__dict__.__contains__, ["__rfloordiv__"],  false]
    - ["cf2836tpe_rmd",  ThreadPoolExecutor.__dict__.__contains__, ["__rmod__"],       false]

# ---------------------------------------------------------------------------
# concurrent.futures.ProcessPoolExecutor — __rtruediv__/__rfloordiv__/__rmod__
# dict-presence checks
#
# ProcessPoolExecutor manages a pool of worker processes. Like ThreadPoolExecutor,
# it is a task dispatching class and does not define reflected division or modulo operator dunders.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2836.processpoolexecutor_operator_dict:
  description: "concurrent.futures.ProcessPoolExecutor __rtruediv__, __rfloordiv__, __rmod__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2836ppe

  columns: [id, function, args, expected]
  rows:
    - ["cf2836ppe_rtd",  ProcessPoolExecutor.__dict__.__contains__, ["__rtruediv__"],   false]
    - ["cf2836ppe_rfd",  ProcessPoolExecutor.__dict__.__contains__, ["__rfloordiv__"],  false]
    - ["cf2836ppe_rmd",  ProcessPoolExecutor.__dict__.__contains__, ["__rmod__"],       false]

# ---------------------------------------------------------------------------
# Full 3×3 cross-type matrix — all concurrent.futures types, all three reflected division/modulo operator dunders
#
# Consolidates the complete 3×3 dict-presence check in one table.
# Every cell is False: Future, ThreadPoolExecutor, and ProcessPoolExecutor
# do not define /, //, or % reflected operator dunders in their __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2836.all_types_rtruediv_rfloordiv_rmod_matrix:
  description: "Full 3×3 dict-presence matrix for concurrent.futures types vs __rtruediv__/__rfloordiv__/__rmod__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
