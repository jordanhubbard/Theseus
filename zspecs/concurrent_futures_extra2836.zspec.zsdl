  id_prefix: cf2836mx

  columns: [id, function, args, expected]
  rows:
    - ["cf2836mx_f_rtd",   Future.__dict__.__contains__,              ["__rtruediv__"],   false]
    - ["cf2836mx_f_rfd",   Future.__dict__.__contains__,              ["__rfloordiv__"],  false]
    - ["cf2836mx_f_rmd",   Future.__dict__.__contains__,              ["__rmod__"],       false]
    - ["cf2836mx_tpe_rtd", ThreadPoolExecutor.__dict__.__contains__,  ["__rtruediv__"],   false]
    - ["cf2836mx_tpe_rfd", ThreadPoolExecutor.__dict__.__contains__,  ["__rfloordiv__"],  false]
    - ["cf2836mx_tpe_rmd", ThreadPoolExecutor.__dict__.__contains__,  ["__rmod__"],       false]
    - ["cf2836mx_ppe_rtd", ProcessPoolExecutor.__dict__.__contains__, ["__rtruediv__"],   false]
