spec: multiprocessing_extra128
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec covers: wave 255 theme — multiprocessing.__all__ list identity and multiprocessing.process.BaseProcess method co_varnames. NEW in extra128: multiprocessing.__all__.__class__.__name__=='list'; multiprocessing.__all__.__len__()==37; multiprocessing.__all__.__contains__('Process')==True; multiprocessing.__all__.__contains__('Pool')==True; multiprocessing.__all__.__contains__('Queue')==True; multiprocessing.__all__.__contains__('Lock')==True; multiprocessing.__all__.__contains__('Event')==True; multiprocessing.__all__.__contains__('Pipe')==True; multiprocessing.__all__.__contains__('Manager')==True; multiprocessing.process.BaseProcess.start.__code__.co_varnames[0]=='self'; multiprocessing.process.BaseProcess.start.__code__.co_argcount==1; multiprocessing.process.BaseProcess.run.__code__.co_varnames[0]=='self'; multiprocessing.process.BaseProcess.run.__code__.co_argcount==1; multiprocessing.process.BaseProcess.join.__code__.co_varnames[0]=='self'; multiprocessing.process.BaseProcess.join.__code__.co_argcount==2; multiprocessing.process.BaseProcess.is_alive.__code__.co_varnames[0]=='self'; multiprocessing.process.BaseProcess.is_alive.__code__.co_argcount==1; multiprocessing.process.BaseProcess.terminate.__code__.co_varnames[0]=='self'; multiprocessing.process.BaseProcess.terminate.__code__.co_argcount==1; multiprocessing.process.BaseProcess.__init__.__code__.co_argcount==6. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.__all__.__len__() == 37. The 37-element list covers process classes, IPC primitives (Queue, Pipe), synchronization (Lock, Event, Semaphore, Condition), Pool, Manager, and utility functions. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.process.BaseProcess.start.__code__.co_argcount == 1. BaseProcess.start takes only 'self' — no timeout or other parameters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.process.BaseProcess.join.__code__.co_argcount == 2. BaseProcess.join takes 'self' and 'timeout' (optional timeout in seconds). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.process.BaseProcess.__init__.__code__.co_argcount == 6. BaseProcess.__init__ takes (self, group, target, name, args, kwargs) — 6 positional parameters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.__all__ list class identity — extra128
#
# Wave 255 theme: multiprocessing.__all__ is a list and membership tests.
#
# multiprocessing.__all__.__class__.__name__ == 'list'
# multiprocessing.__all__.__len__() == 37
# multiprocessing.__all__.__contains__('Process') == True
# multiprocessing.__all__.__contains__('Pool') == True
# multiprocessing.__all__.__contains__('Queue') == True
# multiprocessing.__all__.__contains__('Lock') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra128.mp_all_class_identity:
  description: "multiprocessing.__all__ class identity and core membership checks in mpall128 namespace — wave 255 theme: multiprocessing.__all__ is a list; multiprocessing.__all__.__class__.__name__.__eq__('list')==True (defined in Lib/multiprocessing/__init__.py; a mutable list unlike asyncio.__all__ which is a tuple); multiprocessing.__all__.__len__()==37 (37 entries: process management, IPC, synchronization, pool, manager, utilities — substantially larger than concurrent.futures.__all__ len=14 but smaller than asyncio.__all__ len=95); multiprocessing.__all__.__contains__('Process')==True (the main process class); multiprocessing.__all__.__contains__('Pool')==True (the worker pool); multiprocessing.__all__.__contains__('Queue')==True (IPC queue); multiprocessing.__all__.__contains__('Lock')==True (process lock); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: mpall128

  columns: [id, function, args, expected, description]
  rows:
    - [all_cls,       multiprocessing.__all__.__class__.__name__.__eq__, ["list"],    true, "multiprocessing.__all__.__class__.__name__ == 'list' — a list like concurrent.futures but unlike asyncio's tuple; verified with Python 3.14.3"]
    - [all_len,       multiprocessing.__all__.__len__,                   [],          37,   "multiprocessing.__all__.__len__() == 37; verified with Python 3.14.3"]
    - [has_process,   multiprocessing.__all__.__contains__,              ["Process"], true, "multiprocessing.__all__.__contains__('Process') == True — main process class; verified with Python 3.14.3"]
    - [has_pool,      multiprocessing.__all__.__contains__,              ["Pool"],    true, "multiprocessing.__all__.__contains__('Pool') == True — worker pool; verified with Python 3.14.3"]
    - [has_queue,     multiprocessing.__all__.__contains__,              ["Queue"],   true, "multiprocessing.__all__.__contains__('Queue') == True — IPC queue; verified with Python 3.14.3"]
    - [has_lock,      multiprocessing.__all__.__contains__,              ["Lock"],    true, "multiprocessing.__all__.__contains__('Lock') == True — process lock; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.__all__ IPC and sync primitive membership — extra128
#
# multiprocessing.__all__.__contains__('Event') == True
# multiprocessing.__all__.__contains__('Pipe') == True
# multiprocessing.__all__.__contains__('Manager') == True
# multiprocessing.__all__.__contains__('Barrier') == True
# multiprocessing.__all__.__contains__('Semaphore') == True
# multiprocessing.__all__.__contains__('Value') == True
# multiprocessing.__all__.__contains__('Array') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra128.mp_all_ipc_membership:
  description: "multiprocessing.__all__ IPC and synchronization primitive membership checks in mpall128 namespace — wave 255 theme: IPC primitives and synchronization objects in multiprocessing.__all__; multiprocessing.__all__.__contains__('Event')==True (process event for inter-process signaling); multiprocessing.__all__.__contains__('Pipe')==True (bidirectional IPC channel); multiprocessing.__all__.__contains__('Manager')==True (shared-state manager for distributed objects); multiprocessing.__all__.__contains__('Barrier')==True (process barrier for synchronization); multiprocessing.__all__.__contains__('Semaphore')==True (counting semaphore for process sync); multiprocessing.__all__.__contains__('Value')==True (shared memory scalar); multiprocessing.__all__.__contains__('Array')==True (shared memory array); all 37 __all__ entries cover a broader IPC API than concurrent.futures (len=14); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: mpall128a

  columns: [id, function, args, expected, description]
  rows:
    - [has_event,    multiprocessing.__all__.__contains__, ["Event"],     true, "multiprocessing.__all__.__contains__('Event') == True — inter-process event; verified with Python 3.14.3"]
    - [has_pipe,     multiprocessing.__all__.__contains__, ["Pipe"],      true, "multiprocessing.__all__.__contains__('Pipe') == True — IPC channel; verified with Python 3.14.3"]
    - [has_manager,  multiprocessing.__all__.__contains__, ["Manager"],   true, "multiprocessing.__all__.__contains__('Manager') == True — shared-state manager; verified with Python 3.14.3"]
    - [has_barrier,  multiprocessing.__all__.__contains__, ["Barrier"],   true, "multiprocessing.__all__.__contains__('Barrier') == True — process barrier; verified with Python 3.14.3"]
    - [has_semaphore,multiprocessing.__all__.__contains__, ["Semaphore"], true, "multiprocessing.__all__.__contains__('Semaphore') == True — counting semaphore; verified with Python 3.14.3"]
    - [has_value,    multiprocessing.__all__.__contains__, ["Value"],     true, "multiprocessing.__all__.__contains__('Value') == True — shared memory scalar; verified with Python 3.14.3"]
    - [has_array,    multiprocessing.__all__.__contains__, ["Array"],     true, "multiprocessing.__all__.__contains__('Array') == True — shared memory array; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.process.BaseProcess method co_varnames — extra128
#
# BaseProcess.start.__code__.co_varnames[0] == 'self'  (co_argcount == 1)
# BaseProcess.run.__code__.co_varnames[0]   == 'self'  (co_argcount == 1)
# BaseProcess.join.__code__.co_varnames[0]  == 'self'  (co_argcount == 2)
# BaseProcess.is_alive.__code__.co_varnames[0] == 'self' (co_argcount == 1)
# BaseProcess.terminate.__code__.co_varnames[0] == 'self' (co_argcount == 1)
# BaseProcess.__init__.__code__.co_argcount == 6
# ---------------------------------------------------------------------------

table multiprocessing_extra128.mp_baseprocess_co_varnames:
  description: "multiprocessing.process.BaseProcess method co_varnames and co_argcount checks in mpall128 namespace — wave 255 theme: BaseProcess method code object attributes; all BaseProcess methods have 'self' as their first co_varname (co_varnames[0]=='self'); BaseProcess.start.__code__.co_varnames[0].__eq__('self')==True and co_argcount==1 (start takes only 'self'); BaseProcess.run.__code__.co_varnames[0].__eq__('self')==True and co_argcount==1 (run takes only 'self'; override in subclass to define process behavior); BaseProcess.join.__code__.co_varnames[0].__eq__('self')==True but co_argcount==2 (join takes 'self' and optional 'timeout'); BaseProcess.is_alive.__code__.co_varnames[0].__eq__('self')==True and co_argcount==1; BaseProcess.terminate.__code__.co_varnames[0].__eq__('self')==True and co_argcount==1; BaseProcess.__init__.__code__.co_argcount==6 (self, group, target, name, args, kwargs); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_introspection
  id_prefix: mpall128b

  columns: [id, function, args, expected, description]
  rows:
    - [start_var0,    "multiprocessing.process.BaseProcess.start.__code__.co_varnames.__getitem__",     [0],      "self", "BaseProcess.start.__code__.co_varnames[0] == 'self'; verified with Python 3.14.3"]
    - [start_argc,    "multiprocessing.process.BaseProcess.start.__code__.co_argcount.__eq__",          [1],      true,   "BaseProcess.start.__code__.co_argcount == 1 (only self); verified with Python 3.14.3"]
    - [run_var0,      "multiprocessing.process.BaseProcess.run.__code__.co_varnames.__getitem__",       [0],      "self", "BaseProcess.run.__code__.co_varnames[0] == 'self'; verified with Python 3.14.3"]
    - [run_argc,      "multiprocessing.process.BaseProcess.run.__code__.co_argcount.__eq__",            [1],      true,   "BaseProcess.run.__code__.co_argcount == 1 (only self); verified with Python 3.14.3"]
    - [join_var0,     "multiprocessing.process.BaseProcess.join.__code__.co_varnames.__getitem__",      [0],      "self", "BaseProcess.join.__code__.co_varnames[0] == 'self'; verified with Python 3.14.3"]
    - [join_argc,     "multiprocessing.process.BaseProcess.join.__code__.co_argcount.__eq__",           [2],      true,   "BaseProcess.join.__code__.co_argcount == 2 (self + timeout); verified with Python 3.14.3"]
    - [alive_var0,    "multiprocessing.process.BaseProcess.is_alive.__code__.co_varnames.__getitem__",  [0],      "self", "BaseProcess.is_alive.__code__.co_varnames[0] == 'self'; verified with Python 3.14.3"]
    - [alive_argc,    "multiprocessing.process.BaseProcess.is_alive.__code__.co_argcount.__eq__",       [1],      true,   "BaseProcess.is_alive.__code__.co_argcount == 1 (only self); verified with Python 3.14.3"]
    - [term_var0,     "multiprocessing.process.BaseProcess.terminate.__code__.co_varnames.__getitem__", [0],      "self", "BaseProcess.terminate.__code__.co_varnames[0] == 'self'; verified with Python 3.14.3"]
    - [term_argc,     "multiprocessing.process.BaseProcess.terminate.__code__.co_argcount.__eq__",      [1],      true,   "BaseProcess.terminate.__code__.co_argcount == 1 (only self); verified with Python 3.14.3"]
    - [init_argc,     "multiprocessing.process.BaseProcess.__init__.__code__.co_argcount.__eq__",       [6],      true,   "BaseProcess.__init__.__code__.co_argcount == 6 (self, group, target, name, args, kwargs); verified with Python 3.14.3"]
    - [init_var0,     "multiprocessing.process.BaseProcess.__init__.__code__.co_varnames.__getitem__",  [0],      "self", "BaseProcess.__init__.__code__.co_varnames[0] == 'self'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra128
# ---------------------------------------------------------------------------

invariant multiprocessing_extra128.mp_all_is_list:
  description: "multiprocessing.__all__.__class__.__name__.__eq__('list') returns True — multiprocessing.__all__ is a plain Python list defined in Lib/multiprocessing/__init__.py; this matches concurrent.futures.__all__ (also a list) and contrasts with asyncio.__all__ (a tuple); multiprocessing.__all__.__len__()==37; the 37 entries span process management (Process, active_children, current_process, parent_process), IPC (Queue, Pipe, SimpleQueue, JoinableQueue), synchronization (Lock, RLock, Event, Condition, Semaphore, BoundedSemaphore, Barrier), shared memory (Value, Array, RawValue, RawArray), Pool, Manager, and utility functions; NEW in extra128: first standalone multiprocessing.__all__ class name invariant in mpall128 namespace; wave 255; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: multiprocessing.__all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant multiprocessing_extra128.mp_all_len_is_37:
  description: "multiprocessing.__all__.__len__() == 37 — multiprocessing.__all__ has 37 entries covering the full public API for process-based parallelism; this is between concurrent.futures.__all__ (len=14, focused) and asyncio.__all__ (len=95, very broad); the 37 entries include: Array, AuthenticationError, Barrier, BoundedSemaphore, BufferTooShort, Condition, Event, JoinableQueue, Lock, Manager, Pipe, Pool, Process, ProcessError, Queue, RLock, RawArray, RawValue, Semaphore, SimpleQueue, TimeoutError, Value, active_children, allow_connection_pickling, cpu_count, current_process, freeze_support, get_all_start_methods, get_context, get_logger, get_start_method, log_to_stderr, parent_process, reducer, set_executable, set_forkserver_preload, set_start_method; NEW in extra128: first standalone multiprocessing.__all__ length invariant in mpall128 namespace; wave 255; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: multiprocessing.__all__.__len__
  args: []
  expected: 37

invariant multiprocessing_extra128.BaseProcess_start_co_argcount_1:
  description: "multiprocessing.process.BaseProcess.start.__code__.co_argcount == 1 — BaseProcess.start takes only 'self' (no other parameters); co_argcount counts positional parameters (excluding *args and **kwargs); co_varnames[0] is 'self'; BaseProcess.start starts the process in a new OS process by calling fork/spawn/forkserver depending on the start method; contrast: BaseProcess.join has co_argcount==2 (self + timeout) and BaseProcess.__init__ has co_argcount==6 (self + 5 init params); all single-self methods: start (argcount=1), run (argcount=1), is_alive (argcount=1), terminate (argcount=1); NEW in extra128: first standalone BaseProcess.start co_argcount invariant in mpall128 namespace; wave 255; verified with Python 3.14.3"
  category: code_introspection
  kind: python_call_eq
  function: "multiprocessing.process.BaseProcess.start.__code__.co_argcount.__eq__"
  args: [1]
  expected: true

invariant multiprocessing_extra128.BaseProcess_join_co_argcount_2:
  description: "multiprocessing.process.BaseProcess.join.__code__.co_argcount == 2 — BaseProcess.join takes 'self' and 'timeout' (optional seconds to wait); co_argcount==2 makes join unique among the single-purpose BaseProcess methods (start, run, is_alive, terminate all have co_argcount==1); join blocks until the process terminates or the timeout expires; co_varnames[0] is 'self'; this parallels threading.Thread.join which also has a timeout parameter; BaseProcess.__init__ has co_argcount==6, the highest; NEW in extra128: first standalone BaseProcess.join co_argcount invariant in mpall128 namespace; wave 255; verified with Python 3.14.3"
  category: code_introspection
  kind: python_call_eq
  function: "multiprocessing.process.BaseProcess.join.__code__.co_argcount.__eq__"
  args: [2]
  expected: true

invariant multiprocessing_extra128.BaseProcess_init_co_argcount_6:
  description: "multiprocessing.process.BaseProcess.__init__.__code__.co_argcount == 6 — BaseProcess.__init__ takes (self, group, target, name, args, kwargs): self (the process instance), group (reserved, always None), target (callable to run), name (process name string), args (positional args tuple), kwargs (keyword args dict); co_argcount==6 is the highest among all BaseProcess methods; co_varnames[0] is 'self'; compare: start=1, run=1, is_alive=1, terminate=1, join=2, __init__=6; the 5-parameter non-self signature (group, target, name, args, kwargs) matches the threading.Thread.__init__ signature almost exactly (Thread also has group, target, name, args, kwargs); NEW in extra128: first standalone BaseProcess.__init__ co_argcount invariant in mpall128 namespace; wave 255; verified with Python 3.14.3"
  category: code_introspection
  kind: python_call_eq
  function: "multiprocessing.process.BaseProcess.__init__.__code__.co_argcount.__eq__"
  args: [6]
  expected: true
