spec: pathlib_extra781
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "Python standard library documentation: pathlib module"
    - "CPython source: Lib/pathlib.py"
  not_derived_from:
    - "Any third-party path manipulation library"
  notes:
    - "Covers __qualname__ identity checks for pathlib.PurePath methods"
    - "PurePath is the abstract base; qualnames reflect that class name, not subclasses"
  created_at: "2026-04-12"

table pathlib_extra781.name:
  description: "Verifies __qualname__ strings for pathlib.PurePath methods"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: pb781xx
  columns: [id, function, args, expected]
  rows:
    - [pb781xx001, pathlib.PurePath.is_absolute.__qualname__.__eq__, ["PurePath.is_absolute"], true]
    - [pb781xx002, pathlib.PurePath.is_relative_to.__qualname__.__eq__, ["PurePath.is_relative_to"], true]
    - [pb781xx003, pathlib.PurePath.relative_to.__qualname__.__eq__, ["PurePath.relative_to"], true]
    - [pb781xx004, pathlib.PurePath.joinpath.__qualname__.__eq__, ["PurePath.joinpath"], true]
    - [pb781xx005, pathlib.PurePath.with_name.__qualname__.__eq__, ["PurePath.with_name"], true]
    - [pb781xx006, pathlib.PurePath.with_suffix.__qualname__.__eq__, ["PurePath.with_suffix"], true]
    - [pb781xx007, pathlib.PurePath.with_stem.__qualname__.__eq__, ["PurePath.with_stem"], true]
    - [pb781xx008, pathlib.PurePath.match.__qualname__.__eq__, ["PurePath.match"], true]
    - [pb781xx009, pathlib.PurePath.__str__.__qualname__.__eq__, ["PurePath.__str__"], true]
    - [pb781xx010, pathlib.PurePath.__repr__.__qualname__.__eq__, ["PurePath.__repr__"], true]
    - [pb781xx011, pathlib.PurePath.__fspath__.__qualname__.__eq__, ["PurePath.__fspath__"], true]
    - [pb781xx012, pathlib.PurePath.__bytes__.__qualname__.__eq__, ["PurePath.__bytes__"], true]
