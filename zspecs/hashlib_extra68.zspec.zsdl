spec: hashlib_extra68
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_blake2/blake2module.c"
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra67.zspec.zsdl — covers new.__code__.co_varnames.__class__.__name__=='tuple' / file_digest.__code__.co_varnames.__class__.__name__=='tuple' / new.__code__.co_varnames[0]=='name' / file_digest.__code__.co_varnames[0]=='fileobj' / new.__code__.co_filename.__contains__('.py') / file_digest.__code__.co_filename.__contains__('.py') / algorithms_guaranteed.__contains__ sha256/md5/sha1/sha512 (table + invariants)."
    - "hashlib_extra66.zspec.zsdl — covers new.__code__.co_name ('__hash_new') / file_digest.__code__.co_name / new.__code__.co_argcount==1 / file_digest.__code__.co_argcount==2 (table + invariants)."
    - "hashlib_extra65.zspec.zsdl — covers new.__defaults__.__class__.__name__.__eq__('NoneType') / file_digest.__defaults__.__class__.__name__.__eq__('NoneType') / new.__code__.__class__.__name__.__eq__('code') / file_digest.__code__.__class__.__name__.__eq__('code') (table + invariants)."
    - "hashlib_extra64.zspec.zsdl — covers hashlib.new and file_digest __annotations__.__class__.__name__.__eq__('dict') / __annotations__.__len__()==0 / new.__globals__.__class__.__name__.__eq__('dict') / new.__globals__.__contains__('new') (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra67; it does NOT duplicate invariants present in those files."
    - "Wave 232 theme: __code__.co_consts / co_nlocals / co_stacksize chains for Python functions + algorithms_guaranteed extended membership checks."
    - "hashlib.new.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is always a tuple of constants for a Python code object; new is a pure Python function in Lib/hashlib.py. No prior hashlib spec checks new.__code__.co_consts in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_consts.__class__.__name__ == 'tuple' — same reasoning; file_digest is a pure Python function. No prior hashlib spec checks file_digest.__code__.co_consts. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals is an integer count of local variables (parameters plus locals) for a code object. No prior hashlib spec checks new.__code__.co_nlocals. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_nlocals.__class__.__name__ == 'int' — same reasoning. No prior hashlib spec checks file_digest.__code__.co_nlocals. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is an integer indicating the required stack space for the code object. No prior hashlib spec checks new.__code__.co_stacksize. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_stacksize.__class__.__name__ == 'int' — same reasoning. No prior hashlib spec checks file_digest.__code__.co_stacksize. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True — sha3_256 is in algorithms_guaranteed per the Python docs (guaranteed on all Python platforms since 3.6). hashlib_extra67 checks sha256/md5/sha1/sha512 but not sha3_256 or sha3_512. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha3_512') == True — sha3_512 is in algorithms_guaranteed. No prior hashlib spec checks sha3_512 membership. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha224') == True — sha224 is in algorithms_guaranteed. No prior hashlib spec checks sha224 membership. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha384') == True — sha384 is in algorithms_guaranteed. No prior hashlib spec checks sha384 membership. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('blake2b') == True — blake2b is guaranteed in Python 3.6+ and is in algorithms_guaranteed. No prior hashlib spec checks blake2b membership. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('blake2s') == True — blake2s is guaranteed in Python 3.6+ and is in algorithms_guaranteed. No prior hashlib spec checks blake2s membership. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new and file_digest __code__.co_consts class name
#
# Wave 232 theme: __code__.co_consts chains for Python functions.
#
# co_consts is a tuple containing the constants used in the bytecode of a
# code object. Both new and file_digest are pure Python functions in
# Lib/hashlib.py, so their co_consts is always a tuple. No prior hashlib spec
# checks co_consts for any hashlib function. Verified Python 3.14.3 macOS.
# ---------------------------------------------------------------------------

table hashlib_extra68.co_consts_class_name:
  description: "hashlib.new.__code__.co_consts.__class__.__name__=='tuple' and file_digest.__code__.co_consts.__class__.__name__=='tuple' — co_consts is always a tuple of constants for Python code objects; both new and file_digest are pure Python functions in Lib/hashlib.py; no prior hashlib spec checks co_consts for any hashlib function; first co_consts anchor for hashlib"
  kind: python_call_eq
  category: code_objects
  id_prefix: hashlibcode4_68

  columns: [id, function, args, expected]
  rows:
    - [new_co_consts_class_name,         new.__code__.co_consts.__class__.__name__.__eq__,         ["tuple"], true]
    - [file_digest_co_consts_class_name, file_digest.__code__.co_consts.__class__.__name__.__eq__, ["tuple"], true]

# ---------------------------------------------------------------------------
# hashlib.new and file_digest __code__.co_nlocals class name
#
# Wave 232 theme: __code__.co_nlocals chains for Python functions.
#
# co_nlocals is an integer count of local variables (including parameters)
# used by the code object. Both new and file_digest are pure Python functions
# so co_nlocals is an int. No prior hashlib spec checks co_nlocals for any
# hashlib function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra68.co_nlocals_class_name:
  description: "hashlib.new.__code__.co_nlocals.__class__.__name__=='int' and file_digest.__code__.co_nlocals.__class__.__name__=='int' — co_nlocals is always an integer count of local variables for Python code objects; both new and file_digest are pure Python functions in Lib/hashlib.py; no prior hashlib spec checks co_nlocals for any hashlib function; first co_nlocals anchor for hashlib"
  kind: python_call_eq
  category: code_objects
  id_prefix: hashlibcode4_68

  columns: [id, function, args, expected]
  rows:
    - [new_co_nlocals_class_name,         new.__code__.co_nlocals.__class__.__name__.__eq__,         ["int"], true]
    - [file_digest_co_nlocals_class_name, file_digest.__code__.co_nlocals.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# hashlib.new and file_digest __code__.co_stacksize class name
#
# Wave 232 theme: __code__.co_stacksize chains for Python functions.
#
# co_stacksize is an integer indicating the required virtual machine stack
# space for the code object. Both new and file_digest are pure Python functions
# so co_stacksize is an int. No prior hashlib spec checks co_stacksize for any
# hashlib function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra68.co_stacksize_class_name:
  description: "hashlib.new.__code__.co_stacksize.__class__.__name__=='int' and file_digest.__code__.co_stacksize.__class__.__name__=='int' — co_stacksize is always an integer indicating required stack space for Python code objects; both new and file_digest are pure Python functions in Lib/hashlib.py; no prior hashlib spec checks co_stacksize for any hashlib function; first co_stacksize anchor for hashlib"
  kind: python_call_eq
  category: code_objects
  id_prefix: hashlibcode4_68

  columns: [id, function, args, expected]
  rows:
    - [new_co_stacksize_class_name,         new.__code__.co_stacksize.__class__.__name__.__eq__,         ["int"], true]
    - [file_digest_co_stacksize_class_name, file_digest.__code__.co_stacksize.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed extended membership checks
#
# Wave 232 theme: algorithms_guaranteed extended algorithm membership checks.
#
# hashlib.algorithms_guaranteed is a frozenset of hash algorithm names that
# are always available regardless of platform. hashlib_extra67 checks sha256,
# md5, sha1, sha512. This spec adds sha3_256, sha3_512, sha224, sha384,
# blake2b, blake2s — all guaranteed per the Python documentation since 3.6.
# No prior hashlib spec checks any of these six algorithm names.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra68.algorithms_guaranteed_extended:
  description: "hashlib.algorithms_guaranteed.__contains__ for sha3_256/sha3_512/sha224/sha384/blake2b/blake2s == True — all six are in algorithms_guaranteed per the Python docs; hashlib_extra67 checks sha256/md5/sha1/sha512 but not these six; sha3_256/sha3_512 are SHA-3 variants guaranteed since Python 3.6; sha224/sha384 are SHA-2 variants; blake2b/blake2s are BLAKE2 variants guaranteed since Python 3.6; no prior hashlib spec checks any of these six; extended membership anchor for algorithms_guaranteed"
  kind: python_call_eq
  category: module_constants
  id_prefix: hashlibcode4_68

  columns: [id, function, args, expected]
  rows:
    - [algorithms_guaranteed_sha3_256, algorithms_guaranteed.__contains__, ["sha3_256"], true]
    - [algorithms_guaranteed_sha3_512, algorithms_guaranteed.__contains__, ["sha3_512"], true]
    - [algorithms_guaranteed_sha224,   algorithms_guaranteed.__contains__, ["sha224"],   true]
    - [algorithms_guaranteed_sha384,   algorithms_guaranteed.__contains__, ["sha384"],   true]
    - [algorithms_guaranteed_blake2b,  algorithms_guaranteed.__contains__, ["blake2b"],  true]
    - [algorithms_guaranteed_blake2s,  algorithms_guaranteed.__contains__, ["blake2s"],  true]

# ---------------------------------------------------------------------------
# hashlib.new.__code__.co_consts.__class__.__name__.__eq__('tuple') — standalone
#
# hashlib.new is a pure Python function in Lib/hashlib.py. The code object's
# co_consts attribute is always a tuple — it contains the literal constants
# referenced in the bytecode. No prior hashlib spec checks new.__code__.co_consts
# in any form. First co_consts anchor for any hashlib function.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra68.new_co_consts_tuple:
  description: "hashlib.new.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — co_consts is always a tuple for Python code objects containing the literal constants used in bytecode; new is a pure Python function in Lib/hashlib.py so co_consts is a tuple; no prior hashlib spec checks new.__code__.co_consts; first co_consts anchor for any hashlib function"
  category: code_objects
  kind: python_call_eq
  function: new.__code__.co_consts.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__code__.co_nlocals.__class__.__name__.__eq__('int') — standalone
#
# hashlib.new is a pure Python function. The code object's co_nlocals is an
# integer counting the number of local variables (parameters + locals). No prior
# hashlib spec checks new.__code__.co_nlocals in any form. First co_nlocals
# anchor for any hashlib function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra68.new_co_nlocals_int:
  description: "hashlib.new.__code__.co_nlocals.__class__.__name__.__eq__('int') == True — co_nlocals is always an integer count of local variables for Python code objects; new is a pure Python function in Lib/hashlib.py; no prior hashlib spec checks new.__code__.co_nlocals; first co_nlocals anchor for any hashlib function"
  category: code_objects
  kind: python_call_eq
  function: new.__code__.co_nlocals.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__code__.co_stacksize.__class__.__name__.__eq__('int') — standalone
#
# hashlib.new is a pure Python function. The code object's co_stacksize is an
# integer indicating the required virtual machine stack space. No prior hashlib
# spec checks new.__code__.co_stacksize in any form. First co_stacksize anchor
# for any hashlib function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra68.new_co_stacksize_int:
  description: "hashlib.new.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — co_stacksize is always an integer indicating required VM stack space for Python code objects; new is a pure Python function in Lib/hashlib.py; no prior hashlib spec checks new.__code__.co_stacksize; first co_stacksize anchor for any hashlib function"
  category: code_objects
  kind: python_call_eq
  function: new.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha3_256') — standalone
#
# hashlib.algorithms_guaranteed is a frozenset of hash names always available
# regardless of platform. sha3_256 is a SHA-3 variant guaranteed in Python 3.6+.
# hashlib_extra67 checks sha256/md5/sha1/sha512 but not sha3_256. No prior
# hashlib spec checks algorithms_guaranteed.__contains__('sha3_256').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra68.algorithms_guaranteed_sha3_256:
  description: "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True — sha3_256 is a SHA-3 variant in algorithms_guaranteed per Python docs since 3.6; hashlib_extra67 checks sha256/md5/sha1/sha512 but not sha3_256; no prior hashlib spec checks sha3_256 membership; first SHA-3 membership anchor for algorithms_guaranteed"
  category: module_constants
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha3_256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('blake2b') — standalone
#
# blake2b is a BLAKE2 cryptographic hash function guaranteed in Python 3.6+
# and present in algorithms_guaranteed. hashlib_extra67 does not check blake2b
# membership. blake2b is a fast hash function widely used for checksums and
# non-cryptographic purposes. First BLAKE2 membership anchor for
# algorithms_guaranteed. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra68.algorithms_guaranteed_blake2b:
  description: "hashlib.algorithms_guaranteed.__contains__('blake2b') == True — blake2b is a BLAKE2 variant in algorithms_guaranteed guaranteed since Python 3.6; hashlib_extra67 does not check blake2b membership; no prior hashlib spec checks blake2b membership in algorithms_guaranteed; first BLAKE2 membership anchor for algorithms_guaranteed"
  category: module_constants
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["blake2b"]
  expected: true
