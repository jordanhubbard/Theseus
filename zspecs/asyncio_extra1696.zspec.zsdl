spec: asyncio_extra1696
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/pickle.html — Python pickle protocol documentation"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 560 (_extra1696): pickling protocol dict-presence checks."
    - "asyncio types are not picklable — they hold references to event loops, file descriptors, locks, and other OS resources that cannot be serialized."
    - "None of Future, Task, Lock, Queue, Semaphore, Event, Condition define __reduce__, __getstate__, __setstate__, __getnewargs__, or __getnewargs_ex__ in their own __dict__."
    - "asyncio types also do not define __copy__ or __deepcopy__ — shallow and deep copy are likewise unsupported."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: Pickling protocol methods absent from asyncio class __dict__
#
# __reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__
# are the five dunder hooks the pickle protocol consults.  None of the core
# asyncio event-loop-bound types define any of them in their own __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra1696.pickling_protocol:
  description: "asyncio types pickling protocol dict-presence checks — none of Future, Task, Lock, Queue define __reduce__ or related dunders in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1696

  columns: [id, function, args, expected]
  rows:
    - ["as1696001", "asyncio.Future.__dict__.__contains__",    ["__reduce__"],        false]
    - ["as1696002", "asyncio.Future.__dict__.__contains__",    ["__getstate__"],      false]
    - ["as1696003", "asyncio.Future.__dict__.__contains__",    ["__setstate__"],      false]
    - ["as1696004", "asyncio.Future.__dict__.__contains__",    ["__getnewargs__"],    false]
    - ["as1696005", "asyncio.Future.__dict__.__contains__",    ["__getnewargs_ex__"], false]
    - ["as1696006", "asyncio.Task.__dict__.__contains__",      ["__reduce__"],        false]
    - ["as1696007", "asyncio.Task.__dict__.__contains__",      ["__getstate__"],      false]
    - ["as1696008", "asyncio.Task.__dict__.__contains__",      ["__setstate__"],      false]
    - ["as1696009", "asyncio.Lock.__dict__.__contains__",      ["__reduce__"],        false]
    - ["as1696010", "asyncio.Lock.__dict__.__contains__",      ["__getstate__"],      false]
    - ["as1696011", "asyncio.Lock.__dict__.__contains__",      ["__setstate__"],      false]
    - ["as1696012", "asyncio.Queue.__dict__.__contains__",     ["__reduce__"],        false]
    - ["as1696013", "asyncio.Queue.__dict__.__contains__",     ["__getstate__"],      false]
    - ["as1696014", "asyncio.Queue.__dict__.__contains__",     ["__setstate__"],      false]

# ---------------------------------------------------------------------------
# Table 2: Copy protocol methods absent from asyncio class __dict__
#
# __copy__ and __deepcopy__ are the hooks consulted by copy.copy() and
# copy.deepcopy().  asyncio types do not define these either, for the same
# reason they are not picklable: they bind OS resources.
# ---------------------------------------------------------------------------

table asyncio_extra1696.copy_protocol:
  description: "asyncio types copy protocol dict-presence checks — Future, Task, Lock, Queue, Semaphore, Event do not define __copy__ or __deepcopy__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1696

  columns: [id, function, args, expected]
  rows:
    - ["as1696015", "asyncio.Future.__dict__.__contains__",    ["__copy__"],      false]
    - ["as1696016", "asyncio.Future.__dict__.__contains__",    ["__deepcopy__"],  false]
    - ["as1696017", "asyncio.Task.__dict__.__contains__",      ["__copy__"],      false]
    - ["as1696018", "asyncio.Task.__dict__.__contains__",      ["__deepcopy__"],  false]
    - ["as1696019", "asyncio.Lock.__dict__.__contains__",      ["__copy__"],      false]
    - ["as1696020", "asyncio.Lock.__dict__.__contains__",      ["__deepcopy__"],  false]
    - ["as1696021", "asyncio.Queue.__dict__.__contains__",     ["__copy__"],      false]
    - ["as1696022", "asyncio.Queue.__dict__.__contains__",     ["__deepcopy__"],  false]
    - ["as1696023", "asyncio.Semaphore.__dict__.__contains__", ["__copy__"],      false]
    - ["as1696024", "asyncio.Event.__dict__.__contains__",     ["__copy__"],      false]
