spec: inspect_extra1816
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 568 (_extra1816): __format__ string formatting protocol; copy/pickle protocol; Signature replacement/binding protocol dict-presence checks for inspect types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table inspect_extra1816.format_protocol:
  description: "inspect types __format__/__repr__/__str__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1816

  columns: [id, function, args, expected]
  rows:
    - ["in1816001", "inspect.Parameter.__dict__.__contains__", ["__format__"], false]
    - ["in1816002", "inspect.Signature.__dict__.__contains__", ["__format__"], false]
    - ["in1816003", "inspect.BoundArguments.__dict__.__contains__", ["__format__"], false]
    - ["in1816004", "inspect.Parameter.__dict__.__contains__", ["__repr__"], true]
    - ["in1816005", "inspect.Signature.__dict__.__contains__", ["__repr__"], true]
    - ["in1816006", "inspect.BoundArguments.__dict__.__contains__", ["__repr__"], true]
    - ["in1816007", "inspect.Parameter.__dict__.__contains__", ["__str__"], true]
    - ["in1816008", "inspect.Signature.__dict__.__contains__", ["__str__"], true]

table inspect_extra1816.copy_protocol:
  description: "inspect types __reduce__/__copy__/__deepcopy__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1816

  columns: [id, function, args, expected]
  rows:
    - ["in1816101", "inspect.Parameter.__dict__.__contains__", ["__reduce__"], false]
    - ["in1816102", "inspect.Parameter.__dict__.__contains__", ["__copy__"], false]
    - ["in1816103", "inspect.Parameter.__dict__.__contains__", ["__deepcopy__"], false]
    - ["in1816104", "inspect.Signature.__dict__.__contains__", ["__reduce__"], false]
    - ["in1816105", "inspect.Signature.__dict__.__contains__", ["__copy__"], false]
    - ["in1816106", "inspect.Signature.__dict__.__contains__", ["__deepcopy__"], false]
    - ["in1816107", "inspect.BoundArguments.__dict__.__contains__", ["__reduce__"], false]
    - ["in1816108", "inspect.BoundArguments.__dict__.__contains__", ["__copy__"], false]

table inspect_extra1816.signature_attrs:
  description: "inspect.Signature replacement/binding protocol and BoundArguments method dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1816

  columns: [id, function, args, expected]
  rows:
    - ["in1816201", "inspect.Signature.__dict__.__contains__", ["replace"], true]
    - ["in1816202", "inspect.Signature.__dict__.__contains__", ["bind"], true]
    - ["in1816203", "inspect.Signature.__dict__.__contains__", ["bind_partial"], true]
    - ["in1816204", "inspect.Signature.__dict__.__contains__", ["from_callable"], true]
    - ["in1816205", "inspect.Signature.__dict__.__contains__", ["parameters"], true]
    - ["in1816206", "inspect.Signature.__dict__.__contains__", ["return_annotation"], true]
    - ["in1816207", "inspect.Parameter.__dict__.__contains__", ["replace"], true]
    - ["in1816208", "inspect.BoundArguments.__dict__.__contains__", ["apply_defaults"], true]
    - ["in1816209", "inspect.BoundArguments.__dict__.__contains__", ["args"], true]
    - ["in1816210", "inspect.BoundArguments.__dict__.__contains__", ["kwargs"], true]
