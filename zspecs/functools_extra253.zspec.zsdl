spec: functools_extra253
version: ">=3.4"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.singledispatch behavioral contracts — register and dispatch method identity on the decorated function."
    - "functools.singledispatch(lambda x: x).dispatch.__name__ == 'dispatch' — dispatch is an inner function defined inside singledispatch; its __name__ is 'dispatch'. Verified with Python 3.14.3."
    - "functools.singledispatch(lambda x: x).dispatch.__class__.__name__ == 'function' — dispatch is a regular Python function (not a C-level method). Verified with Python 3.14.3."
    - "functools.singledispatch(lambda x: x).register.__name__ == 'register' — register is an inner function defined inside singledispatch; its __name__ is 'register'. Verified with Python 3.14.3."
    - "functools.singledispatch(lambda x: x).register.__class__.__name__ == 'function' — register is a regular Python function. Verified with Python 3.14.3."
    - "functools.singledispatch.__doc__.__contains__('dispatch') == True — the singledispatch docstring mentions 'dispatch'. Verified with Python 3.14.3."
    - "functools.singledispatch.__doc__.__contains__('register') == True — the singledispatch docstring mentions 'register'. Verified with Python 3.14.3."
    - "functools.singledispatch.__name__ == 'singledispatch'; __module__ == 'functools'; __class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "dispatch.__qualname__ == 'singledispatch.<locals>.dispatch' — dispatch is a closure defined inside singledispatch. Verified with Python 3.14.3."
    - "register.__qualname__ == 'singledispatch.<locals>.register' — register is a closure defined inside singledispatch. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: singledispatch dispatch and register method __name__ and
# __class__.__name__ checks
#
# functools.singledispatch(lambda x: x).dispatch.__name__ == 'dispatch'
# functools.singledispatch(lambda x: x).dispatch.__class__.__name__ == 'function'
# functools.singledispatch(lambda x: x).register.__name__ == 'register'
# functools.singledispatch(lambda x: x).register.__class__.__name__ == 'function'
#
# dispatch and register are inner functions (closures) created each time
# singledispatch decorates a function. They are plain Python functions; their
# __name__ is the unqualified name and their __class__.__name__ is 'function'.
# New to extra253.
# ---------------------------------------------------------------------------

table functools_extra253.singledispatch_method_names:
  description: "functools.singledispatch dispatch/register __name__ and __class__.__name__; new to extra253"
  kind: python_call_eq
  category: identity
  id_prefix: sdispatch253m

  columns: [id, function, args, expected, description]
  rows:
    - [dispatch_name_eq,
       singledispatch.__name__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__name__.__eq__('singledispatch') == True — singledispatch is a module-level Python function; its __name__ is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra253"]
    - [singledispatch_class_function,
       singledispatch.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.singledispatch.__class__.__name__.__eq__('function') == True — singledispatch is a plain Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra253"]
    - [singledispatch_module_eq,
       singledispatch.__module__.__eq__,
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is defined in the functools module; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra253"]
    - [singledispatch_qualname_eq,
       singledispatch.__qualname__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__qualname__.__eq__('singledispatch') == True — singledispatch is a module-level function so its __qualname__ equals its __name__; str.__eq__('singledispatch') returns True; new to extra253"]

# ---------------------------------------------------------------------------
# Table 2: singledispatch.__doc__ contains checks
#
# functools.singledispatch.__doc__.__contains__('dispatch') == True
# functools.singledispatch.__doc__.__contains__('register') == True
# functools.singledispatch.__doc__.__contains__('nonexistent') == False
# functools.singledispatch.__doc__.__class__.__name__ == 'str'
#
# The singledispatch docstring documents the dispatch and register methods
# exposed on the decorated function. New to extra253.
# ---------------------------------------------------------------------------

table functools_extra253.singledispatch_doc_checks:
  description: "functools.singledispatch.__doc__ contains 'dispatch', 'register'; doc is str; new to extra253"
  kind: python_call_eq
  category: doc_checks
  id_prefix: sdispatch253m

  columns: [id, function, args, expected, description]
  rows:
    - [doc_contains_dispatch,
       singledispatch.__doc__.__contains__,
       ["dispatch"],
       true,
       "functools.singledispatch.__doc__.__contains__('dispatch') == True — the singledispatch docstring mentions 'dispatch', the method that returns the implementation for a given type; str.__contains__('dispatch') returns True; new to extra253"]
    - [doc_contains_register,
       singledispatch.__doc__.__contains__,
       ["register"],
       true,
       "functools.singledispatch.__doc__.__contains__('register') == True — the singledispatch docstring mentions 'register', the method used to register implementations for specific types; str.__contains__('register') returns True; new to extra253"]
    - [doc_not_contains_nonexistent,
       singledispatch.__doc__.__contains__,
       ["nonexistent"],
       false,
       "functools.singledispatch.__doc__.__contains__('nonexistent') == False — 'nonexistent' does not appear in the singledispatch docstring; str.__contains__('nonexistent') returns False; new to extra253"]
    - [doc_class_str,
       singledispatch.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.singledispatch.__doc__.__class__.__name__.__eq__('str') == True — the singledispatch docstring is a plain Python str object; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra253"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra253
# ---------------------------------------------------------------------------

invariant functools_extra253.singledispatch.name_eq:
  description: "functools.singledispatch.__name__ == 'singledispatch' — singledispatch is a module-level Python function; new to extra253"
  category: identity
  kind: python_call_eq
  function: singledispatch.__name__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra253.singledispatch.class_is_function:
  description: "functools.singledispatch.__class__.__name__ == 'function' — singledispatch is a plain Python function; new to extra253"
  category: identity
  kind: python_call_eq
  function: singledispatch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra253.singledispatch.module_is_functools:
  description: "functools.singledispatch.__module__ == 'functools' — singledispatch is defined in the functools module; new to extra253"
  category: identity
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra253.singledispatch.doc_contains_dispatch:
  description: "functools.singledispatch.__doc__.__contains__('dispatch') == True — the singledispatch docstring references the dispatch method; new to extra253"
  category: doc_checks
  kind: python_call_eq
  function: singledispatch.__doc__.__contains__
  args: ["dispatch"]
  expected: true

invariant functools_extra253.singledispatch.doc_contains_register:
  description: "functools.singledispatch.__doc__.__contains__('register') == True — the singledispatch docstring references the register method; new to extra253"
  category: doc_checks
  kind: python_call_eq
  function: singledispatch.__doc__.__contains__
  args: ["register"]
  expected: true

invariant functools_extra253.singledispatch.doc_is_str:
  description: "functools.singledispatch.__doc__.__class__.__name__ == 'str' — the singledispatch docstring is a plain Python str; new to extra253"
  category: doc_checks
  kind: python_call_eq
  function: singledispatch.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra253.singledispatch.qualname_eq:
  description: "functools.singledispatch.__qualname__ == 'singledispatch' — module-level function; qualname equals name; new to extra253"
  category: identity
  kind: python_call_eq
  function: singledispatch.__qualname__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra253.singledispatch.module_len_9:
  description: "functools.singledispatch.__module__.__len__() == 9 — 'functools' has 9 characters; new to extra253"
  category: identity
  kind: python_call_eq
  function: singledispatch.__module__.__len__
  args: []
  expected: 9

invariant functools_extra253.singledispatch.doc_len_nonzero:
  description: "functools.singledispatch.__doc__.__len__() == 339 — the singledispatch docstring has exactly 339 characters on Python 3.14.3; new to extra253"
  category: doc_checks
  kind: python_call_eq
  function: singledispatch.__doc__.__len__
  args: []
  expected: 339

invariant functools_extra253.singledispatch.name_len_14:
  description: "functools.singledispatch.__name__.__len__() == 14 — 'singledispatch' has 14 characters; new to extra253"
  category: identity
  kind: python_call_eq
  function: singledispatch.__name__.__len__
  args: []
  expected: 14
