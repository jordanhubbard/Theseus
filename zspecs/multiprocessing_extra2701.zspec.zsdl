spec: multiprocessing_extra2701
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 627 (_extra2701): __lshift__, __rshift__, __invert__ dict-presence checks."
    - "multiprocessing.Process, multiprocessing.pool.Pool, and multiprocessing.pool.AsyncResult are process/IPC primitives, not bitwise types."
    - "None of these types define left-shift, right-shift, or bitwise NOT protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __lshift__ dict-presence checks
#
# Wave 627 theme: multiprocessing process and pool types do not implement
# the left-shift operator. Neither __lshift__ nor its reflected variant
# __rlshift__ appear in any of these classes' own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2701.lshift_protocol:
  description: "multiprocessing.Process, Pool, AsyncResult __lshift__/__rlshift__ dict-presence checks — none define left-shift in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2701

  columns: [id, function, args, expected]
  rows:
    - ["mp2701001", "multiprocessing.Process.__dict__.__contains__",          ["__lshift__"],  false]
    - ["mp2701002", "multiprocessing.Process.__dict__.__contains__",          ["__rlshift__"], false]
    - ["mp2701003", "multiprocessing.pool.Pool.__dict__.__contains__",        ["__lshift__"],  false]
    - ["mp2701004", "multiprocessing.pool.Pool.__dict__.__contains__",        ["__rlshift__"], false]
    - ["mp2701005", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["__lshift__"],  false]
    - ["mp2701006", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["__rlshift__"], false]

# ---------------------------------------------------------------------------
# Table 2: __rshift__ dict-presence checks
#
# Wave 627 theme: multiprocessing types do not implement the right-shift
# operator. Neither __rshift__ nor its reflected variant __rrshift__ appear
# in any of these classes' own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2701.rshift_protocol:
  description: "multiprocessing.Process, Pool, AsyncResult __rshift__/__rrshift__ dict-presence checks — none define right-shift in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2701

  columns: [id, function, args, expected]
  rows:
    - ["mp2701007", "multiprocessing.Process.__dict__.__contains__",          ["__rshift__"],  false]
    - ["mp2701008", "multiprocessing.Process.__dict__.__contains__",          ["__rrshift__"], false]
    - ["mp2701009", "multiprocessing.pool.Pool.__dict__.__contains__",        ["__rshift__"],  false]
    - ["mp2701010", "multiprocessing.pool.Pool.__dict__.__contains__",        ["__rrshift__"], false]
    - ["mp2701011", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["__rshift__"],  false]
    - ["mp2701012", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["__rrshift__"], false]

# ---------------------------------------------------------------------------
# Table 3: __invert__ dict-presence checks
#
# Wave 627 theme: multiprocessing types do not implement the bitwise NOT
# (unary ~) operator. __invert__ does not appear in any of these classes'
# own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2701.invert_protocol:
  description: "multiprocessing.Process, Pool, AsyncResult __invert__ dict-presence checks — none define bitwise NOT in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2701

  columns: [id, function, args, expected]
  rows:
    - ["mp2701013", "multiprocessing.Process.__dict__.__contains__",          ["__invert__"], false]
    - ["mp2701014", "multiprocessing.pool.Pool.__dict__.__contains__",        ["__invert__"], false]
    - ["mp2701015", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["__invert__"], false]

# ---------------------------------------------------------------------------
# Table 4: synchronize types __lshift__/__rshift__/__invert__ checks
#
# Wave 627 theme: multiprocessing.synchronize Lock, RLock, Semaphore, and
# Event are IPC synchronization primitives. None define any bitwise operator
# protocol in their own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2701.synchronize_bitwise:
  description: "multiprocessing.synchronize types __lshift__/__rshift__/__invert__ dict-presence checks — IPC sync primitives define none"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2701

  columns: [id, function, args, expected]
  rows:
    - ["mp2701016", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__lshift__"],  false]
    - ["mp2701017", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__rlshift__"], false]
    - ["mp2701018", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__rshift__"],  false]
    - ["mp2701019", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__rrshift__"], false]
    - ["mp2701020", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__invert__"],  false]
    - ["mp2701021", "multiprocessing.synchronize.RLock.__dict__.__contains__",     ["__lshift__"],  false]
    - ["mp2701022", "multiprocessing.synchronize.RLock.__dict__.__contains__",     ["__rshift__"],  false]
    - ["mp2701023", "multiprocessing.synchronize.RLock.__dict__.__contains__",     ["__invert__"],  false]
    - ["mp2701024", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__lshift__"],  false]
    - ["mp2701025", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__rshift__"],  false]
    - ["mp2701026", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__invert__"],  false]
    - ["mp2701027", "multiprocessing.synchronize.Event.__dict__.__contains__",     ["__lshift__"],  false]
    - ["mp2701028", "multiprocessing.synchronize.Event.__dict__.__contains__",     ["__rshift__"],  false]
    - ["mp2701029", "multiprocessing.synchronize.Event.__dict__.__contains__",     ["__invert__"],  false]
