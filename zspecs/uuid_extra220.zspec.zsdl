spec: uuid_extra220
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.UUID.__name__ == 'UUID' — the UUID class name is 4 characters."
    - "uuid.UUID.__module__ == 'uuid' — UUID is defined in the uuid module."
    - "uuid.UUID.__qualname__ == 'UUID' — UUID is a top-level class (not nested)."
    - "uuid.uuid3.__name__ == 'uuid3' — the uuid3 function name string."
    - "uuid.uuid5.__name__ == 'uuid5' — the uuid5 function name string."
    - "uuid.uuid3.__module__ == 'uuid' — uuid3 is defined in the uuid module."
    - "uuid.uuid5.__module__ == 'uuid' — uuid5 is defined in the uuid module."
    - "uuid.uuid1().__class__.__name__ == 'UUID' — uuid1() returns a UUID instance."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — predefined namespace constants are UUID instances."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' — predefined namespace constants are UUID instances."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID class name contracts
#
# uuid.UUID.__name__    == 'UUID'
# uuid.UUID.__module__  == 'uuid'
# uuid.UUID.__qualname__ == 'UUID'
# uuid.UUID.__name__.__len__() == 4
#
# The UUID class is defined at module level in uuid.py. Its name is the
# 4-character string 'UUID'. qualname equals __name__ for top-level classes.
# ---------------------------------------------------------------------------

table uuid_extra220.uuid_class_name_contracts:
  description: "UUID.__name__=='UUID'; UUID.__module__=='uuid'; UUID.__qualname__=='UUID'; UUID.__name__.__len__()==4; class identity contracts; new to extra220"
  kind: python_call_eq
  category: identity
  id_prefix: uuid220

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_name_eq_UUID,
       "UUID.__name__.__eq__",
       ["UUID"],
       true,
       "uuid.UUID.__name__.__eq__('UUID') == True — the UUID class name is the 4-character string 'UUID'; class.__name__ is a standard Python attribute; new anchor in extra220 namespace; verified Python 3.14.3"]
    - [UUID_module_eq_uuid,
       "UUID.__module__.__eq__",
       ["uuid"],
       true,
       "uuid.UUID.__module__.__eq__('uuid') == True — UUID is defined in the 'uuid' module; __module__ attribute on class gives the defining module name; new anchor in extra220 namespace; verified Python 3.14.3"]
    - [UUID_qualname_eq_UUID,
       "UUID.__qualname__.__eq__",
       ["UUID"],
       true,
       "uuid.UUID.__qualname__.__eq__('UUID') == True — UUID is a top-level class so __qualname__ equals __name__; no outer class scope; new anchor in extra220 namespace; verified Python 3.14.3"]
    - [UUID_name_len_4,
       "UUID.__name__.__len__",
       [],
       4,
       "uuid.UUID.__name__.__len__() == 4 — the string 'UUID' has length 4; portable way to anchor the class name length; new anchor in extra220 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid.uuid3 and uuid.uuid5 function name contracts
#
# uuid.uuid3.__name__   == 'uuid3'
# uuid.uuid5.__name__   == 'uuid5'
# uuid.uuid3.__module__ == 'uuid'
# uuid.uuid5.__module__ == 'uuid'
#
# uuid3 generates a UUID using MD5 of a namespace UUID + name (RFC 4122 §4.3).
# uuid5 generates a UUID using SHA-1 of a namespace UUID + name (RFC 4122 §4.3).
# Both are Python functions defined in uuid.py.
# ---------------------------------------------------------------------------

table uuid_extra220.uuid3_uuid5_function_names:
  description: "uuid3.__name__=='uuid3'; uuid5.__name__=='uuid5'; uuid3.__module__=='uuid'; uuid5.__module__=='uuid'; function identity contracts; new to extra220"
  kind: python_call_eq
  category: identity
  id_prefix: uuid220a

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_name_eq_uuid3,
       "uuid3.__name__.__eq__",
       ["uuid3"],
       true,
       "uuid.uuid3.__name__.__eq__('uuid3') == True — the uuid3 function name string is 'uuid3'; uuid3 generates name-based UUIDs using MD5 per RFC 4122 Section 4.3; new anchor in extra220 namespace; verified Python 3.14.3"]
    - [uuid5_name_eq_uuid5,
       "uuid5.__name__.__eq__",
       ["uuid5"],
       true,
       "uuid.uuid5.__name__.__eq__('uuid5') == True — the uuid5 function name string is 'uuid5'; uuid5 generates name-based UUIDs using SHA-1 per RFC 4122 Section 4.3; new anchor in extra220 namespace; verified Python 3.14.3"]
    - [uuid3_module_eq_uuid,
       "uuid3.__module__.__eq__",
       ["uuid"],
       true,
       "uuid.uuid3.__module__.__eq__('uuid') == True — uuid3 is a Python function defined in uuid.py; __module__ is 'uuid'; new anchor in extra220 namespace; verified Python 3.14.3"]
    - [uuid5_module_eq_uuid,
       "uuid5.__module__.__eq__",
       ["uuid"],
       true,
       "uuid.uuid5.__module__.__eq__('uuid') == True — uuid5 is a Python function defined in uuid.py; __module__ is 'uuid'; new anchor in extra220 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid.uuid1() and uuid.uuid4() return class name contracts
#
# uuid.uuid1().__class__.__name__ == 'UUID'
# uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'
# uuid.NAMESPACE_URL.__class__.__name__ == 'UUID'
#
# All UUID factory functions and predefined namespace constants return/are
# instances of uuid.UUID. The class name is 'UUID'.
# ---------------------------------------------------------------------------

table uuid_extra220.uuid_instance_class_names:
  description: "uuid1().__class__.__name__=='UUID'; NAMESPACE_DNS/__class__/__name__=='UUID'; NAMESPACE_URL/__class__/__name__=='UUID'; all UUID instances; new to extra220"
  kind: python_call_eq
  category: identity
  id_prefix: uuid220b

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_class_name_UUID,
       "uuid1().__class__.__name__.__eq__",
       ["UUID"],
       true,
       "uuid.uuid1().__class__.__name__.__eq__('UUID') == True — uuid1() returns a UUID instance; the class name is 'UUID'; new anchor in extra220 namespace; verified Python 3.14.3"]
    - [NAMESPACE_DNS_class_name_UUID,
       "NAMESPACE_DNS.__class__.__name__.__eq__",
       ["UUID"],
       true,
       "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — NAMESPACE_DNS is a predefined UUID constant for DNS namespace (RFC 4122 Appendix C); it is a UUID instance; new anchor in extra220 namespace; verified Python 3.14.3"]
    - [NAMESPACE_URL_class_name_UUID,
       "NAMESPACE_URL.__class__.__name__.__eq__",
       ["UUID"],
       true,
       "uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID') == True — NAMESPACE_URL is a predefined UUID constant for URL namespace (RFC 4122 Appendix C); it is a UUID instance; new anchor in extra220 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuid_extra220.UUID_name_eq_UUID:
  description: "uuid.UUID.__name__.__eq__('UUID') == True — UUID is the class name of the UUID type defined in the uuid module; __name__ is a standard class attribute returning the class's simple name (not qualified); 'UUID' is a 4-character string; uuid.UUID.__module__ == 'uuid' confirms the defining module; extra219 anchors UUID field attributes; extra220 is the first namespace to anchor UUID.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "UUID.__name__.__eq__"
  args: ["UUID"]
  expected: true

invariant uuid_extra220.uuid3_name_eq_uuid3:
  description: "uuid.uuid3.__name__.__eq__('uuid3') == True — uuid3 is a Python function in uuid.py that generates a UUID using the MD5 hash of a namespace UUID concatenated with a name string per RFC 4122 Section 4.3; the __name__ attribute of a Python function is its simple name string; 'uuid3' is 5 characters; extra220 is the first namespace to anchor uuid3.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "uuid3.__name__.__eq__"
  args: ["uuid3"]
  expected: true

invariant uuid_extra220.uuid5_name_eq_uuid5:
  description: "uuid.uuid5.__name__.__eq__('uuid5') == True — uuid5 is a Python function in uuid.py that generates a UUID using the SHA-1 hash of a namespace UUID concatenated with a name string per RFC 4122 Section 4.3; uuid5 is preferred over uuid3 because SHA-1 is stronger than MD5; the __name__ attribute is 'uuid5' (5 characters); extra220 is the first namespace to anchor uuid5.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "uuid5.__name__.__eq__"
  args: ["uuid5"]
  expected: true
