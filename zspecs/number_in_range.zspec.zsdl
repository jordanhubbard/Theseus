spec: number_in_range
version: ">=1.0.5"
backend: node(number-in-range)

docs: https://www.npmjs.com/package/number-in-range

provenance:
  derived_from:
    - "number-in-range README — https://www.npmjs.com/package/number-in-range"
    - "Test vectors verified with number-in-range via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "number-in-range source"
  notes:
    - "number-in-range is an npm package. Install: npm install number-in-range"
    - "Returns true if the number is within [min, max] inclusive."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table number_in_range.check:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: nir

  columns: [id, args, expected]
  rows:
    - [inside,   [5, 1, 10],  true]
    - [below,    [0, 1, 10],  false]
    - [above,    [11, 1, 10], false]
    - [at_min,   [1, 1, 10],  true]
    - [at_max,   [10, 1, 10], true]
