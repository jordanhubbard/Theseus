spec: decimal_extra1756
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
    - "IBM General Decimal Arithmetic Specification"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 564 (_extra1756): arithmetic operator protocol dict-presence checks."
    - "Previous waves covered: __abs__, __neg__, __pos__, __add__, __round__, __float__, __int__, __bool__ (wave 559); __round__, __floor__, __ceil__, __trunc__, __mod__, __divmod__ (wave 563)."
    - "This wave covers the remaining arithmetic operators: __sub__, __mul__, __truediv__, __floordiv__, __pow__ and their reflected counterparts __radd__, __rsub__, __rmul__, __rtruediv__, __rfloordiv__, __rpow__, __rmod__."
    - "decimal.Decimal.__dict__.__contains__('__sub__') == True — Decimal implements subtraction."
    - "decimal.Decimal.__dict__.__contains__('__mul__') == True — Decimal implements multiplication."
    - "decimal.Decimal.__dict__.__contains__('__truediv__') == True — Decimal implements true division."
    - "decimal.Decimal.__dict__.__contains__('__floordiv__') == True — Decimal implements floor division."
    - "decimal.Decimal.__dict__.__contains__('__pow__') == True — Decimal implements exponentiation."
    - "decimal.Decimal.__dict__.__contains__('__radd__') == True — reflected addition (for int + Decimal)."
    - "decimal.Decimal.__dict__.__contains__('__rsub__') == True — reflected subtraction."
    - "decimal.Decimal.__dict__.__contains__('__rmul__') == True — reflected multiplication."
    - "decimal.Decimal.__dict__.__contains__('__rtruediv__') == True — reflected true division."
    - "decimal.Decimal.__dict__.__contains__('__rfloordiv__') == True — reflected floor division."
    - "decimal.Decimal.__dict__.__contains__('__rpow__') == True — reflected exponentiation."
    - "decimal.Decimal.__dict__.__contains__('__rmod__') == True — reflected modulo."
    - "decimal.Context does NOT define arithmetic operator dunders in its own __dict__; Context performs arithmetic via named methods (add, subtract, multiply, divide, power) not via operator protocol."
    - "decimal.Decimal is a C extension type (Modules/_decimal/_decimal.c); all its operator dunders are wrapper_descriptor objects."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: Decimal forward arithmetic operators dict-presence
#
# Wave 564 theme: which types define __add__, __sub__, __mul__,
# __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__.
#
# decimal.Decimal is a C extension type implementing a full numeric type.
# __sub__, __mul__, __truediv__, __floordiv__, __pow__ are all defined
# directly on Decimal. __neg__ and __pos__ were covered in wave 559.
# __add__ and __mod__ were covered in wave 559/563; included here for
# completeness of the wave 564 arithmetic operator set.
# ---------------------------------------------------------------------------

table decimal_extra1756.Decimal_forward_arithmetic:
  description: "decimal.Decimal forward arithmetic operator dict-presence — all True — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1756

  columns: [id, function, args, expected]
  rows:
    - ["dc1756001", "decimal.Decimal.__dict__.__contains__", ["__add__"], true]
    - ["dc1756002", "decimal.Decimal.__dict__.__contains__", ["__sub__"], true]
    - ["dc1756003", "decimal.Decimal.__dict__.__contains__", ["__mul__"], true]
    - ["dc1756004", "decimal.Decimal.__dict__.__contains__", ["__truediv__"], true]
    - ["dc1756005", "decimal.Decimal.__dict__.__contains__", ["__floordiv__"], true]
    - ["dc1756006", "decimal.Decimal.__dict__.__contains__", ["__pow__"], true]
    - ["dc1756007", "decimal.Decimal.__dict__.__contains__", ["__neg__"], true]
    - ["dc1756008", "decimal.Decimal.__dict__.__contains__", ["__pos__"], true]

# ---------------------------------------------------------------------------
# Table 2: Decimal reflected arithmetic operators dict-presence
#
# Python's reflected (right-hand) operator protocol: when an expression
# like (int + Decimal) is evaluated, Python calls int.__add__(decimal_value)
# first; if it returns NotImplemented, Python calls Decimal.__radd__(int_value).
# Decimal defines all reflected arithmetic operators to handle mixed-type
# arithmetic where Decimal is the right operand.
#
# __radd__, __rsub__, __rmul__, __rtruediv__, __rfloordiv__, __rpow__, __rmod__
# are all defined in Decimal.__dict__. These were not explicitly covered in
# waves 559 or 563.
# ---------------------------------------------------------------------------

table decimal_extra1756.Decimal_reflected_arithmetic:
  description: "decimal.Decimal reflected arithmetic operator dict-presence — all True — enables right-hand mixed-type arithmetic — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1756

  columns: [id, function, args, expected]
  rows:
    - ["dc1756009", "decimal.Decimal.__dict__.__contains__", ["__radd__"], true]
    - ["dc1756010", "decimal.Decimal.__dict__.__contains__", ["__rsub__"], true]
    - ["dc1756011", "decimal.Decimal.__dict__.__contains__", ["__rmul__"], true]
    - ["dc1756012", "decimal.Decimal.__dict__.__contains__", ["__rtruediv__"], true]
    - ["dc1756013", "decimal.Decimal.__dict__.__contains__", ["__rfloordiv__"], true]
    - ["dc1756014", "decimal.Decimal.__dict__.__contains__", ["__rpow__"], true]
    - ["dc1756015", "decimal.Decimal.__dict__.__contains__", ["__rmod__"], true]

# ---------------------------------------------------------------------------
# Table 3: decimal.Context arithmetic operator dict-presence
#
# decimal.Context performs arbitrary-precision arithmetic operations via named
# methods: ctx.add(a, b), ctx.subtract(a, b), ctx.multiply(a, b), etc.
# Context does NOT implement the arithmetic operator protocol (__add__,
# __sub__, __mul__, etc.) in its own __dict__. Context is a configuration
# and computation object, not a numeric operand type.
# ---------------------------------------------------------------------------

table decimal_extra1756.Context_arithmetic_operators:
  description: "decimal.Context arithmetic operator dict-presence — all False — Context uses named methods (add, subtract, multiply) not operator protocol — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1756

  columns: [id, function, args, expected]
  rows:
    - ["dc1756016", "decimal.Context.__dict__.__contains__", ["__add__"], false]
    - ["dc1756017", "decimal.Context.__dict__.__contains__", ["__sub__"], false]
    - ["dc1756018", "decimal.Context.__dict__.__contains__", ["__mul__"], false]
    - ["dc1756019", "decimal.Context.__dict__.__contains__", ["__truediv__"], false]
    - ["dc1756020", "decimal.Context.__dict__.__contains__", ["__floordiv__"], false]
    - ["dc1756021", "decimal.Context.__dict__.__contains__", ["__pow__"], false]
    - ["dc1756022", "decimal.Context.__dict__.__contains__", ["__neg__"], false]
    - ["dc1756023", "decimal.Context.__dict__.__contains__", ["__pos__"], false]
