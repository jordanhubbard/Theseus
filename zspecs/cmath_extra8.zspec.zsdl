spec: cmath_extra8
version: ">=3.9"
backend: python_module(cmath)

docs: https://docs.python.org/3/library/cmath.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cmath.html — Python cmath module documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/cmathmodule.c"
  notes:
    - "This spec extends cmath.zspec.zsdl and prior extras through cmath_extra7.zspec.zsdl."
    - "cmath_extra/cmath_extra2: phase/polar/rect/isclose/isfinite/isinf/isnan __name__ already covered."
    - "cmath_extra6: sqrt.__module__ == 'cmath' already covered."
    - "cmath_extra7: polar.__module__ and rect.__module__ already covered."
    - "No prior spec covers sqrt.__name__ == 'sqrt' via __eq__ invariant form."
    - "No prior spec covers exp.__name__, log.__name__, sin.__name__, cos.__name__ in a unified table."
    - "No prior spec covers phase.__name__ and polar.__name__ and rect.__name__ in a unified table."
    - "No prior spec covers cmath.sqrt(-1).__class__.__name__ == 'complex'."
    - "No prior spec covers cmath.pi.__class__.__name__ == 'float'."
    - "cmath.sqrt.__name__ == 'sqrt' — function name attribute for the square root function."
    - "cmath.exp.__name__ == 'exp' — function name attribute for the exponential function."
    - "cmath.log.__name__ == 'log' — function name attribute for the logarithm function."
    - "cmath.sin.__name__ == 'sin' — function name attribute for sine."
    - "cmath.cos.__name__ == 'cos' — function name attribute for cosine."
    - "cmath.phase.__name__ == 'phase' — function name attribute for phase."
    - "cmath.polar.__name__ == 'polar' — function name attribute for polar."
    - "cmath.rect.__name__ == 'rect' — function name attribute for rect."
    - "cmath.sqrt(-1).__class__.__name__ == 'complex' — sqrt of a negative real returns a complex."
    - "cmath.pi.__class__.__name__ == 'float' — pi is a float constant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ attributes for cmath functions
#
# cmath_extra/cmath_extra2 cover __name__ for phase/polar/rect/isclose/
# isfinite/isinf/isnan. No prior spec covers sqrt/exp/log/sin/cos __name__
# in a unified table, nor phase/polar/rect together in a table.
# ---------------------------------------------------------------------------

invariant cmath_extra8.sqrt.name:
  description: "cmath.sqrt.__name__ == 'sqrt' — function name attribute"
  category: function_identity
  kind: python_call_eq
  function: sqrt.__name__.__eq__
  args: ["sqrt"]
  expected: true

table cmath_extra8.function_names:
  description: "__name__ attributes for exp/log/sin/cos/phase/polar/rect"
  kind: python_call_eq
  category: function_identity
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [exp,   exp.__name__.__eq__,   ["exp"],   true]
    - [log,   log.__name__.__eq__,   ["log"],   true]
    - [sin,   sin.__name__.__eq__,   ["sin"],   true]
    - [cos,   cos.__name__.__eq__,   ["cos"],   true]
    - [phase, phase.__name__.__eq__, ["phase"], true]
    - [polar, polar.__name__.__eq__, ["polar"], true]
    - [rect,  rect.__name__.__eq__,  ["rect"],  true]

# ---------------------------------------------------------------------------
# cmath.sqrt(-1).__class__.__name__ == 'complex'
#
# The square root of a negative real number is purely imaginary; cmath.sqrt
# always returns a complex. The type name is 'complex' (lowercase).
# No prior spec covers the __class__.__name__ of a cmath.sqrt result.
# ---------------------------------------------------------------------------

invariant cmath_extra8.sqrt.result_class_name:
  description: "cmath.sqrt(-1).__class__.__name__ == 'complex' — sqrt of negative real returns complex"
  category: return_type
  kind: python_call_eq
  function: sqrt
  args: [-1]
  method: __class__.__name__.__eq__
  method_args: ["complex"]
  expected: true

# ---------------------------------------------------------------------------
# cmath.pi.__class__.__name__ == 'float'
#
# cmath.pi is the mathematical constant pi stored as a Python float.
# No prior spec checks the __class__.__name__ of the pi constant.
# ---------------------------------------------------------------------------

invariant cmath_extra8.pi.class_name:
  description: "cmath.pi.__class__.__name__ == 'float' — pi is a float constant"
  category: constants
  kind: python_call_eq
  function: pi.__class__.__name__.__eq__
  args: ["float"]
  expected: true
