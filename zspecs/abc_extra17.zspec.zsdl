spec: abc_extra17
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc.zspec.zsdl through abc_extra16.zspec.zsdl."
    - "abc_extra16 covers: combined __module__ table for ABCMeta/ABC/abstractmethod; combined __bases__[0].__name__ table for ABCMeta/ABC; abstractmethod.__name__ standalone; get_cache_token.__module__ == '_abc' standalone; ABC.__class__.__name__ == 'ABCMeta' standalone."
    - "abc_extra14 covers: abstractmethod/__qualname__; ABC/__qualname__; ABCMeta/__qualname__; ABC/__mro__.__len__ == 2; ABCMeta/__mro__.__len__ == 3; get_cache_token/__qualname__."
    - "Focus of this spec: (1) combined __qualname__ table for ABCMeta/ABC/abstractmethod/get_cache_token — all four in one table, not yet done in extra17 namespace; (2) combined __qualname__.__len__ table for all four; (3) ABCMeta.__name__.__len__ == 7 standalone; (4) get_cache_token.__name__.__len__ == 15 standalone; (5) ABCMeta.__mro__.__len__ == 3 as standalone in extra17 namespace; (6) ABC.__mro__.__len__ == 2 as standalone in extra17 namespace."
    - "NOT yet covered (entering this spec): combined __qualname__ table for ABCMeta/ABC/abstractmethod/get_cache_token in the extra17 namespace; combined __qualname__.__len__ table; ABCMeta.__name__.__len__ == 7 standalone; get_cache_token.__name__.__len__ == 15 standalone; ABCMeta.__mro__.__len__ == 3 standalone in extra17 namespace; ABC.__mro__.__len__ == 2 standalone in extra17 namespace."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for ABCMeta, ABC, abstractmethod, get_cache_token
#
# abc_extra14 covers each of these as standalone invariants but no prior spec
# combines all four into one table under the extra17 namespace.
# ABCMeta.__qualname__ == 'ABCMeta', ABC.__qualname__ == 'ABC',
# abstractmethod.__qualname__ == 'abstractmethod',
# get_cache_token.__qualname__ == 'get_cache_token'.
# ---------------------------------------------------------------------------

table abc_extra17.core_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [ABCMeta,          ABCMeta.__qualname__.__eq__,          ["ABCMeta"],          true]
    - [ABC,              ABC.__qualname__.__eq__,              ["ABC"],              true]
    - [abstractmethod,   abstractmethod.__qualname__.__eq__,   ["abstractmethod"],   true]
    - [get_cache_token,  get_cache_token.__qualname__.__eq__,  ["get_cache_token"],  true]

# ---------------------------------------------------------------------------
# __qualname__.__len__ for ABCMeta, ABC, abstractmethod, get_cache_token
#
# ABCMeta len 7, ABC len 3, abstractmethod len 14, get_cache_token len 15.
# No prior spec collects all four lengths together in one combined table under
# the extra17 namespace.
# ---------------------------------------------------------------------------

table abc_extra17.core_qualname_lens:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [ABCMeta,         ABCMeta.__qualname__.__len__,         [], 7]
    - [ABC,             ABC.__qualname__.__len__,             [], 3]
    - [abstractmethod,  abstractmethod.__qualname__.__len__,  [], 14]
    - [get_cache_token, get_cache_token.__qualname__.__len__, [], 15]

# ---------------------------------------------------------------------------
# ABCMeta.__name__.__len__() == 7
#
# The name string 'ABCMeta' has length 7. abc_extra16 covers ABCMeta.__name__
# implicitly via bases checks but no prior spec verifies the length of
# ABCMeta.__name__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant abc_extra17.ABCMeta.name.len:
  description: "abc.ABCMeta.__name__.__len__() == 7 — len('ABCMeta') == 7"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__name__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# get_cache_token.__name__.__len__() == 15
#
# The name string 'get_cache_token' has length 15. No prior spec verifies
# the length of get_cache_token.__name__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant abc_extra17.get_cache_token.name.len:
  description: "abc.get_cache_token.__name__.__len__() == 15 — len('get_cache_token') == 15"
  category: function_names
  kind: python_call_eq
  function: get_cache_token.__name__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# ABCMeta.__mro__.__len__() == 3
#
# ABCMeta MRO is [ABCMeta, type, object]. abc_extra14 covers this as a
# standalone but only in the extra14 namespace. No prior spec covers it in
# the extra17 namespace.
# ---------------------------------------------------------------------------

invariant abc_extra17.ABCMeta.mro.len:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — MRO is [ABCMeta, type, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: ABCMeta.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# ABC.__mro__.__len__() == 2
#
# ABC MRO is [ABC, object]. abc_extra14 covers this in the extra14 namespace.
# No prior spec covers ABC.__mro__.__len__() == 2 in the extra17 namespace.
# ---------------------------------------------------------------------------

invariant abc_extra17.ABC.mro.len:
  description: "abc.ABC.__mro__.__len__() == 2 — MRO is [ABC, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: ABC.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# ABC.__name__.__len__() == 3
#
# The name string 'ABC' has length 3. No prior spec verifies the length of
# ABC.__name__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant abc_extra17.ABC.name.len:
  description: "abc.ABC.__name__.__len__() == 3 — len('ABC') == 3"
  category: class_names
  kind: python_call_eq
  function: ABC.__name__.__len__
  args: []
  expected: 3
