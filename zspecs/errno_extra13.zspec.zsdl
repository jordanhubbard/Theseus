spec: errno_extra13
version: ">=3.9"
backend: python_module(errno)

docs: https://docs.python.org/3/library/errno.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/errno.html — Python errno module documentation"
    - "POSIX.1-2017 — IEEE Std 1003.1, errno.h error codes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/errnomodule.c"
  notes:
    - "This spec extends errno_extra12.zspec.zsdl."
    - "Prior specs covered: errno.__name__/__package__; all POSIX error code constants and values; errorcode type/length (107 entries); errorcode/__class__/__name__/__module__; errno constant __class__.__name__.__len__()==3 for many constants; errorcode reverse-lookups for EPERM(1)/ENOENT(2)/EINVAL(22)/EACCES(13)/ENOTCONN(57)/ETIMEDOUT(60)/ECONNREFUSED(61)/EADDRINUSE(48)/ENETUNREACH(51)/EHOSTUNREACH(65); errno.__name__.__len__()==5; errno.__package__.__len__()==0."
    - "This spec covers: errno constant values for EIO/EBUSY/EEXIST/EINTR/EAGAIN/ENOMEM/ENODEV; errorcode reverse-lookups for EIO(5)/EBUSY(16)/EEXIST(17)/EINTR(4)/EAGAIN(35)/ENOMEM(12)/ENODEV(19); errno.__name__.__class__.__name__.__len__() ('str' == 3); errno constant name string lengths (len('EIO')==3, len('EBUSY')==5, etc.)."
    - "errno.EIO == 5 on macOS/Darwin; errno.errorcode[5] == 'EIO'. Verified at runtime."
    - "errno.EBUSY == 16 on macOS/Darwin; errno.errorcode[16] == 'EBUSY'. Verified at runtime."
    - "errno.EEXIST == 17 on macOS/Darwin; errno.errorcode[17] == 'EEXIST'. Verified at runtime."
    - "errno.EINTR == 4 on macOS/Darwin; errno.errorcode[4] == 'EINTR'. Verified at runtime."
    - "errno.EAGAIN == 35 on macOS/Darwin; errno.errorcode[35] == 'EAGAIN'. Verified at runtime."
    - "errno.ENOMEM == 12 on macOS/Darwin; errno.errorcode[12] == 'ENOMEM'. Verified at runtime."
    - "errno.ENODEV == 19 on macOS/Darwin; errno.errorcode[19] == 'ENODEV'. Verified at runtime."
    - "errno.__name__.__class__.__name__ == 'str'; len == 3. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# errno.EIO value and errorcode reverse-lookup
#
# EIO (I/O error) is errno 5 on macOS/Darwin. errorcode[5] == 'EIO'.
# The constant name 'EIO' is 3 characters — the shortest errno name.
# No prior spec verifies EIO's value or reverse-lookup as standalone invariants.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra13.EIO.value:
  description: "errno.EIO == 5 on macOS/Darwin — I/O error code is 5"
  category: constants
  kind: python_call_eq
  function: EIO.__eq__
  args: [5]
  expected: true

invariant errno_extra13.errorcode.eio_lookup:
  description: "errno.errorcode[5] == 'EIO' — reverse-lookup of errno 5 (EIO) on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [5]
  expected: "EIO"

# ---------------------------------------------------------------------------
# errno.EINTR value and errorcode reverse-lookup
#
# EINTR (interrupted function call) is errno 4 on macOS/Darwin.
# errorcode[4] == 'EINTR'. No prior spec verifies EINTR's value or
# reverse-lookup as standalone invariants.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra13.EINTR.value:
  description: "errno.EINTR == 4 on macOS/Darwin — interrupted function call code is 4"
  category: constants
  kind: python_call_eq
  function: EINTR.__eq__
  args: [4]
  expected: true

invariant errno_extra13.errorcode.eintr_lookup:
  description: "errno.errorcode[4] == 'EINTR' — reverse-lookup of errno 4 (EINTR) on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [4]
  expected: "EINTR"

# ---------------------------------------------------------------------------
# errno.__name__.__class__.__name__.__len__()
#
# errno.__name__ is the string 'errno'. Its class is str, defined in builtins.
# str.__name__ == 'str', a 3-character string.
# The chain errno.__name__.__class__.__name__.__len__() == 3 verifies that
# the module name attribute is indeed a plain Python str.
# No prior spec verifies this four-level chain.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra13.module.name_class_name_len:
  description: "len(errno.__name__.__class__.__name__) == 3 — '__name__' is a str, and 'str' is 3 characters"
  category: module_structure
  kind: python_call_eq
  function: __name__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Table: errno constant values — I/O and resource error tier
#
# Groups value equality checks for seven errno constants that represent I/O
# and resource errors. Prior specs covered the POSIX core set (EPERM/ENOENT/
# EINVAL/EACCES) and the network tier (ENOTCONN/ETIMEDOUT/ECONNREFUSED etc.).
# This table fills in the middle tier: EIO/EBUSY/EEXIST/EINTR/EAGAIN/ENOMEM/ENODEV.
# All verified at runtime on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table errno_extra13.io_resource_constant_values:
  description: "errno I/O and resource error constant values on macOS — EIO/EBUSY/EEXIST/EINTR/EAGAIN/ENOMEM/ENODEV"
  kind: python_call_eq
  category: constants
  id_prefix: e13irc

  columns: [id, function, args, expected]
  rows:
    - [EIO_val,    EIO.__eq__,    [5],  true]
    - [EBUSY_val,  EBUSY.__eq__,  [16], true]
    - [EEXIST_val, EEXIST.__eq__, [17], true]
    - [EINTR_val,  EINTR.__eq__,  [4],  true]
    - [EAGAIN_val, EAGAIN.__eq__, [35], true]
    - [ENOMEM_val, ENOMEM.__eq__, [12], true]
    - [ENODEV_val, ENODEV.__eq__, [19], true]

# ---------------------------------------------------------------------------
# Table: errorcode reverse-lookups for I/O and resource error codes
#
# Groups reverse-lookup checks for the same seven error codes above.
# Prior specs covered the fundamental tier (EPERM/ENOENT/EINVAL/EACCES) in
# extra11 and the network tier (ENOTCONN/ETIMEDOUT/ECONNREFUSED/EADDRINUSE/
# ENETUNREACH/EHOSTUNREACH) in extra12. This table covers the I/O/resource tier.
# All verified at runtime on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table errno_extra13.errorcode_io_resource_lookups:
  description: "errno.errorcode reverse-lookups for I/O and resource error codes on macOS — EIO/EBUSY/EEXIST/EINTR/EAGAIN/ENOMEM/ENODEV"
  kind: python_call_eq
  category: errorcode
  id_prefix: e13erl

  columns: [id, function, args, expected]
  rows:
    - [eio,    errorcode.__getitem__, [5],  "EIO"]
    - [ebusy,  errorcode.__getitem__, [16], "EBUSY"]
    - [eexist, errorcode.__getitem__, [17], "EEXIST"]
    - [eintr,  errorcode.__getitem__, [4],  "EINTR"]
    - [eagain, errorcode.__getitem__, [35], "EAGAIN"]
    - [enomem, errorcode.__getitem__, [12], "ENOMEM"]
    - [enodev, errorcode.__getitem__, [19], "ENODEV"]
