spec: dc3106
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 654 (dc3106): __lt__, __le__, __gt__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "decimal.Decimal defines __lt__, __le__, and __gt__ in its own __dict__: it is a numeric type supporting full ordering by value (e.g. Decimal('1.0') < Decimal('2.0'))."
    - "decimal.Context does NOT define __lt__, __le__, or __gt__ in its own __dict__."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, and decimal.Underflow are exception classes and do NOT define __lt__, __le__, or __gt__ in their own __dict__."
    - "On CPython, the decimal module is backed by _decimal (C accelerator); class __dict__ contents are from the C extension."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __lt__ dict-presence — operator.contains(Cls.__dict__, '__lt__')
#
# decimal.Decimal defines __lt__ (true): numeric ordering is fully implemented.
# decimal.Context and all exception subclasses do not define __lt__ (false).
# ---------------------------------------------------------------------------

table dc3106.lt:
  description: "decimal types __lt__ dict-presence checks; wave 654"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3106

  columns: [id, function, args, expected]
  rows:
    - ["dc3106001", operator.contains, [decimal.Decimal.__dict__,          "__lt__"], true]
    - ["dc3106002", operator.contains, [decimal.Context.__dict__,           "__lt__"], false]
    - ["dc3106003", operator.contains, [decimal.DecimalException.__dict__,  "__lt__"], false]
    - ["dc3106004", operator.contains, [decimal.InvalidOperation.__dict__,  "__lt__"], false]
    - ["dc3106005", operator.contains, [decimal.Overflow.__dict__,          "__lt__"], false]
    - ["dc3106006", operator.contains, [decimal.Underflow.__dict__,         "__lt__"], false]

