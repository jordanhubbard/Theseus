spec: binascii_extra5
version: ">=3.9"
backend: python_module(binascii)

docs: https://docs.python.org/3/library/binascii.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/binascii.html — Python binascii documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/binascii.c"
  notes:
    - "This spec extends binascii.zspec.zsdl and prior extras."
    - "binascii_extra4 covers: __module__ for unhexlify/b2a_hex/a2b_hex/crc_hqx/b2a_base64/a2b_base64; Error/__module__, Incomplete/__module__; __qualname__ for hexlify/unhexlify/b2a_hex/a2b_hex/crc32/crc_hqx; Error/__qualname__, Incomplete/__qualname__; b2a_base64(hello) value and length; crc_hqx(b'A',0)==49664; hexlify(hello) returns bytes."
    - "binascii_extra3 covers: __name__ table for hexlify/unhexlify/crc32/b2a_base64/a2b_base64/b2a_hex/a2b_hex; hexlify/unhexlify/crc32/a2b_base64 values for b'hello'."
    - "binascii_extra2 covers: __name__ for hexlify/unhexlify/b2a_hex/a2b_hex/crc32/crc_hqx; __module__ for hexlify/crc32; b2a_hex/a2b_hex values for b'\\xde\\xad'; crc_hqx(b'',0)==0."
    - "binascii_extra covers: __name__ for hexlify/unhexlify/b2a_base64/a2b_base64/crc32/crc_hqx; __module__ for hexlify; Error/__name__/__bases__; Incomplete/__name__; hexlify(dead)/unhexlify('dead') values."
    - "Focus: __qualname__ for b2a_base64/a2b_base64 (not in extra4 qualname table); hexlify(b'\\xff')==b'ff' and unhexlify(b'ff')==b'\\xff' (single-byte round-trip not yet recorded); crc32(b'A') absolute value; __class__.__name__ checks on function return values."
    - "binascii.b2a_base64.__qualname__ == 'b2a_base64' — C builtin has flat qualname."
    - "binascii.a2b_base64.__qualname__ == 'a2b_base64' — C builtin has flat qualname."
    - "binascii.hexlify(b'\\xff') == b'ff' — single byte 0xFF encodes to two lowercase hex digits."
    - "binascii.unhexlify(b'ff') == b'\\xff' — two hex digits decode to single byte 0xFF."
    - "binascii.crc32(b'A') == 3554254475 — CRC-32 of b'A'; verified on Python 3.12."
    - "binascii.unhexlify(b'ff').__class__.__name__ == 'bytes' — unhexlify always returns bytes."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ — b2a_base64 and a2b_base64
#
# binascii_extra4.function_qualnames covers hexlify/unhexlify/b2a_hex/a2b_hex/
# crc32/crc_hqx but omits b2a_base64 and a2b_base64. This table fills the gap.
# ---------------------------------------------------------------------------

table binascii_extra5.base64_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [b2a_base64, b2a_base64.__qualname__.__eq__, ["b2a_base64"], true]
    - [a2b_base64, a2b_base64.__qualname__.__eq__, ["a2b_base64"], true]

# ---------------------------------------------------------------------------
# hexlify / unhexlify — single-byte round-trip for 0xFF
#
# Prior specs (binascii_extra, binascii_extra3) use b'\\xde\\xad' and b'hello'
# as fixtures. No prior spec records the single-byte 0xFF round-trip, which
# exercises the maximum byte value and verifies lowercase hex output ('ff').
# ---------------------------------------------------------------------------

invariant binascii_extra5.hexlify.ff_byte:
  description: "binascii.hexlify(b'\\xff') == b'ff' — 0xFF encodes to lowercase 'ff'"
  category: hexlify
  kind: python_call_eq
  function: hexlify
  args: [!hex ff]
  expected: !ascii "ff"

invariant binascii_extra5.unhexlify.ff_hex:
  description: "binascii.unhexlify(b'ff') == b'\\xff' — hex digits 'ff' decode to byte 0xFF"
  category: unhexlify
  kind: python_call_eq
  function: unhexlify
  args: [!ascii "ff"]
  expected: !hex ff

# ---------------------------------------------------------------------------
# crc32 — single-byte value for b'A'
#
# binascii_extra2 covers crc32(b'') == 0. No prior spec records the crc32 of
# a non-empty, non-'hello' byte string. crc32(b'A') == 3554254475, verified on
# Python 3.12 (unsigned 32-bit result as returned by the binascii module).
# ---------------------------------------------------------------------------

invariant binascii_extra5.crc32.byte_A:
  description: "binascii.crc32(b'A') == 3554254475 — CRC-32 of single byte 0x41"
  category: crc32
  kind: python_call_eq
  function: crc32
  args: [!hex 41]
  expected: 3554254475

# ---------------------------------------------------------------------------
# unhexlify — return type check
#
# binascii_extra4 verifies hexlify returns bytes (via __class__.__name__).
# This invariant records the symmetric check for unhexlify, confirming that
# the decode path also returns a bytes object.
# ---------------------------------------------------------------------------

invariant binascii_extra5.unhexlify.returns_bytes:
  description: "binascii.unhexlify(b'ff').__class__.__name__ == 'bytes'"
  category: unhexlify
  kind: python_call_eq
  function: unhexlify
  args: [!ascii "ff"]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# b2a_hex / a2b_hex — __qualname__ cross-check (standalone invariants)
#
# b2a_hex is an alias for hexlify and a2b_hex is an alias for unhexlify. Their
# __qualname__ values confirm they are independently registered C-level functions
# (not wrappers), each with a flat qualname matching their __name__.
# binascii_extra4 already records __qualname__ for b2a_hex and a2b_hex in a
# table; these standalone invariants provide explicit, individually named
# entries for cross-reference in audit tooling.
# ---------------------------------------------------------------------------

invariant binascii_extra5.b2a_hex.qualname:
  description: "binascii.b2a_hex.__qualname__ == 'b2a_hex'"
  category: qualnames
  kind: python_call_eq
  function: b2a_hex.__qualname__.__eq__
  args: ["b2a_hex"]
  expected: true

invariant binascii_extra5.a2b_hex.qualname:
  description: "binascii.a2b_hex.__qualname__ == 'a2b_hex'"
  category: qualnames
  kind: python_call_eq
  function: a2b_hex.__qualname__.__eq__
  args: ["a2b_hex"]
  expected: true
