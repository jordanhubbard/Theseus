spec: theseus_warnings_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_warnings_cr2)
blocks: warnings

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html"
  notes:
    - "Clean-room extended warnings utilities. Do NOT import warnings."
    - "catch_warnings(): context manager that saves/restores the warnings filter list."
    - "filterwarnings(action, message='', category=Warning, module='', lineno=0): add filter."
    - "simplefilter(action, category=Warning, lineno=0, append=False): simplified filter."
    - "warnings2_catch(): catch_warnings() works as context manager — returns True."
    - "warnings2_filter(): filterwarnings('ignore') does not raise — returns True."
    - "warnings2_simplefilter(): simplefilter('always') does not raise — returns True."
    - "Zero-arg invariant signatures — def warnings2_catch(): return bool"
    - "Maintain a module-level _filters list; catch_warnings saves/restores it."
    - "filterwarnings prepends or appends a (action, msg_re, cat, mod_re, lineno) tuple."
    - "Export: warn(msg, cat), filterwarnings(...), simplefilter(...), catch_warnings, resetwarnings()."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_warnings_cr2.catch:
  description: "catch_warnings() works as a context manager without error"
  category: catch_warnings
  kind: python_call_eq
  function: warnings2_catch
  args: []
  expected: true

invariant theseus_warnings_cr2.filter:
  description: "filterwarnings('ignore') does not raise"
  category: filterwarnings
  kind: python_call_eq
  function: warnings2_filter
  args: []
  expected: true

invariant theseus_warnings_cr2.simplefilter:
  description: "simplefilter('always') does not raise"
  category: simplefilter
  kind: python_call_eq
  function: warnings2_simplefilter
  args: []
  expected: true
