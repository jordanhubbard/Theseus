invariant inspect_extra276.formatargvalues_module_is_inspect:
  description: "inspect.formatargvalues.__module__ == 'inspect' — formatargvalues is a pure-Python function defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: formatargvalues.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra276.formatargvalues_name_length_is_15:
  description: "inspect.formatargvalues.__name__.__len__() == 15 — 'formatargvalues' has 15 characters"
