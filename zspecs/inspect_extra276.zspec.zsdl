spec: inspect_extra276
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.classify_class_attrs, getdoc, cleandoc, and formatargvalues are all pure-Python functions."
    - "All four have __module__ == 'inspect' and __class__.__name__ == 'function'."
    - "classify_class_attrs.__name__ == 'classify_class_attrs' (20 chars)."
    - "getdoc.__name__ == 'getdoc' (6 chars); cleandoc.__name__ == 'cleandoc' (8 chars)."
    - "formatargvalues.__name__ == 'formatargvalues' (15 chars)."
    - "getmembers.__name__ == 'getmembers' (10 chars); __module__ == 'inspect'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.classify_class_attrs and inspect.getdoc — function identity
#
# Both are pure-Python functions: __class__.__name__ == 'function'.
# Both have __module__ == 'inspect'.
# classify_class_attrs.__name__ == 'classify_class_attrs' (20 chars).
# getdoc.__name__ == 'getdoc' (6 chars).
# ---------------------------------------------------------------------------

table inspect_extra276.classify_getdoc_identity:
  description: "inspect.classify_class_attrs and getdoc function identity — __name__, __module__, __class__.__name__; name lengths; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex276cgd

  columns: [id, function, args, expected, description]
  rows:
    - [cca_name_eq,  classify_class_attrs.__name__.__eq__,           ["classify_class_attrs"], true, "inspect.classify_class_attrs.__name__ == 'classify_class_attrs'; verified with Python 3.14.3"]
    - [cca_name_len, classify_class_attrs.__name__.__len__,           [],                       20,   "inspect.classify_class_attrs.__name__.__len__() == 20; verified with Python 3.14.3"]
    - [cca_mod_eq,   classify_class_attrs.__module__.__eq__,          ["inspect"],              true, "inspect.classify_class_attrs.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [cca_cls_eq,   classify_class_attrs.__class__.__name__.__eq__,  ["function"],             true, "inspect.classify_class_attrs.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [gd_name_eq,   getdoc.__name__.__eq__,                          ["getdoc"],               true, "inspect.getdoc.__name__ == 'getdoc'; verified with Python 3.14.3"]
    - [gd_name_len,  getdoc.__name__.__len__,                          [],                       6,    "inspect.getdoc.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [gd_mod_eq,    getdoc.__module__.__eq__,                         ["inspect"],              true, "inspect.getdoc.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [gd_cls_eq,    getdoc.__class__.__name__.__eq__,                 ["function"],             true, "inspect.getdoc.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# inspect.cleandoc and inspect.formatargvalues — function identity
#
# Both are pure-Python functions: __class__.__name__ == 'function'.
# Both have __module__ == 'inspect'.
# cleandoc.__name__ == 'cleandoc' (8 chars).
# formatargvalues.__name__ == 'formatargvalues' (15 chars).
# ---------------------------------------------------------------------------

table inspect_extra276.cleandoc_formatargvalues_identity:
  description: "inspect.cleandoc and formatargvalues function identity — __name__, __module__, __class__.__name__; name lengths; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex276cfa

  columns: [id, function, args, expected, description]
  rows:
    - [cd_name_eq,  cleandoc.__name__.__eq__,            ["cleandoc"],        true, "inspect.cleandoc.__name__ == 'cleandoc'; verified with Python 3.14.3"]
    - [cd_name_len, cleandoc.__name__.__len__,            [],                  8,    "inspect.cleandoc.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [cd_mod_eq,   cleandoc.__module__.__eq__,           ["inspect"],         true, "inspect.cleandoc.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [cd_cls_eq,   cleandoc.__class__.__name__.__eq__,   ["function"],        true, "inspect.cleandoc.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [fv_name_eq,  formatargvalues.__name__.__eq__,      ["formatargvalues"], true, "inspect.formatargvalues.__name__ == 'formatargvalues'; verified with Python 3.14.3"]
    - [fv_name_len, formatargvalues.__name__.__len__,      [],                  15,   "inspect.formatargvalues.__name__.__len__() == 15; verified with Python 3.14.3"]
    - [fv_mod_eq,   formatargvalues.__module__.__eq__,    ["inspect"],         true, "inspect.formatargvalues.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [fv_cls_eq,   formatargvalues.__class__.__name__.__eq__, ["function"],   true, "inspect.formatargvalues.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra276
# ---------------------------------------------------------------------------

invariant inspect_extra276.classify_class_attrs_module_is_inspect:
  description: "inspect.classify_class_attrs.__module__ == 'inspect' — pure-Python function defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: classify_class_attrs.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra276.classify_class_attrs_name_length_is_20:
  description: "inspect.classify_class_attrs.__name__.__len__() == 20 — 'classify_class_attrs' has 20 characters"
  category: identity
  kind: python_call_eq
  function: classify_class_attrs.__name__.__len__
  args: []
  expected: 20

invariant inspect_extra276.getdoc_module_is_inspect:
  description: "inspect.getdoc.__module__ == 'inspect' — getdoc is a pure-Python function defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: getdoc.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra276.getdoc_is_function:
  description: "inspect.getdoc.__class__.__name__ == 'function' — getdoc is a pure-Python function"
  category: identity
  kind: python_call_eq
  function: getdoc.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra276.cleandoc_module_is_inspect:
  description: "inspect.cleandoc.__module__ == 'inspect' — cleandoc is a pure-Python function defined in the inspect module"
  category: identity
