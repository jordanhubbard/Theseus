spec: re_extra841
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython/Lib/re/__init__.py"
    - "cpython/Lib/re/_compiler.py"
  not_derived_from:
    - "any third-party regex library"
  notes:
    - "Covers __doc__.__class__.__name__ checks for re module functions"
    - "Covers __qualname__ and __module__ checks for re.error exception class"
    - "All docs are non-None strings in CPython 3.9+"
  created_at: "2026-04-12"

table re_extra841.re_func_doc_classnames:
  description: "re module function __doc__.__class__.__name__ equality checks confirming docs are str"
  kind: python_call_eq
  category: doc_class
  id_prefix: re841dc
  columns: [id, function, args, expected]
  rows:
    - [re841dc001, re.compile.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re841dc002, re.match.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re841dc003, re.search.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re841dc004, re.fullmatch.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re841dc005, re.sub.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re841dc006, re.split.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re841dc007, re.findall.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re841dc008, re.finditer.__doc__.__class__.__name__.__eq__, ["str"], true]

table re_extra841.re_error_qualnames:
  description: "re.error exception class __qualname__ and __module__ equality checks"
  kind: python_call_eq
  category: qualname
  id_prefix: re841er
  columns: [id, function, args, expected]
  rows:
    - [re841er001, re.error.__init__.__qualname__.__eq__, ["error.__init__"], true]
    - [re841er002, re.error.__str__.__qualname__.__eq__, ["error.__str__"], true]
    - [re841er003, re.error.__qualname__.__eq__, ["error"], true]
    - [re841er004, re.error.__module__.__eq__, ["re"], true]
