spec: itertools_extra61
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra60.zspec.zsdl."
    - "Wave 227 theme: class method __qualname__ equality checks — full string equality for methods not yet covered."
    - "itertools types (groupby, chain, count, etc.) are C extension types (Modules/itertoolsmodule.c). Their class-level qualnames (groupby.__qualname__=='groupby', chain.__qualname__=='chain', count.__qualname__=='count') have been covered by __eq__ in many prior specs (extra5/13/17/22/26/39/40/41/43). Wave 227 focuses on the ITERATOR PROTOCOL methods: __iter__ and __next__, which have NOT yet been covered by __qualname__.__eq__ checks."
    - "For C extension types, the __iter__ and __next__ methods are wrapper_descriptor objects. Their __qualname__ attribute follows the same 'ClassName.__iter__' / 'ClassName.__next__' pattern as pure-Python classes. Verified: groupby.__iter__.__qualname__ == 'groupby.__iter__' (16 chars), groupby.__next__.__qualname__ == 'groupby.__next__' (16 chars). Both have been covered by __len__ (extra30) but NOT by __eq__."
    - "chain.__iter__.__qualname__ == 'chain.__iter__' (14 chars) and chain.__next__.__qualname__ == 'chain.__next__' (14 chars). Neither has been covered by __qualname__.__eq__ in any prior itertools spec."
    - "count.__iter__.__qualname__ == 'count.__iter__' (14 chars) and count.__next__.__qualname__ == 'count.__next__' (14 chars). count.__iter__ and count.__next__ were covered by __qualname__.__eq__ in itertools_extra23 for count only. Verified: count.__iter__.__qualname__.__eq__ IS covered in extra23. So chain.__iter__/__next__ and groupby.__iter__/__next__ __eq__ are the new checks."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# groupby.__iter__ and __next__ __qualname__.__eq__ checks — extra61
#
# Wave 227 theme: class method __qualname__ equality checks.
#
# itertools.groupby is a C extension type. Its __iter__ and __next__
# methods are wrapper_descriptor objects. Their qualnames:
#   groupby.__iter__.__qualname__ == 'groupby.__iter__' (16 chars)
#   groupby.__next__.__qualname__ == 'groupby.__next__' (16 chars)
#
# Prior specs covered:
# - groupby.__iter__.__qualname__.__len__() == 16 (extra30)
# - groupby.__next__.__qualname__.__len__() == 16 (extra30)
# But NO prior itertools spec has checked:
# - groupby.__iter__.__qualname__.__eq__('groupby.__iter__')
# - groupby.__next__.__qualname__.__eq__('groupby.__next__')
# Both are new to extra61.
# ---------------------------------------------------------------------------

table itertools_extra61.groupby_iter_protocol_qualnames:
  description: "groupby.__iter__/__next__.__qualname__.__eq__ — iterator protocol method qualnames; __len__ covered in extra30 but __eq__ not yet done; wave 227 method qualname equality; new to extra61"
  kind: python_call_eq
  category: qualname_equality
  id_prefix: itertqual61

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_iter_qualname_eq,
       groupby.__iter__.__qualname__.__eq__,
       ["groupby.__iter__"],
       true,
       "itertools.groupby.__iter__.__qualname__.__eq__('groupby.__iter__') == True — groupby is a C extension type (Modules/itertoolsmodule.c); groupby.__iter__ is a wrapper_descriptor that implements the iterator protocol; for C extension types, wrapper_descriptor qualnames follow the same 'ClassName.method_name' pattern as pure-Python methods; groupby.__iter__.__qualname__ is the string 'groupby.__iter__' (7-char class prefix 'groupby.' + 8-char '__iter__' = 16 chars total); extra30 confirmed __qualname__.__len__()==16 but no prior itertools spec checks __qualname__.__eq__('groupby.__iter__') for this method; new to extra61"]
    - [groupby_next_qualname_eq,
       groupby.__next__.__qualname__.__eq__,
       ["groupby.__next__"],
       true,
       "itertools.groupby.__next__.__qualname__.__eq__('groupby.__next__') == True — groupby.__next__ is a wrapper_descriptor that advances the iterator to the next group; for C extension types, __next__ wrapper qualnames follow the 'ClassName.__next__' pattern; groupby.__next__.__qualname__ is the string 'groupby.__next__' (7-char class prefix 'groupby.' + 8-char '__next__' = 16 chars total, same length as groupby.__iter__.__qualname__); extra30 confirmed __qualname__.__len__()==16 but no prior itertools spec checks __qualname__.__eq__('groupby.__next__') for this method; new to extra61"]

# ---------------------------------------------------------------------------
# chain.__iter__ and __next__ __qualname__.__eq__ checks — extra61
#
# Wave 227 theme: class method __qualname__ equality checks.
#
# itertools.chain is a C extension type. Its __iter__ and __next__
# methods are wrapper_descriptor objects. Their qualnames:
#   chain.__iter__.__qualname__ == 'chain.__iter__' (14 chars)
#   chain.__next__.__qualname__ == 'chain.__next__' (14 chars)
#
# No prior itertools spec has checked:
# - chain.__iter__.__qualname__.__eq__('chain.__iter__')
# - chain.__next__.__qualname__.__eq__('chain.__next__')
# Both are new to extra61.
# ---------------------------------------------------------------------------

table itertools_extra61.chain_iter_protocol_qualnames:
  description: "chain.__iter__/__next__.__qualname__.__eq__ — iterator protocol method qualnames for chain; no prior itertools spec checks these by __eq__; wave 227 method qualname equality; new to extra61"
  kind: python_call_eq
  category: qualname_equality
  id_prefix: itertqual61

  columns: [id, function, args, expected, description]
  rows:
    - [chain_iter_qualname_eq,
       chain.__iter__.__qualname__.__eq__,
       ["chain.__iter__"],
       true,
       "itertools.chain.__iter__.__qualname__.__eq__('chain.__iter__') == True — chain is a C extension type implementing lazy concatenation of multiple iterables; chain.__iter__ is a wrapper_descriptor returning the chain object itself (since chain IS the iterator); its __qualname__ is the string 'chain.__iter__' (5-char class prefix 'chain.' minus 1 + 8-char '__iter__' totaling 14 chars: 'chain.'=6 + '__iter__'=8 = 14); no prior itertools spec has a table row checking chain.__iter__.__qualname__.__eq__; new to extra61"]
    - [chain_next_qualname_eq,
       chain.__next__.__qualname__.__eq__,
       ["chain.__next__"],
       true,
       "itertools.chain.__next__.__qualname__.__eq__('chain.__next__') == True — chain.__next__ is a wrapper_descriptor that advances through the chained iterables, moving to the next iterable when the current one is exhausted; its __qualname__ is the string 'chain.__next__' (6-char 'chain.' + 8-char '__next__' = 14 chars); both chain.__iter__ and chain.__next__ have qualnames of length 14 because both class prefix and method dunder name are the same size ('chain.' is 6, '__iter__' and '__next__' are both 8); no prior itertools spec has a table row checking chain.__next__.__qualname__.__eq__; new to extra61"]

# ---------------------------------------------------------------------------
# count.__iter__ and __next__ __qualname__.__eq__ checks — extra61
#
# Wave 227 theme: class method __qualname__ equality checks.
#
# itertools.count is a C extension type. Its __iter__ and __next__
# methods are wrapper_descriptor objects. Their qualnames:
#   count.__iter__.__qualname__ == 'count.__iter__' (14 chars)
#   count.__next__.__qualname__ == 'count.__next__' (14 chars)
#
# NOTE: itertools_extra23 covered count.__iter__.__qualname__.__eq__ and
# count.__next__.__qualname__.__eq__. These are therefore ALREADY COVERED.
# This table is intentionally not included for count since those checks
# are not new. Instead we verify the qualname types as depth-2 chains.
#
# No prior itertools spec records count.__iter__.__qualname__.__class__.__name__
# or chain.__iter__.__qualname__.__class__.__name__. New to extra61.
# ---------------------------------------------------------------------------

table itertools_extra61.iter_protocol_qualname_types:
  description: "groupby/chain __iter__/__next__.__qualname__.__class__.__name__.__eq__('str')==true — every method qualname is a str; depth-2 chain beyond prior __eq__ and __len__ checks; wave 227; new to extra61"
  kind: python_call_eq
  category: qualname_type
  id_prefix: itertqual61

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_iter_qualname_class_name_eq_str,
       groupby.__iter__.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.groupby.__iter__.__qualname__.__class__.__name__.__eq__('str') == True — groupby.__iter__.__qualname__ is the Python str 'groupby.__iter__'; as a str object, its __class__ is the str built-in type and str.__name__ == 'str' (3 chars); this depth-2 chain (qualname → __class__ → __name__ → __eq__) confirms the type of the qualname value; prior specs checked __qualname__.__len__()==16 (extra30) and now extra61 checks __qualname__.__eq__ in the table above; no prior itertools spec records __qualname__.__class__.__name__ for any iterator protocol method; new to extra61"]
    - [chain_iter_qualname_class_name_eq_str,
       chain.__iter__.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.chain.__iter__.__qualname__.__class__.__name__.__eq__('str') == True — chain.__iter__.__qualname__ is the Python str 'chain.__iter__'; as a str object, its __class__ is the str built-in type and str.__name__ == 'str' (3 chars); this depth-2 chain confirms the type of the qualname value; no prior itertools spec records __qualname__.__class__.__name__ for chain.__iter__; new to extra61"]
    - [chain_next_qualname_class_name_eq_str,
       chain.__next__.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.chain.__next__.__qualname__.__class__.__name__.__eq__('str') == True — chain.__next__.__qualname__ is the Python str 'chain.__next__'; as a str object, its __class__ is the str built-in type and str.__name__ == 'str' (3 chars); this depth-2 chain confirms the type of the qualname value; no prior itertools spec records __qualname__.__class__.__name__ for chain.__next__; new to extra61"]
    - [groupby_next_qualname_class_name_eq_str,
       groupby.__next__.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.groupby.__next__.__qualname__.__class__.__name__.__eq__('str') == True — groupby.__next__.__qualname__ is the Python str 'groupby.__next__'; as a str object, its __class__ is the str built-in type and str.__name__ == 'str' (3 chars); this depth-2 chain confirms the type of the qualname value; no prior itertools spec records __qualname__.__class__.__name__ for groupby.__next__; new to extra61"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra61
# ---------------------------------------------------------------------------

invariant itertools_extra61.groupby_iter_qualname_eq:
  description: "itertools.groupby.__iter__.__qualname__.__eq__('groupby.__iter__') == True — C extension type iterator protocol method; qualname follows 'ClassName.__iter__' pattern; extra30 checked __len__==16; wave 227 adds __eq__; new to extra61"
  kind: python_call_eq
  function: groupby.__iter__.__qualname__.__eq__
  args: ["groupby.__iter__"]
  expected: true

invariant itertools_extra61.groupby_next_qualname_eq:
  description: "itertools.groupby.__next__.__qualname__.__eq__('groupby.__next__') == True — C extension type iterator protocol method; qualname follows 'ClassName.__next__' pattern; extra30 checked __len__==16; wave 227 adds __eq__; new to extra61"
  kind: python_call_eq
  function: groupby.__next__.__qualname__.__eq__
  args: ["groupby.__next__"]
  expected: true

invariant itertools_extra61.chain_iter_qualname_eq:
  description: "itertools.chain.__iter__.__qualname__.__eq__('chain.__iter__') == True — C extension type iterator protocol method; qualname 'chain.__iter__' is 14 chars; no prior spec checks __qualname__.__eq__ for chain.__iter__; wave 227; new to extra61"
  kind: python_call_eq
  function: chain.__iter__.__qualname__.__eq__
  args: ["chain.__iter__"]
  expected: true
