spec: concurrent_futures_extra258
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/process.py, Lib/concurrent/futures/thread.py"
  notes:
    - "ProcessPoolExecutor.__module__ == 'concurrent.futures.process'; ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'."
    - "Executor (base class) lives in concurrent.futures._base."
    - "Executor.__init__ inherits from object — its __qualname__ is 'object.__init__'."
    - "ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (overrides Executor.map)."
    - "ThreadPoolExecutor.map is NOT overridden — it inherits Executor.map, so __qualname__ == 'Executor.map'."
    - "ProcessPoolExecutor._adjust_process_count exists as a private method with qualname 'ProcessPoolExecutor._adjust_process_count'."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ProcessPoolExecutor class and method qualnames
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra258.ProcessPoolExecutor.__qualname__:
  description: "concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor'"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__qualname__.__eq__
  args: ["ProcessPoolExecutor"]
  expected: true

invariant concurrent_futures_extra258.ProcessPoolExecutor.__module__:
  description: "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process'"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.process"]
  expected: true

invariant concurrent_futures_extra258.ProcessPoolExecutor.__init__.__qualname__:
  description: "ProcessPoolExecutor.__init__.__qualname__ == 'ProcessPoolExecutor.__init__'"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__init__.__qualname__.__eq__
  args: ["ProcessPoolExecutor.__init__"]
  expected: true

invariant concurrent_futures_extra258.ProcessPoolExecutor.submit.__qualname__:
  description: "ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit'"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.submit.__qualname__.__eq__
  args: ["ProcessPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra258.ProcessPoolExecutor.map.__qualname__:
  description: "ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' — overrides Executor.map"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.map.__qualname__.__eq__
  args: ["ProcessPoolExecutor.map"]
  expected: true

invariant concurrent_futures_extra258.ProcessPoolExecutor.shutdown.__qualname__:
  description: "ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown'"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.shutdown.__qualname__.__eq__
  args: ["ProcessPoolExecutor.shutdown"]
  expected: true

invariant concurrent_futures_extra258.ProcessPoolExecutor._adjust_process_count.__qualname__:
  description: "ProcessPoolExecutor._adjust_process_count.__qualname__ == 'ProcessPoolExecutor._adjust_process_count'"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor._adjust_process_count.__qualname__.__eq__
  args: ["ProcessPoolExecutor._adjust_process_count"]
  expected: true

# ---------------------------------------------------------------------------
# ThreadPoolExecutor class and method qualnames
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra258.ThreadPoolExecutor.__qualname__:
  description: "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor'"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__qualname__.__eq__
  args: ["ThreadPoolExecutor"]
  expected: true

invariant concurrent_futures_extra258.ThreadPoolExecutor.__module__:
  description: "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra258.ThreadPoolExecutor.__init__.__qualname__:
  description: "ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__'"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__init__.__qualname__.__eq__
  args: ["ThreadPoolExecutor.__init__"]
  expected: true

invariant concurrent_futures_extra258.ThreadPoolExecutor.submit.__qualname__:
  description: "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit'"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.submit.__qualname__.__eq__
  args: ["ThreadPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra258.ThreadPoolExecutor.map.__qualname__:
  description: "ThreadPoolExecutor.map.__qualname__ == 'Executor.map' — inherited, not overridden"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true

invariant concurrent_futures_extra258.ThreadPoolExecutor.shutdown.__qualname__:
  description: "ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.shutdown.__qualname__.__eq__
  args: ["ThreadPoolExecutor.shutdown"]
  expected: true

# ---------------------------------------------------------------------------
# Executor base class
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra258.Executor.__qualname__:
  description: "concurrent.futures.Executor.__qualname__ == 'Executor'"
  category: identity
  kind: python_call_eq
  function: Executor.__qualname__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra258.Executor.__module__:
  description: "concurrent.futures.Executor.__module__ == 'concurrent.futures._base'"
  category: identity
  kind: python_call_eq
  function: Executor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra258.Executor.__init__.__qualname__:
  description: "Executor.__init__.__qualname__ == 'object.__init__' — inherits from object"
  category: identity
  kind: python_call_eq
  function: Executor.__init__.__qualname__.__eq__
  args: ["object.__init__"]
  expected: true

invariant concurrent_futures_extra258.Executor.map.__qualname__:
  description: "Executor.map.__qualname__ == 'Executor.map'"
  category: identity
  kind: python_call_eq
  function: Executor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true

# ---------------------------------------------------------------------------
# Cross-executor table: __qualname__ strings side by side
# ---------------------------------------------------------------------------

table concurrent_futures_extra258.executor_qualnames:
  description: "Class-level __qualname__ for ProcessPoolExecutor, ThreadPoolExecutor, and Executor"
  kind: python_call_eq
  category: identity
  id_prefix: eqname

  columns: [id, function, args, expected, description]
  rows:
    - [process_pool, ProcessPoolExecutor.__qualname__.__eq__, ["ProcessPoolExecutor"], true, "ProcessPoolExecutor.__qualname__"]
    - [thread_pool,  ThreadPoolExecutor.__qualname__.__eq__,  ["ThreadPoolExecutor"],  true, "ThreadPoolExecutor.__qualname__"]
    - [executor,     Executor.__qualname__.__eq__,            ["Executor"],            true, "Executor.__qualname__"]

# ---------------------------------------------------------------------------
# Cross-executor table: submit and shutdown qualnames
# ---------------------------------------------------------------------------

table concurrent_futures_extra258.method_qualnames:
  description: "submit and shutdown __qualname__ values for ProcessPoolExecutor and ThreadPoolExecutor"
  kind: python_call_eq
  category: identity
  id_prefix: mqname

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_submit,   ProcessPoolExecutor.submit.__qualname__.__eq__,   ["ProcessPoolExecutor.submit"],   true, "ProcessPoolExecutor.submit.__qualname__"]
    - [ppe_shutdown, ProcessPoolExecutor.shutdown.__qualname__.__eq__,  ["ProcessPoolExecutor.shutdown"], true, "ProcessPoolExecutor.shutdown.__qualname__"]
    - [tpe_submit,   ThreadPoolExecutor.submit.__qualname__.__eq__,    ["ThreadPoolExecutor.submit"],    true, "ThreadPoolExecutor.submit.__qualname__"]
    - [tpe_shutdown, ThreadPoolExecutor.shutdown.__qualname__.__eq__,   ["ThreadPoolExecutor.shutdown"],  true, "ThreadPoolExecutor.shutdown.__qualname__"]
