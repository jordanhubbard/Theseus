# ---------------------------------------------------------------------------
# Standalone invariants — extra79
# ---------------------------------------------------------------------------

invariant threading_extra79.Condition_init_code_co_name:
  description: "threading.Condition.__init__.__code__.co_name.__eq__('__init__') == True — Condition.__init__ code object name is '__init__'; wave 244 Condition.__init__ code attrs; new to extra79"
  kind: python_call_eq
  function: Condition.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

invariant threading_extra79.Condition_init_code_co_argcount:
  description: "threading.Condition.__init__.__code__.co_argcount.__eq__(2) == True — Condition.__init__(self, lock=None) has 2 positional-or-keyword args; wave 244 Condition.__init__ code attrs; new to extra79"
  kind: python_call_eq
  function: Condition.__init__.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant threading_extra79.Barrier_init_code_co_argcount:
  description: "threading.Barrier.__init__.__code__.co_argcount.__eq__(4) == True — Barrier.__init__(self, parties, action, timeout) has 4 positional-or-keyword args; wave 244 Barrier.__init__ code attrs; new to extra79"
  kind: python_call_eq
