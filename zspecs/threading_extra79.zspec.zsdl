  id_prefix: thrdmore79

  columns: [id, function, args, expected, description]
  rows:
    - [Timer_init_code_co_name_eq_init,
       Timer.__init__.__code__.co_name.__eq__,
       ["__init__"],
       true,
       "threading.Timer.__init__.__code__.co_name.__eq__('__init__') == True — Timer is a pure-Python class defined in Lib/threading.py that subclasses Thread; its __init__ method's code object co_name records the method name '__init__' (8 chars); str.__eq__('__init__') returns True; no prior threading spec checks Timer.__init__.__code__.co_name via thrdmore79; new to extra79"]
    - [Timer_init_code_co_argcount_eq_5,
       Timer.__init__.__code__.co_argcount.__eq__,
       [5],
       true,
       "threading.Timer.__init__.__code__.co_argcount.__eq__(5) == True — Timer.__init__(self, interval, function, args=None, kwargs=None) takes five positional-or-keyword arguments: self, interval, function, args (default None), and kwargs (default None); the code object's co_argcount is 5; int.__eq__(5) returns True; no prior threading spec checks Timer.__init__.__code__.co_argcount via thrdmore79; new to extra79"]

