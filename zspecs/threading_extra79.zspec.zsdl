#
# No prior threading spec checks Barrier.__init__.__code__ via thrdmore79. New to extra79.
# ---------------------------------------------------------------------------

table threading_extra79.Barrier_init_code:
  description: "Barrier.__init__.__code__.co_name=='__init__', co_argcount==4, co_varnames.__class__.__name__=='tuple'; wave 244 Barrier.__init__ code attrs; new to extra79"
  kind: python_call_eq
  category: type_identity
  id_prefix: thrdmore79

  columns: [id, function, args, expected, description]
  rows:
    - [Barrier_init_code_co_name_eq_init,
       Barrier.__init__.__code__.co_name.__eq__,
       ["__init__"],
       true,
       "threading.Barrier.__init__.__code__.co_name.__eq__('__init__') == True — Barrier is a pure-Python class defined in Lib/threading.py; its __init__ method's code object co_name records the method name '__init__' (8 chars); str.__eq__('__init__') returns True; no prior threading spec checks Barrier.__init__.__code__.co_name via thrdmore79; new to extra79"]
    - [Barrier_init_code_co_argcount_eq_4,
       Barrier.__init__.__code__.co_argcount.__eq__,
       [4],
       true,
       "threading.Barrier.__init__.__code__.co_argcount.__eq__(4) == True — Barrier.__init__(self, parties, action=None, timeout=None) takes four positional-or-keyword arguments: self, parties, action (default None), and timeout (default None); the code object's co_argcount is 4; int.__eq__(4) returns True; no prior threading spec checks Barrier.__init__.__code__.co_argcount via thrdmore79; new to extra79"]
    - [Barrier_init_code_co_varnames_class_name_eq_tuple,
       Barrier.__init__.__code__.co_varnames.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "threading.Barrier.__init__.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — the co_varnames attribute of any Python code object is always a tuple of local variable name strings; for Barrier.__init__ the first four elements are ('self', 'parties', 'action', 'timeout'); __class__.__name__ == 'tuple' (5 chars); str.__eq__('tuple') returns True; no prior threading spec checks Barrier.__init__.__code__.co_varnames.__class__.__name__ via thrdmore79; new to extra79"]

