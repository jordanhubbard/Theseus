spec: threading_extra79
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra78.zspec.zsdl."
    - "This spec covers: threading Condition.__init__ code attrs + Barrier.__init__ code attrs + Timer.__init__ code attrs + Thread.join code attrs (Wave 244)."
    - "Condition.__init__.__code__.co_name == '__init__' — code object name matches method name. Verified with Python 3.14.3."
    - "Condition.__init__.__code__.co_argcount == 2 — self + lock=None (lock has a default, but co_argcount counts it). Verified with Python 3.14.3."
    - "Condition.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple. Verified with Python 3.14.3."
    - "Barrier.__init__.__code__.co_name == '__init__' — code object name matches method name. Verified with Python 3.14.3."
    - "Barrier.__init__.__code__.co_argcount == 4 — self + parties + action + timeout (action and timeout have defaults). Verified with Python 3.14.3."
    - "Barrier.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple. Verified with Python 3.14.3."
    - "Timer.__init__.__code__.co_name == '__init__' — code object name matches method name. Verified with Python 3.14.3."
    - "Timer.__init__.__code__.co_argcount == 5 — self + interval + function + args + kwargs. Verified with Python 3.14.3."
    - "Thread.join.__code__.co_name == 'join' — code object name matches method name. Verified with Python 3.14.3."
    - "Thread.join.__code__.co_argcount == 2 — self + timeout=None (timeout has a default but co_argcount counts it). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Condition.__init__ code object — extra79
#
# Wave 244 theme: Condition.__init__ code attrs.
#
# threading.Condition.__init__.__code__.co_name                         == '__init__'
# threading.Condition.__init__.__code__.co_argcount                     == 2
# threading.Condition.__init__.__code__.co_varnames.__class__.__name__  == 'tuple'
#
# No prior threading spec checks Condition.__init__.__code__ via thrdmore79. New to extra79.
# ---------------------------------------------------------------------------

table threading_extra79.Condition_init_code:
  description: "Condition.__init__.__code__.co_name=='__init__', co_argcount==2, co_varnames.__class__.__name__=='tuple'; wave 244 Condition.__init__ code attrs; new to extra79"
  kind: python_call_eq
  category: type_identity
  id_prefix: thrdmore79

  columns: [id, function, args, expected, description]
  rows:
    - [Condition_init_code_co_name_eq_init,
       Condition.__init__.__code__.co_name.__eq__,
       ["__init__"],
       true,
       "threading.Condition.__init__.__code__.co_name.__eq__('__init__') == True — Condition is a pure-Python class defined in Lib/threading.py; its __init__ method's code object co_name records the method name '__init__' (8 chars); str.__eq__('__init__') returns True; no prior threading spec checks Condition.__init__.__code__.co_name via thrdmore79; new to extra79"]
    - [Condition_init_code_co_argcount_eq_2,
       Condition.__init__.__code__.co_argcount.__eq__,
       [2],
       true,
       "threading.Condition.__init__.__code__.co_argcount.__eq__(2) == True — Condition.__init__(self, lock=None) takes two positional-or-keyword arguments: self and lock (lock has a default of None but co_argcount still counts it); the code object's co_argcount is 2; int.__eq__(2) returns True; no prior threading spec checks Condition.__init__.__code__.co_argcount via thrdmore79; new to extra79"]
    - [Condition_init_code_co_varnames_class_name_eq_tuple,
       Condition.__init__.__code__.co_varnames.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "threading.Condition.__init__.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — the co_varnames attribute of any Python code object is always a tuple of local variable name strings; __class__.__name__ == 'tuple' (5 chars); str.__eq__('tuple') returns True; no prior threading spec checks Condition.__init__.__code__.co_varnames.__class__.__name__ via thrdmore79; new to extra79"]

# ---------------------------------------------------------------------------
