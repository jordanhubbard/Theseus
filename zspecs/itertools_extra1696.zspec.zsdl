spec: itertools_extra1696
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python itertools documentation — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools.zspec.zsdl — covers classnames and first_element checks"
    - "itertools_extra.zspec.zsdl — covers filterfalse classname, chain/repeat/islice length hints"
    - "itertools_extra1681.zspec.zsdl — covers __call__ callable protocol and iterator protocol presence"
  notes:
    - "Wave 560 (_extra1696): pickling protocol — which stdlib types define __reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__ in their own __dict__."
    - "Most itertools C types are stateful iterators and are intentionally NOT picklable — __reduce__ is absent from their __dict__."
    - "itertools.count defines __reduce__ in its __dict__ (Python 3.12+) to support pickling of its start/step state."
    - "itertools.repeat defines __reduce__ in its __dict__ to support pickling of its object/times state."
    - "itertools.chain, cycle, islice, product, permutations, combinations do NOT define __reduce__ — they are not picklable."
    - "None of the itertools C types define __getstate__, __setstate__, __getnewargs__, or __getnewargs_ex__ in their __dict__."
    - "None of the itertools C types define __copy__ or __deepcopy__ in their __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: pickling_protocol_reduce
#
# Records whether each itertools C type defines __reduce__ in its own
# __dict__.  Only count and repeat define __reduce__ for pickling support.
# All other iterator types do not support pickling.
# ---------------------------------------------------------------------------

table itertools_extra1696.pickling_protocol_reduce:
  description: "itertools types __reduce__ dict-presence checks"
  kind: python_call_eq
  category: pickling_protocol_reduce
  id_prefix: it1696

  columns: [id, function, args, expected]
  rows:
    - ["it1696001", "itertools.count.__dict__.__contains__",                       ["__reduce__"], true]
    - ["it1696002", "itertools.repeat.__dict__.__contains__",                      ["__reduce__"], true]
    - ["it1696003", "itertools.chain.__dict__.__contains__",                       ["__reduce__"], false]
    - ["it1696004", "itertools.cycle.__dict__.__contains__",                       ["__reduce__"], false]
    - ["it1696005", "itertools.islice.__dict__.__contains__",                      ["__reduce__"], false]
    - ["it1696006", "itertools.product.__dict__.__contains__",                     ["__reduce__"], false]
    - ["it1696007", "itertools.permutations.__dict__.__contains__",                ["__reduce__"], false]
    - ["it1696008", "itertools.combinations.__dict__.__contains__",                ["__reduce__"], false]
    - ["it1696009", "itertools.combinations_with_replacement.__dict__.__contains__", ["__reduce__"], false]
    - ["it1696010", "itertools.accumulate.__dict__.__contains__",                  ["__reduce__"], false]
    - ["it1696011", "itertools.compress.__dict__.__contains__",                    ["__reduce__"], false]
    - ["it1696012", "itertools.dropwhile.__dict__.__contains__",                   ["__reduce__"], false]
    - ["it1696013", "itertools.filterfalse.__dict__.__contains__",                 ["__reduce__"], false]
    - ["it1696014", "itertools.starmap.__dict__.__contains__",                     ["__reduce__"], false]
    - ["it1696015", "itertools.takewhile.__dict__.__contains__",                   ["__reduce__"], false]
    - ["it1696016", "itertools.zip_longest.__dict__.__contains__",                 ["__reduce__"], false]

# ---------------------------------------------------------------------------
# Table 2: pickling_protocol_other
#
# Confirms that no itertools C type defines __getstate__, __setstate__,
# __getnewargs__, or __getnewargs_ex__ in its own __dict__.  The types that
# are picklable (count, repeat) use __reduce__ exclusively.
# ---------------------------------------------------------------------------

table itertools_extra1696.pickling_protocol_other:
  description: "itertools types __getstate__/__setstate__/__getnewargs__ dict-presence checks (all false)"
  kind: python_call_eq
  category: pickling_protocol_other
  id_prefix: it1696

  columns: [id, function, args, expected]
  rows:
    - ["it1696020", "itertools.count.__dict__.__contains__",  ["__getstate__"],    false]
    - ["it1696021", "itertools.count.__dict__.__contains__",  ["__setstate__"],    false]
    - ["it1696022", "itertools.count.__dict__.__contains__",  ["__getnewargs__"],  false]
    - ["it1696023", "itertools.count.__dict__.__contains__",  ["__getnewargs_ex__"], false]
    - ["it1696024", "itertools.repeat.__dict__.__contains__", ["__getstate__"],    false]
    - ["it1696025", "itertools.repeat.__dict__.__contains__", ["__setstate__"],    false]
    - ["it1696026", "itertools.repeat.__dict__.__contains__", ["__getnewargs__"],  false]
    - ["it1696027", "itertools.repeat.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["it1696028", "itertools.chain.__dict__.__contains__",  ["__getstate__"],    false]
    - ["it1696029", "itertools.chain.__dict__.__contains__",  ["__setstate__"],    false]
    - ["it1696030", "itertools.cycle.__dict__.__contains__",  ["__getstate__"],    false]
    - ["it1696031", "itertools.cycle.__dict__.__contains__",  ["__setstate__"],    false]

# ---------------------------------------------------------------------------
# Table 3: copy_protocol_absent
#
# Verifies that __copy__ and __deepcopy__ are absent from itertools C type
# __dict__ entries.  No itertools type implements custom copy protocol;
# the few picklable types (count, repeat) rely on __reduce__ for copy too.
# ---------------------------------------------------------------------------

table itertools_extra1696.copy_protocol_absent:
  description: "itertools C types do not define __copy__ or __deepcopy__ in their __dict__"
  kind: python_call_eq
  category: copy_protocol_absent
  id_prefix: it1696

  columns: [id, function, args, expected]
  rows:
    - ["it1696040", "itertools.count.__dict__.__contains__",   ["__copy__"],     false]
    - ["it1696041", "itertools.count.__dict__.__contains__",   ["__deepcopy__"], false]
    - ["it1696042", "itertools.repeat.__dict__.__contains__",  ["__copy__"],     false]
    - ["it1696043", "itertools.repeat.__dict__.__contains__",  ["__deepcopy__"], false]
    - ["it1696044", "itertools.chain.__dict__.__contains__",   ["__copy__"],     false]
    - ["it1696045", "itertools.chain.__dict__.__contains__",   ["__deepcopy__"], false]
    - ["it1696046", "itertools.cycle.__dict__.__contains__",   ["__copy__"],     false]
    - ["it1696047", "itertools.cycle.__dict__.__contains__",   ["__deepcopy__"], false]
    - ["it1696048", "itertools.product.__dict__.__contains__", ["__copy__"],     false]
    - ["it1696049", "itertools.product.__dict__.__contains__", ["__deepcopy__"], false]
