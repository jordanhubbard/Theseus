spec: re_extra67
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python code object co_varnames, co_filename, and co_flags documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra66.zspec.zsdl — covers search/__code__.co_name.__eq__('search'); compile/__code__.co_name.__eq__('compile'); match/__code__.co_name.__eq__('match'); sub/__code__.co_name.__eq__('sub'); search/__code__.co_argcount.__eq__(3); compile/__code__.co_argcount.__eq__(2)."
    - "re_extra65.zspec.zsdl — covers re.search/__defaults__/__class__.__name__.__eq__('tuple') and __len__()==1; re.compile/__defaults__/__class__.__name__.__eq__('tuple') and __len__()==1; re.search/__code__.__class__.__name__.__eq__('code'); re.compile/__code__.__class__.__name__.__eq__('code'); re.Match/__doc__.__contains__('match'/'boolean'); re.Pattern/__doc__.__contains__('regular'/'Compiled')."
    - "re_extra64.zspec.zsdl — covers re.search/__annotations__/__globals__ class identity; re.error/__doc__.__contains__('pattern'/'Exception')."
    - "re_extra56.zspec.zsdl — covers search/compile __qualname__.__eq__() as namespace re-anchors."
  notes:
    - "This spec extends re_extra66.zspec.zsdl."
    - "Theme: __code__ attribute chains — co_varnames, co_filename, co_flags for re.search/re.compile/re.match/re.sub."
    - "re module is pure Python (Lib/re/__init__.py). re.search, re.compile, re.match, and re.sub are Python functions with __code__ objects."
    - "re.search.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple of local variable names in CPython code objects. No prior re spec checks search.__code__.co_varnames.__class__.__name__ in recode3_67 namespace. Novel co_varnames class-name anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.search.__code__.co_varnames[0] == 'pattern' — search(pattern, string, flags=0) so the first positional parameter is 'pattern'; co_varnames[0] is 'pattern'. Table function values containing '[' must be double-quoted. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.compile.__code__.co_varnames[0] == 'pattern' — compile(pattern, flags=0) so first parameter is 'pattern'. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.match.__code__.co_varnames[0] == 'pattern' — match(pattern, string, flags=0) so first parameter is 'pattern'. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.sub.__code__.co_varnames[0] == 'pattern' — sub(pattern, repl, string, count=0, flags=0) so first parameter is 'pattern'. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.search.__code__.co_filename.__contains__('.py') == True — re is pure Python; co_filename contains the path to the .py source file. No prior re spec checks co_filename.__contains__('.py') for any re function. Novel co_filename anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.search.__code__.co_flags.__class__.__name__ == 'int' — co_flags is an integer bitmask encoding code object properties. No prior re spec checks co_flags.__class__.__name__ for any re function. Novel co_flags class-name anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.search, re.compile, re.match __code__.co_varnames class name
#
# co_varnames is a tuple of all local variable names (parameters first, then
# locals). In CPython this is always stored as a Python tuple.
#
#   re.search.__code__.co_varnames.__class__.__name__  == 'tuple'
#   re.compile.__code__.co_varnames.__class__.__name__ == 'tuple'
#   re.match.__code__.co_varnames.__class__.__name__   == 'tuple'
#
# No prior re spec checks co_varnames.__class__.__name__ for any re function
# in the recode3_67 namespace. Novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra67.co_varnames_class_name:
  description: "re.search/compile/match __code__.co_varnames.__class__.__name__.__eq__('tuple') — co_varnames is always a tuple of local variable names in CPython; re is pure Python; no prior re spec checks co_varnames.__class__.__name__ for any re function in recode3_67 namespace; novel co_varnames class-name anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_covarnames
  id_prefix: recode3_67covarclass

  columns: [id, function, args, expected]
  rows:
    - [search_co_varnames_class,  search.__code__.co_varnames.__class__.__name__.__eq__,  ["tuple"], true]
    - [compile_co_varnames_class, compile.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true]
    - [match_co_varnames_class,   match.__code__.co_varnames.__class__.__name__.__eq__,   ["tuple"], true]

# ---------------------------------------------------------------------------
# re.search, re.compile, re.match, re.sub __code__.co_varnames[0]
#
# co_varnames[0] is the first positional parameter of each function.
# All four re functions take 'pattern' as their first argument:
#
#   search(pattern, string, flags=0)         → co_varnames[0] == 'pattern'
#   compile(pattern, flags=0)                → co_varnames[0] == 'pattern'
#   match(pattern, string, flags=0)          → co_varnames[0] == 'pattern'
#   sub(pattern, repl, string, count=0, ...) → co_varnames[0] == 'pattern'
#
# No prior re spec checks co_varnames[0] for any re function.
# Table function values containing '[' MUST be double-quoted YAML strings.
# Novel co_varnames[0] anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra67.co_varnames_first_arg:
  description: "re.search/compile/match/sub __code__.co_varnames[0].__eq__('pattern') — all four re functions take 'pattern' as the first positional argument; co_varnames[0] is always the first parameter; no prior re spec checks co_varnames[0] for any re function in recode3_67 namespace; function values with '[' are double-quoted per ZSDL rules; novel co_varnames[0] anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_covarnames
  id_prefix: recode3_67covarfirst

  columns: [id, function, args, expected]
  rows:
    - [search_co_varnames_0_pattern,  "search.__code__.co_varnames[0].__eq__",  ["pattern"], true]
    - [compile_co_varnames_0_pattern, "compile.__code__.co_varnames[0].__eq__", ["pattern"], true]
    - [match_co_varnames_0_pattern,   "match.__code__.co_varnames[0].__eq__",   ["pattern"], true]
    - [sub_co_varnames_0_pattern,     "sub.__code__.co_varnames[0].__eq__",     ["pattern"], true]

# ---------------------------------------------------------------------------
# re.search, re.compile, re.match, re.sub __code__.co_filename contains '.py'
#
# co_filename holds the source file path from which the code was compiled.
# re is a pure Python module (Lib/re/__init__.py) so the filename contains
# the substring '.py'.
#
#   re.search.__code__.co_filename.__contains__('.py')  == True
#   re.compile.__code__.co_filename.__contains__('.py') == True
#   re.match.__code__.co_filename.__contains__('.py')   == True
#   re.sub.__code__.co_filename.__contains__('.py')     == True
#
# No prior re spec checks co_filename.__contains__('.py') for any re function
# in the recode3_67 namespace. Novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra67.co_filename_contains_py:
  description: "re.search/compile/match/sub __code__.co_filename.__contains__('.py') — re is pure Python (Lib/re/__init__.py); co_filename holds the source file path containing '.py'; no prior re spec checks co_filename.__contains__('.py') for any re function in recode3_67 namespace; novel co_filename anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_cofilename
  id_prefix: recode3_67cofile

  columns: [id, function, args, expected]
  rows:
    - [search_co_filename_contains_py,  search.__code__.co_filename.__contains__,  [".py"], true]
    - [compile_co_filename_contains_py, compile.__code__.co_filename.__contains__, [".py"], true]
    - [match_co_filename_contains_py,   match.__code__.co_filename.__contains__,   [".py"], true]
    - [sub_co_filename_contains_py,     sub.__code__.co_filename.__contains__,     [".py"], true]

# ---------------------------------------------------------------------------
# re.search, re.compile, re.match __code__.co_flags class name
#
# co_flags is an integer bitmask encoding various properties of the code
# object (e.g., CO_OPTIMIZED, CO_NEWLOCALS, CO_VARARGS, CO_VARKEYWORDS).
# Its type is always int.
#
#   re.search.__code__.co_flags.__class__.__name__  == 'int'
#   re.compile.__code__.co_flags.__class__.__name__ == 'int'
#   re.match.__code__.co_flags.__class__.__name__   == 'int'
#
# No prior re spec checks co_flags.__class__.__name__ for any re function
# in the recode3_67 namespace. Novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra67.co_flags_class_name:
  description: "re.search/compile/match __code__.co_flags.__class__.__name__.__eq__('int') — co_flags is an integer bitmask encoding code object properties; no prior re spec checks co_flags.__class__.__name__ for any re function in recode3_67 namespace; novel co_flags class-name anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_coflags
  id_prefix: recode3_67coflags

  columns: [id, function, args, expected]
  rows:
    - [search_co_flags_class,  search.__code__.co_flags.__class__.__name__.__eq__,  ["int"], true]
    - [compile_co_flags_class, compile.__code__.co_flags.__class__.__name__.__eq__, ["int"], true]
    - [match_co_flags_class,   match.__code__.co_flags.__class__.__name__.__eq__,   ["int"], true]

invariant re_extra67.search_co_varnames_tuple:
  description: "re.search.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is always a tuple of local variable names in CPython; re.search is a pure Python function; no prior re spec checks co_varnames.__class__.__name__ for search in recode3_67 namespace; novel co_varnames class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_covarnames
  kind: python_call_eq
  function: search.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant re_extra67.search_co_varnames_first_pattern:
  description: "re.search.__code__.co_varnames[0].__eq__('pattern') == True — search(pattern, string, flags=0) so first positional parameter is 'pattern'; co_varnames[0] is 'pattern'; no prior re spec checks co_varnames[0] for search in recode3_67 namespace; novel co_varnames[0] anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_covarnames
  kind: python_call_eq
  function: "search.__code__.co_varnames[0].__eq__"
  args: ["pattern"]
  expected: true

invariant re_extra67.compile_co_varnames_first_pattern:
  description: "re.compile.__code__.co_varnames[0].__eq__('pattern') == True — compile(pattern, flags=0) so first positional parameter is 'pattern'; co_varnames[0] is 'pattern'; no prior re spec checks co_varnames[0] for compile in recode3_67 namespace; novel co_varnames[0] anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_covarnames
  kind: python_call_eq
  function: "compile.__code__.co_varnames[0].__eq__"
  args: ["pattern"]
  expected: true

invariant re_extra67.search_co_filename_contains_py:
  description: "re.search.__code__.co_filename.__contains__('.py') == True — re is pure Python (Lib/re/__init__.py); co_filename holds the source file path containing '.py'; no prior re spec checks co_filename.__contains__('.py') for search in recode3_67 namespace; novel co_filename anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_cofilename
  kind: python_call_eq
  function: search.__code__.co_filename.__contains__
  args: [".py"]
  expected: true

invariant re_extra67.search_co_flags_int:
  description: "re.search.__code__.co_flags.__class__.__name__.__eq__('int') == True — co_flags is an integer bitmask encoding code object properties; no prior re spec checks co_flags.__class__.__name__ for search in recode3_67 namespace; novel co_flags class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_coflags
  kind: python_call_eq
  function: search.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true
