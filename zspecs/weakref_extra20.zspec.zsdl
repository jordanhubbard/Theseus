spec: weakref_extra20
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
    - "weakref_extra19.zspec.zsdl — covers ReferenceType/CallableProxyType/ProxyType/WeakMethod __qualname__ and WeakValueDictionary/WeakKeyDictionary __module__ in extra19 namespace."
    - "weakref_extra15.zspec.zsdl — covers ref.__qualname__/__eq__('ReferenceType') and WeakValueDictionary/__qualname__/WeakKeyDictionary/__qualname__ in a combined table."
    - "weakref_extra18.zspec.zsdl — covers ref.__qualname__ as a standalone invariant."
    - "weakref_extra6.zspec.zsdl — covers ProxyType/__qualname__/CallableProxyType/__qualname__/WeakMethod/__qualname__ standalones."
  notes:
    - "This spec extends weakref_extra19.zspec.zsdl."
    - "Focus: top-level class __qualname__ values (ref, WeakValueDictionary, WeakKeyDictionary, WeakSet, finalize) and method-level __qualname__ values (WeakValueDictionary.get, WeakSet.add, finalize.__call__) — none of the method-level qualnames appear in any prior weakref spec."
    - "weakref.ref.__qualname__ == 'ReferenceType' — the C-level type's internal qualname; verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-09."
    - "weakref.WeakValueDictionary.__qualname__ == 'WeakValueDictionary' — verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-09."
    - "weakref.WeakKeyDictionary.__qualname__ == 'WeakKeyDictionary' — verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-09."
    - "weakref.WeakSet.__qualname__ == 'WeakSet' — verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-09."
    - "weakref.finalize.__qualname__ == 'finalize' — verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-09."
    - "weakref.WeakValueDictionary.get.__qualname__ == 'WeakValueDictionary.get' — method qualname includes enclosing class; verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-09."
    - "weakref.WeakSet.add.__qualname__ == 'WeakSet.add' — method qualname includes enclosing class; verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-09."
    - "weakref.finalize.__call__.__qualname__ == 'finalize.__call__' — __call__ qualname includes enclosing class; verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# weakref.ref.__qualname__ — extra20 namespace standalone
#
# weakref_extra15 and weakref_extra18 cover ref.__qualname__ in those
# namespaces. Re-anchored here in the extra20 namespace. The C-level
# type's __qualname__ is 'ReferenceType', not 'ref'.
# ---------------------------------------------------------------------------

invariant weakref_extra20.ref.qualname:
  description: "weakref.ref.__qualname__ == 'ReferenceType' — C-level type internal qualname"
  category: class_qualname
  kind: python_call_eq
  function: ref.__qualname__.__eq__
  args: ["ReferenceType"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.WeakValueDictionary.__qualname__ — extra20 namespace standalone
#
# weakref_extra15 covers WeakValueDictionary.__qualname__ via a table.
# Re-anchored here in the extra20 namespace as an independent standalone
# invariant.
# ---------------------------------------------------------------------------

invariant weakref_extra20.WeakValueDictionary.qualname:
  description: "weakref.WeakValueDictionary.__qualname__ == 'WeakValueDictionary' — pure-Python class; qualname equals class name"
  category: class_qualname
  kind: python_call_eq
  function: WeakValueDictionary.__qualname__.__eq__
  args: ["WeakValueDictionary"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.WeakKeyDictionary.__qualname__ — extra20 namespace standalone
#
# weakref_extra15 covers WeakKeyDictionary.__qualname__ via a table.
# Re-anchored here in the extra20 namespace as an independent standalone
# invariant.
# ---------------------------------------------------------------------------

invariant weakref_extra20.WeakKeyDictionary.qualname:
  description: "weakref.WeakKeyDictionary.__qualname__ == 'WeakKeyDictionary' — pure-Python class; qualname equals class name"
  category: class_qualname
  kind: python_call_eq
  function: WeakKeyDictionary.__qualname__.__eq__
  args: ["WeakKeyDictionary"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.WeakSet.__qualname__ — extra20 namespace standalone
#
# Prior specs cover WeakSet.__qualname__ in the extra namespace. Re-anchored
# here in the extra20 namespace as an independent standalone invariant.
# ---------------------------------------------------------------------------

invariant weakref_extra20.WeakSet.qualname:
  description: "weakref.WeakSet.__qualname__ == 'WeakSet' — pure-Python class; qualname equals class name"
  category: class_qualname
  kind: python_call_eq
  function: WeakSet.__qualname__.__eq__
  args: ["WeakSet"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.finalize.__qualname__ — extra20 namespace standalone
#
# Prior specs cover finalize.__qualname__ in other namespaces. Re-anchored
# here in the extra20 namespace as an independent standalone invariant.
# ---------------------------------------------------------------------------

invariant weakref_extra20.finalize.qualname:
  description: "weakref.finalize.__qualname__ == 'finalize' — pure-Python class; qualname equals class name"
  category: class_qualname
  kind: python_call_eq
  function: finalize.__qualname__.__eq__
  args: ["finalize"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.WeakValueDictionary.get.__qualname__ — novel method-level invariant
#
# No prior weakref spec records WeakValueDictionary.get.__qualname__.
# Method qualnames include the enclosing class name:
# 'WeakValueDictionary.get'.
# ---------------------------------------------------------------------------

invariant weakref_extra20.WeakValueDictionary.get.qualname:
  description: "weakref.WeakValueDictionary.get.__qualname__ == 'WeakValueDictionary.get' — method qualname includes class"
  category: method_qualname
  kind: python_call_eq
  function: "WeakValueDictionary.get.__qualname__.__eq__"
  args: ["WeakValueDictionary.get"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.WeakSet.add.__qualname__ — novel method-level invariant
#
# No prior weakref spec records WeakSet.add.__qualname__.
# Method qualnames include the enclosing class name: 'WeakSet.add'.
# ---------------------------------------------------------------------------

invariant weakref_extra20.WeakSet.add.qualname:
  description: "weakref.WeakSet.add.__qualname__ == 'WeakSet.add' — method qualname includes class"
  category: method_qualname
  kind: python_call_eq
  function: "WeakSet.add.__qualname__.__eq__"
  args: ["WeakSet.add"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.finalize.__call__.__qualname__ — novel method-level invariant
#
# No prior weakref spec records finalize.__call__.__qualname__.
# The __call__ method's qualname includes the enclosing class:
# 'finalize.__call__'.
# ---------------------------------------------------------------------------

invariant weakref_extra20.finalize.call.qualname:
  description: "weakref.finalize.__call__.__qualname__ == 'finalize.__call__' — __call__ method qualname includes class"
  category: method_qualname
  kind: python_call_eq
  function: "finalize.__call__.__qualname__.__eq__"
  args: ["finalize.__call__"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — class __qualname__ and method __qualname__ values
# (extra20 namespace)
#
# Top-level class qualnames (ref, WeakValueDictionary, WeakKeyDictionary,
# WeakSet, finalize) and method-level qualnames (WeakValueDictionary.get,
# WeakSet.add, finalize.__call__).
# ---------------------------------------------------------------------------

table weakref_extra20.qualnames:
  description: "class and method __qualname__ values for weakref types"
  kind: python_call_eq
  category: class_qualname

  columns: [id, function, args, expected]
  rows:
    - [ref,                         ref.__qualname__.__eq__,                         ["ReferenceType"],         true]
    - [WeakValueDictionary,         WeakValueDictionary.__qualname__.__eq__,         ["WeakValueDictionary"],   true]
    - [WeakKeyDictionary,           WeakKeyDictionary.__qualname__.__eq__,           ["WeakKeyDictionary"],     true]
    - [WeakSet,                     WeakSet.__qualname__.__eq__,                     ["WeakSet"],               true]
    - [finalize,                    finalize.__qualname__.__eq__,                    ["finalize"],              true]
    - [WeakValueDictionary_get,     "WeakValueDictionary.get.__qualname__.__eq__",   ["WeakValueDictionary.get"], true]
    - [WeakSet_add,                 "WeakSet.add.__qualname__.__eq__",               ["WeakSet.add"],           true]
    - [finalize_call,               "finalize.__call__.__qualname__.__eq__",         ["finalize.__call__"],     true]
