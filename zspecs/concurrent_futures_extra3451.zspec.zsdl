spec: cf3451
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 677 (cf3451): __getitem__, __setitem__, __delitem__ dict-presence (obj[key], obj[key]=val, del obj[key]) for concurrent.futures types."
    - "Theme: __getitem__/__setitem__/__delitem__ dict-presence (obj[key], obj[key]=val, del obj[key])."
    - "All values False — these types do not implement the container/mapping access protocol in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor."
    - "Key finding (__getitem__): all 3 concurrent.futures classes return false for __getitem__. obj[key] delegates to __getitem__ when defined in the class's own __dict__. concurrent.futures.Future: a state-machine result handle (PENDING/RUNNING/CANCELLED/FINISHED) that does NOT define __getitem__ in its own __dict__. Results are retrieved via result()/exception() method calls, not subscript access. ThreadPoolExecutor/ProcessPoolExecutor: worker-pool lifecycle managers with no __getitem__ in their own __dict__."
    - "Key finding (__setitem__): all 3 concurrent.futures classes return false for __setitem__. obj[key]=val delegates to __setitem__ when defined in the class's own __dict__. concurrent.futures.Future: does NOT define __setitem__ in its own Future.__dict__. Future results are set internally by the executor framework, not through item assignment. ThreadPoolExecutor/ProcessPoolExecutor: no __setitem__ defined in their own __dict__."
    - "Key finding (__delitem__): all 3 concurrent.futures classes return false for __delitem__. del obj[key] delegates to __delitem__ when defined in the class's own __dict__. concurrent.futures types define no container/mapping deletion protocol in their own __dict__. Future objects are not subscriptable; __delitem__ is absent from Future.__dict__. ThreadPoolExecutor/ProcessPoolExecutor: executor types with no __delitem__ in their own __dict__."
    - "All 9 values in this wave are false. concurrent.futures is a high-level parallel execution API operating entirely through method calls — submit(), map(), result(), cancel(), add_done_callback(), shutdown() — with no container or mapping access protocol overrides in any class __dict__."
    - "Cross-wave summary for cf subjects:"
    - "  Wave 658 (cf3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (cf3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (cf3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (cf3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (cf3226): __radd__/__rsub__/__rmul__ — all false for all 3."
    - "  Wave 663 (cf3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 3."
    - "  Wave 664 (cf3256): __rpow__/__rlshift__/__rrshift__ — all false for all 3."
    - "  Wave 665 (cf3271): __rand__/__ror__/__rxor__ — all false for all 3."
    - "  Wave 666 (cf3286): __iadd__/__isub__/__imul__ — all false for all 3."
    - "  Wave 667 (cf3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 3."
    - "  Wave 668 (cf3316): __ipow__/__ilshift__/__irshift__ — all false for all 3."
    - "  Wave 669 (cf3331): __iand__/__ior__/__ixor__ — all false for all 3."
    - "  Wave 670 (cf3346): __neg__/__pos__/__abs__ — all false for all 3."
    - "  Wave 671 (cf3361): __invert__/__floor__/__ceil__ — all false for all 3."
    - "  Wave 672 (cf3376): __trunc__/__round__/__index__ — all false for all 3."
    - "  Wave 673 (cf3391): __int__/__float__/__complex__ — all false for all 3."
    - "  Wave 674 (cf3406): __bool__/__str__/__repr__ — all false for all 3."
    - "  Wave 675 (cf3421): __hash__/__eq__/__lt__ — all false for all 3."
    - "  Wave 676 (cf3436): __le__/__gt__/__ge__ — all false for all 3."
    - "  Wave 677 (cf3451): __getitem__/__setitem__/__delitem__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __getitem__ dict-presence — operator.contains(Cls.__dict__, '__getitem__')
#
# All 3 concurrent.futures classes return false for __getitem__.
# obj[key] delegates to __getitem__ when defined in the class's own __dict__.
# concurrent.futures.Future: a state-machine result handle that does not
#   define __getitem__ in its own __dict__. Results are retrieved via
#   result()/exception(); subscript access is not part of the Future API.
# ThreadPoolExecutor/ProcessPoolExecutor: worker-pool lifecycle managers
#   with no __getitem__ in their own __dict__. Pool contents are not
#   subscriptable.
# ---------------------------------------------------------------------------

table cf3451.getitem:
  description: "concurrent.futures types __getitem__ dict-presence checks; wave 677"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3451

  columns: [id, function, args, expected]
  rows:
    - ["cf3451001", operator.contains, [concurrent.futures.Future.__dict__,              "__getitem__"], false]
    - ["cf3451002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__getitem__"], false]
    - ["cf3451003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__getitem__"], false]

# ---------------------------------------------------------------------------
# __setitem__ dict-presence — operator.contains(Cls.__dict__, '__setitem__')
#
# All 3 concurrent.futures classes return false for __setitem__.
# obj[key]=val delegates to __setitem__ when defined in the class's own __dict__.
# concurrent.futures.Future: does NOT define __setitem__ in its own Future.__dict__.
#   Future results are set internally by the executor framework via internal
#   set_result()/set_exception() calls; item assignment is not part of the
#   public API.
# ThreadPoolExecutor/ProcessPoolExecutor: executor types with no __setitem__
#   defined in their own __dict__. Pool state is managed via submit()/shutdown().
# ---------------------------------------------------------------------------

table cf3451.setitem:
  description: "concurrent.futures types __setitem__ dict-presence checks; wave 677"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3451

  columns: [id, function, args, expected]
  rows:
    - ["cf3451004", operator.contains, [concurrent.futures.Future.__dict__,              "__setitem__"], false]
    - ["cf3451005", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__setitem__"], false]
    - ["cf3451006", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__setitem__"], false]

# ---------------------------------------------------------------------------
# __delitem__ dict-presence — operator.contains(Cls.__dict__, '__delitem__')
#
# All 3 concurrent.futures classes return false for __delitem__.
# del obj[key] delegates to __delitem__ when defined in the class's own __dict__.
# concurrent.futures types define no container/mapping deletion protocol in
#   their own __dict__.
# concurrent.futures.Future: an unordered state-machine result handle; no
#   __delitem__ is defined in Future.__dict__. Futures are not subscriptable
#   and do not support item deletion.
# ThreadPoolExecutor/ProcessPoolExecutor: executor types with no __delitem__
#   defined in their own __dict__. Pool instances do not support item deletion.
# ---------------------------------------------------------------------------

table cf3451.delitem:
  description: "concurrent.futures types __delitem__ dict-presence checks; wave 677"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3451

  columns: [id, function, args, expected]
  rows:
    - ["cf3451007", operator.contains, [concurrent.futures.Future.__dict__,              "__delitem__"], false]
    - ["cf3451008", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__delitem__"], false]
    - ["cf3451009", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__delitem__"], false]

# ---------------------------------------------------------------------------
# combined — __getitem__, __setitem__, __delitem__ across all 3 cf subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __getitem__: false for all 3 — obj[key] protocol not in own __dict__.
# __setitem__: false for all 3 — obj[key]=val protocol not in own __dict__.
# __delitem__: false for all 3 — del obj[key] protocol not in own __dict__.
# All 9 values are false.
# concurrent.futures is a high-level parallel execution API. Its entire
#   public surface is method-based: submit(), map(), result(), cancel(),
#   done(), running(), cancelled(), add_done_callback(), shutdown(). Waves
#   658–676 established that no arithmetic, bitwise, reflected, in-place
#   augmented assignment, unary numeric, rounding, numeric conversion,
#   display, hash/eq/lt, or ordering protocol dunder appears in the
#   concurrent.futures type hierarchy. The container/mapping access protocol
#   dunders tested here follow the same pattern.
# concurrent.futures.Future note: despite the name and its state-machine
#   design, Future does not define __getitem__, __setitem__, or __delitem__
#   in its own __dict__. These container/mapping dunders are not meaningful
#   for a result handle whose states are PENDING/RUNNING/CANCELLED/FINISHED
#   — only entries directly defined on the class appear in its __dict__.
# ThreadPoolExecutor/ProcessPoolExecutor note: executor types encapsulate a
#   pool of worker threads or processes; they expose only lifecycle and dispatch
#   methods. No container or mapping protocol overloads are defined in their __dict__.
# ---------------------------------------------------------------------------

table cf3451.combined:
  description: "concurrent.futures types combined __getitem__/__setitem__/__delitem__; wave 677"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3451

  columns: [id, function, args, expected]
  rows:
    - ["cf3451010", operator.contains, [concurrent.futures.Future.__dict__,              "__getitem__"],  false]
    - ["cf3451011", operator.contains, [concurrent.futures.Future.__dict__,              "__setitem__"],  false]
    - ["cf3451012", operator.contains, [concurrent.futures.Future.__dict__,              "__delitem__"],  false]
    - ["cf3451013", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__getitem__"],  false]
    - ["cf3451014", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__setitem__"],  false]
    - ["cf3451015", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__delitem__"],  false]
    - ["cf3451016", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__getitem__"],  false]
    - ["cf3451017", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__setitem__"],  false]
    - ["cf3451018", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__delitem__"],  false]
