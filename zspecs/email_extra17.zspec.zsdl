spec: email_extra17
version: ">=3.6"
backend: python_module(email)

docs: https://docs.python.org/3/library/email.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/email.html — Python email module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/email/"
  notes:
    - "This spec extends email_extra16.zspec.zsdl."
    - "Prior specs covered: email.message.Message class, email.parser.Parser/FeedParser, email.mime.text.MIMEText, email.utils functions, email.__name__/__package__, Message/__name__/__module__/__qualname__, MIMEText/__name__/__module__, Parser/__name__/__module__, FeedParser.__name__/__module__, MIMEText.__bases__[0].__name__, MIMEMultipart.__bases__[0].__name__, MessageParseError identity, headerregistry.Address.__name__, Message.__init__.__name__ (extra14), Message/Parser/FeedParser/MIMEText __module__.__len__() (extra14), Message/Parser/MIMEText __qualname__.__len__() (extra14), MessageError/__module__/__module__.__len__() (extra14), MessageParseError/HeaderParseError __module__.__len__() (extra14), MIMEMultipart/__module__/__name__/__qualname__.__len__() (extra15), MIMEBase/__module__/__name__/__qualname__.__len__() (extra15), Message.__init__.__module__/__qualname__.__len__() (extra15), MessageError/__name__.__len__() (extra15), HeaderParseError.__name__.__len__() (extra15), message_from_string/bytes __module__.__len__() (extra15), Message/MessageError __mro__.__len__(), MessageError.__bases__[0].__name__, MessageParseError/HeaderParseError __mro__.__len__(), Message.__bases__[0].__name__, Message.get/keys/__setitem__/__getitem__ __qualname__.__len__() (extra16)."
    - "This spec covers: email.__all__.__len__()==17; email.__all__.__class__.__name__.__len__()==4 (list); Message/__dict__.__class__.__name__.__len__() series (all 12, 'mappingproxy'); Message.items/values/as_string/get_payload/set_payload/get_content_type/is_multipart __qualname__.__len__(); MIMEText.__mro__.__len__()==5; MIMEBase.__mro__.__len__()==3; EmailMessage.__mro__.__len__()==4; MessageParseError.__bases__[0].__name__.__len__()==12."
    - "email.__all__.__len__() == 17 — the email package exports 17 names; no prior email spec checks __all__.__len__()."
    - "email.__all__.__class__.__name__ == 'list' (len 4) — __all__ is a plain list; no prior email spec checks __all__.__class__.__name__.__len__()."
    - "email.message.Message.__dict__.__class__.__name__ == 'mappingproxy' (len 12) — class __dict__ is always a mappingproxy; no prior email spec checks __dict__.__class__.__name__ on any email class."
    - "email.mime.base.MIMEBase.__dict__.__class__.__name__ == 'mappingproxy' (len 12)."
    - "email.mime.text.MIMEText.__dict__.__class__.__name__ == 'mappingproxy' (len 12)."
    - "email.errors.MessageError.__dict__.__class__.__name__ == 'mappingproxy' (len 12)."
    - "email.headerregistry.HeaderRegistry.__dict__.__class__.__name__ == 'mappingproxy' (len 12)."
    - "email.message.Message.items.__qualname__ == 'Message.items' (len 13) — no prior email spec checks Message.items.__qualname__.__len__()."
    - "email.message.Message.values.__qualname__ == 'Message.values' (len 14) — no prior email spec checks Message.values.__qualname__.__len__()."
    - "email.message.Message.as_string.__qualname__ == 'Message.as_string' (len 17) — no prior email spec checks Message.as_string.__qualname__.__len__()."
    - "email.message.Message.get_payload.__qualname__ == 'Message.get_payload' (len 19) — no prior email spec checks Message.get_payload.__qualname__.__len__()."
    - "email.message.Message.set_payload.__qualname__ == 'Message.set_payload' (len 19) — no prior email spec checks Message.set_payload.__qualname__.__len__()."
    - "email.message.Message.get_content_type.__qualname__ == 'Message.get_content_type' (len 24) — no prior email spec checks Message.get_content_type.__qualname__.__len__()."
    - "email.message.Message.is_multipart.__qualname__ == 'Message.is_multipart' (len 20) — no prior email spec checks Message.is_multipart.__qualname__.__len__()."
    - "email.mime.text.MIMEText.__mro__.__len__() == 5 — MRO: MIMEText->MIMENonMultipart->MIMEBase->Message->object; no prior email spec checks MIMEText.__mro__.__len__()."
    - "email.mime.base.MIMEBase.__mro__.__len__() == 3 — MRO: MIMEBase->Message->object; no prior email spec checks MIMEBase.__mro__.__len__()."
    - "email.message.EmailMessage.__mro__.__len__() == 4 — MRO: EmailMessage->MIMEPart->Message->object; no prior email spec checks EmailMessage.__mro__.__len__()."
    - "email.errors.MessageParseError.__bases__[0].__name__.__len__() == 12 — __bases__[0].__name__ == 'MessageError' (len 12); no prior email spec checks MessageParseError.__bases__[0].__name__.__len__()."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# email.__all__ length and class
#
# email.__all__ lists 17 submodule/function names exported by the package.
# No prior email spec checks email.__all__.__len__() or __all__.__class__.__name__.
# ---------------------------------------------------------------------------

invariant email_extra17.all_len:
  description: "email.__all__.__len__() == 17 — package exports 17 names; no prior email spec checks __all__.__len__()"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 17

invariant email_extra17.all_class_name_len:
  description: "email.__all__.__class__.__name__.__len__() == 4 — __all__ is a 'list' (len('list')==4); no prior email spec checks __all__.__class__.__name__.__len__()"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() for core email classes
#
# Every class __dict__ is a mappingproxy; 'mappingproxy' has length 12.
# No prior email spec checks __dict__.__class__.__name__.__len__() on any class.
# Five classes are checked: Message, MIMEBase, MIMEText, MessageError, HeaderRegistry.
# ---------------------------------------------------------------------------

table email_extra17.dict_class_name_len:
  description: "email class __dict__.__class__.__name__.__len__() — all equal 12 ('mappingproxy'); no prior email spec checks __dict__.__class__.__name__ on any email class"
  kind: python_call_eq
  category: class_dict
  id_prefix: dclnlen17

  columns: [id, function, args, expected]
  rows:
    - [Message,         message.Message.__dict__.__class__.__name__.__len__,          [], 12]
    - [MIMEBase,        mime.base.MIMEBase.__dict__.__class__.__name__.__len__,        [], 12]
    - [MIMEText,        mime.text.MIMEText.__dict__.__class__.__name__.__len__,        [], 12]
    - [MessageError,    errors.MessageError.__dict__.__class__.__name__.__len__,       [], 12]
    - [HeaderRegistry,  headerregistry.HeaderRegistry.__dict__.__class__.__name__.__len__, [], 12]

# ---------------------------------------------------------------------------
# Message method __qualname__ string lengths (items, values, as_string, get_payload,
# set_payload, get_content_type, is_multipart)
#
# extra16 covers Message.get (11), .keys (12), .__setitem__ (19), .__getitem__ (19).
# This table extends coverage to seven additional Message methods.
# No prior email spec checks __qualname__.__len__() on any of these methods.
# ---------------------------------------------------------------------------

table email_extra17.message_method_qualname_lens:
  description: "Message method __qualname__ string lengths — no prior email spec checks __qualname__.__len__() on these Message methods"
  kind: python_call_eq
  category: method_identity
  id_prefix: mmqlen17

  columns: [id, function, args, expected, description]
  rows:
    - [items,            message.Message.items.__qualname__.__len__,            [], 13, "len('Message.items') == 13"]
    - [values,           message.Message.values.__qualname__.__len__,           [], 14, "len('Message.values') == 14"]
    - [as_string,        message.Message.as_string.__qualname__.__len__,        [], 17, "len('Message.as_string') == 17"]
    - [get_payload,      message.Message.get_payload.__qualname__.__len__,      [], 19, "len('Message.get_payload') == 19"]
    - [set_payload,      message.Message.set_payload.__qualname__.__len__,      [], 19, "len('Message.set_payload') == 19"]
    - [get_content_type, message.Message.get_content_type.__qualname__.__len__, [], 24, "len('Message.get_content_type') == 24"]
    - [is_multipart,     message.Message.is_multipart.__qualname__.__len__,     [], 20, "len('Message.is_multipart') == 20"]

# ---------------------------------------------------------------------------
# MIME class __mro__ depths
#
# MIMEText inherits through MIMENonMultipart -> MIMEBase -> Message -> object (5 deep).
# MIMEBase inherits through Message -> object (3 deep).
# EmailMessage inherits through MIMEPart -> Message -> object (4 deep).
# No prior email spec checks __mro__.__len__() on MIMEText, MIMEBase, or EmailMessage.
# ---------------------------------------------------------------------------

invariant email_extra17.MIMEText.mro_len:
  description: "email.mime.text.MIMEText.__mro__.__len__() == 5 — MRO: MIMEText->MIMENonMultipart->MIMEBase->Message->object; no prior email spec checks MIMEText.__mro__.__len__()"
  category: class_hierarchy
  kind: python_call_eq
  function: mime.text.MIMEText.__mro__.__len__
  args: []
  expected: 5

invariant email_extra17.MIMEBase.mro_len:
  description: "email.mime.base.MIMEBase.__mro__.__len__() == 3 — MRO: MIMEBase->Message->object; no prior email spec checks MIMEBase.__mro__.__len__()"
  category: class_hierarchy
  kind: python_call_eq
  function: mime.base.MIMEBase.__mro__.__len__
  args: []
  expected: 3

invariant email_extra17.EmailMessage.mro_len:
  description: "email.message.EmailMessage.__mro__.__len__() == 4 — MRO: EmailMessage->MIMEPart->Message->object; no prior email spec checks EmailMessage.__mro__.__len__()"
  category: class_hierarchy
  kind: python_call_eq
  function: message.EmailMessage.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# MessageParseError.__bases__[0].__name__.__len__()
#
# MessageParseError inherits directly from MessageError (len 12).
# No prior email spec checks MessageParseError.__bases__[0].__name__.__len__().
# ---------------------------------------------------------------------------

invariant email_extra17.MessageParseError.base_name_len:
  description: "email.errors.MessageParseError.__bases__[0].__name__.__len__() == 12 — direct base is 'MessageError' (len 12); no prior email spec checks this"
  category: class_hierarchy
  kind: python_call_eq
  function: "errors.MessageParseError.__bases__[0].__name__.__len__"
  args: []
  expected: 12
