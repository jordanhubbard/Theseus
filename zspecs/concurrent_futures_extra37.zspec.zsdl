spec: concurrent_futures_extra37
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra36.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__.__class__.__name__.__len__() tables, as_completed/wait __module__.__len__(), __all__.__len__()==14, __mro__.__len__() tables, __bases__[0].__name__.__len__() for all classes, Executor context manager qualname lens, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, map/__qualname__.__len__() for both executors, Future method __name__/__qualname__.__len__() tables, ThreadPoolExecutor submit/shutdown __name__/__qualname__.__len__() tables, InvalidStateError/__name__.__len__()==17, CancelledError/__qualname__.__len__()==14, BrokenExecutor/__name__/__qualname__.__len__()==14, BrokenExecutor/__module__.__len__()==24, CancelledError/__module__.__len__()==24, BrokenExecutor/__bases__[0].__name__.__len__()==12, TimeoutError/__name__/__module__.__len__(), concurrent.futures.__package__.__len__()==18, __spec__.__class__.__name__.__len__()==10, ThreadPoolExecutor/__name__=='ThreadPoolExecutor' (extra36), ProcessPoolExecutor/__name__=='ProcessPoolExecutor' (extra36), executor __module__ string equality checks (extra36), wait/__name__=='wait' (extra36), function __module__ string equality checks (extra36)."
    - "This spec covers: Executor.__name__=='Executor'; Executor.__module__=='concurrent.futures._base' (24 chars); Executor.map.__qualname__.__len__()==12 ('Executor.map'); Executor.submit.__qualname__.__len__()==15 ('Executor.submit'); InvalidStateError.__name__=='InvalidStateError'; InvalidStateError.__module__=='concurrent.futures._base' (24 chars); BrokenExecutor.__name__=='BrokenExecutor'; BrokenExecutor.__module__=='concurrent.futures._base' (24 chars)."
    - "concurrent.futures.Executor.__module__ == 'concurrent.futures._base' (24 chars). Executor is the abstract base class for all executors and lives in the private _base submodule — the same module as Future, wait, as_completed, InvalidStateError, and BrokenExecutor. All core abstractions are co-located in '_base' (24 chars)."
    - "Executor.map.__qualname__ == 'Executor.map' (12 chars: 'Executor'(8) + '.'(1) + 'map'(3) = 12). Executor.submit.__qualname__ == 'Executor.submit' (15 chars: 'Executor'(8) + '.'(1) + 'submit'(6) = 15). These qualnames confirm that both map and submit are defined directly on Executor (not on a subclass). Prior specs measured __qualname__.__len__() for ThreadPoolExecutor and ProcessPoolExecutor map/submit, but NOT Executor.map and Executor.submit in the extra37 namespace."
    - "InvalidStateError.__module__ == 'concurrent.futures._base' (24 chars). BrokenExecutor.__module__ == 'concurrent.futures._base' (24 chars). Both exception classes live in the same _base submodule as Executor and Future. Prior specs measured BrokenExecutor.__module__.__len__()==24 as an integer (extra26) and InvalidStateError.__name__.__len__()==17 as an integer (extra27), but NOT the string equality checks in the extra37 namespace."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Executor identity — extra37 namespace
#
# Executor is the abstract base class for all executor implementations:
#   Executor.__name__   == 'Executor'                    ( 8 chars)
#   Executor.__module__ == 'concurrent.futures._base'    (24 chars)
# Executor lives in the private _base submodule alongside Future, wait,
# as_completed, InvalidStateError, and BrokenExecutor. All core concurrent.futures
# abstractions are co-located in 'concurrent.futures._base' (24 chars).
# Prior specs measured Executor.__name__.__len__() and __module__.__len__() as
# integers, but NOT the string equality checks in the extra37 namespace.
# ---------------------------------------------------------------------------

table concurrent_futures_extra37.executor_identity:
  description: "concurrent.futures.Executor identity string equality in extra37 namespace — __name__ and __module__"
  kind: python_call_eq
  category: class_names
  id_prefix: cfexecid37

  columns: [id, function, args, expected, description]
  rows:
    - [name,   Executor.__name__.__eq__,   ["Executor"],                 true, "Executor.__name__ == 'Executor' (8 chars)"]
    - [module, Executor.__module__.__eq__,  ["concurrent.futures._base"], true, "Executor.__module__ == 'concurrent.futures._base' (24 chars)"]

# ---------------------------------------------------------------------------
# concurrent.futures.Executor method __qualname__.__len__() — extra37 namespace
#
# Two key Executor methods and their qualname lengths:
#   Executor.map.__qualname__    == 'Executor.map'    (12 chars)
#   Executor.submit.__qualname__ == 'Executor.submit' (15 chars)
# 'Executor'(8) + '.'(1) + 'map'(3) = 12; 'Executor'(8) + '.'(1) + 'submit'(6) = 15.
# Both qualnames confirm the methods are defined directly on Executor.
# Prior specs measured map/__qualname__.__len__() for ThreadPoolExecutor and
# ProcessPoolExecutor (subclasses), but NOT for Executor itself in extra37.
# ---------------------------------------------------------------------------

table concurrent_futures_extra37.executor_method_qualname_lengths:
  description: "concurrent.futures.Executor method __qualname__.__len__() in extra37 namespace — map and submit"
  kind: python_call_eq
  category: method_names
  id_prefix: cfexecmethqulen37

  columns: [id, function, args, expected, description]
  rows:
    - [map,    Executor.map.__qualname__.__len__,    [], 12, "'Executor.map' is 12 characters — 'Executor'(8) + '.'(1) + 'map'(3)"]
    - [submit, Executor.submit.__qualname__.__len__, [], 15, "'Executor.submit' is 15 characters — 'Executor'(8) + '.'(1) + 'submit'(6)"]

# ---------------------------------------------------------------------------
# concurrent.futures exception identity — extra37 namespace
#
# InvalidStateError and BrokenExecutor are two exception classes in concurrent.futures:
#   InvalidStateError.__name__   == 'InvalidStateError'         (17 chars)
#   InvalidStateError.__module__ == 'concurrent.futures._base'  (24 chars)
#   BrokenExecutor.__name__      == 'BrokenExecutor'            (14 chars)
#   BrokenExecutor.__module__    == 'concurrent.futures._base'  (24 chars)
# Both exceptions live in the _base submodule (same as Executor and Future).
# Prior specs measured __name__.__len__() and __module__.__len__() as integers,
# but NOT the string equality checks in the extra37 namespace.
# ---------------------------------------------------------------------------

table concurrent_futures_extra37.exception_identity:
  description: "concurrent.futures exception identity string equality in extra37 namespace — InvalidStateError and BrokenExecutor"
  kind: python_call_eq
  category: class_names
  id_prefix: cfexcid37

  columns: [id, function, args, expected, description]
  rows:
    - [InvalidStateError_name,   InvalidStateError.__name__.__eq__,   ["InvalidStateError"],        true, "InvalidStateError.__name__ == 'InvalidStateError' (17 chars)"]
    - [InvalidStateError_module, InvalidStateError.__module__.__eq__,  ["concurrent.futures._base"], true, "InvalidStateError.__module__ == 'concurrent.futures._base' (24 chars)"]
    - [BrokenExecutor_name,      BrokenExecutor.__name__.__eq__,       ["BrokenExecutor"],           true, "BrokenExecutor.__name__ == 'BrokenExecutor' (14 chars)"]
    - [BrokenExecutor_module,    BrokenExecutor.__module__.__eq__,     ["concurrent.futures._base"], true, "BrokenExecutor.__module__ == 'concurrent.futures._base' (24 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra37
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra37.Executor_name_eq:
  description: "concurrent.futures.Executor.__name__ == 'Executor' — the abstract base class for all concurrent.futures executors (8 chars)"
  category: class_names
  kind: python_call_eq
  function: Executor.__name__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra37.Executor_module_eq:
  description: "concurrent.futures.Executor.__module__ == 'concurrent.futures._base' — Executor lives in the private _base submodule alongside Future and the utility functions (24 chars)"
  category: module_names
  kind: python_call_eq
  function: Executor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra37.Executor_map_qualname_len:
  description: "concurrent.futures.Executor.map.__qualname__.__len__() == 12 — 'Executor.map' has 12 characters: 'Executor'(8) + '.'(1) + 'map'(3)"
  category: method_names
  kind: python_call_eq
  function: Executor.map.__qualname__.__len__
  args: []
  expected: 12

invariant concurrent_futures_extra37.Executor_submit_qualname_len:
  description: "concurrent.futures.Executor.submit.__qualname__.__len__() == 15 — 'Executor.submit' has 15 characters: 'Executor'(8) + '.'(1) + 'submit'(6)"
  category: method_names
  kind: python_call_eq
  function: Executor.submit.__qualname__.__len__
  args: []
  expected: 15

invariant concurrent_futures_extra37.InvalidStateError_name_eq:
  description: "concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError' — exception for invalid state operations on a Future (17 chars)"
  category: class_names
  kind: python_call_eq
  function: InvalidStateError.__name__.__eq__
  args: ["InvalidStateError"]
  expected: true

invariant concurrent_futures_extra37.BrokenExecutor_name_eq:
  description: "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor' — exception raised when an executor is in a broken state (14 chars)"
  category: class_names
  kind: python_call_eq
  function: BrokenExecutor.__name__.__eq__
  args: ["BrokenExecutor"]
  expected: true
