spec: shutil_extra14
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
  notes:
    - "This spec extends shutil.zspec.zsdl through shutil_extra13.zspec.zsdl."
    - "shutil_extra13 covers get_archive_formats/get_unpack_formats return-is-list standalone invariants; primary function __module__ and __name__ tables for copy/copy2/copytree/rmtree/move; get_terminal_size/disk_usage/which __module__ standalone invariants."
    - "shutil_extra12 covers chown.__name__, copyfileobj.__qualname__, shutil.__name__/__package__, disk_usage return class name, get_archive_formats/get_unpack_formats length, function __module__ table."
    - "shutil_extra10 covers SameFileError/ReadError/Error MRO entries; disk_usage _fields by index; get_archive_formats/get_unpack_formats return type."
    - "NOT yet covered: get_archive_formats().__len__() >= 4 — at least four registered formats."
    - "NOT yet covered: get_archive_formats().__getitem__(0).__class__.__name__ == 'tuple' — entries are tuples."
    - "NOT yet covered: get_unpack_formats().__len__() >= 4 — at least four unpack formats."
    - "NOT yet covered: register_archive_format.__name__ == 'register_archive_format'."
    - "NOT yet covered: unregister_archive_format.__name__ == 'unregister_archive_format'."
    - "NOT yet covered: register_unpack_format.__name__ == 'register_unpack_format'."
    - "NOT yet covered: unregister_unpack_format.__name__ == 'unregister_unpack_format'."
    - "NOT yet covered: make_archive.__name__ == 'make_archive'."
    - "NOT yet covered: unpack_archive.__name__ == 'unpack_archive'."
    - "NOT yet covered: get_archive_formats.__name__ == 'get_archive_formats'."
    - "NOT yet covered: get_unpack_formats.__name__ == 'get_unpack_formats'."
    - "get_archive_formats() returns a list with at least 4 entries (zip, tar, gztar, bztar)."
    - "get_archive_formats()[0] is a tuple — each format entry is a (name, description) tuple."
    - "get_unpack_formats() returns a list with at least 4 entries."
    - "register_archive_format/unregister_archive_format/register_unpack_format/unregister_unpack_format __name__ checks."
    - "make_archive/unpack_archive/get_archive_formats/get_unpack_formats __name__ checks."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# get_archive_formats and get_unpack_formats — length and entry type
#
# shutil_extra10 checks return type is list; shutil_extra12 checks __len__.
# This spec adds fresh anchors: at least 4 formats (zip/tar/gztar/bztar/xztar
# are standard), and the first entry is a tuple (name, extensions, description).
# ---------------------------------------------------------------------------

invariant shutil_extra14.get_archive_formats.length_ge_4:
  description: "shutil.get_archive_formats().__len__() >= 4 — at least four built-in archive formats"
  category: archive_formats
  kind: python_call_eq
  function: get_archive_formats
  args: []
  method: __len__
  method_chain: __ge__
  method_chain_args: [4]
  expected: true

invariant shutil_extra14.get_archive_formats.entry_is_tuple:
  description: "shutil.get_archive_formats()[0].__class__.__name__ == 'tuple' — each entry is a tuple"
  category: archive_formats
  kind: python_call_eq
  function: get_archive_formats
  args: []
  method: __getitem__
  method_args: [0]
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["tuple"]
  expected: true

invariant shutil_extra14.get_unpack_formats.length_ge_4:
  description: "shutil.get_unpack_formats().__len__() >= 4 — at least four built-in unpack formats"
  category: archive_formats
  kind: python_call_eq
  function: get_unpack_formats
  args: []
  method: __len__
  method_chain: __ge__
  method_chain_args: [4]
  expected: true

# ---------------------------------------------------------------------------
# Archive format registration function __name__ attributes
#
# No prior shutil spec covers register_archive_format, unregister_archive_format,
# register_unpack_format, or unregister_unpack_format __name__ attributes.
# These functions manage the runtime archive format registry.
# ---------------------------------------------------------------------------

table shutil_extra14.archive_registry_names:
  description: "shutil archive registry function __name__ attributes"
  kind: python_call_eq
  category: function_identity
  id_prefix: areg14

  columns: [id, function, args, expected]
  rows:
    - [reg_archive,   register_archive_format.__name__.__eq__,   ["register_archive_format"],   true]
    - [unreg_archive, unregister_archive_format.__name__.__eq__, ["unregister_archive_format"], true]
    - [reg_unpack,    register_unpack_format.__name__.__eq__,    ["register_unpack_format"],    true]
    - [unreg_unpack,  unregister_unpack_format.__name__.__eq__,  ["unregister_unpack_format"],  true]

# ---------------------------------------------------------------------------
# Archive operation and query function __name__ attributes
#
# No prior shutil spec verifies __name__ for make_archive, unpack_archive,
# get_archive_formats, or get_unpack_formats as standalone table rows.
# shutil_extra5 covers __qualname__ for make_archive and unpack_archive,
# but not __name__. These are distinct axes.
# ---------------------------------------------------------------------------

table shutil_extra14.archive_operation_names:
  description: "shutil archive operation and query function __name__ attributes"
  kind: python_call_eq
  category: function_identity
  id_prefix: aop14

  columns: [id, function, args, expected]
  rows:
    - [make_archive,        make_archive.__name__.__eq__,        ["make_archive"],        true]
    - [unpack_archive,      unpack_archive.__name__.__eq__,      ["unpack_archive"],      true]
    - [get_archive_formats, get_archive_formats.__name__.__eq__, ["get_archive_formats"], true]
    - [get_unpack_formats,  get_unpack_formats.__name__.__eq__,  ["get_unpack_formats"],  true]
