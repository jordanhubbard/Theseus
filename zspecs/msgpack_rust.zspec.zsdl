spec: msgpack_rust
version: ">=3.9"
backend: rust_module(msgpack_rust)

docs: https://msgpack.org/

provenance:
  derived_from:
    - "https://github.com/msgpack/msgpack-python — msgpack-python documentation"
  not_derived_from:
    - "msgpack source: msgpack/__init__.py"
  notes:
    - "msgpack provides MessagePack serialization for Python."
    - "msgpack.packb([1,2,3]) is bytes."
    - "msgpack.unpackb(msgpack.packb([1,2,3])) == [1,2,3]."
    - "msgpack.unpackb(msgpack.packb({'a':1}), raw=False) == {'a':1}."
    - "len(msgpack.packb([1,2,3])) < len(str([1,2,3]))."
    - "Expose msgpack_roundtrip_list(lst) -> list: msgpack.unpackb(msgpack.packb(lst))."
    - "Expose msgpack_pack_len_positive(lst) -> bool: len(msgpack.packb(lst)) > 0."
    - "All test vectors verified against msgpack 1.1.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# msgpack_roundtrip_list — pack then unpack list
table msgpack_rust.serialize.roundtrip:
  kind: python_call_eq
  category: roundtrip
  id_prefix: msp_rt
  function: msgpack_roundtrip_list

  columns: [id, args, expected]
  rows:
    - [ints,  [[1, 2, 3]],  [1, 2, 3]]
    - [empty, [[]],          []]
    - [one,   [[42]],        [42]]

# msgpack_pack_len_positive — packed bytes non-empty
table msgpack_rust.serialize.pack_len:
  kind: python_call_eq
  category: pack_len
  id_prefix: msp_pl
  function: msgpack_pack_len_positive

  columns: [id, args, expected]
  rows:
    - [ints,  [[1, 2, 3]], true]
    - [empty, [[]], true]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:34:18Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
