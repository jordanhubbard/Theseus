spec: uuid_extra435
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid UUID class identity and attribute names"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid.UUID is a pure-Python class; its properties are defined in uuid.py"
    - "uuid.uuid4 is a module-level function, not a method"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra435.class_identity:
  description: "Identity attributes of the uuid.UUID class and its properties"
  kind: python_call_eq
  category: identity
  id_prefix: uuex

  columns: [id, function, args, expected]
  rows:
    - [uuex001, uuid.UUID.__name__.__eq__,                          ["UUID"],     true]
    - [uuex002, uuid.UUID.__module__.__eq__,                        ["uuid"],     true]
    - [uuex003, "uuid.UUID.__bases__[0].__name__.__eq__",           ["object"],   true]
    - [uuex004, uuid.UUID.int.__class__.__name__.__eq__,            ["property"], true]
    - [uuex005, uuid.UUID.hex.__class__.__name__.__eq__,            ["property"], true]
    - [uuex006, uuid.UUID.bytes.__class__.__name__.__eq__,          ["property"], true]
    - [uuex007, uuid.UUID.version.__class__.__name__.__eq__,        ["property"], true]
    - [uuex008, uuid.UUID.urn.__class__.__name__.__eq__,            ["property"], true]
    - [uuex009, uuid.uuid4.__name__.__eq__,                         ["uuid4"],    true]
    - [uuex010, uuid.uuid4.__module__.__eq__,                       ["uuid"],     true]
