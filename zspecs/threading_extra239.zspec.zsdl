spec: threading_extra239
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers threading.Condition class identity and method contracts."
    - "threading.Condition.__name__ == 'Condition' (len=9) — Python class name. Verified with Python 3.14.3."
    - "threading.Condition.__module__ == 'threading' (len=9) — defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Condition.__bases__[0].__name__ == 'object' — Condition inherits directly from object. Verified with Python 3.14.3."
    - "threading.Condition.__doc__.__contains__('lock') == True — docstring mentions lock. Verified with Python 3.14.3."
    - "threading.Condition.__doc__.__contains__('condition') == True — docstring mentions condition. Verified with Python 3.14.3."
    - "threading.Condition.wait.__name__ == 'wait' (len=4); __qualname__ == 'Condition.wait' (len=14). Verified with Python 3.14.3."
    - "threading.Condition.notify.__name__ == 'notify' (len=6); __qualname__ == 'Condition.notify' (len=16). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Condition class identity contracts
#
# threading.Condition.__name__ == 'Condition' (len=9)
# threading.Condition.__module__ == 'threading' (len=9)
# threading.Condition.__bases__[0].__name__ == 'object'
# threading.Condition.__class__.__name__ == 'type'
# threading.Condition.__doc__.__contains__('lock') == True
#
# Condition is a Python class in Lib/threading.py. New to extra239.
# ---------------------------------------------------------------------------

table threading_extra239.thr239cond_identity:
  description: "threading.Condition class identity: name, module, bases, class, doc; new to extra239"
  kind: python_call_eq
  category: identity
  id_prefix: thr239cond

  columns: [id, function, args, expected, description]
  rows:
    - [condition_name_eq,
       Condition.__name__.__eq__,
       ["Condition"],
       true,
       "threading.Condition.__name__.__eq__('Condition') == True — Condition is a Python class in Lib/threading.py; __name__ is 'Condition' (len=9); new to extra239"]
    - [condition_name_len_9,
       Condition.__name__.__len__,
       [],
       9,
       "threading.Condition.__name__.__len__() == 9 — 'Condition' has exactly 9 characters; str.__len__() returns 9; new to extra239"]
    - [condition_module_eq,
       Condition.__module__.__eq__,
       ["threading"],
       true,
       "threading.Condition.__module__.__eq__('threading') == True — Condition is defined in Lib/threading.py; __module__ is 'threading' (len=9); new to extra239"]
    - [condition_bases_0_is_object,
       "Condition.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Condition.__bases__[0].__name__.__eq__('object') == True — Condition inherits directly from object; __bases__[0] is object; new to extra239"]
    - [condition_class_is_type,
       Condition.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Condition.__class__.__name__.__eq__('type') == True — Condition is a class; its metaclass is the built-in type type; new to extra239"]

# ---------------------------------------------------------------------------
# Table 2: threading.Condition doc and length contracts
#
# threading.Condition.__doc__.__contains__('lock') == True
# threading.Condition.__doc__.__contains__('condition') == True
# threading.Condition.__doc__.__contains__('thread') == True
# threading.Condition.__module__.__len__() == 9
# threading.Condition.__doc__.__class__.__name__ == 'str'
#
# Condition docstring describes condition variables, locks, and threads. New to extra239.
# ---------------------------------------------------------------------------

table threading_extra239.thr239cond_doc_and_lengths:
  description: "threading.Condition doc contains 'lock', 'condition', 'thread'; module len 9; doc class is str; new to extra239"
  kind: python_call_eq
  category: identity
  id_prefix: thr239conddoc

  columns: [id, function, args, expected, description]
  rows:
    - [condition_doc_contains_lock,
       Condition.__doc__.__contains__,
       ["lock"],
       true,
       "threading.Condition.__doc__.__contains__('lock') == True — docstring describes the lock argument used as the underlying lock; str.__contains__('lock') returns True; new to extra239"]
    - [condition_doc_contains_condition,
       Condition.__doc__.__contains__,
       ["condition"],
       true,
       "threading.Condition.__doc__.__contains__('condition') == True — docstring describes a condition variable; str.__contains__('condition') returns True; new to extra239"]
    - [condition_doc_contains_thread,
       Condition.__doc__.__contains__,
       ["thread"],
       true,
       "threading.Condition.__doc__.__contains__('thread') == True — docstring describes threads waiting and being notified; str.__contains__('thread') returns True; new to extra239"]
    - [condition_module_len_9,
       Condition.__module__.__len__,
       [],
       9,
       "threading.Condition.__module__.__len__() == 9 — 'threading' has exactly 9 characters (t-h-r-e-a-d-i-n-g); str.__len__() returns 9; new to extra239"]
    - [condition_doc_class_is_str,
       Condition.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Condition.__doc__.__class__.__name__.__eq__('str') == True — the Condition docstring is a plain Python str object; new to extra239"]

# ---------------------------------------------------------------------------
# Table 3: threading.Condition.wait and notify method identity
#
# threading.Condition.wait.__name__ == 'wait' (len=4)
# threading.Condition.wait.__qualname__ == 'Condition.wait' (len=14)
# threading.Condition.notify.__name__ == 'notify' (len=6)
# threading.Condition.notify.__qualname__ == 'Condition.notify' (len=16)
# threading.Condition.wait.__class__.__name__ == 'function'
#
# wait and notify are Python methods in Lib/threading.py. New to extra239.
# ---------------------------------------------------------------------------

table threading_extra239.thr239meth_method_identity:
  description: "threading.Condition.wait and notify method name and qualname contracts; new to extra239"
  kind: python_call_eq
  category: identity
  id_prefix: thr239meth

  columns: [id, function, args, expected, description]
  rows:
    - [wait_name_eq,
       Condition.wait.__name__.__eq__,
       ["wait"],
       true,
       "threading.Condition.wait.__name__.__eq__('wait') == True — wait is a Python method in Lib/threading.py; __name__ is 'wait' (len=4); new to extra239"]
    - [wait_qualname_eq,
       Condition.wait.__qualname__.__eq__,
       ["Condition.wait"],
       true,
       "threading.Condition.wait.__qualname__.__eq__('Condition.wait') == True — wait is a method of Condition; __qualname__ is 'Condition.wait' (len=14); new to extra239"]
    - [notify_name_eq,
       Condition.notify.__name__.__eq__,
       ["notify"],
       true,
       "threading.Condition.notify.__name__.__eq__('notify') == True — notify is a Python method in Lib/threading.py; __name__ is 'notify' (len=6); new to extra239"]
    - [notify_qualname_eq,
       Condition.notify.__qualname__.__eq__,
       ["Condition.notify"],
       true,
       "threading.Condition.notify.__qualname__.__eq__('Condition.notify') == True — notify is a method of Condition; __qualname__ is 'Condition.notify' (len=16); new to extra239"]
    - [wait_class_is_function,
       Condition.wait.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Condition.wait.__class__.__name__.__eq__('function') == True — wait is a Python function; its __class__ is the built-in function type; new to extra239"]

# ---------------------------------------------------------------------------
# Table 4: threading.Condition method length contracts
#
# threading.Condition.wait.__name__.__len__() == 4
# threading.Condition.wait.__qualname__.__len__() == 14
# threading.Condition.notify.__name__.__len__() == 6
# threading.Condition.notify.__qualname__.__len__() == 16
# threading.Condition.notify.__class__.__name__ == 'function'
#
# Length contracts for wait and notify method names and qualnames. New to extra239.
# ---------------------------------------------------------------------------

table threading_extra239.thr239meth_lengths:
  description: "threading.Condition.wait and notify name and qualname length contracts; new to extra239"
  kind: python_call_eq
  category: identity
  id_prefix: thr239methlens

  columns: [id, function, args, expected, description]
  rows:
    - [wait_name_len_4,
       Condition.wait.__name__.__len__,
       [],
       4,
       "threading.Condition.wait.__name__.__len__() == 4 — 'wait' has exactly 4 characters (w-a-i-t); str.__len__() returns 4; new to extra239"]
    - [wait_qualname_len_14,
       Condition.wait.__qualname__.__len__,
       [],
       14,
       "threading.Condition.wait.__qualname__.__len__() == 14 — 'Condition.wait' has exactly 14 characters; str.__len__() returns 14; new to extra239"]
    - [notify_name_len_6,
       Condition.notify.__name__.__len__,
       [],
       6,
       "threading.Condition.notify.__name__.__len__() == 6 — 'notify' has exactly 6 characters (n-o-t-i-f-y); str.__len__() returns 6; new to extra239"]
    - [notify_qualname_len_16,
       Condition.notify.__qualname__.__len__,
       [],
       16,
       "threading.Condition.notify.__qualname__.__len__() == 16 — 'Condition.notify' has exactly 16 characters; str.__len__() returns 16; new to extra239"]
    - [notify_class_is_function,
       Condition.notify.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Condition.notify.__class__.__name__.__eq__('function') == True — notify is a Python function; its __class__ is the built-in function type; new to extra239"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra239
# ---------------------------------------------------------------------------

invariant threading_extra239.condition_name_eq:
  description: "threading.Condition.__name__ == 'Condition' (len=9); new to extra239"
  kind: python_call_eq
  function: Condition.__name__.__eq__
  args: ["Condition"]
  expected: true

invariant threading_extra239.condition_name_len_9:
  description: "threading.Condition.__name__.__len__() == 9 — 'Condition' has 9 characters; new to extra239"
