spec: in2926
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 642 (in2926): __iand__, __ior__, __ixor__ dict-presence checks for inspect types."
    - "inspect types are introspection helpers — none define in-place bitwise AND, OR, or XOR operators."
    - "Verified types: inspect.Parameter, inspect.BoundArguments, inspect.Signature, inspect.FullArgSpec, inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, inspect.ClosureVars."
    - "inspect.FullArgSpec, inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, and inspect.ClosureVars are namedtuple subclasses."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in2926.iand:
  description: "inspect types __iand__ dict-presence checks; wave 642"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2926
  columns: [id, function, args, expected]
  rows:
    - ["in2926001", operator.contains, [inspect.Parameter.__dict__,       "__iand__"], false]
    - ["in2926002", operator.contains, [inspect.BoundArguments.__dict__,  "__iand__"], false]
    - ["in2926003", operator.contains, [inspect.Signature.__dict__,       "__iand__"], false]
    - ["in2926004", operator.contains, [inspect.FullArgSpec.__dict__,     "__iand__"], false]
    - ["in2926005", operator.contains, [inspect.FrameInfo.__dict__,       "__iand__"], false]
    - ["in2926006", operator.contains, [inspect.ArgInfo.__dict__,         "__iand__"], false]

