spec: pathlib_extra2026
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 582 (_extra2026): __truediv__, __rtruediv__, __itruediv__, __floordiv__, __mod__, __pow__, __divmod__ dict-presence checks."
    - "pathlib.PurePath defines __truediv__ and __rtruediv__ for the / path join operator."
    - "pathlib.Path inherits __truediv__ and __rtruediv__ from PurePath; neither appears in Path.__dict__."
    - "pathlib.PurePosixPath and pathlib.PureWindowsPath inherit __truediv__ and __rtruediv__ from PurePath; neither appears in their own __dict__."
    - "None of the pathlib classes define __itruediv__, __floordiv__, __rfloordiv__, __mod__, __rmod__, __pow__, __rpow__, __divmod__, or __rdivmod__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __truediv__ / __rtruediv__ — true division dict-presence
# PurePath defines both; all subclasses inherit, so subclass __dict__ is False
# ---------------------------------------------------------------------------

table pathlib_extra2026.truediv_protocol:
  description: "pathlib types __truediv__/__rtruediv__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2026

  columns: [id, function, args, expected]
  rows:
    - ["pl2026001", "pathlib.PurePath.__dict__.__contains__",        ["__truediv__"],  true]
    - ["pl2026002", "pathlib.PurePath.__dict__.__contains__",        ["__rtruediv__"], true]
    - ["pl2026003", "pathlib.PurePosixPath.__dict__.__contains__",   ["__truediv__"],  false]
    - ["pl2026004", "pathlib.PurePosixPath.__dict__.__contains__",   ["__rtruediv__"], false]
    - ["pl2026005", "pathlib.PureWindowsPath.__dict__.__contains__", ["__truediv__"],  false]
    - ["pl2026006", "pathlib.PureWindowsPath.__dict__.__contains__", ["__rtruediv__"], false]
    - ["pl2026007", "pathlib.Path.__dict__.__contains__",            ["__truediv__"],  false]
    - ["pl2026008", "pathlib.Path.__dict__.__contains__",            ["__rtruediv__"], false]

# ---------------------------------------------------------------------------
# __itruediv__ — in-place true division dict-presence — all False
# pathlib types are not in-place divisible; no pathlib class defines __itruediv__
# ---------------------------------------------------------------------------

table pathlib_extra2026.itruediv_protocol:
  description: "pathlib types __itruediv__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2026

  columns: [id, function, args, expected]
  rows:
    - ["pl2026009",  "pathlib.PurePath.__dict__.__contains__",        ["__itruediv__"], false]
    - ["pl2026010",  "pathlib.PurePosixPath.__dict__.__contains__",   ["__itruediv__"], false]
    - ["pl2026011",  "pathlib.PureWindowsPath.__dict__.__contains__", ["__itruediv__"], false]
    - ["pl2026012",  "pathlib.Path.__dict__.__contains__",            ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# __floordiv__ — floor division dict-presence — all False
# pathlib has no floor-division semantics; // operator not defined
# ---------------------------------------------------------------------------

table pathlib_extra2026.floordiv_protocol:
  description: "pathlib types __floordiv__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2026

  columns: [id, function, args, expected]
  rows:
    - ["pl2026013", "pathlib.PurePath.__dict__.__contains__",        ["__floordiv__"], false]
    - ["pl2026014", "pathlib.PurePosixPath.__dict__.__contains__",   ["__floordiv__"], false]
    - ["pl2026015", "pathlib.PureWindowsPath.__dict__.__contains__", ["__floordiv__"], false]
    - ["pl2026016", "pathlib.Path.__dict__.__contains__",            ["__floordiv__"], false]

# ---------------------------------------------------------------------------
# __mod__ — modulo dict-presence — all False
# % operator not defined on any pathlib class
# ---------------------------------------------------------------------------

table pathlib_extra2026.mod_protocol:
  description: "pathlib types __mod__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2026

  columns: [id, function, args, expected]
  rows:
    - ["pl2026017", "pathlib.PurePath.__dict__.__contains__",        ["__mod__"], false]
    - ["pl2026018", "pathlib.PurePosixPath.__dict__.__contains__",   ["__mod__"], false]
    - ["pl2026019", "pathlib.PureWindowsPath.__dict__.__contains__", ["__mod__"], false]
    - ["pl2026020", "pathlib.Path.__dict__.__contains__",            ["__mod__"], false]

# ---------------------------------------------------------------------------
# __pow__ — exponentiation dict-presence — all False
# ** operator not defined on any pathlib class
# ---------------------------------------------------------------------------

table pathlib_extra2026.pow_protocol:
  description: "pathlib types __pow__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2026

  columns: [id, function, args, expected]
  rows:
    - ["pl2026021", "pathlib.PurePath.__dict__.__contains__",        ["__pow__"], false]
    - ["pl2026022", "pathlib.PurePosixPath.__dict__.__contains__",   ["__pow__"], false]
    - ["pl2026023", "pathlib.PureWindowsPath.__dict__.__contains__", ["__pow__"], false]
    - ["pl2026024", "pathlib.Path.__dict__.__contains__",            ["__pow__"], false]

# ---------------------------------------------------------------------------
# __divmod__ — divmod dict-presence — all False
# divmod() builtin not supported on pathlib classes
# ---------------------------------------------------------------------------

table pathlib_extra2026.divmod_protocol:
  description: "pathlib types __divmod__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2026

  columns: [id, function, args, expected]
  rows:
    - ["pl2026025", "pathlib.PurePath.__dict__.__contains__",        ["__divmod__"], false]
    - ["pl2026026", "pathlib.PurePosixPath.__dict__.__contains__",   ["__divmod__"], false]
    - ["pl2026027", "pathlib.PureWindowsPath.__dict__.__contains__", ["__divmod__"], false]
    - ["pl2026028", "pathlib.Path.__dict__.__contains__",            ["__divmod__"], false]

# ---------------------------------------------------------------------------
# Reflected and in-place variants — all False for all pathlib classes
# __rfloordiv__, __rmod__, __rpow__, __rdivmod__, __ifloordiv__, __imod__
# None of these are defined on any pathlib class
# ---------------------------------------------------------------------------

table pathlib_extra2026.reflected_inplace_protocol:
  description: "pathlib PurePath reflected and in-place division/modulo/pow/divmod dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2026

  columns: [id, function, args, expected]
  rows:
    - ["pl2026029", "pathlib.PurePath.__dict__.__contains__", ["__rfloordiv__"], false]
    - ["pl2026030", "pathlib.PurePath.__dict__.__contains__", ["__rmod__"],      false]
    - ["pl2026031", "pathlib.PurePath.__dict__.__contains__", ["__rpow__"],      false]
    - ["pl2026032", "pathlib.PurePath.__dict__.__contains__", ["__rdivmod__"],   false]
    - ["pl2026033", "pathlib.PurePath.__dict__.__contains__", ["__ifloordiv__"], false]
    - ["pl2026034", "pathlib.PurePath.__dict__.__contains__", ["__imod__"],      false]
    - ["pl2026035", "pathlib.Path.__dict__.__contains__",     ["__rfloordiv__"], false]
    - ["pl2026036", "pathlib.Path.__dict__.__contains__",     ["__rmod__"],      false]
    - ["pl2026037", "pathlib.Path.__dict__.__contains__",     ["__rpow__"],      false]
    - ["pl2026038", "pathlib.Path.__dict__.__contains__",     ["__rdivmod__"],   false]
