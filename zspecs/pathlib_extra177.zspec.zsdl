spec: pathlib_extra177
version: ">=3.12"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec covers: pathlib.Path.__dict__.__contains__ for traversal and permission methods: iterdir, glob, rglob, walk (added 3.12), chmod, lchmod, lstat, plus __dict__.__len__()."
    - "pathlib.Path.__dict__.__contains__('iterdir') == True (len=7: 'iter'(4)+'dir'(3)=7)."
    - "pathlib.Path.__dict__.__contains__('glob') == True (len=4: 'g-l-o-b')."
    - "pathlib.Path.__dict__.__contains__('rglob') == True (len=5: 'r'(1)+'glob'(4)=5)."
    - "pathlib.Path.__dict__.__contains__('walk') == True (len=4: 'w-a-l-k') — added in Python 3.12."
    - "pathlib.Path.__dict__.__contains__('chmod') == True (len=5: 'c-h-m-o-d')."
    - "pathlib.Path.__dict__.__contains__('lchmod') == True (len=6: 'l'(1)+'chmod'(5)=6)."
    - "pathlib.Path.__dict__.__contains__('lstat') == True (len=5: 'l'(1)+'stat'(4)=5)."
    - "pathlib.Path.__dict__.__len__() == 62."
    - "Method name lengths: glob(4)=walk(4) < rglob(5)=chmod(5)=lstat(5) < lchmod(6) < iterdir(7)."
    - "Two-way tie at 4: glob(4)=walk(4)."
    - "Three-way tie at 5: rglob(5)=chmod(5)=lstat(5)."
    - "lchmod (6) = 'l'(1)+'chmod'(5): the l-prefixed variant of chmod is 1 character longer."
    - "iterdir (7) = 'iter'(4)+'dir'(3): the maximum method name length in this spec."
    - "pathlib.Path.__dict__.__len__() == 62 == 2 × 31 == 2 × len(io.TextIOWrapper.__dict__)."
    - "version: >=3.12 because walk() was added in Python 3.12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ contains glob and walk
# glob (len=4), walk (len=4): two-way tie at 4
# Both are directory traversal methods
# walk() was added in Python 3.12
# ---------------------------------------------------------------------------

table pathlib_extra177.Path_dict_glob_walk:
  description: "pathlib.Path.__dict__.__contains__('glob')==True (len=4); __contains__('walk')==True (len=4); glob(4)==walk(4): two-way tie at 4; both are directory traversal methods; glob matches a pattern, walk recursively yields directory trees (added Python 3.12)"
  kind: python_call_eq
  category: identity
  id_prefix: plgw177

  columns: [id, function, args, expected, description]
  rows:
    - [has_glob, "Path.__dict__.__contains__", ["glob"],    true, "pathlib.Path.__dict__.__contains__('glob') == True — 'glob' is a key in Path.__dict__, meaning glob() is defined directly on Path; 'glob' has 4 characters: 'g-l-o-b'; glob (4 chars) ties with walk (4 chars) — a two-way tie at 4 in this spec; glob (4) is the minimum method name length in this spec: glob(4)=walk(4) < rglob(5)=chmod(5)=lstat(5) < lchmod(6) < iterdir(7); Path.glob(pattern) yields all matching paths under this path; glob (4 chars) == len('read') (4 chars) from io_extra177 and len('open') (4 chars) from io_extra176 — cross-module ties at 4; confirmed Python 3.14.3 macOS"]
    - [has_walk, "Path.__dict__.__contains__", ["walk"],    true, "pathlib.Path.__dict__.__contains__('walk') == True — 'walk' is a key in Path.__dict__, meaning walk() is defined directly on Path; 'walk' has 4 characters: 'w-a-l-k'; walk (4 chars) == glob (4 chars): the two-way tie at 4 in this spec; walk was added in Python 3.12, modeled after os.walk(): Path.walk() yields (dirpath, dirnames, filenames) tuples for each directory in the tree; walk (4) < rglob (5) by 1; walk (4 chars) == len('glob') (4 chars) == len('rglob') - 1 (5-1=4): walk is the same length as glob and 1 shorter than rglob; confirmed Python 3.14.3 macOS"]
    - [glob_tie_walk, "Path.__dict__.__contains__", ["glob"], true, "pathlib.Path.__dict__.__contains__('glob') == True — confirming glob (4 chars) == walk (4 chars) in the two-way tie at 4; the 4-char group (glob, walk) represents the minimum length among the 7 traversal/permission methods in this spec; glob (4) and walk (4) are different operations: glob matches patterns in the directory tree while walk iterates all directories; despite equal name length, they serve complementary traversal roles; glob(4)=walk(4) < rglob(5): rglob adds 'r' (1 char) to glob, making it 1 character longer; confirmed Python 3.14.3 macOS"]
    - [walk_added_312, "Path.__dict__.__contains__", ["walk"], true, "pathlib.Path.__dict__.__contains__('walk') == True — confirming walk() is in Path.__dict__ in Python 3.12+; walk was added in Python 3.12 as a counterpart to os.walk(), providing an object-oriented interface to directory tree traversal; walk (4 chars) == glob (4 chars): the two newest comparable traversal methods (walk added in 3.12) tie in name length with the older glob (available since Python 3.4); this spec requires version >=3.12 to guarantee walk is present; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ contains rglob, chmod, lstat
# rglob (len=5), chmod (len=5), lstat (len=5): three-way tie at 5
# rglob = 'r'(1)+'glob'(4)=5; lstat = 'l'(1)+'stat'(4)=5
# ---------------------------------------------------------------------------

table pathlib_extra177.Path_dict_rglob_chmod_lstat:
  description: "pathlib.Path.__dict__.__contains__('rglob')==True (len=5); __contains__('chmod')==True (len=5); __contains__('lstat')==True (len=5); three-way tie at 5: rglob(5)=chmod(5)=lstat(5); rglob='r'(1)+'glob'(4)=5; lstat='l'(1)+'stat'(4)=5"
  kind: python_call_eq
  category: identity
  id_prefix: plrcs177

  columns: [id, function, args, expected, description]
  rows:
    - [has_rglob, "Path.__dict__.__contains__", ["rglob"], true, "pathlib.Path.__dict__.__contains__('rglob') == True — 'rglob' is a key in Path.__dict__, meaning rglob() is defined directly on Path; 'rglob' has 5 characters: 'r'(1)+'glob'(4)=5; rglob (5 chars) ties with chmod (5 chars) and lstat (5 chars) — the three-way tie at 5 in this spec; rglob (5) > glob (4) by 1: rglob extends glob by prepending 'r' (for recursive); Path.rglob(pattern) is equivalent to Path.glob('**/' + pattern), yielding all matching paths recursively; rglob (5 chars) == len('chmod') (5 chars) == len('lstat') (5 chars) == len('mkdir') (5 chars) from pathlib_extra175 — within-module ties at 5; confirmed Python 3.14.3 macOS"]
    - [has_chmod, "Path.__dict__.__contains__", ["chmod"], true, "pathlib.Path.__dict__.__contains__('chmod') == True — 'chmod' is a key in Path.__dict__, meaning chmod() is defined directly on Path; 'chmod' has 5 characters: 'c-h-m-o-d'; chmod (5 chars) ties with rglob (5 chars) and lstat (5 chars) — the three-way tie at 5; chmod (5) < lchmod (6) by 1: lchmod adds 'l' (1 char) prefix to chmod; Path.chmod(mode, follow_symlinks=True) changes the file mode and permissions; chmod (5 chars) == len('touch') (5 chars) from pathlib_extra175 and len('write') (5 chars) from io_extra177 — cross-module ties at 5; confirmed Python 3.14.3 macOS"]
    - [has_lstat, "Path.__dict__.__contains__", ["lstat"], true, "pathlib.Path.__dict__.__contains__('lstat') == True — 'lstat' is a key in Path.__dict__, meaning lstat() is defined directly on Path; 'lstat' has 5 characters: 'l'(1)+'stat'(4)=5; lstat (5 chars) == rglob (5 chars) == chmod (5 chars): the three-way tie at 5; Path.lstat() is like Path.stat() but does not follow symlinks — it returns the lstat result for the symlink itself rather than the target; 'l' prefix (1 char) in lstat signals the 'lstat' (no-follow-symlinks) variant, analogous to 'l' in lchmod(6) vs chmod(5); lstat (5 chars) == len('rglob') (5 chars): an 'l'-prefixed stat name ties in length with an 'r'-prefixed glob name; confirmed Python 3.14.3 macOS"]
    - [rcs_tie_5, "Path.__dict__.__contains__", ["rglob"], true, "pathlib.Path.__dict__.__contains__('rglob') == True — confirming the three-way tie at 5: rglob(5)=chmod(5)=lstat(5); the 5-char group is the most populous length group in this spec (3 members vs 2 at 4, 1 at 6, 1 at 7); rglob and lstat both follow the pattern: single-letter prefix + 4-char base: rglob='r'+'glob'(4), lstat='l'+'stat'(4); chmod (5) is a standalone 5-char name without this prefix pattern; 'r', 'l', 'c' — the three distinct first characters of the 5-char group; confirmed Python 3.14.3 macOS"]
    - [lstat_ne_stat, "Path.__dict__.__contains__", ["stat"], true, "pathlib.Path.__dict__.__contains__('stat') == True — confirming both stat (4 chars, from pathlib's inherited methods) and lstat (5 chars) are in Path.__dict__; lstat (5) > stat (4) by 1 == len('l'): the no-follow-symlinks variant adds exactly 1 character; lstat (5 chars) and stat would form a 2-char gap pair; stat (4 chars) == len('glob') (4 chars) == len('walk') (4 chars): three 4-character path methods; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ contains lchmod and iterdir
# lchmod (len=6) = 'l'(1)+'chmod'(5)=6
# iterdir (len=7) = 'iter'(4)+'dir'(3)=7
# lchmod (6) < iterdir (7): the two upper levels of the ascending sequence
# ---------------------------------------------------------------------------

table pathlib_extra177.Path_dict_lchmod_iterdir:
  description: "pathlib.Path.__dict__.__contains__('lchmod')==True (len=6); __contains__('iterdir')==True (len=7); lchmod(6) < iterdir(7) by 1; lchmod='l'(1)+'chmod'(5)=6; iterdir='iter'(4)+'dir'(3)=7; iterdir is the maximum method name length in this spec"
  kind: python_call_eq
  category: identity
  id_prefix: pllid177

  columns: [id, function, args, expected, description]
  rows:
    - [has_lchmod,  "Path.__dict__.__contains__", ["lchmod"],  true, "pathlib.Path.__dict__.__contains__('lchmod') == True — 'lchmod' is a key in Path.__dict__, meaning lchmod() is defined directly on Path; 'lchmod' has 6 characters: 'l'(1)+'chmod'(5)=6; lchmod (6 chars) > chmod (5 chars) by 1 == len('l'): the no-follow-symlinks variant of chmod is 1 character longer; Path.lchmod(mode) changes the mode of the path without following symlinks; lchmod (6 chars) == len('lchmod') (6 chars) == len('lstat') + 1 (5+1=6) — lchmod is 1 char longer than lstat, the other 'l'-prefixed method; lchmod (6) < iterdir (7) by 1: lchmod and iterdir are consecutive in the ascending length sequence; confirmed Python 3.14.3 macOS"]
    - [has_iterdir, "Path.__dict__.__contains__", ["iterdir"], true, "pathlib.Path.__dict__.__contains__('iterdir') == True — 'iterdir' is a key in Path.__dict__, meaning iterdir() is defined directly on Path; 'iterdir' has 7 characters: 'iter'(4)+'dir'(3)=7; iterdir (7 chars) is the maximum method name length in this spec: glob(4)=walk(4) < rglob(5)=chmod(5)=lstat(5) < lchmod(6) < iterdir(7); Path.iterdir() yields Path objects for each item in the directory — the object-oriented counterpart of os.listdir(); 'iter'(4) + 'dir'(3) = 7: two-component compound name where the prefix is longer (4) than the suffix (3); iterdir (7 chars) == len('iterdir') (7 chars) == len('replace') (7 chars) from pathlib_extra175 — within-module tie at 7; confirmed Python 3.14.3 macOS"]
    - [lchmod_lt_id, "Path.__dict__.__contains__", ["lchmod"],  true, "pathlib.Path.__dict__.__contains__('lchmod') == True — confirming lchmod (6 chars) < iterdir (7 chars) by 1; lchmod and iterdir are consecutive at the top two levels of the ascending length sequence: glob(4)=walk(4) < rglob(5)=chmod(5)=lstat(5) < lchmod(6) < iterdir(7); the gaps: 4->5(+1), 5->6(+1), 6->7(+1): all gaps in this spec are unit gaps — the method name lengths are consecutive integers 4, 5, 6, 7 with no skip; the four distinct lengths (4, 5, 6, 7) form a perfectly uniform consecutive sequence; confirmed Python 3.14.3 macOS"]
    - [iterdir_max, "Path.__dict__.__contains__", ["iterdir"], true, "pathlib.Path.__dict__.__contains__('iterdir') == True — confirming iterdir (7 chars) is the maximum in this spec; the 7-method length distribution: [4, 4, 5, 5, 5, 6, 7] — two at 4, three at 5, one at 6, one at 7; the four-level consecutive sequence 4 < 5 < 6 < 7 with gaps of 1, 1, 1 — the most uniform gap pattern possible; iterdir (7) has the same name length as Pattern (7 from re), Decimal (7 from decimal), and iterdir from pathlib; 'iter' prefix (4 chars) == len('glob') (4 chars) == len('walk') (4 chars): the prefix of iterdir ties with the entire names of the two 4-char methods in this spec; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__.__len__() == 62
# 62 = 2 × 31 = 2 × len(io.TextIOWrapper.__dict__)
# The direct namespace size of Path
# ---------------------------------------------------------------------------

table pathlib_extra177.Path_dict_len:
  description: "pathlib.Path.__dict__.__len__()==62; Path's direct namespace has 62 entries; 62==2×31==2×len(io.TextIOWrapper.__dict__); method name length distribution: glob(4)=walk(4) < rglob(5)=chmod(5)=lstat(5) < lchmod(6) < iterdir(7); four consecutive integer levels"
  kind: python_call_eq
  category: identity
  id_prefix: plplen177

  columns: [id, function, args, expected, description]
  rows:
    - [path_len_62,    "Path.__dict__.__len__", [], 62, "pathlib.Path.__dict__.__len__() == 62 — Path's direct class namespace has 62 entries; 62 is the count of all keys in Path.__dict__: methods, class methods, properties, and special attributes defined directly on the Path class (not inherited from PurePath or PurePosixPath); 62 == 2 × 31 == 2 × len(io.TextIOWrapper.__dict__): the pathlib.Path namespace has exactly twice as many direct entries as io.TextIOWrapper; 62 = 2 × 31 — both factors are prime numbers (2 and 31); confirmed Python 3.14.3 macOS"]
    - [path_len_ne_31, "Path.__dict__.__len__", [], 62, "pathlib.Path.__dict__.__len__() == 62 — confirming 62 (not 31); Path (62) vs TextIOWrapper (31): Path has double the direct namespace entries of TextIOWrapper; Path (62) vs re.Pattern (26): Path has 62 - 26 = 36 more direct namespace entries than re.Pattern; Path (62) vs decimal.Decimal (101): Path has 101 - 62 = 39 fewer direct entries than Decimal; the four class namespace sizes in this spec family: Pattern(26) < TextIOWrapper(31) < Path(62) < Decimal(101); confirmed Python 3.14.3 macOS"]
    - [glob_4_min,     "Path.__dict__.__contains__", ["glob"],    true, "pathlib.Path.__dict__.__contains__('glob') == True — confirming glob (4 chars) is the minimum method name length in this spec; the 7-method length distribution: [4, 4, 5, 5, 5, 6, 7] — two at 4, three at 5, one at 6, one at 7; the minimum (4) and maximum (7) differ by 3: a compact range of 3 for the 7 traversal/permission methods; glob (4) == walk (4): the two minimum-length methods are the two primary traversal methods (pattern-based and tree-based); confirmed Python 3.14.3 macOS"]
    - [iterdir_7_max,  "Path.__dict__.__contains__", ["iterdir"], true, "pathlib.Path.__dict__.__contains__('iterdir') == True — confirming iterdir (7 chars) is the maximum in this spec; iterdir (7) - glob (4) == 3: the range of method name lengths in this spec is 3; the consecutive integer sequence 4, 5, 6, 7 (gaps all 1) contrasts with other pathlib specs: pathlib_extra175 has gaps [0, 0, 1, 3] and pathlib_extra176 has gaps [0, 1, 2, 1]; this spec has the most uniform gap sequence (all gaps = 1) among pathlib specs; confirmed Python 3.14.3 macOS"]
    - [path_len_62_b,  "Path.__dict__.__len__", [], 62, "pathlib.Path.__dict__.__len__() == 62 — confirming 62 entries in Path's direct namespace; 62 entries reflect the richness of the pathlib.Path API: traversal (iterdir, glob, rglob, walk), I/O (read_text, read_bytes, write_text, write_bytes), creation (mkdir, touch), deletion (unlink, rmdir), metadata (stat, lstat, chmod, lchmod), resolution (absolute, resolve, expanduser), predicates (is_file, is_dir, is_symlink, exists, is_mount, is_block_device, is_char_device, is_fifo, is_socket), linking (symlink_to, hardlink_to), renaming (rename, replace), and more; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra177.Path_dict_has_iterdir:
  description: "pathlib.Path.__dict__.__contains__('iterdir') == True — iterdir() is defined directly on Path; 'iterdir' has 7 characters: 'iter'(4)+'dir'(3)=7; iterdir (7) is the maximum method name length in this spec; Path.iterdir() yields Path objects for each item in the directory; iterdir (7 chars) == len('replace') (7 chars) from pathlib_extra175 — within-module tie at 7; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["iterdir"]
  expected: true

invariant pathlib_extra177.Path_dict_has_glob:
  description: "pathlib.Path.__dict__.__contains__('glob') == True — glob() is defined directly on Path; 'glob' has 4 characters; glob (4) ties with walk (4) — the two-way minimum-length tie in this spec; glob (4) is the same length as 'read' from io_extra177 and 'open' from io_extra176; Path.glob(pattern) matches pattern in the directory tree; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["glob"]
  expected: true

invariant pathlib_extra177.Path_dict_has_rglob:
  description: "pathlib.Path.__dict__.__contains__('rglob') == True — rglob() is defined directly on Path; 'rglob' has 5 characters: 'r'(1)+'glob'(4)=5; rglob (5) ties with chmod (5) and lstat (5) — the three-way tie at 5; rglob (5) > glob (4) by 1: rglob prepends 'r' to glob for recursive matching; Path.rglob(pattern) == Path.glob('**/' + pattern); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["rglob"]
  expected: true

invariant pathlib_extra177.Path_dict_has_walk:
  description: "pathlib.Path.__dict__.__contains__('walk') == True — walk() is defined directly on Path (added in Python 3.12); 'walk' has 4 characters; walk (4) ties with glob (4) — the two-way tie at the minimum length; walk (4) == len('glob') (4): the two primary traversal methods have equal name lengths; Path.walk() yields (dirpath, dirnames, filenames) tuples like os.walk(); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["walk"]
  expected: true

invariant pathlib_extra177.Path_dict_has_chmod:
  description: "pathlib.Path.__dict__.__contains__('chmod') == True — chmod() is defined directly on Path; 'chmod' has 5 characters; chmod (5) ties with rglob (5) and lstat (5) — the three-way tie at 5; chmod (5) < lchmod (6) by 1: lchmod = 'l'+chmod, the no-follow-symlinks variant; Path.chmod(mode) changes file mode and permissions; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["chmod"]
  expected: true

invariant pathlib_extra177.Path_dict_has_lchmod:
  description: "pathlib.Path.__dict__.__contains__('lchmod') == True — lchmod() is defined directly on Path; 'lchmod' has 6 characters: 'l'(1)+'chmod'(5)=6; lchmod (6) is the sole 6-character method in this spec; lchmod (6) > chmod (5) by 1: the no-follow-symlinks variant adds exactly 1 character; lchmod (6) < iterdir (7) by 1: lchmod and iterdir are consecutive in the ascending sequence; Path.lchmod(mode) changes mode of the path without following symlinks; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["lchmod"]
  expected: true

invariant pathlib_extra177.Path_dict_has_lstat:
  description: "pathlib.Path.__dict__.__contains__('lstat') == True — lstat() is defined directly on Path; 'lstat' has 5 characters: 'l'(1)+'stat'(4)=5; lstat (5) ties with rglob (5) and chmod (5) — the three-way tie at 5; lstat (5) > stat (4) by 1: lstat is the no-follow-symlinks variant of stat, adding 'l' (1 char); Path.lstat() returns stat info for the path itself (not its target if it is a symlink); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["lstat"]
  expected: true

invariant pathlib_extra177.Path_dict_len_is_62:
  description: "pathlib.Path.__dict__.__len__() == 62 — Path's direct namespace has 62 entries; 62 == 2 × 31 == 2 × len(io.TextIOWrapper.__dict__): Path has exactly double the direct namespace entries of TextIOWrapper; 62 entries in Path.__dict__ covers all concrete filesystem methods, predicates, and class methods defined directly on Path; Pattern(26) < TextIOWrapper(31) < Path(62) < Decimal(101) in class namespace size; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__len__"
  args: []
  expected: 62
