spec: theseus_dis_cr
version: ">=3.8"
backend: python_cleanroom(theseus_dis_cr)
blocks: dis

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/dis.html"
  not_derived_from:
    - "CPython source: Lib/dis.py"
  notes:
    - "Clean-room dis module. Do NOT import dis."

error_model: python_exceptions

invariant theseus_dis_cr.dis2_get_instructions:
  description: "get_instructions() yields Instruction objects for a function"
  category: behavior
  kind: python_call_eq
  function: dis2_get_instructions
  args: []
  expected: true

invariant theseus_dis_cr.dis2_findlinestarts:
  description: "findlinestarts() yields (offset, lineno) pairs"
  category: behavior
  kind: python_call_eq
  function: dis2_findlinestarts
  args: []
  expected: true

invariant theseus_dis_cr.dis2_opname:
  description: "opname mapping exists and LOAD_CONST is in it"
  category: behavior
  kind: python_call_eq
  function: dis2_opname
  args: []
  expected: true
