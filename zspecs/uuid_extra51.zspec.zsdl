spec: uuid_extra51
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra50.zspec.zsdl — covers uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant); UUID.__eq__.__qualname__.__eq__('UUID.__eq__') (table)."
    - "uuid_extra49.zspec.zsdl — covers UUID/uuid4/uuid1 __doc__.__class__.__qualname__.__eq__('str') (table); uuid.__dict__.__contains__ for UUID/uuid4/NAMESPACE_DNS/getnode/uuid1 (table + invariant)."
    - "uuid_extra48.zspec.zsdl — covers UUID.__eq__/__lt__/__le__/__gt__/__ge__.__class__.__name__.__eq__('function'); uuid.__dict__.__contains__('__all__') == False."
    - "uuid_extra25.zspec.zsdl — covers uuid.__spec__.__name__.__len__()==4 and uuid.__loader__.__class__.__name__.__len__()==16."
    - "uuid_extra17.zspec.zsdl — covers UUID.__lt__/__gt__/__le__/__ge__.__qualname__.__eq__ and __qualname__.__len__()==11."
    - "uuid_extra16.zspec.zsdl — covers UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__.__qualname__.__eq__ and __qualname__.__len__()."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra50; it does NOT duplicate invariants present in those files."
    - "Wave 226 theme: __spec__.origin values + __spec__.submodule_search_locations + __loader__.__name__ length checks."
    - "uuid is a pure-Python module (Lib/uuid.py). It is not a package: it has no sub-module directory, so __spec__.submodule_search_locations is None (NoneType). For Python source files, __spec__.has_location is True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 1: No prior uuid spec checks uuid.__loader__.__class__.__name__.__len__()==16 in a table row context alongside the new __spec__.origin checks. uuid_extra25 covers __loader__.__class__.__name__.__len__()==16 as a standalone invariant; uuid_extra50 covers __loader__.__class__.__name__.__eq__('SourceFileLoader'). This spec adds __loader__.__class__.__name__.__len__()==16 as a table row in the wave 226 grouped context. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior uuid spec checks uuid.__spec__.origin.__class__.__name__.__eq__('str'). uuid.__spec__.origin is the absolute file path to uuid.py as a Python str. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.origin.__class__.__name__ == 'str'. The ModuleSpec.origin attribute is the path to the source file (e.g., '.../lib/python3.14/uuid.py') stored as a Python str. No prior uuid spec checks __spec__.origin.__class__.__name__ in any form. Entirely novel origin type anchor for uuid. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior uuid spec checks uuid.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType'). uuid is a single-file module (uuid.py), not a package; therefore __spec__.submodule_search_locations is None. None.__class__.__name__ == 'NoneType'. This confirms uuid is not a package. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.submodule_search_locations is None. For non-package modules, ModuleSpec.submodule_search_locations is None. None.__class__.__name__ == 'NoneType'. No prior uuid spec checks submodule_search_locations in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 4: No prior uuid spec checks uuid.__spec__.has_location. For Python source modules, ModuleSpec.has_location is True. has_location being True confirms uuid is file-backed. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.has_location == True. uuid.py is a file-backed Python module; its ModuleSpec.has_location is True. No prior uuid spec checks __spec__.has_location. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 5: uuid_extra17 covers UUID.__lt__/__gt__/__le__/__ge__.__qualname__.__eq__ (all four comparison dunder methods). uuid_extra16 covers UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__.__qualname__.__eq__. UUID.__ne__.__qualname__ == 'object.__ne__' because UUID does NOT define __ne__ directly — it inherits from object. This is a distinct structural fact: uuid_extra48 checks UUID.__ne__.__class__.__name__.__eq__('wrapper_descriptor') (the object type) but no prior uuid spec checks UUID.__ne__.__qualname__.__eq__('object.__ne__') (the qualname showing inheritance). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ne__.__qualname__ == 'object.__ne__'. UUID does not define __ne__ directly; Python inherits it from object. The qualname 'object.__ne__' (as opposed to 'UUID.__ne__') is the signal that __ne__ is not overridden in UUID. This contrasts with __eq__, __lt__, __gt__, __le__, __ge__ which all have 'UUID.*' qualnames (defined on UUID itself). No prior uuid spec checks UUID.__ne__.__qualname__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid __spec__.origin + submodule_search_locations + has_location checks
#
# Wave 226 theme: __spec__.origin values + __spec__.submodule_search_locations +
# __loader__.__name__ length checks.
#
# uuid is a single-file Python module (not a package). Its ModuleSpec has:
#   - origin: str path to uuid.py
#   - submodule_search_locations: None (NoneType) — not a package
#   - has_location: True — file-backed module
# ---------------------------------------------------------------------------

table uuid_extra51.spec_origin_submodule_location:
  description: "uuid __loader__.__class__.__name__.__len__()==16 / __spec__.origin.__class__.__name__.__eq__('str') / __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') / __spec__.has_location==True — wave 226 theme: origin/submodule_search_locations/has_location checks for uuid; uuid is a single-file Python module (not a package); origin is a str path, submodule_search_locations is None (NoneType), has_location is True; all spec.origin/submodule/has_location rows are novel for uuid"
  kind: python_call_eq
  category: module_structure
  id_prefix: uuidspec51

  columns: [id, function, args, expected]
  rows:
    - [loader_class_name_len,               __loader__.__class__.__name__.__len__,                             [], 16]
    - [spec_origin_class_name_eq,           __spec__.origin.__class__.__name__.__eq__,                         ["str"],      true]
    - [spec_submodule_search_class_name_eq, __spec__.submodule_search_locations.__class__.__name__.__eq__,      ["NoneType"], true]
    - [spec_has_location,                   __spec__.has_location.__eq__,                                       [true],       true]

# ---------------------------------------------------------------------------
# uuid.UUID.__ne__.__qualname__.__eq__('object.__ne__') — inherited __ne__
#
# UUID defines __eq__, __lt__, __gt__, __le__, __ge__ directly on the class
# (all have 'UUID.*' qualnames). It does NOT define __ne__; Python inherits
# __ne__ from object. UUID.__ne__.__qualname__ == 'object.__ne__' reveals
# this inheritance at the qualname level.
#
# uuid_extra48 covers UUID.__ne__.__class__.__name__.__eq__('wrapper_descriptor')
# (the type of the inherited slot wrapper). uuid_extra17 covers __qualname__.__eq__
# for __lt__/__gt__/__le__/__ge__. No prior uuid spec checks UUID.__ne__.__qualname__
# in any form.
# ---------------------------------------------------------------------------

table uuid_extra51.UUID_ne_qualname:
  description: "uuid.UUID.__ne__.__qualname__.__eq__('object.__ne__') — UUID does not define __ne__ directly; it inherits from object, giving qualname 'object.__ne__' rather than 'UUID.__ne__'; uuid_extra48 covers UUID.__ne__.__class__.__name__.__eq__('wrapper_descriptor') (type axis) but no prior uuid spec checks UUID.__ne__.__qualname__ in any form; reveals inheritance vs direct definition"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidspec51

  columns: [id, function, args, expected]
  rows:
    - [UUID_ne_qualname_eq, "UUID.__ne__.__qualname__.__eq__", ["object.__ne__"], true]

# ---------------------------------------------------------------------------
# uuid.__spec__.origin.__class__.__name__.__eq__('str') — standalone
#
# uuid.__spec__.origin is the absolute file path to uuid.py, stored as a
# Python str. No prior uuid spec checks __spec__.origin in any form. This
# is the primary origin type anchor for the uuid module: it confirms that
# uuid has a file-system location discoverable as a str path.
# ---------------------------------------------------------------------------

invariant uuid_extra51.spec_origin_class_name_str:
  description: "uuid.__spec__.origin.__class__.__name__.__eq__('str') == True — uuid.__spec__.origin is the str path to uuid.py; ModuleSpec.origin is str for file-backed Python modules; no prior uuid spec checks __spec__.origin in any form; primary origin type anchor for uuid confirming file-system-backed loading"
  category: module_structure
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType')
# — standalone
#
# uuid is not a package: it is a single file (uuid.py) with no sub-modules.
# ModuleSpec.submodule_search_locations is None for non-package modules.
# None.__class__.__name__ == 'NoneType'. No prior uuid spec checks
# submodule_search_locations in any form.
# ---------------------------------------------------------------------------

invariant uuid_extra51.spec_submodule_search_locations_nonetype:
  description: "uuid.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — uuid is a single-file module (not a package); ModuleSpec.submodule_search_locations is None for non-package modules; None.__class__.__name__ == 'NoneType'; no prior uuid spec checks submodule_search_locations; confirms uuid has no package sub-path"
  category: module_structure
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true
