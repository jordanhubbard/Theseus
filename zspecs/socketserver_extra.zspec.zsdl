spec: socketserver_extra
version: ">=3.9"
backend: python_module(socketserver)

docs: https://docs.python.org/3/library/socketserver.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socketserver.html — Python socketserver module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/socketserver.py"
  notes:
    - "This spec covers class name and module identity invariants for the socketserver module."
    - "socketserver.BaseServer is the abstract base for all server classes."
    - "socketserver.TCPServer and socketserver.UDPServer are the concrete server classes."
    - "socketserver.StreamRequestHandler and socketserver.DatagramRequestHandler handle stream and datagram connections respectively."
    - "socketserver.BaseRequestHandler is the base class for all request handler classes."
    - "socketserver.ThreadingMixIn and socketserver.ForkingMixIn enable concurrent request handling."
    - "socketserver.ThreadingTCPServer and socketserver.ForkingTCPServer are convenience subclasses."
    - "All class __name__ attributes match the class's unqualified identifier."
    - "All class __module__ attributes are 'socketserver' — all classes are defined in Lib/socketserver.py."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TCPServer — class name and module
# ---------------------------------------------------------------------------

invariant socketserver_extra.TCPServer.class_name:
  description: "socketserver.TCPServer.__name__ == 'TCPServer'"
  category: class_names
  kind: python_call_eq
  function: TCPServer.__name__.__eq__
  args: ["TCPServer"]
  expected: true

invariant socketserver_extra.TCPServer.module:
  description: "socketserver.TCPServer.__module__ == 'socketserver'"
  category: class_modules
  kind: python_call_eq
  function: TCPServer.__module__.__eq__
  args: ["socketserver"]
  expected: true

# ---------------------------------------------------------------------------
# UDPServer — class name and module
# ---------------------------------------------------------------------------

invariant socketserver_extra.UDPServer.class_name:
  description: "socketserver.UDPServer.__name__ == 'UDPServer'"
  category: class_names
  kind: python_call_eq
  function: UDPServer.__name__.__eq__
  args: ["UDPServer"]
  expected: true

invariant socketserver_extra.UDPServer.module:
  description: "socketserver.UDPServer.__module__ == 'socketserver'"
  category: class_modules
  kind: python_call_eq
  function: UDPServer.__module__.__eq__
  args: ["socketserver"]
  expected: true

