# ---------------------------------------------------------------------------
# Class hierarchy checks
# TCPServer inherits from BaseServer
# UDPServer inherits from TCPServer
# StreamRequestHandler and DatagramRequestHandler both inherit from BaseRequestHandler
# ---------------------------------------------------------------------------

invariant socketserver_extra.TCPServer.base_is_BaseServer:
  description: "socketserver.TCPServer.__bases__[0].__name__ == 'BaseServer'"
  category: class_hierarchy
  kind: python_call_eq
  function: TCPServer.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseServer"

invariant socketserver_extra.StreamRequestHandler.base_is_BaseRequestHandler:
  description: "socketserver.StreamRequestHandler.__bases__[0].__name__ == 'BaseRequestHandler'"
  category: class_hierarchy
  kind: python_call_eq
  function: StreamRequestHandler.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseRequestHandler"

invariant socketserver_extra.DatagramRequestHandler.base_is_BaseRequestHandler:
  description: "socketserver.DatagramRequestHandler.__bases__[0].__name__ == 'BaseRequestHandler'"
  category: class_hierarchy
  kind: python_call_eq
  function: DatagramRequestHandler.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseRequestHandler"
