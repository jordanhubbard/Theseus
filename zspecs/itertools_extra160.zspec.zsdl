  notes:
    - "This spec covers: itertools.chain.from_iterable.__class__.__name__ 'builtin_function_or_method'; itertools.chain.from_iterable.__qualname__ 'chain.from_iterable'; itertools.chain.from_iterable.__name__ 'from_iterable'; itertools.starmap.__module__ 'itertools'; itertools.starmap.__name__ 'starmap'; itertools.compress.__module__ 'itertools'; itertools.compress.__name__ 'compress' (Wave 289)."
    - "itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method' — chain.from_iterable is a classmethod-like built-in callable defined in itertoolsmodule.c; it has no __func__ attribute; its __class__.__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — the __qualname__ of chain.from_iterable is 'chain.from_iterable', reflecting its location as a method on the chain type. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__name__ == 'from_iterable' — the simple __name__ of the bound C method is 'from_iterable'. Verified with Python 3.14.3."
    - "itertools.starmap.__module__ == 'itertools' — starmap is a C extension type in itertoolsmodule.c; its __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.starmap.__name__ == 'starmap' — the C extension type starmap has __name__ 'starmap'. Verified with Python 3.14.3."
    - "itertools.compress.__module__ == 'itertools' — compress is a C extension type in itertoolsmodule.c; its __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.compress.__name__ == 'compress' — the C extension type compress has __name__ 'compress'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain.from_iterable classmethod identity
#
# Wave 289 theme: itertools.chain.from_iterable class, qualname, and name.
#
# itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method'
# itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'
# itertools.chain.from_iterable.__name__ == 'from_iterable'
# itertools.chain.__name__ == 'chain'
#
# itertools.chain is a C extension type defined in itertoolsmodule.c that
# chains multiple iterables end-to-end into a single iterable. chain.from_iterable
# is an alternate constructor that takes a single iterable of iterables (rather
# than multiple positional arguments). It is exposed as a C builtin method on
# the chain type object; its __class__.__name__ is 'builtin_function_or_method'
# (it does not have a __func__ attribute like Python classmethods do). Its
# __qualname__ is 'chain.from_iterable' and its simple __name__ is
# 'from_iterable'. New to extra160.
# ---------------------------------------------------------------------------

table itertools_extra160.chain_from_iterable_identity:
  description: "itertools.chain.from_iterable: __class__.__name__ 'builtin_function_or_method', __qualname__ 'chain.from_iterable', __name__ 'from_iterable'; chain.__name__ 'chain'; wave 289; new to extra160"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscfi160

  columns: [id, function, args, expected, description]
  rows:
    - [cfi_class_name_eq_builtin,
       "chain.from_iterable.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.chain.from_iterable.__class__.__name__.__eq__('builtin_function_or_method') == True — chain.from_iterable is a C builtin method on the chain type object in itertoolsmodule.c; it constructs a chain from a single iterable of iterables; it has no __func__ attribute; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra160"]
    - [cfi_qualname_eq,
       "chain.from_iterable.__qualname__.__eq__",
       ["chain.from_iterable"],
       true,
       "itertools.chain.from_iterable.__qualname__.__eq__('chain.from_iterable') == True — chain.from_iterable is an alternate constructor on the chain C type; its __qualname__ is 'chain.from_iterable' reflecting its position as a method on chain; str.__eq__('chain.from_iterable') returns True; new to extra160"]
    - [cfi_name_eq_from_iterable,
       "chain.from_iterable.__name__.__eq__",
       ["from_iterable"],
       true,
       "itertools.chain.from_iterable.__name__.__eq__('from_iterable') == True — the simple __name__ of the C builtin method chain.from_iterable is 'from_iterable'; str.__eq__('from_iterable') returns True; new to extra160"]
    - [chain_name_eq_chain,
       "chain.__name__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__name__.__eq__('chain') == True — chain is a C extension type in itertoolsmodule.c that chains multiple iterables end-to-end; its type __name__ is 'chain'; str.__eq__('chain') returns True; new to extra160"]

# ---------------------------------------------------------------------------
# Table 2: itertools.starmap and itertools.compress identity
#
# Wave 289 theme: itertools.starmap and itertools.compress __module__ and
# __name__ attributes.
#
# itertools.starmap.__module__ == 'itertools'
# itertools.starmap.__name__ == 'starmap'
# itertools.compress.__module__ == 'itertools'
# itertools.compress.__name__ == 'compress'
#
# starmap and compress are C extension types defined in itertoolsmodule.c.
# starmap(func, iterable) applies func to each tuple of arguments from
# iterable, equivalent to (func(*args) for args in iterable). compress(data,
# selectors) returns elements of data for which the corresponding selector is
# True. Both report __module__ == 'itertools' and their __name__ is the simple
# type name. New to extra160.
# ---------------------------------------------------------------------------

table itertools_extra160.starmap_and_compress_identity:
  description: "itertools: starmap.__module__ 'itertools', starmap.__name__ 'starmap', compress.__module__ 'itertools', compress.__name__ 'compress'; wave 289; new to extra160"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolssmci160

  columns: [id, function, args, expected, description]
  rows:
    - [starmap_module_eq_itertools,
       "starmap.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.starmap.__module__.__eq__('itertools') == True — starmap is a C extension type in itertoolsmodule.c that applies a function to each tuple of arguments taken from an iterable; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra160"]
    - [starmap_name_eq_starmap,
       "starmap.__name__.__eq__",
       ["starmap"],
       true,
       "itertools.starmap.__name__.__eq__('starmap') == True — the C extension type starmap has __name__ 'starmap'; starmap(func, iterable) is equivalent to (func(*args) for args in iterable); str.__eq__('starmap') returns True; new to extra160"]
    - [compress_module_eq_itertools,
       "compress.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.compress.__module__.__eq__('itertools') == True — compress is a C extension type in itertoolsmodule.c that filters one iterable based on truth values from another; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra160"]
    - [compress_name_eq_compress,
       "compress.__name__.__eq__",
       ["compress"],
       true,
       "itertools.compress.__name__.__eq__('compress') == True — the C extension type compress has __name__ 'compress'; compress(data, selectors) returns elements of data for which the corresponding selector is truthy; str.__eq__('compress') returns True; new to extra160"]

