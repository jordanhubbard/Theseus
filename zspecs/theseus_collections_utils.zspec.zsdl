spec: theseus_collections_utils
version: ">=3.9"
backend: python_cleanroom(theseus_collections_utils)
blocks: collections

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html"
  notes:
    - "Clean-room collections utilities. Do NOT import collections."
    - "Counter(iterable): counts element frequencies; Counter('aabbc')['a'] == 2."
    - "defaultdict(default_factory): returns default_factory() for missing keys."
    - "deque(iterable, maxlen=None): double-ended queue with appendleft/popleft/append/pop."
    - "OrderedDict: dict that remembers insertion order (iteration order matches insertion)."
    - "Export: Counter, defaultdict, deque, OrderedDict."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_collections_utils.counter_freq:
  description: "Counter('aabbc')['a'] == 2"
  category: counter
  kind: python_call_eq
  function: collections_counter_freq
  args: []
  expected: 2

invariant theseus_collections_utils.defaultdict_missing:
  description: "defaultdict(int)['missing'] == 0"
  category: defaultdict
  kind: python_call_eq
  function: collections_defaultdict_missing
  args: []
  expected: 0

invariant theseus_collections_utils.deque_appendleft:
  description: "deque appendleft then popleft returns first"
  category: deque
  kind: python_call_eq
  function: collections_deque_appendleft
  args: []
  expected: 99
