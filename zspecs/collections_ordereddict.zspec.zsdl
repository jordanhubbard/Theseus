spec: collections_ordereddict
version: ">=3.1"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html#collections.OrderedDict

provenance:
  derived_from:
    - "Python collections documentation — https://docs.python.org/3/library/collections.html"
    - "Test vectors verified with Python 3.14 on macOS Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
  notes:
    - "OrderedDict is a dict subclass that remembers insertion order and provides move_to_end() and popitem()."
    - "OrderedDict.__bases__[0].__name__ == 'dict' — it directly subclasses dict."
    - "OrderedDict([('a',1),('b',2),('c',3)]).__len__() == 3."
    - "popitem(last=True) removes and returns the (key, value) pair in LIFO order (last inserted)."
    - "popitem(last=False) removes and returns the (key, value) pair in FIFO order (first inserted)."
    - "move_to_end(key) moves an existing key to the rightmost (last) position by default."
    - "move_to_end(key, last=False) moves the key to the leftmost (first) position."
    - "OrderedDict equality: two OrderedDicts with same content in different order are NOT equal."
    - "OrderedDict.__module__ == 'collections'."
    - "All expected values verified by running Python 3.14 on macOS Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class identity
# ---------------------------------------------------------------------------

invariant collections_ordereddict.class.name:
  description: "OrderedDict.__name__ == 'OrderedDict'"
  category: identity
  kind: python_call_eq
  function: OrderedDict.__name__.__eq__
  args: ["OrderedDict"]
  expected: true

invariant collections_ordereddict.class.module:
  description: "OrderedDict.__module__ == 'collections'"
  category: identity
  kind: python_call_eq
  function: OrderedDict.__module__.__eq__
  args: ["collections"]
  expected: true

invariant collections_ordereddict.class.base:
  description: "OrderedDict.__bases__[0].__name__ == 'dict' — inherits from dict"
  category: identity
  kind: python_call_eq
  function: OrderedDict.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "dict"

# ---------------------------------------------------------------------------
# Basic construction and length
# ---------------------------------------------------------------------------

invariant collections_ordereddict.construction.len_three:
  description: "len(OrderedDict([('a',1),('b',2),('c',3)])) == 3"
  category: construction
  kind: python_call_eq
  function: OrderedDict
  args: [[["a", 1], ["b", 2], ["c", 3]]]
  method: __len__
  expected: 3

invariant collections_ordereddict.construction.empty_len:
  description: "len(OrderedDict()) == 0 — empty OrderedDict"
  category: construction
  kind: python_call_eq
  function: OrderedDict
  args: []
  method: __len__
  expected: 0

# ---------------------------------------------------------------------------
# Key access and containment
# ---------------------------------------------------------------------------

invariant collections_ordereddict.access.key_b:
  description: "OrderedDict([('a',1),('b',2),('c',3)])['b'] == 2"
  category: access
  kind: python_call_eq
  function: OrderedDict
  args: [[["a", 1], ["b", 2], ["c", 3]]]
  method: __getitem__
  method_args: ["b"]
  expected: 2

invariant collections_ordereddict.access.contains_a:
  description: "'a' in OrderedDict([('a',1),('b',2)]) == True"
  category: access
  kind: python_call_eq
  function: OrderedDict
  args: [[["a", 1], ["b", 2]]]
  method: __contains__
  method_args: ["a"]
  expected: true

invariant collections_ordereddict.access.not_contains_z:
  description: "'z' in OrderedDict([('a',1),('b',2)]) == False"
  category: access
  kind: python_call_eq
  function: OrderedDict
  args: [[["a", 1], ["b", 2]]]
  method: __contains__
  method_args: ["z"]
  expected: false

# ---------------------------------------------------------------------------
# get() with default — inherited from dict but important OrderedDict behaviour
# ---------------------------------------------------------------------------

invariant collections_ordereddict.access.get_existing:
  description: "OrderedDict([('a',1)]).get('a', 99) == 1"
  category: access
  kind: python_call_eq
  function: OrderedDict
  args: [[["a", 1]]]
  method: get
  method_args: ["a", 99]
  expected: 1

invariant collections_ordereddict.access.get_missing_default:
  description: "OrderedDict([('a',1)]).get('z', 99) == 99 — missing key returns default"
  category: access
  kind: python_call_eq
  function: OrderedDict
  args: [[["a", 1]]]
  method: get
  method_args: ["z", 99]
  expected: 99

# ---------------------------------------------------------------------------
# keys() — ordered key sequence
# ---------------------------------------------------------------------------

invariant collections_ordereddict.keys.len:
  description: "len(list(OrderedDict([('x',10),('y',20)]).keys())) == 2"
  category: keys
  kind: python_call_eq
  function: OrderedDict
  args: [[["x", 10], ["y", 20]]]
  method: __len__
  expected: 2

