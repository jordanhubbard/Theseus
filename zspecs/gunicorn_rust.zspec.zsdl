spec: gunicorn_rust
version: ">=3.9"
backend: rust_module(gunicorn_rust)

docs: https://docs.gunicorn.org/en/stable/

provenance:
  derived_from:
    - "https://docs.gunicorn.org/en/stable/ — Gunicorn documentation"
  not_derived_from:
    - "gunicorn source: gunicorn/__init__.py"
  notes:
    - "Gunicorn is a Python WSGI HTTP server."
    - "gunicorn.__version__ is a non-empty string."
    - "gunicorn.config.Config is available."
    - "gunicorn.config.Config().workers == 1 — default."
    - "gunicorn.config.Config().bind == ['127.0.0.1:8000'] — default."
    - "Expose gunicorn_version_nonempty() -> bool: len(gunicorn.__version__) > 0."
    - "Expose gunicorn_has_config() -> bool: hasattr(gunicorn, 'config')."
    - "Expose gunicorn_default_workers() -> int: gunicorn.config.Config().workers."
    - "All test vectors verified against gunicorn 23.0.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# gunicorn_version_nonempty — version non-empty
invariant gunicorn_rust.version.nonempty:
  description: "gunicorn.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: gunicorn_version_nonempty
  args: []
  expected: true

# gunicorn_has_config — config module present
invariant gunicorn_rust.module.has_config:
  description: "gunicorn.config is available"
  category: module
  kind: python_call_eq
  function: gunicorn_has_config
  args: []
  expected: true

# gunicorn_default_workers — default workers == 1
invariant gunicorn_rust.config.default_workers:
  description: "gunicorn.config.Config().workers == 1"
  category: config
  kind: python_call_eq
  function: gunicorn_default_workers
  args: []
  expected: 1

