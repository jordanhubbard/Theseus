spec: pathlib_extra1666
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath component access and predicates"
    - "pathlib_extra.zspec.zsdl — covers Path/PurePosixPath class metadata, parent, parts, suffix, division"
    - "pathlib_pure.zspec.zsdl — covers class names, module, hierarchy, match, drive, anchor"
  notes:
    - "Theme: __new__ object construction protocol — which pathlib classes define custom __new__."
    - "In Python 3.12+, PurePath defines its own __new__ to assemble the path from *args into _raw_paths and resolve the flavour (posix vs windows). This replaced the old class-dispatch mechanism."
    - "PurePath also defines __init__ to validate and normalise the raw path segments (accept str or PurePath objects)."
    - "Path defines its own __new__ (delegates to PosixPath or WindowsPath depending on platform) but does NOT define __init__; it inherits PurePath.__init__."
    - "PurePosixPath, PureWindowsPath, PosixPath, and WindowsPath define neither __new__ nor __init__ in their own __dict__; they rely on PurePath.__new__ and PurePath.__init__ from the MRO."
    - "PurePath.__new__ is a Python function (not a builtin); Path.__new__ is also a Python function."
    - "PurePath uses __slots__ to avoid per-instance __dict__ overhead: _raw_paths, _drv, _root, _tail_cached, _str, etc."
    - "PurePosixPath.__bases__[0].__name__ == 'PurePath' — direct base class."
    - "PosixPath.__bases__[0].__name__ == 'Path' — concrete posix subclass inherits from Path."
    - "All expected values verified by running Python 3.14.4 pathlib on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table pathlib_extra1666.purepath_new_init
# PurePath defines both __new__ and __init__ in its own __dict__.
# Subclasses PurePosixPath and PureWindowsPath inherit both without override.
# ---------------------------------------------------------------------------

table pathlib_extra1666.purepath_new_init:
  kind: python_call_eq
  category: construction_protocol
  id_prefix: pl1666

  columns: [id, function, args, expected]
  rows:
    - ["pl1666.PurePath.has_new",             PurePath.__dict__.__contains__,        ["__new__"],   true  ]
    - ["pl1666.PurePath.has_init",            PurePath.__dict__.__contains__,        ["__init__"],  true  ]
    - ["pl1666.PurePath.has_slots",           PurePath.__dict__.__contains__,        ["__slots__"], true  ]
    - ["pl1666.PurePath.new_is_function",     PurePath.__new__.__class__.__name__.__eq__, ["function"], true ]
    - ["pl1666.PurePath.name",                PurePath.__name__.__eq__,              ["PurePath"],  true  ]
    - ["pl1666.PurePath.module",              PurePath.__module__.__eq__,            ["pathlib"],   true  ]
    - ["pl1666.PurePosixPath.has_new",        PurePosixPath.__dict__.__contains__,   ["__new__"],   false ]
    - ["pl1666.PurePosixPath.has_init",       PurePosixPath.__dict__.__contains__,   ["__init__"],  false ]
    - ["pl1666.PureWindowsPath.has_new",      PureWindowsPath.__dict__.__contains__, ["__new__"],   false ]
    - ["pl1666.PureWindowsPath.has_init",     PureWindowsPath.__dict__.__contains__, ["__init__"],  false ]

# ---------------------------------------------------------------------------
# PurePath base class — PurePosixPath and PureWindowsPath have PurePath as direct base
# ---------------------------------------------------------------------------

invariant pathlib_extra1666.PurePosixPath.base_is_PurePath:
  description: "PurePosixPath.__bases__[0].__name__ == 'PurePath'"
  category: hierarchy
  kind: python_call_eq
  function: PurePosixPath.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "PurePath"

invariant pathlib_extra1666.PureWindowsPath.base_is_PurePath:
  description: "PureWindowsPath.__bases__[0].__name__ == 'PurePath'"
  category: hierarchy
  kind: python_call_eq
  function: PureWindowsPath.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "PurePath"

# ---------------------------------------------------------------------------
# Table pathlib_extra1666.path_new_init
# Path defines its own __new__ for platform dispatch (posix vs windows)
# but inherits __init__ from PurePath without overriding it.
# ---------------------------------------------------------------------------

table pathlib_extra1666.path_new_init:
  kind: python_call_eq
  category: construction_protocol
  id_prefix: pl1666

  columns: [id, function, args, expected]
  rows:
    - ["pl1666.Path.has_new",         Path.__dict__.__contains__,   ["__new__"],  true  ]
    - ["pl1666.Path.has_init",        Path.__dict__.__contains__,   ["__init__"], false ]
    - ["pl1666.Path.new_is_function", Path.__new__.__class__.__name__.__eq__, ["function"], true ]
    - ["pl1666.Path.name",            Path.__name__.__eq__,         ["Path"],     true  ]
    - ["pl1666.Path.module",          Path.__module__.__eq__,       ["pathlib"],  true  ]

invariant pathlib_extra1666.Path.base_is_PurePath:
  description: "Path.__bases__[0].__name__ == 'PurePath'"
  category: hierarchy
  kind: python_call_eq
  function: Path.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "PurePath"

# ---------------------------------------------------------------------------
# Table pathlib_extra1666.subpath_new_init
# Concrete platform subclasses (PosixPath, WindowsPath) do not define __new__
# or __init__ in their own __dict__; they inherit from Path and PurePath.
# ---------------------------------------------------------------------------

table pathlib_extra1666.subpath_new_init:
  kind: python_call_eq
  category: construction_protocol
  id_prefix: pl1666

  columns: [id, function, args, expected]
  rows:
    - ["pl1666.PosixPath.has_new",       PosixPath.__dict__.__contains__,    ["__new__"],       false ]
    - ["pl1666.PosixPath.has_init",      PosixPath.__dict__.__contains__,    ["__init__"],      false ]
    - ["pl1666.WindowsPath.has_new",     WindowsPath.__dict__.__contains__,  ["__new__"],       false ]
    - ["pl1666.WindowsPath.has_init",    WindowsPath.__dict__.__contains__,  ["__init__"],      false ]
    - ["pl1666.PosixPath.name",          PosixPath.__name__.__eq__,          ["PosixPath"],     true  ]
    - ["pl1666.WindowsPath.name",        WindowsPath.__name__.__eq__,        ["WindowsPath"],   true  ]
    - ["pl1666.PurePosixPath.name",      PurePosixPath.__name__.__eq__,      ["PurePosixPath"], true  ]
    - ["pl1666.PureWindowsPath.name",    PureWindowsPath.__name__.__eq__,    ["PureWindowsPath"], true ]

invariant pathlib_extra1666.PosixPath.base_is_Path:
  description: "PosixPath.__bases__[0].__name__ == 'Path'"
  category: hierarchy
  kind: python_call_eq
  function: PosixPath.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Path"

invariant pathlib_extra1666.WindowsPath.base_is_Path:
  description: "WindowsPath.__bases__[0].__name__ == 'Path'"
  category: hierarchy
  kind: python_call_eq
  function: WindowsPath.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Path"
