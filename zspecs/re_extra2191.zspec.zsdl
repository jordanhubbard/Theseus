spec: re_extra2191
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2191: context manager protocol dict-presence checks — __enter__, __exit__, __aenter__, __aexit__, acquire, release, __wrapped__, __closure__."
    - "re.Pattern and re.Match are C-extension types; neither defines any context manager or lock protocol method in its own __dict__."
    - "re.error is a Python exception class; its __dict__ does not contain any context manager or lock protocol methods."
    - "re.RegexFlag is an IntFlag enum; its __dict__ does not contain any context manager or lock protocol methods."
    - "re._compile_template is an lru_cache-wrapped function; its instance __dict__ DOES contain __wrapped__ (set by functools.lru_cache) but does NOT contain __closure__ (lru_cache wrappers are C objects, not Python functions)."
    - "Regular re module functions (compile, search, match, etc.) are Python functions; their instance __dict__ does NOT contain __wrapped__ or __closure__ (those are type-level descriptors on the function type, not instance dict entries)."
    - "None of the re classes or functions define __enter__, __exit__, __aenter__, __aexit__, acquire, or release."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table re_extra2191.pattern_context_protocol:
  description: "re.Pattern dict-presence checks for context manager and lock protocol keys"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2191

  columns: [id, function, args, expected]
  rows:
    - ["re2191001", "re.Pattern.__dict__.__contains__", ["__enter__"], false]
    - ["re2191002", "re.Pattern.__dict__.__contains__", ["__exit__"], false]
    - ["re2191003", "re.Pattern.__dict__.__contains__", ["__aenter__"], false]
    - ["re2191004", "re.Pattern.__dict__.__contains__", ["__aexit__"], false]
    - ["re2191005", "re.Pattern.__dict__.__contains__", ["acquire"], false]
    - ["re2191006", "re.Pattern.__dict__.__contains__", ["release"], false]
    - ["re2191007", "re.Pattern.__dict__.__contains__", ["__wrapped__"], false]
    - ["re2191008", "re.Pattern.__dict__.__contains__", ["__closure__"], false]

