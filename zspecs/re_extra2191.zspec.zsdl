table re_extra2191.compile_template_wrapper:
  description: "re._compile_template instance dict-presence checks — lru_cache wrapper stores __wrapped__ in instance __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2191

  columns: [id, function, args, expected]
  rows:
    - ["re2191033", "re._compile_template.__dict__.__contains__", ["__wrapped__"], true]
    - ["re2191034", "re._compile_template.__dict__.__contains__", ["__closure__"], false]
    - ["re2191035", "re._compile_template.__dict__.__contains__", ["__enter__"], false]
    - ["re2191036", "re._compile_template.__dict__.__contains__", ["__exit__"], false]
    - ["re2191037", "re._compile_template.__dict__.__contains__", ["__aenter__"], false]
    - ["re2191038", "re._compile_template.__dict__.__contains__", ["__aexit__"], false]
    - ["re2191039", "re._compile_template.__dict__.__contains__", ["acquire"], false]
    - ["re2191040", "re._compile_template.__dict__.__contains__", ["release"], false]
