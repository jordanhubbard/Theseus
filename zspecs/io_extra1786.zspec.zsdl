spec: io_extra1786
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE, SEEK_* types, TextIOWrapper/BufferedRandom/UnsupportedOperation class names"
    - "io_extra1771.zspec.zsdl — covers async protocol and SEEK_* constant values"
  notes:
    - "Wave 566, theme: __class_getitem__ and __init_subclass__ class creation hooks."
    - "All io types (IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, TextIOWrapper) return False for both hooks."
    - "io types are C extension types defined in _io; they do not define __class_getitem__ (no generic subscript syntax) nor __init_subclass__."
    - "Complementary rows: BytesIO defines read, write, close, seek, tell directly in its own __dict__; IOBase does NOT define any of those."
    - "All expected values verified by running Python 3.14 io module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Wave 566 theme: __class_getitem__ — absent from all io types
# io types are C extension types; none support generic subscript syntax
# ---------------------------------------------------------------------------

table io_extra1786.class_getitem:
  description: "__class_getitem__ absent from all io type __dict__ — C extension types do not define it"
  kind: python_call_eq
  category: class_creation_hooks
  id_prefix: io1786

  columns: [id, function, args, expected]
  rows:
    - ["io1786001", io.IOBase.__dict__.__contains__,        ["__class_getitem__"], false]
    - ["io1786002", io.RawIOBase.__dict__.__contains__,     ["__class_getitem__"], false]
    - ["io1786003", io.BufferedIOBase.__dict__.__contains__, ["__class_getitem__"], false]
    - ["io1786004", io.TextIOBase.__dict__.__contains__,    ["__class_getitem__"], false]
    - ["io1786005", io.BytesIO.__dict__.__contains__,       ["__class_getitem__"], false]
    - ["io1786006", io.StringIO.__dict__.__contains__,      ["__class_getitem__"], false]
    - ["io1786007", io.FileIO.__dict__.__contains__,        ["__class_getitem__"], false]
    - ["io1786008", io.BufferedReader.__dict__.__contains__, ["__class_getitem__"], false]
    - ["io1786009", io.BufferedWriter.__dict__.__contains__, ["__class_getitem__"], false]
    - ["io1786010", io.TextIOWrapper.__dict__.__contains__, ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Wave 566 theme: __init_subclass__ — absent from all io types
# ---------------------------------------------------------------------------

table io_extra1786.init_subclass:
  description: "__init_subclass__ absent from all io type __dict__ — inherited from object, not overridden"
  kind: python_call_eq
  category: class_creation_hooks
  id_prefix: io1786

  columns: [id, function, args, expected]
  rows:
    - ["io1786011", io.IOBase.__dict__.__contains__,        ["__init_subclass__"], false]
    - ["io1786012", io.RawIOBase.__dict__.__contains__,     ["__init_subclass__"], false]
    - ["io1786013", io.BufferedIOBase.__dict__.__contains__, ["__init_subclass__"], false]
    - ["io1786014", io.TextIOBase.__dict__.__contains__,    ["__init_subclass__"], false]
    - ["io1786015", io.BytesIO.__dict__.__contains__,       ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Complementary: BytesIO defines core IO methods directly in its own __dict__
# BytesIO is a concrete leaf type; read/write/seek/tell/close are all defined on it
# ---------------------------------------------------------------------------

table io_extra1786.bytesio_dict_methods:
  description: "BytesIO defines read, write, seek, tell, close directly in its own __dict__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: io1786

  columns: [id, function, args, expected]
  rows:
    - ["io1786016", io.BytesIO.__dict__.__contains__, ["read"],  true]
    - ["io1786017", io.BytesIO.__dict__.__contains__, ["write"], true]
    - ["io1786018", io.BytesIO.__dict__.__contains__, ["seek"],  true]
    - ["io1786019", io.BytesIO.__dict__.__contains__, ["tell"],  true]
    - ["io1786020", io.BytesIO.__dict__.__contains__, ["close"], true]

# ---------------------------------------------------------------------------
# Complementary: IOBase does NOT define read, write, seek, tell, close in __dict__
# These are abstract or inherited and not defined on the base class itself
# ---------------------------------------------------------------------------

table io_extra1786.iobase_absent_methods:
  description: "IOBase does NOT define read, write, seek, tell, close in its own __dict__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: io1786

  columns: [id, function, args, expected]
  rows:
    - ["io1786021", io.IOBase.__dict__.__contains__, ["read"],  false]
    - ["io1786022", io.IOBase.__dict__.__contains__, ["write"], false]
    - ["io1786023", io.IOBase.__dict__.__contains__, ["seek"],  false]
    - ["io1786024", io.IOBase.__dict__.__contains__, ["tell"],  false]
    - ["io1786025", io.IOBase.__dict__.__contains__, ["close"], false]
