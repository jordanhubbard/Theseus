spec: in3151
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 657 (in3151): __setitem__, __delitem__, __contains__ dict-presence checks for inspect types."
    - "No inspect type defines __setitem__, __delitem__, or __contains__ in its own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "None of these types implement mapping or container protocols directly."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3151.setitem:
  description: "inspect types __setitem__ dict-presence checks; wave 657"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in3151
  columns: [id, function, args, expected]
  rows:
    - ["in3151001", operator.contains, [inspect.Parameter.__dict__,           "__setitem__"], false]
    - ["in3151002", operator.contains, [inspect.Signature.__dict__,           "__setitem__"], false]
    - ["in3151003", operator.contains, [inspect.BoundArguments.__dict__,      "__setitem__"], false]
    - ["in3151004", operator.contains, [inspect.FrameInfo.__dict__,           "__setitem__"], false]
    - ["in3151005", operator.contains, [inspect.ArgInfo.__dict__,             "__setitem__"], false]
    - ["in3151006", operator.contains, [inspect.FullArgSpec.__dict__,         "__setitem__"], false]
    - ["in3151007", operator.contains, [inspect.Attribute.__dict__,           "__setitem__"], false]
    - ["in3151008", operator.contains, [inspect.ClassFoundException.__dict__, "__setitem__"], false]
    - ["in3151009", operator.contains, [inspect.EndOfBlock.__dict__,          "__setitem__"], false]

