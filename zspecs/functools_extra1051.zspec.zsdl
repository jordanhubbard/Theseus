spec: functools_extra1051
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks functools error conditions, reduce behavior, singledispatch and wraps introspection"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1051.error_conditions:
  description: "functools error conditions that must raise"
  kind: python_call_raises
  category: error_conditions
  id_prefix: ft1051x
  columns: [id, function, args, expected]
  rows:
    - [ft1051x001, functools.total_ordering,                      ["class MissingEq: pass"],        ValueError]
    - [ft1051x002, functools.lru_cache,                           [{"maxsize": -2}],                ValueError]
    - [ft1051x003, functools.reduce,                              [[], null],                       TypeError]
    - [ft1051x004, functools.partial.__call__,                    [42],                             TypeError]
    - [ft1051x005, functools.reduce,                              [null, [1, 2, 3]],                TypeError]
    - [ft1051x006, functools.lru_cache,                           [{"maxsize": -100}],              ValueError]

table functools_extra1051.reduce_behavior:
  description: "functools.reduce correct computation results"
  kind: python_call_eq
  category: reduce_behavior
  id_prefix: ft1051r
  columns: [id, function, args, expected]
  rows:
    - [ft1051r001, functools.reduce.__call__.__qualname__.__eq__, ["reduce.__call__"],              true]
    - [ft1051r002, functools.reduce.__module__.__eq__,            ["functools"],                    true]
    - [ft1051r003, functools.reduce.__class__.__name__.__eq__,    ["builtin_function_or_method"],   true]

table functools_extra1051.singledispatch_introspection:
  description: "functools.singledispatch and wraps attribute introspection"
  kind: python_call_eq
  category: singledispatch_introspection
  id_prefix: ft1051s
  columns: [id, function, args, expected]
  rows:
    - [ft1051s001, functools.singledispatch.__class__.__name__.__eq__,      ["function"],           true]
    - [ft1051s002, functools.singledispatch.__module__.__eq__,              ["functools"],          true]
    - [ft1051s003, functools.singledispatch.__qualname__.__eq__,            ["singledispatch"],     true]
    - [ft1051s004, functools.wraps.__class__.__name__.__eq__,               ["function"],           true]
    - [ft1051s005, functools.wraps.__module__.__eq__,                       ["functools"],          true]
    - [ft1051s006, functools.wraps.__qualname__.__eq__,                     ["wraps"],              true]
    - [ft1051s007, functools.lru_cache.__class__.__name__.__eq__,           ["function"],           true]
    - [ft1051s008, functools.lru_cache.__module__.__eq__,                   ["functools"],          true]
    - [ft1051s009, functools.partial.__class__.__name__.__eq__,             ["type"],               true]
    - [ft1051s010, functools.partial.__module__.__eq__,                     ["functools"],          true]
