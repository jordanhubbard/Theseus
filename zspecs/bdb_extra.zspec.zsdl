spec: bdb_extra
version: ">=3.9"
backend: python_module(bdb)

docs: https://docs.python.org/3/library/bdb.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bdb.html — Python bdb module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bdb.py"
  notes:
    - "Extends bdb.zspec.zsdl with additional class name, module, hierarchy, and method invariants."
    - "bdb.Bdb.__name__ == 'Bdb' and __module__ == 'bdb' — the base debugger class."
    - "bdb.Breakpoint.__name__ == 'Breakpoint' and __module__ == 'bdb' — breakpoint descriptor class."
    - "bdb.BdbQuit.__name__ == 'BdbQuit' and __bases__[0].__name__ == 'Exception'."
    - "bdb.Bdb.set_trace is the primary entry point for starting tracing; its __name__ == 'set_trace'."
    - "bdb.Bdb.set_next, set_step, set_return are execution-control hooks on Bdb."
    - "bdb.Breakpoint.__module__ == 'bdb' — confirmed by introspection on Python 3.12."
    - "bdb.BdbQuit.__module__ == 'bdb' — the quit exception is defined in bdb."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Bdb — class name and module affiliation
# ---------------------------------------------------------------------------

invariant bdb_extra.Bdb.name:
  description: "bdb.Bdb.__name__ == 'Bdb'"
  category: class_names
  kind: python_call_eq
  function: Bdb.__name__.__eq__
  args: ["Bdb"]
  expected: true

invariant bdb_extra.Bdb.module:
  description: "bdb.Bdb.__module__ == 'bdb'"
  category: class_modules
  kind: python_call_eq
  function: Bdb.__module__.__eq__
  args: ["bdb"]
  expected: true

# ---------------------------------------------------------------------------
# Breakpoint — class name and module affiliation
# ---------------------------------------------------------------------------

invariant bdb_extra.Breakpoint.name:
  description: "bdb.Breakpoint.__name__ == 'Breakpoint'"
  category: class_names
  kind: python_call_eq
  function: Breakpoint.__name__.__eq__
  args: ["Breakpoint"]
  expected: true

invariant bdb_extra.Breakpoint.module:
  description: "bdb.Breakpoint.__module__ == 'bdb'"
  category: class_modules
  kind: python_call_eq
  function: Breakpoint.__module__.__eq__
  args: ["bdb"]
  expected: true

# ---------------------------------------------------------------------------
# BdbQuit — class name, module, and inheritance hierarchy
# ---------------------------------------------------------------------------

invariant bdb_extra.BdbQuit.name:
  description: "bdb.BdbQuit.__name__ == 'BdbQuit'"
  category: class_names
  kind: python_call_eq
  function: BdbQuit.__name__.__eq__
  args: ["BdbQuit"]
  expected: true

invariant bdb_extra.BdbQuit.module:
  description: "bdb.BdbQuit.__module__ == 'bdb'"
  category: class_modules
  kind: python_call_eq
  function: BdbQuit.__module__.__eq__
  args: ["bdb"]
  expected: true

invariant bdb_extra.BdbQuit.base_is_Exception:
  description: "bdb.BdbQuit.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: BdbQuit.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

invariant bdb_extra.BdbQuit.bases_len:
  description: "len(bdb.BdbQuit.__bases__) == 1 — BdbQuit has exactly one direct base"
  category: class_hierarchy
  kind: python_call_eq
  function: BdbQuit.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Bdb method names — execution control and tracing hooks
# ---------------------------------------------------------------------------

invariant bdb_extra.Bdb.set_trace_name:
  description: "bdb.Bdb.set_trace.__name__ == 'set_trace'"
  category: methods
  kind: python_call_eq
  function: Bdb.set_trace.__name__.__eq__
  args: ["set_trace"]
  expected: true

invariant bdb_extra.Bdb.set_step_name:
  description: "bdb.Bdb.set_step.__name__ == 'set_step'"
  category: methods
  kind: python_call_eq
  function: Bdb.set_step.__name__.__eq__
  args: ["set_step"]
  expected: true

invariant bdb_extra.Bdb.set_next_name:
  description: "bdb.Bdb.set_next.__name__ == 'set_next'"
  category: methods
  kind: python_call_eq
  function: Bdb.set_next.__name__.__eq__
  args: ["set_next"]
  expected: true

invariant bdb_extra.Bdb.set_return_name:
  description: "bdb.Bdb.set_return.__name__ == 'set_return'"
  category: methods
  kind: python_call_eq
  function: Bdb.set_return.__name__.__eq__
  args: ["set_return"]
  expected: true

invariant bdb_extra.Bdb.set_quit_name:
  description: "bdb.Bdb.set_quit.__name__ == 'set_quit'"
  category: methods
  kind: python_call_eq
  function: Bdb.set_quit.__name__.__eq__
  args: ["set_quit"]
  expected: true

invariant bdb_extra.Bdb.set_break_name:
  description: "bdb.Bdb.set_break.__name__ == 'set_break'"
  category: methods
  kind: python_call_eq
  function: Bdb.set_break.__name__.__eq__
  args: ["set_break"]
  expected: true

invariant bdb_extra.Bdb.run_name:
  description: "bdb.Bdb.run.__name__ == 'run'"
  category: methods
  kind: python_call_eq
  function: Bdb.run.__name__.__eq__
  args: ["run"]
  expected: true

# ---------------------------------------------------------------------------
# Bdb method name table — compact form for remaining execution hooks
# ---------------------------------------------------------------------------

table bdb_extra.bdb_method_names:
  kind: python_call_eq
  category: methods
  id_prefix: method
  columns: [id, function, args, expected]
  rows:
    - [runcall,      Bdb.runcall.__name__.__eq__,      ["runcall"],      true]
    - [runeval,      Bdb.runeval.__name__.__eq__,      ["runeval"],      true]
    - [set_continue, Bdb.set_continue.__name__.__eq__, ["set_continue"], true]
    - [clear_break,  Bdb.clear_break.__name__.__eq__,  ["clear_break"],  true]
