spec: uuid_extra36
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra35.zspec.zsdl — covers UUID.__init__/__repr__/__hash__/__eq__/__int__/__lt__/__le__/__gt__/__ge__ __name__.__eq__ string values (bare unqualified name axis)."
    - "uuid_extra34.zspec.zsdl — covers UUID.time/node/clock_seq/time_hi_version/clock_seq_hi_variant fget __qualname__.__eq__ string values."
    - "uuid_extra32.zspec.zsdl — covers UUID.__str__.__name__.__eq__('__str__') and UUID.__str__.__module__.__eq__('uuid')."
    - "uuid_extra21.zspec.zsdl — covers UUID.__init__.__module__.__len__()==4 (length only, NOT string eq value)."
    - "uuid_extra17.zspec.zsdl — covers UUID.__lt__/__le__/__gt__/__ge__ __qualname__.__eq__ and __qualname__.__len__() (qualname axis)."
    - "uuid_extra16.zspec.zsdl — covers UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__ __qualname__.__eq__ and __qualname__.__len__() (qualname axis)."
  notes:
    - "This spec extends uuid through uuid_extra35; it does NOT duplicate invariants present in those files."
    - "Coverage gap: uuid_extra32 covers UUID.__str__.__module__.__eq__('uuid') (__module__ axis for __str__). uuid_extra21 covers UUID.__init__.__module__.__len__()==4 (length only, NOT string eq). But NO prior spec checks UUID.__module__.__eq__('uuid') for any of: __repr__, __hash__, __eq__, __int__, __lt__, __le__, __gt__, __ge__. The __module__ attribute gives the module where the method is defined ('uuid' for all Python-defined UUID methods). These are distinct attribute chains from __name__ and __qualname__, providing independent regression vectors. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__module__ == 'uuid'. Python method defined in Lib/uuid.py; __module__ == 'uuid'. uuid_extra16 covers __qualname__.__eq__ and uuid_extra35 covers __name__.__eq__; no prior spec checks __module__.__eq__('uuid') for UUID.__repr__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__module__ == 'uuid'. UUID defines its own __hash__; __module__ == 'uuid'. No prior spec checks __module__.__eq__('uuid') for UUID.__hash__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__module__ == 'uuid'. No prior spec checks __module__.__eq__('uuid') for UUID.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__module__ == 'uuid'. No prior spec checks __module__.__eq__('uuid') for UUID.__int__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__module__ == 'uuid'. uuid_extra17 covers __qualname__.__eq__ and __qualname__.__len__() for __lt__; no prior spec checks __module__.__eq__('uuid') for UUID.__lt__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__module__ == 'uuid'. Same as __lt__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__gt__.__module__ == 'uuid'. Same as __lt__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ge__.__module__ == 'uuid'. Same as __lt__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID dunder method __module__.__eq__ string values
#
# uuid_extra32 covers UUID.__str__.__module__.__eq__('uuid') (__module__ axis for __str__).
# uuid_extra21 covers UUID.__init__.__module__.__len__()==4 (length only, NOT string eq).
# No prior spec checks __module__.__eq__('uuid') for any of:
#   UUID.__repr__, UUID.__hash__, UUID.__eq__, UUID.__int__,
#   UUID.__lt__, UUID.__le__, UUID.__gt__, UUID.__ge__.
# All these methods are Python-defined in Lib/uuid.py, so __module__ == 'uuid'.
# The __module__ attribute is a distinct axis from __name__ (extra35) and
# __qualname__ (extra16/extra17), providing independent regression vectors.
# ---------------------------------------------------------------------------

table uuid_extra36.UUID_dunder_module_eq:
  description: "uuid.UUID dunder method __module__.__eq__('uuid') string values — novel: extra32 covers UUID.__str__.__module__.__eq__; extra21 covers UUID.__init__.__module__.__len__ only; no prior spec checks __module__.__eq__('uuid') for UUID.__repr__/__hash__/__eq__/__int__/__lt__/__le__/__gt__/__ge__"
  kind: python_call_eq
  category: function_module
  id_prefix: udme36

  columns: [id, function, args, expected]
  rows:
    - [repr_module_eq, "UUID.__repr__.__module__.__eq__", ["uuid"], true]
    - [hash_module_eq, "UUID.__hash__.__module__.__eq__", ["uuid"], true]
    - [eq_module_eq,   "UUID.__eq__.__module__.__eq__",   ["uuid"], true]
    - [int_module_eq,  "UUID.__int__.__module__.__eq__",  ["uuid"], true]
    - [lt_module_eq,   "UUID.__lt__.__module__.__eq__",   ["uuid"], true]
    - [le_module_eq,   "UUID.__le__.__module__.__eq__",   ["uuid"], true]
    - [gt_module_eq,   "UUID.__gt__.__module__.__eq__",   ["uuid"], true]
    - [ge_module_eq,   "UUID.__ge__.__module__.__eq__",   ["uuid"], true]
