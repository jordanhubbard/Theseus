spec: concurrent_futures_extra77
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra76.zspec.zsdl."
    - "This spec covers: wave 244 theme — concurrent.futures exception __qualname__ lengths and InvalidStateError hierarchy. NEW in extra77: CancelledError.__qualname__=='CancelledError'; CancelledError.__qualname__.__len__()==14; TimeoutError.__qualname__.__len__()==12; BrokenExecutor.__qualname__.__len__()==14; InvalidStateError.__qualname__.__len__()==17; InvalidStateError.__bases__[0].__name__=='Error'; InvalidStateError.__mro__.__len__()==5 (MRO: InvalidStateError, Error, Exception, BaseException, object); ThreadPoolExecutor.__qualname__=='ThreadPoolExecutor'; ThreadPoolExecutor.__qualname__.__len__()==18; ProcessPoolExecutor.__qualname__.__len__()==19. BrokenThreadPool and BrokenProcessPool do NOT exist in concurrent.futures on Python 3.14.3. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.CancelledError.__qualname__ == 'CancelledError'. CancelledError is a simple top-level exception class. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.CancelledError.__qualname__.__len__() == 14. len('CancelledError') == 14. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.TimeoutError.__qualname__.__len__() == 12. len('TimeoutError') == 12. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__qualname__.__len__() == 14. len('BrokenExecutor') == 14. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__qualname__.__len__() == 17. len('InvalidStateError') == 17. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__bases__[0].__name__ == 'Error'. InvalidStateError extends Error (not Exception directly). MRO is [InvalidStateError, Error, Exception, BaseException, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__mro__.__len__() == 5. MRO is [InvalidStateError, Error, Exception, BaseException, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor'. len==18. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__() == 19. len('ProcessPoolExecutor') == 19. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures CancelledError and TimeoutError qualname lengths — extra77
#
# Wave 244 theme: exception __qualname__ lengths and InvalidStateError hierarchy.
#
# CancelledError.__qualname__ == 'CancelledError'
# CancelledError.__qualname__.__len__() == 14
# TimeoutError.__qualname__.__len__() == 12
# ---------------------------------------------------------------------------

table concurrent_futures_extra77.CancelledError_and_TimeoutError_qualnames:
  description: "concurrent.futures CancelledError and TimeoutError __qualname__ checks in cfextra77 namespace — wave 244 theme: exception __qualname__ lengths; CancelledError.__qualname__=='CancelledError'; CancelledError.__qualname__.__len__()==14 (len('CancelledError')==14); TimeoutError.__qualname__.__len__()==12 (len('TimeoutError')==12); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfextra77

  columns: [id, function, args, expected, description]
  rows:
    - [cancelled_qualname,     CancelledError.__qualname__.__eq__,     ["CancelledError"], true, "CancelledError.__qualname__ == 'CancelledError' — simple top-level exception class; verified with Python 3.14.3"]
    - [cancelled_qualname_len, CancelledError.__qualname__.__len__,    [],                 14,   "CancelledError.__qualname__.__len__() == 14 — len('CancelledError') == 14; verified with Python 3.14.3"]
    - [timeout_qualname_len,   TimeoutError.__qualname__.__len__,      [],                 12,   "TimeoutError.__qualname__.__len__() == 12 — len('TimeoutError') == 12; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
