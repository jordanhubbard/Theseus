spec: uuid_extra107
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra106.zspec.zsdl — covers uuid module-level function __name__ equality / uuid function co_argcount grouping (0 vs 2) / uuid function qualname and getnode identity (table + invariants)."
    - "uuid_extra105.zspec.zsdl — covers UUID.__le__/__gt__/__ge__ qualname equality / UUID.__int__ qualname / UUID method co_argcount grouping / comparison operator type identity (table + invariants)."
    - "uuid_extra104.zspec.zsdl — covers UUID class __name__/__module__/__qualname__ equality and lengths / UUID property fget qualname lengths / uuid.getnode identity and NAMESPACE str lengths (table + invariants)."
    - "uuid_extra103.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __module__ equality / uuid module __name__/__package__/__spec__ identity / UUID.__new__ qualname 'object.__new__' (table + invariants)."
    - "uuid_extra102.zspec.zsdl — covers UUID.variant property vs UUID.is_safe member_descriptor / UUID.__reduce__/__hash__/__str__ type and qualname / UUID comparison method qualnames (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__str__/__repr__ qualname equality and lengths / UUID.__eq__/__hash__/__lt__ qualname equality and lengths / UUID.__init__ code attributes (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality / type(UUID.hex).__name__=='property' (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name / UUID.__module__/__class__/__qualname__ equality and length (table + invariants)."
    - "uuid_extra95.zspec.zsdl — covers UUID property fget.__qualname__.__len__() values / SafeUUID name/qualname/bases (table + invariants)."
    - "uuid_extra92.zspec.zsdl — covers UUID property fget.__code__.co_name equality and co_argcount==1 (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra106; it does NOT duplicate invariants present in those files."
    - "Wave 275 theme: UUID property descriptor fget __name__ equality not yet covered / fget __module__ equality not yet covered / fget type identity (__class__.__name__=='function') not yet covered as a grouped table — uuid_extra97 anchors fget.__qualname__ equality; no prior spec anchors fget.__name__ or fget.__module__ as a grouped table."
    - "uuid.UUID.bytes_le.fget.__name__ == 'bytes_le'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__name__ == 'fields'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__name__ == 'time'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq_hi_variant.fget.__name__ == 'clock_seq_hi_variant'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.fget.__name__ == 'node'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le.fget.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq_hi_variant.fget.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.fget.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le.fget.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq_hi_variant.fget.__name__.__len__() == 20. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.fget.__name__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: UUID property fget functions are ordinary Python functions (class name 'function') defined in Lib/uuid.py using the @property decorator. Their __qualname__ is 'UUID.<name>' (anchored in uuid_extra97). Their __name__ is just '<name>' (the bare property name, without the 'UUID.' prefix). Their __module__ is 'uuid'. This spec anchors fget.__name__ equality and fget.__module__ equality as new angles on UUID property identity."
    - "Note: fget.__name__ differs from fget.__qualname__ in that __name__ is the bare function name ('bytes_le', 'fields', 'time', etc.) while __qualname__ includes the class prefix ('UUID.bytes_le', 'UUID.fields', 'UUID.time', etc.). For top-level module functions __name__==__qualname__, but for methods defined inside a class, __qualname__ adds the class prefix. uuid_extra97 anchors __qualname__; this spec anchors __name__ for the first time."
    - "Note: clock_seq_hi_variant is the longest UUID property name at 20 chars. uuid_extra97 anchors its fget qualname length at 25 ('UUID.clock_seq_hi_variant'); this spec anchors the bare __name__ length at 20. node and time are the shortest at 4 chars each."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.bytes_le.fget.__name__.__eq__('bytes_le')
# uuid.UUID.fields.fget.__name__.__eq__('fields')
# uuid.UUID.time.fget.__name__.__eq__('time')
# uuid.UUID.clock_seq_hi_variant.fget.__name__.__eq__('clock_seq_hi_variant')
# uuid.UUID.node.fget.__name__.__eq__('node')
#
# Wave 275 theme: UUID property fget __name__ equality (bare function name).
#
# UUID property fget functions are Python functions with __name__ equal to the
# bare property name (no 'UUID.' prefix). uuid_extra97 anchors fget.__qualname__
# equality ('UUID.hex', 'UUID.bytes_le', etc.). This spec anchors fget.__name__
# equality for the first time: 'bytes_le' (8 chars), 'fields' (6 chars), 'time'
# (4 chars), 'clock_seq_hi_variant' (20 chars), 'node' (4 chars).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra107.UUID_property_fget_name_equality:
  description: "UUID.bytes_le.fget.__name__.__eq__('bytes_le')==True / UUID.fields.fget.__name__.__eq__('fields')==True / UUID.time.fget.__name__.__eq__('time')==True / UUID.clock_seq_hi_variant.fget.__name__.__eq__('clock_seq_hi_variant')==True / UUID.node.fget.__name__.__eq__('node')==True — fget.__name__ is the bare property name (no 'UUID.' prefix; contrasts with __qualname__ which has prefix); bytes_le=8 chars, fields=6, time=4, clock_seq_hi_variant=20, node=4; extra97 anchors __qualname__ equality; first uuidfget107 anchor for __name__ equality"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidfget107

  columns: [id, function, args, expected, description]
  rows:
    - [bytes_le_name_eq,  "UUID.bytes_le.fget.__name__.__eq__",            ["bytes_le"],            true, "UUID.bytes_le.fget.__name__ is 'bytes_le' (8 chars; bare name without 'UUID.' prefix; contrasts with __qualname__=='UUID.bytes_le')"]
    - [fields_name_eq,    "UUID.fields.fget.__name__.__eq__",              ["fields"],              true, "UUID.fields.fget.__name__ is 'fields' (6 chars; returns tuple of 6 integer components of the UUID)"]
    - [time_name_eq,      "UUID.time.fget.__name__.__eq__",                ["time"],                true, "UUID.time.fget.__name__ is 'time' (4 chars; returns 60-bit timestamp from uuid1; same length as 'node')"]
    - [cshv_name_eq,      "UUID.clock_seq_hi_variant.fget.__name__.__eq__",["clock_seq_hi_variant"],true, "UUID.clock_seq_hi_variant.fget.__name__ is 'clock_seq_hi_variant' (20 chars; longest UUID property name; RFC 4122 field)"]
    - [node_name_eq,      "UUID.node.fget.__name__.__eq__",                ["node"],                true, "UUID.node.fget.__name__ is 'node' (4 chars; 48-bit hardware address; same length as 'time')"]

# ---------------------------------------------------------------------------
# uuid.UUID.bytes_le.fget.__module__.__eq__('uuid')
# uuid.UUID.fields.fget.__module__.__eq__('uuid')
# uuid.UUID.time.fget.__module__.__eq__('uuid')
# uuid.UUID.clock_seq_hi_variant.fget.__module__.__eq__('uuid')
# uuid.UUID.node.fget.__module__.__eq__('uuid')
#
# Wave 275 theme: UUID property fget __module__ equality.
#
# All UUID property fget functions have __module__ == 'uuid'. They are defined
# in Lib/uuid.py. uuid_extra97 anchors fget.__qualname__; uuid_extra92 anchors
# fget.__code__.co_name; uuid_extra104 anchors uuid function module equality.
# No prior uuid spec anchors fget.__module__ equality as a grouped table under
# uuidfget107. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra107.UUID_property_fget_module_equality:
  description: "UUID.bytes_le.fget.__module__.__eq__('uuid')==True / UUID.fields.fget.__module__.__eq__('uuid')==True / UUID.time.fget.__module__.__eq__('uuid')==True / UUID.clock_seq_hi_variant.fget.__module__.__eq__('uuid')==True / UUID.node.fget.__module__.__eq__('uuid')==True — all UUID property fget functions have __module__=='uuid' (4 chars; defined in Lib/uuid.py); extra97 anchors fget qualname; extra92 anchors fget co_name; no prior spec anchors fget __module__; first uuidfget107 anchor for fget module equality"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidfget107

  columns: [id, function, args, expected, description]
  rows:
    - [bytes_le_module_eq, "UUID.bytes_le.fget.__module__.__eq__",            ["uuid"], true, "UUID.bytes_le.fget.__module__ is 'uuid' (4 chars; defined in Lib/uuid.py; same module for all UUID property fgets)"]
    - [fields_module_eq,   "UUID.fields.fget.__module__.__eq__",              ["uuid"], true, "UUID.fields.fget.__module__ is 'uuid' (4 chars; returns 6-tuple of UUID integer fields)"]
    - [time_module_eq,     "UUID.time.fget.__module__.__eq__",                ["uuid"], true, "UUID.time.fget.__module__ is 'uuid' (4 chars; 60-bit timestamp for uuid1)"]
    - [cshv_module_eq,     "UUID.clock_seq_hi_variant.fget.__module__.__eq__",["uuid"], true, "UUID.clock_seq_hi_variant.fget.__module__ is 'uuid' (4 chars; RFC 4122 field; same module as all other fgets)"]
    - [node_module_eq,     "UUID.node.fget.__module__.__eq__",                ["uuid"], true, "UUID.node.fget.__module__ is 'uuid' (4 chars; 48-bit hardware address property)"]

# ---------------------------------------------------------------------------
# uuid.UUID.bytes_le.fget.__class__.__name__.__eq__('function')
# uuid.UUID.fields.fget.__class__.__name__.__eq__('function')
# uuid.UUID.time.fget.__class__.__name__.__eq__('function')
# uuid.UUID.clock_seq_hi_variant.fget.__name__.__len__() == 20
# uuid.UUID.node.fget.__name__.__len__() == 4
#
# Wave 275 theme: UUID property fget type identity and __name__ lengths.
#
# All UUID property fget functions are Python 'function' objects (not
# builtin_function_or_method or method_descriptor). type(fget).__name__ == 'function'.
# clock_seq_hi_variant is the longest UUID property name (20 chars bare, 25 chars
# as qualname). node and time are the shortest (4 chars each). uuid_extra95
# anchors some fget qualname lengths; uuid_extra97 anchors type(UUID.hex).__name__
# as 'property'. This spec anchors the fget function type identity as a group.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra107.UUID_property_fget_type_and_name_lens:
  description: "UUID.bytes_le.fget.__class__.__name__.__eq__('function')==True / UUID.fields.fget.__class__.__name__.__eq__('function')==True / UUID.time.fget.__class__.__name__.__eq__('function')==True / UUID.clock_seq_hi_variant.fget.__name__.__len__()==20 / UUID.node.fget.__name__.__len__()==4 — fget functions are Python 'function' type (not builtin_function_or_method); clock_seq_hi_variant is longest bare name at 20 chars; node and time are shortest at 4 chars each; extra97 anchors type(UUID.hex).__name__=='property' but not fget class; first uuidfget107 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidfget107

  columns: [id, function, args, expected, description]
  rows:
    - [bytes_le_fget_type, "UUID.bytes_le.fget.__class__.__name__.__eq__",            ["function"], true, "UUID.bytes_le.fget.__class__.__name__ is 'function' (Python-level function; not C-level builtin_function_or_method)"]
    - [fields_fget_type,   "UUID.fields.fget.__class__.__name__.__eq__",              ["function"], true, "UUID.fields.fget.__class__.__name__ is 'function' (all UUID property fgets are Python functions defined in Lib/uuid.py)"]
    - [time_fget_type,     "UUID.time.fget.__class__.__name__.__eq__",                ["function"], true, "UUID.time.fget.__class__.__name__ is 'function' (same type as all other UUID property fgets)"]
    - [cshv_name_len,      "UUID.clock_seq_hi_variant.fget.__name__.__len__",         [],           20,   "UUID.clock_seq_hi_variant.fget.__name__.__len__() is 20 (longest UUID property bare name; 'clock_seq_hi_variant'=20 chars)"]
    - [node_name_len,      "UUID.node.fget.__name__.__len__",                         [],           4,    "UUID.node.fget.__name__.__len__() is 4 (tied with 'time' for shortest UUID property name; 'node'=4, 'time'=4)"]

# ---------------------------------------------------------------------------
# uuid.UUID.bytes_le.fget.__name__.__eq__('bytes_le') — standalone
#
# uuid.UUID.bytes_le.fget.__name__ is 'bytes_le' (8 chars). The bytes_le
# property returns the UUID as a 16-byte string in little-endian byte order
# (the time_low, time_mid, time_hi_version fields are reversed compared to
# the standard bytes property). It is used for interoperability with Windows
# GUIDs which use little-endian byte order. uuid_extra97 anchors
# UUID.bytes_le.fget.__qualname__=='UUID.bytes_le'; this spec anchors
# fget.__name__=='bytes_le' (without 'UUID.' prefix) as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra107.UUID_bytes_le_fget_name_eq:
  description: "uuid.UUID.bytes_le.fget.__name__.__eq__('bytes_le') == True — fget.__name__ is 'bytes_le' (8 chars; bare name without 'UUID.' prefix; contrasts with __qualname__=='UUID.bytes_le'=13 chars); bytes_le returns UUID in little-endian byte order (Windows GUID compatibility); extra97 anchors fget qualname; first standalone for fget __name__ under uuidfget107"
  category: function_identity
  kind: python_call_eq
  function: "UUID.bytes_le.fget.__name__.__eq__"
  args: ["bytes_le"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.fields.fget.__module__.__eq__('uuid') — standalone
#
# uuid.UUID.fields.fget.__module__ is 'uuid'. The fields property returns a
# tuple of six integers: (time_low, time_mid, time_hi_version, clock_seq_hi_variant,
# clock_seq_low, node). Together these six 32/16/16/8/8/48-bit fields make up
# the 128-bit UUID value. The fget function is defined in Lib/uuid.py so its
# __module__ is 'uuid'. uuid_extra97 anchors fget qualname; no prior uuid spec
# anchors fget.__module__ as a standalone under uuidfget107.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra107.UUID_fields_fget_module_eq:
  description: "uuid.UUID.fields.fget.__module__.__eq__('uuid') == True — fget.__module__ is 'uuid' (4 chars; defined in Lib/uuid.py); fields returns 6-tuple (time_low, time_mid, time_hi_version, clock_seq_hi_variant, clock_seq_low, node); all UUID property fgets share __module__=='uuid'; extra97 anchors fget qualname; first standalone for fget __module__ under uuidfget107"
  category: function_identity
  kind: python_call_eq
  function: "UUID.fields.fget.__module__.__eq__"
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.time.fget.__name__.__eq__('time') — standalone
#
# uuid.UUID.time.fget.__name__ is 'time' (4 chars). The time property returns
# the 60-bit timestamp value from a UUID version 1. For uuid1, the timestamp
# is the number of 100-nanosecond intervals since October 15, 1582 (the adoption
# of the Gregorian calendar). The bare __name__ 'time' (4 chars) is shorter than
# the qualname 'UUID.time' (9 chars). uuid_extra97 anchors uuid.UUID.time.fget.
# __qualname__.__eq__('UUID.time'); no prior uuid spec anchors uuid.UUID.time.fget.
# __name__ equality as a standalone under uuidfget107.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra107.UUID_time_fget_name_eq:
  description: "uuid.UUID.time.fget.__name__.__eq__('time') == True — fget.__name__ is 'time' (4 chars; bare name; same length as 'node'); 60-bit timestamp from uuid1 (100ns intervals since 1582-10-15); qualname is 'UUID.time' (9 chars; extra97 anchors); __name__ is 5 chars shorter than qualname; first standalone for UUID.time fget __name__ under uuidfget107"
  category: function_identity
  kind: python_call_eq
  function: "UUID.time.fget.__name__.__eq__"
  args: ["time"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.clock_seq_hi_variant.fget.__name__.__len__() == 20 — standalone
#
# uuid.UUID.clock_seq_hi_variant.fget.__name__.__len__() is 20. The bare
# property name 'clock_seq_hi_variant' has 20 characters: 'clock_seq_hi_variant'.
# This is the longest UUID property name. The full qualname 'UUID.clock_seq_hi_variant'
# is 25 chars (uuid_extra97 anchors this length). The 5-char difference is 'UUID.'
# prefix. clock_seq_hi_variant is the raw RFC 4122 field combining the 6-bit
# high bits of the clock sequence and the 2-bit variant indicator. No prior
# uuid spec anchors clock_seq_hi_variant fget.__name__.__len__() as a standalone
# under uuidfget107. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra107.UUID_cshv_fget_name_len_20:
  description: "uuid.UUID.clock_seq_hi_variant.fget.__name__.__len__() == 20 — bare property name is 20 chars ('clock_seq_hi_variant'); qualname is 25 chars ('UUID.clock_seq_hi_variant'; extra97 anchors); difference is 5 chars ('UUID.' prefix); longest UUID property name; RFC 4122 field with 6-bit high clock seq and 2-bit variant; first standalone for cshv fget name len under uuidfget107"
  category: function_identity
  kind: python_call_eq
  function: "UUID.clock_seq_hi_variant.fget.__name__.__len__"
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# uuid.UUID.node.fget.__class__.__name__.__eq__('function') — standalone
#
# uuid.UUID.node.fget.__class__.__name__ is 'function'. All UUID property fget
# functions are Python 'function' objects — they are defined in Lib/uuid.py
# using the @property decorator and are pure Python (not C extensions). This
# is distinct from C-level hash functions like hashlib.sha256 which are
# 'builtin_function_or_method'. uuid_extra97 anchors type(UUID.node).__name__
# == 'property' (the property wrapper); this spec anchors type(fget).__name__
# == 'function' (the underlying getter function) as a standalone under uuidfget107.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra107.UUID_node_fget_class_function:
  description: "uuid.UUID.node.fget.__class__.__name__.__eq__('function') == True — fget is a Python 'function' type (not builtin_function_or_method; defined in Lib/uuid.py); extra97 anchors type(UUID.node).__name__=='property' (the wrapper); this spec anchors the fget function type; all UUID property fgets have __class__.__name__=='function'; first standalone for fget type identity under uuidfget107"
  category: type_identity
  kind: python_call_eq
  function: "UUID.node.fget.__class__.__name__.__eq__"
  args: ["function"]
  expected: true
