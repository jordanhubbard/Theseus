spec: is_hexcolor
version: ">=1.0.0"
backend: node(is-hexcolor)

docs: https://www.npmjs.com/package/is-hexcolor

provenance:
  derived_from:
    - "is-hexcolor README — https://www.npmjs.com/package/is-hexcolor"
    - "Test vectors verified with is-hexcolor via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-hexcolor source"
  notes:
    - "is-hexcolor is an npm package. Install: npm install is-hexcolor"
    - "Returns true if the string is a valid hex color (with leading #, 3 or 6 hex digits)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_hexcolor.check:
  kind: node_module_call_eq
  function: ~
  category: color
  id_prefix: ishex

  columns: [id, args, expected]
  rows:
    - [six_digit,   ["#ff0000"],    true]
    - [three_digit, ["#fff"],       true]
    - [uppercase,   ["#AABBCC"],    true]
    - [no_hash,     ["ff0000"],     false]
    - [invalid,     ["not-color"],  false]
