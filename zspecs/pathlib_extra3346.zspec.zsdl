spec: pp3346
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 670 (pp3346): __neg__, __pos__, __abs__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __neg__, __pos__, __abs__ dict-presence (unary operators: -x, +x, abs(x))."
    - "No pathlib class defines __neg__ in its own __dict__: path objects are filesystem path abstractions, not numeric types; unary negation has no meaning for paths."
    - "No pathlib class defines __pos__ in its own __dict__: path objects do not implement unary plus; the +x operator has no semantic meaning for filesystem paths."
    - "No pathlib class defines __abs__ in its own __dict__: path objects do not implement abs(); magnitude is not a concept defined for filesystem path objects."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all unary arithmetic operators absent from pathlib class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __neg__ dict-presence — operator.contains(Cls.__dict__, '__neg__')
#
# No pathlib class defines __neg__ in its own __dict__; all false.
# pathlib path objects are filesystem path abstractions, not numeric types;
# the -x operator has no semantic meaning for path objects.
# ---------------------------------------------------------------------------

table pp3346.neg:
  description: "pathlib types __neg__ dict-presence checks; wave 670"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3346

  columns: [id, function, args, expected]
  rows:
    - ["pp3346001", operator.contains, [pathlib.PurePath.__dict__,         "__neg__"], false]
    - ["pp3346002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__neg__"], false]
    - ["pp3346003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__neg__"], false]
    - ["pp3346004", operator.contains, [pathlib.Path.__dict__,             "__neg__"], false]
    - ["pp3346005", operator.contains, [pathlib.PosixPath.__dict__,        "__neg__"], false]

