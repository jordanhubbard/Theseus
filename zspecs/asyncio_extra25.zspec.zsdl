spec: asyncio_extra25
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "This spec extends asyncio.zspec.zsdl and prior extras through asyncio_extra24.zspec.zsdl."
    - "asyncio_extra18 covers: Task/Future/Queue/Lock/Event/Semaphore __qualname__ eq table."
    - "asyncio_extra22 covers: Condition/BoundedSemaphore __qualname__ eq; class __qualname__ length table."
    - "asyncio_extra23 covers: Queue method qualnames (put/get/put_nowait/get_nowait/empty/full/qsize); Lock.acquire/release standalone invariants."
    - "asyncio_extra24 covers: Task.cancel/done/result method qualnames; Future.set_result/set_exception qualnames."
    - "NOT yet covered in any prior spec: asyncio.PriorityQueue/__qualname__ eq and length in extra25 namespace."
    - "NOT yet covered: asyncio.LifoQueue/__qualname__ eq and length in extra25 namespace."
    - "NOT yet covered: asyncio.Semaphore method __qualname__ table (acquire/release) in extra25 namespace."
    - "NOT yet covered: asyncio.BoundedSemaphore method __qualname__ table in extra25 namespace."
    - "NOT yet covered: asyncio.Event method __qualname__ table (set/clear/wait/is_set) in extra25 namespace."
    - "NOT yet covered: asyncio.Condition method __qualname__ table (wait/notify/notify_all) in extra25 namespace."
    - "PriorityQueue.__qualname__ == 'PriorityQueue' — length 13."
    - "LifoQueue.__qualname__ == 'LifoQueue' — length 9."
    - "Semaphore.acquire.__qualname__ == 'Semaphore.acquire' — length 17."
    - "Semaphore.release.__qualname__ == 'Semaphore.release' — length 17."
    - "BoundedSemaphore.acquire.__qualname__ == 'Semaphore.acquire' — INHERITED from Semaphore (length 17)."
    - "BoundedSemaphore.release.__qualname__ == 'BoundedSemaphore.release' — overridden (length 24)."
    - "Event.set.__qualname__ == 'Event.set' — length 9."
    - "Event.clear.__qualname__ == 'Event.clear' — length 11."
    - "Event.wait.__qualname__ == 'Event.wait' — length 10."
    - "Event.is_set.__qualname__ == 'Event.is_set' — length 12."
    - "Condition.wait.__qualname__ == 'Condition.wait' — length 14."
    - "Condition.notify.__qualname__ == 'Condition.notify' — length 16."
    - "Condition.notify_all.__qualname__ == 'Condition.notify_all' — length 20."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PriorityQueue and LifoQueue __qualname__ table — extra25 namespace
#
# asyncio_extra18 checks Queue.__qualname__ == 'Queue'. No prior spec checks
# PriorityQueue or LifoQueue class __qualname__ values.
# PriorityQueue.__qualname__ == 'PriorityQueue' (length 13).
# LifoQueue.__qualname__ == 'LifoQueue' (length 9).
# ---------------------------------------------------------------------------

table asyncio_extra25.queue_subclass_qualnames:
  description: "asyncio.PriorityQueue and asyncio.LifoQueue __qualname__ values in extra25 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: qsubmqn25

  columns: [id, function, args, expected]
  rows:
    - [PriorityQueue, PriorityQueue.__qualname__.__eq__, ["PriorityQueue"], true]
    - [LifoQueue,     LifoQueue.__qualname__.__eq__,     ["LifoQueue"],     true]

# ---------------------------------------------------------------------------
# PriorityQueue and LifoQueue __qualname__ length table — extra25 namespace
#
# Lengths: PriorityQueue(13), LifoQueue(9).
# ---------------------------------------------------------------------------

table asyncio_extra25.queue_subclass_qualname_lengths:
  description: "asyncio.PriorityQueue and asyncio.LifoQueue __qualname__ lengths in extra25 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: qsubmqnlen25

  columns: [id, function, args, expected]
  rows:
    - [PriorityQueue, PriorityQueue.__qualname__.__len__, [], 13]
    - [LifoQueue,     LifoQueue.__qualname__.__len__,     [], 9]

# ---------------------------------------------------------------------------
# Semaphore method __qualname__ table — extra25 namespace
#
# asyncio_extra18 checks Semaphore.__qualname__ == 'Semaphore' (the class).
# No prior spec provides a table of Semaphore *method* __qualname__ values.
# Semaphore.acquire and release are both defined directly on Semaphore.
# Lengths: Semaphore.acquire(17), Semaphore.release(17).
# ---------------------------------------------------------------------------

table asyncio_extra25.semaphore_method_qualnames:
  description: "asyncio.Semaphore method __qualname__ values in extra25 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: semmqn25

  columns: [id, function, args, expected]
  rows:
    - [acquire, Semaphore.acquire.__qualname__.__eq__, ["Semaphore.acquire"], true]
    - [release, Semaphore.release.__qualname__.__eq__, ["Semaphore.release"], true]

# ---------------------------------------------------------------------------
# Semaphore method __qualname__ length table — extra25 namespace
#
# Lengths: Semaphore.acquire(17), Semaphore.release(17).
# ---------------------------------------------------------------------------

table asyncio_extra25.semaphore_method_qualname_lengths:
  description: "asyncio.Semaphore method __qualname__ lengths in extra25 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: semmqnlen25

  columns: [id, function, args, expected]
  rows:
    - [acquire, Semaphore.acquire.__qualname__.__len__, [], 17]
    - [release, Semaphore.release.__qualname__.__len__, [], 17]

# ---------------------------------------------------------------------------
# BoundedSemaphore method __qualname__ table — extra25 namespace
#
# asyncio_extra22 checks BoundedSemaphore.__qualname__ == 'BoundedSemaphore'.
# No prior spec covers BoundedSemaphore *method* __qualname__ values.
# BoundedSemaphore.acquire is INHERITED from Semaphore — qualname is
# 'Semaphore.acquire' (length 17), NOT 'BoundedSemaphore.acquire'.
# BoundedSemaphore.release is overridden — qualname is 'BoundedSemaphore.release'
# (length 24).
# ---------------------------------------------------------------------------

table asyncio_extra25.boundedsemaphore_method_qualnames:
  description: "asyncio.BoundedSemaphore method __qualname__ values in extra25 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: bsmqn25

  columns: [id, function, args, expected]
  rows:
    - [acquire, BoundedSemaphore.acquire.__qualname__.__eq__, ["Semaphore.acquire"],        true]
    - [release, BoundedSemaphore.release.__qualname__.__eq__, ["BoundedSemaphore.release"], true]

# ---------------------------------------------------------------------------
# BoundedSemaphore method __qualname__ length table — extra25 namespace
#
# acquire inherits -> length 17; release overridden -> length 24.
# ---------------------------------------------------------------------------

table asyncio_extra25.boundedsemaphore_method_qualname_lengths:
  description: "asyncio.BoundedSemaphore method __qualname__ lengths in extra25 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: bsmqnlen25

  columns: [id, function, args, expected]
  rows:
    - [acquire, BoundedSemaphore.acquire.__qualname__.__len__, [], 17]
    - [release, BoundedSemaphore.release.__qualname__.__len__, [], 24]

