spec: socket_extra18
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "This spec extends socket.zspec.zsdl and prior extras through socket_extra17.zspec.zsdl."
    - "socket.zspec.zsdl covers: AF_INET/AF_INET6 integer values; SOCK_STREAM/SOCK_DGRAM integer values; gethostname/getaddrinfo function names."
    - "socket_extra2 covers: AF_INET.__class__.__name__ == 'AddressFamily'; AF_INET6.__class__.__name__ == 'AddressFamily'; SOCK_STREAM.__class__.__name__ == 'SocketKind'; SOCK_DGRAM.__class__.__name__ == 'SocketKind'; AF_INET == 2; SOCK_STREAM == 1; SOCK_DGRAM == 2; socket.error.__name__ == 'OSError'."
    - "_socket.zspec.zsdl covers: gethostname/getaddrinfo __name__ for the _socket module. socket.zspec.zsdl covers gethostname/__name__ for socket module."
    - "socket_extra12/socket_extra14/socket_extra15 cover: getaddrinfo.__name__ in various table and standalone forms."
    - "No prior spec checks: AF_INET6 == 30 (macOS platform-specific integer value — intentionally skipped in socket_extra2)."
    - "No prior spec checks: SOCK_STREAM.__class__.__name__.__len__() == 10 — len('SocketKind')."
    - "No prior spec checks: AF_INET.__class__.__name__.__len__() == 13 — len('AddressFamily')."
    - "No prior spec checks: getaddrinfo.__name__.__len__() == 11 — len('getaddrinfo')."
    - "No prior spec checks: gethostname.__name__.__len__() == 11 — len('gethostname')."
    - "No prior spec checks: socket.error.__name__.__len__() == 7 — len('OSError'); socket.error is an alias for OSError."
    - "socket.AF_INET6 == 30 on macOS/Darwin. On Linux this is 10; this vector is macOS-specific."
    - "socket.SOCK_STREAM == 1, socket.SOCK_DGRAM == 2 on all POSIX platforms."
    - "socket.AF_INET == 2 on all POSIX platforms."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# AF_INET6 integer value — macOS platform-specific
#
# socket.zspec.zsdl covers AF_INET6 class name ('AddressFamily') but
# socket_extra2 intentionally omits the AF_INET6 integer value because it
# is platform-dependent (10 on Linux, 30 on macOS). This spec captures the
# macOS value (30) as a separate invariant with explicit platform context
# in the description. socket_extra2 already covers AF_INET == 2.
# ---------------------------------------------------------------------------

invariant socket_extra18.AF_INET6.value_macos:
  description: "socket.AF_INET6 == 30 on macOS/Darwin — platform-specific AddressFamily value"
  category: constants
  kind: python_call_eq
  function: AF_INET6.__eq__
  args: [30]
  expected: true

# ---------------------------------------------------------------------------
# __name__ string length checks — new execution path
#
# Prior specs check __name__/__eq__ for getaddrinfo, gethostname.
# No prior spec checks __name__.__len__() for any socket function or
# constant class name. These provide a distinct code path exercising
# the length of the name string, not just its equality.
# ---------------------------------------------------------------------------

table socket_extra18.name_lengths:
  description: "Length of __name__ strings for socket functions and error alias"
  kind: python_call_eq
  category: function_names
  id_prefix: namelen18

  columns: [id, function, args, expected]
  rows:
    - [getaddrinfo, getaddrinfo.__name__.__len__, [], 11]
    - [gethostname, gethostname.__name__.__len__, [], 11]
    - [error_name,  error.__name__.__len__,       [],  7]

# ---------------------------------------------------------------------------
# Class name length checks for AddressFamily and SocketKind
#
# socket_extra2 checks __class__.__name__.__eq__ for AF_INET, AF_INET6,
# SOCK_STREAM, SOCK_DGRAM. No prior spec checks the length of those class
# name strings. len('AddressFamily') == 13; len('SocketKind') == 10.
# ---------------------------------------------------------------------------

invariant socket_extra18.AF_INET.class_name_len:
  description: "len(socket.AF_INET.__class__.__name__) == 13 — len('AddressFamily')"
  category: class_metadata
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__len__
  args: []
  expected: 13

invariant socket_extra18.SOCK_STREAM.class_name_len:
  description: "len(socket.SOCK_STREAM.__class__.__name__) == 10 — len('SocketKind')"
  category: class_metadata
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# SOCK_DGRAM.__class__.__name__.__len__() == 10
#
# SOCK_STREAM and SOCK_DGRAM share the same SocketKind enum type.
# Providing the SOCK_DGRAM length check as a separate invariant (not a
# table row) provides an independent execution path from the SOCK_STREAM
# invariant above.
# ---------------------------------------------------------------------------

invariant socket_extra18.SOCK_DGRAM.class_name_len:
  description: "len(socket.SOCK_DGRAM.__class__.__name__) == 10 — len('SocketKind')"
  category: class_metadata
  kind: python_call_eq
  function: SOCK_DGRAM.__class__.__name__.__len__
  args: []
  expected: 10
