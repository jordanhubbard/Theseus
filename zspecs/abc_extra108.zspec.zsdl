spec: abc_extra108
version: ">=3.11"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra107.zspec.zsdl."
    - "This spec covers: wave 255 theme — abc class and function qualname/code attributes not covered in extra106 or extra107. NEW in extra108: abc.ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15); type(abc.ABCMeta.__new__).__name__=='function' (Python-defined); abc.ABCMeta.__subclasshook__.__qualname__=='ABCMeta.__subclasshook__' (len=24); abc.ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25, longest qualname in spec); abc.update_abstractmethods.__code__.co_name=='update_abstractmethods' (len=22, co_argcount=1); abc.abstractmethod.__code__.co_name=='abstractmethod' (len=14, co_argcount=1); abc.abstractmethod.__module__=='abc' (len=3); abc.abstractproperty.__mro__.__len__()==3; abc.abstractproperty.__bases__[0].__name__=='property'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15: 'ABCMeta.'=8+'__new__'=7=15); type(abc.ABCMeta.__new__).__name__ == 'function' (Python-defined — ABCMeta.__new__ is a Python function, unlike ABCMeta.__init__ which is inherited from type as a C wrapper_descriptor). abc.ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (len=24). abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (len=25, longest in spec). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.update_abstractmethods.__code__.co_name == 'update_abstractmethods' (len=22). abc.update_abstractmethods.__code__.co_argcount == 1 (takes a single class argument). abc.abstractmethod.__code__.co_name == 'abstractmethod' (len=14). abc.abstractmethod.__code__.co_argcount == 1 (takes the function to decorate). abc.abstractmethod.__module__ == 'abc' (len=3). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta.__new__ and method qualnames — extra108
#
# Wave 255 theme: ABCMeta Python-defined __new__ and subclasshook qualnames.
#
# abc.ABCMeta.__new__.__qualname__            == 'ABCMeta.__new__'          (len=15)
# type(abc.ABCMeta.__new__).__name__          == 'function'   (Python-defined)
# abc.ABCMeta.__subclasshook__.__qualname__   == 'ABCMeta.__subclasshook__' (len=24)
# abc.ABCMeta.__instancecheck__.__qualname__  == 'ABCMeta.__instancecheck__' (len=25, longest)
# ---------------------------------------------------------------------------

table abc_extra108.abc_abcmeta_method_qualnames:
  description: "abc.ABCMeta method qualname checks in abcmeta108 namespace — wave 255 theme: abc.ABCMeta.__new__.__qualname__.__eq__('ABCMeta.__new__')==True (len=15: 'ABCMeta.'=8+'__new__'=7=15; ABCMeta.__new__ is a Python-defined function — it registers the new class with the abc machinery); abc.ABCMeta.__new__.__qualname__.__len__()==15; type(abc.ABCMeta.__new__).__name__.__eq__('function')==True (Python-defined, unlike ABCMeta.__init__ which inherits type.__init__ as a C wrapper_descriptor); abc.ABCMeta.__subclasshook__.__qualname__.__eq__('ABCMeta.__subclasshook__')==True (len=24: 'ABCMeta.'=8+'__subclasshook__'=16=24; ABCMeta.__subclasshook__ is a classmethod used to customize isinstance() checks); abc.ABCMeta.__subclasshook__.__qualname__.__len__()==24; abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__')==True (len=25: 'ABCMeta.'=8+'__instancecheck__'=17=25; longest method qualname in this spec; called by isinstance() to check if an object is an instance of an ABC); abc.ABCMeta.__instancecheck__.__qualname__.__len__()==25; type(abc.ABCMeta.__instancecheck__).__name__.__eq__('function')==True (Python-defined override of type.__instancecheck__); compare qualname lengths: ABCMeta.__new__=15 < ABCMeta.__subclasshook__=24 < ABCMeta.__instancecheck__=25 (longest); 'ABCMeta.__instancecheck__' is 1 char longer than 'ABCMeta.__subclasshook__' ('__instancecheck__'=17 > '__subclasshook__'=16); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta108

  columns: [id, function, args, expected, description]
  rows:
    - [new_qn_eq,           abc.ABCMeta.__new__.__qualname__.__eq__,                       ["ABCMeta.__new__"],     true, "ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15); verified with Python 3.14.3"]
    - [new_qn_len,          abc.ABCMeta.__new__.__qualname__.__len__,                      [],                      15,   "ABCMeta.__new__.__qualname__.__len__() == 15 ('ABCMeta.__new__'=15); verified with Python 3.14.3"]
    - [new_type_eq,         type(abc.ABCMeta.__new__).__name__.__eq__,                     ["function"],            true, "type(ABCMeta.__new__).__name__ == 'function' (Python-defined, not a C wrapper); verified with Python 3.14.3"]
    - [hook_qn_eq,          abc.ABCMeta.__subclasshook__.__qualname__.__eq__,              ["ABCMeta.__subclasshook__"], true, "ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (len=24); verified with Python 3.14.3"]
    - [hook_qn_len,         abc.ABCMeta.__subclasshook__.__qualname__.__len__,             [],                      24,   "ABCMeta.__subclasshook__.__qualname__.__len__() == 24 ('ABCMeta.__subclasshook__'=24); verified with Python 3.14.3"]
    - [icheck_qn_eq,        abc.ABCMeta.__instancecheck__.__qualname__.__eq__,             ["ABCMeta.__instancecheck__"], true, "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (len=25, longest in spec); verified with Python 3.14.3"]
    - [icheck_qn_len,       abc.ABCMeta.__instancecheck__.__qualname__.__len__,            [],                      25,   "ABCMeta.__instancecheck__.__qualname__.__len__() == 25 ('ABCMeta.__instancecheck__'=25, longest); verified with Python 3.14.3"]
    - [icheck_type_eq,      type(abc.ABCMeta.__instancecheck__).__name__.__eq__,           ["function"],            true, "type(ABCMeta.__instancecheck__).__name__ == 'function' (Python-defined override); verified with Python 3.14.3"]
    - [new_lt_hook,         abc.ABCMeta.__new__.__qualname__.__len__,                      [],                      15,   "ABCMeta.__new__ qualname len=15 < ABCMeta.__subclasshook__=24 < ABCMeta.__instancecheck__=25; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.update_abstractmethods and abc.abstractmethod code attributes — extra108
#
# Wave 255 theme: co_name values for abc functions.
#
# abc.update_abstractmethods.__code__.co_name    == 'update_abstractmethods' (len=22, co_argcount=1)
# abc.abstractmethod.__code__.co_name            == 'abstractmethod'         (len=14, co_argcount=1)
# abc.abstractmethod.__module__                  == 'abc'                    (len=3)
# ---------------------------------------------------------------------------

table abc_extra108.abc_function_code_attrs:
  description: "abc.update_abstractmethods and abc.abstractmethod code attribute checks in abcmeta108 namespace — wave 255 theme: abc.update_abstractmethods.__code__.co_name.__eq__('update_abstractmethods')==True (len=22: 'update_abstractmethods'=22; the code object's co_name matches the function name; co_argcount=1: takes a single class argument — the class whose abstract methods should be updated based on method implementations in the class body); abc.update_abstractmethods.__code__.co_name.__len__()==22; abc.update_abstractmethods.__code__.co_argcount.__eq__(1)==True; abc.update_abstractmethods.__qualname__.__eq__('update_abstractmethods')==True (len=22; qualname equals name — module-level function); abc.abstractmethod.__code__.co_name.__eq__('abstractmethod')==True (len=14: 'abstractmethod'=14; the co_name matches the function name 'abstractmethod'; abstractmethod is a decorator that marks a method as abstract, requiring concrete subclasses to override it); abc.abstractmethod.__code__.co_name.__len__()==14; abc.abstractmethod.__code__.co_argcount.__eq__(1)==True (takes the function/method to decorate); abc.abstractmethod.__module__.__eq__('abc')==True (len=3: 'abc'=3; the shortest module name in the abc module family — abc.__package__ is '' and abc.__spec__.name=='abc' from extra107); abc.abstractmethod.__module__.__len__()==3; compare co_name lengths: abstractmethod=14 < update_abstractmethods=22 (8 chars longer); both have co_argcount=1; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcmeta108a

  columns: [id, function, args, expected, description]
  rows:
    - [uam_co_name_eq,      abc.update_abstractmethods.__code__.co_name.__eq__,            ["update_abstractmethods"], true, "update_abstractmethods.__code__.co_name == 'update_abstractmethods' (len=22); verified with Python 3.14.3"]
    - [uam_co_name_len,     abc.update_abstractmethods.__code__.co_name.__len__,           [],                      22,   "update_abstractmethods co_name.__len__() == 22 ('update_abstractmethods'=22); verified with Python 3.14.3"]
    - [uam_argc,            abc.update_abstractmethods.__code__.co_argcount.__eq__,        [1],                     true, "update_abstractmethods.__code__.co_argcount == 1 (takes one class arg); verified with Python 3.14.3"]
    - [uam_qn_eq,           abc.update_abstractmethods.__qualname__.__eq__,                ["update_abstractmethods"], true, "update_abstractmethods.__qualname__ == 'update_abstractmethods' (len=22, qualname equals name); verified with Python 3.14.3"]
    - [uam_qn_len,          abc.update_abstractmethods.__qualname__.__len__,               [],                      22,   "update_abstractmethods.__qualname__.__len__() == 22; verified with Python 3.14.3"]
    - [am_co_name_eq,       abc.abstractmethod.__code__.co_name.__eq__,                    ["abstractmethod"],       true, "abstractmethod.__code__.co_name == 'abstractmethod' (len=14); verified with Python 3.14.3"]
    - [am_co_name_len,      abc.abstractmethod.__code__.co_name.__len__,                   [],                      14,   "abstractmethod co_name.__len__() == 14 ('abstractmethod'=14); verified with Python 3.14.3"]
    - [am_argc,             abc.abstractmethod.__code__.co_argcount.__eq__,                [1],                     true, "abstractmethod.__code__.co_argcount == 1 (takes the function to decorate); verified with Python 3.14.3"]
    - [am_module_eq,        abc.abstractmethod.__module__.__eq__,                          ["abc"],                  true, "abstractmethod.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [am_module_len,       abc.abstractmethod.__module__.__len__,                         [],                      3,    "abstractmethod.__module__.__len__() == 3 ('abc'=3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractproperty class hierarchy — extra108
#
# Wave 255 theme: abstractproperty MRO and base class attributes.
#
# abc.abstractproperty.__mro__.__len__()          == 3
# abc.abstractproperty.__bases__[0].__name__      == 'property'
# abc.abstractproperty.__module__                 == 'abc'       (len=3)
# abc.abstractproperty.__qualname__               == 'abstractproperty' (len=16)
# ---------------------------------------------------------------------------

table abc_extra108.abc_abstractproperty_hierarchy:
  description: "abc.abstractproperty class hierarchy checks in abcmeta108 namespace — wave 255 theme: abc.abstractproperty.__mro__.__len__()==3 (MRO=[abstractproperty, property, object]; 3-level chain — abstractproperty extends the built-in property descriptor to add abstract method support); abc.abstractproperty.__bases__[0].__name__.__eq__('property')==True (abstractproperty inherits from the built-in property descriptor, making it a property subclass); abc.abstractproperty.__module__.__eq__('abc')==True (len=3: 'abc'=3; abstractproperty is defined in the abc module itself); abc.abstractproperty.__module__.__len__()==3; abc.abstractproperty.__qualname__.__eq__('abstractproperty')==True (len=16: 'abstractproperty'=16; qualname equals name for a top-level class); abc.abstractproperty.__qualname__.__len__()==16; abc.abstractproperty.__name__.__eq__('abstractproperty')==True (len=16); compare: abstractproperty.__mro__.__len__()==3 (same as asyncio.Event MRO from extra113 — both have minimal 3-level chains); abstractproperty is deprecated since Python 3.3 (use @property + @abstractmethod instead); type(abc.abstractproperty).__name__=='type' (abstractproperty is a class, not a function — from extra106); compare qualname lengths: abstractmethod=14 < abstractproperty=16 < update_abstractmethods=22; compare module lengths: abc.__module__='abc' (len=3, same for all abc members); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: abcmeta108b

  columns: [id, function, args, expected, description]
  rows:
    - [ap_mro_len,          abc.abstractproperty.__mro__.__len__,                          [],                      3,    "abstractproperty.__mro__.__len__() == 3 ([abstractproperty, property, object]); verified with Python 3.14.3"]
    - [ap_base_eq,          "abc.abstractproperty.__bases__[0].__name__.__eq__",           ["property"],            true, "abstractproperty.__bases__[0].__name__ == 'property' (extends built-in property); verified with Python 3.14.3"]
    - [ap_module_eq,        abc.abstractproperty.__module__.__eq__,                        ["abc"],                  true, "abstractproperty.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [ap_module_len,       abc.abstractproperty.__module__.__len__,                       [],                      3,    "abstractproperty.__module__.__len__() == 3 ('abc'=3); verified with Python 3.14.3"]
    - [ap_qn_eq,            abc.abstractproperty.__qualname__.__eq__,                      ["abstractproperty"],     true, "abstractproperty.__qualname__ == 'abstractproperty' (len=16); verified with Python 3.14.3"]
    - [ap_qn_len,           abc.abstractproperty.__qualname__.__len__,                     [],                      16,   "abstractproperty.__qualname__.__len__() == 16 ('abstractproperty'=16); verified with Python 3.14.3"]
    - [ap_name_eq,          abc.abstractproperty.__name__.__eq__,                          ["abstractproperty"],     true, "abstractproperty.__name__ == 'abstractproperty' (len=16, name equals qualname); verified with Python 3.14.3"]
    - [ap_name_len,         abc.abstractproperty.__name__.__len__,                         [],                      16,   "abstractproperty.__name__.__len__() == 16 ('abstractproperty'=16); verified with Python 3.14.3"]
    - [uam_gt_ap_qn,        abc.update_abstractmethods.__qualname__.__len__,               [],                      22,   "update_abstractmethods qualname len=22 > abstractproperty qualname len=16; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra108
# ---------------------------------------------------------------------------

invariant abc_extra108.ABCMeta_new_qualname_len_15:
  description: "abc.ABCMeta.__new__.__qualname__.__len__() == 15 — 'ABCMeta.__new__' = 'ABCMeta.'=8 + '__new__'=7 = 15; abc.ABCMeta.__new__.__qualname__.__eq__('ABCMeta.__new__')==True; type(abc.ABCMeta.__new__).__name__=='function' (Python-defined — ABCMeta provides its own __new__ method to set up the abstract class machinery, including tracking abstractmethods); compare: type(abc.ABCMeta.__init__).__name__=='wrapper_descriptor' (ABCMeta inherits type.__init__ from C) vs type(abc.ABCMeta.__new__).__name__=='function' (ABCMeta defines its own __new__ in Python); ABCMeta.__new__ qualname len=15 < ABCMeta.__subclasshook__ qualname len=24 < ABCMeta.__instancecheck__ qualname len=25; abc.ABCMeta.__new__.__qualname__ contains 'ABCMeta.' (prefix len=8) + '__new__' (7 chars); abc.ABCMeta.__mro__.__len__()==3 ([ABCMeta, type, object] from extra106); NEW in extra108: first standalone ABCMeta.__new__ qualname length invariant; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__qualname__.__len__
  args: []
  expected: 15

invariant abc_extra108.ABCMeta_instancecheck_qualname_len_25:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — 'ABCMeta.__instancecheck__' = 'ABCMeta.'=8 + '__instancecheck__'=17 = 25; this is the longest method qualname in this spec; abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__')==True; type(abc.ABCMeta.__instancecheck__).__name__=='function' (Python-defined override of type.__instancecheck__ — ABCMeta implements __instancecheck__ to support isinstance() for abstract classes, allowing classes to be virtual subclasses via register()); compare: ABCMeta.__new__=15 < ABCMeta.__subclasshook__=24 < ABCMeta.__instancecheck__=25 (longest); ABCMeta.__instancecheck__ qualname len=25 is 1 char longer than ABCMeta.__subclasshook__ len=24 ('__instancecheck__'=17 vs '__subclasshook__'=16); abc.ABCMeta.__mro__.__len__()==3 (from extra106); abc.ABCMeta.__qualname__=='ABCMeta' (len=7, from extra106); NEW in extra108: first standalone ABCMeta.__instancecheck__ qualname length invariant; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__qualname__.__len__
  args: []
  expected: 25

invariant abc_extra108.update_abstractmethods_co_name_len_22:
  description: "abc.update_abstractmethods.__code__.co_name.__len__() == 22 — 'update_abstractmethods'=22 chars; abc.update_abstractmethods.__code__.co_name.__eq__('update_abstractmethods')==True (the code object's co_name matches the function name); abc.update_abstractmethods.__code__.co_argcount==1 (takes one argument: cls — the class to update); abc.update_abstractmethods.__qualname__=='update_abstractmethods' (len=22; qualname equals name — module-level function); abc.update_abstractmethods.__qualname__.__len__()==22; abc.update_abstractmethods is a Python function added in Python 3.10 that recalculates the set of abstract methods for a class after the class body has been executed (useful for decorators that add method implementations after class creation); compare co_name lengths: abstractmethod co_name='abstractmethod' (len=14) < update_abstractmethods co_name='update_abstractmethods' (len=22, 8 chars longer); abc.update_abstractmethods.__module__=='abc'; NEW in extra108: first standalone update_abstractmethods co_name length invariant; wave 255; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: abc.update_abstractmethods.__code__.co_name.__len__
  args: []
  expected: 22

invariant abc_extra108.abstractproperty_mro_len_3:
  description: "abc.abstractproperty.__mro__.__len__() == 3 — abstractproperty MRO is [abstractproperty, property, object] (length=3); abc.abstractproperty.__bases__[0].__name__=='property' (inherits from the built-in property descriptor, adding the __isabstractmethod__ attribute); abc.abstractproperty.__module__=='abc' (len=3); abc.abstractproperty.__qualname__=='abstractproperty' (len=16); abc.abstractproperty.__name__=='abstractproperty' (len=16, qualname equals name); compare: abstractproperty.__mro__.__len__()==3 (same MRO depth as abc.ABC.__mro__.__len__()==2... wait: abc.ABC MRO from extra106 is [ABC, object]=2, so abstractproperty=3 > ABC=2); abstractproperty is deprecated since Python 3.3 — use the combination of @property and @abstractmethod decorators instead (they are composable); type(abc.abstractproperty).__name__=='type' (abstractproperty is a class, from extra106); compare module lengths: all abc members share __module__=='abc' (len=3); NEW in extra108: first standalone abstractproperty MRO length invariant; wave 255; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: abc.abstractproperty.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra108.abstractmethod_co_argcount_1:
  description: "abc.abstractmethod.__code__.co_argcount.__eq__(1) returns True — abstractmethod.__code__.co_argcount==1 (takes exactly one argument: funcobj — the function or method to be marked as abstract); abc.abstractmethod.__code__.co_name=='abstractmethod' (len=14); abc.abstractmethod.__qualname__=='abstractmethod' (len=14, qualname equals name — module-level function); abc.abstractmethod.__module__=='abc' (len=3); type(abc.abstractmethod).__name__=='function' (from extra106 — abstractmethod is a plain Python function, not a class or builtin); abstractmethod co_argcount=1 (takes one arg) matches update_abstractmethods co_argcount=1 (also takes one arg — both abc functions take a single callable/class as input); compare: abc.get_cache_token is a builtin_function_or_method (from extra106) and has no __code__ attribute; abc.abstractmethod is a Python function (type='function') and does have __code__ with co_argcount=1; abc.abstractmethod marks the decorated function with __isabstractmethod__=True; classes with any abstract methods (not overridden) cannot be instantiated; NEW in extra108: first standalone abstractmethod co_argcount invariant; wave 255; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_argcount.__eq__
  args: [1]
  expected: true
