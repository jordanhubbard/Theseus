spec: ordinalize
version: ">=1.0.2"
backend: node(ordinalize)

docs: https://www.npmjs.com/package/ordinalize

provenance:
  derived_from:
    - "ordinalize README — https://www.npmjs.com/package/ordinalize"
    - "Test vectors verified with ordinalize via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "ordinalize source"
  notes:
    - "ordinalize is an npm package. Install: npm install ordinalize"
    - "Converts an integer to its ordinal string (1st, 2nd, 3rd, etc.)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table ordinalize.convert:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: ord

  columns: [id, args, expected]
  rows:
    - [first,    [1],  "1st"]
    - [second,   [2],  "2nd"]
    - [third,    [3],  "3rd"]
    - [eleventh, [11], "11th"]
    - [twentyone,[21], "21st"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:18:31Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
