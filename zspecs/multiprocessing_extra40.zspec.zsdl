spec: multiprocessing_extra40
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#exceptions — multiprocessing exception hierarchy"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra39.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__ tables, DefaultContext method qualname lengths, BaseProcess metadata, function __name__.__len__() tables, pool result class tables, Process/__name__=='Process' (extra37), Process/__module__=='multiprocessing.context' (extra37), Queue/__name__=='Queue' (extra37), Pipe/__name__=='Pipe' (extra37), Process method qualname lens for start/join/run (extra37), Process.__bases__[0].__name__=='BaseProcess'/__mro__.__len__()==3/Manager.__name__=='Manager' (extra38), function __name__/__module__ string equality for cpu_count/current_process/active_children (extra38), AuthenticationError/__name__/__module__/__bases__[0].__name__, ProcessError/__name__/__bases__[0].__name__, BufferTooShort/__name__, TimeoutError/__name__/__bases__[0].__name__, all four exception __module__ string equality (extra39)."
    - "This spec covers: ProcessError.__mro__.__len__()==4; AuthenticationError.__mro__.__len__()==5; TimeoutError.__mro__.__len__()==5; BufferTooShort.__mro__.__len__()==5; Process.__qualname__=='Process'; Process.__qualname__.__len__()==7; multiprocessing.context.BaseContext.__name__=='BaseContext'; get_start_method/__name__=='get_start_method'."
    - "ProcessError.__mro__.__len__() == 4. ProcessError's MRO: [ProcessError, Exception, BaseException, object]. It has depth 4 — one less than the subclasses (AuthenticationError, TimeoutError, BufferTooShort) which all have depth 5 because they add one more level (ProcessError) above Exception."
    - "AuthenticationError, TimeoutError, and BufferTooShort all have __mro__.__len__() == 5. Their MROs: [SubclassName, ProcessError, Exception, BaseException, object]. All three share the same depth because they all inherit directly from ProcessError (which itself inherits from Exception)."
    - "multiprocessing.Process.__qualname__ == 'Process' (7 chars). __qualname__ equals __name__ for top-level classes. len('Process') == 7. Prior specs captured Process.__qualname__ as a string equality check; extra40 adds the __len__() measurement."
    - "multiprocessing.context.BaseContext.__name__ == 'BaseContext'. BaseContext is accessible via the context submodule (multiprocessing.context). It is the abstract base for DefaultContext, ForkContext, SpawnContext, and ForkServerContext. Its __module__ == 'multiprocessing.context' (23 chars)."
    - "multiprocessing.get_start_method.__name__ == 'get_start_method'. The __name__ attribute of the function matches its Python-level name. This was covered as a __len__() measurement in prior specs; extra40 captures the string equality check."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing exception MRO depths — extra40 namespace
#
# Exception hierarchy MRO depths:
#   ProcessError.__mro__.__len__()        == 4   [ProcessError, Exception, BaseException, object]
#   AuthenticationError.__mro__.__len__() == 5   [AuthenticationError, ProcessError, Exception, BaseException, object]
#   TimeoutError.__mro__.__len__()        == 5   [TimeoutError, ProcessError, Exception, BaseException, object]
#   BufferTooShort.__mro__.__len__()      == 5   [BufferTooShort, ProcessError, Exception, BaseException, object]
# ProcessError is one level shallower (depth 4) because it sits at the root
# of the multiprocessing exception hierarchy. The three subclasses that extend
# ProcessError all have depth 5. Prior specs confirmed base class names (extra39).
# ---------------------------------------------------------------------------

table multiprocessing_extra40.exception_mro_depths:
  description: "multiprocessing exception MRO depths in extra40 namespace — ProcessError (4) vs subclasses (5)"
  kind: python_call_eq
  category: class_names
  id_prefix: mpexcmrolen40

  columns: [id, function, args, expected, description]
  rows:
    - [ProcessError,        ProcessError.__mro__.__len__,        [], 4, "ProcessError.__mro__.__len__() == 4 — MRO: [ProcessError, Exception, BaseException, object]"]
    - [AuthenticationError, AuthenticationError.__mro__.__len__, [], 5, "AuthenticationError.__mro__.__len__() == 5 — MRO: [AuthenticationError, ProcessError, Exception, BaseException, object]"]
    - [TimeoutError,        TimeoutError.__mro__.__len__,        [], 5, "TimeoutError.__mro__.__len__() == 5 — MRO: [TimeoutError, ProcessError, Exception, BaseException, object]"]
    - [BufferTooShort,      BufferTooShort.__mro__.__len__,      [], 5, "BufferTooShort.__mro__.__len__() == 5 — MRO: [BufferTooShort, ProcessError, Exception, BaseException, object]"]

# ---------------------------------------------------------------------------
# multiprocessing.Process qualname — extra40 namespace
#
# Process.__qualname__ == 'Process' (7 chars)
# For top-level classes, __qualname__ equals __name__. Both are 'Process'
# (7 chars: P-r-o-c-e-s-s). Prior specs captured __qualname__ as string
# equality in earlier namespaces; extra40 captures __qualname__.__len__() == 7.
# ---------------------------------------------------------------------------

table multiprocessing_extra40.process_qualname:
  description: "multiprocessing.Process __qualname__ in extra40 namespace — string equality and length"
  kind: python_call_eq
  category: class_names
  id_prefix: mpprocqualname40

  columns: [id, function, args, expected, description]
  rows:
    - [qualname_eq,  Process.__qualname__.__eq__,  ["Process"], true, "Process.__qualname__ == 'Process' — top-level class qualname equals name (7 chars)"]
    - [qualname_len, Process.__qualname__.__len__, [],          7,    "Process.__qualname__.__len__() == 7 — 'Process' has 7 characters"]

# ---------------------------------------------------------------------------
# multiprocessing.context.BaseContext identity — extra40 namespace
#
# multiprocessing.context.BaseContext.__name__ == 'BaseContext'
# BaseContext is the abstract base class for all multiprocessing context
# objects (DefaultContext, ForkContext, SpawnContext, ForkServerContext).
# It is accessible via the context submodule. Its __module__ is
# 'multiprocessing.context' (23 chars), confirming it is defined there.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra40.BaseContext_name_eq:
  description: "multiprocessing.context.BaseContext.__name__ == 'BaseContext' — the abstract base class for all multiprocessing context objects (11 chars)"
  category: class_names
  kind: python_call_eq
  function: context.BaseContext.__name__.__eq__
  args: ["BaseContext"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing.get_start_method function __name__ — extra40 namespace
#
# get_start_method.__name__ == 'get_start_method'
# Prior specs measured get_start_method.__name__.__len__() as an integer.
# Extra40 captures the string equality check confirming the function's name
# attribute exactly matches its Python-level identifier.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra40.get_start_method_name_eq:
  description: "multiprocessing.get_start_method.__name__ == 'get_start_method' — returns the name of the start method used for spawning processes (16 chars)"
  category: function_names
  kind: python_call_eq
  function: get_start_method.__name__.__eq__
  args: ["get_start_method"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — extra40
# ---------------------------------------------------------------------------

invariant multiprocessing_extra40.ProcessError_mro_len:
  description: "multiprocessing.ProcessError.__mro__.__len__() == 4 — MRO is [ProcessError, Exception, BaseException, object]; root of the multiprocessing exception hierarchy"
  category: class_names
  kind: python_call_eq
  function: ProcessError.__mro__.__len__
  args: []
  expected: 4

invariant multiprocessing_extra40.AuthenticationError_mro_len:
  description: "multiprocessing.AuthenticationError.__mro__.__len__() == 5 — MRO is [AuthenticationError, ProcessError, Exception, BaseException, object]"
  category: class_names
  kind: python_call_eq
  function: AuthenticationError.__mro__.__len__
  args: []
  expected: 5

invariant multiprocessing_extra40.TimeoutError_mro_len:
  description: "multiprocessing.TimeoutError.__mro__.__len__() == 5 — MRO is [TimeoutError, ProcessError, Exception, BaseException, object]; distinct from built-in TimeoutError"
  category: class_names
  kind: python_call_eq
  function: TimeoutError.__mro__.__len__
  args: []
  expected: 5

invariant multiprocessing_extra40.BufferTooShort_mro_len:
  description: "multiprocessing.BufferTooShort.__mro__.__len__() == 5 — MRO is [BufferTooShort, ProcessError, Exception, BaseException, object]"
  category: class_names
  kind: python_call_eq
  function: BufferTooShort.__mro__.__len__
  args: []
  expected: 5

invariant multiprocessing_extra40.Process_qualname_eq:
  description: "multiprocessing.Process.__qualname__ == 'Process' — top-level class qualname equals name; 7 chars"
  category: class_names
  kind: python_call_eq
  function: Process.__qualname__.__eq__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra40.Process_qualname_len:
  description: "multiprocessing.Process.__qualname__.__len__() == 7 — 'Process' has 7 characters"
  category: class_names
  kind: python_call_eq
  function: Process.__qualname__.__len__
  args: []
  expected: 7
