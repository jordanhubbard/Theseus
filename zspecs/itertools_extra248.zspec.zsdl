spec: itertools_extra248
version: ">=3.0"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "Python itertools documentation — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.count behavioral contracts — identity, doc, and first-element checks."
    - "itertools.count.__name__ == 'count' — count is a C-level type; its __name__ is 'count'. Verified with Python 3.14.3."
    - "itertools.count.__class__.__name__ == 'type' — count is a C-level type object; its metaclass is 'type'. Verified with Python 3.14.3."
    - "itertools.count.__module__ == 'itertools' — count reports __module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.count.__doc__.__contains__('count') == True — the count docstring references 'count'. Verified with Python 3.14.3."
    - "itertools.count.__doc__.__contains__('step') == True — the count docstring mentions 'step' (the step argument). Verified with Python 3.14.3."
    - "itertools.count(5).__next__() == 5 — count(5) starts at 5; first element is 5. Verified with Python 3.14.3."
    - "itertools.count(0, 2).__next__() == 0 — count(0, 2) starts at 0 with step 2; first element is 0. Verified with Python 3.14.3."
    - "itertools.count(10, 3).__next__() == 10 — count(10, 3) starts at 10 with step 3; first element is 10. Verified with Python 3.14.3."
    - "itertools.count(-1).__next__() == -1 — count(-1) starts at -1; first element is -1. Verified with Python 3.14.3."
    - "count.__name__.__len__() == 5 — 'count' has 5 characters. Verified with Python 3.14.3."
    - "count.__module__.__len__() == 9 — 'itertools' has 9 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.count identity checks
#
# itertools.count.__name__ == 'count'
# itertools.count.__class__.__name__ == 'type'
# itertools.count.__module__ == 'itertools'
# itertools.count.__qualname__ == 'count'
#
# count is a C-level type exposed in the itertools module. Its __name__ is
# 'count', its metaclass is 'type', and its __module__ is 'itertools'.
# New to extra248.
# ---------------------------------------------------------------------------

table itertools_extra248.count_identity:
  description: "itertools.count __name__, __class__.__name__, __module__, __qualname__ identity checks; new to extra248"
  kind: python_call_eq
  category: identity
  id_prefix: count248id

  columns: [id, function, args, expected, description]
  rows:
    - [count_name_eq,
       count.__name__.__eq__,
       ["count"],
       true,
       "itertools.count.__name__.__eq__('count') == True — count is a C-level type in itertools; its __name__ is 'count'; str.__eq__('count') returns True; new to extra248"]
    - [count_class_type,
       count.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.count.__class__.__name__.__eq__('type') == True — count is a C-level type object whose metaclass is the built-in 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra248"]
    - [count_module_eq,
       count.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.count.__module__.__eq__('itertools') == True — count reports __module__ == 'itertools'; str.__eq__('itertools') returns True; new to extra248"]
    - [count_qualname_eq,
       count.__qualname__.__eq__,
       ["count"],
       true,
       "itertools.count.__qualname__.__eq__('count') == True — count is a top-level C type so __qualname__ equals __name__; str.__eq__('count') returns True; new to extra248"]

# ---------------------------------------------------------------------------
# Table 2: itertools.count.__doc__ content checks
#
# itertools.count.__doc__.__contains__('count') == True
# itertools.count.__doc__.__contains__('step') == True
# itertools.count.__doc__.__contains__('nonexistent') == False
# itertools.count.__doc__.__class__.__name__ == 'str'
#
# The count docstring documents the count(start=0, step=1) constructor and
# the step parameter. New to extra248.
# ---------------------------------------------------------------------------

table itertools_extra248.count_doc_checks:
  description: "itertools.count.__doc__ contains 'count', 'step'; not 'nonexistent'; doc is str; new to extra248"
  kind: python_call_eq
  category: doc_checks
  id_prefix: count248id

  columns: [id, function, args, expected, description]
  rows:
    - [doc_contains_count,
       count.__doc__.__contains__,
       ["count"],
       true,
       "itertools.count.__doc__.__contains__('count') == True — the count type docstring references 'count'; str.__contains__('count') returns True; new to extra248"]
    - [doc_contains_step,
       count.__doc__.__contains__,
       ["step"],
       true,
       "itertools.count.__doc__.__contains__('step') == True — the count docstring mentions 'step', the optional step argument; str.__contains__('step') returns True; new to extra248"]
    - [doc_not_contains_nonexistent,
       count.__doc__.__contains__,
       ["nonexistent"],
       false,
       "itertools.count.__doc__.__contains__('nonexistent') == False — 'nonexistent' does not appear in the count docstring; str.__contains__('nonexistent') returns False; new to extra248"]
    - [doc_class_str,
       count.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.count.__doc__.__class__.__name__.__eq__('str') == True — the count docstring is a plain Python str object; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra248"]

# ---------------------------------------------------------------------------
# Standalone first-element invariants — extra248
#
# count(5).__next__() == 5
# count(0, 2).__next__() == 0
# count(10, 3).__next__() == 10
# count(-1).__next__() == -1
#
# count(start, step) returns an infinite iterator; the first element equals
# start regardless of step. New to extra248.
# ---------------------------------------------------------------------------

invariant itertools_extra248.count.first_element_5:
  description: "itertools.count(5).__next__() == 5 — count(5) starts at 5; first element is 5; new to extra248"
  category: first_element
  kind: python_call_eq
  function: count
  args: [5]
  method: __next__
  expected: 5

invariant itertools_extra248.count.first_element_0_2:
  description: "itertools.count(0, 2).__next__() == 0 — count(0, 2) starts at 0 with step 2; first element is 0; new to extra248"
  category: first_element
  kind: python_call_eq
  function: count
  args: [0, 2]
  method: __next__
  expected: 0

invariant itertools_extra248.count.first_element_10_3:
  description: "itertools.count(10, 3).__next__() == 10 — count(10, 3) starts at 10 with step 3; first element is 10; new to extra248"
  category: first_element
  kind: python_call_eq
  function: count
  args: [10, 3]
  method: __next__
  expected: 10

invariant itertools_extra248.count.first_element_neg1:
  description: "itertools.count(-1).__next__() == -1 — count(-1) starts at -1 with default step 1; first element is -1; new to extra248"
  category: first_element
  kind: python_call_eq
  function: count
  args: [-1]
  method: __next__
  expected: -1

# ---------------------------------------------------------------------------
# Additional standalone invariants — extra248
# ---------------------------------------------------------------------------

invariant itertools_extra248.count.name_eq:
  description: "itertools.count.__name__ == 'count' — count is a C-level type; its __name__ is 'count'; new to extra248"
  category: identity
  kind: python_call_eq
  function: count.__name__.__eq__
  args: ["count"]
  expected: true

invariant itertools_extra248.count.class_is_type:
  description: "itertools.count.__class__.__name__ == 'type' — count is a C-level type whose metaclass is 'type'; new to extra248"
  category: identity
  kind: python_call_eq
  function: count.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra248.count.module_is_itertools:
  description: "itertools.count.__module__ == 'itertools' — count reports __module__ == 'itertools'; new to extra248"
  category: identity
  kind: python_call_eq
  function: count.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra248.count.doc_contains_count:
  description: "itertools.count.__doc__.__contains__('count') == True — the count docstring references 'count'; new to extra248"
  category: doc_checks
  kind: python_call_eq
  function: count.__doc__.__contains__
  args: ["count"]
  expected: true

invariant itertools_extra248.count.doc_contains_step:
  description: "itertools.count.__doc__.__contains__('step') == True — the count docstring mentions the step argument; new to extra248"
  category: doc_checks
  kind: python_call_eq
  function: count.__doc__.__contains__
  args: ["step"]
  expected: true

invariant itertools_extra248.count.name_len_5:
  description: "itertools.count.__name__.__len__() == 5 — 'count' has exactly 5 characters; new to extra248"
  category: identity
  kind: python_call_eq
  function: count.__name__.__len__
  args: []
  expected: 5

invariant itertools_extra248.count.module_len_9:
  description: "itertools.count.__module__.__len__() == 9 — 'itertools' has exactly 9 characters; new to extra248"
  category: identity
  kind: python_call_eq
  function: count.__module__.__len__
  args: []
  expected: 9
