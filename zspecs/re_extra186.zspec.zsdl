spec: re_extra186
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "re.escape.__name__=='escape' (len=6); __module__=='re'; __qualname__=='escape'."
    - "re.purge.__name__=='purge' (len=5); __module__=='re'; __qualname__=='purge'."
    - "re.error.__name__=='PatternError' (len=12); __module__=='re' — in Python 3.14.3, re.error is an alias for re.PatternError; the canonical __name__ is 'PatternError'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.escape function identity
# __name__=='escape' (len=6); __module__=='re'; __qualname__=='escape'
# ---------------------------------------------------------------------------

table re_extra186.escape_identity:
  description: "re.escape function identity: __name__=='escape' (len=6); __module__=='re'; __qualname__=='escape'"
  kind: python_call_eq
  category: identity
  id_prefix: reescape186

  columns: [id, function, args, expected, description]
  rows:
    - [esc_name,     escape.__name__.__eq__,     ["escape"],  true,  "re.escape.__name__ == 'escape' — returns string with all non-alphanumerics backslashed; confirmed Python 3.14.3 macOS"]
    - [esc_name_len, escape.__name__.__len__,    [],          6,     "re.escape.__name__.__len__() == 6 — e(1)s(2)c(3)a(4)p(5)e(6); confirmed Python 3.14.3 macOS"]
    - [esc_module,   escape.__module__.__eq__,   ["re"],      true,  "re.escape.__module__ == 're' — defined in the re standard library module; confirmed Python 3.14.3 macOS"]
    - [esc_qualname, escape.__qualname__.__eq__, ["escape"],  true,  "re.escape.__qualname__ == 'escape' — simple unqualified function name; confirmed Python 3.14.3 macOS"]
    - [esc_ne_purge, escape.__name__.__eq__,     ["purge"],   false, "re.escape.__name__.__eq__('purge') == False — escape and purge are distinct functions; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.purge function identity
# __name__=='purge' (len=5); __module__=='re'; __qualname__=='purge'
# ---------------------------------------------------------------------------

table re_extra186.purge_identity:
  description: "re.purge function identity: __name__=='purge' (len=5); __module__=='re'; __qualname__=='purge'"
  kind: python_call_eq
  category: identity
  id_prefix: reescape186

  columns: [id, function, args, expected, description]
  rows:
    - [purge_name,     purge.__name__.__eq__,     ["purge"],  true,  "re.purge.__name__ == 'purge' — clears the regular expression cache; confirmed Python 3.14.3 macOS"]
    - [purge_name_len, purge.__name__.__len__,    [],         5,     "re.purge.__name__.__len__() == 5 — p(1)u(2)r(3)g(4)e(5); confirmed Python 3.14.3 macOS"]
    - [purge_module,   purge.__module__.__eq__,   ["re"],     true,  "re.purge.__module__ == 're' — defined in the re standard library module; confirmed Python 3.14.3 macOS"]
    - [purge_qualname, purge.__qualname__.__eq__, ["purge"],  true,  "re.purge.__qualname__ == 'purge' — simple unqualified function name; confirmed Python 3.14.3 macOS"]
    - [purge_ne_esc,   purge.__name__.__eq__,     ["escape"], false, "re.purge.__name__.__eq__('escape') == False — purge and escape are distinct functions; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.error class identity
# In Python 3.14.3, re.error is an alias for re.PatternError.
# re.error.__name__ == 'PatternError' (len=12); __module__ == 're'
# ---------------------------------------------------------------------------

table re_extra186.error_identity:
  description: "re.error class identity: in Python 3.14.3, re.error is an alias for re.PatternError; __name__=='PatternError' (len=12); __module__=='re'"
  kind: python_call_eq
  category: identity
  id_prefix: reescape186

  columns: [id, function, args, expected, description]
  rows:
    - [err_name,     error.__name__.__eq__,     ["PatternError"],  true,  "re.error.__name__ == 'PatternError' — in Python 3.14.3 re.error is an alias for re.PatternError; confirmed Python 3.14.3 macOS"]
    - [err_name_len, error.__name__.__len__,    [],                12,    "re.error.__name__.__len__() == 12 — P(1)a(2)t(3)t(4)e(5)r(6)n(7)E(8)r(9)r(10)o(11)r(12); confirmed Python 3.14.3 macOS"]
    - [err_module,   error.__module__.__eq__,   ["re"],            true,  "re.error.__module__ == 're' — defined in the re standard library module; confirmed Python 3.14.3 macOS"]
    - [err_ne_esc,   error.__name__.__eq__,     ["escape"],        false, "re.error.__name__.__eq__('escape') == False — error is a class, escape is a function; confirmed Python 3.14.3 macOS"]
    - [err_ne_error, error.__name__.__eq__,     ["error"],         false, "re.error.__name__.__eq__('error') == False — canonical __name__ is 'PatternError' in Python 3.14.3; confirmed Python 3.14.3 macOS"]

