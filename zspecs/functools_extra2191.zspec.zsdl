spec: functools_extra2191
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2191: context manager protocol dict-presence checks — __enter__, __exit__, __aenter__, __aexit__, acquire, release, __wrapped__, __closure__."
    - "functools.RLock is an alias for _thread.RLock and IS a sync context manager with acquire/release."
    - "functools.partial does NOT define __enter__, __exit__, acquire, release, __wrapped__, or __closure__ in its own __dict__."
    - "functools.partialmethod does NOT define any context manager or lock protocol in its own __dict__."
    - "functools.cached_property does NOT define __enter__, __exit__, acquire, release, __wrapped__, or __closure__ in its own __dict__."
    - "functools._lru_cache_wrapper does NOT define __wrapped__ in its own __dict__; __wrapped__ is set as an instance attribute by the lru_cache decorator."
    - "functools._singledispatchmethod_get DOES define __wrapped__ in its own __dict__."
    - "None of the functools classes define __aenter__ or __aexit__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table functools_extra2191.partial_context_protocol:
  description: "functools.partial dict-presence checks for context manager and lock protocol keys"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2191

  columns: [id, function, args, expected]
  rows:
    - ["ft2191001", "functools.partial.__dict__.__contains__", ["__enter__"], false]
    - ["ft2191002", "functools.partial.__dict__.__contains__", ["__exit__"], false]
    - ["ft2191003", "functools.partial.__dict__.__contains__", ["__aenter__"], false]
    - ["ft2191004", "functools.partial.__dict__.__contains__", ["__aexit__"], false]
    - ["ft2191005", "functools.partial.__dict__.__contains__", ["acquire"], false]
    - ["ft2191006", "functools.partial.__dict__.__contains__", ["release"], false]
    - ["ft2191007", "functools.partial.__dict__.__contains__", ["__wrapped__"], false]
    - ["ft2191008", "functools.partial.__dict__.__contains__", ["__closure__"], false]

table functools_extra2191.rlock_context_protocol:
  description: "functools.RLock dict-presence checks — RLock is a full sync context manager and lock"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2191

  columns: [id, function, args, expected]
  rows:
    - ["ft2191009", "functools.RLock.__dict__.__contains__", ["__enter__"], true]
    - ["ft2191010", "functools.RLock.__dict__.__contains__", ["__exit__"], true]
    - ["ft2191011", "functools.RLock.__dict__.__contains__", ["__aenter__"], false]
    - ["ft2191012", "functools.RLock.__dict__.__contains__", ["__aexit__"], false]
    - ["ft2191013", "functools.RLock.__dict__.__contains__", ["acquire"], true]
    - ["ft2191014", "functools.RLock.__dict__.__contains__", ["release"], true]
    - ["ft2191015", "functools.RLock.__dict__.__contains__", ["__wrapped__"], false]
    - ["ft2191016", "functools.RLock.__dict__.__contains__", ["__closure__"], false]

