spec: crc32
version: ">=0.2.2"
backend: node(crc32)

docs: https://www.npmjs.com/package/crc32

provenance:
  derived_from:
    - "crc32 README — https://www.npmjs.com/package/crc32"
    - "Test vectors verified with crc32 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "crc32 source"
  notes:
    - "crc32 is an npm package. Install: npm install crc32"
    - "Returns the CRC-32 checksum of a string as an 8-character hex string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an 8-character hex string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table crc32.hash:
  kind: node_module_call_eq
  function: ~
  category: crypto
  id_prefix: crc32

  columns: [id, args, expected]
  rows:
    - [hello,  ["hello"],  "3610a686"]
    - [world,  ["world"],  "3a771143"]
    - [empty,  [""],       "0"]
