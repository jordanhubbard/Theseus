spec: marshal_extra7
version: ">=3.9"
backend: python_module(marshal)

docs: https://docs.python.org/3/library/marshal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/marshal.html — Python marshal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/marshal.c"
  notes:
    - "This spec extends marshal.zspec.zsdl through marshal_extra6.zspec.zsdl."
    - "marshal_extra6 covers: version == 5 standalone; version.__le__(10); function __qualname__ table (re-anchor fq6); function __module__ table (re-anchor fm6); version.__class__.__name__."
    - "marshal_extra5 covers: __name__ table anchor; version.__class__.__name__; dumps(42).__class__.__name__; roundtrip int 42 / str 'hello' / list [1,2,3]."
    - "marshal_extra4 covers: function __class__.__name__ table; roundtrip {} and b'hello'."
    - "marshal_extra3 covers: function __module__ (all 'marshal'); version >= 3 and <= 10."
    - "marshal_extra2 covers: version >= 2; __qualname__ for all four functions; roundtrip True/False/-1."
    - "Focus: new axes — marshal.__name__; marshal.__package__; marshal.__spec__.name; marshal.__spec__.origin; version.__ge__(5)."
    - "marshal.__name__ == 'marshal' — module identity; no prior marshal spec checks __name__ at the module object level (marshal_extra5 checks function __name__ values in a table, not module __name__)."
    - "marshal.__package__ == '' — marshal is a built-in module with no parent package; no prior spec checks __package__."
    - "marshal.__spec__.name == 'marshal' — importlib ModuleSpec name field; no prior spec checks marshal.__spec__.name."
    - "marshal.__spec__.origin == 'built-in' — marshal is a C extension loaded as a built-in; no prior spec checks this."
    - "marshal.version.__ge__(5) == True — lower-bound guard at version 5; marshal_extra3 checks >= 3, not >= 5."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# marshal module identity — __name__ and __package__
#
# marshal_extra5 checks function __name__ values in a table using the module
# backend (so those are function names, not the module's own __name__).
# No prior marshal spec checks __name__ or __package__ at the module level.
# ---------------------------------------------------------------------------

invariant marshal_extra7.module.name:
  description: "marshal.__name__ == 'marshal' — module identity name"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["marshal"]
  expected: true

invariant marshal_extra7.module.package:
  description: "marshal.__package__ == '' — built-in module has no parent package"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# marshal.__spec__ — ModuleSpec fields
#
# marshal is imported as a built-in C extension. Its __spec__.name equals the
# module name and __spec__.origin is 'built-in'. No prior marshal spec checks
# any __spec__ field.
# ---------------------------------------------------------------------------

invariant marshal_extra7.spec.name:
  description: "marshal.__spec__.name == 'marshal' — importlib ModuleSpec name"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["marshal"]
  expected: true

invariant marshal_extra7.spec.origin:
  description: "marshal.__spec__.origin == 'built-in' — C built-in module origin"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.origin.__eq__
  args: ["built-in"]
  expected: true

# ---------------------------------------------------------------------------
# marshal.version lower-bound at 5
#
# marshal_extra3 checks version >= 3; no prior spec checks version >= 5.
# marshal.version == 5 in CPython 3.4+ (verified 5 on Python 3.12).
# ---------------------------------------------------------------------------

invariant marshal_extra7.version.ge5:
  description: "marshal.version >= 5 — version lower-bound guard at 5"
  category: constants
  kind: python_call_eq
  function: version.__ge__
  args: [5]
  expected: true
