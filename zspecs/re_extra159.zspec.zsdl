spec: re_extra159
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.Pattern method __qualname__ length values for all eight primary Pattern methods."
    - "All re.Pattern method qualnames use the 'Pattern.' prefix (8 characters). The lengths are: sub=11, subn=12, match=13, split=13, search=14, findall=15, finditer=16, fullmatch=17."
    - "re.Pattern.match.__qualname__.__len__() == 13 ('Pattern.' (8) + 'match' (5) = 13; established in re_extra158)."
    - "re.Pattern.search.__qualname__.__len__() == 14 ('Pattern.' (8) + 'search' (6) = 14; established in re_extra158)."
    - "re.Pattern.sub.__qualname__.__len__() == 11 ('Pattern.' (8) + 'sub' (3) = 11; established in re_extra158)."
    - "re.Pattern.subn.__qualname__.__len__() == 12 ('Pattern.' (8) + 'subn' (4) = 12)."
    - "re.Pattern.split.__qualname__.__len__() == 13 ('Pattern.' (8) + 'split' (5) = 13; tied with 'Pattern.match' at 13)."
    - "re.Pattern.findall.__qualname__.__len__() == 15 ('Pattern.' (8) + 'findall' (7) = 15)."
    - "re.Pattern.finditer.__qualname__.__len__() == 16 ('Pattern.' (8) + 'finditer' (8) = 16)."
    - "re.Pattern.fullmatch.__qualname__.__len__() == 17 ('Pattern.' (8) + 'fullmatch' (9) = 17; the longest Pattern method qualname)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern method __qualname__ lengths (group 1: sub, subn, match, split)
# sub=11, subn=12, match=13, split=13
# 'Pattern.' prefix = 8 characters for all methods.
# sub and subn are the two shortest; match and split are tied at 13.
# ---------------------------------------------------------------------------

table re_extra159.Pattern_qualname_lengths_group1:
  description: "re.Pattern method __qualname__ lengths: sub=11, subn=12, match=13, split=13; sub is shortest, match and split are tied; all use 'Pattern.' (8-char) prefix"
  kind: python_call_eq
  category: qualname
  id_prefix: repatqlen159

  columns: [id, function, args, expected, description]
  rows:
    - [sub_qlen,   Pattern.sub.__qualname__.__len__,   [], 11, "re.Pattern.sub.__qualname__.__len__() == 11 ('Pattern.sub' has 11 characters: 'Pattern.' (8) + 'sub' (3) = 11; Pattern.sub() replaces occurrences of the pattern with a replacement string or callable; it is the shortest Pattern method qualname along with Pattern.sub being established in re_extra158; 'sub' (3 chars) is the shortest method name among the eight primary Pattern methods)"]
    - [subn_qlen,  Pattern.subn.__qualname__.__len__,  [], 12, "re.Pattern.subn.__qualname__.__len__() == 12 ('Pattern.subn' has 12 characters: 'Pattern.' (8) + 'subn' (4) = 12; Pattern.subn() is like sub() but also returns the substitution count as a 2-tuple (new_string, count); 'subn' (4 chars) is one character longer than 'sub' (3 chars); the 'n' suffix stands for 'number' indicating the count return value; subn qualname length 12 falls between sub (11) and match/split (13))"]
    - [match_qlen, Pattern.match.__qualname__.__len__,  [], 13, "re.Pattern.match.__qualname__.__len__() == 13 ('Pattern.match' has 13 characters: 'Pattern.' (8) + 'match' (5) = 13; established in re_extra158; Pattern.match() attempts to apply the pattern at the start of the string (anchored match); match() returns a Match object or None; 'Pattern.match' (13) is tied with 'Pattern.split' (13) — both have 5-character method names)"]
    - [split_qlen, Pattern.split.__qualname__.__len__,  [], 13, "re.Pattern.split.__qualname__.__len__() == 13 ('Pattern.split' has 13 characters: 'Pattern.' (8) + 'split' (5) = 13; Pattern.split() splits the string by occurrences of the pattern, returning a list; accepts a maxsplit parameter; 'Pattern.split' (13) is tied with 'Pattern.match' (13) — both 5-character method names produce the same qualname length; split() is the opposite of sub() in terms of the pattern's role)"]

# ---------------------------------------------------------------------------
# re.Pattern method __qualname__ lengths (group 2: search, findall, finditer, fullmatch)
# search=14, findall=15, finditer=16, fullmatch=17
# These are the four longest Pattern method qualnames.
# fullmatch (17) is the longest of all eight Pattern method qualnames.
# ---------------------------------------------------------------------------

table re_extra159.Pattern_qualname_lengths_group2:
  description: "re.Pattern method __qualname__ lengths: search=14, findall=15, finditer=16, fullmatch=17; these are the four longest Pattern method qualnames; fullmatch is the longest at 17"
  kind: python_call_eq
  category: qualname
  id_prefix: repatqlen159

  columns: [id, function, args, expected, description]
  rows:
    - [search_qlen,    Pattern.search.__qualname__.__len__,    [], 14, "re.Pattern.search.__qualname__.__len__() == 14 ('Pattern.search' has 14 characters: 'Pattern.' (8) + 'search' (6) = 14; established in re_extra158; Pattern.search() scans through the string to find the first location where the pattern produces a match; unlike match(), search() is not anchored to the start; 'Pattern.search' (14) is one character longer than 'Pattern.match' (13) and one shorter than 'Pattern.findall' (15))"]
    - [findall_qlen,   Pattern.findall.__qualname__.__len__,   [], 15, "re.Pattern.findall.__qualname__.__len__() == 15 ('Pattern.findall' has 15 characters: 'Pattern.' (8) + 'findall' (7) = 15; Pattern.findall() returns all non-overlapping matches of the pattern in the string as a list; if the pattern contains groups, it returns a list of groups; 'Pattern.findall' (15) is the middle value among the four long qualnames: search (14), findall (15), finditer (16), fullmatch (17); consecutive 4-value run from 14 to 17)"]
    - [finditer_qlen,  Pattern.finditer.__qualname__.__len__,  [], 16, "re.Pattern.finditer.__qualname__.__len__() == 16 ('Pattern.finditer' has 16 characters: 'Pattern.' (8) + 'finditer' (8) = 16; Pattern.finditer() returns an iterator yielding Match objects over all non-overlapping matches; unlike findall() which returns a list, finditer() is memory-efficient for large strings; 'Pattern.finditer' (16): 'finditer' (8 chars) equals the 'Pattern.' prefix length (8 chars) — the same elegant symmetry seen in decimal.Context.quantize)"]
    - [fullmatch_qlen, Pattern.fullmatch.__qualname__.__len__, [], 17, "re.Pattern.fullmatch.__qualname__.__len__() == 17 ('Pattern.fullmatch' has 17 characters: 'Pattern.' (8) + 'fullmatch' (9) = 17; the longest Pattern method qualname of all eight primary methods; Pattern.fullmatch() matches the entire string against the pattern (anchored at both start and end), returning Match or None; added in Python 3.4; 'fullmatch' (9 chars) is the longest method name, making 'Pattern.fullmatch' the overall longest Pattern method qualname)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra159.Pattern_fullmatch_is_longest_qualname:
  description: "re.Pattern.fullmatch.__qualname__.__len__() == 17 — 'Pattern.fullmatch' is the longest of all eight primary Pattern method qualnames; the complete length ranking is: sub=11, subn=12, match=13, split=13, search=14, findall=15, finditer=16, fullmatch=17; fullmatch() was added in Python 3.4 and requires the entire string to match (anchored both start and end); 'fullmatch' (9 chars) is one character longer than 'finditer' (8 chars); confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Pattern.fullmatch.__qualname__.__len__
  args: []
  expected: 17

invariant re_extra159.Pattern_finditer_qualname_eq:
  description: "re.Pattern.finditer.__qualname__ == 'Pattern.finditer' — finditer() is the iterator-based version of findall() yielding Match objects rather than strings; its qualname uses the public class name 'Pattern' consistent with all Pattern methods; 'Pattern.finditer' has 16 characters where 'finditer' (8 chars) equals the 'Pattern.' prefix length (8 chars) — this 8+8=16 symmetry also appears in decimal.Context.finditer-equivalent methods; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Pattern.finditer.__qualname__.__eq__
  args: ["Pattern.finditer"]
  expected: true

invariant re_extra159.Pattern_sub_is_shortest_qualname:
  description: "re.Pattern.sub.__qualname__.__len__() == 11 — 'Pattern.sub' is the shortest of all eight primary Pattern method qualnames at 11 characters; 'sub' (3 chars) is the shortest method name; the complete ascending order by length is: sub (11), subn (12), match=split (13), search (14), findall (15), finditer (16), fullmatch (17); the range from shortest (11) to longest (17) spans 6 characters; all qualnames share the fixed 'Pattern.' (8-char) prefix; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Pattern.sub.__qualname__.__len__
  args: []
  expected: 11

invariant re_extra159.Pattern_match_split_tied_at_13:
  description: "re.Pattern.match.__qualname__.__len__() == re.Pattern.split.__qualname__.__len__() == 13 — match and split are the only two Pattern methods whose qualnames are tied in length; both 'match' and 'split' are 5-character method names, producing qualnames of 13 characters each: 'Pattern.' (8) + 5 = 13; Pattern.match() matches anchored at the start, while Pattern.split() splits the string by pattern occurrences — conceptually opposite operations that share the same qualname length; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Pattern.split.__qualname__.__len__
  args: []
  expected: 13

