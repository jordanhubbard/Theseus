spec: io_extra242
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/_iomodule.c"
    - "_io.zspec.zsdl — covers BytesIO getvalue length (5), tell initial (0), read all, readable, seekable"
  notes:
    - "This spec covers: io.BytesIO slice and index access contracts — getvalue length, tell position, read length, and class identity."
    - "_io.zspec.zsdl covers: BytesIO(b'hello').getvalue().__len__()==5, tell()==0, read()==b'hello'. This spec adds BytesIO(b'abc') (len=3), BytesIO(b'') empty (len=0), read().__class__.__name__=='bytes', and getvalue().__class__.__name__=='bytes'."
    - "io.BytesIO(b'hello').getvalue().__len__() == 5 — byte string 'hello' has 5 bytes; verified Python 3.14.3 macOS."
    - "io.BytesIO(b'').getvalue().__len__() == 0 — empty BytesIO getvalue has zero length; verified Python 3.14.3 macOS."
    - "io.BytesIO(b'abc').getvalue().__len__() == 3 — 3-byte buffer has length 3; verified Python 3.14.3 macOS."
    - "io.BytesIO(b'hello').tell() == 0 — initial stream position is 0 before any read; verified Python 3.14.3 macOS."
    - "io.BytesIO(b'hello').read().__len__() == 5 — full read from position 0 returns 5 bytes; verified Python 3.14.3 macOS."
    - "io.BytesIO(b'').read().__len__() == 0 — full read from empty BytesIO returns 0 bytes; verified Python 3.14.3 macOS."
    - "io.BytesIO(b'hello').getvalue().__class__.__name__ == 'bytes' — getvalue returns a bytes object; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO.getvalue() length contracts
# getvalue() returns the entire buffer as a bytes object regardless of position.
# args use {type: bytes_ascii, value: "..."} to represent bytes literals.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra242.BytesIO.getvalue.len_hello:
  description: "io.BytesIO(b'hello').getvalue().__len__() == 5 — byte string b'hello' has 5 bytes; verified Python 3.14.3 macOS"
  category: getvalue_behavior
  kind: python_call_eq
  function: BytesIO
  args: [{type: bytes_ascii, value: "hello"}]
  method: getvalue
  method_chain: __len__
  expected: 5

invariant io_extra242.BytesIO.getvalue.len_empty:
  description: "io.BytesIO(b'').getvalue().__len__() == 0 — empty BytesIO getvalue has zero length; verified Python 3.14.3 macOS"
  category: getvalue_behavior
  kind: python_call_eq
  function: BytesIO
  args: [{type: bytes_ascii, value: ""}]
  method: getvalue
  method_chain: __len__
  expected: 0

invariant io_extra242.BytesIO.getvalue.len_abc:
  description: "io.BytesIO(b'abc').getvalue().__len__() == 3 — 3-byte buffer yields length 3; verified Python 3.14.3 macOS"
  category: getvalue_behavior
  kind: python_call_eq
  function: BytesIO
  args: [{type: bytes_ascii, value: "abc"}]
  method: getvalue
  method_chain: __len__
  expected: 3

invariant io_extra242.BytesIO.getvalue.class_name:
  description: "io.BytesIO(b'hello').getvalue().__class__.__name__ == 'bytes' — getvalue returns a bytes object; verified Python 3.14.3 macOS"
  category: getvalue_behavior
  kind: python_call_eq
  function: BytesIO
  args: [{type: bytes_ascii, value: "hello"}]
  method: getvalue
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# io.BytesIO.tell() positional contracts
# tell() returns the current stream position as a non-negative integer.
# Initial position before any read is always 0.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra242.BytesIO.tell.initial_zero:
  description: "io.BytesIO(b'hello').tell() == 0 — initial stream position is 0 before any read; verified Python 3.14.3 macOS"
  category: tell_behavior
  kind: python_call_eq
  function: BytesIO
  args: [{type: bytes_ascii, value: "hello"}]
  method: tell
  method_args: []
  expected: 0

invariant io_extra242.BytesIO.tell.empty_initial_zero:
  description: "io.BytesIO(b'').tell() == 0 — initial stream position of empty BytesIO is 0; verified Python 3.14.3 macOS"
  category: tell_behavior
  kind: python_call_eq
  function: BytesIO
  args: [{type: bytes_ascii, value: ""}]
  method: tell
  method_args: []
  expected: 0

# ---------------------------------------------------------------------------
# io.BytesIO.read() length contracts
# read() reads from current position to end; returns a bytes object.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra242.BytesIO.read.len_hello:
  description: "io.BytesIO(b'hello').read().__len__() == 5 — full read from position 0 returns 5 bytes; verified Python 3.14.3 macOS"
  category: read_behavior
  kind: python_call_eq
  function: BytesIO
  args: [{type: bytes_ascii, value: "hello"}]
  method: read
  method_chain: __len__
  expected: 5

invariant io_extra242.BytesIO.read.len_empty:
  description: "io.BytesIO(b'').read().__len__() == 0 — full read from empty BytesIO returns 0 bytes; verified Python 3.14.3 macOS"
  category: read_behavior
  kind: python_call_eq
  function: BytesIO
  args: [{type: bytes_ascii, value: ""}]
  method: read
  method_chain: __len__
  expected: 0

# ---------------------------------------------------------------------------
# io.BytesIO class identity spot-checks
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra242.BytesIO_class_identity:
  description: "io.BytesIO class __name__ and __module__ identity spot-checks; verified Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: iobytesio242

  columns: [id, function, args, expected]
  rows:
    - [name_eq,    BytesIO.__name__.__eq__,    ["BytesIO"], true]
    - [module_eq,  BytesIO.__module__.__eq__,  ["_io"],     true]
    - [name_len,   BytesIO.__name__.__len__,   [],          7]
    - [module_len, BytesIO.__module__.__len__, [],          3]
