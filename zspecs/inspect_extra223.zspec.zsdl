spec: inspect_extra223
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect Signature, Parameter, BoundArguments, and FrameInfo class identity contracts."
    - "inspect.Signature.__bases__[0].__name__ == 'object' — Signature inherits directly from object. Verified with Python 3.14.3."
    - "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter inherits directly from object. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__name__ == 'BoundArguments'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__bases__[0].__name__ == 'object' — BoundArguments inherits directly from object. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__qualname__ == 'BoundArguments'. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__class__.__name__ == 'type' — empty is a sentinel class (not an instance). Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo' — FrameInfo inherits from the internal _FrameInfo namedtuple base. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect Signature, Parameter, BoundArguments, FrameInfo base class checks
#
# Verified with Python 3.14.3:
#   inspect.Signature.__bases__[0].__name__ == 'object'
#   inspect.Parameter.__bases__[0].__name__ == 'object'
#   inspect.BoundArguments.__bases__[0].__name__ == 'object'
#   inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo'
# ---------------------------------------------------------------------------

table inspect_extra223.class_bases:
  description: "inspect Signature, Parameter, BoundArguments, FrameInfo __bases__[0].__name__ checks; new to extra223"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra223classbases

  columns: [id, function, args, expected, description]
  rows:
    - [signature_base_name_eq,
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature is a plain Python class in Lib/inspect.py with no intermediate base; __bases__[0] is object; str.__eq__('object') returns True; new to extra223"]
    - [parameter_base_name_eq,
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter is a plain Python class in Lib/inspect.py with no intermediate base; __bases__[0] is object; str.__eq__('object') returns True; new to extra223"]
    - [bound_arguments_base_name_eq,
       "BoundArguments.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__bases__[0].__name__.__eq__('object') == True — BoundArguments is a plain Python class in Lib/inspect.py with no intermediate base; __bases__[0] is object; str.__eq__('object') returns True; new to extra223"]
    - [frameinfo_base_name_eq,
       "FrameInfo.__bases__[0].__name__.__eq__",
       ["_FrameInfo"],
       true,
       "inspect.FrameInfo.__bases__[0].__name__.__eq__('_FrameInfo') == True — FrameInfo inherits from the internal _FrameInfo helper class; __bases__[0] is _FrameInfo; str.__eq__('_FrameInfo') returns True; new to extra223"]

# ---------------------------------------------------------------------------
# Table 2: inspect BoundArguments identity checks
#
# Verified with Python 3.14.3:
#   inspect.BoundArguments.__name__ == 'BoundArguments'
#   inspect.BoundArguments.__module__ == 'inspect'
#   inspect.BoundArguments.__qualname__ == 'BoundArguments'
# ---------------------------------------------------------------------------

table inspect_extra223.bound_arguments_identity:
  description: "inspect.BoundArguments __name__, __module__, __qualname__ identity checks; new to extra223"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra223boundargid

  columns: [id, function, args, expected, description]
  rows:
    - [bound_arguments_name_eq,
       BoundArguments.__name__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — BoundArguments is a Python class defined in Lib/inspect.py; __name__ is 'BoundArguments'; str.__eq__('BoundArguments') returns True; new to extra223"]
    - [bound_arguments_module_eq,
       BoundArguments.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is defined in the inspect module; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra223"]
    - [bound_arguments_qualname_eq,
       BoundArguments.__qualname__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__qualname__.__eq__('BoundArguments') == True — BoundArguments is defined at module scope; __qualname__ is 'BoundArguments' (no enclosing scope prefix); str.__eq__('BoundArguments') returns True; new to extra223"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter sentinel and kind __class__.__name__ checks
#
# Verified with Python 3.14.3:
#   inspect.Parameter.empty.__class__.__name__ == 'type'
#   inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'
#   inspect.Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind'
#   inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind'
# ---------------------------------------------------------------------------

table inspect_extra223.parameter_kind_types:
  description: "inspect.Parameter sentinel and kind constant __class__.__name__ type checks; new to extra223"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra223paramkind

  columns: [id, function, args, expected, description]
  rows:
    - [param_empty_class_name_eq,
       Parameter.empty.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is a sentinel class (the class object itself, not an instance); its metaclass is 'type'; str.__eq__('type') returns True; new to extra223"]
    - [param_positional_only_class_name_eq,
       Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is an instance of the _ParameterKind enum; __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra223"]
    - [param_var_keyword_class_name_eq,
       Parameter.VAR_KEYWORD.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — VAR_KEYWORD is an instance of the _ParameterKind enum; __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra223"]
    - [param_keyword_only_class_name_eq,
       Parameter.KEYWORD_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — KEYWORD_ONLY is an instance of the _ParameterKind enum; __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra223"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra223
# ---------------------------------------------------------------------------

invariant inspect_extra223.Signature_bases_name:
  description: "inspect.Signature.__bases__[0].__name__ == 'object' — Signature's sole base class is object; new to extra223"
  kind: python_call_eq
  function: Signature.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant inspect_extra223.Parameter_bases_name:
  description: "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter's sole base class is object; new to extra223"
  kind: python_call_eq
  function: Parameter.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant inspect_extra223.BoundArguments_bases_name:
  description: "inspect.BoundArguments.__bases__[0].__name__ == 'object' — BoundArguments's sole base class is object; new to extra223"
  kind: python_call_eq
  function: BoundArguments.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant inspect_extra223.FrameInfo_bases_name:
  description: "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo' — FrameInfo's base class is the internal _FrameInfo; new to extra223"
  kind: python_call_eq
  function: FrameInfo.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_FrameInfo"

invariant inspect_extra223.BoundArguments_name:
  description: "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — BoundArguments __name__ is 'BoundArguments'; new to extra223"
  kind: python_call_eq
  function: BoundArguments.__name__.__eq__
  args: ["BoundArguments"]
  expected: true

invariant inspect_extra223.BoundArguments_module:
  description: "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments __module__ is 'inspect'; new to extra223"
  kind: python_call_eq
  function: BoundArguments.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra223.BoundArguments_qualname:
  description: "inspect.BoundArguments.__qualname__.__eq__('BoundArguments') == True — BoundArguments __qualname__ is 'BoundArguments'; new to extra223"
  kind: python_call_eq
  function: BoundArguments.__qualname__.__eq__
  args: ["BoundArguments"]
  expected: true

invariant inspect_extra223.Parameter_empty_class_name:
  description: "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is a sentinel class; new to extra223"
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra223.Parameter_POSITIONAL_ONLY_class_name:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is a _ParameterKind enum instance; new to extra223"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra223.Parameter_VAR_KEYWORD_class_name:
  description: "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — VAR_KEYWORD is a _ParameterKind enum instance; new to extra223"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra223.Parameter_KEYWORD_ONLY_class_name:
  description: "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — KEYWORD_ONLY is a _ParameterKind enum instance; new to extra223"
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true
