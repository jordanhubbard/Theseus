spec: struct_extra262
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths and Struct.size/format descriptor __doc__ strings."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() values."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__()."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() values."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality and Struct.format/__qualname__."
    - "struct_extra92.zspec.zsdl — covers struct module-level function __class__.__name__ and Struct method __class__.__name__."
  notes:
    - "struct.Struct.pack.__name__ == 'pack' and __class__.__name__ == 'method_descriptor' — Struct.pack is a C-level method_descriptor on the Struct type from _struct.c. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct.unpack.__name__ == 'unpack' and __class__.__name__ == 'method_descriptor' — Struct.unpack is a C-level method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct.pack_into.__name__ == 'pack_into' and __class__.__name__ == 'method_descriptor' — Struct.pack_into is a C-level method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct.unpack_from.__name__ == 'unpack_from' and __class__.__name__ == 'method_descriptor' — Struct.unpack_from is a C-level method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct.iter_unpack.__name__ == 'iter_unpack' and __class__.__name__ == 'method_descriptor' — Struct.iter_unpack is a C-level method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct.pack.__qualname__ == 'Struct.pack' — qualname has 'Struct.' prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack' — qualname has 'Struct.' prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct.size is a getset_descriptor — type(struct.Struct.size).__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct.format is a getset_descriptor — type(struct.Struct.format).__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct method __name__ identity — pack, unpack, pack_into, unpack_from, iter_unpack
# All five are C-level method_descriptor objects on the Struct type from _struct.c.
# __class__.__name__ == 'method_descriptor' for all of them.
# ---------------------------------------------------------------------------

table struct_extra262.Struct_method_name_identity:
  description: "struct.Struct pack/unpack/pack_into/unpack_from/iter_unpack method __name__ equality — all C-level method_descriptor objects on the Struct type from _struct.c; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structmeth262

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name,        Struct.pack.__name__.__eq__,        ["pack"],        true, "struct.Struct.pack.__name__ == 'pack' — C method_descriptor on Struct"]
    - [unpack_name,      Struct.unpack.__name__.__eq__,      ["unpack"],      true, "struct.Struct.unpack.__name__ == 'unpack' — C method_descriptor on Struct"]
    - [pack_into_name,   Struct.pack_into.__name__.__eq__,   ["pack_into"],   true, "struct.Struct.pack_into.__name__ == 'pack_into' — C method_descriptor on Struct"]
    - [unpack_from_name, Struct.unpack_from.__name__.__eq__, ["unpack_from"], true, "struct.Struct.unpack_from.__name__ == 'unpack_from' — C method_descriptor on Struct"]
    - [iter_unpack_name, Struct.iter_unpack.__name__.__eq__, ["iter_unpack"], true, "struct.Struct.iter_unpack.__name__ == 'iter_unpack' — C method_descriptor on Struct"]

# ---------------------------------------------------------------------------
# struct.Struct method __class__.__name__ identity
# All five Struct methods are C-level method_descriptor objects.
# ---------------------------------------------------------------------------

table struct_extra262.Struct_method_class_identity:
  description: "struct.Struct pack/unpack/pack_into/unpack_from/iter_unpack method __class__.__name__ == 'method_descriptor' — all C-level descriptors from _struct.c; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structmethcls262

  columns: [id, function, args, expected, description]
  rows:
    - [pack_class,        Struct.pack.__class__.__name__.__eq__,        ["method_descriptor"], true, "struct.Struct.pack.__class__.__name__ == 'method_descriptor' — C-level descriptor"]
    - [unpack_class,      Struct.unpack.__class__.__name__.__eq__,      ["method_descriptor"], true, "struct.Struct.unpack.__class__.__name__ == 'method_descriptor' — C-level descriptor"]
    - [pack_into_class,   Struct.pack_into.__class__.__name__.__eq__,   ["method_descriptor"], true, "struct.Struct.pack_into.__class__.__name__ == 'method_descriptor' — C-level descriptor"]
    - [unpack_from_class, Struct.unpack_from.__class__.__name__.__eq__, ["method_descriptor"], true, "struct.Struct.unpack_from.__class__.__name__ == 'method_descriptor' — C-level descriptor"]
    - [iter_unpack_class, Struct.iter_unpack.__class__.__name__.__eq__, ["method_descriptor"], true, "struct.Struct.iter_unpack.__class__.__name__ == 'method_descriptor' — C-level descriptor"]

# ---------------------------------------------------------------------------
# struct.Struct method qualname identity — pack, unpack, pack_into, unpack_from, iter_unpack
# All qualnames have the 'Struct.' prefix.
# ---------------------------------------------------------------------------

invariant struct_extra262.Struct_pack_qualname_eq:
  description: "struct.Struct.pack.__qualname__ == 'Struct.pack' — C method_descriptor qualname has 'Struct.' prefix confirming class membership; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: Struct.pack.__qualname__.__eq__
  args: ["Struct.pack"]
  expected: true

invariant struct_extra262.Struct_unpack_qualname_eq:
  description: "struct.Struct.unpack.__qualname__ == 'Struct.unpack' — C method_descriptor qualname has 'Struct.' prefix; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: Struct.unpack.__qualname__.__eq__
  args: ["Struct.unpack"]
  expected: true

invariant struct_extra262.Struct_pack_into_qualname_eq:
  description: "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into' — C method_descriptor qualname has 'Struct.' prefix; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: Struct.pack_into.__qualname__.__eq__
  args: ["Struct.pack_into"]
  expected: true

invariant struct_extra262.Struct_unpack_from_qualname_eq:
  description: "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from' — C method_descriptor qualname has 'Struct.' prefix; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: Struct.unpack_from.__qualname__.__eq__
  args: ["Struct.unpack_from"]
  expected: true

invariant struct_extra262.Struct_iter_unpack_qualname_eq:
  description: "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack' — C method_descriptor qualname has 'Struct.' prefix; iter_unpack returns an iterator over repeated unpacking; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: Struct.iter_unpack.__qualname__.__eq__
  args: ["Struct.iter_unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.size and struct.Struct.format are getset_descriptors
# type(struct.Struct.size).__name__ == 'getset_descriptor'
# type(struct.Struct.format).__name__ == 'getset_descriptor'
# ---------------------------------------------------------------------------

invariant struct_extra262.Struct_size_type_name_eq:
  description: "type(struct.Struct.size).__name__ == 'getset_descriptor' — Struct.size is a getset_descriptor C-level attribute (not a property); it has no fget; defined in _struct.c; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: Struct.size.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant struct_extra262.Struct_format_type_name_eq:
  description: "type(struct.Struct.format).__name__ == 'getset_descriptor' — Struct.format is a getset_descriptor C-level attribute (not a property); it has no fget; defined in _struct.c; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: Struct.format.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true
