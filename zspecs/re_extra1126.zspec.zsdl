spec: re_extra1126
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module RegexFlag enum member __class__.__name__ documentation for IGNORECASE, MULTILINE, DOTALL, VERBOSE, ASCII, UNICODE, NOFLAG, LOCALE"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.IGNORECASE/__class__.__name__, re.MULTILINE/__class__.__name__, re.DOTALL/__class__.__name__, re.VERBOSE/__class__.__name__, re.ASCII/__class__.__name__, re.UNICODE/__class__.__name__, re.LOCALE/__class__.__name__ — all are RegexFlag; also checks integer values of each flag; re.NOFLAG class name was in _extra1096 but the remaining flag members were not covered in _extra1096 or _extra1111"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1126.flag_class_names_group1:
  description: "re.IGNORECASE, re.MULTILINE, re.DOTALL, re.VERBOSE __class__.__name__ checks — all must be RegexFlag"
  kind: python_call_eq
  category: flag_class_names_group1
  id_prefix: re1126f1
  columns: [id, function, args, expected]
  rows:
    - [re1126f1001, re.IGNORECASE.__class__.__name__.__eq__,  ["RegexFlag"], true]
    - [re1126f1002, re.MULTILINE.__class__.__name__.__eq__,   ["RegexFlag"], true]
    - [re1126f1003, re.DOTALL.__class__.__name__.__eq__,      ["RegexFlag"], true]
    - [re1126f1004, re.VERBOSE.__class__.__name__.__eq__,     ["RegexFlag"], true]
    - [re1126f1005, re.IGNORECASE.__class__.__name__.__eq__,  ["int"],       false]
    - [re1126f1006, re.MULTILINE.__class__.__name__.__eq__,   ["int"],       false]
    - [re1126f1007, re.DOTALL.__class__.__name__.__eq__,      ["str"],       false]

