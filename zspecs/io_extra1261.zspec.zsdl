spec: io_extra1261
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "Wave 531 spec: focuses on io.__all__.__contains__ membership checks."
    - "io has __all__ (a list of 24 names); type confirmed as list via __all__.__class__.__name__=='list'."
    - "io.__all__.__len__() == 24 (established in io_extra98)."
    - "This wave checks __contains__ for names IN __all__: BufferedWriter, BufferedRandom, BufferedRWPair, BufferedIOBase, SEEK_SET, SEEK_CUR, SEEK_END, DEFAULT_BUFFER_SIZE, IncrementalNewlineDecoder, Reader, text_encoding, open_code."
    - "This wave checks __contains__ for names NOT IN __all__: os, sys, abc, stat, errno, threading."
    - "Table io1261aa covers __all__.__class__.__name__ type check plus membership for Buffered* classes."
    - "Table io1261bb covers __all__.__contains__ for seek constants and DEFAULT_BUFFER_SIZE."
    - "Table io1261cc covers __all__.__contains__ for IncrementalNewlineDecoder, Reader, text_encoding, open_code; not-in checks for imported helper modules."
    - "io.__all__.__contains__('BufferedWriter') == True (position 10)."
    - "io.__all__.__contains__('BufferedRandom') == True (position 12)."
    - "io.__all__.__contains__('BufferedRWPair') == True (position 11)."
    - "io.__all__.__contains__('BufferedIOBase') == True (position 8)."
    - "io.__all__.__contains__('SEEK_SET') == True (position 16)."
    - "io.__all__.__contains__('SEEK_CUR') == True (position 17)."
    - "io.__all__.__contains__('SEEK_END') == True (position 18)."
    - "io.__all__.__contains__('DEFAULT_BUFFER_SIZE') == True (position 19)."
    - "io.__all__.__contains__('IncrementalNewlineDecoder') == True (position 21); longest name in __all__ at 25 chars."
    - "io.__all__.__contains__('Reader') == True (position 22)."
    - "io.__all__.__contains__('text_encoding') == True (position 20)."
    - "io.__all__.__contains__('open_code') == True (position 2)."
    - "io.__all__.__contains__('os') == False (os is imported internally but not re-exported)."
    - "io.__all__.__contains__('sys') == False (sys is an internal dependency only)."
    - "io.__all__.__contains__('abc') == False (abc is used for ABCMeta but not exported)."
    - "io.__all__.__contains__('stat') == False (stat is imported for S_ISREG checks; not a public io name)."
    - "io.__all__.__class__.__name__ == 'list' (io.__all__ is a plain Python list, not tuple or set)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.__all__ type check and Buffered* class membership
# io.__all__.__class__.__name__ == 'list' (a list, not a tuple or set).
# BufferedIOBase (pos 8), BufferedReader (pos 9), BufferedWriter (pos 10),
# BufferedRWPair (pos 11), BufferedRandom (pos 12) are all in __all__.
# Prior waves covered open, FileIO, BytesIO, StringIO, IOBase, RawIOBase,
# TextIOWrapper, UnsupportedOperation, DEFAULT_BUFFER_SIZE, BlockingIOError.
# ---------------------------------------------------------------------------

table io_extra1261.all_type_and_buffered_membership:
  description: "io.__all__ type is 'list'; BufferedIOBase/Reader/Writer/RWPair/Random are all in __all__; wave 531 novel contains checks for Buffered* family at positions 8-12"
  kind: python_call_eq
  category: module_identity
  id_prefix: io1261aa

  columns: [id, function, args, expected, description]
  rows:
    - [io1261aa001, "__all__.__class__.__name__.__eq__", ["list"],           true,  "io.__all__.__class__.__name__ == 'list' (io.__all__ is a plain Python list; not a tuple or frozenset; the type has been stable across Python 3.x versions)"]
    - [io1261aa002, "__all__.__contains__",              ["BufferedIOBase"], true,  "io.__all__.__contains__('BufferedIOBase') == True (position 8; abstract base for buffered binary I/O; both BufferedReader and BufferedWriter extend it)"]
    - [io1261aa003, "__all__.__contains__",              ["BufferedReader"], true,  "io.__all__.__contains__('BufferedReader') == True (position 9; concrete buffered binary reader wrapping a RawIOBase; adds read-ahead buffering)"]
    - [io1261aa004, "__all__.__contains__",              ["BufferedWriter"], true,  "io.__all__.__contains__('BufferedWriter') == True (position 10; concrete buffered binary writer; flushes to underlying RawIOBase on demand)"]
    - [io1261aa005, "__all__.__contains__",              ["BufferedRWPair"], true,  "io.__all__.__contains__('BufferedRWPair') == True (position 11; combines a BufferedReader and a BufferedWriter into a single object; used for sockets)"]
    - [io1261aa006, "__all__.__contains__",              ["BufferedRandom"], true,  "io.__all__.__contains__('BufferedRandom') == True (position 12; buffered random-access binary I/O; wraps a seekable RawIOBase; supports both reading and writing)"]
    - [io1261aa007, "__all__.__contains__",              ["os"],             false, "io.__all__.__contains__('os') == False ('os' is imported inside io for OS-level operations but is not re-exported in io.__all__)"]
    - [io1261aa008, "__all__.__contains__",              ["sys"],            false, "io.__all__.__contains__('sys') == False ('sys' is an internal dependency used in io but not listed in the public API)"]

# ---------------------------------------------------------------------------
# io.__all__ membership for SEEK constants and DEFAULT_BUFFER_SIZE
# SEEK_SET (pos 16), SEEK_CUR (pos 17), SEEK_END (pos 18): integer seek-mode constants.
# DEFAULT_BUFFER_SIZE (pos 19): the default buffer size (8192 bytes) used by open().
# All three SEEK_* names have identical length (8 chars).
# Not covered by prior io_extra waves.
# ---------------------------------------------------------------------------

table io_extra1261.all_seek_constants_and_buffer_size:
  description: "io.__all__.__contains__ for SEEK_SET/SEEK_CUR/SEEK_END (positions 16-18) and DEFAULT_BUFFER_SIZE (position 19); all are in __all__; abc and stat are not; novel wave-531 checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: io1261bb

  columns: [id, function, args, expected, description]
  rows:
    - [io1261bb001, "__all__.__contains__", ["SEEK_SET"],            true,  "io.__all__.__contains__('SEEK_SET') == True (position 16; SEEK_SET==0; passed to seek() to position relative to the start of the stream)"]
    - [io1261bb002, "__all__.__contains__", ["SEEK_CUR"],            true,  "io.__all__.__contains__('SEEK_CUR') == True (position 17; SEEK_CUR==1; passed to seek() to position relative to the current stream position)"]
    - [io1261bb003, "__all__.__contains__", ["SEEK_END"],            true,  "io.__all__.__contains__('SEEK_END') == True (position 18; SEEK_END==2; passed to seek() to position relative to the end of the stream)"]
    - [io1261bb004, "__all__.__contains__", ["DEFAULT_BUFFER_SIZE"], true,  "io.__all__.__contains__('DEFAULT_BUFFER_SIZE') == True (position 19; integer constant equal to 8192; used as the default buffer size in open() and BufferedReader/Writer)"]
    - [io1261bb005, "__all__.__contains__", ["abc"],                 false, "io.__all__.__contains__('abc') == False ('abc' module is used via ABCMeta for abstract base classes but is not a public io export)"]
    - [io1261bb006, "__all__.__contains__", ["stat"],                false, "io.__all__.__contains__('stat') == False ('stat' module is imported by io internally but is not listed in io.__all__)"]
    - [io1261bb007, "__all__.__contains__", ["errno"],               false, "io.__all__.__contains__('errno') == False ('errno' is used in io's C implementation for error code mapping but is not a public io name)"]
    - [io1261bb008, "__all__.__contains__", ["threading"],           false, "io.__all__.__contains__('threading') == False ('threading' is imported for lock support in buffered streams but is not exported by io)"]

# ---------------------------------------------------------------------------
# io.__all__ membership for IncrementalNewlineDecoder, Reader, text_encoding, open_code
# IncrementalNewlineDecoder (pos 21): longest name in __all__ at 25 chars.
# Reader (pos 22) and Writer (pos 23): type aliases added in Python 3.12.
# text_encoding (pos 20): helper function for accepting encoding args.
# open_code (pos 2): secure open for code files.
# ---------------------------------------------------------------------------

table io_extra1261.all_incremental_reader_textencoding_opencode:
  description: "io.__all__.__contains__ for IncrementalNewlineDecoder(pos 21, len 25), Reader(pos 22), text_encoding(pos 20), open_code(pos 2); and not-in checks for posixpath, io (self-reference)"
  kind: python_call_eq
  category: module_identity
  id_prefix: io1261cc

  columns: [id, function, args, expected, description]
  rows:
    - [io1261cc001, "__all__.__contains__", ["IncrementalNewlineDecoder"], true,  "io.__all__.__contains__('IncrementalNewlineDecoder') == True (position 21; 25-char name — the longest in io.__all__; translates universal newlines during text decoding; wraps a codec incrementally)"]
    - [io1261cc002, "__all__.__contains__", ["Reader"],                   true,  "io.__all__.__contains__('Reader') == True (position 22; type alias for io.TextIOBase introduced in Python 3.12 as a complement to io.Writer; length 6)"]
    - [io1261cc003, "__all__.__contains__", ["text_encoding"],            true,  "io.__all__.__contains__('text_encoding') == True (position 20; helper function that selects an appropriate text encoding; accepts 'locale' as a special value; length 13)"]
    - [io1261cc004, "__all__.__contains__", ["open_code"],                true,  "io.__all__.__contains__('open_code') == True (position 2; opens a file for reading Python source code; may apply security policies; length 9)"]
    - [io1261cc005, "__all__.__contains__", ["TextIOBase"],               true,  "io.__all__.__contains__('TextIOBase') == True (position 13; abstract base for text I/O classes; TextIOWrapper is its primary concrete subclass)"]
    - [io1261cc006, "__all__.__contains__", ["io"],                       false, "io.__all__.__contains__('io') == False ('io' itself is not in its own __all__; module self-references are not part of the public API list)"]
    - [io1261cc007, "__all__.__contains__", ["posixpath"],                false, "io.__all__.__contains__('posixpath') == False ('posixpath' is not imported or re-exported by the io module)"]
    - [io1261cc008, "__all__.__contains__", ["IOError"],                  false, "io.__all__.__contains__('IOError') == False ('IOError' was an alias for OSError in Python 2; it is not in io.__all__ in Python 3 — use OSError directly)"]
