spec: threading_extra2761
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "Wave 631 theme: __matmul__, __truediv__, and __iadd__ dict-presence checks."
    - "threading.Thread, Event, Condition, Semaphore, BoundedSemaphore, Timer, Barrier are pure-Python classes."
    - "threading.Lock is a C-level type (_thread.lock); its __name__ == 'lock' (lowercase)."
    - "threading.local is exposed as threading.local but the underlying class is _thread._local; __name__ == '_local'."
    - "None of the nine threading types define __matmul__, __truediv__, or __iadd__ in their __dict__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Thread, Lock, Event — __matmul__/__truediv__/__iadd__ dict-presence
#
# Thread and Event are pure-Python classes; Lock is a C-level type (_thread.lock).
# None defines arithmetic operator dunders.
# All nine checks return False.
# ---------------------------------------------------------------------------

table threading_extra2761.thread_lock_event_operator_dict:
  description: "threading.Thread, Lock, Event — __matmul__, __truediv__, __iadd__ dict-presence all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: th2761tle

  columns: [id, function, args, expected]
  rows:
    - ["th2761tle_th_mm",  Thread.__dict__.__contains__, ["__matmul__"],  false]
    - ["th2761tle_th_td",  Thread.__dict__.__contains__, ["__truediv__"], false]
    - ["th2761tle_th_ia",  Thread.__dict__.__contains__, ["__iadd__"],    false]
    - ["th2761tle_lk_mm",  Lock.__dict__.__contains__,   ["__matmul__"],  false]
    - ["th2761tle_lk_td",  Lock.__dict__.__contains__,   ["__truediv__"], false]
    - ["th2761tle_lk_ia",  Lock.__dict__.__contains__,   ["__iadd__"],    false]
    - ["th2761tle_ev_mm",  Event.__dict__.__contains__,  ["__matmul__"],  false]
    - ["th2761tle_ev_td",  Event.__dict__.__contains__,  ["__truediv__"], false]
    - ["th2761tle_ev_ia",  Event.__dict__.__contains__,  ["__iadd__"],    false]

