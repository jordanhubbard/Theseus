    - ["th2761csb_cn_td",  Condition.__dict__.__contains__,        ["__truediv__"], false]
    - ["th2761csb_cn_ia",  Condition.__dict__.__contains__,        ["__iadd__"],    false]
    - ["th2761csb_se_mm",  Semaphore.__dict__.__contains__,        ["__matmul__"],  false]
    - ["th2761csb_se_td",  Semaphore.__dict__.__contains__,        ["__truediv__"], false]
