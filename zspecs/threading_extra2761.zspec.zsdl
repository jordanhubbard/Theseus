# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra2761
# ---------------------------------------------------------------------------

invariant threading_extra2761.thread_no_matmul:
  description: "'__matmul__' not in threading.Thread.__dict__ — Thread is a pure-Python class for managing threads and does not implement the @ operator"
  category: behavior
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__matmul__"]
  expected: false

invariant threading_extra2761.thread_no_truediv:
  description: "'__truediv__' not in threading.Thread.__dict__ — Thread does not implement the / operator"
  category: behavior
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__truediv__"]
  expected: false

invariant threading_extra2761.thread_no_iadd:
  description: "'__iadd__' not in threading.Thread.__dict__ — Thread does not implement the += operator"
  category: behavior
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__iadd__"]
  expected: false

invariant threading_extra2761.lock_no_matmul:
  description: "'__matmul__' not in threading.Lock.__dict__ — Lock is a C-level synchronization primitive with no @ operator support"
  category: behavior
  kind: python_call_eq
  function: Lock.__dict__.__contains__
  args: ["__matmul__"]
  expected: false

invariant threading_extra2761.semaphore_no_iadd:
  description: "'__iadd__' not in threading.Semaphore.__dict__ — Semaphore does not implement the += operator despite managing a counter internally"
  category: behavior
  kind: python_call_eq
  function: Semaphore.__dict__.__contains__
  args: ["__iadd__"]
  expected: false

invariant threading_extra2761.barrier_no_truediv:
  description: "'__truediv__' not in threading.Barrier.__dict__ — Barrier does not implement the / operator"
  category: behavior
  kind: python_call_eq
  function: Barrier.__dict__.__contains__
  args: ["__truediv__"]
  expected: false
