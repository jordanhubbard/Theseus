  columns: [id, function, args, expected]
  rows:
    - ["th2761tbl_ti_mm",  Timer.__dict__.__contains__,   ["__matmul__"],  false]
    - ["th2761tbl_ti_td",  Timer.__dict__.__contains__,   ["__truediv__"], false]
