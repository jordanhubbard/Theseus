spec: mitt
version: ">=3.0.0"
backend: node(mitt)

docs: https://github.com/developit/mitt#readme

provenance:
  derived_from:
    - "mitt README — https://github.com/developit/mitt#readme"
    - "Test vectors verified with mitt via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "mitt source"
  notes:
    - "Tiny (~200B) functional event emitter — used by Vue 3 internals & many UI libs."
    - "Install: npm install mitt"
    - "v3 CJS; default export is the mitt() factory; instance has .all (Map) / .on / .off / .emit."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure factory; never throws."
  stderr: "null"
  stickiness: "N/A — each emitter independent."
  codes: {}

invariant mitt.factory_arity:
  description: "mitt factory accepts a single (optional) all-handlers Map"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 1

invariant mitt.emitter_keys_count:
  description: "mitt() instance has exactly 4 own keys (all/on/off/emit)"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {method: hasOwnProperty, args: ["on"]}
  expected: true

invariant mitt.has_off:
  description: "mitt() instance has .off"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {method: hasOwnProperty, args: ["off"]}
  expected: true

invariant mitt.has_emit:
  description: "mitt() instance has .emit"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {method: hasOwnProperty, args: ["emit"]}
  expected: true

invariant mitt.all_is_map:
  description: "instance.all is a Map (constructor.name === 'Map')"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {get: all}
    - {get: "constructor.name"}
  expected: "Map"

invariant mitt.all_size_zero_initially:
  description: "instance.all.size is 0 on a fresh emitter"
  category: state
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {get: all}
    - {get: size}
  expected: 0

invariant mitt.on_arity:
  description: "instance.on takes (type, handler) — function.length 2"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {get: "on"}
    - {get: length}
  expected: 2

invariant mitt.emit_arity:
  description: "instance.emit takes (type, evt) — function.length 2"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {get: "emit"}
    - {get: length}
  expected: 2
