  description: "re.match.__qualname__ == 'match' — top-level function qualname, length 5; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.match.__qualname__.__eq__
  args: ["match"]
  expected: true

