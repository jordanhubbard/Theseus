  args: ["purge"]
  expected: true

invariant re_extra192.sub_qualname_eq:
  description: "re.sub.__qualname__ == 'sub' — top-level function qualname, length 3, shortest of the eight; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.sub.__qualname__.__eq__
  args: ["sub"]
  expected: true

invariant re_extra192.split_qualname_eq:
  description: "re.split.__qualname__ == 'split' — top-level function qualname, length 5, ties with match and purge; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
