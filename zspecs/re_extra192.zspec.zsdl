spec: re_extra192
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re.py"
  notes:
    - "re.search.__qualname__ == 'search' (len=6); confirmed Python 3.14.3 macOS."
    - "re.match.__qualname__ == 'match' (len=5); confirmed Python 3.14.3 macOS."
    - "re.fullmatch.__qualname__ == 'fullmatch' (len=9); confirmed Python 3.14.3 macOS."
    - "re.compile.__qualname__ == 'compile' (len=7); confirmed Python 3.14.3 macOS."
    - "re.escape.__qualname__ == 'escape' (len=6); confirmed Python 3.14.3 macOS."
    - "re.purge.__qualname__ == 'purge' (len=5); confirmed Python 3.14.3 macOS."
    - "re.sub.__qualname__ == 'sub' (len=3); shortest of the eight; confirmed Python 3.14.3 macOS."
    - "re.split.__qualname__ == 'split' (len=5); confirmed Python 3.14.3 macOS."
    - "Length ordering: sub(3) < match(5)==purge(5)==split(5) < search(6)==escape(6) < compile(7) < fullmatch(9)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re module function __qualname__ equality — group A
# search(6), match(5), fullmatch(9), compile(7)
# ---------------------------------------------------------------------------

table re_extra192.re_func_qualnames_a:
  description: "re module function __qualname__ equality: search='search'(6), match='match'(5), fullmatch='fullmatch'(9), compile='compile'(7)"
  kind: python_call_eq
  category: identity
  id_prefix: refuncqualnames192

  columns: [id, function, args, expected, description]
  rows:
    - [search_qn_eq,    re.search.__qualname__.__eq__,    ["search"],    true, "re.search.__qualname__ == 'search'; confirmed Python 3.14.3 macOS"]
    - [match_qn_eq,     re.match.__qualname__.__eq__,     ["match"],     true, "re.match.__qualname__ == 'match'; confirmed Python 3.14.3 macOS"]
    - [fullmatch_qn_eq, re.fullmatch.__qualname__.__eq__, ["fullmatch"], true, "re.fullmatch.__qualname__ == 'fullmatch'; confirmed Python 3.14.3 macOS"]
    - [compile_qn_eq,   re.compile.__qualname__.__eq__,   ["compile"],   true, "re.compile.__qualname__ == 'compile'; confirmed Python 3.14.3 macOS"]
    - [search_qn_len,   re.search.__qualname__.__len__,   [],            6,    "re.search.__qualname__.__len__() == 6 — s(1)e(2)a(3)r(4)c(5)h(6); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re module function __qualname__ equality — group B
# escape(6), purge(5), sub(3), split(5)
# ---------------------------------------------------------------------------

table re_extra192.re_func_qualnames_b:
  description: "re module function __qualname__ equality: escape='escape'(6), purge='purge'(5), sub='sub'(3), split='split'(5)"
  kind: python_call_eq
  category: identity
  id_prefix: refuncqualnames192

  columns: [id, function, args, expected, description]
  rows:
    - [escape_qn_eq, re.escape.__qualname__.__eq__, ["escape"], true, "re.escape.__qualname__ == 'escape'; confirmed Python 3.14.3 macOS"]
    - [purge_qn_eq,  re.purge.__qualname__.__eq__,  ["purge"],  true, "re.purge.__qualname__ == 'purge'; confirmed Python 3.14.3 macOS"]
    - [sub_qn_eq,    re.sub.__qualname__.__eq__,    ["sub"],    true, "re.sub.__qualname__ == 'sub'; shortest qualname of the eight; confirmed Python 3.14.3 macOS"]
    - [split_qn_eq,  re.split.__qualname__.__eq__,  ["split"],  true, "re.split.__qualname__ == 'split'; confirmed Python 3.14.3 macOS"]
    - [sub_qn_len,   re.sub.__qualname__.__len__,   [],         3,    "re.sub.__qualname__.__len__() == 3 — s(1)u(2)b(3); shortest qualname; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re module function __qualname__ lengths (ordering table)
# sub(3), match(5), purge(5), split(5), search(6), escape(6), compile(7), fullmatch(9)
# ---------------------------------------------------------------------------

table re_extra192.re_func_qualname_lengths:
  description: "re module function __qualname__ lengths: sub=3, match/purge/split=5, search/escape=6, compile=7, fullmatch=9"
  kind: python_call_eq
  category: identity
  id_prefix: refuncqualnames192

  columns: [id, function, args, expected, description]
  rows:
    - [sub_qn_len,       re.sub.__qualname__.__len__,       [], 3, "re.sub.__qualname__.__len__() == 3; shortest; confirmed Python 3.14.3 macOS"]
    - [match_qn_len,     re.match.__qualname__.__len__,     [], 5, "re.match.__qualname__.__len__() == 5; confirmed Python 3.14.3 macOS"]
    - [compile_qn_len,   re.compile.__qualname__.__len__,   [], 7, "re.compile.__qualname__.__len__() == 7 — c(1)o(2)m(3)p(4)i(5)l(6)e(7); confirmed Python 3.14.3 macOS"]
    - [fullmatch_qn_len, re.fullmatch.__qualname__.__len__, [], 9, "re.fullmatch.__qualname__.__len__() == 9; longest qualname; confirmed Python 3.14.3 macOS"]
    - [escape_qn_len,    re.escape.__qualname__.__len__,    [], 6, "re.escape.__qualname__.__len__() == 6; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra192.search_qualname_eq:
  description: "re.search.__qualname__ == 'search' — top-level function qualname, length 6; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.search.__qualname__.__eq__
  args: ["search"]
  expected: true

