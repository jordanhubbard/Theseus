spec: inspect_extra1906
version: ">=3.9"
backend: python_module(inspect)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 574: __reversed__ reverse iteration protocol; __missing__ dict protocol; __match_args__ structural pattern matching (3.10+); __qualname__ values."
    - "inspect.Parameter is a Python class defined in inspect.py; its __dict__ does not contain __reversed__, __missing__, __match_args__, __abstractmethods__, or __type_params__."
    - "inspect.Signature is a Python class defined in inspect.py; its __dict__ does not contain __reversed__, __missing__, __match_args__, __abstractmethods__, or __type_params__."
    - "inspect.BoundArguments is a Python class defined in inspect.py; its __dict__ does not contain __reversed__, __missing__, __match_args__, or __abstractmethods__."
    - "inspect.Parameter.__qualname__ == 'Parameter' — top-level Python class."
    - "inspect.Signature.__qualname__ == 'Signature' — top-level Python class."
    - "inspect.BoundArguments.__qualname__ == 'BoundArguments' — top-level Python class."
    - "inspect.Parameter.__module__ == 'inspect'."
    - "inspect.Signature.__module__ == 'inspect'."
    - "inspect.BoundArguments.__module__ == 'inspect'."
    - "inspect.Parameter.__name__ == 'Parameter'."
    - "inspect.Signature.__name__ == 'Signature'."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table inspect_extra1906.reversed_missing_protocol:
  kind: python_call_eq
  category: reversed_missing_protocol
  id_prefix: in1906

  columns: [id, function, args, expected]
  rows:
    - ["in1906001", "inspect.Parameter.__dict__.__contains__", ["__reversed__"], false]
    - ["in1906002", "inspect.Parameter.__dict__.__contains__", ["__missing__"], false]
    - ["in1906003", "inspect.Signature.__dict__.__contains__", ["__reversed__"], false]
    - ["in1906004", "inspect.Signature.__dict__.__contains__", ["__missing__"], false]
    - ["in1906005", "inspect.BoundArguments.__dict__.__contains__", ["__reversed__"], false]
    - ["in1906006", "inspect.BoundArguments.__dict__.__contains__", ["__missing__"], false]
    - ["in1906007", "inspect.Parameter.__dict__.__contains__", ["__length_hint__"], false]
    - ["in1906008", "inspect.Signature.__dict__.__contains__", ["__length_hint__"], false]

table inspect_extra1906.match_args_protocol:
  kind: python_call_eq
  category: match_args_protocol
  id_prefix: in1906

  columns: [id, function, args, expected]
  rows:
    - ["in1906011", "inspect.Parameter.__dict__.__contains__", ["__match_args__"], false]
    - ["in1906012", "inspect.Signature.__dict__.__contains__", ["__match_args__"], false]
    - ["in1906013", "inspect.BoundArguments.__dict__.__contains__", ["__match_args__"], false]
    - ["in1906014", "inspect.Parameter.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["in1906015", "inspect.Signature.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["in1906016", "inspect.BoundArguments.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["in1906017", "inspect.Parameter.__dict__.__contains__", ["__type_params__"], false]
    - ["in1906018", "inspect.Signature.__dict__.__contains__", ["__type_params__"], false]

table inspect_extra1906.qualname_values:
  kind: python_call_eq
  category: qualname_values
  id_prefix: in1906

  columns: [id, function, args, expected]
  rows:
