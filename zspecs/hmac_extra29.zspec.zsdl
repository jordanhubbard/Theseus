spec: hmac_extra29
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hmac_extra28.zspec.zsdl — covers HMAC.__init__.__name__; HMAC.update/digest/hexdigest/copy __name__ and __qualname__ re-anchor; hmac.new.__module__ re-anchor."
    - "hmac_extra27.zspec.zsdl — covers HMAC.__qualname__/__bases__[0].__name__ re-anchor; compare_digest __qualname__/__module__; digest.__module__; HMAC.update/hexdigest __qualname__ re-anchor."
    - "hmac_extra26.zspec.zsdl — covers HMAC method __module__ (update/digest/hexdigest/copy); HMAC.__init__.__qualname__/__module__; HMAC.__name__.__eq__; HMAC.blocksize value."
    - "hmac_extra23.zspec.zsdl — covers new/digest/compare_digest __qualname__.__len__; HMAC.__module__.__eq__."
    - "hmac_extra22.zspec.zsdl — covers HMAC.__mro__.__len__; HMAC.__qualname__.__len__==4; HMAC.__name__.__len__==4."
    - "hmac_extra17.zspec.zsdl — covers new/compare_digest/digest __name__/__module__; HMAC __qualname__/__module__/__bases__."
  notes:
    - "This spec extends hmac through hmac_extra28; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: HMAC/__name__/__module__/__qualname__/__bases__[0].__name__ (extra17, extra22, extra23, extra26); hmac.new/__name__/__module__ (extra17, extra28); compare_digest/__name__/__module__ (extra17, extra27); digest/__name__ (extra17); HMAC.__init__.__name__ (extra28); HMAC.update/digest/hexdigest/copy __name__ and __qualname__ (extra24, extra28); hmac.new.__module__ (extra28)."
    - "This spec covers: hmac.HMAC.__module__.__len__() (NOVEL — no prior spec checks __module__.__len__() for HMAC class); hmac.HMAC.__name__.__len__() (re-anchor from extra29 — extra22 covers from extra22 namespace); hmac.HMAC.__qualname__.__len__() (re-anchor from extra29 — extra22 covers from extra22 namespace); hmac.new.__module__.__len__() (NOVEL — no prior spec checks __module__.__len__() for hmac.new); hmac.compare_digest.__module__.__len__() (NOVEL — no prior spec checks this length); hmac.digest.__module__.__len__() (NOVEL); hmac.new.__name__.__len__() (NOVEL — no prior spec checks __name__.__len__() for hmac.new); hmac.compare_digest.__name__.__len__() (NOVEL); hmac.digest.__name__.__len__() (NOVEL); hmac.HMAC.update.__name__.__len__() (NOVEL); hmac.HMAC.digest.__name__.__len__() (NOVEL); hmac.HMAC.hexdigest.__name__.__len__() (NOVEL)."
    - "hmac.HMAC.__module__.__len__() == 4: 'hmac' has 4 characters. No prior spec checks __module__.__len__() for the HMAC class. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__name__.__len__() == 4: 'HMAC' has 4 characters. extra22 covers this from extra22 namespace. Re-anchored from extra29. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__qualname__.__len__() == 4: 'HMAC' has 4 characters. extra22 covers this from extra22 namespace. Re-anchored from extra29. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.new.__module__.__len__() == 4: 'hmac' has 4 characters. No prior spec checks __module__.__len__() for hmac.new. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.compare_digest.__module__.__len__() == 8: '_hashlib' has 8 characters (compare_digest is implemented in the _hashlib C extension). No prior spec checks this length. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.digest.__module__.__len__() == 4: 'hmac' has 4 characters. No prior spec checks __module__.__len__() for hmac.digest. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.new.__name__.__len__() == 3: 'new' has 3 characters. No prior spec checks __name__.__len__() for hmac.new. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.compare_digest.__name__.__len__() == 14: 'compare_digest' has 14 characters. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.digest.__name__.__len__() == 6: 'digest' has 6 characters. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.update.__name__.__len__() == 6: 'update' has 6 characters. extra28 covers __name__.__eq__; no prior spec checks __len__(). NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.digest.__name__.__len__() == 6: 'digest' has 6 characters. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.hexdigest.__name__.__len__() == 9: 'hexdigest' has 9 characters. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HMAC class __module__.__len__(), __name__.__len__(), __qualname__.__len__()
#
# hmac_extra22 covers __name__.__len__==4 and __qualname__.__len__==4 from
# extra22. hmac_extra23 covers __module__.__eq__('hmac') from extra23.
# __module__.__len__() is novel. __name__/__qualname__.__len__() are
# re-anchored from extra29 for independent regression coverage.
# ---------------------------------------------------------------------------

invariant hmac_extra29.HMAC.module_len:
  description: "hmac.HMAC.__module__.__len__() == 4 — 'hmac' has 4 characters, novel invariant"
  category: module_metadata
  kind: python_call_eq
  function: HMAC.__module__.__len__
  args: []
  expected: 4

table hmac_extra29.HMAC_identity_lengths:
  description: "HMAC.__name__.__len__() and __qualname__.__len__() == 4 — re-anchored from extra29 namespace"
  kind: python_call_eq
  category: function_names
  id_prefix: hmacil29

  columns: [id, function, args, expected]
  rows:
    - [name,     HMAC.__name__.__len__,     [], 4]
    - [qualname, HMAC.__qualname__.__len__, [], 4]

# ---------------------------------------------------------------------------
# Module-level function __module__.__len__() — novel invariants
#
# hmac_extra17 and hmac_extra27/28 cover __module__.__eq__ for new,
# compare_digest, and digest. No prior spec checks __module__.__len__()
# for any of these three functions.
# new.__module__ == 'hmac' (4 chars); digest.__module__ == 'hmac' (4 chars);
# compare_digest.__module__ == '_hashlib' (8 chars — C extension).
# ---------------------------------------------------------------------------

table hmac_extra29.function_module_lengths:
  description: "hmac.new/digest/compare_digest __module__.__len__() — novel invariants"
  kind: python_call_eq
  category: module_metadata
  id_prefix: hmacml29

  columns: [id, function, args, expected]
  rows:
    - [new,             new.__module__.__len__,             [], 4]
    - [digest,          digest.__module__.__len__,          [], 4]
    - [compare_digest,  compare_digest.__module__.__len__,  [], 8]

# ---------------------------------------------------------------------------
# Module-level function __name__.__len__() — novel invariants
#
# hmac_extra17 covers __name__.__eq__ for new, compare_digest, and digest.
# No prior spec checks __name__.__len__() for any of these.
# new=3, compare_digest=14, digest=6.
# ---------------------------------------------------------------------------

table hmac_extra29.function_name_lengths:
  description: "hmac.new/compare_digest/digest __name__.__len__() — novel invariants"
  kind: python_call_eq
  category: function_names
  id_prefix: hmacnl29

  columns: [id, function, args, expected]
  rows:
    - [new,            new.__name__.__len__,            [], 3]
    - [compare_digest, compare_digest.__name__.__len__, [], 14]
    - [digest,         digest.__name__.__len__,         [], 6]

# ---------------------------------------------------------------------------
# HMAC method __name__.__len__() — novel invariants
#
# hmac_extra28 covers HMAC.update/digest/hexdigest/copy __name__.__eq__.
# No prior spec checks __name__.__len__() for any HMAC instance method.
# update=6, digest=6, hexdigest=9.
# ---------------------------------------------------------------------------

table hmac_extra29.HMAC_method_name_lengths:
  description: "HMAC.update/digest/hexdigest __name__.__len__() — novel invariants"
  kind: python_call_eq
  category: function_names
  id_prefix: hmacmnl29

  columns: [id, function, args, expected]
  rows:
    - [update,    HMAC.update.__name__.__len__,    [], 6]
    - [digest,    HMAC.digest.__name__.__len__,    [], 6]
    - [hexdigest, HMAC.hexdigest.__name__.__len__, [], 9]
