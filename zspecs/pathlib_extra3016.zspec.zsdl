spec: pp3016
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module class hierarchy"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 648 (pp3016): __iter__, __next__, __reversed__ dict-presence checks for pathlib types."
    - "pathlib path objects represent filesystem paths; they are not sequences or iterators."
    - "None of PurePath, PurePosixPath, PureWindowsPath, or Path define __iter__, __next__, or __reversed__ in their own __dict__."
    - "Path iteration (e.g. iterating over directory contents) is done via Path.iterdir(), not via the iterator protocol on the Path class itself."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iter__ dict-presence — operator.contains(Cls.__dict__, '__iter__')
#
# pathlib path types are not iterable objects; none define __iter__; all false.
# ---------------------------------------------------------------------------

table pp3016.iter:
  description: "pathlib types __iter__ dict-presence checks; wave 648"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp3016
  columns: [id, function, args, expected]
  rows:
    - ["pp3016001", operator.contains, [pathlib.PurePath.__dict__,        "__iter__"], false]
    - ["pp3016002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__iter__"], false]
    - ["pp3016003", operator.contains, [pathlib.PureWindowsPath.__dict__, "__iter__"], false]
    - ["pp3016004", operator.contains, [pathlib.Path.__dict__,            "__iter__"], false]
    - ["pp3016005", operator.contains, [pathlib.PurePath.__dict__,        "__iter__"], false]
    - ["pp3016006", operator.contains, [pathlib.Path.__dict__,            "__iter__"], false]

