spec: re_extra220
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.match() result attributes group(), start(), end(); re.search() result attributes group(), start(), end(); re.fullmatch() result group() and end(); re.IGNORECASE/MULTILINE/DOTALL/VERBOSE integer values."
    - "re.match(r'[a-z]+', 'hello123').group() == 'hello' — match anchors at start; stops at first non-matching char."
    - "re.match(r'[a-z]+', 'hello123').start() == 0 — match always starts at position 0."
    - "re.match(r'[a-z]+', 'hello123').end() == 5 — match ends at the first non-matching character."
    - "re.search(r'[0-9]+', 'abc456def').group() == '456' — search scans the whole string."
    - "re.search(r'[0-9]+', 'abc456def').start() == 3 — digits start at index 3."
    - "re.search(r'[0-9]+', 'abc456def').end() == 6 — digits end at index 6 (exclusive)."
    - "re.fullmatch(r'[0-9]+', '789').group() == '789' — fullmatch requires the entire string to match."
    - "re.fullmatch(r'[0-9]+', '789').end() == 3 — the entire 3-character string was consumed."
    - "re.IGNORECASE == 2 (integer value of the RegexFlag enum member)."
    - "re.MULTILINE == 8, re.DOTALL == 16, re.VERBOSE == 64."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.match() result attributes
# re.match(pattern, string) anchors at position 0. The returned Match object
# has group(), start(), end() methods.
# match(r'[a-z]+', 'hello123'): group='hello', start=0, end=5
# match(r'\d+', '42xyz'):       group='42',    start=0, end=2
# ---------------------------------------------------------------------------

table re_extra220.match_result_attrs:
  description: "re.match() result: group(), start(), end() for two patterns"
  kind: python_call_eq
  category: match
  id_prefix: rematch220
  function: match

  columns: [id, args, method, expected]
  rows:
    - [alpha_group, ["[a-z]+", "hello123"], group, "hello"]
    - [alpha_start, ["[a-z]+", "hello123"], start, 0     ]
    - [alpha_end,   ["[a-z]+", "hello123"], end,   5     ]
    - [digit_group, ["\\d+",   "42xyz"   ], group, "42"  ]
    - [digit_start, ["\\d+",   "42xyz"   ], start, 0     ]
    - [digit_end,   ["\\d+",   "42xyz"   ], end,   2     ]

# ---------------------------------------------------------------------------
# re.search() result attributes
# re.search() scans the entire string and returns the first match.
# search(r'[0-9]+', 'abc456def'): group='456', start=3, end=6
# search(r'\d+',    '123abc'):    group='123', start=0, end=3
# ---------------------------------------------------------------------------

table re_extra220.search_result_attrs:
  description: "re.search() result: group(), start(), end() for two patterns"
  kind: python_call_eq
  category: search
  id_prefix: research220
  function: search

  columns: [id, args, method, expected]
  rows:
    - [mid_group,   ["[0-9]+", "abc456def"], group, "456"]
    - [mid_start,   ["[0-9]+", "abc456def"], start, 3   ]
    - [mid_end,     ["[0-9]+", "abc456def"], end,   6   ]
    - [front_group, ["\\d+",   "123abc"   ], group, "123"]
    - [front_start, ["\\d+",   "123abc"   ], start, 0   ]
    - [front_end,   ["\\d+",   "123abc"   ], end,   3   ]

# ---------------------------------------------------------------------------
# re.fullmatch() result attributes
# re.fullmatch() requires the entire string to match the pattern.
# fullmatch(r'[0-9]+', '789'): group='789', start=0, end=3
# ---------------------------------------------------------------------------

table re_extra220.fullmatch_result_attrs:
  description: "re.fullmatch() result: group(), start(), end()"
  kind: python_call_eq
  category: fullmatch
  id_prefix: refullmatch220
  function: fullmatch

  columns: [id, args, method, expected]
  rows:
    - [digits_group, ["[0-9]+", "789"],   group, "789"]
    - [digits_start, ["[0-9]+", "789"],   start, 0   ]
    - [digits_end,   ["[0-9]+", "789"],   end,   3   ]
    - [alpha_group,  ["[a-z]+", "hello"], group, "hello"]
    - [alpha_end,    ["[a-z]+", "hello"], end,   5   ]

# ---------------------------------------------------------------------------
# re flag integer values
# re.IGNORECASE, MULTILINE, DOTALL, VERBOSE are RegexFlag (IntFlag) members.
# Their integer values match the underlying bit positions used by PCRE/sre.
# IGNORECASE=2, MULTILINE=8, DOTALL=16, VERBOSE=64
# ---------------------------------------------------------------------------

table re_extra220.flag_integer_values:
  description: "re flag integer values: IGNORECASE=2, MULTILINE=8, DOTALL=16, VERBOSE=64"
  kind: python_call_eq
  category: constants
  id_prefix: reflags220

  columns: [id, function, args, expected]
  rows:
    - [ignorecase_val, IGNORECASE.__int__, [], 2 ]
    - [multiline_val,  MULTILINE.__int__,  [], 8 ]
    - [dotall_val,     DOTALL.__int__,     [], 16]
    - [verbose_val,    VERBOSE.__int__,    [], 64]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra220.match.group_anchored_at_zero:
  description: "re.match(r'[a-z]+', 'hello123').group() == 'hello' — match anchors at start of string and stops at first non-[a-z] character"
  category: match
  kind: python_call_eq
  function: match
  args: ["[a-z]+", "hello123"]
  method: group
  expected: "hello"

invariant re_extra220.search.mid_string_group:
  description: "re.search(r'[0-9]+', 'abc456def').group() == '456' — search finds digits embedded in non-digit context"
  category: search
  kind: python_call_eq
  function: search
  args: ["[0-9]+", "abc456def"]
  method: group
  expected: "456"

invariant re_extra220.fullmatch.whole_string_group:
  description: "re.fullmatch(r'[0-9]+', '789').group() == '789' — fullmatch consumes entire string"
  category: fullmatch
  kind: python_call_eq
  function: fullmatch
  args: ["[0-9]+", "789"]
  method: group
  expected: "789"

invariant re_extra220.IGNORECASE.integer_value:
  description: "int(re.IGNORECASE) == 2 — the IGNORECASE RegexFlag bit position"
  category: constants
  kind: python_call_eq
  function: IGNORECASE.__int__
  args: []
  expected: 2

invariant re_extra220.DOTALL.integer_value:
  description: "int(re.DOTALL) == 16 — the DOTALL RegexFlag bit position"
  category: constants
  kind: python_call_eq
  function: DOTALL.__int__
  args: []
  expected: 16
