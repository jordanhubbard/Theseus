spec: qs
version: ">=6.0.0"
backend: node(qs)

docs: https://www.npmjs.com/package/qs

provenance:
  derived_from:
    - "qs README — https://www.npmjs.com/package/qs"
    - "Test vectors verified with qs via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "qs source"
  notes:
    - "qs is an npm package. Install: npm install qs"
    - "qs.parse(str) parses a query string to an object (all values are strings)."
    - "qs.stringify(obj) serializes an object to a query string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns parsed object or query string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table qs.parse:
  kind: node_module_call_eq
  function: parse
  category: parse
  id_prefix: qsparse

  columns: [id, args, expected]
  rows:
    - [simple,   ["a=1&b=2&c=hello"],  {"a": "1", "b": "2", "c": "hello"}]

table qs.stringify:
  kind: node_module_call_eq
  function: stringify
  category: format
  id_prefix: qsstr

  columns: [id, args, expected]
  rows:
    - [simple,   [{"a": 1, "b": 2}],  "a=1&b=2"]
