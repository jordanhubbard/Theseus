table asyncio_extra194.asyncio_condition_method_qualnames:
  description: "asyncio.Condition method qualname identity in asynciocond194 namespace — Condition.wait.__qualname__=='Condition.wait' (len=14: 'Condition'=9+'.'=1+'wait'=4=14; suspends the calling coroutine, releasing the underlying lock, until notified); Condition.notify.__qualname__=='Condition.notify' (len=16: 'Condition'=9+'.'=1+'notify'=6=16; wakes one waiting coroutine); Condition.notify_all.__qualname__=='Condition.notify_all' (len=20: 'Condition'=9+'.'=1+'notify_all'=10=20; wakes all waiting coroutines); Condition.wait_for.__qualname__=='Condition.wait_for' (len=18: 'Condition'=9+'.'=1+'wait_for'=8=18; waits until a predicate becomes True); length ordering: wait(14) < notify(16) < wait_for(18) < notify_all(20); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciocond194

  columns: [id, function, args, expected, description]
  rows:
    - [cond_wait_qualname_eq,       "asyncio.Condition.wait.__qualname__.__eq__",       ["Condition.wait"],       true, "asyncio.Condition.wait.__qualname__ == 'Condition.wait' (len=14; suspends coroutine until notified); verified Python 3.14.3"]
    - [cond_wait_qualname_len,      "asyncio.Condition.wait.__qualname__.__len__",       [],                       14,   "asyncio.Condition.wait.__qualname__.__len__() == 14 ('Condition.wait'=14: 'Condition'=9+'.'=1+'wait'=4=14); verified Python 3.14.3"]
    - [cond_notify_qualname_eq,     "asyncio.Condition.notify.__qualname__.__eq__",      ["Condition.notify"],     true, "asyncio.Condition.notify.__qualname__ == 'Condition.notify' (len=16; wakes one waiting coroutine); verified Python 3.14.3"]
    - [cond_notify_qualname_len,    "asyncio.Condition.notify.__qualname__.__len__",     [],                       16,   "asyncio.Condition.notify.__qualname__.__len__() == 16 ('Condition.notify'=16: 'Condition'=9+'.'=1+'notify'=6=16); verified Python 3.14.3"]
    - [cond_notifyall_qualname_eq,  "asyncio.Condition.notify_all.__qualname__.__eq__",  ["Condition.notify_all"], true, "asyncio.Condition.notify_all.__qualname__ == 'Condition.notify_all' (len=20; wakes all waiting coroutines); verified Python 3.14.3"]

