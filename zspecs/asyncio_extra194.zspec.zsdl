spec: asyncio_extra194
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "asyncio.Condition.__name__ == 'Condition' (len=9: C(1)o(2)n(3)d(4)i(5)t(6)i(7)o(8)n(9)); Condition is the asyncio monitor primitive for coroutines."
    - "asyncio.Condition.__module__ == 'asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13); pure Python, not C-accelerated."
    - "asyncio.Condition.__bases__[0].__name__ == '_ContextManagerMixin' (len=20); Condition supports 'async with' via this mixin."
    - "asyncio.Condition.__init__.__qualname__ == 'Condition.__init__' (len=18: 'Condition'=9+'.'=1+'__init__'=8=18)."
    - "asyncio.Condition.wait.__qualname__ == 'Condition.wait' (len=14: 'Condition'=9+'.'=1+'wait'=4=14)."
    - "asyncio.Condition.notify.__qualname__ == 'Condition.notify' (len=16: 'Condition'=9+'.'=1+'notify'=6=16)."
    - "asyncio.Condition.notify_all.__qualname__ == 'Condition.notify_all' (len=20: 'Condition'=9+'.'=1+'notify_all'=10=20)."
    - "asyncio.Condition.wait_for.__qualname__ == 'Condition.wait_for' (len=18: 'Condition'=9+'.'=1+'wait_for'=8=18)."
    - "Length ordering: wait (14) < notify (16) < __init__ (18) == wait_for (18) < notify_all (20) for qualnames."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

