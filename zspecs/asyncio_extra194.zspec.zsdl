table asyncio_extra194.asyncio_condition_class_identity:
  description: "asyncio.Condition class identity checks in asynciocond194 namespace — Condition.__name__=='Condition' (len=9: C(1)o(2)n(3)d(4)i(5)t(6)i(7)o(8)n(9); the asyncio monitor for coroutines combining a Lock with a notification mechanism); Condition.__module__=='asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13; pure Python in Lib/asyncio/locks.py alongside Lock, Semaphore, Event); Condition.__bases__[0].__name__=='_ContextManagerMixin' (len=20: '_'=1+'Context'=7+'Manager'=7+'Mixin'=5=20; enables 'async with cond:' syntax); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciocond194

  columns: [id, function, args, expected, description]
  rows:
    - [cond_name_eq,    asyncio.Condition.__name__.__eq__,    ["Condition"],       true, "asyncio.Condition.__name__ == 'Condition' (len=9; asyncio monitor primitive for coroutines); verified Python 3.14.3"]
    - [cond_name_len,   asyncio.Condition.__name__.__len__,   [],                  9,    "asyncio.Condition.__name__.__len__() == 9 ('Condition'=9: C(1)o(2)n(3)d(4)i(5)t(6)i(7)o(8)n(9)); verified Python 3.14.3"]
    - [cond_module_eq,  asyncio.Condition.__module__.__eq__,  ["asyncio.locks"],   true, "asyncio.Condition.__module__ == 'asyncio.locks' (len=13; pure Python in Lib/asyncio/locks.py); verified Python 3.14.3"]
    - [cond_module_len, asyncio.Condition.__module__.__len__, [],                  13,   "asyncio.Condition.__module__.__len__() == 13 ('asyncio.locks'=13: 'asyncio'=7+'.'=1+'locks'=5=13); verified Python 3.14.3"]
    - ["cond_base_eq",  "asyncio.Condition.__bases__[0].__name__.__eq__",          ["_ContextManagerMixin"], true, "asyncio.Condition.__bases__[0].__name__ == '_ContextManagerMixin' (len=20; enables 'async with cond:' usage); verified Python 3.14.3"]

