    - [cond_init_qualname_len,     "asyncio.Condition.__init__.__qualname__.__len__",   [],                        18,   "asyncio.Condition.__init__.__qualname__.__len__() == 18 ('Condition.__init__'=18: 'Condition'=9+'.'=1+'__init__'=8=18); verified Python 3.14.3"]
    - [cond_waitfor_qualname_eq,   "asyncio.Condition.wait_for.__qualname__.__eq__",    ["Condition.wait_for"],    true, "asyncio.Condition.wait_for.__qualname__ == 'Condition.wait_for' (len=18; waits until predicate() returns truthy); verified Python 3.14.3"]
    - [cond_waitfor_qualname_len,  "asyncio.Condition.wait_for.__qualname__.__len__",   [],                        18,   "asyncio.Condition.wait_for.__qualname__.__len__() == 18 ('Condition.wait_for'=18: 'Condition'=9+'.'=1+'wait_for'=8=18); verified Python 3.14.3"]
    - [cond_notifyall_qualname_len,"asyncio.Condition.notify_all.__qualname__.__len__", [],                        20,   "asyncio.Condition.notify_all.__qualname__.__len__() == 20 ('Condition.notify_all'=20: 'Condition'=9+'.'=1+'notify_all'=10=20); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra194
# ---------------------------------------------------------------------------

invariant asyncio_extra194.asyncio_Condition_name_eq:
  description: "asyncio.Condition.__name__.__eq__('Condition') returns True — asyncio.Condition is the coroutine-safe monitor primitive; Condition.__name__=='Condition' (len=9: C(1)o(2)n(3)d(4)i(5)t(6)i(7)o(8)n(9)); a Condition wraps an asyncio.Lock and provides wait()/notify()/notify_all() for coroutines; callers must hold the underlying lock before calling wait() or notify(); Condition.__name__ (9) == Semaphore.__name__ (9) — same length as the asyncio counting semaphore; NEW in extra194: first standalone Condition.__name__.__eq__ invariant in asynciocond194 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.__name__.__eq__
  args: ["Condition"]
  expected: true

invariant asyncio_extra194.asyncio_Condition_module_eq:
  description: "asyncio.Condition.__module__.__eq__('asyncio.locks') returns True — asyncio.Condition is defined in Lib/asyncio/locks.py; Condition.__module__=='asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13); asyncio.locks also contains Lock, Semaphore, BoundedSemaphore, and Event — all asyncio synchronization primitives; Condition.__module__ (13) == Semaphore.__module__ (13) — all asyncio sync primitives share the same source file; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra194.asyncio_Condition_base_is_ContextManagerMixin:
  description: "asyncio.Condition.__bases__[0].__name__.__eq__('_ContextManagerMixin') returns True — asyncio.Condition inherits from _ContextManagerMixin (len=20: '_'=1+'Context'=7+'Manager'=7+'Mixin'=5=20); _ContextManagerMixin provides __aenter__ and __aexit__ enabling 'async with cond:' syntax; both Condition and Lock use _ContextManagerMixin as their direct base; Condition.__bases__[0].__name__ (20) — same mixin as asyncio.Lock; Semaphore.__bases__[0].__name__ also is '_ContextManagerMixin' (20); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Condition.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true

invariant asyncio_extra194.asyncio_Condition_init_qualname_eq:
  description: "asyncio.Condition.__init__.__qualname__.__eq__('Condition.__init__') returns True — Condition.__init__.__qualname__=='Condition.__init__' (len=18: 'Condition'=9+'.'=1+'__init__'=8=18); Condition.__init__ accepts an optional 'lock' parameter; if None is passed a new asyncio.Lock() is created automatically; Condition.__init__.__qualname__ (18) == Condition.wait_for.__qualname__ (18) — identical lengths for __init__ and wait_for; the pattern 'ClassName.__init__' gives qualname_len == name_len + 9; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Condition.__init__.__qualname__.__eq__"
  args: ["Condition.__init__"]
  expected: true

invariant asyncio_extra194.asyncio_Condition_wait_qualname_eq:
  description: "asyncio.Condition.wait.__qualname__.__eq__('Condition.wait') returns True — Condition.wait.__qualname__=='Condition.wait' (len=14: 'Condition'=9+'.'=1+'wait'=4=14); Condition.wait() releases the underlying lock, suspends the coroutine until notify() or notify_all() is called, then re-acquires the lock before returning; Condition.wait.__qualname__ (14) is the shortest method qualname in this spec — 'wait' (4) is shorter than 'notify' (6), 'wait_for' (8), 'notify_all' (10); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Condition.wait.__qualname__.__eq__"
  args: ["Condition.wait"]
  expected: true

invariant asyncio_extra194.asyncio_Condition_notify_qualname_eq:
  description: "asyncio.Condition.notify.__qualname__.__eq__('Condition.notify') returns True — Condition.notify.__qualname__=='Condition.notify' (len=16: 'Condition'=9+'.'=1+'notify'=6=16); Condition.notify(n=1) wakes up at most n coroutines waiting on this condition; the lock must be held when calling notify(); Condition.notify.__qualname__ (16) > Condition.wait.__qualname__ (14) by 2 — 'notify' (6) is 2 longer than 'wait' (4); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Condition.notify.__qualname__.__eq__"
  args: ["Condition.notify"]
  expected: true

invariant asyncio_extra194.asyncio_Condition_notify_all_qualname_eq:
  description: "asyncio.Condition.notify_all.__qualname__.__eq__('Condition.notify_all') returns True — Condition.notify_all.__qualname__=='Condition.notify_all' (len=20: 'Condition'=9+'.'=1+'notify_all'=10=20); Condition.notify_all() wakes all coroutines currently waiting on the condition; Condition.notify_all.__qualname__ (20) is the longest method qualname in this spec and equals Condition.__bases__[0].__name__ length (20: '_ContextManagerMixin'=20) — a numerical coincidence; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Condition.notify_all.__qualname__.__eq__"
  args: ["Condition.notify_all"]
  expected: true

invariant asyncio_extra194.asyncio_Condition_wait_for_qualname_eq:
  description: "asyncio.Condition.wait_for.__qualname__.__eq__('Condition.wait_for') returns True — Condition.wait_for.__qualname__=='Condition.wait_for' (len=18: 'Condition'=9+'.'=1+'wait_for'=8=18); Condition.wait_for(predicate) calls wait() in a loop until predicate() returns a truthy value, avoiding spurious wakeup bugs; Condition.wait_for.__qualname__ (18) == Condition.__init__.__qualname__ (18) — 'wait_for' (8) and '__init__' (8) are the same length; Condition.wait_for.__qualname__ (18) < Condition.notify_all.__qualname__ (20) by 2; NEW in extra194: completing 8-invariant coverage for asyncio Condition identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Condition.wait_for.__qualname__.__eq__"
  args: ["Condition.wait_for"]
  expected: true
