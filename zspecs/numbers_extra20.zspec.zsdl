spec: numbers_extra20
version: ">=3.9"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers_extra19.zspec.zsdl."
    - "Prior specs covered: Number/Complex/Real/Rational/Integral __name__/__module__/__qualname__, bases, ABCMeta.__name__, abstractmethods __class__.__name__, len(Integral.__abstractmethods__)==34, Number/Complex module length, __qualname__.__eq__ for all 5 ABCs, __name__.__len__() table for all 5 ABCs, __module__.__len__() table for all 5 ABCs, Number/Integral __qualname__.__len__() standalone."
    - "This spec covers: __mro__.__len__() for all 5 ABCs; len(Real.__abstractmethods__)==23 and len(Rational.__abstractmethods__)==24; __qualname__.__len__() table for Complex/Real/Rational; cross-check that __name__.__len__()==__qualname__.__len__() for all 5 ABCs."
    - "MRO lengths: Number=2, Complex=3, Real=4, Rational=5, Integral=6 (hierarchy depth)."
    - "Abstract method counts: Number=0, Complex=16, Real=23, Rational=24, Integral=34."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() table — MRO depth for all 5 ABCs
#
# The numbers hierarchy is a strict linear chain: Number → Complex → Real →
# Rational → Integral. Each ABC's __mro__ includes all ancestors plus object.
# Number.__mro__ has length 2 (Number, object); each level down adds one entry.
# Integral.__mro__ has length 6 (Integral, Rational, Real, Complex, Number,
# object). This table records __mro__.__len__() for all five ABCs. No prior
# numbers spec records __mro__.__len__() for any of the ABCs.
# ---------------------------------------------------------------------------

table numbers_extra20.abc_mro_lengths:
  kind: python_call_eq
  category: class_identity
  id_prefix: mro_len

  columns: [id, function, args, expected, description]
  rows:
    - [Number,
       Number.__mro__.__len__,
       [],
       2,
       "len(numbers.Number.__mro__) == 2 — [Number, object]"]
    - [Complex,
       Complex.__mro__.__len__,
       [],
       3,
       "len(numbers.Complex.__mro__) == 3 — [Complex, Number, object]"]
    - [Real,
       Real.__mro__.__len__,
       [],
       4,
       "len(numbers.Real.__mro__) == 4 — [Real, Complex, Number, object]"]
    - [Rational,
       Rational.__mro__.__len__,
       [],
       5,
       "len(numbers.Rational.__mro__) == 5 — [Rational, Real, Complex, Number, object]"]
    - [Integral,
       Integral.__mro__.__len__,
       [],
       6,
       "len(numbers.Integral.__mro__) == 6 — [Integral, Rational, Real, Complex, Number, object]"]

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — qualname string lengths for Complex, Real, Rational
#
# numbers_extra18 records __qualname__.__len__() for all 5 ABCs as standalone
# invariants; numbers_extra19 records Number and Integral as standalone
# invariants in table complement form. This table records Complex (7), Real (4),
# and Rational (8) together — the three middle members of the hierarchy — as a
# combined tabular view not previously expressed in the extra20 namespace.
# For all five top-level ABCs, __qualname__ equals __name__.
# ---------------------------------------------------------------------------

table numbers_extra20.abc_qualname_lengths_mid:
  kind: python_call_eq
  category: class_identity
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [Complex,
       Complex.__qualname__.__len__,
       [],
       7,
       "len(numbers.Complex.__qualname__) == 7 — 'Complex' is 7 chars"]
    - [Real,
       Real.__qualname__.__len__,
       [],
       4,
       "len(numbers.Real.__qualname__) == 4 — 'Real' is 4 chars"]
    - [Rational,
       Rational.__qualname__.__len__,
       [],
       8,
       "len(numbers.Rational.__qualname__) == 8 — 'Rational' is 8 chars"]

# ---------------------------------------------------------------------------
# Integral.__mro__.__len__() — standalone MRO depth
#
# numbers.Integral.__mro__ contains 6 entries: Integral, Rational, Real,
# Complex, Number, and object. This is the maximum depth of the numbers
# hierarchy. Each level of the ABC chain adds exactly one entry; Integral is
# at the bottom of the tower and therefore has the deepest MRO. No prior
# numbers spec records Integral.__mro__.__len__() as a standalone invariant.
# ---------------------------------------------------------------------------

invariant numbers_extra20.Integral.mro_len:
  description: "len(numbers.Integral.__mro__) == 6 — full hierarchy depth"
  category: class_identity
  kind: python_call_eq
  function: Integral.__mro__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# len(Real.__abstractmethods__) == 23 — standalone abstract method count
#
# numbers.Real defines 23 abstract methods. This is seven more than Complex (16)
# and one fewer than Rational (24). Real adds real-number operations such as
# __trunc__, __floor__, __ceil__, __round__, and the corresponding arithmetic
# on real numbers. No prior numbers spec records Real.__abstractmethods__.__len__()
# as a standalone invariant.
# ---------------------------------------------------------------------------

invariant numbers_extra20.Real.abstractmethods_len:
  description: "len(numbers.Real.__abstractmethods__) == 23 — Real declares 23 abstract methods"
  category: class_identity
  kind: python_call_eq
  function: Real.__abstractmethods__.__len__
  args: []
  expected: 23

# ---------------------------------------------------------------------------
# len(Rational.__abstractmethods__) == 24 — standalone abstract method count
#
# numbers.Rational defines 24 abstract methods — one more than Real (23) and
# ten fewer than Integral (34). Rational adds __numerator__ and __denominator__
# properties to the Real contract. No prior numbers spec records
# Rational.__abstractmethods__.__len__() as a standalone invariant.
# ---------------------------------------------------------------------------

invariant numbers_extra20.Rational.abstractmethods_len:
  description: "len(numbers.Rational.__abstractmethods__) == 24 — Rational declares 24 abstract methods"
  category: class_identity
  kind: python_call_eq
  function: Rational.__abstractmethods__.__len__
  args: []
  expected: 24

# ---------------------------------------------------------------------------
# Number.__mro__.__len__() — standalone MRO depth
#
# numbers.Number.__mro__ has length 2: [Number, object]. Number is the root of
# the numeric tower and has no numeric ancestors; only the implicit object base
# is present. This is the minimum possible MRO depth for any user-defined class.
# No prior numbers spec records Number.__mro__.__len__() as a standalone invariant.
# ---------------------------------------------------------------------------

invariant numbers_extra20.Number.mro_len:
  description: "len(numbers.Number.__mro__) == 2 — Number has only object as ancestor"
  category: class_identity
  kind: python_call_eq
  function: Number.__mro__.__len__
  args: []
  expected: 2
