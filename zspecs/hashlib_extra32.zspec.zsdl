spec: hashlib_extra32
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra31.zspec.zsdl — covers md5/sha1/sha256/sha512/sha224/sha384 __name__.__len__(); md5/sha1/sha256/sha512 __module__.__eq__('_hashlib'); md5/__module__.__len__ and sha256/__module__.__len__ (both 8)."
  notes:
    - "This spec extends hashlib through hashlib_extra31; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: md5/sha1/sha256/sha512/sha224/sha384 __name__.__len__() (extra31); md5/sha1/sha256/sha512 __module__.__eq__ (extra31); md5/__module__.__len__ and sha256/__module__.__len__ (both 8) (extra31); blake2b/blake2s __name__/__qualname__ (extra28/extra29); new.__module__ (extra29); sha3_256/sha3_512 __name__ (extra29)."
    - "This spec covers: sha1.__module__.__len__() (NOVEL — extra31 covers __module__.__eq__ but not __len__() for sha1); sha512.__module__.__len__() (NOVEL); sha224.__module__.__len__() (NOVEL); sha384.__module__.__len__() (NOVEL); blake2b.__module__.__len__() (NOVEL — no prior spec covers blake2b.__module__.__len__()); blake2s.__module__.__len__() (NOVEL); blake2b.__name__.__len__() (NOVEL — no prior spec checks __name__.__len__() for blake2b); blake2s.__name__.__len__() (NOVEL); new.__module__.__len__() (NOVEL — no prior spec checks __len__ for new.__module__); new.__name__.__len__() (NOVEL); sha3_256.__module__.__len__() (NOVEL); sha3_256.__name__.__len__() (NOVEL)."
    - "hashlib.sha1.__module__.__len__() == 8: '_hashlib' has 8 characters. extra31 covers __module__.__eq__ for sha1. __len__() is novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__module__.__len__() == 8: '_hashlib' has 8 characters. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__module__.__len__() == 8: '_hashlib' has 8 characters. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__module__.__len__() == 8: '_hashlib' has 8 characters. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__ == '_blake2' (len 7). blake2b is backed by the _blake2 C extension, not _hashlib. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__module__ == '_blake2' (len 7). Same C extension as blake2b. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__name__.__len__() == 7: 'blake2b' has 7 characters. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__name__.__len__() == 7: 'blake2s' has 7 characters. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__ == 'hashlib' (len 7). new is a pure-Python wrapper (__hash_new), so its __module__ is 'hashlib' not '_hashlib'. Novel __len__ check. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.new.__name__ == '__hash_new' (len 10). Novel __name__.__len__() check. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__module__ == '_hashlib' (len 8). Novel __module__.__len__() check. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__name__ == 'openssl_sha3_256' (len 16). Novel __name__.__len__() check. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sha1/sha512/sha224/sha384 __module__.__len__() — novel
#
# extra31 covers __module__.__eq__('_hashlib') for sha1 and sha512.
# No prior spec checks __module__.__len__() for any of these four.
# All four are OpenSSL-backed and live in '_hashlib'; len('_hashlib') == 8.
# ---------------------------------------------------------------------------

invariant hashlib_extra32.sha1.module_len:
  description: "hashlib.sha1.__module__.__len__() == 8 — '_hashlib' has 8 characters, novel invariant"
  category: module_metadata
  kind: python_call_eq
  function: sha1.__module__.__len__
  args: []
  expected: 8

invariant hashlib_extra32.sha512.module_len:
  description: "hashlib.sha512.__module__.__len__() == 8 — '_hashlib' has 8 characters, novel invariant"
  category: module_metadata
  kind: python_call_eq
  function: sha512.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# blake2b and blake2s __module__.__len__() — novel
#
# blake2b and blake2s are implemented in the _blake2 C extension, not _hashlib.
# No prior spec checks __module__.__len__() for either.
# '_blake2' has 7 characters. Both novel.
# ---------------------------------------------------------------------------

invariant hashlib_extra32.blake2b.module_len:
  description: "hashlib.blake2b.__module__.__len__() == 7 — '_blake2' has 7 characters, novel invariant"
  category: module_metadata
  kind: python_call_eq
  function: blake2b.__module__.__len__
  args: []
  expected: 7

invariant hashlib_extra32.blake2s.module_len:
  description: "hashlib.blake2s.__module__.__len__() == 7 — '_blake2' has 7 characters, novel invariant"
  category: module_metadata
  kind: python_call_eq
  function: blake2s.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# hashlib.new.__module__.__len__() and __name__.__len__() — novel
#
# new is the pure-Python dispatch wrapper (__hash_new). extra29 covers
# new.__module__.__eq__('hashlib'). No prior spec checks __module__.__len__()
# or __name__.__len__() for new.
# new.__module__ == 'hashlib' (len 7); new.__name__ == '__hash_new' (len 10).
# ---------------------------------------------------------------------------

invariant hashlib_extra32.new.module_len:
  description: "hashlib.new.__module__.__len__() == 7 — 'hashlib' has 7 characters, novel invariant"
  category: module_metadata
  kind: python_call_eq
  function: new.__module__.__len__
  args: []
  expected: 7

invariant hashlib_extra32.new.name_len:
  description: "hashlib.new.__name__.__len__() == 10 — '__hash_new' has 10 characters, novel invariant"
  category: function_names
  kind: python_call_eq
  function: new.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Table: sha224/sha384/sha512/sha1 __module__.__len__() — novel
#
# Groups the four OpenSSL-backed constructors whose __module__.__len__() had
# not been checked before extra32. All share '_hashlib' (len 8).
# ---------------------------------------------------------------------------

table hashlib_extra32.openssl_module_lengths:
  description: "sha224/sha384/sha512/sha1 __module__.__len__() == 8 — '_hashlib' C extension, novel invariants"
  kind: python_call_eq
  category: module_metadata
  id_prefix: hlmopl32

  columns: [id, function, args, expected]
  rows:
    - [sha224, sha224.__module__.__len__, [], 8]
    - [sha384, sha384.__module__.__len__, [], 8]
    - [sha512, sha512.__module__.__len__, [], 8]
    - [sha1,   sha1.__module__.__len__,   [], 8]

# ---------------------------------------------------------------------------
# Table: blake2b/blake2s __name__.__len__() and sha3_256 __name__/__module__
#
# blake2b/blake2s __name__.__len__() are novel. sha3_256 __name__.__len__()
# and __module__.__len__() are also novel.
# blake2b.__name__ == 'blake2b' (7), blake2s.__name__ == 'blake2s' (7),
# sha3_256.__name__ == 'openssl_sha3_256' (16), sha3_256.__module__ == '_hashlib' (8).
# ---------------------------------------------------------------------------

table hashlib_extra32.blake2_sha3_name_lengths:
  description: "blake2b/blake2s __name__.__len__() and sha3_256 __name__/__module__.__len__() — novel invariants"
  kind: python_call_eq
  category: function_names
  id_prefix: hlbl32

  columns: [id, function, args, expected]
  rows:
    - [blake2b_name_len,        blake2b.__name__.__len__,        [], 7]
    - [blake2s_name_len,        blake2s.__name__.__len__,        [], 7]
    - [blake2b_module_len,      blake2b.__module__.__len__,      [], 7]
    - [blake2s_module_len,      blake2s.__module__.__len__,      [], 7]
    - [sha3_256_name_len,       sha3_256.__name__.__len__,       [], 16]
    - [sha3_256_module_len,     sha3_256.__module__.__len__,     [], 8]
