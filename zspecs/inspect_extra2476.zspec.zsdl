spec: inspect_extra2476
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2476 (_extra2476): __contains__ and __getitem__ dict-presence checks across inspect types."
    - "Theme: membership-test and item-access protocol presence in class __dict__."
    - "inspect.Parameter: introspection class for function parameters — defines name/default/annotation/kind/replace but NOT __contains__ or __getitem__."
    - "inspect.Signature: call signature class — defines parameters/bind/bind_partial/replace/from_callable but NOT __contains__ or __getitem__."
    - "inspect.BoundArguments: result of Signature.bind() — defines args/kwargs/arguments/apply_defaults but NOT __contains__ or __getitem__."
    - "inspect.FullArgSpec: named tuple — defines field properties but NOT __contains__ or __getitem__ in its class __dict__."
    - "inspect.ClosureVars: named tuple for closure vars — no membership or item protocols."
    - "inspect.Traceback: introspection result type — no membership or item protocols."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __contains__ dict-presence across inspect introspection types
#
# inspect.Parameter, Signature, BoundArguments, FullArgSpec, ClosureVars,
# and Traceback are introspection helper classes. None implement the
# membership-test protocol directly in their class __dict__.
# All checks return False.
# ---------------------------------------------------------------------------

table inspect_extra2476.contains_protocol:
  description: "inspect introspection types __contains__ dict-presence — all False — wave 2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2476

  columns: [id, function, args, expected]
  rows:
    - ["in2476001", "inspect.Parameter.__dict__.__contains__", ["__contains__"], false]
    - ["in2476002", "inspect.Signature.__dict__.__contains__", ["__contains__"], false]
    - ["in2476003", "inspect.BoundArguments.__dict__.__contains__", ["__contains__"], false]
    - ["in2476004", "inspect.FullArgSpec.__dict__.__contains__", ["__contains__"], false]
    - ["in2476005", "inspect.ClosureVars.__dict__.__contains__", ["__contains__"], false]
    - ["in2476006", "inspect.Traceback.__dict__.__contains__", ["__contains__"], false]

# ---------------------------------------------------------------------------
# Table 2: __getitem__ dict-presence across inspect introspection types
#
# None of the inspect introspection types define __getitem__ in their
# class __dict__. Despite Signature.parameters returning an OrderedDict
# that supports indexing, Signature itself does not define __getitem__.
# All checks return False.
# ---------------------------------------------------------------------------

table inspect_extra2476.getitem_protocol:
  description: "inspect introspection types __getitem__ dict-presence — all False — wave 2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2476

  columns: [id, function, args, expected]
  rows:
    - ["in2476007", "inspect.Parameter.__dict__.__contains__", ["__getitem__"], false]
    - ["in2476008", "inspect.Signature.__dict__.__contains__", ["__getitem__"], false]
    - ["in2476009", "inspect.BoundArguments.__dict__.__contains__", ["__getitem__"], false]
    - ["in2476010", "inspect.FullArgSpec.__dict__.__contains__", ["__getitem__"], false]
    - ["in2476011", "inspect.ClosureVars.__dict__.__contains__", ["__getitem__"], false]
    - ["in2476012", "inspect.Traceback.__dict__.__contains__", ["__getitem__"], false]

# ---------------------------------------------------------------------------
# Table 3: Confirmed attrs in inspect.Parameter.__dict__ and Signature.__dict__
#
# Even though membership and item-access protocols are absent, these classes
# define rich introspection APIs. This table confirms the keys that ARE
# present to contrast with the absent protocol keys.
# ---------------------------------------------------------------------------

table inspect_extra2476.confirmed_present_keys:
  description: "inspect.Parameter and Signature known-present dict keys — wave 2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2476

  columns: [id, function, args, expected]
  rows:
    - ["in2476013", "inspect.Parameter.__dict__.__contains__", ["name"], true]
    - ["in2476014", "inspect.Parameter.__dict__.__contains__", ["default"], true]
    - ["in2476015", "inspect.Parameter.__dict__.__contains__", ["annotation"], true]
    - ["in2476016", "inspect.Parameter.__dict__.__contains__", ["kind"], true]
    - ["in2476017", "inspect.Parameter.__dict__.__contains__", ["replace"], true]
    - ["in2476018", "inspect.Parameter.__dict__.__contains__", ["empty"], true]
    - ["in2476019", "inspect.Parameter.__dict__.__contains__", ["POSITIONAL_ONLY"], true]
    - ["in2476020", "inspect.Parameter.__dict__.__contains__", ["KEYWORD_ONLY"], true]
    - ["in2476021", "inspect.Signature.__dict__.__contains__", ["parameters"], true]
    - ["in2476022", "inspect.Signature.__dict__.__contains__", ["return_annotation"], true]
    - ["in2476023", "inspect.Signature.__dict__.__contains__", ["bind"], true]
    - ["in2476024", "inspect.Signature.__dict__.__contains__", ["bind_partial"], true]
    - ["in2476025", "inspect.Signature.__dict__.__contains__", ["from_callable"], true]
    - ["in2476026", "inspect.BoundArguments.__dict__.__contains__", ["args"], true]
    - ["in2476027", "inspect.BoundArguments.__dict__.__contains__", ["kwargs"], true]
    - ["in2476028", "inspect.BoundArguments.__dict__.__contains__", ["arguments"], true]
    - ["in2476029", "inspect.BoundArguments.__dict__.__contains__", ["apply_defaults"], true]
    - ["in2476030", "inspect.BoundArguments.__dict__.__contains__", ["signature"], true]

# ---------------------------------------------------------------------------
# Table 4: KeyError from inspect class __dict__.__getitem__ for absent keys
#
# Because no inspect type defines __contains__ or __getitem__ in its
# class __dict__, looking them up via __getitem__ on the class __dict__
# (a mappingproxy) raises KeyError.
# ---------------------------------------------------------------------------

table inspect_extra2476.getitem_raises_keyerror:
  description: "inspect class __dict__.__getitem__ raises KeyError for __contains__ and __getitem__ — wave 2476"
  kind: python_call_raises
  category: dict_contains
  id_prefix: in2476

  columns: [id, function, args, expected]
  rows:
    - ["in2476031", "inspect.Parameter.__dict__.__getitem__", ["__contains__"], "KeyError"]
    - ["in2476032", "inspect.Parameter.__dict__.__getitem__", ["__getitem__"], "KeyError"]
    - ["in2476033", "inspect.Signature.__dict__.__getitem__", ["__contains__"], "KeyError"]
    - ["in2476034", "inspect.Signature.__dict__.__getitem__", ["__getitem__"], "KeyError"]
    - ["in2476035", "inspect.BoundArguments.__dict__.__getitem__", ["__contains__"], "KeyError"]
    - ["in2476036", "inspect.BoundArguments.__dict__.__getitem__", ["__getitem__"], "KeyError"]
