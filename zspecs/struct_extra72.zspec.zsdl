spec: struct_extra72
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra71.zspec.zsdl — covers Struct.__dict__.__contains__('__doc__') / pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/__module__=='_struct' (table + invariants)."
    - "struct_extra70.zspec.zsdl — covers Struct/__dict__/__contains__ __init__/__new__/__repr__/__module__ / pack/unpack/calcsize/__doc__.__contains__('format') / Struct/__doc__.__contains__('fmt'/'Struct') (table + invariants)."
    - "struct_extra65.zspec.zsdl — covers Struct/__dict__/__contains__ pack/unpack/pack_into/unpack_from/iter_unpack/size/format (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra71; it does NOT duplicate invariants present in those files."
    - "Wave 243 theme: struct.Struct method __doc__ content."
    - "struct.Struct.pack.__doc__.__class__.__name__ == 'str' — Struct.pack has a C docstring starting with 'S.pack(v1, v2, ...) -> bytes'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__doc__.__contains__('pack') == True — the docstring for Struct.pack mentions 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__doc__.__class__.__name__ == 'str' — Struct.unpack has a C docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__doc__.__contains__('unpack') == True — the docstring for Struct.unpack mentions 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__doc__.__class__.__name__ == 'str' — Struct.pack_into has a C docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__doc__.__contains__('pack') == True — the docstring for Struct.pack_into mentions 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__doc__.__class__.__name__ == 'str' — Struct.unpack_from has a C docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__doc__.__contains__('unpack') == True — the docstring for Struct.unpack_from mentions 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__doc__.__class__.__name__ == 'str' — Struct.iter_unpack has a C docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__doc__.__contains__('unpack') == True — the docstring for Struct.iter_unpack mentions 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack and Struct.unpack __doc__ class name and content
#
# Wave 243 theme: struct.Struct method __doc__ content.
#
# struct.Struct.pack and struct.Struct.unpack are C method_descriptors; each
# has a C docstring (a str). The pack docstring mentions 'pack'; the unpack
# docstring mentions 'unpack'. struct_extra70 checks module-level pack/unpack
# __doc__.__contains__('format'). No prior struct spec checks Struct.pack.__doc__
# class or Struct.pack.__doc__.__contains__('pack').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra72.Struct_pack_unpack_doc:
  description: "struct.Struct.pack/__doc__/__class__/__name__.__eq__('str')==True / Struct.pack/__doc__.__contains__('pack')==True / Struct.unpack/__doc__/__class__/__name__.__eq__('str')==True / Struct.unpack/__doc__.__contains__('unpack')==True — Struct.pack and Struct.unpack are C method_descriptors with str docstrings; pack docstring mentions 'pack'; unpack docstring mentions 'unpack'; no prior struct spec checks Struct.pack or Struct.unpack __doc__ class or content; first __doc__ class and content anchor for Struct.pack and Struct.unpack"
  kind: python_call_eq
  category: docstrings
  id_prefix: structmore72

  columns: [id, function, args, expected]
  rows:
    - [Struct_pack_doc_class_str,       Struct.pack.__doc__.__class__.__name__.__eq__, ["str"],   true]
    - [Struct_pack_doc_contains_pack,   Struct.pack.__doc__.__contains__,              ["pack"],  true]
    - [Struct_unpack_doc_class_str,     Struct.unpack.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [Struct_unpack_doc_contains_unpack, Struct.unpack.__doc__.__contains__,          ["unpack"], true]

# ---------------------------------------------------------------------------
# struct.Struct.pack_into and Struct.unpack_from __doc__ class name and content
#
# Wave 243 theme: struct.Struct method __doc__ content.
#
# struct.Struct.pack_into and struct.Struct.unpack_from are C method_descriptors
# with str docstrings. The pack_into docstring mentions 'pack'; the unpack_from
# docstring mentions 'unpack'. No prior struct spec checks Struct.pack_into.__doc__
# class or Struct.unpack_from.__doc__ class.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra72.Struct_pack_into_unpack_from_doc:
  description: "struct.Struct.pack_into/__doc__/__class__/__name__.__eq__('str')==True / Struct.pack_into/__doc__.__contains__('pack')==True / Struct.unpack_from/__doc__/__class__/__name__.__eq__('str')==True / Struct.unpack_from/__doc__.__contains__('unpack')==True — Struct.pack_into and Struct.unpack_from are C method_descriptors with str docstrings; no prior struct spec checks Struct.pack_into or Struct.unpack_from __doc__ class; first __doc__ class and content anchor for Struct.pack_into and Struct.unpack_from"
  kind: python_call_eq
  category: docstrings
  id_prefix: structmore72

  columns: [id, function, args, expected]
  rows:
    - [Struct_pack_into_doc_class_str,       Struct.pack_into.__doc__.__class__.__name__.__eq__,   ["str"],    true]
    - [Struct_pack_into_doc_contains_pack,   Struct.pack_into.__doc__.__contains__,                ["pack"],   true]
    - [Struct_unpack_from_doc_class_str,     Struct.unpack_from.__doc__.__class__.__name__.__eq__, ["str"],    true]
    - [Struct_unpack_from_doc_contains_unpack, Struct.unpack_from.__doc__.__contains__,            ["unpack"], true]

# ---------------------------------------------------------------------------
