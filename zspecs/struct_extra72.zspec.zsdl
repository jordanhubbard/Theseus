# Struct.iter_unpack.__doc__ class or Struct.iter_unpack.__doc__.__contains__('unpack').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra72.Struct_iter_unpack_doc:
  description: "struct.Struct.iter_unpack/__doc__/__class__/__name__.__eq__('str')==True / Struct.iter_unpack/__doc__.__contains__('unpack')==True — Struct.iter_unpack is a C method_descriptor with a str docstring; docstring mentions 'unpack'; no prior struct spec checks Struct.iter_unpack.__doc__ class; first __doc__ class and content anchor for Struct.iter_unpack"
  kind: python_call_eq
  category: docstrings
  id_prefix: structmore72

  columns: [id, function, args, expected]
  rows:
    - [Struct_iter_unpack_doc_class_str,     Struct.iter_unpack.__doc__.__class__.__name__.__eq__, ["str"],    true]
    - [Struct_iter_unpack_doc_contains_unpack, Struct.iter_unpack.__doc__.__contains__,            ["unpack"], true]

# ---------------------------------------------------------------------------
# struct.Struct.pack and Struct.pack_into __doc__ content cross-check
#
# Wave 243 theme: pack-family method docstring mentions 'pack'.
#
# Both Struct.pack and Struct.pack_into mention 'pack' in their docstrings.
# This cross-check pairs the two pack-family methods in a single table.
# No prior struct spec checks these methods' __doc__.__contains__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra72.Struct_pack_family_contains_pack:
  description: "struct.Struct.pack/__doc__.__contains__('pack')==True / Struct.pack_into/__doc__.__contains__('pack')==True — both pack-family methods mention 'pack' in their docstrings; no prior struct spec checks __doc__.__contains__ for Struct.pack or Struct.pack_into; first pack-family docstring content cross-check"
  kind: python_call_eq
  category: docstrings
  id_prefix: structmore72

  columns: [id, function, args, expected]
  rows:
    - [Struct_pack_doc_contains_pack2,      Struct.pack.__doc__.__contains__,      ["pack"], true]
    - [Struct_pack_into_doc_contains_pack2, Struct.pack_into.__doc__.__contains__, ["pack"], true]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__doc__.__class__.__name__.__eq__('str') — standalone
#
# Struct.pack has a C docstring; its __doc__.__class__.__name__ is 'str'. No
# prior struct spec checks Struct.pack.__doc__ class. First __doc__ class
# standalone for Struct.pack. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra72.Struct_pack_doc_class_str:
  description: "struct.Struct.pack.__doc__.__class__.__name__.__eq__('str') == True — Struct.pack is a C method_descriptor with a str docstring; no prior struct spec checks Struct.pack.__doc__ class; first __doc__ class standalone for Struct.pack"
  category: docstrings
  kind: python_call_eq
  function: Struct.pack.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

