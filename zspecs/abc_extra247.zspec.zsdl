spec: abc_extra247
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "https://docs.python.org/3/library/abc.html#abc.ABCMeta — ABCMeta documentation"
    - "https://docs.python.org/3/library/abc.html#abc.ABCMeta.register — register method documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py (pure Python implementation of ABCMeta)"
    - "CPython source: Modules/_abc.c (C-level accelerators for ABCMeta)"
  notes:
    - "abc.ABCMeta.register.__name__ == 'register' (len=8); __qualname__ == 'ABCMeta.register' (len=16); __module__ == 'abc' (len=3); __class__.__name__ == 'function'."
    - "abc.ABCMeta.__subclasshook__.__name__ == '__subclasshook__' (len=16); __qualname__ == 'ABCMeta.__subclasshook__' (len=24); __class__.__name__ == 'builtin_function_or_method' (C builtin, unlike register)."
    - "abc.ABCMeta.__instancecheck__.__name__ == '__instancecheck__' (len=17); __qualname__ == 'ABCMeta.__instancecheck__' (len=25); __module__ == 'abc' (len=3); __class__.__name__ == 'function'."
    - "abc.ABCMeta.__subclasscheck__.__name__ == '__subclasscheck__' (len=17); __qualname__ == 'ABCMeta.__subclasscheck__' (len=25); __module__ == 'abc' (len=3); __class__.__name__ == 'function'."
    - "abc.abstractmethod.__call__.__name__ == '__call__' (len=8); __qualname__ == 'function.__call__' (len=17); __class__.__name__ == 'method-wrapper'."
    - "__instancecheck__ and __subclasscheck__ have the same __name__ length (17) and __qualname__ length (25)."
    - "__subclasshook__ is a builtin_function_or_method (C-level) while __instancecheck__ and __subclasscheck__ are pure Python functions."
    - "abstractmethod.__call__ is a method-wrapper (slot wrapper) not a plain function — it is the tp_call slot of the function type."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta method identity — register, __subclasshook__, __instancecheck__,
# __subclasscheck__
#
# register.__name__ == 'register' (len=8)
# register.__qualname__ == 'ABCMeta.register' (len=16)
# register.__module__ == 'abc' (len=3)
# register.__class__.__name__ == 'function'
# __subclasshook__.__name__ == '__subclasshook__' (len=16)
# __subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (len=24)
# __subclasshook__.__class__.__name__ == 'builtin_function_or_method'
# __instancecheck__.__name__ == '__instancecheck__' (len=17)
# __instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (len=25)
# __instancecheck__.__module__ == 'abc' (len=3)
# __subclasscheck__.__name__ == '__subclasscheck__' (len=17)
# __subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (len=25)
# __subclasscheck__.__module__ == 'abc' (len=3)
# ---------------------------------------------------------------------------

table abc_extra247.abcmeta_method_identity:
  description: "abc.ABCMeta method identity — register(len=8) is a pure Python function with qualname 'ABCMeta.register'(len=16) and module 'abc'(len=3); __subclasshook__(len=16) is a builtin_function_or_method (C-level) with qualname 'ABCMeta.__subclasshook__'(len=24); __instancecheck__(len=17) and __subclasscheck__(len=17) are pure Python functions sharing qualname length 25 and module 'abc'(len=3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc247ami

  columns: [id, function, args, expected, description]
  rows:
    - [ami_reg_name_eq,    ABCMeta.register.__name__.__eq__,              ["register"],                        true, "ABCMeta.register.__name__ == 'register'; verified with Python 3.14.3"]
    - [ami_reg_name_len,   ABCMeta.register.__name__.__len__,             [],                                  8,    "ABCMeta.register.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [ami_reg_qual_eq,    ABCMeta.register.__qualname__.__eq__,          ["ABCMeta.register"],                true, "ABCMeta.register.__qualname__ == 'ABCMeta.register'; verified with Python 3.14.3"]
    - [ami_reg_qual_len,   ABCMeta.register.__qualname__.__len__,         [],                                  16,   "ABCMeta.register.__qualname__.__len__() == 16; verified with Python 3.14.3"]
    - [ami_reg_mod_eq,     ABCMeta.register.__module__.__eq__,            ["abc"],                             true, "ABCMeta.register.__module__ == 'abc'; verified with Python 3.14.3"]
    - [ami_reg_mod_len,    ABCMeta.register.__module__.__len__,           [],                                  3,    "ABCMeta.register.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [ami_reg_cls_eq,     ABCMeta.register.__class__.__name__.__eq__,    ["function"],                        true, "ABCMeta.register.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]
    - [ami_sch_name_eq,    ABCMeta.__subclasshook__.__name__.__eq__,      ["__subclasshook__"],                true, "ABCMeta.__subclasshook__.__name__ == '__subclasshook__'; verified with Python 3.14.3"]
    - [ami_sch_name_len,   ABCMeta.__subclasshook__.__name__.__len__,     [],                                  16,   "ABCMeta.__subclasshook__.__name__.__len__() == 16; verified with Python 3.14.3"]
    - [ami_sch_qual_eq,    ABCMeta.__subclasshook__.__qualname__.__eq__,  ["ABCMeta.__subclasshook__"],        true, "ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__'; verified with Python 3.14.3"]
    - [ami_sch_qual_len,   ABCMeta.__subclasshook__.__qualname__.__len__, [],                                  24,   "ABCMeta.__subclasshook__.__qualname__.__len__() == 24; verified with Python 3.14.3"]
    - [ami_sch_cls_eq,     ABCMeta.__subclasshook__.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "ABCMeta.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' (C builtin); verified with Python 3.14.3"]
    - [ami_ic_name_eq,     ABCMeta.__instancecheck__.__name__.__eq__,     ["__instancecheck__"],               true, "ABCMeta.__instancecheck__.__name__ == '__instancecheck__'; verified with Python 3.14.3"]
    - [ami_ic_name_len,    ABCMeta.__instancecheck__.__name__.__len__,    [],                                  17,   "ABCMeta.__instancecheck__.__name__.__len__() == 17; verified with Python 3.14.3"]
    - [ami_ic_qual_eq,     ABCMeta.__instancecheck__.__qualname__.__eq__, ["ABCMeta.__instancecheck__"],       true, "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'; verified with Python 3.14.3"]
    - [ami_ic_qual_len,    ABCMeta.__instancecheck__.__qualname__.__len__, [],                                 25,   "ABCMeta.__instancecheck__.__qualname__.__len__() == 25; verified with Python 3.14.3"]
    - [ami_ic_mod_eq,      ABCMeta.__instancecheck__.__module__.__eq__,   ["abc"],                             true, "ABCMeta.__instancecheck__.__module__ == 'abc'; verified with Python 3.14.3"]
    - [ami_ic_mod_len,     ABCMeta.__instancecheck__.__module__.__len__,  [],                                  3,    "ABCMeta.__instancecheck__.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [ami_ic_cls_eq,      ABCMeta.__instancecheck__.__class__.__name__.__eq__, ["function"],                  true, "ABCMeta.__instancecheck__.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]
    - [ami_scc_name_eq,    ABCMeta.__subclasscheck__.__name__.__eq__,     ["__subclasscheck__"],               true, "ABCMeta.__subclasscheck__.__name__ == '__subclasscheck__'; verified with Python 3.14.3"]
    - [ami_scc_name_len,   ABCMeta.__subclasscheck__.__name__.__len__,    [],                                  17,   "ABCMeta.__subclasscheck__.__name__.__len__() == 17; verified with Python 3.14.3"]
    - [ami_scc_qual_eq,    ABCMeta.__subclasscheck__.__qualname__.__eq__, ["ABCMeta.__subclasscheck__"],       true, "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'; verified with Python 3.14.3"]
    - [ami_scc_qual_len,   ABCMeta.__subclasscheck__.__qualname__.__len__, [],                                 25,   "ABCMeta.__subclasscheck__.__qualname__.__len__() == 25; verified with Python 3.14.3"]
    - [ami_scc_mod_eq,     ABCMeta.__subclasscheck__.__module__.__eq__,   ["abc"],                             true, "ABCMeta.__subclasscheck__.__module__ == 'abc'; verified with Python 3.14.3"]
    - [ami_scc_mod_len,    ABCMeta.__subclasscheck__.__module__.__len__,  [],                                  3,    "ABCMeta.__subclasscheck__.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [ami_scc_cls_eq,     ABCMeta.__subclasscheck__.__class__.__name__.__eq__, ["function"],                  true, "ABCMeta.__subclasscheck__.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractmethod.__call__ identity
#
# abstractmethod.__call__.__name__ == '__call__' (len=8)
# abstractmethod.__call__.__qualname__ == 'function.__call__' (len=17)
# abstractmethod.__call__.__class__.__name__ == 'method-wrapper'
# ---------------------------------------------------------------------------

table abc_extra247.abstractmethod_call_identity:
  description: "abc.abstractmethod.__call__ identity — abstractmethod is a plain Python function (type='function'), so its __call__ slot is a method-wrapper (tp_call slot of the function type); __call__.__name__=='__call__'(len=8); __call__.__qualname__=='function.__call__'(len=17, shows it belongs to the function type, not to abstractmethod itself); __call__.__class__.__name__=='method-wrapper'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc247ac

  columns: [id, function, args, expected, description]
  rows:
    - [ac_name_eq,  abstractmethod.__call__.__name__.__eq__,               ["__call__"],          true, "abstractmethod.__call__.__name__ == '__call__'; verified with Python 3.14.3"]
    - [ac_name_len, abstractmethod.__call__.__name__.__len__,              [],                    8,    "abstractmethod.__call__.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [ac_qual_eq,  abstractmethod.__call__.__qualname__.__eq__,           ["function.__call__"], true, "abstractmethod.__call__.__qualname__ == 'function.__call__' (belongs to function type); verified with Python 3.14.3"]
    - [ac_qual_len, abstractmethod.__call__.__qualname__.__len__,          [],                    17,   "abstractmethod.__call__.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [ac_cls_eq,   abstractmethod.__call__.__class__.__name__.__eq__,     ["method-wrapper"],    true, "abstractmethod.__call__.__class__.__name__ == 'method-wrapper' (tp_call slot wrapper); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra247
# ---------------------------------------------------------------------------

invariant abc_extra247.subclasshook_is_c_builtin:
  description: "abc.ABCMeta.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') returns True — __subclasshook__ is the only ABCMeta method in this spec implemented as a C builtin; it contrasts with register, __instancecheck__, and __subclasscheck__ which are all pure Python functions; __subclasshook__.__name__=='__subclasshook__'(len=16); __qualname__=='ABCMeta.__subclasshook__'(len=24); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__subclasshook__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra247.instancecheck_subclasscheck_equal_qualname_len:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — __instancecheck__ and __subclasscheck__ share identical qualname length 25 ('ABCMeta.__instancecheck__' and 'ABCMeta.__subclasscheck__' are both len=25); this contrasts with register.__qualname__ (len=16) and __subclasshook__.__qualname__ (len=24); ABCMeta.__instancecheck__.__module__=='abc'(len=3); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__qualname__.__len__
  args: []
  expected: 25

invariant abc_extra247.abstractmethod_call_is_method_wrapper:
  description: "abc.abstractmethod.__call__.__qualname__.__eq__('function.__call__') returns True — abstractmethod.__call__ is the tp_call slot of the function type (qualname 'function.__call__', len=17), not an abstractmethod-specific __call__; __class__.__name__=='method-wrapper'; this shows that abstractmethod inherits its call behavior from the built-in function type; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__call__.__qualname__.__eq__
  args: ["function.__call__"]
  expected: true
