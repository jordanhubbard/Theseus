    - [io1471gd002, io.StringIO.__dict__.__contains__,     ["__getitem__"], false]
    - [io1471gd003, io.IOBase.__dict__.__contains__,       ["__getitem__"], false]
    - [io1471gd004, io.RawIOBase.__dict__.__contains__,    ["__getitem__"], false]
    - [io1471gd005, io.BufferedIOBase.__dict__.__contains__, ["__getitem__"], false]
    - [io1471gd006, io.TextIOBase.__dict__.__contains__,   ["__getitem__"], false]

