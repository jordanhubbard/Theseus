spec: itertools_extra70
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra69.zspec.zsdl."
    - "Wave 236 theme: itertools C type __class__.__name__ — all 16 module-level types have __class__.__name__ == 'type'."
    - "chain.__class__.__name__ == 'type' — chain is a C extension type; its metaclass is the built-in type. Verified with Python 3.14.3."
    - "islice.__class__.__name__ == 'type' — islice is a C extension type. Verified with Python 3.14.3."
    - "product.__class__.__name__ == 'type' — product is a C extension type. Verified with Python 3.14.3."
    - "combinations.__class__.__name__ == 'type' — combinations is a C extension type. Verified with Python 3.14.3."
    - "permutations.__class__.__name__ == 'type' — permutations is a C extension type. Verified with Python 3.14.3."
    - "accumulate.__class__.__name__ == 'type' — accumulate is a C extension type. Verified with Python 3.14.3."
    - "cycle.__class__.__name__ == 'type' — cycle is a C extension type. Verified with Python 3.14.3."
    - "repeat.__class__.__name__ == 'type' — repeat is a C extension type. Verified with Python 3.14.3."
    - "groupby.__class__.__name__ == 'type' — groupby is a C extension type. Verified with Python 3.14.3."
    - "starmap.__class__.__name__ == 'type' — starmap is a C extension type. Verified with Python 3.14.3."
    - "compress.__class__.__name__ == 'type' — compress is a C extension type. Verified with Python 3.14.3."
    - "dropwhile.__class__.__name__ == 'type' — dropwhile is a C extension type. Verified with Python 3.14.3."
    - "takewhile.__class__.__name__ == 'type' — takewhile is a C extension type. Verified with Python 3.14.3."
    - "zip_longest.__class__.__name__ == 'type' — zip_longest is a C extension type. Verified with Python 3.14.3."
    - "filterfalse.__class__.__name__ == 'type' — filterfalse is a C extension type. Verified with Python 3.14.3."
    - "count.__class__.__name__ == 'type' — count is a C extension type. Verified with Python 3.14.3."
    - "Prior itertools_extra69 covered __qualname__ for all 16 types. itertools_extra68 covered __name__ and __module__. This spec covers __class__.__name__ == 'type' for all 16 types, which is novel to extra70 under the itertclass70 id_prefix."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools C type __class__.__name__ — set 1 — extra70
#
# Wave 236 theme: all 16 module-level itertools types have the built-in type
# as their metaclass, so __class__.__name__ == 'type' for each.
#
# C extension types defined at module level in Modules/itertoolsmodule.c are
# created using PyType_Ready() with no custom metaclass, so their __class__
# (the metaclass) is the built-in type.
#
# chain.__class__.__name__        == 'type'
# islice.__class__.__name__       == 'type'
# product.__class__.__name__      == 'type'
# combinations.__class__.__name__ == 'type'
# permutations.__class__.__name__ == 'type'
#
# No prior itertools spec checks __class__.__name__ for any itertools type.
# New to extra70.
# ---------------------------------------------------------------------------

table itertools_extra70.itertools_class_names_1:
  description: "itertools C types __class__.__name__ set 1: chain/islice/product/combinations/permutations __class__.__name__=='type'; wave 236 metaclass identity; new to extra70"
  kind: python_call_eq
  category: type_metaclass
  id_prefix: itertclass70

  columns: [id, function, args, expected, description]
  rows:
    - [chain_class_name_eq_type,
       chain.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.chain.__class__.__name__.__eq__('type') == True — chain is a C extension type defined in Modules/itertoolsmodule.c that chains together multiple iterables into a single sequential iterator; C extension types are created via PyType_Ready() with the default metaclass, which is the built-in type; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior itertools spec checks chain.__class__.__name__; new to extra70"]
    - [islice_class_name_eq_type,
       islice.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.islice.__class__.__name__.__eq__('type') == True — islice is a C extension type defined in Modules/itertoolsmodule.c that returns selected elements from an iterator like slicing a sequence; C extension types use the built-in type as their default metaclass; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior itertools spec checks islice.__class__.__name__; new to extra70"]
    - [product_class_name_eq_type,
       product.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.product.__class__.__name__.__eq__('type') == True — product is a C extension type defined in Modules/itertoolsmodule.c that computes the Cartesian product of input iterables; C extension types use the built-in type as their default metaclass; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior itertools spec checks product.__class__.__name__; new to extra70"]
    - [combinations_class_name_eq_type,
       combinations.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.combinations.__class__.__name__.__eq__('type') == True — combinations is a C extension type defined in Modules/itertoolsmodule.c that returns r-length subsequences of elements from an iterable without replacement; C extension types use the built-in type as their default metaclass; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior itertools spec checks combinations.__class__.__name__; new to extra70"]
    - [permutations_class_name_eq_type,
       permutations.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.permutations.__class__.__name__.__eq__('type') == True — permutations is a C extension type defined in Modules/itertoolsmodule.c that returns successive r-length permutations of elements from an iterable; C extension types use the built-in type as their default metaclass; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior itertools spec checks permutations.__class__.__name__; new to extra70"]

# ---------------------------------------------------------------------------
# itertools C type __class__.__name__ — set 2 — extra70
#
# Wave 236 theme: __class__.__name__ == 'type' for 5 more itertools C types.
#
# accumulate, cycle, repeat, groupby, starmap are all C extension types
# defined in Modules/itertoolsmodule.c with the default metaclass (type).
#
# accumulate.__class__.__name__ == 'type'
# cycle.__class__.__name__      == 'type'
# repeat.__class__.__name__     == 'type'
# groupby.__class__.__name__    == 'type'
# starmap.__class__.__name__    == 'type'
#
# New to extra70.
# ---------------------------------------------------------------------------

table itertools_extra70.itertools_class_names_2:
  description: "itertools C types __class__.__name__ set 2: accumulate/cycle/repeat/groupby/starmap __class__.__name__=='type'; wave 236 metaclass identity; new to extra70"
  kind: python_call_eq
  category: type_metaclass
  id_prefix: itertclass70

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_class_name_eq_type,
       accumulate.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.accumulate.__class__.__name__.__eq__('type') == True — accumulate is a C extension type defined in Modules/itertoolsmodule.c that returns accumulated sums or accumulated results of other binary functions; C extension types use the built-in type as their default metaclass; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior itertools spec checks accumulate.__class__.__name__; new to extra70"]
    - [cycle_class_name_eq_type,
       cycle.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.cycle.__class__.__name__.__eq__('type') == True — cycle is a C extension type defined in Modules/itertoolsmodule.c that cycles through an iterable indefinitely by saving a copy of each element and re-yielding them; C extension types use the built-in type as their default metaclass; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior itertools spec checks cycle.__class__.__name__; new to extra70"]
    - [repeat_class_name_eq_type,
       repeat.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.repeat.__class__.__name__.__eq__('type') == True — repeat is a C extension type defined in Modules/itertoolsmodule.c that returns a value a specified number of times or indefinitely; C extension types use the built-in type as their default metaclass; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior itertools spec checks repeat.__class__.__name__; new to extra70"]
    - [groupby_class_name_eq_type,
       groupby.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.groupby.__class__.__name__.__eq__('type') == True — groupby is a C extension type defined in Modules/itertoolsmodule.c that groups consecutive elements of an iterable using a key function and returns (key, group_iterator) pairs; C extension types use the built-in type as their default metaclass; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior itertools spec checks groupby.__class__.__name__; new to extra70"]
    - [starmap_class_name_eq_type,
       starmap.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.starmap.__class__.__name__.__eq__('type') == True — starmap is a C extension type defined in Modules/itertoolsmodule.c that applies a function to argument tuples by unpacking each element from the iterable (equivalent to map(func, *zip(*iterable))); C extension types use the built-in type as their default metaclass; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior itertools spec checks starmap.__class__.__name__; new to extra70"]

# ---------------------------------------------------------------------------
# itertools C type __class__.__name__ — set 3 — extra70
#
# Wave 236 theme: __class__.__name__ == 'type' for 5 more itertools C types.
#
# compress, dropwhile, takewhile, zip_longest, filterfalse are all C extension
# types defined in Modules/itertoolsmodule.c with the default metaclass (type).
#
# compress.__class__.__name__    == 'type'
# dropwhile.__class__.__name__   == 'type'
# takewhile.__class__.__name__   == 'type'
# zip_longest.__class__.__name__ == 'type'
# filterfalse.__class__.__name__ == 'type'
#
# New to extra70.
# ---------------------------------------------------------------------------

table itertools_extra70.itertools_class_names_3:
  description: "itertools C types __class__.__name__ set 3: compress/dropwhile/takewhile/zip_longest/filterfalse __class__.__name__=='type'; wave 236 metaclass identity; new to extra70"
  kind: python_call_eq
  category: type_metaclass
  id_prefix: itertclass70

  columns: [id, function, args, expected, description]
  rows:
    - [compress_class_name_eq_type,
       compress.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.compress.__class__.__name__.__eq__('type') == True — compress is a C extension type defined in Modules/itertoolsmodule.c that filters elements from a data iterable using a boolean selector iterable, yielding only those elements whose corresponding selector is True; C extension types use the built-in type as their default metaclass; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior itertools spec checks compress.__class__.__name__; new to extra70"]
    - [dropwhile_class_name_eq_type,
       dropwhile.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.dropwhile.__class__.__name__.__eq__('type') == True — dropwhile is a C extension type defined in Modules/itertoolsmodule.c that drops elements from the iterable while the predicate is true and then yields the remaining elements; C extension types use the built-in type as their default metaclass; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior itertools spec checks dropwhile.__class__.__name__; new to extra70"]
    - [takewhile_class_name_eq_type,
       takewhile.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.takewhile.__class__.__name__.__eq__('type') == True — takewhile is a C extension type defined in Modules/itertoolsmodule.c that yields elements from the iterable as long as the predicate is true and then stops; C extension types use the built-in type as their default metaclass; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior itertools spec checks takewhile.__class__.__name__; new to extra70"]
    - [zip_longest_class_name_eq_type,
       zip_longest.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.zip_longest.__class__.__name__.__eq__('type') == True — zip_longest is a C extension type defined in Modules/itertoolsmodule.c that aggregates elements from each of the iterables using a fillvalue for shorter ones (unlike built-in zip which stops at the shortest); C extension types use the built-in type as their default metaclass; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior itertools spec checks zip_longest.__class__.__name__; new to extra70"]
    - [filterfalse_class_name_eq_type,
       filterfalse.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.filterfalse.__class__.__name__.__eq__('type') == True — filterfalse is a C extension type defined in Modules/itertoolsmodule.c that yields elements for which the predicate returns False (complementing the built-in filter which yields elements for which the predicate returns True); C extension types use the built-in type as their default metaclass; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior itertools spec checks filterfalse.__class__.__name__; new to extra70"]

# ---------------------------------------------------------------------------
# itertools C type __class__.__name__ — set 4 — extra70
#
# Wave 236 theme: __class__.__name__ == 'type' for count.
#
# count is a C extension type defined at module level in itertoolsmodule.c.
# Its metaclass is the built-in type.
#
# count.__class__.__name__ == 'type'
#
# New to extra70.
# ---------------------------------------------------------------------------

table itertools_extra70.itertools_class_names_4:
  description: "itertools C type __class__.__name__ set 4: count __class__.__name__=='type'; wave 236 metaclass identity; new to extra70"
  kind: python_call_eq
  category: type_metaclass
  id_prefix: itertclass70

  columns: [id, function, args, expected, description]
  rows:
    - [count_class_name_eq_type,
       count.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.count.__class__.__name__.__eq__('type') == True — count is a C extension type defined in Modules/itertoolsmodule.c that generates an infinite arithmetic sequence (count(start, step)) starting from a given number with a given step; C extension types use the built-in type as their default metaclass; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior itertools spec checks count.__class__.__name__; new to extra70"]

