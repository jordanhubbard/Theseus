spec: asyncio_extra2086
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-queue.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2086 (_extra2086): __format__, __bytes__, __fspath__, __buffer__/__release_buffer__ dict-presence checks."
    - "asyncio types (Task, Future, Event, Lock, Queue, Semaphore, Condition, StreamReader, BoundedSemaphore) are concurrency primitives."
    - "None of these types define __format__, __bytes__, __fspath__, __buffer__, or __release_buffer__ in their own __dict__."
    - "__format__ is the string-formatting protocol; asyncio types rely on object.__format__ inherited from object."
    - "__bytes__ is the bytes-conversion protocol; asyncio types have no binary serialization support."
    - "__fspath__ is the filesystem-path protocol (os.fspath); asyncio types are not path-like objects."
    - "__buffer__ and __release_buffer__ are the PEP 688 buffer protocol; asyncio types do not expose raw buffers."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table asyncio_extra2086.format_protocol:
  description: "asyncio types __format__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2086

  columns: [id, function, args, expected]
  rows:
    - ["as2086001", "asyncio.Task.__dict__.__contains__", ["__format__"], false]
    - ["as2086002", "asyncio.Future.__dict__.__contains__", ["__format__"], false]
    - ["as2086003", "asyncio.Event.__dict__.__contains__", ["__format__"], false]
    - ["as2086004", "asyncio.Lock.__dict__.__contains__", ["__format__"], false]
    - ["as2086005", "asyncio.Queue.__dict__.__contains__", ["__format__"], false]
    - ["as2086006", "asyncio.Semaphore.__dict__.__contains__", ["__format__"], false]
    - ["as2086007", "asyncio.Condition.__dict__.__contains__", ["__format__"], false]
    - ["as2086008", "asyncio.StreamReader.__dict__.__contains__", ["__format__"], false]
    - ["as2086009", "asyncio.BoundedSemaphore.__dict__.__contains__", ["__format__"], false]

