spec: modulefinder
version: ">=3.x"
backend: python_module(modulefinder)

docs: https://docs.python.org/3/library/modulefinder.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/modulefinder.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "modulefinder source: Lib/modulefinder.py (PSF; source inspection permitted)"
  not_derived_from:
    - "modulefinder source: internal Import machinery / sys.path resolution details"
  notes:
    - "modulefinder.ModuleFinder traces all modules used by a script, following imports recursively."
    - "modulefinder.Module is the data class used to represent each found module; it holds __name__, __file__, __path__, etc."
    - "ModuleFinder().any_missing() returns a list of module names that were imported but not found; this is [] before run_script() is called."
    - "ModuleFinder.find_module() is the internal resolver; ModuleFinder.find_all_submodules() recurses into packages."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "ModuleFinder.run_script() raises IOError/FileNotFoundError if the script path does not exist. any_missing() never raises."
  stderr: "null"
  stickiness: "N/A — each ModuleFinder instance maintains independent state."
  codes: {}

# ---------------------------------------------------------------------------
# Class names
# ---------------------------------------------------------------------------

invariant modulefinder.names.ModuleFinder:
  description: "modulefinder.ModuleFinder.__name__ == 'ModuleFinder'"
  category: names
  kind: python_call_eq
  function: ModuleFinder.__name__.__eq__
  args: ["ModuleFinder"]
  expected: true

invariant modulefinder.names.Module:
  description: "modulefinder.Module.__name__ == 'Module'"
  category: names
  kind: python_call_eq
  function: Module.__name__.__eq__
  args: ["Module"]
  expected: true

# ---------------------------------------------------------------------------
# Module membership
# ---------------------------------------------------------------------------

invariant modulefinder.modules.ModuleFinder:
  description: "modulefinder.ModuleFinder.__module__ == 'modulefinder'"
  category: modules
  kind: python_call_eq
  function: ModuleFinder.__module__.__eq__
  args: ["modulefinder"]
  expected: true

# ---------------------------------------------------------------------------
# Method names on ModuleFinder
# ---------------------------------------------------------------------------

table modulefinder.ModuleFinder.method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [run_script,           ModuleFinder.run_script.__name__.__eq__,           ["run_script"],           true]
    - [report,               ModuleFinder.report.__name__.__eq__,               ["report"],               true]
    - [any_missing,          ModuleFinder.any_missing.__name__.__eq__,          ["any_missing"],          true]
    - [find_module,          ModuleFinder.find_module.__name__.__eq__,          ["find_module"],          true]
    - [find_all_submodules,  ModuleFinder.find_all_submodules.__name__.__eq__,  ["find_all_submodules"],  true]

# ---------------------------------------------------------------------------
# Method names on Module
# ---------------------------------------------------------------------------

invariant modulefinder.Module.init_name:
  description: "modulefinder.Module.__init__.__name__ == '__init__'"
  category: method_names
  kind: python_call_eq
  function: Module.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral — ModuleFinder instantiation
# ---------------------------------------------------------------------------

invariant modulefinder.ModuleFinder.instantiable:
  description: "ModuleFinder().__class__.__name__ == 'ModuleFinder' — can be instantiated with no args"
  category: behavioral
  kind: python_call_eq
  function: ModuleFinder
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["ModuleFinder"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral — any_missing() before run_script returns empty list
# ---------------------------------------------------------------------------

invariant modulefinder.any_missing.initially_empty:
  description: "ModuleFinder().any_missing() == [] — no missing modules before run_script()"
  category: behavioral
  kind: python_call_eq
  function: ModuleFinder
  args: []
  method: any_missing
  method_args: []
  expected: []

# ---------------------------------------------------------------------------
# Behavioral — any_missing() return type is list
# ---------------------------------------------------------------------------

invariant modulefinder.any_missing.returns_list:
  description: "type(ModuleFinder().any_missing()).__name__ == 'list'"
  category: behavioral
  kind: python_call_eq
  function: ModuleFinder
  args: []
  method: any_missing
  method_args: []
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["list"]
  expected: true

