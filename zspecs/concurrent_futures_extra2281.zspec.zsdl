spec: concurrent_futures_extra2281
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 599 (_extra2281): class hierarchy metrics — MRO depth, base count."
    - "Covers concurrent.futures.Future, ThreadPoolExecutor, ProcessPoolExecutor, Executor, CancelledError, TimeoutError, BrokenExecutor."
    - "Executor has no __abstractmethods__ attribute in Python 3.14 (not an ABC in the traditional sense)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra2281.future_executor_mro:
  description: "concurrent.futures.Future and Executor hierarchy MRO and base class metrics"
  kind: python_call_eq
  category: mro_depth
  id_prefix: cf2281

  columns: [id, function, args, expected]
  rows:
    - ["cf2281001", "concurrent.futures.Future.__mro__.__len__", [], 2]
    - ["cf2281002", "concurrent.futures.Future.__bases__.__len__", [], 1]
    - ["cf2281003", "concurrent.futures.Executor.__mro__.__len__", [], 2]
    - ["cf2281004", "concurrent.futures.Executor.__bases__.__len__", [], 1]
    - ["cf2281005", "concurrent.futures.ThreadPoolExecutor.__mro__.__len__", [], 3]
