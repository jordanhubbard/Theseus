spec: re_extra1846
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python 3 re module documentation"
    - "CPython source: Lib/re/__init__.py, Modules/_sre.c"
  not_derived_from:
    - "Any third-party regex library"
  notes:
    - "re.Pattern defines __eq__ and __hash__ for use in sets/dicts"
    - "re.Pattern does not define ordering operators (__lt__, __gt__, __le__, __ge__)"
    - "re.Match uses object identity (no __eq__ in its __dict__)"
    - "re.RegexFlag inherits __eq__ from int via IntFlag; not defined in RegexFlag.__dict__"
    - "re.template was removed in Python 3.12"
  created_at: "2026-04-12"

table re_extra1846.arithmetic_operators:
  columns: [id, function, args, expected]
  rows:
    - ["re1846-arith-001", "re.Pattern.__dict__.__contains__", ["__add__"], false]
    - ["re1846-arith-002", "re.Pattern.__dict__.__contains__", ["__mul__"], false]
    - ["re1846-arith-003", "re.Pattern.__dict__.__contains__", ["__or__"], false]
    - ["re1846-arith-004", "re.Match.__dict__.__contains__", ["__add__"], false]
    - ["re1846-arith-005", "re.Match.__dict__.__contains__", ["__mul__"], false]
    - ["re1846-arith-006", "re.error.__dict__.__contains__", ["__add__"], false]
    - ["re1846-arith-007", "re.RegexFlag.__dict__.__contains__", ["__add__"], false]
    - ["re1846-arith-008", "re.Pattern.__dict__.__contains__", ["__truediv__"], false]

table re_extra1846.comparison_operators:
  columns: [id, function, args, expected]
  rows:
    - ["re1846-cmp-001", "re.Pattern.__dict__.__contains__", ["__eq__"], true]
    - ["re1846-cmp-002", "re.Pattern.__dict__.__contains__", ["__lt__"], false]
    - ["re1846-cmp-003", "re.Pattern.__dict__.__contains__", ["__gt__"], false]
    - ["re1846-cmp-004", "re.Pattern.__dict__.__contains__", ["__le__"], false]
    - ["re1846-cmp-005", "re.Pattern.__dict__.__contains__", ["__ge__"], false]
    - ["re1846-cmp-006", "re.Match.__dict__.__contains__", ["__eq__"], false]
    - ["re1846-cmp-007", "re.error.__dict__.__contains__", ["__eq__"], false]
    - ["re1846-cmp-008", "re.RegexFlag.__dict__.__contains__", ["__eq__"], false]

table re_extra1846.re_module_compile_attrs:
  columns: [id, function, args, expected]
  rows:
    - ["re1846-mod-001", "re.__dict__.__contains__", ["Pattern"], true]
    - ["re1846-mod-002", "re.__dict__.__contains__", ["Match"], true]
    - ["re1846-mod-003", "re.__dict__.__contains__", ["error"], true]
    - ["re1846-mod-004", "re.__dict__.__contains__", ["RegexFlag"], true]
    - ["re1846-mod-005", "re.__dict__.__contains__", ["purge"], true]
    - ["re1846-mod-006", "re.__dict__.__contains__", ["template"], false]
    - ["re1846-mod-007", "re.__dict__.__contains__", ["UNICODE"], true]
    - ["re1846-mod-008", "re.__dict__.__contains__", ["IGNORECASE"], true]
    - ["re1846-mod-009", "re.__dict__.__contains__", ["MULTILINE"], true]
    - ["re1846-mod-010", "re.__dict__.__contains__", ["DOTALL"], true]
