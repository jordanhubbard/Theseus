spec: netifaces_rust
version: ">=3.9"
backend: rust_module(netifaces_rust)

docs: https://github.com/al45tair/netifaces

provenance:
  derived_from:
    - "https://github.com/al45tair/netifaces — netifaces library"
  notes:
    - "netifaces provides network interface information."
    - "netifaces.interfaces() returns a non-empty list."
    - "netifaces.AF_INET is an integer."
    - "netifaces.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant netifaces_rust.interfaces_nonempty:
  description: "netifaces.interfaces() returns non-empty list"
  category: interfaces
  kind: python_call_eq
  function: netifaces_interfaces_nonempty
  args: []
  expected: true

invariant netifaces_rust.af_inet_positive:
  description: "netifaces.AF_INET is a positive integer"
  category: constants
  kind: python_call_eq
  function: netifaces_af_inet_positive
  args: []
  expected: true

invariant netifaces_rust.version_nonempty:
  description: "netifaces.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: netifaces_version_nonempty
  args: []
  expected: true

