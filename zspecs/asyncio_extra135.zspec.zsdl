invariant asyncio_extra135.Condition_notify_all_qualname_len_20:
  description: "asyncio.Condition.notify_all.__qualname__.__len__() == 20 — asyncio.Condition.notify_all.__qualname__ is 'Condition.notify_all' (20 chars: 'Condition'=9 + '.'=1 + 'notify_all'=10 = 20); this is the longest method qualname in asyncio.Condition: notify_all=20 > __init__=wait_for=18 > notify=16 > wait=14; notify_all.__code__.co_argcount is 1 (self only — notify_all wakes ALL waiting coroutines with no count parameter); contrast with notify.__code__.co_argcount which is 2 (self + n, count of waiters to wake); Condition.__module__ is 'asyncio.locks' (len=13); NEW in extra135: first standalone Condition.notify_all qualname length invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.notify_all.__qualname__.__len__
  args: []
  expected: 20

invariant asyncio_extra135.Condition_mro_len_4:
  description: "asyncio.Condition.__mro__.__len__() == 4 — asyncio.Condition's MRO is [Condition, _ContextManagerMixin, _LoopBoundMixin, object] (length=4); the same depth as asyncio.Semaphore whose MRO is also [Semaphore, _ContextManagerMixin, _LoopBoundMixin, object] (len=4); both Condition and Semaphore share _ContextManagerMixin as first base; asyncio.Event has a shallower MRO of [Event, _LoopBoundMixin, object] (len=3) — it lacks _ContextManagerMixin; Condition.__bases__[0].__name__ is '_ContextManagerMixin'; Condition.__module__ is 'asyncio.locks' (len=13); NEW in extra135: first standalone Condition MRO length invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra135.Condition_module_eq_asyncio_locks:
  description: "asyncio.Condition.__module__.__eq__('asyncio.locks') returns True — asyncio.Condition.__module__ is 'asyncio.locks' (13 chars: 'asyncio'=7 + '.'=1 + 'locks'=5 = 13); Condition is defined in Lib/asyncio/locks.py alongside Lock, Event, Semaphore, BoundedSemaphore, and Barrier — all sharing the same __module__ of 'asyncio.locks' (len=13); asyncio.Condition.__qualname__.__len__() is 9 ('Condition'=9); Condition.__init__.__code__.co_argcount is 2 (self + lock); NEW in extra135: first standalone Condition module equality invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra135.Condition_init_qualname_len_18:
  description: "asyncio.Condition.__init__.__qualname__.__len__() == 18 — asyncio.Condition.__init__.__qualname__ is 'Condition.__init__' (18 chars: 'Condition'=9 + '.'=1 + '__init__'=8 = 18); the same length as asyncio.Condition.wait_for.__qualname__.__len__() (also 18: 'wait_for'=8 == '__init__'=8); Condition.__init__.__code__.co_argcount is 2 (self + lock); co_varnames is ('self', 'lock'); Condition.wait.__qualname__.__len__() is 14 (shortest); Condition.notify_all.__qualname__.__len__() is 20 (longest); Condition.__module__ is 'asyncio.locks' (len=13); NEW in extra135: first standalone Condition.__init__ qualname length invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.__init__.__qualname__.__len__
  args: []
  expected: 18

invariant asyncio_extra135.Condition_notify_argc_2:
  description: "asyncio.Condition.notify.__code__.co_argcount.__eq__(2) returns True — Condition.notify takes (self, n) where n defaults to 1, meaning it wakes n waiting coroutines; this contrasts with notify_all whose co_argcount is 1 (self only, no count parameter); Condition.wait.__code__.co_argcount is also 1 (self only); Condition.wait_for.__code__.co_argcount is 2 (self + predicate); Condition.__init__.__code__.co_argcount is also 2 (self + lock); Condition.notify.__qualname__ is 'Condition.notify' (len=16); Condition.__module__ is 'asyncio.locks'; NEW in extra135: first standalone Condition.notify co_argcount invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.notify.__code__.co_argcount.__eq__
  args: [2]
  expected: true

