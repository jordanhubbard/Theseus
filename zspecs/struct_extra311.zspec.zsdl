spec: struct_extra311
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "This spec extends struct.zspec.zsdl and struct_extra.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "struct.pack, unpack, calcsize, pack_into, unpack_from, and iter_unpack are all implemented in the C extension _struct; their __module__ == '_struct'."
    - "struct.error is the pure-Python exception class re-exported from the struct module; its __module__ == 'struct' (not '_struct')."
    - "struct.Struct is the compiled struct object class; its __module__ == '_struct'."
    - "All __name__ and __module__ values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __name__ identity
# (struct_extra.zspec.zsdl covers unpack_from.__name__ and iter_unpack.__name__;
#  this spec adds pack, unpack, calcsize, and pack_into for completeness)
# ---------------------------------------------------------------------------

table struct_extra311.function_names:
  description: "struct module-level functions report their own name via __name__"
  kind: python_call_eq
  category: function_identity
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [pack,        pack.__name__.__eq__,        ["pack"],        true]
    - [unpack,      unpack.__name__.__eq__,      ["unpack"],      true]
    - [calcsize,    calcsize.__name__.__eq__,    ["calcsize"],    true]
    - [pack_into,   pack_into.__name__.__eq__,   ["pack_into"],   true]
    - [unpack_from, unpack_from.__name__.__eq__, ["unpack_from"], true]
    - [iter_unpack, iter_unpack.__name__.__eq__, ["iter_unpack"], true]

# ---------------------------------------------------------------------------
# Module-level function __module__ identity — all resolve to '_struct'
# ---------------------------------------------------------------------------

table struct_extra311.function_modules:
  description: "struct module-level functions are implemented in the _struct C extension"
  kind: python_call_eq
  category: function_identity
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [pack,        pack.__module__.__eq__,        ["_struct"], true]
    - [unpack,      unpack.__module__.__eq__,      ["_struct"], true]
    - [calcsize,    calcsize.__module__.__eq__,    ["_struct"], true]
    - [pack_into,   pack_into.__module__.__eq__,   ["_struct"], true]
    - [unpack_from, unpack_from.__module__.__eq__, ["_struct"], true]
    - [iter_unpack, iter_unpack.__module__.__eq__, ["_struct"], true]

# ---------------------------------------------------------------------------
# struct.error — class identity
# struct_extra.zspec.zsdl covers error.__name__=='error' and base class;
# this spec covers error.__module__ == 'struct' (not '_struct').
# ---------------------------------------------------------------------------

invariant struct_extra311.error.module:
  description: "struct.error.__module__ == 'struct' — error is re-exported from the pure-Python layer"
  category: class_metadata
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct — class __module__
# struct_extra.zspec.zsdl covers format/size/pack_into_method_name;
# this spec covers Struct.__module__ == '_struct'.
# ---------------------------------------------------------------------------

invariant struct_extra311.Struct.module:
  description: "struct.Struct.__module__ == '_struct' — Struct is implemented in the C extension"
  category: class_metadata
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true
