spec: abc_extra86
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra85

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra85.zspec.zsdl."
    - "This spec covers: wave 251 theme — abc.ABCMeta.__new__ and abc.ABCMeta.__prepare__ class identity, and abc.ABC.__init_subclass__ identity. NEW in extra86: ABCMeta.__new__.__class__.__name__=='function' (ABCMeta.__new__ is a Python function defined in abc.py); ABCMeta.__new__.__qualname__.__eq__('ABCMeta.__new__')==True; ABCMeta.__new__.__module__.__eq__('abc')==True; ABCMeta.__new__.__code__.co_name.__eq__('__new__')==True; ABCMeta.__new__.__code__.co_argcount==4; ABCMeta.__prepare__.__class__.__name__=='builtin_function_or_method' (ABCMeta.__prepare__ is a builtin, inherited from type); ABCMeta.__prepare__.__qualname__.__eq__('ABCMeta.__prepare__')==True; ABC.__init_subclass__.__class__.__name__=='builtin_function_or_method'; ABC.__init_subclass__.__qualname__.__eq__('ABC.__init_subclass__')==True; ABCMeta.register.__code__.co_argcount==2; ABCMeta.register.__code__.co_name.__eq__('register')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__class__.__name__ == 'function'. ABCMeta.__new__ is a Python function defined in abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__module__ == 'abc'. ABCMeta.__new__ is defined in abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__code__.co_name == '__new__'. The code object co_name for ABCMeta.__new__ is '__new__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__code__.co_argcount == 4. ABCMeta.__new__ takes 4 positional arguments: cls, name, bases, namespace. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__prepare__.__class__.__name__ == 'builtin_function_or_method'. ABCMeta.__prepare__ is a builtin_function_or_method (inherited from type and customized). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__prepare__.__qualname__ == 'ABCMeta.__prepare__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__init_subclass__.__class__.__name__ == 'builtin_function_or_method'. ABC.__init_subclass__ is a builtin_function_or_method. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__code__.co_argcount == 2. ABCMeta.register takes cls and subclass as positional arguments. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__code__.co_name == 'register'. The code object co_name for ABCMeta.register is 'register'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc ABCMeta.__new__ and __prepare__ identity — extra86
#
# Wave 251 theme: abc.ABCMeta.__new__ and __prepare__ class identity,
# and abc.ABC.__init_subclass__ identity.
#
# ABCMeta.__new__.__class__.__name__ == 'function'
# ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__'
# ABCMeta.__new__.__module__ == 'abc'
# ABCMeta.__prepare__.__class__.__name__ == 'builtin_function_or_method'
# ABCMeta.__prepare__.__qualname__ == 'ABCMeta.__prepare__'
# ---------------------------------------------------------------------------

table abc_extra86.ABCMeta_new_prepare_identity:
  description: "abc ABCMeta.__new__ and __prepare__ class identity checks in abcmetanewprep86 namespace — wave 251 theme: abc.ABCMeta.__new__ and __prepare__ class identity and abc.ABC.__init_subclass__ identity; ABCMeta.__new__.__class__.__name__=='function' (Python function defined in abc.py); ABCMeta.__new__.__qualname__.__eq__('ABCMeta.__new__')==True; ABCMeta.__new__.__module__.__eq__('abc')==True; ABCMeta.__prepare__.__class__.__name__=='builtin_function_or_method' (builtin, not a Python function); ABCMeta.__prepare__.__qualname__.__eq__('ABCMeta.__prepare__')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetanewprep86

  columns: [id, function, args, expected, description]
  rows:
    - [new_class_name,     "ABCMeta.__new__.__class__.__name__.__eq__",     ["function"],       true, "ABCMeta.__new__.__class__.__name__ == 'function' — Python function defined in abc.py; verified with Python 3.14.3"]
    - [new_qualname_eq,    ABCMeta.__new__.__qualname__.__eq__,             ["ABCMeta.__new__"], true, "ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' — verified with Python 3.14.3"]
    - [new_module_eq,      ABCMeta.__new__.__module__.__eq__,               ["abc"],             true, "ABCMeta.__new__.__module__ == 'abc' — defined in abc.py; verified with Python 3.14.3"]
    - [prep_class_name,    "ABCMeta.__prepare__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "ABCMeta.__prepare__.__class__.__name__ == 'builtin_function_or_method' — not a Python function; verified with Python 3.14.3"]
    - [prep_qualname_eq,   ABCMeta.__prepare__.__qualname__.__eq__,         ["ABCMeta.__prepare__"], true, "ABCMeta.__prepare__.__qualname__ == 'ABCMeta.__prepare__' — verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABC.__init_subclass__ identity — extra86
#
# ABC.__init_subclass__.__class__.__name__ == 'builtin_function_or_method'
# ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__'
# ---------------------------------------------------------------------------

table abc_extra86.ABC_init_subclass_identity:
  description: "abc ABC.__init_subclass__ identity checks in abcmetanewprep86 namespace — wave 251 theme: abc.ABCMeta.__new__ and __prepare__ class identity and abc.ABC.__init_subclass__ identity; ABC.__init_subclass__.__class__.__name__=='builtin_function_or_method'; ABC.__init_subclass__.__qualname__.__eq__('ABC.__init_subclass__')==True; ABCMeta.__new__.__class__.__name__=='function' (cross-check); ABCMeta.__new__.__module__.__eq__('abc')==True (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetanewprep86a

  columns: [id, function, args, expected, description]
  rows:
    - [initsc_class_name,  "ABC.__init_subclass__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "ABC.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' — verified with Python 3.14.3"]
    - [initsc_qualname_eq, ABC.__init_subclass__.__qualname__.__eq__,         ["ABC.__init_subclass__"],      true, "ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__' — verified with Python 3.14.3"]
    - [new_class_cross,    "ABCMeta.__new__.__class__.__name__.__eq__",       ["function"],                   true, "ABCMeta.__new__.__class__.__name__ == 'function' — cross-check; verified with Python 3.14.3"]
    - [new_module_cross,   ABCMeta.__new__.__module__.__eq__,                 ["abc"],                        true, "ABCMeta.__new__.__module__ == 'abc' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABCMeta.register code attrs — extra86
#
# ABCMeta.register.__code__.co_argcount == 2
# ABCMeta.register.__code__.co_name == 'register'
# ---------------------------------------------------------------------------

table abc_extra86.ABCMeta_register_code_attrs:
  description: "abc ABCMeta.register code object attribute checks in abcmetanewprep86 namespace — wave 251 theme: abc.ABCMeta.__new__ and __prepare__ class identity and abc.ABC.__init_subclass__ identity; ABCMeta.register.__code__.co_argcount==2 (takes cls and subclass as positional arguments); ABCMeta.register.__code__.co_name.__eq__('register')==True; ABCMeta.__new__.__code__.co_argcount==4 (cross-check: takes cls, name, bases, namespace); ABCMeta.__new__.__code__.co_name.__eq__('__new__')==True (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetanewprep86b

  columns: [id, function, args, expected, description]
  rows:
    - [reg_co_argcount,  ABCMeta.register.__code__.co_argcount,       [], 2,    "ABCMeta.register.__code__.co_argcount == 2 — takes cls and subclass; verified with Python 3.14.3"]
    - [reg_co_name_eq,   ABCMeta.register.__code__.co_name.__eq__,    ["register"], true, "ABCMeta.register.__code__.co_name == 'register' — verified with Python 3.14.3"]
    - [new_co_argcount,  ABCMeta.__new__.__code__.co_argcount,        [], 4,    "ABCMeta.__new__.__code__.co_argcount == 4 — cross-check: takes cls, name, bases, namespace; verified with Python 3.14.3"]
    - [new_co_name_eq,   ABCMeta.__new__.__code__.co_name.__eq__,     ["__new__"], true, "ABCMeta.__new__.__code__.co_name == '__new__' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc cross-checks: ABCMeta.__new__, __prepare__, ABC.__init_subclass__ — extra86
#
# Cross-checks across __new__, __prepare__, and __init_subclass__ identity facts.
# ---------------------------------------------------------------------------

table abc_extra86.cross_checks:
  description: "abc ABCMeta.__new__, __prepare__, ABC.__init_subclass__ cross-checks in abcmetanewprep86 namespace — wave 251 theme: abc.ABCMeta.__new__ and __prepare__ class identity and abc.ABC.__init_subclass__ identity; ABCMeta.__new__.__qualname__.__eq__('ABCMeta.__new__')==True (cross-check); ABCMeta.__prepare__.__qualname__.__eq__('ABCMeta.__prepare__')==True (cross-check); ABC.__init_subclass__.__qualname__.__eq__('ABC.__init_subclass__')==True (cross-check); ABCMeta.register.__code__.co_argcount==2 (cross-check); ABCMeta.__new__.__module__.__eq__('abc')==True (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetanewprep86c

  columns: [id, function, args, expected, description]
  rows:
    - [new_qualname_cross,   ABCMeta.__new__.__qualname__.__eq__,    ["ABCMeta.__new__"],         true, "ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' — cross-check; verified with Python 3.14.3"]
    - [prep_qualname_cross,  ABCMeta.__prepare__.__qualname__.__eq__, ["ABCMeta.__prepare__"],    true, "ABCMeta.__prepare__.__qualname__ == 'ABCMeta.__prepare__' — cross-check; verified with Python 3.14.3"]
    - [initsc_qualname_cross,ABC.__init_subclass__.__qualname__.__eq__,["ABC.__init_subclass__"], true, "ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__' — cross-check; verified with Python 3.14.3"]
    - [reg_argcount_cross,   ABCMeta.register.__code__.co_argcount,  [],                          2,    "ABCMeta.register.__code__.co_argcount == 2 — cross-check; verified with Python 3.14.3"]
    - [new_module_cross,     ABCMeta.__new__.__module__.__eq__,      ["abc"],                     true, "ABCMeta.__new__.__module__ == 'abc' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra86
# ---------------------------------------------------------------------------

invariant abc_extra86.ABCMeta_new_class_is_function:
  description: "abc.ABCMeta.__new__.__class__.__name__.__eq__('function') returns True — ABCMeta.__new__ is a Python function defined in abc.py; this is the metaclass's object creation hook which sets up the abstract method registry; NEW in extra86: first standalone __class__.__name__ invariant for ABCMeta.__new__ in abcmetanewprep86 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__new__.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

invariant abc_extra86.ABCMeta_new_module_is_abc:
  description: "abc.ABCMeta.__new__.__module__.__eq__('abc') returns True — ABCMeta.__new__ is defined in abc.py; its __module__ attribute confirms its origin; NEW in extra86: first standalone __module__ invariant for ABCMeta.__new__ in abcmetanewprep86 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__new__.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra86.ABCMeta_prepare_class_is_builtin:
  description: "abc.ABCMeta.__prepare__.__class__.__name__.__eq__('builtin_function_or_method') returns True — ABCMeta.__prepare__ is a builtin_function_or_method, unlike __new__ which is a Python function; NEW in extra86: first standalone __class__.__name__ invariant for ABCMeta.__prepare__ in abcmetanewprep86 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__prepare__.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra86.ABCMeta_register_co_argcount:
  description: "abc.ABCMeta.register.__code__.co_argcount == 2 — ABCMeta.register takes two positional arguments: cls (the ABC) and subclass (the class to register); this code object attribute confirms the function signature; NEW in extra86: first standalone co_argcount invariant for ABCMeta.register in abcmetanewprep86 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.register.__code__.co_argcount
  args: []
  expected: 2

invariant abc_extra86.ABC_init_subclass_class_is_builtin:
  description: "abc.ABC.__init_subclass__.__class__.__name__.__eq__('builtin_function_or_method') returns True — ABC.__init_subclass__ is a builtin_function_or_method; it is the hook called when a class subclasses ABC; NEW in extra86: first standalone __class__.__name__ invariant for ABC.__init_subclass__ in abcmetanewprep86 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABC.__init_subclass__.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true
