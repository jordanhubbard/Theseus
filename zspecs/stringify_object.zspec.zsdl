spec: stringify_object
version: ">=5.0.0"
backend: node(stringify-object)

docs: https://github.com/sindresorhus/stringify-object#readme

provenance:
  derived_from:
    - "stringify-object README — https://github.com/sindresorhus/stringify-object#readme"
    - "Test vectors verified with stringify-object via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "stringify-object source"
  notes:
    - "Stringify a JS object literal — output is human-readable JS source (single-quoted strings by default)."
    - "Install: npm install stringify-object"
    - "v5 ESM only; default export is the function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on plain objects/arrays."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant stringify_object.basic_default_singleQuotes:
  description: "Default output uses tabs and single-quoted strings"
  category: serialize
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{a: 1, b: "hi"}]
  chain: []
  expected: "{\n\ta: 1,\n\tb: 'hi'\n}"

invariant stringify_object.double_quotes_option:
  description: "{singleQuotes:false} uses double-quoted strings"
  category: serialize
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{a: "hi"}, {singleQuotes: false}]
  chain: []
  expected: "{\n\ta: \"hi\"\n}"

invariant stringify_object.indent_two_spaces:
  description: "{indent: '  '} uses two-space indent"
  category: serialize
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{a: 1}, {indent: "  "}]
  chain: []
  expected: "{\n  a: 1\n}"

invariant stringify_object.empty_object:
  description: "Empty object stringifies to '{}'"
  category: edge
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{}]
  chain: []
  expected: "{}"

invariant stringify_object.empty_array:
  description: "Empty array stringifies to '[]'"
  category: edge
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [[]]
  chain: []
  expected: "[]"

invariant stringify_object.string_literal:
  description: "Bare string is single-quoted"
  category: serialize
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["hello"]
  chain: []
  expected: "'hello'"

invariant stringify_object.number_passthrough:
  description: "Number serializes to its toString form"
  category: serialize
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [42]
  chain: []
  expected: "42"

invariant stringify_object.factory_arity:
  description: "stringifyObject takes (obj, options, pad) — length 3"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 3
