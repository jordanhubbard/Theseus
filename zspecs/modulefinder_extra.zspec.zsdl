spec: modulefinder_extra
version: ">=3.9"
backend: python_module(modulefinder)

docs: https://docs.python.org/3/library/modulefinder.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/modulefinder.html — Python modulefinder module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/modulefinder.py"
  notes:
    - "This spec extends modulefinder.zspec.zsdl with function name, class module membership, and constant invariants."
    - "modulefinder.ModuleFinder.__name__ == 'ModuleFinder' — the main analysis class."
    - "modulefinder.ModuleFinder.__module__ == 'modulefinder' — defined in the modulefinder module."
    - "modulefinder.Module.__name__ == 'Module' — data class representing a discovered module."
    - "modulefinder.Module.__module__ == 'modulefinder' — defined in the modulefinder module."
    - "modulefinder.AddPackagePath.__name__ == 'AddPackagePath' — registers additional search paths for a package."
    - "modulefinder.ReplacePackage.__name__ == 'ReplacePackage' — redirects imports of one package name to another."
    - "modulefinder.LOAD_FROM_PATH is an integer constant with value -1, used internally as a sentinel."
    - "modulefinder.LOAD_FROM_PATH.__class__.__name__ == 'int' — it is an integer."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — ModuleFinder and Module
# ---------------------------------------------------------------------------

invariant modulefinder_extra.names.ModuleFinder:
  description: "modulefinder.ModuleFinder.__name__ == 'ModuleFinder'"
  category: names
  kind: python_call_eq
  function: ModuleFinder.__name__.__eq__
  args: ["ModuleFinder"]
  expected: true

invariant modulefinder_extra.names.Module:
  description: "modulefinder.Module.__name__ == 'Module'"
  category: names
  kind: python_call_eq
  function: Module.__name__.__eq__
  args: ["Module"]
  expected: true

# ---------------------------------------------------------------------------
# Module membership — ModuleFinder and Module belong to modulefinder
# ---------------------------------------------------------------------------

invariant modulefinder_extra.module.ModuleFinder:
  description: "modulefinder.ModuleFinder.__module__ == 'modulefinder'"
  category: module
  kind: python_call_eq
  function: ModuleFinder.__module__.__eq__
  args: ["modulefinder"]
  expected: true

invariant modulefinder_extra.module.Module:
  description: "modulefinder.Module.__module__ == 'modulefinder'"
  category: module
  kind: python_call_eq
  function: Module.__module__.__eq__
  args: ["modulefinder"]
  expected: true

# ---------------------------------------------------------------------------
# Function name checks — AddPackagePath and ReplacePackage
# ---------------------------------------------------------------------------

invariant modulefinder_extra.names.AddPackagePath:
  description: "modulefinder.AddPackagePath.__name__ == 'AddPackagePath'"
  category: names
  kind: python_call_eq
  function: AddPackagePath.__name__.__eq__
  args: ["AddPackagePath"]
  expected: true

invariant modulefinder_extra.names.ReplacePackage:
  description: "modulefinder.ReplacePackage.__name__ == 'ReplacePackage'"
  category: names
  kind: python_call_eq
  function: ReplacePackage.__name__.__eq__
  args: ["ReplacePackage"]
  expected: true

# ---------------------------------------------------------------------------
# AddPackagePath and ReplacePackage module affiliation
# ---------------------------------------------------------------------------

invariant modulefinder_extra.module.AddPackagePath:
  description: "modulefinder.AddPackagePath.__module__ == 'modulefinder'"
  category: module
  kind: python_call_eq
  function: AddPackagePath.__module__.__eq__
  args: ["modulefinder"]
  expected: true

invariant modulefinder_extra.module.ReplacePackage:
  description: "modulefinder.ReplacePackage.__module__ == 'modulefinder'"
  category: module
  kind: python_call_eq
  function: ReplacePackage.__module__.__eq__
  args: ["modulefinder"]
  expected: true

# ---------------------------------------------------------------------------
# LOAD_FROM_PATH — integer sentinel constant (-1)
#
# LOAD_FROM_PATH is used internally by ModuleFinder as a sentinel value to
# indicate that a module should be loaded by searching sys.path rather than
# from a specific file path. Its value is -1 in all CPython implementations.
# ---------------------------------------------------------------------------

invariant modulefinder_extra.LOAD_FROM_PATH.is_int:
  description: "modulefinder.LOAD_FROM_PATH.__class__.__name__ == 'int' — LOAD_FROM_PATH is an integer constant"
  category: constants
  kind: python_call_eq
  function: LOAD_FROM_PATH.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant modulefinder_extra.LOAD_FROM_PATH.value:
  description: "modulefinder.LOAD_FROM_PATH == -1 — sentinel value indicating sys.path-based loading"
  category: constants
  kind: python_call_eq
  function: LOAD_FROM_PATH.__eq__
  args: [-1]
  expected: true

# ---------------------------------------------------------------------------
# Callable type checks — AddPackagePath and ReplacePackage are functions
# ---------------------------------------------------------------------------

invariant modulefinder_extra.callable_type.AddPackagePath:
  description: "modulefinder.AddPackagePath.__class__.__name__ == 'function' — AddPackagePath is a plain Python function"
  category: callable_type
  kind: python_call_eq
  function: AddPackagePath.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant modulefinder_extra.callable_type.ReplacePackage:
  description: "modulefinder.ReplacePackage.__class__.__name__ == 'function' — ReplacePackage is a plain Python function"
  category: callable_type
  kind: python_call_eq
  function: ReplacePackage.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# Class type checks — ModuleFinder and Module are classes (type instances)
# ---------------------------------------------------------------------------

invariant modulefinder_extra.class_type.ModuleFinder:
  description: "modulefinder.ModuleFinder.__class__.__name__ == 'type' — ModuleFinder is a class"
  category: class_type
  kind: python_call_eq
  function: ModuleFinder.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant modulefinder_extra.class_type.Module:
  description: "modulefinder.Module.__class__.__name__ == 'type' — Module is a class"
  category: class_type
  kind: python_call_eq
  function: Module.__class__.__name__.__eq__
  args: ["type"]
  expected: true
