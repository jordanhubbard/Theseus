spec: pyotp_rust
version: ">=3.9"
backend: rust_module(pyotp_rust)

docs: https://pyauth.github.io/pyotp/

provenance:
  derived_from:
    - "https://pyauth.github.io/pyotp/ — PyOTP documentation"
  not_derived_from:
    - "pyotp source: pyotp/__init__.py"
  notes:
    - "PyOTP provides TOTP/HOTP one-time password generation."
    - "pyotp.random_base32() generates a base32 secret."
    - "len(pyotp.random_base32()) == 32 — default length."
    - "pyotp.TOTP(secret).now() is a 6-digit string."
    - "len(pyotp.TOTP(secret).now()) == 6."
    - "pyotp.HOTP(secret).at(0) is a 6-digit string."
    - "Expose pyotp_secret_len() -> int: len(pyotp.random_base32())."
    - "Expose pyotp_totp_len(secret) -> int: len(pyotp.TOTP(secret).now())."
    - "Expose pyotp_hotp_len(secret, count) -> int: len(pyotp.HOTP(secret).at(count))."
    - "All test vectors verified against pyotp 2.9.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# pyotp_secret_len — random secret is 32 chars
invariant pyotp_rust.secret.len_32:
  description: "pyotp.random_base32() has length 32"
  category: secret
  kind: python_call_eq
  function: pyotp_secret_len
  args: []
  expected: 32

# pyotp_totp_len — TOTP is 6 digits
table pyotp_rust.totp.length:
  kind: python_call_eq
  category: totp_len
  id_prefix: otp_tl
  function: pyotp_totp_len

  columns: [id, args, expected]
  rows:
    - [base, ["JBSWY3DPEHPK3PXP"], 6]
    - [alt,  ["MFRA2YLBMFRA2YLB"], 6]

# pyotp_hotp_len — HOTP is 6 digits
invariant pyotp_rust.hotp.len_6:
  description: "pyotp.HOTP(secret).at(0) has length 6"
  category: hotp_len
  kind: python_call_eq
  function: pyotp_hotp_len
  args: ["JBSWY3DPEHPK3PXP", 0]
  expected: 6

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:25:58Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
