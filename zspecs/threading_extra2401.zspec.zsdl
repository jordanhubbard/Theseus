spec: threading_extra2401
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/threading.html"
    - "CPython source — Lib/threading.py"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 607 (_extra2401): __hash__ and __eq__ implementation type classification."
    - "threading.Thread, Event, Condition, Semaphore, Barrier, and Timer all inherit __hash__ and __eq__ from object."
    - "All standard threading synchronization types have __hash__.__class__.__name__ == 'wrapper_descriptor'."
    - "threading.WeakSet sets __hash__ = None (unhashable, has custom __eq__) — it is unhashable."
    - "threading._deque sets __hash__ = None (deque is unhashable by design)."
    - "threading.BoundedSemaphore inherits from Semaphore and also has inherited wrapper_descriptor hash/eq."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
# Table 1: __hash__ implementation type for threading classes (class level)
# ===

table threading_extra2401.hash_class_types:
  description: "__hash__ implementation type (class-level) for key threading types"
  kind: python_call_eq
  category: type_identity
  id_prefix: th2401
  columns: [id, function, args, expected]
  rows:
    - ["th2401001", "threading.Thread.__hash__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2401002", "threading.Event.__hash__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2401003", "threading.Condition.__hash__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2401004", "threading.Semaphore.__hash__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2401005", "threading.Barrier.__hash__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2401006", "threading.BoundedSemaphore.__hash__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2401007", "threading.Timer.__hash__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2401008", "threading.WeakSet.__hash__.__class__.__name__", [], "NoneType"]

# ===
# Table 2: __eq__ implementation type for threading classes (class level)
# ===

table threading_extra2401.eq_class_types:
  description: "__eq__ implementation type (class-level) for key threading types"
  kind: python_call_eq
  category: type_identity
  id_prefix: th2401
  columns: [id, function, args, expected]
  rows:
    - ["th2401009", "threading.Thread.__eq__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2401010", "threading.Event.__eq__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2401011", "threading.Condition.__eq__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2401012", "threading.Semaphore.__eq__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2401013", "threading.Barrier.__eq__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2401014", "threading.BoundedSemaphore.__eq__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2401015", "threading.Timer.__eq__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2401016", "threading.WeakSet.__eq__.__class__.__name__", [], "function"]

# ===
# Table 3: __hash__ NOT in class __dict__ for standard threading types
# ===

table threading_extra2401.hash_not_in_dict:
  description: "__hash__ is not in __dict__ for threading types that inherit from object"
  kind: python_call_eq
  category: type_identity
  id_prefix: th2401
  columns: [id, function, args, expected]
  rows:
    - ["th2401017", "threading.Thread.__dict__.__contains__", ["__hash__"], false]
    - ["th2401018", "threading.Event.__dict__.__contains__", ["__hash__"], false]
    - ["th2401019", "threading.Condition.__dict__.__contains__", ["__hash__"], false]
    - ["th2401020", "threading.Semaphore.__dict__.__contains__", ["__hash__"], false]
    - ["th2401021", "threading.Barrier.__dict__.__contains__", ["__hash__"], false]
    - ["th2401022", "threading.Timer.__dict__.__contains__", ["__hash__"], false]

# ===
# Table 4: WeakSet sets __hash__ = None (unhashable by design)
# ===

table threading_extra2401.weakset_unhashable:
  description: "threading.WeakSet sets __hash__ = None making it unhashable; __hash__ is in __dict__"
  kind: python_call_eq
  category: type_identity
  id_prefix: th2401
  columns: [id, function, args, expected]
  rows:
    - ["th2401023", "threading.WeakSet.__dict__.__contains__", ["__hash__"], true]
    - ["th2401024", "threading.WeakSet.__dict__.__getitem__", ["__hash__"], null]
    - ["th2401025", "threading.WeakSet.__dict__.__contains__", ["__eq__"], true]
