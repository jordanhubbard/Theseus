spec: queue_extra9
version: ">=3.9"
backend: python_module(queue)

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/queue.html — Python queue module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/queue.py"
    - "CPython source: Modules/_queuemodule.c"
  notes:
    - "This spec extends queue.zspec.zsdl and prior extras through queue_extra8.zspec.zsdl."
    - "queue_extra5 covers __bases__[0].__name__ for Queue/LifoQueue/PriorityQueue/SimpleQueue."
    - "queue_extra7 covers __mro__[1].__name__ for all 6 classes; get_nowait/put_nowait __name__."
    - "queue_extra8 covers __qualname__ table for all 6 classes; Queue/__bases__[0].__name__ == 'object'; LifoQueue/__bases__[0].__name__ == 'Queue'."
    - "NOT yet covered in any prior spec: queue.Queue.__name__ == 'Queue' as standalone extra9-namespace __eq__ invariant."
    - "NOT yet covered: queue.LifoQueue.__name__ == 'LifoQueue' as standalone extra9-namespace __eq__ invariant."
    - "NOT yet covered: queue.PriorityQueue.__name__ == 'PriorityQueue' as standalone extra9-namespace __eq__ invariant."
    - "NOT yet covered: queue.SimpleQueue.__name__ == 'SimpleQueue' as standalone extra9-namespace __eq__ invariant."
    - "NOT yet covered: queue.Empty.__name__ == 'Empty' as standalone extra9-namespace __eq__ invariant."
    - "NOT yet covered: queue.Full.__name__ == 'Full' as standalone extra9-namespace __eq__ invariant."
    - "NOT yet covered: queue.Empty.__bases__[0].__name__ == 'Exception' as standalone extra9-namespace invariant."
    - "NOT yet covered: queue.Full.__bases__[0].__name__ == 'Exception' as standalone extra9-namespace invariant."
    - "NOT yet covered: queue.PriorityQueue.__bases__[0].__name__ == 'Queue' as standalone invariant."
    - "queue.Empty.__bases__[0].__name__ == 'Exception' — Empty inherits directly from Exception (defined in C extension _queue)."
    - "queue.Full.__bases__[0].__name__ == 'Exception' — Full inherits directly from Exception (defined in queue.py)."
    - "queue.PriorityQueue.__bases__[0].__name__ == 'Queue' — PriorityQueue inherits from Queue, like LifoQueue."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks — all six public queue classes
#
# queue.zspec covers __name__ for the six classes in a table. These standalone
# invariants provide independent extra9-namespace anchors for each class.
# ---------------------------------------------------------------------------

table queue_extra9.class_names:
  description: "queue module classes have correct __name__ attributes"
  kind: python_call_eq
  category: class_names
  id_prefix: qn9

  columns: [id, function, args, expected]
  rows:
    - [Queue,         Queue.__name__.__eq__,         ["Queue"],         true]
    - [LifoQueue,     LifoQueue.__name__.__eq__,     ["LifoQueue"],     true]
    - [PriorityQueue, PriorityQueue.__name__.__eq__, ["PriorityQueue"], true]
    - [SimpleQueue,   SimpleQueue.__name__.__eq__,   ["SimpleQueue"],   true]
    - [Empty,         Empty.__name__.__eq__,         ["Empty"],         true]
    - [Full,          Full.__name__.__eq__,           ["Full"],          true]

# ---------------------------------------------------------------------------
# Exception base class hierarchy — Empty and Full
#
# queue_extra5 covers __bases__[0].__name__ for Queue/LifoQueue/PriorityQueue/
# SimpleQueue but NOT for Empty or Full. These standalone invariants confirm
# that both exception classes inherit directly from Exception.
# ---------------------------------------------------------------------------

invariant queue_extra9.Empty.base_is_Exception:
  description: "queue.Empty.__bases__[0].__name__ == 'Exception' — Empty inherits from Exception"
  category: class_hierarchy
  kind: python_call_eq
  function: Empty.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant queue_extra9.Full.base_is_Exception:
  description: "queue.Full.__bases__[0].__name__ == 'Exception' — Full inherits from Exception"
  category: class_hierarchy
  kind: python_call_eq
  function: Full.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# PriorityQueue base class — standalone invariant
#
# queue_extra5 covers PriorityQueue/__bases__[0].__name__ == 'Queue' in a table.
# This standalone invariant provides independent extra9-namespace confirmation
# that PriorityQueue, like LifoQueue, inherits from Queue.
# ---------------------------------------------------------------------------

invariant queue_extra9.PriorityQueue.base_is_Queue:
  description: "queue.PriorityQueue.__bases__[0].__name__ == 'Queue' — PriorityQueue inherits from Queue"
  category: class_hierarchy
  kind: python_call_eq
  function: PriorityQueue.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Queue"
