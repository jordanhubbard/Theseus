spec: threading_extra2161
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
    - "threading_extra1936.zspec.zsdl — covers __get__/__set__/__delete__/__set_name__ dict-presence on Thread/Event/Condition/Semaphore/BoundedSemaphore/Barrier/Timer/local, class name checks, module identity"
  notes:
    - "Wave 2161 (_extra2161): descriptor protocol dict-presence theme — fget/fset/fdel (property attrs), __objclass__ and __func__ (method wrapper attrs)."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "threading.Thread, Event, Condition, Semaphore, BoundedSemaphore, Barrier, Timer, and local do NOT define fget, fset, fdel, __objclass__, or __func__ in their own __dict__."
    - "threading.Thread defines four read-only or read-write properties (name, ident, native_id, daemon) as property objects in its __dict__; the property objects carry fget (and fset for name and daemon) as Python functions."
    - "threading.Barrier defines three read-only properties (parties, n_waiting, broken) as property objects in its __dict__."
    - "threading.Lock (alias for _thread.lock) method descriptors (acquire, release) are method_descriptor objects that carry __objclass__ == _thread.lock; __objclass__ points to the defining class."
    - "threading.Lock.acquire.__objclass__.__name__ == 'lock' — the C-level lock type name is lowercase 'lock'."
    - "method_descriptor type defines __get__ and __objclass__ in its __dict__; it does NOT define fget, fset, fdel, or __func__."
  created_at: "2026-04-12"
error_model: python_exceptions

table threading_extra2161.fget_fset_fdel_thread_event:
  description: "threading.Thread and Event fget/fset/fdel dict-presence checks — all false"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2161
  columns: [id, function, args, expected]
  rows:
    - ["th2161001", "threading.Thread.__dict__.__contains__",  ["fget"],  false]
    - ["th2161002", "threading.Thread.__dict__.__contains__",  ["fset"],  false]
    - ["th2161003", "threading.Thread.__dict__.__contains__",  ["fdel"],  false]
    - ["th2161004", "threading.Event.__dict__.__contains__",   ["fget"],  false]
    - ["th2161005", "threading.Event.__dict__.__contains__",   ["fset"],  false]
    - ["th2161006", "threading.Event.__dict__.__contains__",   ["fdel"],  false]

