table threading_extra2161.thread_property_fget:
  description: "threading.Thread property objects have non-None fget; name and daemon also have non-None fset"
  kind: python_call_eq
  category: fget_attr
  id_prefix: th2161
  columns: [id, function, args, expected]
  rows:
    - ["th2161030", "threading.Thread.name.fget.__name__.__eq__",       ["name"],      true]
    - ["th2161031", "threading.Thread.ident.fget.__name__.__eq__",      ["ident"],     true]
    - ["th2161032", "threading.Thread.native_id.fget.__name__.__eq__",  ["native_id"], true]
    - ["th2161033", "threading.Thread.daemon.fget.__name__.__eq__",     ["daemon"],    true]
    - ["th2161034", "threading.Thread.name.fget.__class__.__name__.__eq__",   ["function"], true]
    - ["th2161035", "threading.Thread.daemon.fget.__class__.__name__.__eq__", ["function"], true]

table threading_extra2161.thread_property_fset:
  description: "threading.Thread.name and .daemon have non-None fset; ident and native_id do not"
  kind: python_call_eq
  category: fset_attr
  id_prefix: th2161
  columns: [id, function, args, expected]
  rows:
    - ["th2161036", "threading.Thread.name.fset.__name__.__eq__",       ["name"],   true]
    - ["th2161037", "threading.Thread.daemon.fset.__name__.__eq__",     ["daemon"], true]
    - ["th2161038", "threading.Thread.name.fset.__class__.__name__.__eq__",   ["function"], true]
    - ["th2161039", "threading.Thread.daemon.fset.__class__.__name__.__eq__", ["function"], true]

table threading_extra2161.barrier_property_fget:
  description: "threading.Barrier properties are read-only; fget is a function, fset is None"
  kind: python_call_eq
  category: fget_attr
  id_prefix: th2161
  columns: [id, function, args, expected]
  rows:
    - ["th2161040", "threading.Barrier.parties.fget.__name__.__eq__",   ["parties"],   true]
    - ["th2161041", "threading.Barrier.n_waiting.fget.__name__.__eq__", ["n_waiting"], true]
    - ["th2161042", "threading.Barrier.broken.fget.__name__.__eq__",    ["broken"],    true]
    - ["th2161043", "threading.Barrier.parties.fget.__class__.__name__.__eq__",   ["function"], true]
    - ["th2161044", "threading.Barrier.n_waiting.fget.__class__.__name__.__eq__", ["function"], true]

table threading_extra2161.lock_acquire_objclass:
  description: "threading.Lock method descriptors carry __objclass__ pointing to the C lock type"
  kind: python_call_eq
  category: objclass
  id_prefix: th2161
  columns: [id, function, args, expected]
  rows:
    - ["th2161045", "threading.Lock.acquire.__objclass__.__name__.__eq__",  ["lock"], true]
    - ["th2161046", "threading.Lock.release.__objclass__.__name__.__eq__",  ["lock"], true]
    - ["th2161047", "threading.Lock.acquire.__class__.__name__.__eq__",     ["method_descriptor"], true]
    - ["th2161048", "threading.Lock.release.__class__.__name__.__eq__",     ["method_descriptor"], true]
    - ["th2161049", "threading.Lock.__dict__.__contains__",                 ["acquire"], true]
    - ["th2161050", "threading.Lock.__dict__.__contains__",                 ["release"], true]
