spec: front_matter
version: ">=4.0.0"
backend: node(front-matter)

docs: https://github.com/jxson/front-matter#readme

provenance:
  derived_from:
    - "front-matter README — https://github.com/jxson/front-matter#readme"
    - "Test vectors verified with front-matter via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "front-matter source"
  notes:
    - "front-matter is a lightweight alternative to gray-matter; the module export IS the parser function."
    - "Install: npm install front-matter"
    - "Usage: const fm = require('front-matter'); fm('---\\nfoo: bar\\n---\\nbody') -> {attributes, body, frontmatter, bodyBegin}"
    - "fm.test(string) is a callable property that returns true iff the string starts with a front-matter block."
    - "Unlike gray-matter (which uses .data and .content), front-matter uses .attributes (parsed YAML) and .body (rest of the file as a string)."
    - "Spec name underscored per ZSDL convention; npm package name is front-matter."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "fm() returns an object with .attributes, .body, .frontmatter (raw YAML), .bodyBegin (line number)."
  stderr: "null"
  stickiness: "N/A — each call is independent."
  codes: {}

# ── attributes — parsed front-matter as JS object ───────────────────────────

table front_matter.attributes:
  kind: node_chain_eq
  category: attributes
  entry: module
  id_prefix: attrs

  columns: [id, entry_args, chain, expected]
  rows:
    - [single_pair,
       ["---\nfoo: bar\n---\nbody"],
       [{get: attributes}],
       {foo: "bar"}]

    - [two_keys,
       ["---\ntitle: Hello\nauthor: Alice\n---\n\nx"],
       [{get: attributes}],
       {title: "Hello", author: "Alice"}]

    - [no_frontmatter_empty,
       ["plain body"],
       [{get: attributes}],
       {}]

    - [yaml_list,
       ["---\ntags:\n  - a\n  - b\n---\nx"],
       [{get: attributes}],
       {tags: ["a", "b"]}]

# ── body — content after the front-matter ───────────────────────────────────

table front_matter.body:
  kind: node_chain_eq
  category: body
  entry: module
  id_prefix: body

  columns: [id, entry_args, chain, expected]
  rows:
    - [body_only,
       ["---\nfoo: bar\n---\nbody"],
       [{get: body}],
       "body"]

    - [no_frontmatter_passthrough,
       ["plain body"],
       [{get: body}],
       "plain body"]

    - [empty_input,
       [""],
       [{get: body}],
       ""]

# ── test() — predicate for front-matter presence ────────────────────────────

table front_matter.test:
  kind: node_chain_eq
  category: predicates
  entry: named
  function: test
  id_prefix: test

  columns: [id, entry_args, chain, expected]
  rows:
    - [with_frontmatter,
       ["---\nfoo: bar\n---\nbody"],
       [],
       true]

    - [no_frontmatter,
       ["just a body"],
       [],
       false]

    - [empty_input,
       [""],
       [],
       false]
