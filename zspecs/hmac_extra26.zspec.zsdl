spec: hmac_extra26
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hmac_extra25.zspec.zsdl — covers HMAC.digest_size/block_size __class__.__name__ at class level (member_descriptor); HMAC method qualnames re-anchored from extra25 namespace."
    - "hmac_extra24.zspec.zsdl — covers HMAC.update/digest/hexdigest/copy __qualname__.__eq__ and __qualname__.__len__."
    - "hmac_extra23.zspec.zsdl — covers new/digest/compare_digest __qualname__.__len__; HMAC.__module__.__eq__."
    - "hmac_extra22.zspec.zsdl — covers HMAC.__mro__.__len__; HMAC.__qualname__.__len__==4; HMAC.__name__.__len__==4."
    - "hmac_extra19.zspec.zsdl — covers new.__qualname__.__eq__ and digest.__qualname__.__eq__ standalone."
    - "hmac_extra17.zspec.zsdl — covers new/compare_digest/digest __name__/__module__; HMAC __qualname__/__module__/__bases__."
    - "hmac_extra14.zspec.zsdl — covers new/digest/compare_digest __qualname__.__eq__; HMAC.__qualname__.__eq__."
  notes:
    - "This spec extends hmac through hmac_extra25; it does NOT duplicate invariants present in those files."
    - "Focus: HMAC instance method __module__ values (update/digest/hexdigest/copy); HMAC.__init__.__qualname__ and __module__; HMAC.__name__.__eq__; HMAC.blocksize class attribute value."
    - "hmac.HMAC.update.__module__ == 'hmac': No prior spec checks __module__ for any HMAC method. hmac_extra17 covers HMAC.__module__ (the class); hmac_extra24/25 cover method __qualname__. Method __module__ is new coverage. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__init__.__qualname__ == 'HMAC.__init__': No prior spec checks HMAC.__init__.__qualname__. Extra24/25 cover update/digest/hexdigest/copy qualnames but not __init__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__init__.__module__ == 'hmac': No prior spec checks HMAC.__init__.__module__. Novel coverage. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__name__ == 'HMAC': hmac_extra22 covers __name__.__len__()==4; hmac_extra14 covers __qualname__.__eq__('HMAC'). No prior spec covers __name__.__eq__('HMAC') as a standalone invariant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.blocksize == 64: Legacy alias for block_size. Extra25 covers block_size (C-level descriptor type); extra2/11 cover block_size instance values. blocksize is the old alias; no prior spec checks its class-level integer value. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HMAC instance method __module__ — update, digest, hexdigest, copy
#
# hmac_extra24 covers __qualname__.__eq__ and __qualname__.__len__ for these
# four methods. hmac_extra25 re-anchors the __qualname__.__eq__ checks.
# No prior spec checks __module__ for any HMAC instance method.
# All four methods are defined in the hmac module: __module__ == 'hmac'.
# ---------------------------------------------------------------------------

table hmac_extra26.HMAC_method_modules:
  description: "HMAC instance method __module__ == 'hmac' — all defined in hmac module"
  kind: python_call_eq
  category: module_metadata
  id_prefix: hmacmm26

  columns: [id, function, args, expected]
  rows:
    - [update,    "HMAC.update.__module__.__eq__",    ["hmac"], true]
    - [digest,    "HMAC.digest.__module__.__eq__",    ["hmac"], true]
    - [hexdigest, "HMAC.hexdigest.__module__.__eq__", ["hmac"], true]
    - [copy,      "HMAC.copy.__module__.__eq__",      ["hmac"], true]

# ---------------------------------------------------------------------------
# HMAC.__init__.__qualname__ and __module__
#
# hmac_extra24/25 cover update/digest/hexdigest/copy __qualname__. No prior
# spec covers __init__.__qualname__ or __init__.__module__ for HMAC.
# HMAC.__init__.__qualname__ == 'HMAC.__init__'; __module__ == 'hmac'.
# ---------------------------------------------------------------------------

invariant hmac_extra26.HMAC.init.qualname:
  description: "hmac.HMAC.__init__.__qualname__ == 'HMAC.__init__' — constructor qualname"
  category: function_qualnames
  kind: python_call_eq
  function: "HMAC.__init__.__qualname__.__eq__"
  args: ["HMAC.__init__"]
  expected: true

invariant hmac_extra26.HMAC.init.module:
  description: "hmac.HMAC.__init__.__module__ == 'hmac' — constructor defined in hmac module"
  category: module_metadata
  kind: python_call_eq
  function: "HMAC.__init__.__module__.__eq__"
  args: ["hmac"]
  expected: true

# ---------------------------------------------------------------------------
# HMAC.__name__.__eq__ — standalone invariant
#
# hmac_extra22 covers HMAC.__name__.__len__()==4.
# hmac_extra14 covers HMAC.__qualname__.__eq__('HMAC').
# No prior spec covers HMAC.__name__.__eq__('HMAC') as a standalone invariant.
# ---------------------------------------------------------------------------

invariant hmac_extra26.HMAC.name_eq:
  description: "hmac.HMAC.__name__ == 'HMAC' — class name equality, anchored from extra26 namespace"
  category: type_metadata
  kind: python_call_eq
  function: "HMAC.__name__.__eq__"
  args: ["HMAC"]
  expected: true

# ---------------------------------------------------------------------------
# HMAC.blocksize class attribute value
#
# HMAC.blocksize is the legacy alias for block_size. At the class level it
# stores the integer value 64 (the default HMAC block size for SHA256).
# hmac_extra25 covers block_size.__class__.__name__ == 'member_descriptor'.
# hmac_extra2/11 cover instance-level block_size values. No prior spec checks
# the class-level integer value of HMAC.blocksize (the legacy alias).
# ---------------------------------------------------------------------------

invariant hmac_extra26.HMAC.blocksize.value:
  description: "hmac.HMAC.blocksize == 64 — legacy block size alias class-level integer value"
  category: module_metadata
  kind: python_call_eq
  function: "HMAC.blocksize.__eq__"
  args: [64]
  expected: true
