spec: multiprocessing_extra73
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing_extra72.zspec.zsdl."
    - "This spec covers: wave 241 theme — multiprocessing BaseProcess class identity via exception hierarchy. NEW in extra73: AuthenticationError.__qualname__=='AuthenticationError'; ProcessError.__qualname__=='ProcessError'; TimeoutError.__qualname__=='TimeoutError'; BufferTooShort.__name__=='BufferTooShort'; BufferTooShort.__bases__[0].__name__=='ProcessError'; AuthenticationError.__mro__.__len__()==5 (AuthenticationError, ProcessError, Exception, BaseException, object); ProcessError.__mro__.__len__()==4 (ProcessError, Exception, BaseException, object); TimeoutError.__mro__.__len__()==5 (TimeoutError, ProcessError, Exception, BaseException, object); Process.__bases__[0].__name__=='BaseProcess' (from mpmore72, recapped in context)."
    - "multiprocessing.AuthenticationError.__qualname__ == 'AuthenticationError'. AuthenticationError is defined directly in Lib/multiprocessing/context.py; __qualname__ is 'AuthenticationError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__qualname__ == 'ProcessError'. ProcessError is the base for multiprocessing process exceptions; __qualname__ is 'ProcessError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.TimeoutError.__qualname__ == 'TimeoutError'. multiprocessing.TimeoutError is a ProcessError subclass (not OSError); __qualname__ is 'TimeoutError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.BufferTooShort.__name__ == 'BufferTooShort'. BufferTooShort is defined in multiprocessing; __name__ is 'BufferTooShort'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'. BufferTooShort directly subclasses ProcessError; __bases__[0].__name__ is 'ProcessError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__mro__.__len__() == 5. MRO is (AuthenticationError, ProcessError, Exception, BaseException, object) — 5 entries. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__mro__.__len__() == 4. MRO is (ProcessError, Exception, BaseException, object) — 4 entries. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.TimeoutError.__mro__.__len__() == 5. MRO is (TimeoutError, ProcessError, Exception, BaseException, object) — 5 entries. Note: multiprocessing.TimeoutError subclasses ProcessError (not OSError), unlike the built-in TimeoutError. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing AuthenticationError and ProcessError qualname checks — extra73
#
# Wave 241 theme: multiprocessing BaseProcess class identity via exceptions.
#
# AuthenticationError.__qualname__ == 'AuthenticationError'
# ProcessError.__qualname__ == 'ProcessError'
# TimeoutError.__qualname__ == 'TimeoutError'
# ---------------------------------------------------------------------------

table multiprocessing_extra73.exception_qualnames:
  description: "multiprocessing exception __qualname__ checks in mpmore73 namespace — wave 241 theme: BaseProcess identity via exception hierarchy; AuthenticationError.__qualname__=='AuthenticationError'; ProcessError.__qualname__=='ProcessError'; TimeoutError.__qualname__=='TimeoutError'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmore73

  columns: [id, function, args, expected, description]
  rows:
    - [autherror_qualname,    AuthenticationError.__qualname__.__eq__, ["AuthenticationError"], true, "AuthenticationError.__qualname__ == 'AuthenticationError' — defined in multiprocessing; verified with Python 3.14.3"]
    - [procerror_qualname,    ProcessError.__qualname__.__eq__,        ["ProcessError"],        true, "ProcessError.__qualname__ == 'ProcessError' — base process exception; verified with Python 3.14.3"]
    - [timeouterror_qualname, TimeoutError.__qualname__.__eq__,        ["TimeoutError"],        true, "TimeoutError.__qualname__ == 'TimeoutError' — multiprocessing.TimeoutError subclasses ProcessError; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing BufferTooShort identity — extra73
#
# BufferTooShort.__name__ == 'BufferTooShort'
# BufferTooShort.__bases__[0].__name__ == 'ProcessError'
# ---------------------------------------------------------------------------

table multiprocessing_extra73.BufferTooShort_identity:
  description: "multiprocessing BufferTooShort identity checks in mpmore73 namespace — wave 241 theme: exception hierarchy; BufferTooShort.__name__=='BufferTooShort'; BufferTooShort.__bases__[0].__name__=='ProcessError' (direct base class); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmore73a

  columns: [id, function, args, expected, description]
  rows:
    - [buffertoo_name,      BufferTooShort.__name__.__eq__,                ["BufferTooShort"], true, "BufferTooShort.__name__ == 'BufferTooShort' — defined in multiprocessing; verified with Python 3.14.3"]
    - [buffertoo_base_name, "BufferTooShort.__bases__[0].__name__.__eq__", ["ProcessError"],   true, "BufferTooShort.__bases__[0].__name__ == 'ProcessError' — BufferTooShort directly subclasses ProcessError; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing exception MRO lengths — extra73
#
# AuthenticationError.__mro__.__len__() == 5
# ProcessError.__mro__.__len__() == 4
# TimeoutError.__mro__.__len__() == 5
# ---------------------------------------------------------------------------

table multiprocessing_extra73.exception_mro_lengths:
  description: "multiprocessing exception MRO length checks in mpmore73 namespace — wave 241 theme: exception hierarchy depth; AuthenticationError.__mro__.__len__()==5 (AuthenticationError, ProcessError, Exception, BaseException, object); ProcessError.__mro__.__len__()==4 (ProcessError, Exception, BaseException, object); TimeoutError.__mro__.__len__()==5 (TimeoutError, ProcessError, Exception, BaseException, object); verified with Python 3.14.3"
  kind: python_call_eq
  category: hierarchy
  id_prefix: mpmore73b

  columns: [id, function, args, expected, description]
  rows:
    - [autherror_mro_len,    AuthenticationError.__mro__.__len__, [], 5, "AuthenticationError.__mro__.__len__() == 5 — MRO: (AuthenticationError, ProcessError, Exception, BaseException, object); verified with Python 3.14.3"]
    - [procerror_mro_len,    ProcessError.__mro__.__len__,        [], 4, "ProcessError.__mro__.__len__() == 4 — MRO: (ProcessError, Exception, BaseException, object); verified with Python 3.14.3"]
    - [timeouterror_mro_len, TimeoutError.__mro__.__len__,        [], 5, "TimeoutError.__mro__.__len__() == 5 — MRO: (TimeoutError, ProcessError, Exception, BaseException, object); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing AuthenticationError qualname and MRO cross-check — extra73
# ---------------------------------------------------------------------------

table multiprocessing_extra73.AuthenticationError_detail:
  description: "multiprocessing AuthenticationError qualname and MRO length cross-check in mpmore73 namespace — wave 241 theme: exception hierarchy; AuthenticationError.__qualname__=='AuthenticationError'; AuthenticationError.__mro__.__len__()==5; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmore73c

  columns: [id, function, args, expected, description]
  rows:
    - [autherror_qualname_check, AuthenticationError.__qualname__.__eq__, ["AuthenticationError"], true, "AuthenticationError.__qualname__ == 'AuthenticationError'; verified with Python 3.14.3"]
    - [autherror_mro_len_check,  AuthenticationError.__mro__.__len__,     [],                      5,    "AuthenticationError.__mro__.__len__() == 5; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra73
# ---------------------------------------------------------------------------

invariant multiprocessing_extra73.AuthenticationError_qualname:
  description: "multiprocessing.AuthenticationError.__qualname__.__eq__('AuthenticationError') returns True — AuthenticationError is defined in multiprocessing; __qualname__ is 'AuthenticationError'; NEW in extra73: first standalone __qualname__ invariant for AuthenticationError in mpmore73 namespace; wave 241; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: AuthenticationError.__qualname__.__eq__
  args: ["AuthenticationError"]
  expected: true

invariant multiprocessing_extra73.ProcessError_mro_len:
  description: "multiprocessing.ProcessError.__mro__.__len__() == 4 — MRO is (ProcessError, Exception, BaseException, object); 4 entries; NEW in extra73: first standalone __mro__.__len__ invariant for ProcessError in mpmore73 namespace; wave 241; verified with Python 3.14.3"
  category: hierarchy
  kind: python_call_eq
  function: ProcessError.__mro__.__len__
  args: []
  expected: 4

invariant multiprocessing_extra73.BufferTooShort_name:
  description: "multiprocessing.BufferTooShort.__name__.__eq__('BufferTooShort') returns True — BufferTooShort is defined in multiprocessing; __name__ is 'BufferTooShort'; NEW in extra73: first standalone __name__ invariant for BufferTooShort in mpmore73 namespace; wave 241; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BufferTooShort.__name__.__eq__
  args: ["BufferTooShort"]
  expected: true

invariant multiprocessing_extra73.BufferTooShort_base_name:
  description: "multiprocessing.BufferTooShort.__bases__[0].__name__.__eq__('ProcessError') returns True — BufferTooShort directly subclasses ProcessError; NEW in extra73: first standalone __bases__[0].__name__ invariant for BufferTooShort in mpmore73 namespace; wave 241; verified with Python 3.14.3"
  category: hierarchy
  kind: python_call_eq
  function: "BufferTooShort.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra73.TimeoutError_mro_len:
  description: "multiprocessing.TimeoutError.__mro__.__len__() == 5 — MRO is (TimeoutError, ProcessError, Exception, BaseException, object); multiprocessing.TimeoutError subclasses ProcessError (not the built-in OSError-based TimeoutError); NEW in extra73: first standalone __mro__.__len__ invariant for TimeoutError in mpmore73 namespace; wave 241; verified with Python 3.14.3"
  category: hierarchy
  kind: python_call_eq
  function: TimeoutError.__mro__.__len__
  args: []
  expected: 5
