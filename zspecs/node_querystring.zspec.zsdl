spec: node_querystring
version: ">=12.0.0"
backend: node(querystring)

docs: https://nodejs.org/api/querystring.html

provenance:
  derived_from:
    - "Node.js querystring module documentation — https://nodejs.org/api/querystring.html"
    - "Test vectors verified with Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "Node.js source"
  notes:
    - "querystring is a Node.js built-in module. No npm install required."
    - "querystring.parse decodes a URL query string into an object. Values are always strings."
    - "querystring.stringify encodes an object into a URL query string."
    - "The module is deprecated in newer Node.js but remains functional."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns string or object. No errors for valid inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table node_querystring.parse:
  kind: node_module_call_eq
  function: parse
  category: parse
  id_prefix: qsparse

  columns: [id, args, expected]
  rows:
    - [simple,   ["a=1&b=2"],          {"a": "1", "b": "2"}]
    - [single,   ["foo=bar"],           {"foo": "bar"}]
    - [empty,    [""],                  {}]

table node_querystring.stringify:
  kind: node_module_call_eq
  function: stringify
  category: stringify
  id_prefix: qsstr

  columns: [id, args, expected]
  rows:
    - [simple,   [{"a": "1", "b": "2"}],   "a=1&b=2"]
    - [single,   [{"foo": "bar"}],          "foo=bar"]
    - [empty,    [{}],                       ""]
