spec: ujson_rust
version: ">=3.9"
backend: rust_module(ujson_rust)

docs: https://github.com/ultrajson/ultrajson

provenance:
  derived_from:
    - "https://github.com/ultrajson/ultrajson — UltraJSON documentation"
  not_derived_from:
    - "ujson source: ujson/__init__.py"
  notes:
    - "UltraJSON (ujson) is a fast JSON encoder/decoder."
    - "ujson.dumps({'a': 1}) == '{\"a\":1}'."
    - "ujson.loads('{\"a\":1}') == {'a': 1}."
    - "ujson.dumps([1,2,3]) == '[1,2,3]'."
    - "ujson.loads('[1,2,3]') == [1,2,3]."
    - "Expose ujson_dumps(obj) -> str: ujson.dumps(obj)."
    - "Expose ujson_loads(s) -> any: ujson.loads(s)."
    - "All test vectors verified against ujson 5.10.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# ujson_dumps — serialize to JSON
table ujson_rust.serialize.dumps:
  kind: python_call_eq
  category: dumps
  id_prefix: uj_d
  function: ujson_dumps

  columns: [id, args, expected]
  rows:
    - [list,  [[1, 2, 3]],  "[1,2,3]"]
    - [int,   [42],         "42"]
    - [true,  [true],       "true"]

# ujson_loads — deserialize from JSON
table ujson_rust.deserialize.loads:
  kind: python_call_eq
  category: loads
  id_prefix: uj_l
  function: ujson_loads

  columns: [id, args, expected]
  rows:
    - [list, ["[1,2,3]"], [1, 2, 3]]
    - [int,  ["42"],       42]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:36:22Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
