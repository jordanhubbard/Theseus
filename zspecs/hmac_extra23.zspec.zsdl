spec: hmac_extra23
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hmac_extra22.zspec.zsdl — covers HMAC.__mro__.__len__(); HMAC.__qualname__.__len__()==4; HMAC.__name__.__len__()==4; HMAC.__qualname__.__eq__; MRO member name/qualname table."
    - "hmac_extra21.zspec.zsdl — covers digest/compare_digest/new/HMAC __module__.__len__(); sha224/sha384 digest_size/block_size; callable __class__.__name__ table."
    - "hmac_extra19.zspec.zsdl — covers new.__qualname__.__eq__ and digest.__qualname__.__eq__ as standalone invariants."
    - "hmac_extra14.zspec.zsdl — covers new/digest/compare_digest/HMAC __qualname__ via table rows."
    - "hmac_extra17.zspec.zsdl — covers new/compare_digest/digest __name__/__module__; HMAC __qualname__/__module__/__bases__."
  notes:
    - "This spec extends hmac through hmac_extra22; it does NOT duplicate invariants present in those files."
    - "Focus: __qualname__.__len__() checks for hmac module-level functions — new, digest, compare_digest. hmac_extra22 covers HMAC.__qualname__.__len__() == 4 but no prior spec covers the length of qualname strings for the three functions."
    - "hmac.new.__qualname__ == 'new': len == 3. Plain module-level function; qualname equals name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.digest.__qualname__ == 'digest': len == 6. Plain module-level function. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.compare_digest.__qualname__ == 'compare_digest': len == 14. C builtin function; qualname accessible. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__module__ == 'hmac': no prior spec anchors this __eq__ from the extra23 namespace. hmac_extra17 covers it from extra17. Provides independent regression path. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hmac function __qualname__.__len__() — new, digest, compare_digest
#
# hmac_extra14 and hmac_extra19 cover __qualname__.__eq__ for these functions.
# hmac_extra22 covers HMAC.__qualname__.__len__() == 4.
# No prior spec checks __qualname__.__len__() for new, digest, or compare_digest.
# new == 'new' (len 3), digest == 'digest' (len 6),
# compare_digest == 'compare_digest' (len 14).
# ---------------------------------------------------------------------------

table hmac_extra23.function_qualname_lengths:
  description: "Length of __qualname__ strings for hmac module-level functions"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: hmacqlen23

  columns: [id, function, args, expected]
  rows:
    - [new,             new.__qualname__.__len__,             [],  3]
    - [digest,          digest.__qualname__.__len__,          [],  6]
    - [compare_digest,  compare_digest.__qualname__.__len__,  [], 14]

# ---------------------------------------------------------------------------
# hmac.HMAC.__module__ — standalone __eq__ from extra23 namespace
#
# hmac_extra17 covers HMAC.__module__.__eq__('hmac') == True from extra17.
# This invariant anchors the same property from the extra23 namespace,
# providing an independent execution path for regression detection.
# ---------------------------------------------------------------------------

invariant hmac_extra23.HMAC.module_eq:
  description: "hmac.HMAC.__module__ == 'hmac' — top-level class defined in hmac module"
  category: module_metadata
  kind: python_call_eq
  function: HMAC.__module__.__eq__
  args: ["hmac"]
  expected: true
