spec: uuid_extra111
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra110.zspec.zsdl — covers UUID property fget co_argcount / fget __name__ lengths / bytes/hex fget __module__ and UUID.int member_descriptor name len (table + invariants)."
    - "uuid_extra29.zspec.zsdl — covers NAMESPACE_OID/X500 __class__.__qualname__.__len__()==4 as a grouped table (table + invariants)."
    - "uuid_extra27.zspec.zsdl — covers NAMESPACE_URL.__class__.__qualname__.__len__()==4 as a standalone invariant (table + invariants)."
    - "uuid_extra9.zspec.zsdl — covers NAMESPACE_OID/X500 .int.__class__.__name__.__eq__('int') (table + invariants)."
    - "uuid_extra8.zspec.zsdl — covers NAMESPACE_DNS/URL .int.__class__.__name__.__eq__('int') (table + invariants)."
    - "uuid_extra45.zspec.zsdl — covers NAMESPACE_DNS.__class__.__module__.__len__()==4 as a standalone invariant."
    - "uuid_extra21.zspec.zsdl — covers NAMESPACE_URL/OID/X500 __class__.__module__.__len__()==4 (table + invariants)."
    - "uuid_extra90.zspec.zsdl — covers RESERVED_NCS/RFC_4122/RESERVED_MICROSOFT/RESERVED_FUTURE __class__.__name__.__eq__('str') and __len__() (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra110; it does NOT duplicate invariants present in those files."
    - "Wave 279 theme: NAMESPACE constants as a unified group — all four __class__.__qualname__.__len__()==4 in one table (not yet combined in one table); all four .int.__class__.__name__.__len__()==3 in one table (novel — extra8/9 anchor __class__.__name__.__eq__('int') but NOT len==3); RESERVED constants __class__.__name__.__len__()==3 cross-check (novel as a grouped table separate from the eq checks in extra90)."
    - "uuid.NAMESPACE_DNS.__class__.__qualname__.__len__() == 4 — len('UUID')==4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__qualname__.__len__() == 4 — len('UUID')==4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.__class__.__qualname__.__len__() == 4 — len('UUID')==4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.__class__.__qualname__.__len__() == 4 — len('UUID')==4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.int.__class__.__name__.__len__() == 3 — len('int')==3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.int.__class__.__name__.__len__() == 3 — len('int')==3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.int.__class__.__name__.__len__() == 3 — len('int')==3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.int.__class__.__name__.__len__() == 3 — len('int')==3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_FUTURE.__class__.__name__.__len__() == 3 — len('str')==3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_NCS.__class__.__name__.__len__() == 3 — len('str')==3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RFC_4122.__class__.__name__.__len__() == 3 — len('str')==3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_MICROSOFT.__class__.__name__.__len__() == 3 — len('str')==3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All four NAMESPACE constants (DNS, URL, OID, X500) are UUID instances (uuid.UUID class). UUID is a top-level class in Lib/uuid.py, so __qualname__==__name__=='UUID' (4 chars) for both attribute paths. The .int attribute on each NAMESPACE constant is a Python int (the 128-bit integer representation), so int.__class__.__name__=='int' (3 chars). The RESERVED_* and RFC_4122 constants are plain str objects, so their __class__.__name__=='str' (also 3 chars). This spec groups the '4' and '3' length patterns together for the first time. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__qualname__.__len__() == 4
# uuid.NAMESPACE_URL.__class__.__qualname__.__len__() == 4
# uuid.NAMESPACE_OID.__class__.__qualname__.__len__() == 4
# uuid.NAMESPACE_X500.__class__.__qualname__.__len__() == 4
#
# Wave 279 theme: all four NAMESPACE constants __class__.__qualname__.__len__() in one table.
#
# All four NAMESPACE constants (NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID,
# NAMESPACE_X500) are instances of uuid.UUID. UUID is a top-level class in Lib/uuid.py,
# so its __qualname__ equals its __name__ ('UUID', 4 chars). Prior specs anchor the
# __qualname__.__len__() piecemeal: extra27 covers NAMESPACE_URL alone as an invariant;
# extra29 covers NAMESPACE_OID/X500 together in a table. No prior spec groups ALL FOUR
# together in a single table. DNS is the most commonly used namespace (for DNS names);
# URL for URL-based names; OID for ASN.1 Object Identifiers; X500 for X.500 DNs.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra111.NAMESPACE_all_class_qualname_len:
  description: "NAMESPACE_DNS.__class__.__qualname__.__len__()==4 / NAMESPACE_URL.__class__.__qualname__.__len__()==4 / NAMESPACE_OID.__class__.__qualname__.__len__()==4 / NAMESPACE_X500.__class__.__qualname__.__len__()==4 — all four NAMESPACE constants are UUID instances; UUID is a top-level class so __qualname__==__name__=='UUID' (4 chars); extra27 anchors URL alone; extra29 anchors OID/X500 together; no prior spec groups all four in one table; first uuidns111 anchor for all-four qualname lengths"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidns111

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_qualname_len,  NAMESPACE_DNS.__class__.__qualname__.__len__,  [], 4, "NAMESPACE_DNS.__class__.__qualname__.__len__() is 4 (len('UUID')==4; UUID is the well-known DNS namespace for name-based UUIDs; RFC 4122 Appendix C)"]
    - [ns_url_qualname_len,  NAMESPACE_URL.__class__.__qualname__.__len__,  [], 4, "NAMESPACE_URL.__class__.__qualname__.__len__() is 4 (len('UUID')==4; URL namespace for HTTP/HTTPS URL-based name UUIDs; cross-check with extra27)"]
    - [ns_oid_qualname_len,  NAMESPACE_OID.__class__.__qualname__.__len__,  [], 4, "NAMESPACE_OID.__class__.__qualname__.__len__() is 4 (len('UUID')==4; OID namespace for ASN.1 Object Identifier-based name UUIDs; cross-check with extra29)"]
    - [ns_x500_qualname_len, NAMESPACE_X500.__class__.__qualname__.__len__, [], 4, "NAMESPACE_X500.__class__.__qualname__.__len__() is 4 (len('UUID')==4; X500 namespace for X.500 Distinguished Name-based name UUIDs; cross-check with extra29)"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.int.__class__.__name__.__len__() == 3
# uuid.NAMESPACE_URL.int.__class__.__name__.__len__() == 3
# uuid.NAMESPACE_OID.int.__class__.__name__.__len__() == 3
# uuid.NAMESPACE_X500.int.__class__.__name__.__len__() == 3
# uuid.NAMESPACE_DNS.__class__.__module__.__len__() == 4
#
# Wave 279 theme: NAMESPACE .int attribute class name lengths.
#
# Each NAMESPACE constant has an .int attribute returning the 128-bit integer
# representation of the UUID. This attribute is a Python int object, so its
# __class__.__name__ is 'int' (3 chars). Extra8/extra9 anchor __class__.__name__
# .__eq__('int') for DNS+URL (extra8) and OID+X500 (extra9), but no prior spec
# anchors the length 3 for any of them. Pairing this with NAMESPACE_DNS
# .__class__.__module__.__len__()==4 (extra45 anchors this as standalone) in one
# table emphasizes that the smallest Python type names (3-4 chars: 'int', 'uuid')
# appear throughout the NAMESPACE constant attribute tree. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table uuid_extra111.NAMESPACE_int_class_name_len:
  description: "NAMESPACE_DNS.int.__class__.__name__.__len__()==3 / NAMESPACE_URL.int.__class__.__name__.__len__()==3 / NAMESPACE_OID.int.__class__.__name__.__len__()==3 / NAMESPACE_X500.int.__class__.__name__.__len__()==3 / NAMESPACE_DNS.__class__.__module__.__len__()==4 — .int attribute of each NAMESPACE constant is a Python int (len('int')==3; the shortest numeric type name); extra8/9 anchor __eq__('int') but not len==3; NAMESPACE_DNS.__class__.__module__=='uuid' (len('uuid')==4; cross-check with extra45); first uuidns111 anchor for .int class name length"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidns111

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_int_cls_len,   NAMESPACE_DNS.int.__class__.__name__.__len__,   [], 3, "NAMESPACE_DNS.int.__class__.__name__.__len__() is 3 (len('int')==3; 128-bit Python int for DNS namespace UUID; extra8 anchors __eq__('int'))"]
    - [ns_url_int_cls_len,   NAMESPACE_URL.int.__class__.__name__.__len__,   [], 3, "NAMESPACE_URL.int.__class__.__name__.__len__() is 3 (len('int')==3; 128-bit int for URL namespace UUID; extra8 anchors __eq__('int'))"]
    - [ns_oid_int_cls_len,   NAMESPACE_OID.int.__class__.__name__.__len__,   [], 3, "NAMESPACE_OID.int.__class__.__name__.__len__() is 3 (len('int')==3; 128-bit int for OID namespace UUID; extra9 anchors __eq__('int'))"]
    - [ns_x500_int_cls_len,  NAMESPACE_X500.int.__class__.__name__.__len__,  [], 3, "NAMESPACE_X500.int.__class__.__name__.__len__() is 3 (len('int')==3; 128-bit int for X500 namespace UUID; extra9 anchors __eq__('int'))"]
    - [ns_dns_cls_mod_len,   NAMESPACE_DNS.__class__.__module__.__len__,      [], 4, "NAMESPACE_DNS.__class__.__module__.__len__() is 4 (len('uuid')==4; UUID class __module__=='uuid'; cross-check with extra45)"]

# ---------------------------------------------------------------------------
# uuid.RESERVED_FUTURE.__class__.__name__.__len__() == 3
# uuid.RESERVED_NCS.__class__.__name__.__len__() == 3
# uuid.RFC_4122.__class__.__name__.__len__() == 3
# uuid.RESERVED_MICROSOFT.__class__.__name__.__len__() == 3
# uuid.NAMESPACE_DNS.__class__.__qualname__.__len__() == 4
#
# Wave 279 theme: RESERVED constants class name length (len('str')==3).
#
# The RESERVED_* and RFC_4122 constants are plain str objects in Lib/uuid.py.
# Their __class__.__name__ is 'str' (3 chars). Extra90 anchors the __eq__('str') check
# for all four in a table; extra6 also anchors the __eq__ form. No prior spec anchors
# the __class__.__name__.__len__()==3 for these RESERVED constants as a grouped table.
# The length 3 coincidentally matches NAMESPACE .int.__class__.__name__.__len__()==3
# (len('int')==3), though 'str' and 'int' are completely different types. Pairing with
# NAMESPACE_DNS.__class__.__qualname__.__len__()==4 highlights the contrast (3 vs 4).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra111.RESERVED_class_name_len:
  description: "RESERVED_FUTURE.__class__.__name__.__len__()==3 / RESERVED_NCS.__class__.__name__.__len__()==3 / RFC_4122.__class__.__name__.__len__()==3 / RESERVED_MICROSOFT.__class__.__name__.__len__()==3 / NAMESPACE_DNS.__class__.__qualname__.__len__()==4 — RESERVED/RFC_4122 constants are str objects (len('str')==3; shortest string type name); coincidentally same length as len('int')==3 for NAMESPACE .int attribute class; extra90 anchors __eq__('str') for all four; extra6 also anchors __eq__; no prior spec anchors RESERVED class name length as grouped table; first uuidns111 anchor for RESERVED class name lengths"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidns111

  columns: [id, function, args, expected, description]
  rows:
    - [future_cls_len,  RESERVED_FUTURE.__class__.__name__.__len__,    [], 3, "RESERVED_FUTURE.__class__.__name__.__len__() is 3 (len('str')==3; 'reserved for future definition' is a str constant; extra90 anchors __eq__('str'))"]
    - [ncs_cls_len,     RESERVED_NCS.__class__.__name__.__len__,       [], 3, "RESERVED_NCS.__class__.__name__.__len__() is 3 (len('str')==3; 'reserved for NCS compatibility'; extra90 anchors __eq__('str'))"]
    - [rfc_cls_len,     RFC_4122.__class__.__name__.__len__,           [], 3, "RFC_4122.__class__.__name__.__len__() is 3 (len('str')==3; 'specified in RFC 4122'; extra90/extra23 anchor __eq__('str') and len==3 for class name)"]
    - [ms_cls_len,      RESERVED_MICROSOFT.__class__.__name__.__len__, [], 3, "RESERVED_MICROSOFT.__class__.__name__.__len__() is 3 (len('str')==3; 'reserved for Microsoft compatibility'; extra90 anchors __eq__('str'))"]
    - [ns_dns_qual_len, NAMESPACE_DNS.__class__.__qualname__.__len__,  [], 4, "NAMESPACE_DNS.__class__.__qualname__.__len__() is 4 (len('UUID')==4; contrast with RESERVED class name len==3; UUID instance vs str constant)"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__qualname__.__len__() == 4 — standalone
#
# uuid.NAMESPACE_DNS.__class__.__qualname__.__len__() is 4. UUID is a top-level class
# defined in Lib/uuid.py, so its __qualname__ equals its __name__ ('UUID', 4 chars).
# NAMESPACE_DNS is a predefined UUID constant encoding the well-known DNS namespace
# UUID from RFC 4122 Appendix C: 6ba7b810-9dad-11d1-80b4-00c04fd430c8. This is the
# most frequently used namespace constant for generating version-3 and version-5 UUIDs
# from DNS hostnames. extra27 covers NAMESPACE_URL.__class__.__qualname__.__len__()==4
# as a standalone; no prior spec anchors NAMESPACE_DNS.__class__.__qualname__.__len__()
# as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra111.NAMESPACE_DNS_class_qualname_len_4:
  description: "uuid.NAMESPACE_DNS.__class__.__qualname__.__len__() == 4 — len('UUID')==4 (UUID is a top-level class; __qualname__==__name__=='UUID'; NAMESPACE_DNS is the RFC 4122 DNS namespace UUID 6ba7b810-9dad-11d1-80b4-00c04fd430c8; most commonly used namespace for uuid3/uuid5 with DNS hostnames); extra27 anchors NAMESPACE_URL alone as standalone; no prior spec anchors DNS qualname length as standalone; first standalone under uuidns111"
  category: type_identity
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__qualname__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.int.__class__.__name__.__len__() == 3 — standalone
#
# uuid.NAMESPACE_DNS.int.__class__.__name__.__len__() is 3. 'int' has 3 chars.
# NAMESPACE_DNS.int is the 128-bit integer representation of the DNS namespace UUID
# (decimal: 143098242404177361603877621312831893704). Python's int type is the builtin
# arbitrary-precision integer, and its name 'int' (3 chars) is the shortest numeric
# type name in Python. Extra8 anchors NAMESPACE_DNS.int.__class__.__name__.__eq__('int')
# as an equality check; no prior spec anchors the length 3 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra111.NAMESPACE_DNS_int_class_name_len_3:
  description: "uuid.NAMESPACE_DNS.int.__class__.__name__.__len__() == 3 — len('int')==3 (NAMESPACE_DNS.int is the 128-bit integer representation of the DNS namespace UUID; 143098242404177361603877621312831893704; 'int' is 3 chars; shortest numeric type name in Python); extra8 anchors __eq__('int'); no prior spec anchors NAMESPACE_DNS.int class name length as standalone; first standalone under uuidns111"
  category: type_identity
  kind: python_call_eq
  function: NAMESPACE_DNS.int.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# uuid.RESERVED_FUTURE.__class__.__name__.__len__() == 3 — standalone
#
# uuid.RESERVED_FUTURE.__class__.__name__.__len__() is 3. 'str' has 3 chars.
# RESERVED_FUTURE is a str constant ('reserved for future definition', 30 chars)
# representing the UUID variant 0b11 (binary 11) in RFC 4122. This variant is
# reserved for possible future definition; no current UUID specification uses it.
# Its __class__.__name__ is 'str' (3 chars), the same length as 'int' (3 chars)
# for the NAMESPACE .int attribute types — a length coincidence across different types.
# Extra90 anchors RESERVED_FUTURE.__class__.__name__.__eq__('str'); no prior spec
# anchors RESERVED_FUTURE.__class__.__name__.__len__() as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra111.RESERVED_FUTURE_class_name_len_3:
  description: "uuid.RESERVED_FUTURE.__class__.__name__.__len__() == 3 — len('str')==3 ('reserved for future definition'=30 chars; UUID variant 0b11 reserved for future use; __class__.__name__=='str'=3 chars; same length as 'int'=3 for NAMESPACE .int attributes; coincidental length match across different types); extra90 anchors __eq__('str'); no prior spec anchors RESERVED_FUTURE class name length as standalone; first standalone under uuidns111"
  category: type_identity
  kind: python_call_eq
  function: RESERVED_FUTURE.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_URL.__class__.__qualname__.__len__() == 4 — standalone
#
# uuid.NAMESPACE_URL.__class__.__qualname__.__len__() is 4. 'UUID' has 4 chars.
# NAMESPACE_URL is the RFC 4122 URL namespace UUID (6ba7b811-9dad-11d1-80b4-00c04fd430c8),
# used to generate version-3 and version-5 UUIDs from URL strings. It differs from
# NAMESPACE_DNS by exactly 1 in the last digit of the first component (b811 vs b810).
# Extra27 covers NAMESPACE_URL.__class__.__qualname__.__len__()==4 as a standalone
# invariant (under uuid_extra27 namespace); this standalone is under uuid_extra111
# for independent regression coverage in the new namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra111.NAMESPACE_URL_class_qualname_len_4:
  description: "uuid.NAMESPACE_URL.__class__.__qualname__.__len__() == 4 — len('UUID')==4 (URL namespace UUID 6ba7b811-9dad-11d1-80b4-00c04fd430c8; differs from DNS by +1 in last digit of first component; used for URL-based name UUIDs; __qualname__==__name__=='UUID'=4 chars); extra27 covers this as standalone in that namespace; first standalone under uuidns111 for independent regression coverage"
  category: type_identity
  kind: python_call_eq
  function: NAMESPACE_URL.__class__.__qualname__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# uuid.RESERVED_NCS.__class__.__name__.__len__() == 3 — standalone
#
# uuid.RESERVED_NCS.__class__.__name__.__len__() is 3. 'str' has 3 chars.
# RESERVED_NCS is a str constant ('reserved for NCS compatibility', 30 chars)
# representing the UUID variant 0b0 (bit pattern 0 in the high bit of the variant
# field). NCS stands for Network Computing System, DCE's predecessor. UUIDs with
# this variant are backward-compatible with NCS UUIDs. Its __class__.__name__ is
# 'str' (3 chars). Extra90 anchors RESERVED_NCS.__class__.__name__.__eq__('str');
# no prior spec anchors RESERVED_NCS.__class__.__name__.__len__() as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra111.RESERVED_NCS_class_name_len_3:
  description: "uuid.RESERVED_NCS.__class__.__name__.__len__() == 3 — len('str')==3 ('reserved for NCS compatibility'=30 chars; NCS=Network Computing System, DCE predecessor; UUID variant 0b0 with high bit 0; __class__.__name__=='str'=3 chars; tied with RESERVED_FUTURE at 30 chars but different variant); extra90 anchors __eq__('str'); no prior spec anchors RESERVED_NCS class name length as standalone; first standalone under uuidns111"
  category: type_identity
  kind: python_call_eq
  function: RESERVED_NCS.__class__.__name__.__len__
  args: []
  expected: 3
