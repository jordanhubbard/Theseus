spec: theseus_inspect_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_inspect_cr2)
blocks: inspect

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html"
  notes:
    - "Clean-room extended inspect utilities. Do NOT import inspect."
    - "getmembers(obj, predicate=None): return list of (name, value) pairs for obj attributes."
    - "isbuiltin(obj): return True if obj is a built-in function or bound method."
    - "ismodule(obj): return True if obj is a module."
    - "inspect2_getmembers_count(): len([m for m in getmembers(int) if not m[0].startswith('_')]) > 0."
    - "inspect2_isbuiltin(): isbuiltin(len) == True."
    - "inspect2_ismodule(): import os; ismodule(os) == True."
    - "Zero-arg invariant signatures — def inspect2_getmembers_count(): return bool"
    - "Use sys.modules and type introspection; do not import inspect."
    - "Export: getmembers(obj, predicate=None), isbuiltin(obj), ismodule(obj)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_inspect_cr2.getmembers_count:
  description: "getmembers(int) has public members"
  category: getmembers
  kind: python_call_eq
  function: inspect2_getmembers_count
  args: []
  expected: true

invariant theseus_inspect_cr2.isbuiltin:
  description: "isbuiltin(len) == True"
  category: isbuiltin
  kind: python_call_eq
  function: inspect2_isbuiltin
  args: []
  expected: true

invariant theseus_inspect_cr2.ismodule:
  description: "ismodule(os) == True"
  category: ismodule
  kind: python_call_eq
  function: inspect2_ismodule
  args: []
  expected: true
