spec: abc_extra53
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/library/abc.html#abc.ABCMeta.__instancecheck__ — ABCMeta.__instancecheck__ documentation"
    - "https://docs.python.org/3/library/abc.html#abc.abstractmethod — abstractmethod documentation"
    - "https://docs.python.org/3/library/abc.html#abc.get_cache_token — get_cache_token documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra52.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all abc exports, abstractproperty/abstractclassmethod/abstractstaticmethod lengths/qualnames/bases, ABCMeta.register qualname lengths/equality, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2)/abstractproperty(3)/abstractclassmethod(3)/abstractstaticmethod(3), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() tables, ABCMeta/__dict__.__class__.__name__.__eq__('mappingproxy') (extra9), ABC/__dict__.__class__.__name__.__eq__('mappingproxy') (extra8), ABCMeta/__dict__.__class__.__qualname__ and ABC/__dict__.__class__.__qualname__ (extra49), abstractproperty/abstractclassmethod/abstractstaticmethod __dict__.__class__.__name__.__eq__('mappingproxy') (extra49), abc module __dict__.__class__.__name__/__qualname__ (extra49), abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta' (extra40), __class__.__qualname__ string equality for all abc exports (extra41-extra43), abstractmethod/__class__.__module__=='builtins', abstractproperty/__class__.__module__=='builtins', ABC/__class__.__module__=='abc', ABCMeta/__class__.__module__=='builtins', abstractclassmethod/__class__.__module__=='builtins', abstractstaticmethod/__class__.__module__=='builtins' (extra42), abstractproperty/__init__.__class__.__name__=='wrapper_descriptor', abstractmethod/__init__.__class__.__name__=='method-wrapper' (extra50), __class__.__module__.__len__() cross-checks (extra50), __repr__.__class__.__name__ for all abc objects (extra51), __weakref__.__class__.__name__ for abstractproperty/abstractclassmethod/abstractstaticmethod (extra51), ABCMeta.__instancecheck__/__subclasscheck__.__class__.__name__.__eq__('function') (extra52), ABC/ABCMeta __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra52). NOTE: abc has no __all__ — confirmed in extra52; hasattr(abc, '__all__') is False in Python 3.14.3."
    - "This spec covers (abcpkg53 namespace): abc.__package__.__eq__('') — abc is a top-level module (single file Lib/abc.py, not a package directory); for top-level modules __package__ is the empty string ''; __eq__('') returns True; __len__() == 0. ABC/__doc__/__class__/__name__/__eq__('str') and ABCMeta/__doc__/__class__/__name__/__eq__('str') — ABC and ABCMeta are pure-Python classes with docstrings; __doc__ is a plain Python str; __class__.__name__ == 'str'. abstractmethod/__doc__/__class__/__name__/__eq__('str') and get_cache_token/__doc__/__class__.__name__/__eq__('str') — abstractmethod is a class and get_cache_token is a function, both with docstrings that are plain Python str objects. ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') — ABCMeta overrides __instancecheck__ in pure Python (Lib/abc.py); its __qualname__ is 'ABCMeta.__instancecheck__'; __qualname__.__len__() == 25. No prior abc spec has captured __package__.__eq__, __doc__.__class__.__name__.__eq__ for these objects, or ABCMeta.__instancecheck__.__qualname__.__eq__ as string equality checks."
    - "abc.__package__ == ''. abc is a top-level module implemented as a single file (Lib/abc.py), not a package directory. For top-level modules (non-package modules), Python sets __package__ to the empty string ''. __eq__('') returns True. __len__() == 0. Note: __package__ == '' is distinct from __package__ == 'abc'; abc.__package__.__eq__('abc') returns False. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__doc__.__class__.__name__ == 'str'. ABC is a helper class with a docstring beginning 'Helper class that provides a standard wa...'. The docstring is a plain Python str; __class__.__name__ == 'str'; __doc__.__class__.__name__.__eq__('str') returns True. No prior abc spec captured ABC.__doc__.__class__.__name__ as a string equality check. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__doc__.__class__.__name__ == 'str'. ABCMeta is a metaclass with a docstring beginning 'Metaclass for defining Abstract Base Cla...'. The docstring is a plain Python str; __class__.__name__ == 'str'; __doc__.__class__.__name__.__eq__('str') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__doc__.__class__.__name__ == 'str'. abstractmethod is a class (decorator) with the docstring 'A decorator indicating abstract methods.' The docstring is a plain Python str; __class__.__name__ == 'str'; __doc__.__class__.__name__.__eq__('str') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token.__doc__.__class__.__name__ == 'str'. get_cache_token is a function with the docstring 'Returns the current ABC cache token.\\n\\n...'. The docstring is a plain Python str; __class__.__name__ == 'str'; __doc__.__class__.__name__.__eq__('str') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'. ABCMeta overrides __instancecheck__ in pure Python (Lib/abc.py). The __qualname__ of this Python function is 'ABCMeta.__instancecheck__', reflecting its definition inside the ABCMeta class body. __qualname__.__eq__('ABCMeta.__instancecheck__') returns True. __qualname__.__len__() == 25. No prior abc spec captured ABCMeta.__instancecheck__.__qualname__ as a string equality check (prior specs captured __qualname__.__len__() for ABCMeta methods but not __instancecheck__.__qualname__ equality). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.__package__ identity check — extra53
#
# abc is a top-level module (single file Lib/abc.py, not a package directory).
# For top-level modules (non-package modules), Python sets __package__ to
# the empty string ''. __eq__('') returns True. __len__() == 0.
#
# This is distinct from __package__ == 'abc'; __eq__('abc') returns False.
#
# No prior abc spec has captured __package__.__eq__ as a string equality check.
# Extra53 introduces this in the abcpkg53 namespace.
# ---------------------------------------------------------------------------

table abc_extra53.package_identity:
  description: "abc.__package__ identity in abcpkg53 namespace — abc is a top-level module (Lib/abc.py single file, not a package directory); for top-level modules __package__ is the empty string ''; __eq__('') returns True; __len__() == 0; __eq__('abc') returns False; first __package__.__eq__ table in any abc spec"
  kind: python_call_eq
  category: package_identity
  id_prefix: abcpkg53pkgid

  columns: [id, function, args, expected, description]
  rows:
    - [pkg_eq_empty, __package__.__eq__, [""], true,  "abc.__package__.__eq__('') == True — abc is a top-level module (Lib/abc.py single file); for non-package top-level modules __package__ is the empty string ''; __eq__('') returns True; first __package__ string equality check in any abc spec"]
    - [pkg_eq_abc,   __package__.__eq__, ["abc"], false, "abc.__package__.__eq__('abc') == False — abc.__package__ is '' (empty string), not 'abc'; top-level modules (not package directories) have __package__ == ''"]
    - [pkg_len,      __package__.__len__, [],     0,    "abc.__package__.__len__() == 0 — abc.__package__ is '' (empty string); __len__() of the empty string is 0; cross-check of the top-level module __package__ string length"]

# ---------------------------------------------------------------------------
# abc ABC/ABCMeta __doc__.__class__.__name__ — extra53
#
# ABC and ABCMeta are pure-Python classes in Lib/abc.py. Both define
# docstrings. The docstring (__doc__) is a plain Python str object.
# str is a built-in type; __class__.__name__ == 'str'.
#
# ABC.__doc__.__class__.__name__.__eq__('str')    returns True.
# ABCMeta.__doc__.__class__.__name__.__eq__('str') returns True.
#
# No prior abc spec has captured __doc__.__class__.__name__ as a string
# equality check for ABC or ABCMeta. Extra53 introduces this in abcpkg53.
# ---------------------------------------------------------------------------

table abc_extra53.class_doc_class_name_eq:
  description: "abc ABC/ABCMeta __doc__.__class__.__name__ in abcpkg53 namespace — ABC and ABCMeta are pure-Python classes with docstrings; __doc__ is a plain Python str; __class__.__name__ == 'str'; __doc__.__class__.__name__.__eq__('str') returns True; first __doc__.__class__.__name__ equality checks for ABC/ABCMeta in any abc spec"
  kind: python_call_eq
  category: class_names
  id_prefix: abcpkg53classdoc

  columns: [id, function, args, expected, description]
  rows:
    - [ABC,    ABC.__doc__.__class__.__name__.__eq__,    ["str"], true, "abc.ABC.__doc__.__class__.__name__ == 'str' — ABC has docstring 'Helper class that provides a standard way to create an ABC...'; __doc__ is a plain Python str; str is a built-in type; __class__.__name__ == 'str'; first ABC.__doc__.__class__.__name__ equality check in any abc spec"]
    - [ABCMeta, ABCMeta.__doc__.__class__.__name__.__eq__, ["str"], true, "abc.ABCMeta.__doc__.__class__.__name__ == 'str' — ABCMeta has docstring 'Metaclass for defining Abstract Base Classes...'; __doc__ is a plain Python str; str is a built-in type; __class__.__name__ == 'str'"]

# ---------------------------------------------------------------------------
# abc abstractmethod/get_cache_token __doc__.__class__.__name__ — extra53
#
# abstractmethod is a class (decorator) in Lib/abc.py with a docstring.
# get_cache_token is a function in Lib/abc.py with a docstring.
# Both docstrings are plain Python str objects; __class__.__name__ == 'str'.
#
# abstractmethod.__doc__.__class__.__name__.__eq__('str')  returns True.
# get_cache_token.__doc__.__class__.__name__.__eq__('str') returns True.
#
# No prior abc spec has captured __doc__.__class__.__name__ as string
# equality checks for abstractmethod or get_cache_token. Extra53 introduces
# this in the abcpkg53 namespace.
# ---------------------------------------------------------------------------

table abc_extra53.callable_doc_class_name_eq:
  description: "abc abstractmethod/get_cache_token __doc__.__class__.__name__ in abcpkg53 namespace — abstractmethod (a class/decorator) and get_cache_token (a function) both define docstrings that are plain Python str objects; __class__.__name__ == 'str'; __doc__.__class__.__name__.__eq__('str') returns True; first __doc__.__class__.__name__ equality checks for abstractmethod/get_cache_token in any abc spec"
  kind: python_call_eq
  category: class_names
  id_prefix: abcpkg53callabledoc

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod,   abstractmethod.__doc__.__class__.__name__.__eq__,   ["str"], true, "abc.abstractmethod.__doc__.__class__.__name__ == 'str' — abstractmethod has docstring 'A decorator indicating abstract methods.'; __doc__ is a plain Python str; str is a built-in type; __class__.__name__ == 'str'; first abstractmethod.__doc__.__class__.__name__ equality check in any abc spec"]
    - [get_cache_token, get_cache_token.__doc__.__class__.__name__.__eq__, ["str"], true, "abc.get_cache_token.__doc__.__class__.__name__ == 'str' — get_cache_token has docstring 'Returns the current ABC cache token.\\n\\n...'; __doc__ is a plain Python str; str is a built-in type; __class__.__name__ == 'str'"]

# ---------------------------------------------------------------------------
# abc ABCMeta.__instancecheck__.__qualname__ string equality — extra53
#
# ABCMeta overrides __instancecheck__ in pure Python in Lib/abc.py.
# The __qualname__ of this pure-Python function is 'ABCMeta.__instancecheck__',
# reflecting its definition inside the ABCMeta class body.
# __qualname__.__eq__('ABCMeta.__instancecheck__') returns True.
# __qualname__.__len__() == 25.
#
# No prior abc spec has captured ABCMeta.__instancecheck__.__qualname__
# as a string equality check (prior specs captured __qualname__.__len__()
# for ABCMeta methods via table but not __instancecheck__ qualname equality).
# Extra53 introduces this in the abcpkg53 namespace.
# ---------------------------------------------------------------------------

table abc_extra53.instancecheck_qualname_eq:
  description: "abc ABCMeta.__instancecheck__.__qualname__ string equality in abcpkg53 namespace — ABCMeta overrides __instancecheck__ in pure Python (Lib/abc.py); __qualname__ == 'ABCMeta.__instancecheck__'; __qualname__.__eq__('ABCMeta.__instancecheck__') returns True; __qualname__.__len__() == 25; first __instancecheck__.__qualname__ string equality check in any abc spec"
  kind: python_call_eq
  category: qualname
  id_prefix: abcpkg53instcheck

  columns: [id, function, args, expected, description]
  rows:
    - [qualname_eq,  ABCMeta.__instancecheck__.__qualname__.__eq__,  ["ABCMeta.__instancecheck__"], true, "ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') == True — ABCMeta overrides __instancecheck__ in pure Python (Lib/abc.py); this Python function's __qualname__ is 'ABCMeta.__instancecheck__' reflecting its definition inside the ABCMeta class body; first __instancecheck__.__qualname__ string equality check in any abc spec"]
    - [qualname_len, ABCMeta.__instancecheck__.__qualname__.__len__, [],                             25,   "ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — 'ABCMeta.__instancecheck__' has 25 characters; cross-check of the qualname string length"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra53
# ---------------------------------------------------------------------------

invariant abc_extra53.package_eq_empty:
  description: "abc.__package__.__eq__('') returns True — abc is a top-level module (Lib/abc.py single file, not a package directory); for non-package top-level modules __package__ is the empty string ''; first __package__ string equality invariant in any abc spec"
  category: package_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant abc_extra53.ABC_doc_class_name_eq:
  description: "abc.ABC.__doc__.__class__.__name__.__eq__('str') returns True — ABC has a docstring which is a plain Python str; str is a built-in type; __class__.__name__ == 'str'; first ABC.__doc__.__class__.__name__ string equality invariant in any abc spec"
  category: class_names
  kind: python_call_eq
  function: ABC.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra53.ABCMeta_doc_class_name_eq:
  description: "abc.ABCMeta.__doc__.__class__.__name__.__eq__('str') returns True — ABCMeta has a docstring which is a plain Python str; str is a built-in type; __class__.__name__ == 'str'; novel docstring type check for ABCMeta in abcpkg53 namespace"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra53.abstractmethod_doc_class_name_eq:
  description: "abc.abstractmethod.__doc__.__class__.__name__.__eq__('str') returns True — abstractmethod has docstring 'A decorator indicating abstract methods.' which is a plain Python str; __class__.__name__ == 'str'; novel docstring type check for abstractmethod"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra53.get_cache_token_doc_class_name_eq:
  description: "abc.get_cache_token.__doc__.__class__.__name__.__eq__('str') returns True — get_cache_token has a docstring which is a plain Python str; __class__.__name__ == 'str'; novel docstring type check for get_cache_token"
  category: class_names
  kind: python_call_eq
  function: get_cache_token.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra53.ABCMeta_instancecheck_qualname_eq:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') returns True — ABCMeta overrides __instancecheck__ in pure Python (Lib/abc.py); the override's __qualname__ is 'ABCMeta.__instancecheck__' reflecting its definition inside the ABCMeta class body; first __instancecheck__.__qualname__ string equality invariant in any abc spec"
  category: qualname
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__qualname__.__eq__
  args: ["ABCMeta.__instancecheck__"]
  expected: true
