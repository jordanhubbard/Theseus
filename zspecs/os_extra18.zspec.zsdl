spec: os_extra18
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "CPython source: Lib/os.py"
  notes:
    - "This spec extends os.zspec.zsdl and prior extras through os_extra17.zspec.zsdl."
    - "os_extra.zspec covers getpid().__class__.__name__=='int' and getpid()>0 via direct call syntax."
    - "os_extra5 covers listdir/__name__, makedirs/__name__, rename/__name__, remove/__name__, getcwd/__name__."
    - "os_extra7 covers cpu_count/__name__, getpid/__name__."
    - "os_extra8 covers getpid/__qualname__, getcwd/__qualname__, cpu_count/__qualname__."
    - "os_extra11 covers getpid/__module__, getcwd/__module__, getlogin/__module__, getlogin/__qualname__."
    - "os_extra12 covers stat/__module__."
    - "os_extra13 covers cpu_count/__module__, listdir/__module__, makedirs/__module__."
    - "NOT yet covered: os.getpid().__class__.__name__ via attribute chain (new axis vs. direct call)."
    - "NOT yet covered: os.getcwd().__class__.__name__ via attribute chain."
    - "NOT yet covered: os.cpu_count().__class__.__name__ via attribute chain."
    - "NOT yet covered: os.stat.__name__ or os.stat.__qualname__."
    - "NOT yet covered: os.getuid.__name__, os.getgid.__name__."
    - "NOT yet covered: os.getenv.__qualname__ (os_extra8 covers only getpid/getcwd)."
    - "os.getpid().__class__.__name__ == 'int' — PID is always an integer."
    - "os.getcwd().__class__.__name__ == 'str' — current directory is always a string."
    - "os.cpu_count().__class__.__name__ == 'int' — CPU count is always an integer."
    - "os.stat.__name__ == 'stat' and os.stat.__qualname__ == 'stat'."
    - "os.getuid.__name__ == 'getuid' and os.getgid.__name__ == 'getgid'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Return type of os.getpid(), os.getcwd(), os.cpu_count()
#
# os_extra.zspec covers these via function call syntax (getpid(), getcwd(),
# cpu_count()) which requires the compiler's direct-call path. No prior spec
# covers these via the attribute-chain path using __class__.__name__.__eq__.
# This spec uses the attribute-chain form as a new, independently testable axis.
# ---------------------------------------------------------------------------

invariant os_extra18.stat.class_name:
  description: "os.stat.__class__.__name__ == 'builtin_function_or_method' — stat is a C built-in"
  category: function_identity
  kind: python_call_eq
  function: stat.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant os_extra18.getpid.class_name:
  description: "os.getpid.__class__.__name__ — getpid is a builtin_function_or_method"
  category: function_identity
  kind: python_call_eq
  function: getpid.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant os_extra18.getcwd.class_name:
  description: "os.getcwd.__class__.__name__ == 'builtin_function_or_method'"
  category: function_identity
  kind: python_call_eq
  function: getcwd.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# os.stat — __name__ and __qualname__
#
# os_extra12 covers os.stat.__module__ == 'posix'. No prior spec covers
# os.stat.__name__ or os.stat.__qualname__. Both equal 'stat' since stat
# is a module-level built-in function.
# ---------------------------------------------------------------------------

invariant os_extra18.stat.name:
  description: "os.stat.__name__ == 'stat'"
  category: function_identity
  kind: python_call_eq
  function: stat.__name__.__eq__
  args: ["stat"]
  expected: true

invariant os_extra18.stat.qualname:
  description: "os.stat.__qualname__ == 'stat'"
  category: function_identity
  kind: python_call_eq
  function: stat.__qualname__.__eq__
  args: ["stat"]
  expected: true

# ---------------------------------------------------------------------------
# os.getuid, os.getgid — __name__
#
# No prior os spec covers os.getuid.__name__ or os.getgid.__name__.
# These are POSIX-only functions returning the process UID and GID.
# ---------------------------------------------------------------------------

invariant os_extra18.getuid.name:
  description: "os.getuid.__name__ == 'getuid' — POSIX user ID getter"
  category: function_identity
  kind: python_call_eq
  function: getuid.__name__.__eq__
  args: ["getuid"]
  expected: true

invariant os_extra18.getgid.name:
  description: "os.getgid.__name__ == 'getgid' — POSIX group ID getter"
  category: function_identity
  kind: python_call_eq
  function: getgid.__name__.__eq__
  args: ["getgid"]
  expected: true

# ---------------------------------------------------------------------------
# os.getuid, os.getgid — __qualname__
#
# No prior os spec covers os.getuid.__qualname__ or os.getgid.__qualname__.
# Module-level built-in functions have __qualname__ equal to __name__.
# ---------------------------------------------------------------------------

invariant os_extra18.getuid.qualname:
  description: "os.getuid.__qualname__ == 'getuid' — qualname equals name for module-level builtins"
  category: function_identity
  kind: python_call_eq
  function: getuid.__qualname__.__eq__
  args: ["getuid"]
  expected: true

invariant os_extra18.getgid.qualname:
  description: "os.getgid.__qualname__ == 'getgid' — qualname equals name for module-level builtins"
  category: function_identity
  kind: python_call_eq
  function: getgid.__qualname__.__eq__
  args: ["getgid"]
  expected: true

# ---------------------------------------------------------------------------
# os.getenv — __qualname__
#
# os_extra6 covers os.getenv.__name__ == 'getenv'.
# os_extra8 covers __qualname__ for getpid and getcwd only.
# No prior spec covers os.getenv.__qualname__.
# ---------------------------------------------------------------------------

invariant os_extra18.getenv.qualname:
  description: "os.getenv.__qualname__ == 'getenv' — qualname equals name for module-level functions"
  category: function_identity
  kind: python_call_eq
  function: getenv.__qualname__.__eq__
  args: ["getenv"]
  expected: true
