spec: itertools_extra378
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "itertools.count.__doc__.__class__.__name__ == 'str' — count is a C type with a plain string docstring. Verified with Python 3.14.3."
    - "itertools.repeat.__doc__.__class__.__name__ == 'str' — repeat is a C type with a plain string docstring. Verified with Python 3.14.3."
    - "itertools.chain.__doc__.__class__.__name__ == 'str' — chain is a C type with a plain string docstring. Verified with Python 3.14.3."
    - "itertools.cycle.__doc__.__class__.__name__ == 'str' — cycle is a C type with a plain string docstring. Verified with Python 3.14.3."
    - "itertools.count.__qualname__ == 'count' — count is a top-level C type so __qualname__ equals __name__. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__name__ == 'from_iterable' — class method descriptor on chain. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — qualified name includes the owning class. Verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools C type docstring class names
#
# itertools.count.__doc__.__class__.__name__ == 'str'
# itertools.repeat.__doc__.__class__.__name__ == 'str'
# itertools.chain.__doc__.__class__.__name__ == 'str'
# itertools.cycle.__doc__.__class__.__name__ == 'str'
#
# count, repeat, chain, and cycle are all C extension types in
# Modules/itertoolsmodule.c. Their __doc__ attributes are plain Python str
# objects (not NoneType or some other type).
# ---------------------------------------------------------------------------

table itertools_extra378.c_type_doc_class_names:
  description: "itertools.count, repeat, chain, cycle docstring __class__.__name__ is 'str' for all four C extension types; new to extra378"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsdoc378

  columns: [id, function, args, expected, description]
  rows:
    - [count_doc_class_name_eq,
       "count.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.count.__doc__.__class__.__name__.__eq__('str') == True — count is a C extension type in Modules/itertoolsmodule.c that makes an iterator returning evenly spaced values starting with a given number; its __doc__ attribute is a plain str; str.__eq__('str') returns True; new to extra378"]
    - [repeat_doc_class_name_eq,
       "repeat.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.repeat.__doc__.__class__.__name__.__eq__('str') == True — repeat is a C extension type in Modules/itertoolsmodule.c that returns a value repeatedly or a given number of times; its __doc__ attribute is a plain str; str.__eq__('str') returns True; new to extra378"]
    - [chain_doc_class_name_eq,
       "chain.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.chain.__doc__.__class__.__name__.__eq__('str') == True — chain is a C extension type in Modules/itertoolsmodule.c that chains multiple iterables into a single iterator; its __doc__ attribute is a plain str; str.__eq__('str') returns True; new to extra378"]
    - [cycle_doc_class_name_eq,
       "cycle.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.cycle.__doc__.__class__.__name__.__eq__('str') == True — cycle is a C extension type in Modules/itertoolsmodule.c that cycles through an iterable indefinitely; its __doc__ attribute is a plain str; str.__eq__('str') returns True; new to extra378"]

# ---------------------------------------------------------------------------
# Table 2: itertools.count qualname and itertools.chain.from_iterable identity
#
# itertools.count.__qualname__ == 'count'
# itertools.chain.from_iterable.__name__ == 'from_iterable'
# itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'
#
# count is a top-level C type so its __qualname__ matches its __name__.
# chain.from_iterable is a class method descriptor; its __name__ is 'from_iterable'
# and its __qualname__ encodes the owning class as 'chain.from_iterable'.
# ---------------------------------------------------------------------------

table itertools_extra378.count_qualname_and_chain_from_iterable_identity:
  description: "itertools.count __qualname__, and itertools.chain.from_iterable __name__ and __qualname__; new to extra378"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsqn378

  columns: [id, function, args, expected, description]
  rows:
    - [count_qualname_eq,
       "count.__qualname__.__eq__",
       ["count"],
       true,
       "itertools.count.__qualname__.__eq__('count') == True — count is a top-level C extension type so its __qualname__ equals its __name__ 'count'; str.__eq__('count') returns True; new to extra378"]
    - [chain_from_iterable_name_eq,
       "chain.from_iterable.__name__.__eq__",
       ["from_iterable"],
       true,
       "itertools.chain.from_iterable.__name__.__eq__('from_iterable') == True — chain.from_iterable is a classmethod descriptor on the chain C type that chains a single iterable of iterables; its __name__ is 'from_iterable'; str.__eq__('from_iterable') returns True; new to extra378"]
    - [chain_from_iterable_qualname_eq,
       "chain.from_iterable.__qualname__.__eq__",
       ["chain.from_iterable"],
       true,
       "itertools.chain.from_iterable.__qualname__.__eq__('chain.from_iterable') == True — chain.from_iterable is a classmethod on the chain C type; its __qualname__ encodes the owning class giving 'chain.from_iterable'; str.__eq__('chain.from_iterable') returns True; new to extra378"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra378
# ---------------------------------------------------------------------------

invariant itertools_extra378.count_doc_class_name:
  description: "itertools.count.__doc__.__class__.__name__ == 'str' — count C type has a plain string docstring; new to extra378"
  kind: python_call_eq
  function: count.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra378.repeat_doc_class_name:
  description: "itertools.repeat.__doc__.__class__.__name__ == 'str' — repeat C type has a plain string docstring; new to extra378"
  kind: python_call_eq
  function: repeat.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra378.chain_doc_class_name:
  description: "itertools.chain.__doc__.__class__.__name__ == 'str' — chain C type has a plain string docstring; new to extra378"
  kind: python_call_eq
  function: chain.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra378.cycle_doc_class_name:
  description: "itertools.cycle.__doc__.__class__.__name__ == 'str' — cycle C type has a plain string docstring; new to extra378"
  kind: python_call_eq
  function: cycle.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra378.count_qualname:
  description: "itertools.count.__qualname__ == 'count' — top-level C type so __qualname__ equals __name__; new to extra378"
  kind: python_call_eq
  function: count.__qualname__.__eq__
  args: ["count"]
  expected: true

invariant itertools_extra378.chain_from_iterable_name:
  description: "itertools.chain.from_iterable.__name__ == 'from_iterable' — classmethod descriptor on chain C type; new to extra378"
  kind: python_call_eq
  function: chain.from_iterable.__name__.__eq__
  args: ["from_iterable"]
  expected: true

invariant itertools_extra378.chain_from_iterable_qualname:
  description: "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — qualified name encodes the owning class; new to extra378"
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__eq__
  args: ["chain.from_iterable"]
  expected: true
