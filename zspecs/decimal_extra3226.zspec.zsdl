spec: dc3226
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 662 (dc3226): __radd__, __rsub__, __rmul__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "Theme: __radd__, __rsub__, __rmul__ dict-presence (reflected arithmetic)."
    - "Key finding: decimal.Decimal defines all 3 reflected operators (complete numeric type supporting right-hand arithmetic); all other classes are False."
    - "decimal.Decimal.__radd__ = True: Decimal is a full numeric type implementing IEEE 754 decimal arithmetic; it defines __radd__ so that expressions like (int + Decimal) work correctly by delegating to Decimal.__radd__."
    - "decimal.Decimal.__rsub__ = True: Decimal defines __rsub__ to handle right-hand subtraction, e.g. (int - Decimal) dispatches to Decimal.__rsub__."
    - "decimal.Decimal.__rmul__ = True: Decimal defines __rmul__ to handle right-hand multiplication, e.g. (int * Decimal) dispatches to Decimal.__rmul__."
    - "decimal.Context does NOT define __radd__, __rsub__, or __rmul__ in its own __dict__: Context is a precision/rounding configuration object, not a numeric operand."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow are exception subclasses with no arithmetic protocol defined in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __radd__ dict-presence — operator.contains(Cls.__dict__, '__radd__')
#
# decimal.Decimal defines __radd__ in its own __dict__: true.
# Decimal is a complete numeric type implementing IEEE 754; __radd__ enables
# right-hand addition so that (int + Decimal) dispatches to Decimal.__radd__.
# All other decimal classes: false.
# ---------------------------------------------------------------------------

table dc3226.radd:
  description: "decimal types __radd__ dict-presence checks; wave 662"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3226

  columns: [id, function, args, expected]
  rows:
    - ["dc3226001", operator.contains, [decimal.Decimal.__dict__,          "__radd__"], true]
    - ["dc3226002", operator.contains, [decimal.Context.__dict__,           "__radd__"], false]
    - ["dc3226003", operator.contains, [decimal.DecimalException.__dict__,  "__radd__"], false]
    - ["dc3226004", operator.contains, [decimal.InvalidOperation.__dict__,  "__radd__"], false]
    - ["dc3226005", operator.contains, [decimal.Overflow.__dict__,          "__radd__"], false]
    - ["dc3226006", operator.contains, [decimal.Underflow.__dict__,         "__radd__"], false]

