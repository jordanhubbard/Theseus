spec: hashlib_extra98
version: ">=3.9"
backend: python_module(hashlib)
extends: hashlib_extra97

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership for sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512/sha3_224/sha3_384/blake2b/blake2s/shake_128/shake_256 / algorithms_available membership for sha256/sha512 / new/__qualname__.__eq__('__hash_new') / new/__qualname__.__len__()==10 (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / hashlib.new __qualname__/__module__/co_argcount cross-checks / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__.__eq__('__hash_new') / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__.__eq__ and __module__.__eq__('_hashlib') (table + invariants)."
    - "hashlib_extra94.zspec.zsdl — covers hashlib.algorithms_available/algorithms_guaranteed set class identity and membership / sha256/sha512/sha1/md5 constructor __class__.__name__=='builtin_function_or_method' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra97; it does NOT duplicate invariants present in those files."
    - "Wave 258 theme: hashlib sha3 and shake constructor qualnames + file_digest function identity + hashlib.__all__ class name and length."
    - "hashlib.sha3_224.__qualname__ == 'openssl_sha3_224'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__qualname__ == 'openssl_sha3_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__qualname__ == 'openssl_sha3_384'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__qualname__ == 'openssl_sha3_512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__qualname__ == 'openssl_shake_128'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__qualname__ == 'openssl_shake_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__qualname__ == 'file_digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__module__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__.__class__.__name__ == 'tuple'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__.__len__() == 19. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha3_224.__qualname__.__eq__('openssl_sha3_224')
# hashlib.sha3_256.__qualname__.__eq__('openssl_sha3_256')
# hashlib.sha3_384.__qualname__.__eq__('openssl_sha3_384')
# hashlib.sha3_512.__qualname__.__eq__('openssl_sha3_512')
#
# Wave 258 theme: sha3_* constructor __qualname__ equality.
#
# The four SHA-3 constructors exposed by hashlib are backed by OpenSSL and
# live in the _hashlib C extension. Their __qualname__ carries the 'openssl_'
# prefix (e.g. 'openssl_sha3_224'), distinguishing them from the pure-Python
# fallback names. No prior hashlib spec anchors these four sha3 __qualname__
# values together under hashlibsha3shake98.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra98.sha3_qualname_eq:
  description: "hashlib.sha3_224/__qualname__.__eq__('openssl_sha3_224')==True / sha3_256/__qualname__.__eq__('openssl_sha3_256')==True / sha3_384/__qualname__.__eq__('openssl_sha3_384')==True / sha3_512/__qualname__.__eq__('openssl_sha3_512')==True — the SHA-3 constructors are OpenSSL-backed (_hashlib C extension); their __qualname__ carries the 'openssl_' prefix; no prior hashlib spec anchors these four sha3 __qualname__ values together; first hashlibsha3shake98 anchor for sha3_* constructor __qualname__ equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibsha3shake98

  columns: [id, function, args, expected]
  rows:
    - [sha3_224_qualname, sha3_224.__qualname__.__eq__, ["openssl_sha3_224"], true]
    - [sha3_256_qualname, sha3_256.__qualname__.__eq__, ["openssl_sha3_256"], true]
    - [sha3_384_qualname, sha3_384.__qualname__.__eq__, ["openssl_sha3_384"], true]
    - [sha3_512_qualname, sha3_512.__qualname__.__eq__, ["openssl_sha3_512"], true]

# ---------------------------------------------------------------------------
# hashlib.shake_128.__qualname__.__eq__('openssl_shake_128')
# hashlib.shake_256.__qualname__.__eq__('openssl_shake_256')
# hashlib.shake_128.__module__.__eq__('_hashlib')
# hashlib.shake_256.__module__.__eq__('_hashlib')
#
# Wave 258 theme: shake_128/shake_256 __qualname__ and __module__ equality.
#
# The two SHAKE XOF constructors are also OpenSSL-backed (_hashlib). Their
# __qualname__ values are 'openssl_shake_128' and 'openssl_shake_256', and
# their __module__ is '_hashlib'. No prior hashlib spec anchors these four
# checks together under hashlibsha3shake98.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra98.shake_qualname_and_module_eq:
  description: "hashlib.shake_128/__qualname__.__eq__('openssl_shake_128')==True / shake_256/__qualname__.__eq__('openssl_shake_256')==True / shake_128/__module__.__eq__('_hashlib')==True / shake_256/__module__.__eq__('_hashlib')==True — the SHAKE XOF constructors are OpenSSL-backed (_hashlib); __qualname__ carries the 'openssl_' prefix; __module__ is '_hashlib'; no prior hashlib spec anchors these four checks together; first hashlibsha3shake98 anchor for shake_128/shake_256 __qualname__ and __module__ equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibsha3shake98

  columns: [id, function, args, expected]
  rows:
    - [shake_128_qualname, shake_128.__qualname__.__eq__, ["openssl_shake_128"], true]
    - [shake_256_qualname, shake_256.__qualname__.__eq__, ["openssl_shake_256"], true]
    - [shake_128_module,   shake_128.__module__.__eq__,   ["_hashlib"],          true]
    - [shake_256_module,   shake_256.__module__.__eq__,   ["_hashlib"],          true]

# ---------------------------------------------------------------------------
# hashlib.sha3_224.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha3_256.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha3_384.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha3_512.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.shake_128.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.shake_256.__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 258 theme: sha3_*/shake_* __class__.__name__ equality.
#
# All six SHA-3/SHAKE constructors exposed by hashlib are C builtin functions
# from the _hashlib extension. Each has __class__.__name__ ==
# 'builtin_function_or_method'. hashlib_extra94 first anchors
# sha256/sha512/sha1/md5 as builtin_function_or_method; this table extends
# that to the sha3_* and shake_* family.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra98.sha3_shake_class_names:
  description: "hashlib.sha3_224/__class__.__name__.__eq__('builtin_function_or_method')==True / sha3_256/__class__.__name__.__eq__==True / sha3_384/__class__.__name__.__eq__==True / sha3_512/__class__.__name__.__eq__==True / shake_128/__class__.__name__.__eq__==True / shake_256/__class__.__name__.__eq__==True — all six SHA-3/SHAKE constructors are C builtin functions from _hashlib; hashlib_extra94 first anchors sha256/sha512/sha1/md5; this table extends the class name check to sha3_*/shake_*; first hashlibsha3shake98 anchor for sha3_*/shake_* class names"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibsha3shake98

  columns: [id, function, args, expected]
  rows:
    - [sha3_224_class, sha3_224.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [sha3_256_class, sha3_256.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [sha3_384_class, sha3_384.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [sha3_512_class, sha3_512.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [shake_128_class, shake_128.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [shake_256_class, shake_256.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# hashlib.file_digest.__class__.__name__.__eq__('function')
# hashlib.file_digest.__qualname__.__eq__('file_digest')
# hashlib.file_digest.__module__.__eq__('hashlib')
# hashlib.file_digest.__code__.co_argcount.__eq__(2)
# hashlib.__all__.__class__.__name__.__eq__('tuple')
# hashlib.__all__.__len__()==19
#
# Wave 258 theme: file_digest function identity + hashlib.__all__ class and length.
#
# hashlib.file_digest (added in Python 3.11) is a pure-Python function defined
# in Lib/hashlib.py. It takes 2 positional args (fileobj and digest). Its
# __class__.__name__ is 'function', __qualname__ is 'file_digest', and
# __module__ is 'hashlib'. hashlib.__all__ is a tuple with 19 entries.
# No prior hashlib spec anchors file_digest identity or __all__ class/len
# together under hashlibsha3shake98. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra98.file_digest_identity_and_all:
  description: "hashlib.file_digest/__class__.__name__.__eq__('function')==True / file_digest/__qualname__.__eq__('file_digest')==True / file_digest/__module__.__eq__('hashlib')==True / file_digest/__code__/co_argcount.__eq__(2)==True / __all__/__class__/__name__.__eq__('tuple')==True / __all__/__len__()==19 — file_digest (Python 3.11+) is a pure-Python function taking fileobj+digest (co_argcount==2); __all__ is a tuple with 19 entries; no prior hashlib spec anchors these together; first hashlibsha3shake98 anchor for file_digest identity and __all__ class/length"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibsha3shake98

  columns: [id, function, args, expected]
  rows:
    - [file_digest_class,      file_digest.__class__.__name__.__eq__,      ["function"],    true]
    - [file_digest_qualname,   file_digest.__qualname__.__eq__,             ["file_digest"], true]
    - [file_digest_module,     file_digest.__module__.__eq__,               ["hashlib"],     true]
    - [file_digest_co_argcount, file_digest.__code__.co_argcount.__eq__,    [2],             true]
    - [all_class_name,         __all__.__class__.__name__.__eq__,           ["tuple"],       true]
    - [all_len,                __all__.__len__,                             [],              19]

# ---------------------------------------------------------------------------
# hashlib.sha3_224.__qualname__.__eq__('openssl_sha3_224') — standalone
#
# hashlib.sha3_224.__qualname__ is 'openssl_sha3_224'. The sha3_224 constructor
# is an OpenSSL-backed C builtin from _hashlib. Its __qualname__ carries the
# 'openssl_' prefix, identifying it as the OpenSSL implementation of SHA3-224.
# No prior hashlib spec anchors sha3_224.__qualname__.__eq__ as a standalone
# under hashlibsha3shake98. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra98.sha3_224_qualname:
  description: "hashlib.sha3_224.__qualname__.__eq__('openssl_sha3_224') == True — sha3_224 is an OpenSSL-backed C builtin from _hashlib; its __qualname__ 'openssl_sha3_224' identifies it as the OpenSSL SHA3-224 implementation; no prior hashlib spec anchors this as a standalone; first standalone for sha3_224 __qualname__ under hashlibsha3shake98"
  category: type_identity
  kind: python_call_eq
  function: sha3_224.__qualname__.__eq__
  args: ["openssl_sha3_224"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.shake_128.__qualname__.__eq__('openssl_shake_128') — standalone
#
# hashlib.shake_128.__qualname__ is 'openssl_shake_128'. shake_128 is an XOF
# (extendable-output function) from the SHA-3 family, backed by OpenSSL and
# implemented as a C builtin in _hashlib. Its __qualname__ carries the 'openssl_'
# prefix. No prior hashlib spec anchors shake_128.__qualname__.__eq__ as a
# standalone under hashlibsha3shake98. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra98.shake_128_qualname:
  description: "hashlib.shake_128.__qualname__.__eq__('openssl_shake_128') == True — shake_128 is an OpenSSL-backed XOF (extendable-output function) from the SHA-3 family; its __qualname__ 'openssl_shake_128' carries the 'openssl_' prefix; no prior hashlib spec anchors this as a standalone; first standalone for shake_128 __qualname__ under hashlibsha3shake98"
  category: type_identity
  kind: python_call_eq
  function: shake_128.__qualname__.__eq__
  args: ["openssl_shake_128"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__module__.__eq__('hashlib') — standalone
#
# hashlib.file_digest.__module__ is 'hashlib'. file_digest is a pure-Python
# function defined in Lib/hashlib.py (added in Python 3.11). It accepts a file
# object and a digest algorithm and returns the digest. Being a pure-Python
# function, its __module__ is 'hashlib' (not '_hashlib'). No prior hashlib spec
# anchors file_digest.__module__.__eq__ as a standalone under hashlibsha3shake98.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra98.file_digest_module:
  description: "hashlib.file_digest.__module__.__eq__('hashlib') == True — file_digest (Python 3.11+) is a pure-Python function in Lib/hashlib.py; its __module__ is 'hashlib' (not '_hashlib'), distinguishing it from the OpenSSL-backed C builtins; no prior hashlib spec anchors this as a standalone; first standalone for file_digest __module__ under hashlibsha3shake98"
  category: type_identity
  kind: python_call_eq
  function: file_digest.__module__.__eq__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__all__.__class__.__name__.__eq__('tuple') — standalone
#
# hashlib.__all__.__class__.__name__ is 'tuple'. hashlib defines __all__ as a
# tuple (not a list) to enumerate the public API surface of the module. This is
# a tuple with 19 entries. No prior hashlib spec anchors
# __all__.__class__.__name__.__eq__ as a standalone under hashlibsha3shake98.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra98.all_class_name:
  description: "hashlib.__all__.__class__.__name__.__eq__('tuple') == True — hashlib defines __all__ as a tuple (not a list) enumerating the module's public API; no prior hashlib spec anchors this as a standalone; first standalone for hashlib.__all__ class name under hashlibsha3shake98"
  category: type_identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_512.__module__.__eq__('_hashlib') — standalone
#
# hashlib.sha3_512.__module__ is '_hashlib'. The sha3_512 constructor is an
# OpenSSL-backed C builtin from the _hashlib extension module. All SHA-3 and
# SHAKE constructors exposed through hashlib have __module__ == '_hashlib'.
# No prior hashlib spec anchors sha3_512.__module__.__eq__ as a standalone
# under hashlibsha3shake98. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra98.sha3_512_module:
  description: "hashlib.sha3_512.__module__.__eq__('_hashlib') == True — sha3_512 is an OpenSSL-backed C builtin from the _hashlib extension; its __module__ is '_hashlib' (not 'hashlib'), placing it in the C extension layer; no prior hashlib spec anchors this as a standalone; first standalone for sha3_512 __module__ under hashlibsha3shake98"
  category: type_identity
  kind: python_call_eq
  function: sha3_512.__module__.__eq__
  args: ["_hashlib"]
  expected: true
