spec: datetime_extra24
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
    - "datetime_extra21.zspec.zsdl — covers __module__.__len__() and __name__.__len__() for date/time/datetime/timedelta/timezone; date.today.__qualname__.__len__() and datetime.now.__qualname__.__len__()"
    - "datetime_extra22.zspec.zsdl — covers __qualname__.__len__() for date/time/datetime/timedelta/timezone/tzinfo; __module__.__len__() and __name__.__len__() for tzinfo; __qualname__.__len__() for datetime.fromisoformat/datetime.strptime/date.fromisoformat/timedelta.__repr__"
    - "datetime_extra23.zspec.zsdl — covers __mro__.__len__() for datetime/date/timedelta/timezone/tzinfo; __bases__[0].__name__ for datetime/timezone/date/timedelta/tzinfo; __qualname__.__len__() for datetime.utcnow/combine/isoformat and date.isoformat"
  notes:
    - "This spec extends datetime_extra23.zspec.zsdl."
    - "Prior specs covered: date/time/datetime/timedelta/timezone/tzinfo __name__/__module__/__qualname__, __module__.__len__() and __name__.__len__() for all six classes, __qualname__.__len__() for class names and key methods, __mro__.__len__() and __bases__[0].__name__ for all five main classes."
    - "This spec covers: datetime.__all__.__len__() and datetime.__all__.__class__.__name__; datetime.datetime.__dict__.__class__.__name__.__len__() (mappingproxy=12) for all five main classes; datetime.datetime.__reduce__.__name__.__len__() for date/datetime/timedelta/timezone; datetime.datetime.__init_subclass__.__qualname__.__len__() for date/datetime/timedelta/timezone/tzinfo; datetime.MINYEAR and datetime.MAXYEAR class names and values."
    - "datetime.__all__ == ('date', 'datetime', 'time', 'timedelta', 'timezone', 'tzinfo', 'MINYEAR', 'MAXYEAR', 'UTC') — len 9, class 'tuple'. Verified Python 3.12."
    - "datetime.__all__.__class__.__name__ == 'tuple' — __all__ is a tuple in datetime (unlike many other modules where it is a list). len('tuple') == 5. Verified Python 3.12."
    - "datetime.datetime.__dict__.__class__.__name__ == 'mappingproxy' — len 12. Same for date/timedelta/timezone/tzinfo. Verified Python 3.12."
    - "datetime.datetime.__reduce__.__name__ == '__reduce__' — len 10 (not 8; '__reduce__' has 10 chars including both dunder pairs). Same for date/timedelta/timezone. Verified Python 3.12."
    - "datetime.datetime.__init_subclass__.__qualname__ == 'datetime.__init_subclass__' — len 26. Verified Python 3.12."
    - "datetime.date.__init_subclass__.__qualname__ == 'date.__init_subclass__' — len 22. Verified Python 3.12."
    - "datetime.timedelta.__init_subclass__.__qualname__ == 'timedelta.__init_subclass__' — len 27. Verified Python 3.12."
    - "datetime.timezone.__init_subclass__.__qualname__ == 'timezone.__init_subclass__' — len 26. Verified Python 3.12."
    - "datetime.tzinfo.__init_subclass__.__qualname__ == 'tzinfo.__init_subclass__' — len 24. Verified Python 3.12."
    - "datetime.MINYEAR == 1, __class__.__name__ == 'int', len('int') == 3. Verified Python 3.12."
    - "datetime.MAXYEAR == 9999, __class__.__name__ == 'int', len('int') == 3. Verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# datetime.__all__.__len__() and __all__.__class__.__name__
#
# datetime.__all__ is a tuple (not a list) containing 9 public names:
#   ('date', 'datetime', 'time', 'timedelta', 'timezone', 'tzinfo',
#    'MINYEAR', 'MAXYEAR', 'UTC')
# __all__.__class__.__name__ == 'tuple' (len 5).
# No prior datetime spec checks __all__.__len__() or __all__.__class__.__name__.
# ---------------------------------------------------------------------------

invariant datetime_extra24.all.len:
  description: "datetime.__all__.__len__() == 9 — nine public names exported: date, datetime, time, timedelta, timezone, tzinfo, MINYEAR, MAXYEAR, UTC"
  category: module_identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 9

invariant datetime_extra24.all.class_name_len:
  description: "datetime.__all__.__class__.__name__.__len__() == 5 — __all__ is a tuple (len('tuple') == 5); datetime uses a tuple unlike most modules that use a list"
  category: module_identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# SomeClass.__dict__.__class__.__name__.__len__() == 12 for all five main
# datetime classes — 'mappingproxy' always has 12 characters
#
# Every Python class exposes its namespace through __dict__, which is a
# types.MappingProxyType. Its __class__.__name__ is 'mappingproxy' (len 12).
# No prior datetime spec checks __dict__.__class__.__name__.__len__() for any
# datetime class.
# ---------------------------------------------------------------------------

table datetime_extra24.class_dict_proxy_name_len:
  description: "SomeClass.__dict__.__class__.__name__.__len__() == 12 for all five datetime classes — 'mappingproxy' has 12 characters"
  kind: python_call_eq
  category: class_introspection
  id_prefix: dmp24

  columns: [id, function, args, expected]
  rows:
    - [date,      date.__dict__.__class__.__name__.__len__,      [], 12]
    - [datetime,  datetime.__dict__.__class__.__name__.__len__,  [], 12]
    - [timedelta, timedelta.__dict__.__class__.__name__.__len__, [], 12]
    - [timezone,  timezone.__dict__.__class__.__name__.__len__,  [], 12]
    - [tzinfo,    tzinfo.__dict__.__class__.__name__.__len__,    [], 12]

# ---------------------------------------------------------------------------
# SomeClass.__reduce__.__name__.__len__() == 10 for date, datetime, timedelta,
# timezone — '__reduce__' always has 10 characters
#
# '__reduce__' is the dunder method name string: 2 leading underscores + 'reduce'
# + 2 trailing underscores = 2+6+2 = 10 characters. This is the inherited
# slot wrapper from object. No prior datetime spec checks __reduce__.__name__
# for any datetime class.
# ---------------------------------------------------------------------------

table datetime_extra24.class_reduce_name_len:
  description: "SomeClass.__reduce__.__name__.__len__() == 10 for date, datetime, timedelta, timezone — '__reduce__' has 10 characters"
  kind: python_call_eq
  category: class_introspection
  id_prefix: drn24

  columns: [id, function, args, expected]
  rows:
    - [date,      date.__reduce__.__name__.__len__,      [], 10]
    - [datetime,  datetime.__reduce__.__name__.__len__,  [], 10]
    - [timedelta, timedelta.__reduce__.__name__.__len__, [], 10]
    - [timezone,  timezone.__reduce__.__name__.__len__,  [], 10]

# ---------------------------------------------------------------------------
# SomeClass.__init_subclass__.__qualname__.__len__() for all five datetime
# classes
#
# __init_subclass__ is a class method inherited from object (unless overridden).
# Its qualname takes the form 'ClassName.__init_subclass__', so the length is
# len(class_name) + len('.__init_subclass__') = len(class_name) + 18.
#   date     -> 'date.__init_subclass__'     -> 4  + 18 = 22
#   tzinfo   -> 'tzinfo.__init_subclass__'   -> 6  + 18 = 24
#   datetime -> 'datetime.__init_subclass__' -> 8  + 18 = 26
#   timezone -> 'timezone.__init_subclass__' -> 8  + 18 = 26
#   timedelta-> 'timedelta.__init_subclass__'-> 9  + 18 = 27
# No prior datetime spec checks __init_subclass__.__qualname__.__len__() for any
# datetime class.
# ---------------------------------------------------------------------------

invariant datetime_extra24.date.init_subclass_qualname_len:
  description: "datetime.date.__init_subclass__.__qualname__.__len__() == 22 — 'date.__init_subclass__' has 22 characters"
  category: class_introspection
  kind: python_call_eq
  function: date.__init_subclass__.__qualname__.__len__
  args: []
  expected: 22

invariant datetime_extra24.tzinfo.init_subclass_qualname_len:
  description: "datetime.tzinfo.__init_subclass__.__qualname__.__len__() == 24 — 'tzinfo.__init_subclass__' has 24 characters"
  category: class_introspection
  kind: python_call_eq
  function: tzinfo.__init_subclass__.__qualname__.__len__
  args: []
  expected: 24

table datetime_extra24.class_init_subclass_qualname_lens:
  description: "__init_subclass__.__qualname__.__len__() for datetime (26), timezone (26), timedelta (27) — novel invariants"
  kind: python_call_eq
  category: class_introspection
  id_prefix: dis24

  columns: [id, function, args, expected]
  rows:
    - [datetime,  datetime.__init_subclass__.__qualname__.__len__,  [], 26]
    - [timezone,  timezone.__init_subclass__.__qualname__.__len__,  [], 26]
    - [timedelta, timedelta.__init_subclass__.__qualname__.__len__, [], 27]

# ---------------------------------------------------------------------------
# datetime.MINYEAR and datetime.MAXYEAR — type and value
#
# MINYEAR == 1, MAXYEAR == 9999; both are plain Python int instances.
# __class__.__name__ == 'int' for both (len 3).
# No prior datetime spec checks MINYEAR or MAXYEAR class names.
# ---------------------------------------------------------------------------

invariant datetime_extra24.MINYEAR.class_name_len:
  description: "datetime.MINYEAR.__class__.__name__.__len__() == 3 — MINYEAR is an int; len('int') == 3"
  category: constants
  kind: python_call_eq
  function: MINYEAR.__class__.__name__.__len__
  args: []
  expected: 3

invariant datetime_extra24.MAXYEAR.class_name_len:
  description: "datetime.MAXYEAR.__class__.__name__.__len__() == 3 — MAXYEAR is an int; len('int') == 3"
  category: constants
  kind: python_call_eq
  function: MAXYEAR.__class__.__name__.__len__
  args: []
  expected: 3
