spec: inspect_extra289
version: ">=3.11"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module function identity attributes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "getmembers_static was added in Python 3.11"
    - "All functions in this spec have __module__ == 'inspect'"
    - "All functions are plain Python functions with matching __qualname__ and __name__"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table inspect_extra289.qualnames:
  description: "__qualname__ for inspect introspection functions"
  kind: python_call_eq
  category: identity
  id_prefix: ine289q

  columns: [id, function, args, expected, description]
  rows:
    - [ine289q001, inspect.getmembers.__qualname__.__eq__, ["getmembers"], true, "getmembers qualname"]
    - [ine289q002, inspect.getmembers_static.__qualname__.__eq__, ["getmembers_static"], true, "getmembers_static qualname (3.11+)"]
    - [ine289q003, inspect.classify_class_attrs.__qualname__.__eq__, ["classify_class_attrs"], true, "classify_class_attrs qualname"]
    - [ine289q004, inspect.getattr_static.__qualname__.__eq__, ["getattr_static"], true, "getattr_static qualname"]
    - [ine289q005, inspect.isabstract.__qualname__.__eq__, ["isabstract"], true, "isabstract qualname"]
    - [ine289q006, inspect.isroutine.__qualname__.__eq__, ["isroutine"], true, "isroutine qualname"]
    - [ine289q007, inspect.isdatadescriptor.__qualname__.__eq__, ["isdatadescriptor"], true, "isdatadescriptor qualname"]
    - [ine289q008, inspect.ismethoddescriptor.__qualname__.__eq__, ["ismethoddescriptor"], true, "ismethoddescriptor qualname"]

table inspect_extra289.modules:
  description: "__module__ for inspect introspection functions (all 'inspect')"
  kind: python_call_eq
  category: identity
  id_prefix: ine289m

  columns: [id, function, args, expected, description]
  rows:
    - [ine289m001, inspect.getmembers.__module__.__eq__, ["inspect"], true, "getmembers module"]
    - [ine289m002, inspect.getmembers_static.__module__.__eq__, ["inspect"], true, "getmembers_static module"]
    - [ine289m003, inspect.classify_class_attrs.__module__.__eq__, ["inspect"], true, "classify_class_attrs module"]
    - [ine289m004, inspect.getattr_static.__module__.__eq__, ["inspect"], true, "getattr_static module"]
    - [ine289m005, inspect.isabstract.__module__.__eq__, ["inspect"], true, "isabstract module"]
    - [ine289m006, inspect.isroutine.__module__.__eq__, ["inspect"], true, "isroutine module"]
    - [ine289m007, inspect.isdatadescriptor.__module__.__eq__, ["inspect"], true, "isdatadescriptor module"]
    - [ine289m008, inspect.ismethoddescriptor.__module__.__eq__, ["inspect"], true, "ismethoddescriptor module"]

invariant inspect_extra289.unwrap_qualname:
  description: "unwrap __qualname__ confirmed"
  category: identity
  kind: python_call_eq
  function: inspect.unwrap.__qualname__.__eq__
  args: ["unwrap"]
  expected: true

invariant inspect_extra289.unwrap_module:
  description: "unwrap __module__ is inspect"
  category: identity
  kind: python_call_eq
  function: inspect.unwrap.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra289.isgetsetdescriptor_qualname:
  description: "isgetsetdescriptor __qualname__ confirmed"
  category: identity
  kind: python_call_eq
  function: inspect.isgetsetdescriptor.__qualname__.__eq__
  args: ["isgetsetdescriptor"]
  expected: true

invariant inspect_extra289.ismemberdescriptor_qualname:
  description: "ismemberdescriptor __qualname__ confirmed"
  category: identity
  kind: python_call_eq
  function: inspect.ismemberdescriptor.__qualname__.__eq__
  args: ["ismemberdescriptor"]
  expected: true

invariant inspect_extra289.isgetsetdescriptor_module:
  description: "isgetsetdescriptor __module__ is inspect"
  category: identity
  kind: python_call_eq
  function: inspect.isgetsetdescriptor.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra289.ismemberdescriptor_module:
  description: "ismemberdescriptor __module__ is inspect"
  category: identity
  kind: python_call_eq
  function: inspect.ismemberdescriptor.__module__.__eq__
  args: ["inspect"]
  expected: true
