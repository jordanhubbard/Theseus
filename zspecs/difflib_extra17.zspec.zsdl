spec: difflib_extra17
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec extends difflib.zspec.zsdl and prior extras through difflib_extra16.zspec.zsdl."
    - "difflib_extra3 covers: unified_diff/__qualname__; context_diff/__qualname__; ndiff/__qualname__; SequenceMatcher/__qualname__; Differ/__qualname__; HtmlDiff/__qualname__."
    - "difflib_extra11 covers: unified_diff/__qualname__; get_close_matches/__qualname__ as standalone invariants."
    - "difflib_extra8 covers: context_diff/__qualname__; IS_LINE_JUNK/__qualname__."
    - "difflib_extra16 covers: SequenceMatcher/Differ/HtmlDiff __qualname__.__len__(); unified_diff/context_diff/ndiff/get_close_matches __qualname__.__len__()."
    - "No prior spec covers difflib.SequenceMatcher.ratio.__qualname__ or difflib.SequenceMatcher.get_matching_blocks.__qualname__ as method qualnames."
    - "No prior spec covers difflib.Differ.compare.__qualname__ or difflib.HtmlDiff.make_file.__qualname__ as method qualnames."
    - "difflib.unified_diff.__qualname__ == 'unified_diff' — module-level function. Verified at runtime."
    - "difflib.context_diff.__qualname__ == 'context_diff' — module-level function. Verified at runtime."
    - "difflib.ndiff.__qualname__ == 'ndiff' — module-level function. Verified at runtime."
    - "difflib.get_close_matches.__qualname__ == 'get_close_matches' — module-level function. Verified at runtime."
    - "difflib.SequenceMatcher.ratio.__qualname__ == 'SequenceMatcher.ratio' — method qualname includes owning class. Verified at runtime."
    - "difflib.SequenceMatcher.get_matching_blocks.__qualname__ == 'SequenceMatcher.get_matching_blocks' — method qualname includes owning class. Verified at runtime."
    - "difflib.Differ.compare.__qualname__ == 'Differ.compare' — method qualname includes owning class. Verified at runtime."
    - "difflib.HtmlDiff.make_file.__qualname__ == 'HtmlDiff.make_file' — method qualname includes owning class. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# difflib.unified_diff — __qualname__ (extra17 namespace anchor)
#
# difflib_extra3/extra11 cover unified_diff.__qualname__ == 'unified_diff'.
# Re-anchored here as a named standalone invariant in the extra17 namespace.
# Verified at runtime: 'unified_diff'.
# ---------------------------------------------------------------------------

invariant difflib_extra17.unified_diff.qualname:
  description: "difflib.unified_diff.__qualname__ == 'unified_diff' — module-level function qualname equals its simple name"
  category: function_identity
  kind: python_call_eq
  function: unified_diff.__qualname__.__eq__
  args: ["unified_diff"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.context_diff — __qualname__ (extra17 namespace anchor)
#
# difflib_extra3/extra8 cover context_diff.__qualname__ == 'context_diff'.
# Re-anchored here as a named standalone invariant in the extra17 namespace.
# Verified at runtime: 'context_diff'.
# ---------------------------------------------------------------------------

invariant difflib_extra17.context_diff.qualname:
  description: "difflib.context_diff.__qualname__ == 'context_diff' — module-level function qualname equals its simple name"
  category: function_identity
  kind: python_call_eq
  function: context_diff.__qualname__.__eq__
  args: ["context_diff"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.ndiff — __qualname__ (extra17 namespace anchor)
#
# difflib_extra3 covers ndiff.__qualname__ == 'ndiff'. Re-anchored here.
# Verified at runtime: 'ndiff'.
# ---------------------------------------------------------------------------

invariant difflib_extra17.ndiff.qualname:
  description: "difflib.ndiff.__qualname__ == 'ndiff' — module-level function qualname equals its simple name"
  category: function_identity
  kind: python_call_eq
  function: ndiff.__qualname__.__eq__
  args: ["ndiff"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.get_close_matches — __qualname__ (extra17 namespace anchor)
#
# difflib_extra11 covers get_close_matches.__qualname__ == 'get_close_matches'.
# Re-anchored here as a named standalone invariant in the extra17 namespace.
# Verified at runtime: 'get_close_matches'.
# ---------------------------------------------------------------------------

invariant difflib_extra17.get_close_matches.qualname:
  description: "difflib.get_close_matches.__qualname__ == 'get_close_matches' — module-level function qualname equals its simple name"
  category: function_identity
  kind: python_call_eq
  function: get_close_matches.__qualname__.__eq__
  args: ["get_close_matches"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.SequenceMatcher.ratio — __qualname__
#
# No prior spec verifies SequenceMatcher.ratio.__qualname__. For a method
# defined in class SequenceMatcher, __qualname__ takes the form
# 'SequenceMatcher.ratio'. Verified at runtime: 'SequenceMatcher.ratio'.
# ---------------------------------------------------------------------------

invariant difflib_extra17.SequenceMatcher.ratio_qualname:
  description: "difflib.SequenceMatcher.ratio.__qualname__ == 'SequenceMatcher.ratio' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: SequenceMatcher.ratio.__qualname__.__eq__
  args: ["SequenceMatcher.ratio"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.SequenceMatcher.get_matching_blocks — __qualname__
#
# No prior spec verifies SequenceMatcher.get_matching_blocks.__qualname__. For
# a method in class SequenceMatcher, __qualname__ is
# 'SequenceMatcher.get_matching_blocks'.
# Verified at runtime: 'SequenceMatcher.get_matching_blocks'.
# ---------------------------------------------------------------------------

invariant difflib_extra17.SequenceMatcher.get_matching_blocks_qualname:
  description: "difflib.SequenceMatcher.get_matching_blocks.__qualname__ == 'SequenceMatcher.get_matching_blocks' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: SequenceMatcher.get_matching_blocks.__qualname__.__eq__
  args: ["SequenceMatcher.get_matching_blocks"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.Differ.compare — __qualname__
#
# No prior spec verifies Differ.compare.__qualname__. For a method defined in
# class Differ, __qualname__ takes the form 'Differ.compare'.
# Verified at runtime: 'Differ.compare'.
# ---------------------------------------------------------------------------

invariant difflib_extra17.Differ.compare_qualname:
  description: "difflib.Differ.compare.__qualname__ == 'Differ.compare' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Differ.compare.__qualname__.__eq__
  args: ["Differ.compare"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.HtmlDiff.make_file — __qualname__
#
# No prior spec verifies HtmlDiff.make_file.__qualname__. For a method defined
# in class HtmlDiff, __qualname__ takes the form 'HtmlDiff.make_file'.
# Verified at runtime: 'HtmlDiff.make_file'.
# ---------------------------------------------------------------------------

invariant difflib_extra17.HtmlDiff.make_file_qualname:
  description: "difflib.HtmlDiff.make_file.__qualname__ == 'HtmlDiff.make_file' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: HtmlDiff.make_file.__qualname__.__eq__
  args: ["HtmlDiff.make_file"]
  expected: true

# ---------------------------------------------------------------------------
# Table: consolidated difflib function and method __qualname__ values
#
# Groups all eight __qualname__ checks from this spec into a single table:
# four module-level functions (unified_diff, context_diff, ndiff,
# get_close_matches) and four class methods (SequenceMatcher.ratio,
# SequenceMatcher.get_matching_blocks, Differ.compare, HtmlDiff.make_file).
# All values verified at runtime.
# ---------------------------------------------------------------------------

table difflib_extra17.qualnames:
  description: "difflib function and method __qualname__ values — four module-level functions and four class methods"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [unified_diff,
       unified_diff.__qualname__.__eq__,
       ["unified_diff"],
       true,
       "unified_diff.__qualname__ == 'unified_diff'"]
    - [context_diff,
       context_diff.__qualname__.__eq__,
       ["context_diff"],
       true,
       "context_diff.__qualname__ == 'context_diff'"]
    - [ndiff,
       ndiff.__qualname__.__eq__,
       ["ndiff"],
       true,
       "ndiff.__qualname__ == 'ndiff'"]
    - [get_close_matches,
       get_close_matches.__qualname__.__eq__,
       ["get_close_matches"],
       true,
       "get_close_matches.__qualname__ == 'get_close_matches'"]
    - [SequenceMatcher_ratio,
       SequenceMatcher.ratio.__qualname__.__eq__,
       ["SequenceMatcher.ratio"],
       true,
       "SequenceMatcher.ratio.__qualname__ == 'SequenceMatcher.ratio'"]
    - [SequenceMatcher_get_matching_blocks,
       SequenceMatcher.get_matching_blocks.__qualname__.__eq__,
       ["SequenceMatcher.get_matching_blocks"],
       true,
       "SequenceMatcher.get_matching_blocks.__qualname__ == 'SequenceMatcher.get_matching_blocks'"]
    - [Differ_compare,
       Differ.compare.__qualname__.__eq__,
       ["Differ.compare"],
       true,
       "Differ.compare.__qualname__ == 'Differ.compare'"]
    - [HtmlDiff_make_file,
       HtmlDiff.make_file.__qualname__.__eq__,
       ["HtmlDiff.make_file"],
       true,
       "HtmlDiff.make_file.__qualname__ == 'HtmlDiff.make_file'"]
