spec: uuid_extra1711
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 561 (_extra1711): __init__ protocol dict-presence checks."
    - "uuid.UUID is a pure Python class with __slots__; defines both __init__ and __new__."
    - "uuid.SafeUUID is an IntEnum subclass; defines neither __init__ nor __new__ in own dict."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra1711.init_protocol:
  description: "uuid types __init__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1711

  columns: [id, function, args, expected]
  rows:
    - ["uu1711001", "uuid.UUID.__dict__.__contains__", ["__init__"], true]
    - ["uu1711002", "uuid.UUID.__dict__.__contains__", ["__new__"],  true]
    - ["uu1711003", "uuid.SafeUUID.__dict__.__contains__", ["__init__"], false]
    - ["uu1711004", "uuid.SafeUUID.__dict__.__contains__", ["__new__"],  false]
    - ["uu1711005", "uuid.UUID.__dict__.__contains__", ["__slots__"], true]
    - ["uu1711006", "uuid.UUID.__dict__.__contains__", ["__hash__"],  true]
    - ["uu1711007", "uuid.UUID.__dict__.__contains__", ["__eq__"],    true]
    - ["uu1711008", "uuid.UUID.__dict__.__contains__", ["__str__"],   true]
    - ["uu1711009", "uuid.UUID.__dict__.__contains__", ["__repr__"],  true]
    - ["uu1711010", "uuid.UUID.__dict__.__contains__", ["__int__"],   true]
    - ["uu1711011", "uuid.UUID.__dict__.__contains__", ["__lt__"],    true]
    - ["uu1711012", "uuid.UUID.__dict__.__contains__", ["__call__"],  false]
    - ["uu1711013", "uuid.UUID.__dict__.__contains__", ["int"],       true]
    - ["uu1711014", "uuid.UUID.__dict__.__contains__", ["hex"],       true]
    - ["uu1711015", "uuid.UUID.__dict__.__contains__", ["version"],   true]
    - ["uu1711016", "uuid.UUID.__dict__.__contains__", ["bytes"],     true]
    - ["uu1711017", "uuid.UUID.__dict__.__contains__", ["urn"],       true]
    - ["uu1711018", "uuid.UUID.__dict__.__contains__", ["variant"],   true]

table uuid_extra1711.type_identity:
  description: "uuid type identity checks"
  kind: python_call_eq
  category: str_repr
  id_prefix: uu1711

  columns: [id, function, args, expected]
  rows:
    - ["uu1711019", "uuid.UUID.__name__",      [], "UUID"]
    - ["uu1711020", "uuid.UUID.__module__",    [], "uuid"]
    - ["uu1711021", "uuid.SafeUUID.__name__",  [], "SafeUUID"]
    - ["uu1711022", "uuid.SafeUUID.__module__", [], "uuid"]
    - ["uu1711023", "uuid.NAMESPACE_DNS.__class__.__name__", [], "UUID"]
    - ["uu1711024", "uuid.NAMESPACE_URL.__class__.__name__", [], "UUID"]
    - ["uu1711025", "uuid.NAMESPACE_OID.__class__.__name__", [], "UUID"]
    - ["uu1711026", "uuid.NAMESPACE_X500.__class__.__name__", [], "UUID"]

table uuid_extra1711.safeuuid_values:
  description: "uuid.SafeUUID enum values"
  kind: python_call_eq
  category: constants
  id_prefix: uu1711

  columns: [id, function, args, expected]
  rows:
    - ["uu1711027", "uuid.SafeUUID.safe.__class__.__name__",   [], "SafeUUID"]
    - ["uu1711028", "uuid.SafeUUID.unsafe.__class__.__name__", [], "SafeUUID"]
    - ["uu1711029", "uuid.SafeUUID.safe.__int__",   [], 0]
    - ["uu1711030", "uuid.SafeUUID.unsafe.__int__", [], -1]
