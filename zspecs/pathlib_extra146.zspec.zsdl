spec: pathlib_extra146
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib module-level identity (__name__, __package__, __spec__.__class__.__name__, __spec__.name), pathlib.Path.__doc__ and pathlib.PurePath.__doc__ class and length, pathlib.PurePosixPath and pathlib.PureWindowsPath class identity and MRO."
    - "pathlib.__name__ == 'pathlib' (length 7); pathlib.__package__ == 'pathlib' (length 7)."
    - "pathlib.__spec__.__class__.__name__ == 'ModuleSpec' (length 10); pathlib.__spec__.name == 'pathlib' (length 7)."
    - "pathlib.Path.__doc__.__class__.__name__ == 'str'; len(pathlib.Path.__doc__) == 393."
    - "pathlib.PurePath.__doc__.__class__.__name__ == 'str'; len(pathlib.PurePath.__doc__) == 356."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath' (13); __module__ == 'pathlib' (7); MRO length 3."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' (15); __module__ == 'pathlib' (7); MRO length 3."
    - "PurePosixPath and PureWindowsPath both have a single base: PurePath."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib module-level identity
# pathlib.__name__ == 'pathlib' (7), pathlib.__package__ == 'pathlib' (7).
# pathlib.__spec__.__class__.__name__ == 'ModuleSpec' (10).
# pathlib.__spec__.name == 'pathlib' (7).
# ---------------------------------------------------------------------------

table pathlib_extra146.module_identity:
  description: "pathlib module identity: __name__='pathlib' (7), __package__='pathlib' (7), __spec__.__class__.__name__='ModuleSpec' (10), __spec__.name='pathlib' (7)"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibmod146

  columns: [id, function, args, expected]
  rows:
    - [mod_name_eq,       __name__.__eq__,                        ["pathlib"],    true]
    - [mod_name_len,      __name__.__len__,                       [],             7]
    - [mod_pkg_eq,        __package__.__eq__,                     ["pathlib"],    true]
    - [mod_pkg_len,       __package__.__len__,                    [],             7]
    - [spec_cls_eq,       __spec__.__class__.__name__.__eq__,     ["ModuleSpec"], true]
    - [spec_cls_len,      __spec__.__class__.__name__.__len__,    [],             10]
    - [spec_name_eq,      __spec__.name.__eq__,                   ["pathlib"],    true]
    - [spec_name_len,     __spec__.name.__len__,                  [],             7]

# ---------------------------------------------------------------------------
# pathlib.Path.__doc__ and pathlib.PurePath.__doc__ identity
# Both __doc__ attributes are str instances.
# Path.__doc__ length == 393; PurePath.__doc__ length == 356.
# ---------------------------------------------------------------------------

table pathlib_extra146.Path_PurePath_doc_identity:
  description: "pathlib.Path.__doc__ and PurePath.__doc__ are str instances; Path.__doc__ length=393, PurePath.__doc__ length=356"
  kind: python_call_eq
  category: doc_identity
  id_prefix: pathlibdoc146

  columns: [id, function, args, expected]
  rows:
    - [path_doc_cls_eq,    Path.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [path_doc_len,       Path.__doc__.__len__,                      [],      393]
    - [pure_doc_cls_eq,    PurePath.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [pure_doc_len,       PurePath.__doc__.__len__,                  [],      356]

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath class identity and MRO
# __name__ == 'PurePosixPath' (13), __module__ == 'pathlib' (7),
# __qualname__ == 'PurePosixPath' (13), __class__.__name__ == 'type'.
# __bases__[0].__name__ == 'PurePath'; MRO length == 3.
# MRO: (PurePosixPath, PurePath, object).
# ---------------------------------------------------------------------------

table pathlib_extra146.PurePosixPath_identity_mro:
  description: "pathlib.PurePosixPath class identity: __name__='PurePosixPath' (13), __module__='pathlib' (7), __class__.__name__='type'; MRO length 3 — PurePosixPath, PurePath, object"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibppp146

  columns: [id, function, args, expected]
  rows:
    - [ppp_name_eq,      PurePosixPath.__name__.__eq__,           ["PurePosixPath"], true]
    - [ppp_name_len,     PurePosixPath.__name__.__len__,          [],                13]
    - [ppp_module_eq,    PurePosixPath.__module__.__eq__,         ["pathlib"],       true]
    - [ppp_module_len,   PurePosixPath.__module__.__len__,        [],                7]
    - [ppp_qualname_eq,  PurePosixPath.__qualname__.__eq__,       ["PurePosixPath"], true]
    - [ppp_cls_eq,       PurePosixPath.__class__.__name__.__eq__, ["type"],          true]
    - [ppp_base0_eq,     "PurePosixPath.__bases__[0].__name__.__eq__", ["PurePath"],   true]
    - [ppp_mro_len,      "PurePosixPath.__mro__.__len__",         [],                3]
    - [ppp_mro0_eq,      "PurePosixPath.__mro__[0].__name__.__eq__", ["PurePosixPath"], true]
    - [ppp_mro1_eq,      "PurePosixPath.__mro__[1].__name__.__eq__", ["PurePath"],   true]
    - [ppp_mro2_eq,      "PurePosixPath.__mro__[2].__name__.__eq__", ["object"],     true]

# ---------------------------------------------------------------------------
# pathlib.PureWindowsPath class identity and MRO
# __name__ == 'PureWindowsPath' (15), __module__ == 'pathlib' (7),
# __qualname__ == 'PureWindowsPath' (15), __class__.__name__ == 'type'.
# __bases__[0].__name__ == 'PurePath'; MRO length == 3.
# MRO: (PureWindowsPath, PurePath, object).
# ---------------------------------------------------------------------------

table pathlib_extra146.PureWindowsPath_identity_mro:
  description: "pathlib.PureWindowsPath class identity: __name__='PureWindowsPath' (15), __module__='pathlib' (7), __class__.__name__='type'; MRO length 3 — PureWindowsPath, PurePath, object"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibpwp146

  columns: [id, function, args, expected]
  rows:
    - [pwp_name_eq,      PureWindowsPath.__name__.__eq__,           ["PureWindowsPath"], true]
    - [pwp_name_len,     PureWindowsPath.__name__.__len__,          [],                  15]
    - [pwp_module_eq,    PureWindowsPath.__module__.__eq__,         ["pathlib"],         true]
    - [pwp_module_len,   PureWindowsPath.__module__.__len__,        [],                  7]
    - [pwp_qualname_eq,  PureWindowsPath.__qualname__.__eq__,       ["PureWindowsPath"], true]
    - [pwp_cls_eq,       PureWindowsPath.__class__.__name__.__eq__, ["type"],            true]
    - [pwp_base0_eq,     "PureWindowsPath.__bases__[0].__name__.__eq__", ["PurePath"],     true]
    - [pwp_mro_len,      "PureWindowsPath.__mro__.__len__",         [],                  3]
    - [pwp_mro0_eq,      "PureWindowsPath.__mro__[0].__name__.__eq__", ["PureWindowsPath"], true]
    - [pwp_mro1_eq,      "PureWindowsPath.__mro__[1].__name__.__eq__", ["PurePath"],     true]
    - [pwp_mro2_eq,      "PureWindowsPath.__mro__[2].__name__.__eq__", ["object"],       true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra146.module.spec_class_is_ModuleSpec:
  description: "pathlib.__spec__.__class__.__name__ == 'ModuleSpec' (length 10; the module spec records loader, origin, and submodule search locations; all stdlib Python modules have a ModuleSpec)"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant pathlib_extra146.Path.doc_len_393:
  description: "pathlib.Path.__doc__.__len__() == 393 (Path has a 393-character docstring; it is longer than PurePath.__doc__ (356) because Path adds concrete filesystem-access methods beyond pure path manipulation)"
  category: doc_identity
  kind: python_call_eq
  function: Path.__doc__.__len__
  args: []
  expected: 393

invariant pathlib_extra146.PurePath.doc_len_356:
  description: "pathlib.PurePath.__doc__.__len__() == 356 (PurePath has a 356-character docstring; shorter than Path.__doc__ (393) because PurePath covers only path string manipulation without filesystem access)"
  category: doc_identity
  kind: python_call_eq
  function: PurePath.__doc__.__len__
  args: []
  expected: 356

invariant pathlib_extra146.PurePosixPath.name_len_13:
  description: "pathlib.PurePosixPath.__name__.__len__() == 13 ('PurePosixPath' has 13 characters; shorter than PureWindowsPath (15) by 2 — 'Posix' vs 'Windows')"
  category: class_identity
  kind: python_call_eq
  function: PurePosixPath.__name__.__len__
  args: []
  expected: 13

invariant pathlib_extra146.PureWindowsPath.name_len_15:
  description: "pathlib.PureWindowsPath.__name__.__len__() == 15 ('PureWindowsPath' has 15 characters; the longest name among the four pathlib Pure* classes)"
  category: class_identity
  kind: python_call_eq
  function: PureWindowsPath.__name__.__len__
  args: []
  expected: 15

invariant pathlib_extra146.PurePosixPath.mro_len_3:
  description: "pathlib.PurePosixPath.__mro__.__len__() == 3 (MRO is: PurePosixPath, PurePath, object — three entries; PurePosixPath has a single base PurePath, making it shallower than the concrete Path (MRO length 3) or PosixPath (MRO length 5))"
  category: class_identity
  kind: python_call_eq
  function: "PurePosixPath.__mro__.__len__"
  args: []
  expected: 3
