spec: logging_extra2
version: ">=3.2"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "Python 3 logging documentation — https://docs.python.org/3/library/logging.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
    - "logging.zspec.zsdl — covers level ordering and reverse getLevelName lookups"
    - "logging_extra.zspec.zsdl — covers level constants, Logger/Handler/Formatter/Filter/LogRecord/Manager names"
    - "logging_config.zspec.zsdl — covers logging.config classes and dictConfig/fileConfig"
    - "logging_handlers.zspec.zsdl — covers logging.handlers submodule classes and port constants"
    - "logging_nullhandler.zspec.zsdl — covers NullHandler, inheritance chains, and __module__ checks"
  notes:
    - "StreamHandler is defined in logging/__init__.py and its __name__ is 'StreamHandler'."
    - "FileHandler is also defined in the core logging package; __name__ is 'FileHandler'."
    - "logging.DEBUG=10, INFO=20, WARNING=30, ERROR=40, CRITICAL=50 verified via __eq__ on the int objects."
    - "StreamHandler.__module__ and FileHandler.__module__ are both 'logging'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ checks — StreamHandler and FileHandler
# ---------------------------------------------------------------------------

table logging_extra2.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [streamhandler, StreamHandler.__name__.__eq__, ["StreamHandler"], true]
    - [filehandler,   FileHandler.__name__.__eq__,   ["FileHandler"],   true]

# ---------------------------------------------------------------------------
# Class __module__ checks — StreamHandler and FileHandler
# ---------------------------------------------------------------------------

table logging_extra2.class_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [streamhandler, StreamHandler.__module__.__eq__, ["logging"], true]
    - [filehandler,   FileHandler.__module__.__eq__,   ["logging"], true]

# ---------------------------------------------------------------------------
# Level constant integer equality checks
# ---------------------------------------------------------------------------

invariant logging_extra2.level.debug:
  description: "logging.DEBUG == 10"
  category: level_int
  kind: python_call_eq
  function: DEBUG.__eq__
  args: [10]
  expected: true

invariant logging_extra2.level.info:
  description: "logging.INFO == 20"
  category: level_int
  kind: python_call_eq
  function: INFO.__eq__
  args: [20]
  expected: true

invariant logging_extra2.level.warning:
  description: "logging.WARNING == 30"
  category: level_int
  kind: python_call_eq
  function: WARNING.__eq__
  args: [30]
  expected: true

invariant logging_extra2.level.error:
  description: "logging.ERROR == 40"
  category: level_int
  kind: python_call_eq
  function: ERROR.__eq__
  args: [40]
  expected: true

invariant logging_extra2.level.critical:
  description: "logging.CRITICAL == 50"
  category: level_int
  kind: python_call_eq
  function: CRITICAL.__eq__
  args: [50]
  expected: true

# ---------------------------------------------------------------------------
# Additional function __name__ checks
# ---------------------------------------------------------------------------

table logging_extra2.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [basicConfig,      basicConfig.__name__.__eq__,      ["basicConfig"],      true]
    - [makeLogRecord,    makeLogRecord.__name__.__eq__,    ["makeLogRecord"],    true]
    - [captureWarnings,  captureWarnings.__name__.__eq__,  ["captureWarnings"],  true]
    - [disable,          disable.__name__.__eq__,          ["disable"],          true]
    - [addLevelName,     addLevelName.__name__.__eq__,     ["addLevelName"],     true]
