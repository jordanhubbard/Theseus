spec: concurrent_futures_extra2206
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
    - "concurrent_futures.zspec.zsdl"
    - "concurrent_futures_extra.zspec.zsdl"
    - "concurrent_futures_extra2.zspec.zsdl"
  notes:
    - "Wave _extra2206: rich comparison operator protocol dict-presence checks for concurrent.futures classes."
    - "Covers __lt__, __le__, __gt__, __ge__, __eq__, __ne__ presence in Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor class dicts."
    - "concurrent.futures.Future does not define any comparison operators in its own __dict__; it uses object identity semantics inherited from object."
    - "concurrent.futures.Executor is an abstract base class; it defines no comparison operators."
    - "ThreadPoolExecutor and ProcessPoolExecutor inherit from Executor; neither defines comparison operators in their own class dicts."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra2206.Future_comparison_protocol:
  description: "concurrent.futures.Future __lt__/__le__/__gt__/__ge__/__eq__/__ne__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2206

  columns: [id, function, args, expected]
  rows:
    - ["cf2206001", "concurrent.futures.Future.__dict__.__contains__", ["__lt__"], false]
    - ["cf2206002", "concurrent.futures.Future.__dict__.__contains__", ["__le__"], false]
    - ["cf2206003", "concurrent.futures.Future.__dict__.__contains__", ["__gt__"], false]
    - ["cf2206004", "concurrent.futures.Future.__dict__.__contains__", ["__ge__"], false]
    - ["cf2206005", "concurrent.futures.Future.__dict__.__contains__", ["__eq__"], false]
    - ["cf2206006", "concurrent.futures.Future.__dict__.__contains__", ["__ne__"], false]

