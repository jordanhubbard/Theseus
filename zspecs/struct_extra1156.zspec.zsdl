spec: struct_extra1156
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.pack_into/unpack_from/iter_unpack __module__/__qualname__/__class__.__name__, struct.Struct.__class__ type attrs, struct.Struct.pack/unpack method_descriptor qualname and class name, struct.Struct.__init__ wrapper_descriptor attrs, struct.error __class__ type attrs and module"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1156.pack_into_unpack_from_iter_unpack_attrs:
  description: "struct.pack_into, unpack_from, iter_unpack __module__/__qualname__/__class__.__name__ identity"
  kind: python_call_eq
  category: pack_into_unpack_from_iter_unpack_attrs
  id_prefix: st1156pu
  columns: [id, function, args, expected]
  rows:
    - [st1156pu001, struct.pack_into.__module__.__eq__,                         ["_struct"],                     true]
    - [st1156pu002, struct.unpack_from.__module__.__eq__,                       ["_struct"],                     true]
    - [st1156pu003, struct.iter_unpack.__module__.__eq__,                       ["_struct"],                     true]
    - [st1156pu004, struct.pack_into.__qualname__.__eq__,                       ["pack_into"],                   true]
    - [st1156pu005, struct.unpack_from.__qualname__.__eq__,                     ["unpack_from"],                 true]
    - [st1156pu006, struct.iter_unpack.__qualname__.__eq__,                     ["iter_unpack"],                 true]
    - [st1156pu007, struct.pack_into.__class__.__name__.__eq__,                 ["builtin_function_or_method"],  true]
    - [st1156pu008, struct.unpack_from.__class__.__name__.__eq__,               ["builtin_function_or_method"],  true]
    - [st1156pu009, struct.iter_unpack.__class__.__name__.__eq__,               ["builtin_function_or_method"],  true]
    - [st1156pu010, struct.pack_into.__module__.__class__.__name__.__eq__,      ["str"],                         true]
    - [st1156pu011, struct.unpack_from.__module__.__class__.__name__.__eq__,    ["str"],                         true]
    - [st1156pu012, struct.iter_unpack.__module__.__class__.__name__.__eq__,    ["str"],                         true]

table struct_extra1156.struct_class_type_attrs_and_method_descriptors:
  description: "struct.Struct __class__ type attrs, and Struct.pack/Struct.unpack method_descriptor qualname and class name"
  kind: python_call_eq
  category: struct_class_type_method_descriptor_attrs
  id_prefix: st1156sm
  columns: [id, function, args, expected]
  rows:
    - [st1156sm001, struct.Struct.__class__.__name__.__eq__,                    ["type"],              true]
    - [st1156sm002, struct.Struct.__class__.__qualname__.__eq__,                ["type"],              true]
    - [st1156sm003, struct.Struct.__class__.__module__.__eq__,                  ["builtins"],          true]
    - [st1156sm004, struct.Struct.pack.__qualname__.__eq__,                     ["Struct.pack"],       true]
    - [st1156sm005, struct.Struct.pack.__class__.__name__.__eq__,               ["method_descriptor"], true]
    - [st1156sm006, struct.Struct.unpack.__qualname__.__eq__,                   ["Struct.unpack"],     true]
    - [st1156sm007, struct.Struct.unpack.__class__.__name__.__eq__,             ["method_descriptor"], true]
    - [st1156sm008, struct.Struct.__init__.__qualname__.__eq__,                 ["Struct.__init__"],   true]
    - [st1156sm009, struct.Struct.__init__.__class__.__name__.__eq__,           ["wrapper_descriptor"], true]

table struct_extra1156.error_class_type_attrs_and_module:
  description: "struct.error __class__ type attrs, module, and qualname identity"
  kind: python_call_eq
  category: error_class_type_attrs_module
  id_prefix: st1156ec
  columns: [id, function, args, expected]
  rows:
    - [st1156ec001, struct.error.__class__.__name__.__eq__,                     ["type"],              true]
    - [st1156ec002, struct.error.__class__.__qualname__.__eq__,                 ["type"],              true]
    - [st1156ec003, struct.error.__class__.__module__.__eq__,                   ["builtins"],          true]
    - [st1156ec004, struct.error.__module__.__eq__,                             ["struct"],            true]
    - [st1156ec005, struct.error.__name__.__eq__,                               ["error"],             true]
    - [st1156ec006, struct.error.__qualname__.__eq__,                           ["error"],             true]
    - [st1156ec007, struct.error.__module__.__class__.__name__.__eq__,          ["str"],               true]
    - [st1156ec008, struct.error.__name__.__class__.__name__.__eq__,            ["str"],               true]
    - [st1156ec009, struct.error.__weakref__.__qualname__.__eq__,               ["error.__weakref__"], true]
    - [st1156ec010, struct.error.__weakref__.__class__.__name__.__eq__,         ["getset_descriptor"], true]
