spec: inspect_extra72
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra71.zspec.zsdl."
    - "Wave 238 theme: inspect function __annotations__ attributes and Parameter class identity."
    - "getmembers.__annotations__.__class__.__name__ == 'dict' — getmembers is a pure-Python function with an empty __annotations__ dict. Verified with Python 3.14.3."
    - "getmembers.__annotations__.__len__() == 0 — no annotations in the getmembers definition. Verified with Python 3.14.3."
    - "isfunction.__annotations__.__class__.__name__ == 'dict' — isfunction is a pure-Python function with an empty __annotations__ dict. Verified with Python 3.14.3."
    - "isfunction.__annotations__.__len__() == 0 — no annotations in the isfunction definition. Verified with Python 3.14.3."
    - "signature.__annotations__.__class__.__name__ == 'dict' — signature is a pure-Python function with an empty __annotations__ dict. Verified with Python 3.14.3."
    - "signature.__annotations__.__len__() == 0 — no annotations in the signature definition. Verified with Python 3.14.3."
    - "Parameter.__init__.__code__.co_name == '__init__' — co_name records the def statement name. Verified with Python 3.14.3."
    - "Parameter.__init__.__code__.co_argcount == 3 — Parameter.__init__(self, name, kind, *, default, annotation) has 3 positional parameters (self, name, kind); default and annotation are keyword-only. Verified with Python 3.14.3."
    - "Parameter.__name__ == 'Parameter' — Parameter is a pure-Python class in Lib/inspect.py. Verified with Python 3.14.3."
    - "Parameter.__module__ == 'inspect' — Parameter is defined in the inspect module. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# getmembers __annotations__ — extra72
#
# Wave 238 theme: getmembers __annotations__ is an empty dict.
#
# inspect.getmembers is a pure-Python function defined in Lib/inspect.py.
# Its __annotations__ attribute is a dict with no entries.
#
# No prior inspect spec checks getmembers.__annotations__ via inspann72. New to extra72.
# ---------------------------------------------------------------------------

table inspect_extra72.getmembers_annotations:
  description: "getmembers.__annotations__.__class__.__name__=='dict', __len__()==0; wave 238 getmembers __annotations__; new to extra72"
  kind: python_call_eq
  category: annotations
  id_prefix: inspann72

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_ann_class_name_eq_dict,
       getmembers.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "inspect.getmembers.__annotations__.__class__.__name__.__eq__('dict') == True — getmembers is a pure-Python function in Lib/inspect.py that returns all the members of an object in a list of (name, value) pairs; it carries an __annotations__ dict that is empty (no type annotations in the CPython implementation); __class__.__name__ for a dict is 'dict' (4 chars); str.__eq__('dict') returns True; no prior inspect spec checks getmembers.__annotations__.__class__.__name__ via inspann72; new to extra72"]
    - [getmembers_ann_len_eq_0,
       getmembers.__annotations__.__len__,
       [],
       0,
       "inspect.getmembers.__annotations__.__len__() == 0 — getmembers is defined in Lib/inspect.py with no type annotations on any parameter or on the return value; the __annotations__ dict is therefore empty and its len is 0; no prior inspect spec checks getmembers.__annotations__.__len__ via inspann72; new to extra72"]

# ---------------------------------------------------------------------------
# isfunction and signature __annotations__ — extra72
#
# Wave 238 theme: isfunction and signature __annotations__ are empty dicts.
#
# inspect.isfunction is a pure-Python function in Lib/inspect.py.
# inspect.signature is a pure-Python function in Lib/inspect.py.
# Both carry empty __annotations__ dicts.
#
# No prior inspect spec checks these __annotations__ via inspann72. New to extra72.
# ---------------------------------------------------------------------------

table inspect_extra72.isfunction_signature_annotations:
  description: "isfunction/__annotations__.__class__.__name__=='dict'; signature/__annotations__.__len__()==0; wave 238 inspect __annotations__; new to extra72"
  kind: python_call_eq
  category: annotations
  id_prefix: inspann72

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_ann_class_name_eq_dict,
       isfunction.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "inspect.isfunction.__annotations__.__class__.__name__.__eq__('dict') == True — isfunction is a pure-Python function in Lib/inspect.py that returns True if the object is a Python function; it carries an empty __annotations__ dict; __class__.__name__ for a dict is 'dict' (4 chars); str.__eq__('dict') returns True; no prior inspect spec checks isfunction.__annotations__.__class__.__name__ via inspann72; new to extra72"]
    - [isfunction_ann_len_eq_0,
       isfunction.__annotations__.__len__,
       [],
       0,
       "inspect.isfunction.__annotations__.__len__() == 0 — isfunction is defined with no type annotations on any parameter or on the return value; the __annotations__ dict is therefore empty and its len is 0; no prior inspect spec checks isfunction.__annotations__.__len__ via inspann72; new to extra72"]
    - [signature_ann_class_name_eq_dict,
       signature.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "inspect.signature.__annotations__.__class__.__name__.__eq__('dict') == True — signature is a pure-Python function in Lib/inspect.py that returns a Signature object for the given callable; it carries an empty __annotations__ dict; __class__.__name__ for a dict is 'dict' (4 chars); str.__eq__('dict') returns True; no prior inspect spec checks signature.__annotations__.__class__.__name__ via inspann72; new to extra72"]
    - [signature_ann_len_eq_0,
       signature.__annotations__.__len__,
       [],
       0,
       "inspect.signature.__annotations__.__len__() == 0 — signature is defined with no type annotations on any parameter or on the return value; the __annotations__ dict is therefore empty and its len is 0; no prior inspect spec checks signature.__annotations__.__len__ via inspann72; new to extra72"]

# ---------------------------------------------------------------------------
# Parameter.__init__ __code__ attributes — extra72
#
# Wave 238 theme: Parameter.__init__ code attributes.
#
# inspect.Parameter is a pure-Python class in Lib/inspect.py.
# Its __init__ is defined as:
#   def __init__(self, name, kind, *, default=_empty, annotation=_empty):
#
# co_name     == '__init__'
# co_argcount == 3  (self, name, kind are positional; default and annotation are keyword-only)
#
# No prior inspect spec checks Parameter.__init__.__code__ via inspann72. New to extra72.
# ---------------------------------------------------------------------------

table inspect_extra72.Parameter_init_code:
  description: "Parameter.__init__.__code__.co_name=='__init__', co_argcount==3; wave 238 Parameter.__init__ __code__; new to extra72"
  kind: python_call_eq
  category: code_attributes
  id_prefix: inspann72

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_init_co_name_eq_init,
       Parameter.__init__.__code__.co_name.__eq__,
       ["__init__"],
       true,
       "inspect.Parameter.__init__.__code__.co_name.__eq__('__init__') == True — Parameter.__init__ is a pure-Python method defined in Lib/inspect.py; the code object's co_name stores the name from the def statement which is '__init__' (8 chars including underscores); str.__eq__('__init__') returns True; no prior inspect spec checks Parameter.__init__.__code__.co_name via inspann72; new to extra72"]
    - [Parameter_init_co_argcount_eq_3,
       Parameter.__init__.__code__.co_argcount.__eq__,
       [3],
       true,
       "inspect.Parameter.__init__.__code__.co_argcount.__eq__(3) == True — Parameter.__init__ is defined as 'def __init__(self, name, kind, *, default=_empty, annotation=_empty):' with 3 positional parameters (self, name, kind); default and annotation are keyword-only (after the * separator); co_argcount counts only positional parameters and equals 3; int.__eq__(3) returns True; no prior inspect spec checks Parameter.__init__.__code__.co_argcount via inspann72; new to extra72"]

# ---------------------------------------------------------------------------
# Parameter class identity — extra72
#
# Wave 238 theme: Parameter class identity attributes.
#
# inspect.Parameter.__name__   == 'Parameter'
# inspect.Parameter.__module__ == 'inspect'
#
# No prior inspect spec checks Parameter.__name__ or __module__ via inspann72. New to extra72.
# ---------------------------------------------------------------------------

table inspect_extra72.Parameter_identity:
  description: "Parameter.__name__=='Parameter', Parameter.__module__=='inspect'; wave 238 Parameter class identity; new to extra72"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspann72

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_name_eq_Parameter,
       Parameter.__name__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter is a pure-Python class defined in Lib/inspect.py that represents a parameter in a function signature; __name__ stores the class name as a str 'Parameter' (9 chars); str.__eq__('Parameter') returns True; no prior inspect spec checks Parameter.__name__ via inspann72; new to extra72"]
    - [Parameter_module_eq_inspect,
       Parameter.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py and its __module__ attribute records the module name as the str 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks Parameter.__module__ via inspann72; new to extra72"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra72
# ---------------------------------------------------------------------------

invariant inspect_extra72.getmembers_ann_class_dict:
  description: "inspect.getmembers.__annotations__.__class__.__name__.__eq__('dict') == True — getmembers __annotations__ is an empty dict; wave 238 inspect __annotations__; new to extra72"
  kind: python_call_eq
  function: getmembers.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant inspect_extra72.getmembers_ann_len_zero:
  description: "inspect.getmembers.__annotations__.__len__() == 0 — no annotations in getmembers definition; wave 238 inspect __annotations__; new to extra72"
  kind: python_call_eq
  function: getmembers.__annotations__.__len__
  args: []
  expected: 0

invariant inspect_extra72.signature_ann_len_zero:
  description: "inspect.signature.__annotations__.__len__() == 0 — no annotations in signature definition; wave 238 inspect __annotations__; new to extra72"
  kind: python_call_eq
  function: signature.__annotations__.__len__
  args: []
  expected: 0

invariant inspect_extra72.Parameter_init_co_argcount:
  description: "inspect.Parameter.__init__.__code__.co_argcount.__eq__(3) == True — Parameter.__init__(self, name, kind) has 3 positional parameters; wave 238 Parameter.__init__ __code__; new to extra72"
  kind: python_call_eq
  function: Parameter.__init__.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant inspect_extra72.Parameter_module:
  description: "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter.__module__ is 'inspect'; wave 238 Parameter class identity; new to extra72"
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true
