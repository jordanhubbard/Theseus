spec: multiprocessing_extra118
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra117.zspec.zsdl."
    - "This spec covers: wave 260 theme — multiprocessing.process.BaseProcess class method co_varnames not previously covered. Note: multiprocessing.Process is a platform-specific subclass of BaseProcess defined in multiprocessing.context; its methods are inherited from BaseProcess (co_qualname shows 'BaseProcess.*'). Prior specs covered BaseProcess qualname strings (extra10-103) but NOT co_varnames element equality. NOT previously covered: BaseProcess.__init__.__code__.co_varnames[1].__eq__('group'); co_varnames[2].__eq__('target'); co_varnames[5].__eq__('kwargs'); BaseProcess.join.__code__.co_varnames[1].__eq__('timeout'); BaseProcess.join.__code__.co_varnames.__len__()==3; BaseProcess.start/__code__.co_varnames.__len__()==1; BaseProcess.run.__code__.co_varnames.__len__()==1; BaseProcess.terminate.__code__.co_varnames.__len__()==1. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.process.BaseProcess.__init__.__code__.co_varnames == ('self','group','target','name','args','kwargs','daemon','count'): len=8; co_argcount==6 (self, group, target, name, args, kwargs; daemon and count are positional-only or local depending on version); co_qualname=='BaseProcess.__init__' (len=20). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.process.BaseProcess.start.__code__.co_varnames==('self',): len=1. BaseProcess.run.__code__.co_varnames==('self',): len=1. BaseProcess.terminate.__code__.co_varnames==('self',): len=1. BaseProcess.kill.__code__.co_varnames==('self',): len=1. All four have only 'self' in co_varnames. BaseProcess.join.__code__.co_varnames==('self','timeout','res'): len=3; co_qualname=='BaseProcess.join' (len=16). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.process.BaseProcess.__init__ co_varnames element equality — extra118
#
# Wave 260 theme: BaseProcess.__init__ co_varnames[1]-[6] element equality.
#
# BaseProcess.__init__.__code__.co_varnames[0] == 'self'   (len=4)
# BaseProcess.__init__.__code__.co_varnames[1] == 'group'  (len=5)
# BaseProcess.__init__.__code__.co_varnames[2] == 'target' (len=6)
# BaseProcess.__init__.__code__.co_varnames[3] == 'name'   (len=4)
# BaseProcess.__init__.__code__.co_varnames[4] == 'args'   (len=4)
# BaseProcess.__init__.__code__.co_varnames[5] == 'kwargs' (len=6)
# BaseProcess.__init__.__code__.co_varnames[6] == 'daemon' (len=6)
# BaseProcess.__init__.__code__.co_varnames[7] == 'count'  (len=5)
# ---------------------------------------------------------------------------

table multiprocessing_extra118.mp_baseprocess_init_co_varnames:
  description: "multiprocessing.process.BaseProcess.__init__ co_varnames element equality checks in mpbp118 namespace — wave 260 theme: first element-level coverage of BaseProcess.__init__ co_varnames; co_varnames==('self','group','target','name','args','kwargs','daemon','count') len=8; BaseProcess.__init__ defines the interface for creating a new process: group is always None (reserved for future use, analogous to threading.Thread); target is the callable object; name is the process name string; args is the tuple of arguments for target; kwargs is the dict of keyword arguments; daemon controls whether the process is a daemon process; count is an internal counter for auto-generating process names; co_varnames[1].__eq__('group')==True (len=5: always None, kept for API compatibility with threading.Thread); co_varnames[2].__eq__('target')==True (len=6: the callable to run in the child process; tied in length with 'kwargs'=6 and 'daemon'=6); co_varnames[3].__eq__('name')==True (len=4: the process name; tied with 'self'=4, 'args'=4); co_varnames[4].__eq__('args')==True (len=4: positional arguments tuple for target; tied with 'name'=4 and 'self'=4); co_varnames[5].__eq__('kwargs')==True (len=6: keyword arguments dict for target; tied with 'target'=6 and 'daemon'=6); element length ordering: self==name==args=4 (tied, shortest params) < group==count=5 < target==kwargs==daemon=6 (tied, longest params); co_argcount==6 (self,group,target,name,args,kwargs; daemon is keyword-only or local per version); co_qualname=='BaseProcess.__init__' (len=20); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: mpbp118

  columns: [id, function, args, expected, description]
  rows:
    - [v_len,   "BaseProcess.__init__.__code__.co_varnames.__len__",    [],          8,    "BaseProcess.__init__ co_varnames.__len__() == 8 (most in spec; 8 variables total); verified with Python 3.14.3"]
    - [v1_eq,   "BaseProcess.__init__.__code__.co_varnames[1].__eq__",  ["group"],   true, "BaseProcess.__init__ co_varnames[1] == 'group' (len=5; always None, reserved for future use); verified with Python 3.14.3"]
    - [v1_len,  "BaseProcess.__init__.__code__.co_varnames[1].__len__", [],          5,    "BaseProcess.__init__ co_varnames[1].__len__() == 5 ('group'=5); verified with Python 3.14.3"]
    - [v2_eq,   "BaseProcess.__init__.__code__.co_varnames[2].__eq__",  ["target"],  true, "BaseProcess.__init__ co_varnames[2] == 'target' (len=6; callable to run in child process); verified with Python 3.14.3"]
    - [v2_len,  "BaseProcess.__init__.__code__.co_varnames[2].__len__", [],          6,    "BaseProcess.__init__ co_varnames[2].__len__() == 6 ('target'=6; tied with kwargs=6 and daemon=6); verified with Python 3.14.3"]
    - [v3_eq,   "BaseProcess.__init__.__code__.co_varnames[3].__eq__",  ["name"],    true, "BaseProcess.__init__ co_varnames[3] == 'name' (len=4; process name string); verified with Python 3.14.3"]
    - [v3_len,  "BaseProcess.__init__.__code__.co_varnames[3].__len__", [],          4,    "BaseProcess.__init__ co_varnames[3].__len__() == 4 ('name'=4; tied with self=4 and args=4); verified with Python 3.14.3"]
    - [v4_eq,   "BaseProcess.__init__.__code__.co_varnames[4].__eq__",  ["args"],    true, "BaseProcess.__init__ co_varnames[4] == 'args' (len=4; positional args tuple for target); verified with Python 3.14.3"]
    - [v4_len,  "BaseProcess.__init__.__code__.co_varnames[4].__len__", [],          4,    "BaseProcess.__init__ co_varnames[4].__len__() == 4 ('args'=4; tied with name=4 and self=4); verified with Python 3.14.3"]
    - [v5_eq,   "BaseProcess.__init__.__code__.co_varnames[5].__eq__",  ["kwargs"],  true, "BaseProcess.__init__ co_varnames[5] == 'kwargs' (len=6; keyword args dict for target); verified with Python 3.14.3"]
    - [v5_len,  "BaseProcess.__init__.__code__.co_varnames[5].__len__", [],          6,    "BaseProcess.__init__ co_varnames[5].__len__() == 6 ('kwargs'=6; tied with target=6 and daemon=6); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.process.BaseProcess lifecycle method co_varnames lengths — extra118
#
# Wave 260 theme: start, run, terminate, kill co_varnames lengths (all == 1).
# BaseProcess.start.__code__.co_varnames.__len__()     == 1  (only 'self')
# BaseProcess.run.__code__.co_varnames.__len__()       == 1  (only 'self', tied)
# BaseProcess.terminate.__code__.co_varnames.__len__() == 1  (only 'self', tied)
# BaseProcess.kill.__code__.co_varnames.__len__()      == 1  (only 'self', tied)
# BaseProcess.join.__code__.co_varnames.__len__()      == 3  ('self','timeout','res')
# ---------------------------------------------------------------------------

table multiprocessing_extra118.mp_baseprocess_lifecycle_co_varnames_len:
  description: "multiprocessing.process.BaseProcess lifecycle method co_varnames length checks in mpbp118 namespace — wave 260 theme: start, run, terminate, kill, join co_varnames lengths; BaseProcess.start.__code__.co_varnames.__len__()==1 (('self',): start() has no parameters beyond self; it spawns the child process using the appropriate start method; co_qualname=='BaseProcess.start' len=17); BaseProcess.run.__code__.co_varnames.__len__()==1 (('self',): run() is the method called in the child process; it calls self._target(*self._args, **self._kwargs) if target is set; tied with start=1; co_qualname=='BaseProcess.run' len=15); BaseProcess.terminate.__code__.co_varnames.__len__()==1 (('self',): terminate() sends SIGTERM on Unix or TerminateProcess() on Windows; tied with start=run=1; co_qualname=='BaseProcess.terminate' len=21: longest lifecycle qualname in spec); BaseProcess.kill.__code__.co_varnames.__len__()==1 (('self',): kill() sends SIGKILL on Unix; identical to terminate() on Windows; tied with all others=1; co_qualname=='BaseProcess.kill' len=16); BaseProcess.join.__code__.co_varnames.__len__()==3 (('self','timeout','res'): join() has two extra variables: timeout for the wait duration and res for the waitpid result; most co_varnames among lifecycle methods; co_qualname=='BaseProcess.join' len=16; tied with kill=16); all four single-variable methods have co_argcount==1; join has co_argcount==2 (self and timeout); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: mpbp118a

  columns: [id, function, args, expected, description]
  rows:
    - [start_vlen,  "BaseProcess.start.__code__.co_varnames.__len__",     [], 1, "BaseProcess.start co_varnames.__len__() == 1 (only 'self'; no params); verified with Python 3.14.3"]
    - [run_vlen,    "BaseProcess.run.__code__.co_varnames.__len__",       [], 1, "BaseProcess.run co_varnames.__len__() == 1 (only 'self'; tied with start=1); verified with Python 3.14.3"]
    - [term_vlen,   "BaseProcess.terminate.__code__.co_varnames.__len__", [], 1, "BaseProcess.terminate co_varnames.__len__() == 1 (only 'self'; tied with start=run=1); verified with Python 3.14.3"]
    - [kill_vlen,   "BaseProcess.kill.__code__.co_varnames.__len__",      [], 1, "BaseProcess.kill co_varnames.__len__() == 1 (only 'self'; tied with start=run=terminate=1); verified with Python 3.14.3"]
    - [join_vlen,   "BaseProcess.join.__code__.co_varnames.__len__",      [], 3, "BaseProcess.join co_varnames.__len__() == 3 ('self','timeout','res'; most among lifecycle methods); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.process.BaseProcess.join co_varnames element equality — extra118
#
# Wave 260 theme: BaseProcess.join co_varnames[1] and [2] equality.
#
# BaseProcess.join.__code__.co_varnames[1] == 'timeout' (len=7)
# BaseProcess.join.__code__.co_varnames[2] == 'res'     (len=3)
# BaseProcess.join.__code__.co_qualname    == 'BaseProcess.join' (len=16)
# ---------------------------------------------------------------------------

table multiprocessing_extra118.mp_baseprocess_join_co_varnames:
  description: "multiprocessing.process.BaseProcess.join co_varnames element equality checks in mpbp118 namespace — wave 260 theme: first element-level coverage of BaseProcess.join co_varnames; co_varnames==('self','timeout','res') len=3; join() waits for the child process to terminate; timeout is the optional wait duration in seconds (None means wait indefinitely); res is a local variable holding the result of os.waitpid() or equivalent; co_varnames[1].__eq__('timeout')==True (len=7: timeout is the only parameter beyond self; if timeout elapses, join() returns even if the process has not terminated; co_argcount==2: self and timeout); co_varnames[1].__len__()==7; co_varnames[2].__eq__('res')==True (len=3: res is a local variable used to capture the process exit status from waitpid; not a parameter; shortest co_varnames element in this spec among named variables); co_varnames[2].__len__()==3; compare element lengths: res=3 < self=4 < group=5 < target==kwargs==daemon=6 < timeout=7 (timeout is the longest element in join co_varnames); co_qualname=='BaseProcess.join' (len=16: 'BaseProcess.'=12+'join'=4=16; tied with kill=16: 'BaseProcess.'=12+'kill'=4=16); compare qualname lengths: run=15 < join==kill=16 < start=17 < __init__=20 < terminate=21 (longest lifecycle qualname in spec); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: mpbp118b

  columns: [id, function, args, expected, description]
  rows:
    - [join_v1_eq,  "BaseProcess.join.__code__.co_varnames[1].__eq__",  ["timeout"], true, "BaseProcess.join co_varnames[1] == 'timeout' (len=7; optional wait duration); verified with Python 3.14.3"]
    - [join_v1_len, "BaseProcess.join.__code__.co_varnames[1].__len__", [],          7,    "BaseProcess.join co_varnames[1].__len__() == 7 ('timeout'=7; longest in join co_varnames); verified with Python 3.14.3"]
    - [join_v2_eq,  "BaseProcess.join.__code__.co_varnames[2].__eq__",  ["res"],     true, "BaseProcess.join co_varnames[2] == 'res' (len=3; local for waitpid result); verified with Python 3.14.3"]
    - [join_v2_len, "BaseProcess.join.__code__.co_varnames[2].__len__", [],          3,    "BaseProcess.join co_varnames[2].__len__() == 3 ('res'=3; shortest named local in spec); verified with Python 3.14.3"]
    - [join_qn_len, "BaseProcess.join.__code__.co_qualname.__len__",    [],          16,   "BaseProcess.join co_qualname.__len__() == 16 ('BaseProcess.join'=16; tied with kill=16); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra118
# ---------------------------------------------------------------------------

invariant multiprocessing_extra118.bp_init_v1_group:
  description: "multiprocessing.process.BaseProcess.__init__.__code__.co_varnames[1].__eq__('group') returns True — BaseProcess.__init__ co_varnames[1]='group' (len=5); group is the first non-self parameter of Process/__init__; it is always None in practice and is only kept for API compatibility with threading.Thread.__init__(group=None,...); BaseProcess.__init__.__code__.co_varnames.__len__()==8 (most in spec); co_argcount==6 (self,group,target,name,args,kwargs); 'group'=5 chars is between 'name'/'args'/'self'=4 (shorter) and 'target'/'kwargs'/'daemon'=6 (longer); compare: ThreadPoolExecutor.__init__ co_varnames[1]='max_workers' (len=11, much longer); BaseProcess.__init__.__code__.co_qualname=='BaseProcess.__init__' (len=20: 'BaseProcess.'=12+'__init__'=8=20); BaseProcess.__name__='BaseProcess' (len=11); BaseProcess.__module__='multiprocessing.process' (len=23); first standalone BaseProcess.__init__ co_varnames[1] equality invariant in mpbp118 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "BaseProcess.__init__.__code__.co_varnames[1].__eq__"
  args: ["group"]
  expected: true

invariant multiprocessing_extra118.bp_init_v2_target:
  description: "multiprocessing.process.BaseProcess.__init__.__code__.co_varnames[2].__eq__('target') returns True — BaseProcess.__init__ co_varnames[2]='target' (len=6); target is the callable object to be invoked in the child process; it is called as target(*args, **kwargs) from within run(); if target is None, run() does nothing; 'target'=6 chars is tied with 'kwargs'=6 (co_varnames[5]) and 'daemon'=6 (co_varnames[6]); BaseProcess.__init__.__code__.co_varnames[2].__len__()==6; co_varnames length ordering: self==name==args=4 < group==count=5 < target==kwargs==daemon=6; BaseProcess.__init__.__code__.co_qualname=='BaseProcess.__init__' (len=20); compare: BaseProcess.start/run/terminate/kill all have co_varnames.__len__()==1 (only 'self', no target param); BaseProcess.join has co_varnames.__len__()==3 with 'timeout' as the only non-self param; first standalone BaseProcess.__init__ co_varnames[2] equality invariant in mpbp118 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "BaseProcess.__init__.__code__.co_varnames[2].__eq__"
  args: ["target"]
  expected: true

invariant multiprocessing_extra118.bp_start_co_varnames_len_1:
  description: "multiprocessing.process.BaseProcess.start.__code__.co_varnames.__len__() == 1 — co_varnames==('self',): start() has no parameters beyond self; it spawns the child process using the platform-appropriate start method (fork, spawn, or forkserver); start() must not be called more than once per Process object; BaseProcess.start.__code__.co_qualname=='BaseProcess.start' (len=17: 'BaseProcess.'=12+'start'=5=17); compare qualname lengths: run=15 < join==kill=16 < start=17 < __init__=20 < terminate=21 (longest); co_varnames.__len__()==1 is tied with run, terminate, and kill (all four have only 'self'); join has co_varnames.__len__()==3 (most among lifecycle methods); BaseProcess.__init__ has co_varnames.__len__()==8 (most in entire spec); BaseProcess.__name__='BaseProcess' (len=11); BaseProcess.__module__='multiprocessing.process' (len=23); first standalone BaseProcess.start co_varnames length invariant in mpbp118 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "BaseProcess.start.__code__.co_varnames.__len__"
  args: []
  expected: 1

invariant multiprocessing_extra118.bp_join_v1_timeout:
  description: "multiprocessing.process.BaseProcess.join.__code__.co_varnames[1].__eq__('timeout') returns True — BaseProcess.join co_varnames[1]='timeout' (len=7; longest element in join co_varnames); join(timeout=None) blocks until the child process terminates or until timeout seconds elapse; if timeout is None, join() waits indefinitely; after timeout elapses join() returns and the process may still be alive; co_argcount==2 (self and timeout); co_varnames.__len__()==3 ('self','timeout','res'); 'timeout'=7 chars; compare: 'res'=3 (4 shorter, the local result variable); BaseProcess.join.__code__.co_qualname=='BaseProcess.join' (len=16: 'BaseProcess.'=12+'join'=4=16; tied with kill=16); compare: 'timeout' also appears in BaseEventLoop.shutdown_default_executor.__code__.co_varnames[1] as 'timeout'; BaseProcess.__name__='BaseProcess' (len=11); first standalone BaseProcess.join co_varnames[1] equality invariant in mpbp118 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "BaseProcess.join.__code__.co_varnames[1].__eq__"
  args: ["timeout"]
  expected: true

invariant multiprocessing_extra118.bp_run_co_varnames_len_1:
  description: "multiprocessing.process.BaseProcess.run.__code__.co_varnames.__len__() == 1 — co_varnames==('self',): run() has no parameters beyond self; it calls self._target(*self._args, **self._kwargs) if _target is set; run() is the method that is executed in the child process when the process starts; users can override run() in a subclass instead of passing target= to Process; BaseProcess.run.__code__.co_qualname=='BaseProcess.run' (len=15: 'BaseProcess.'=12+'run'=3=15; shortest lifecycle qualname in spec: 'run'=3 vs 'kill'='join'=4 vs 'start'=5); co_varnames.__len__()==1 is tied with start, terminate, and kill; compare: join has co_varnames.__len__()==3 (2 more); __init__ has co_varnames.__len__()==8 (7 more); BaseProcess.run is the method subclasses override to define process behavior (e.g., class MyProcess(Process): def run(self): ...); BaseProcess.__module__='multiprocessing.process' (len=23); first standalone BaseProcess.run co_varnames length invariant in mpbp118 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "BaseProcess.run.__code__.co_varnames.__len__"
  args: []
  expected: 1

