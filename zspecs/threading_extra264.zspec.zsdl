spec: threading_extra264
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.RLock factory function identity and instance class identity; threading.Lock class identity; acquire/release/context manager qualnames."
    - "threading.RLock is a factory function (not a class); RLock.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.RLock.__name__ == 'RLock'; __module__ == 'threading'. Verified with Python 3.14.3."
    - "type(threading.RLock()) == _thread.RLock; accessible as RLock.__call__().__class__. Verified with Python 3.14.3."
    - "type(threading.RLock()).__name__ == 'RLock'; __module__ == '_thread'; __bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "type(threading.RLock()).acquire.__qualname__ == 'RLock.acquire'. Verified with Python 3.14.3."
    - "type(threading.RLock()).release.__qualname__ == 'RLock.release'. Verified with Python 3.14.3."
    - "type(threading.RLock()).__enter__.__qualname__ == 'RLock.__enter__'. Verified with Python 3.14.3."
    - "type(threading.RLock()).__exit__.__qualname__ == 'RLock.__exit__'. Verified with Python 3.14.3."
    - "threading.Lock.__name__ == 'lock' (lowercase); __module__ == '_thread'. threading.Lock is a type, not a factory function. Verified with Python 3.14.3."
    - "threading.Lock.acquire.__qualname__ == 'lock.acquire'; threading.Lock.release.__qualname__ == 'lock.release'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.RLock factory function identity
#
# threading.RLock is a factory function defined in Lib/threading.py.
# threading.RLock.__class__.__name__ == 'function'
# threading.RLock.__name__ == 'RLock'
# threading.RLock.__module__ == 'threading'
#
# New to extra264.
# ---------------------------------------------------------------------------

table threading_extra264.rlock_factory_identity:
  description: "threading.RLock factory function __class__.__name__, __name__, __module__ identity; new to extra264"
  kind: python_call_eq
  category: identity
  id_prefix: threadingrlock264

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_class_name_eq,
       RLock.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.RLock.__class__.__name__.__eq__('function') == True — RLock is a module-level factory function in Lib/threading.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra264"]
    - [rlock_name_eq,
       RLock.__name__.__eq__,
       ["RLock"],
       true,
       "threading.RLock.__name__.__eq__('RLock') == True — the RLock factory function has __name__ 'RLock'; str.__eq__('RLock') returns True; new to extra264"]
    - [rlock_module_eq,
       RLock.__module__.__eq__,
       ["threading"],
       true,
       "threading.RLock.__module__.__eq__('threading') == True — the RLock factory function is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra264"]
    - [rlock_name_len_5,
       RLock.__name__.__len__,
       [],
       5,
       "threading.RLock.__name__.__len__() == 5 — the name 'RLock' has exactly 5 characters: R-L-o-c-k; str.__len__() returns 5; new to extra264"]
    - [rlock_module_len_9,
       RLock.__module__.__len__,
       [],
       9,
       "threading.RLock.__module__.__len__() == 9 — the module name 'threading' has exactly 9 characters; str.__len__() returns 9; new to extra264"]

# ---------------------------------------------------------------------------
# Table 2: threading.RLock instance class identity
#
# RLock.__call__().__class__.__name__ == 'RLock'
# RLock.__call__().__class__.__module__ == '_thread'
# RLock.__call__().__class__.__bases__[0].__name__ == 'object'
# RLock.__call__().__class__.acquire.__qualname__ == 'RLock.acquire'
# RLock.__call__().__class__.release.__qualname__ == 'RLock.release'
#
# The _thread.RLock C extension class is the actual lock type returned by the
# factory. New to extra264.
# ---------------------------------------------------------------------------

table threading_extra264.rlock_instance_class_identity:
  description: "type(threading.RLock()) class __name__, __module__, base, acquire/release qualnames; new to extra264"
  kind: python_call_eq
  category: identity
  id_prefix: threadingrlocktype264

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_instance_class_name_eq,
       RLock.__call__().__class__.__name__.__eq__,
       ["RLock"],
       true,
       "threading.RLock().__class__.__name__.__eq__('RLock') == True — the factory returns an _thread.RLock instance whose type __name__ is 'RLock'; str.__eq__('RLock') returns True; new to extra264"]
    - [rlock_instance_class_module_eq,
       RLock.__call__().__class__.__module__.__eq__,
       ["_thread"],
       true,
       "threading.RLock().__class__.__module__.__eq__('_thread') == True — the _thread.RLock C extension type has __module__ '_thread'; str.__eq__('_thread') returns True; new to extra264"]
    - [rlock_instance_class_base_name_eq,
       RLock.__call__().__class__.__bases__.__getitem__(0).__name__.__eq__,
       ["object"],
       true,
       "threading.RLock().__class__.__bases__[0].__name__.__eq__('object') == True — _thread.RLock inherits directly from object; str.__eq__('object') returns True; new to extra264"]
    - [rlock_acquire_qualname_eq,
       RLock.__call__().__class__.acquire.__qualname__.__eq__,
       ["RLock.acquire"],
       true,
       "threading.RLock().__class__.acquire.__qualname__.__eq__('RLock.acquire') == True — acquire is a method of _thread.RLock; its __qualname__ is 'RLock.acquire'; str.__eq__('RLock.acquire') returns True; new to extra264"]
    - [rlock_release_qualname_eq,
       RLock.__call__().__class__.release.__qualname__.__eq__,
       ["RLock.release"],
       true,
       "threading.RLock().__class__.release.__qualname__.__eq__('RLock.release') == True — release is a method of _thread.RLock; its __qualname__ is 'RLock.release'; str.__eq__('RLock.release') returns True; new to extra264"]

# ---------------------------------------------------------------------------
# Table 3: threading.RLock instance context manager qualnames
#
# RLock.__call__().__class__.__enter__.__qualname__ == 'RLock.__enter__'
# RLock.__call__().__class__.__exit__.__qualname__ == 'RLock.__exit__'
#
# _thread.RLock implements the context manager protocol. New to extra264.
# ---------------------------------------------------------------------------

table threading_extra264.rlock_context_manager_qualnames:
  description: "threading.RLock().__class__.__enter__ and __exit__ qualnames; new to extra264"
  kind: python_call_eq
  category: identity
  id_prefix: threadingrlockcm264

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_enter_qualname_eq,
       RLock.__call__().__class__.__enter__.__qualname__.__eq__,
       ["RLock.__enter__"],
       true,
       "threading.RLock().__class__.__enter__.__qualname__.__eq__('RLock.__enter__') == True — _thread.RLock implements __enter__ for use as a context manager; its __qualname__ is 'RLock.__enter__'; str.__eq__('RLock.__enter__') returns True; new to extra264"]
    - [rlock_exit_qualname_eq,
       RLock.__call__().__class__.__exit__.__qualname__.__eq__,
       ["RLock.__exit__"],
       true,
       "threading.RLock().__class__.__exit__.__qualname__.__eq__('RLock.__exit__') == True — _thread.RLock implements __exit__ for use as a context manager; its __qualname__ is 'RLock.__exit__'; str.__eq__('RLock.__exit__') returns True; new to extra264"]

# ---------------------------------------------------------------------------
# Table 4: threading.Lock class identity
#
# threading.Lock.__name__ == 'lock'  (lowercase — the C extension type name)
# threading.Lock.__module__ == '_thread'
# threading.Lock.__bases__[0].__name__ == 'object'
# threading.Lock.acquire.__qualname__ == 'lock.acquire'
# threading.Lock.release.__qualname__ == 'lock.release'
#
# threading.Lock is the C extension type _thread.lock, re-exported via the
# threading module. Unlike RLock, Lock is a type (not a factory function).
# New to extra264.
# ---------------------------------------------------------------------------

table threading_extra264.lock_class_identity:
  description: "threading.Lock class __name__, __module__, base, acquire/release qualnames; new to extra264"
  kind: python_call_eq
  category: identity
  id_prefix: threadinglock264

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_eq,
       Lock.__name__.__eq__,
       ["lock"],
       true,
       "threading.Lock.__name__.__eq__('lock') == True — threading.Lock is the C extension type _thread.lock; its __name__ is lowercase 'lock'; str.__eq__('lock') returns True; new to extra264"]
    - [lock_module_eq,
       Lock.__module__.__eq__,
       ["_thread"],
       true,
       "threading.Lock.__module__.__eq__('_thread') == True — threading.Lock is the _thread.lock C extension type; its __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra264"]
    - [lock_base_name_eq,
       Lock.__bases__.__getitem__(0).__name__.__eq__,
       ["object"],
       true,
       "threading.Lock.__bases__[0].__name__.__eq__('object') == True — _thread.lock inherits directly from object; its first base class is object; str.__eq__('object') returns True; new to extra264"]
    - [lock_acquire_qualname_eq,
       Lock.acquire.__qualname__.__eq__,
       ["lock.acquire"],
       true,
       "threading.Lock.acquire.__qualname__.__eq__('lock.acquire') == True — acquire is a method of _thread.lock; its __qualname__ is 'lock.acquire'; str.__eq__('lock.acquire') returns True; new to extra264"]
    - [lock_release_qualname_eq,
       Lock.release.__qualname__.__eq__,
       ["lock.release"],
       true,
       "threading.Lock.release.__qualname__.__eq__('lock.release') == True — release is a method of _thread.lock; its __qualname__ is 'lock.release'; str.__eq__('lock.release') returns True; new to extra264"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra264
# ---------------------------------------------------------------------------

invariant threading_extra264.rlock_factory.class_name_eq:
  description: "threading.RLock.__class__.__name__.__eq__('function') == True — RLock is a factory function; new to extra264"
  category: identity
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra264.rlock_factory.name_eq:
  description: "threading.RLock.__name__.__eq__('RLock') == True — factory function __name__; new to extra264"
  category: identity
  kind: python_call_eq
  function: RLock.__name__.__eq__
  args: ["RLock"]
  expected: true

invariant threading_extra264.rlock_factory.module_eq:
  description: "threading.RLock.__module__.__eq__('threading') == True — defined in Lib/threading.py; new to extra264"
  category: identity
  kind: python_call_eq
  function: RLock.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra264.lock_class.name_eq:
  description: "threading.Lock.__name__.__eq__('lock') == True — C extension type, lowercase name; new to extra264"
  category: identity
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra264.lock_class.module_eq:
  description: "threading.Lock.__module__.__eq__('_thread') == True — _thread C extension type; new to extra264"
  category: identity
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra264.lock_class.acquire_qualname_eq:
  description: "threading.Lock.acquire.__qualname__.__eq__('lock.acquire') == True; new to extra264"
  category: identity
  kind: python_call_eq
  function: Lock.acquire.__qualname__.__eq__
  args: ["lock.acquire"]
  expected: true

invariant threading_extra264.lock_class.release_qualname_eq:
  description: "threading.Lock.release.__qualname__.__eq__('lock.release') == True; new to extra264"
  category: identity
  kind: python_call_eq
  function: Lock.release.__qualname__.__eq__
  args: ["lock.release"]
  expected: true

invariant threading_extra264.lock_class.base_name_eq:
  description: "threading.Lock.__bases__[0].__name__.__eq__('object') == True — inherits from object; new to extra264"
  category: identity
  kind: python_call_eq
  function: Lock.__bases__.__getitem__(0).__name__.__eq__
  args: ["object"]
  expected: true
