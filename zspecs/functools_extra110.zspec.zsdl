spec: functools_extra110
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra109

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra109.zspec.zsdl."
    - "This spec covers: __module__ attribute values for cached_property and singledispatchmethod methods; co_qualname (Python 3.11+) for top-level functools functions; all are 'functools' since they live in Lib/functools.py (Wave 258)."
    - "functools.cached_property.__init__.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.cached_property.__set_name__.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.cached_property.__get__.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__init__.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__get__.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.lru_cache.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.total_ordering.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.wraps.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.singledispatch.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_qualname == 'lru_cache'. Verified with Python 3.14.3."
    - "functools.total_ordering.__code__.co_qualname == 'total_ordering'. Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_qualname == 'wraps'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__code__.co_qualname == 'update_wrapper'. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_qualname == 'singledispatch'. Verified with Python 3.14.3."
    - "functools.cached_property.__init__.__code__.co_qualname == 'cached_property.__init__'. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__get__.__code__.co_qualname == 'singledispatchmethod.__get__'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools cached_property and singledispatchmethod method __module__
#
# Wave 258 theme: __module__ for cached_property and singledispatchmethod
# methods is always 'functools' — all defined in Lib/functools.py.
#
# functools.cached_property.__init__.__module__ == 'functools'
# functools.cached_property.__set_name__.__module__ == 'functools'
# functools.cached_property.__get__.__module__ == 'functools'
# functools.singledispatchmethod.__init__.__module__ == 'functools'
# functools.singledispatchmethod.__get__.__module__ == 'functools'
#
# New to extra110.
# ---------------------------------------------------------------------------

table functools_extra110.method_module_cached_property:
  description: "functools cached_property and singledispatchmethod method __module__ == 'functools'; all defined in Lib/functools.py; wave 258; new to extra110"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsmethmod110

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_init_module_functools,
       "cached_property.__init__.__module__.__eq__",
       ["functools"],
       true,
       "functools.cached_property.__init__.__module__.__eq__('functools') == True — cached_property is a pure-Python class defined in Lib/functools.py; its __init__ method inherits __module__ == 'functools' from the module in which the class was defined; str.__eq__('functools') returns True; new to extra110"]
    - [cached_property_set_name_module_functools,
       "cached_property.__set_name__.__module__.__eq__",
       ["functools"],
       true,
       "functools.cached_property.__set_name__.__module__.__eq__('functools') == True — cached_property.__set_name__ is a descriptor protocol method defined inside the cached_property class in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra110"]
    - [cached_property_get_module_functools,
       "cached_property.__get__.__module__.__eq__",
       ["functools"],
       true,
       "functools.cached_property.__get__.__module__.__eq__('functools') == True — cached_property.__get__ implements the descriptor protocol in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra110"]
    - [singledispatchmethod_init_module_functools,
       "singledispatchmethod.__init__.__module__.__eq__",
       ["functools"],
       true,
       "functools.singledispatchmethod.__init__.__module__.__eq__('functools') == True — singledispatchmethod is a pure-Python class descriptor defined in Lib/functools.py; its __init__ method's __module__ is 'functools'; str.__eq__('functools') returns True; new to extra110"]
    - [singledispatchmethod_get_module_functools,
       "singledispatchmethod.__get__.__module__.__eq__",
       ["functools"],
       true,
       "functools.singledispatchmethod.__get__.__module__.__eq__('functools') == True — singledispatchmethod.__get__ implements the descriptor protocol for non-data descriptors in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra110"]

# ---------------------------------------------------------------------------
# Table 2: functools top-level function __module__ values
#
# Wave 258 theme: top-level functools pure-Python functions all have
# __module__ == 'functools'.
#
# functools.lru_cache.__module__ == 'functools'
# functools.total_ordering.__module__ == 'functools'
# functools.wraps.__module__ == 'functools'
# functools.update_wrapper.__module__ == 'functools'
# functools.singledispatch.__module__ == 'functools'
#
# Contrast: functools.reduce.__module__ == '_functools' (C extension).
# New to extra110.
# ---------------------------------------------------------------------------

table functools_extra110.top_level_module:
  description: "functools pure-Python top-level function __module__ == 'functools': lru_cache/total_ordering/wraps/update_wrapper/singledispatch; wave 258; new to extra110"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolstopmod110

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_module_functools,
       "lru_cache.__module__.__eq__",
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is a pure-Python decorator factory defined in Lib/functools.py; its __module__ is 'functools' (not '_functools'); str.__eq__('functools') returns True; new to extra110"]
    - [total_ordering_module_functools,
       "total_ordering.__module__.__eq__",
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is a pure-Python class decorator defined in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra110"]
    - [wraps_module_functools,
       "wraps.__module__.__eq__",
       ["functools"],
       true,
       "functools.wraps.__module__.__eq__('functools') == True — wraps is a pure-Python decorator defined in Lib/functools.py using partial(update_wrapper, ...); its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra110"]
    - [update_wrapper_module_functools,
       "update_wrapper.__module__.__eq__",
       ["functools"],
       true,
       "functools.update_wrapper.__module__.__eq__('functools') == True — update_wrapper is a pure-Python function defined in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra110"]
    - [singledispatch_module_functools,
       "singledispatch.__module__.__eq__",
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is a pure-Python decorator defined in Lib/functools.py; its __module__ is 'functools' (not '_functools'); str.__eq__('functools') returns True; new to extra110"]

# ---------------------------------------------------------------------------
# Table 3: functools __code__.co_qualname values (Python 3.11+)
#
# Wave 258 theme: functools function __code__.co_qualname values.
# co_qualname was added in Python 3.11 (PEP 657). For top-level functions,
# co_qualname == __qualname__ == the simple function name.
#
# functools.lru_cache.__code__.co_qualname == 'lru_cache'
# functools.total_ordering.__code__.co_qualname == 'total_ordering'
# functools.wraps.__code__.co_qualname == 'wraps'
# functools.update_wrapper.__code__.co_qualname == 'update_wrapper'
# functools.singledispatch.__code__.co_qualname == 'singledispatch'
# functools.cached_property.__init__.__code__.co_qualname == 'cached_property.__init__'
# functools.singledispatchmethod.__get__.__code__.co_qualname == 'singledispatchmethod.__get__'
#
# New to extra110.
# ---------------------------------------------------------------------------

table functools_extra110.code_co_qualname:
  description: "functools __code__.co_qualname values (Python 3.11+); top-level functions match simple name; methods use 'ClassName.method' pattern; wave 258; new to extra110"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolscoqn110

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_co_qualname_eq,
       "lru_cache.__code__.co_qualname.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__code__.co_qualname.__eq__('lru_cache') == True — co_qualname (added Python 3.11) records the qualified name of the function as seen in its code object; for top-level functions co_qualname equals the simple function name; str.__eq__('lru_cache') returns True; new to extra110"]
    - [total_ordering_co_qualname_eq,
       "total_ordering.__code__.co_qualname.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__code__.co_qualname.__eq__('total_ordering') == True — co_qualname for the top-level total_ordering function is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra110"]
    - [wraps_co_qualname_eq,
       "wraps.__code__.co_qualname.__eq__",
       ["wraps"],
       true,
       "functools.wraps.__code__.co_qualname.__eq__('wraps') == True — co_qualname for the top-level wraps function is 'wraps'; str.__eq__('wraps') returns True; new to extra110"]
    - [update_wrapper_co_qualname_eq,
       "update_wrapper.__code__.co_qualname.__eq__",
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__code__.co_qualname.__eq__('update_wrapper') == True — co_qualname for the top-level update_wrapper function is 'update_wrapper'; str.__eq__('update_wrapper') returns True; new to extra110"]
    - [singledispatch_co_qualname_eq,
       "singledispatch.__code__.co_qualname.__eq__",
       ["singledispatch"],
       true,
       "functools.singledispatch.__code__.co_qualname.__eq__('singledispatch') == True — co_qualname for top-level singledispatch is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra110"]
    - [cached_property_init_co_qualname_eq,
       "cached_property.__init__.__code__.co_qualname.__eq__",
       ["cached_property.__init__"],
       true,
       "functools.cached_property.__init__.__code__.co_qualname.__eq__('cached_property.__init__') == True — methods defined inside a class have co_qualname equal to 'ClassName.method_name'; cached_property.__init__.__code__.co_qualname is 'cached_property.__init__'; str.__eq__('cached_property.__init__') returns True; new to extra110"]
    - [singledispatchmethod_get_co_qualname_eq,
       "singledispatchmethod.__get__.__code__.co_qualname.__eq__",
       ["singledispatchmethod.__get__"],
       true,
       "functools.singledispatchmethod.__get__.__code__.co_qualname.__eq__('singledispatchmethod.__get__') == True — co_qualname for a method follows the 'ClassName.method_name' pattern; singledispatchmethod.__get__.__code__.co_qualname is 'singledispatchmethod.__get__'; str.__eq__('singledispatchmethod.__get__') returns True; new to extra110"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra110
# ---------------------------------------------------------------------------

invariant functools_extra110.cached_property_init_module:
  description: "functools.cached_property.__init__.__module__ == 'functools' — method defined in Lib/functools.py; wave 258; new to extra110"
  kind: python_call_eq
  function: cached_property.__init__.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra110.singledispatchmethod_get_module:
  description: "functools.singledispatchmethod.__get__.__module__ == 'functools' — method defined in Lib/functools.py; wave 258; new to extra110"
  kind: python_call_eq
  function: singledispatchmethod.__get__.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra110.lru_cache_co_qualname:
  description: "functools.lru_cache.__code__.co_qualname == 'lru_cache' — top-level function co_qualname equals simple name; Python 3.11+; wave 258; new to extra110"
  kind: python_call_eq
  function: lru_cache.__code__.co_qualname.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra110.singledispatch_module:
  description: "functools.singledispatch.__module__ == 'functools' — pure-Python function in Lib/functools.py; wave 258; new to extra110"
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra110.cached_property_init_co_qualname:
  description: "functools.cached_property.__init__.__code__.co_qualname == 'cached_property.__init__' — method co_qualname uses ClassName.method pattern; Python 3.11+; wave 258; new to extra110"
  kind: python_call_eq
  function: cached_property.__init__.__code__.co_qualname.__eq__
  args: ["cached_property.__init__"]
  expected: true
