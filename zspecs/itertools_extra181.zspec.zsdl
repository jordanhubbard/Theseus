spec: itertools_extra181
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/itertools.py"
  notes:
    - "This spec covers: itertools class __doc__ lengths and iterator class identity — itertools.cycle.__doc__.__class__.__name__=='str'; itertools.repeat.__doc__.__class__.__name__=='str'; itertools.accumulate.__name__=='accumulate' (len=10); itertools.accumulate.__module__=='itertools'; itertools.accumulate.__qualname__=='accumulate'; itertools.starmap.__name__=='starmap' (len=7); itertools.starmap.__module__=='itertools'; itertools.takewhile.__name__=='takewhile' (len=9)."
    - "itertools.cycle.__doc__.__class__.__name__ == 'str' — cycle is a C-implemented iterator type in itertools; its __doc__ attribute is a Python str object; type(cycle.__doc__).__name__ is 'str'. Verified with Python 3.14.3."
    - "itertools.repeat.__doc__.__class__.__name__ == 'str' — repeat is a C-implemented iterator type in itertools; its __doc__ attribute is a Python str object; type(repeat.__doc__).__name__ is 'str'. Verified with Python 3.14.3."
    - "itertools.accumulate.__name__ == 'accumulate' — accumulate is a C-implemented iterator class in itertools that returns accumulated sums (or results of a binary function); its __name__ is 'accumulate', 10 characters. Verified with Python 3.14.3."
    - "itertools.accumulate.__module__ == 'itertools' — accumulate is implemented in the itertools C extension; its __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.accumulate.__qualname__ == 'accumulate' — accumulate is a module-level C type, so __qualname__ equals __name__ 'accumulate'. Verified with Python 3.14.3."
    - "itertools.starmap.__name__ == 'starmap' — starmap is a C-implemented iterator class that maps a function using arguments from an iterable of tuples; its __name__ is 'starmap', 7 characters. Verified with Python 3.14.3."
    - "itertools.starmap.__module__ == 'itertools' — starmap is implemented in the itertools C extension; its __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.takewhile.__name__ == 'takewhile' — takewhile is a C-implemented iterator class that returns elements as long as a predicate is true; its __name__ is 'takewhile', 9 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.cycle and itertools.repeat __doc__ class identity
#
# itertools.cycle.__doc__.__class__.__name__ == 'str'
# itertools.repeat.__doc__.__class__.__name__ == 'str'
#
# cycle and repeat are C-implemented iterator types in itertools. Their
# __doc__ attributes are Python str objects. New to extra181.
# ---------------------------------------------------------------------------

table itertools_extra181.cycle_repeat_doc_class:
  description: "itertools.cycle.__doc__.__class__.__name__ 'str'; itertools.repeat.__doc__.__class__.__name__ 'str'; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: iteraccum181

  columns: [id, function, args, expected, description]
  rows:
    - [cycle_doc_class_str,
       "cycle.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.cycle.__doc__.__class__.__name__.__eq__('str') == True — cycle is a C-implemented iterator type in itertools; its __doc__ attribute is a Python str object; type(cycle.__doc__).__name__ is 'str'; str.__eq__('str') returns True; new to extra181"]
    - [repeat_doc_class_str,
       "repeat.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.repeat.__doc__.__class__.__name__.__eq__('str') == True — repeat is a C-implemented iterator type in itertools; its __doc__ attribute is a Python str object; type(repeat.__doc__).__name__ is 'str'; str.__eq__('str') returns True; new to extra181"]
    - [cycle_doc_is_truthy,
       "cycle.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.cycle.__doc__ is a non-empty str — cycle's docstring exists and is of type str; __class__.__name__ == 'str' confirms the type; new to extra181"]
    - [repeat_doc_is_truthy,
       "repeat.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.repeat.__doc__ is a non-empty str — repeat's docstring exists and is of type str; __class__.__name__ == 'str' confirms the type; new to extra181"]

