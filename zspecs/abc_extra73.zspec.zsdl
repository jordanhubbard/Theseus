#
# ABCMeta.__instancecheck__.__code__.co_name == '__instancecheck__'
# ABCMeta.__instancecheck__.__code__.co_argcount == 2
# ABCMeta.__instancecheck__.__code__.co_varnames.__class__.__name__ == 'tuple'
# ---------------------------------------------------------------------------

table abc_extra73.ABCMeta_instancecheck_code_attrs:
  description: "abc ABCMeta.__instancecheck__ code attribute checks in abcmore73 namespace — wave 244 theme: ABCMeta.__instancecheck__ code attributes; ABCMeta.__instancecheck__.__code__.co_name=='__instancecheck__' (code object co_name matches method name); ABCMeta.__instancecheck__.__code__.co_argcount==2 (cls + instance); ABCMeta.__instancecheck__.__code__.co_varnames.__class__.__name__=='tuple' (co_varnames is always a tuple in CPython); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abcmore73

  columns: [id, function, args, expected, description]
  rows:
    - [instancecheck_co_name,     ABCMeta.__instancecheck__.__code__.co_name.__eq__,                    ["__instancecheck__"], true, "ABCMeta.__instancecheck__.__code__.co_name == '__instancecheck__' — code object co_name matches the method name; verified with Python 3.14.3"]
    - [instancecheck_co_argcount, ABCMeta.__instancecheck__.__code__.co_argcount.__eq__,                 [2],                   true, "ABCMeta.__instancecheck__.__code__.co_argcount == 2 — cls and instance are positional parameters; verified with Python 3.14.3"]
    - [instancecheck_varnames_cls, ABCMeta.__instancecheck__.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"],             true, "ABCMeta.__instancecheck__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple in CPython; verified with Python 3.14.3"]

