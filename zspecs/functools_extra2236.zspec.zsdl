spec: functools_extra2236
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2236: __slots__ and slot descriptor protocol — checking __slots__, __weakref__, __dict__, __abstractmethods__ presence in class dicts."
    - "functools.partial is a C extension type: no __slots__ (C types use tp_members), no __weakref__ slot, but __dict__ IS in its class dict (supports per-instance dicts), no __abstractmethods__."
    - "functools.partialmethod is a pure-Python class: no __slots__, has __weakref__ (supports weak refs), has __dict__, no __abstractmethods__."
    - "functools.cached_property is a pure-Python descriptor: no __slots__, has __weakref__, has __dict__, no __abstractmethods__, defines __init__ but not __new__."
    - "functools._lru_cache_wrapper is a C extension type: no __slots__, no __weakref__, has __dict__, no __abstractmethods__, defines __new__ but not __init__."
    - "functools.singledispatchmethod is a pure-Python class: no __slots__, has __weakref__, has __dict__, no __abstractmethods__, defines __init__."
    - "functools._CacheInfo is a namedtuple subclass: has __slots__ (empty tuple from namedtuple), no __weakref__, no __dict__, no __abstractmethods__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table functools_extra2236.partial_slot_protocol:
  description: "functools.partial slot descriptor protocol — C extension type, no __slots__ key, __dict__ present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2236

  columns: [id, function, args, expected]
  rows:
    - ["ft2236001", "functools.partial.__dict__.__contains__", ["__slots__"], false]
    - ["ft2236002", "functools.partial.__dict__.__contains__", ["__weakref__"], false]
    - ["ft2236003", "functools.partial.__dict__.__contains__", ["__dict__"], true]
    - ["ft2236004", "functools.partial.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["ft2236005", "functools.partial.__dict__.__contains__", ["__init__"], false]
    - ["ft2236006", "functools.partial.__dict__.__contains__", ["__new__"], true]
    - ["ft2236007", "functools.partial.__dict__.__contains__", ["__subclasshook__"], false]

