spec: cProfile_extra
version: ">=3.x"
backend: python_module(cProfile)

docs: https://docs.python.org/3/library/profile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/profile.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_lsprof.c"
  notes:
    - "This spec extends cProfile.zspec.zsdl."
    - "cProfile.zspec.zsdl covers: Profile/__name__/__module__; run/__name__; runctx/__name__; Profile method __name__ checks for enable/disable/clear/print_stats/dump_stats/runcall/runctx."
    - "This spec adds: Profile/__qualname__; run/__qualname__/__module__; runctx/__qualname__/__module__ — not covered in cProfile.zspec.zsdl."
    - "cProfile.Profile.__qualname__ == 'Profile' — top-level class; qualname equals name."
    - "cProfile.run.__qualname__ == 'run' — module-level function; qualname equals name."
    - "cProfile.runctx.__qualname__ == 'runctx' — module-level function; qualname equals name."
    - "cProfile.run.__module__ == 'cProfile' — run is defined in the cProfile module."
    - "cProfile.runctx.__module__ == 'cProfile' — runctx is defined in the cProfile module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Profile.__qualname__ — not covered by cProfile.zspec.zsdl
# Top-level class: __qualname__ == __name__ == 'Profile'.
# ---------------------------------------------------------------------------

invariant cProfile_extra.Profile.qualname:
  description: "cProfile.Profile.__qualname__ == 'Profile' — top-level class qualname matches name"
  category: classes
  kind: python_call_eq
  function: Profile.__qualname__.__eq__
  args: ["Profile"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function __qualname__ and __module__
# cProfile.zspec.zsdl checks __name__ for run and runctx; this spec adds __qualname__ and __module__.
# ---------------------------------------------------------------------------

table cProfile_extra.function_qualnames_and_modules:
  kind: python_call_eq
  category: functions
  id_prefix: func

  columns: [id, function, args, expected]
  rows:
    - [run_qualname,    run.__qualname__.__eq__,    ["run"],      true]
    - [run_module,      run.__module__.__eq__,      ["cProfile"], true]
    - [runctx_qualname, runctx.__qualname__.__eq__, ["runctx"],   true]
    - [runctx_module,   runctx.__module__.__eq__,   ["cProfile"], true]
