spec: inspect_extra236
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect.Parameter class identity and inspect.Parameter.empty sentinel contracts."
    - "inspect.Parameter.__name__ == 'Parameter' (len=9) — the class name. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect' (len=7) — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Parameter.__qualname__ == 'Parameter' (len=9). Verified with Python 3.14.3."
    - "inspect.Parameter.__class__.__name__ == 'type' — Parameter is a Python class. Verified with Python 3.14.3."
    - "inspect.Parameter.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__name__ == '_empty' (len=6) — the sentinel class name. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__module__ == 'inspect' (len=7) — _empty is defined in inspect. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__class__.__name__ == 'type' — empty is itself a class. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__qualname__ == '_empty' — top-level sentinel class. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter class identity contracts
#
# inspect.Parameter.__name__ == 'Parameter' (len=9)
# inspect.Parameter.__module__ == 'inspect' (len=7)
# inspect.Parameter.__qualname__ == 'Parameter' (len=9)
# inspect.Parameter.__class__.__name__ == 'type'
# inspect.Parameter.__bases__[0].__name__ == 'object'
#
# Parameter is a Python class in Lib/inspect.py. New to extra236.
# ---------------------------------------------------------------------------

table inspect_extra236.parameter_class_identity:
  description: "inspect.Parameter class identity: name, module, qualname, metaclass type, base object; new to extra236"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra236paramclassid

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_name_eq,
       Parameter.__name__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter is a Python class in Lib/inspect.py representing a function parameter; __name__ is 'Parameter' (len=9); new to extra236"]
    - [parameter_name_len_9,
       Parameter.__name__.__len__,
       [],
       9,
       "inspect.Parameter.__name__.__len__() == 9 — 'Parameter' has exactly 9 characters (P-a-r-a-m-e-t-e-r); str.__len__() returns 9; new to extra236"]
    - [parameter_module_eq,
       Parameter.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra236"]
    - [parameter_qualname_eq,
       Parameter.__qualname__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__.__eq__('Parameter') == True — Parameter is a top-level class with unqualified qualname 'Parameter'; new to extra236"]
    - [parameter_class_is_type,
       Parameter.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Parameter.__class__.__name__.__eq__('type') == True — Parameter is a Python class; its metaclass is the built-in type; new to extra236"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter.empty sentinel contracts
#
# inspect.Parameter.empty.__name__ == '_empty' (len=6)
# inspect.Parameter.empty.__module__ == 'inspect' (len=7)
# inspect.Parameter.empty.__qualname__ == '_empty' (len=6)
# inspect.Parameter.empty.__class__.__name__ == 'type'
# inspect.Parameter.__bases__[0].__name__ == 'object'
#
# Parameter.empty is a sentinel class used to detect missing default values. New to extra236.
# ---------------------------------------------------------------------------

table inspect_extra236.parameter_empty_sentinel:
  description: "inspect.Parameter.empty sentinel: name '_empty', module 'inspect', class is type, qualname; new to extra236"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra236emptyid

  columns: [id, function, args, expected, description]
  rows:
    - [empty_name_eq,
       Parameter.empty.__name__.__eq__,
       ["_empty"],
       true,
       "inspect.Parameter.empty.__name__.__eq__('_empty') == True — Parameter.empty is a sentinel class with __name__ '_empty' (len=6); used to indicate missing default/annotation values; new to extra236"]
    - [empty_name_len_6,
       Parameter.empty.__name__.__len__,
       [],
       6,
       "inspect.Parameter.empty.__name__.__len__() == 6 — '_empty' has exactly 6 characters (_-e-m-p-t-y); str.__len__() returns 6; new to extra236"]
    - [empty_module_eq,
       Parameter.empty.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Parameter.empty.__module__.__eq__('inspect') == True — _empty sentinel is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra236"]
    - [empty_qualname_eq,
       Parameter.empty.__qualname__.__eq__,
       ["_empty"],
       true,
       "inspect.Parameter.empty.__qualname__.__eq__('_empty') == True — _empty sentinel has unqualified qualname '_empty'; new to extra236"]
    - [empty_class_is_type,
       Parameter.empty.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is itself a class (a sentinel class); its metaclass is the built-in type; new to extra236"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter module length, base, and doc contracts
#
# inspect.Parameter.__module__.__len__() == 7
# inspect.Parameter.__bases__[0].__name__ == 'object'
# inspect.Parameter.empty.__module__.__len__() == 7
# inspect.Parameter.empty.__name__.__len__() == 6
# inspect.Parameter.__name__.__len__() == 9
#
# Additional length and base contracts for Parameter and empty. New to extra236.
# ---------------------------------------------------------------------------

table inspect_extra236.parameter_lengths_and_base:
  description: "inspect.Parameter module length 7; base is object; empty module length 7; name lengths; new to extra236"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra236paramlenbase

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_module_len_7,
       Parameter.__module__.__len__,
       [],
       7,
       "inspect.Parameter.__module__.__len__() == 7 — 'inspect' has exactly 7 characters (i-n-s-p-e-c-t); str.__len__() returns 7; new to extra236"]
    - [parameter_base_is_object,
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter inherits directly from object; __bases__[0].__name__ is 'object'; new to extra236"]
    - [empty_module_len_7,
       Parameter.empty.__module__.__len__,
       [],
       7,
       "inspect.Parameter.empty.__module__.__len__() == 7 — 'inspect' has exactly 7 characters; the empty sentinel is also in the inspect module; str.__len__() returns 7; new to extra236"]
    - [empty_qualname_len_6,
       Parameter.empty.__qualname__.__len__,
       [],
       6,
       "inspect.Parameter.empty.__qualname__.__len__() == 6 — '_empty' qualname has exactly 6 characters; str.__len__() returns 6; new to extra236"]
    - [parameter_qualname_len_9,
       Parameter.__qualname__.__len__,
       [],
       9,
       "inspect.Parameter.__qualname__.__len__() == 9 — 'Parameter' qualname has exactly 9 characters; str.__len__() returns 9; new to extra236"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra236
# ---------------------------------------------------------------------------

invariant inspect_extra236.parameter_name_eq:
  description: "inspect.Parameter.__name__ == 'Parameter' (len=9); new to extra236"
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra236.parameter_name_len_9:
  description: "inspect.Parameter.__name__.__len__() == 9 — 'Parameter' has 9 characters; new to extra236"
  kind: python_call_eq
  function: Parameter.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra236.parameter_module_eq:
  description: "inspect.Parameter.__module__ == 'inspect'; new to extra236"
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra236.parameter_module_len_7:
  description: "inspect.Parameter.__module__.__len__() == 7 — 'inspect' has 7 characters; new to extra236"
  kind: python_call_eq
  function: Parameter.__module__.__len__
  args: []
  expected: 7

invariant inspect_extra236.parameter_qualname_eq:
  description: "inspect.Parameter.__qualname__ == 'Parameter'; new to extra236"
  kind: python_call_eq
  function: Parameter.__qualname__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra236.parameter_class_is_type:
  description: "inspect.Parameter.__class__.__name__ == 'type'; new to extra236"
  kind: python_call_eq
  function: Parameter.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra236.parameter_base_is_object:
  description: "inspect.Parameter.__bases__[0].__name__ == 'object'; new to extra236"
  kind: python_call_eq
  function: "Parameter.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra236.empty_name_eq:
  description: "inspect.Parameter.empty.__name__ == '_empty' (len=6); new to extra236"
  kind: python_call_eq
  function: Parameter.empty.__name__.__eq__
  args: ["_empty"]
  expected: true

invariant inspect_extra236.empty_name_len_6:
  description: "inspect.Parameter.empty.__name__.__len__() == 6 — '_empty' has 6 characters; new to extra236"
  kind: python_call_eq
  function: Parameter.empty.__name__.__len__
  args: []
  expected: 6

invariant inspect_extra236.empty_module_eq:
  description: "inspect.Parameter.empty.__module__ == 'inspect'; new to extra236"
  kind: python_call_eq
  function: Parameter.empty.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra236.empty_module_len_7:
  description: "inspect.Parameter.empty.__module__.__len__() == 7 — 'inspect' has 7 characters; new to extra236"
  kind: python_call_eq
  function: Parameter.empty.__module__.__len__
  args: []
  expected: 7

invariant inspect_extra236.empty_qualname_eq:
  description: "inspect.Parameter.empty.__qualname__ == '_empty'; new to extra236"
  kind: python_call_eq
  function: Parameter.empty.__qualname__.__eq__
  args: ["_empty"]
  expected: true

invariant inspect_extra236.empty_class_is_type:
  description: "inspect.Parameter.empty.__class__.__name__ == 'type' — empty sentinel is a class; new to extra236"
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true
