spec: signal_extra
version: ">=3.8"
backend: python_module(signal)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "Python signal documentation — https://docs.python.org/3/library/signal.html"
    - "POSIX.1-2017 — The Open Group Base Specifications Issue 7, 2018 Edition"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
  notes:
    - "This spec extends signal.zspec.zsdl with aspects not covered there."
    - "signal.__name__ is 'signal' — the module's own __name__ attribute."
    - "getsignal.__name__ == 'getsignal' — the function is named getsignal."
    - "raise_signal.__name__ == 'raise_signal' — available since Python 3.8."
    - "strsignal.__name__ == 'strsignal' — available since Python 3.8."
    - "valid_signals.__name__ == 'valid_signals' — returns the set of valid signal numbers."
    - "SIG_DFL and SIG_IGN are members of the Handlers enum; their __class__.__name__ is 'Handlers'."
    - "SIGABRT, SIGFPE, SIGILL, SIGINT, SIGSEGV, SIGTERM are members of the Signals enum; __class__.__name__ is 'Signals'."
    - "SIGINT == 2 and SIGTERM == 15 are POSIX-mandated values consistent across Linux/macOS/BSD."
    - "valid_signals() returns a set; set.__class__.__name__ == 'set'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module and function name checks
# ---------------------------------------------------------------------------

table signal_extra.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, description, function, args, expected]
  rows:
    - [getsignal,     "getsignal.__name__ == 'getsignal'",         getsignal.__name__.__eq__,     ["getsignal"],     true]
    - [raise_signal,  "raise_signal.__name__ == 'raise_signal'",   raise_signal.__name__.__eq__,  ["raise_signal"],  true]
    - [strsignal,     "strsignal.__name__ == 'strsignal'",         strsignal.__name__.__eq__,     ["strsignal"],     true]
    - [valid_signals, "valid_signals.__name__ == 'valid_signals'", valid_signals.__name__.__eq__, ["valid_signals"], true]

# ---------------------------------------------------------------------------
# SIG_DFL and SIG_IGN — members of the Handlers enum
# ---------------------------------------------------------------------------

invariant signal_extra.SIG_DFL_class_name:
  description: "SIG_DFL.__class__.__name__ == 'Handlers' — SIG_DFL is a Handlers enum member"
  category: handlers
  kind: python_call_eq
  function: SIG_DFL.__class__.__name__.__eq__
  args: ["Handlers"]
  expected: true

invariant signal_extra.SIG_IGN_class_name:
  description: "SIG_IGN.__class__.__name__ == 'Handlers' — SIG_IGN is a Handlers enum member"
  category: handlers
  kind: python_call_eq
  function: SIG_IGN.__class__.__name__.__eq__
  args: ["Handlers"]
  expected: true

# ---------------------------------------------------------------------------
# Signal constants — class membership checks (Signals enum)
# ---------------------------------------------------------------------------

table signal_extra.signal_class_names:
  kind: python_call_eq
  category: signals_enum
  id_prefix: sig_class

  columns: [id, description, function, args, expected]
  rows:
    - [SIGABRT, "SIGABRT.__class__.__name__ == 'Signals'", SIGABRT.__class__.__name__.__eq__, ["Signals"], true]
    - [SIGFPE,  "SIGFPE.__class__.__name__ == 'Signals'",  SIGFPE.__class__.__name__.__eq__,  ["Signals"], true]
    - [SIGILL,  "SIGILL.__class__.__name__ == 'Signals'",  SIGILL.__class__.__name__.__eq__,  ["Signals"], true]
    - [SIGINT,  "SIGINT.__class__.__name__ == 'Signals'",  SIGINT.__class__.__name__.__eq__,  ["Signals"], true]
    - [SIGSEGV, "SIGSEGV.__class__.__name__ == 'Signals'", SIGSEGV.__class__.__name__.__eq__, ["Signals"], true]
    - [SIGTERM, "SIGTERM.__class__.__name__ == 'Signals'", SIGTERM.__class__.__name__.__eq__, ["Signals"], true]

# ---------------------------------------------------------------------------
# POSIX-mandated integer values for SIGINT and SIGTERM
# (already in signal.zspec.zsdl table; repeated here as standalone invariants
#  for cross-referencing, with distinct invariant IDs)
# ---------------------------------------------------------------------------

invariant signal_extra.SIGINT_eq_2:
  description: "SIGINT == 2 — POSIX.1 requires SIGINT to be signal number 2"
  category: posix_values
  kind: python_call_eq
  function: SIGINT.__eq__
  args: [2]
  expected: true

invariant signal_extra.SIGTERM_eq_15:
  description: "SIGTERM == 15 — POSIX.1 requires SIGTERM to be signal number 15"
  category: posix_values
  kind: python_call_eq
  function: SIGTERM.__eq__
  args: [15]
  expected: true

# ---------------------------------------------------------------------------
# valid_signals() — return type
# ---------------------------------------------------------------------------

invariant signal_extra.valid_signals_returns_set:
  description: "valid_signals().__class__.__name__ == 'set' — valid_signals() returns a set"
  category: valid_signals
  kind: python_call_eq
  function: valid_signals().__class__.__name__.__eq__
  args: ["set"]
  expected: true

invariant signal_extra.valid_signals_nonempty:
  description: "len(valid_signals()) > 0 — there is at least one valid signal"
  category: valid_signals
  kind: python_call_eq
  function: valid_signals().__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true

invariant signal_extra.valid_signals_contains_sigint:
  description: "SIGINT in valid_signals() — SIGINT is always a valid signal"
  category: valid_signals
  kind: python_call_eq
  function: valid_signals().__contains__
  args: [2]
  expected: true

invariant signal_extra.valid_signals_contains_sigterm:
  description: "SIGTERM in valid_signals() — SIGTERM is always a valid signal"
  category: valid_signals
  kind: python_call_eq
  function: valid_signals().__contains__
  args: [15]
  expected: true
