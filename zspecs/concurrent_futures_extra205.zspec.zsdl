table concurrent_futures_extra205.wait_covarnames:
  description: "concurrent.futures.wait __code__.co_varnames type and membership checks in cfcovarnames205 namespace — wait.__code__.co_varnames.__class__.__name__=='tuple' (co_varnames is always a tuple of parameter and local variable name strings); co_varnames.__contains__('fs')==True ('fs' is the first positional param of wait(fs, timeout=None, return_when=ALL_COMPLETED)); co_varnames.__contains__('timeout')==True; co_varnames.__contains__('return_when')==True; full co_varnames on 3.14.3 is ('fs', 'timeout', 'return_when', 'f', 'done', 'not_done', 'waiter'); verified with Python 3.14.3"
  kind: python_call_eq
  category: covarnames
  id_prefix: cfcovarnames205

  columns: [id, function, args, expected, description]
  rows:
    - [wait_covarnames_class_name,      "concurrent.futures.wait.__code__.co_varnames.__class__.__name__.__eq__",   ["tuple"],       true, "concurrent.futures.wait.__code__.co_varnames.__class__.__name__ == 'tuple'; verified Python 3.14.3"]
    - [wait_covarnames_has_fs,          "concurrent.futures.wait.__code__.co_varnames.__contains__",                ["fs"],          true, "concurrent.futures.wait.__code__.co_varnames.__contains__('fs') — fs is first param; verified Python 3.14.3"]
    - [wait_covarnames_has_timeout,     "concurrent.futures.wait.__code__.co_varnames.__contains__",                ["timeout"],     true, "concurrent.futures.wait.__code__.co_varnames.__contains__('timeout'); verified Python 3.14.3"]
    - [wait_covarnames_has_return_when, "concurrent.futures.wait.__code__.co_varnames.__contains__",                ["return_when"], true, "concurrent.futures.wait.__code__.co_varnames.__contains__('return_when'); verified Python 3.14.3"]

