table concurrent_futures_extra205.future_dict_membership:
  description: "concurrent.futures.Future.__dict__ membership checks in cfcovarnames205 namespace — Future.__dict__.__contains__('result')==True (Future.result(timeout=None) blocks until the future completes and returns the result or re-raises the exception); Future.__dict__.__contains__('cancel')==True (Future.cancel() attempts to cancel the future before it is running); Future.__dict__.__contains__('done')==True (Future.done() returns True when the future is finished); Future.__dict__.__contains__('add_done_callback')==True; all four methods are defined directly in concurrent.futures._base.Future on Python 3.14.3; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: cfcovarnames205a

  columns: [id, function, args, expected, description]
  rows:
    - [future_dict_has_result,            "concurrent.futures.Future.__dict__.__contains__",   ["result"],            true, "concurrent.futures.Future.__dict__.__contains__('result') == True; verified Python 3.14.3"]
    - [future_dict_has_cancel,            "concurrent.futures.Future.__dict__.__contains__",   ["cancel"],            true, "concurrent.futures.Future.__dict__.__contains__('cancel') == True; verified Python 3.14.3"]
    - [future_dict_has_done,              "concurrent.futures.Future.__dict__.__contains__",   ["done"],              true, "concurrent.futures.Future.__dict__.__contains__('done') == True; verified Python 3.14.3"]
