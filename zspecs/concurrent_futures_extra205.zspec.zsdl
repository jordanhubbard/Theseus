spec: concurrent_futures_extra205
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py, Lib/concurrent/futures/thread.py"
  notes:
    - "concurrent.futures.wait.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple; wait co_varnames is ('fs', 'timeout', 'return_when', 'f', 'done', 'not_done', 'waiter') on Python 3.14.3."
    - "concurrent.futures.wait.__code__.co_varnames.__contains__('fs') returns True — 'fs' is the first positional parameter of wait(fs, timeout=None, return_when=ALL_COMPLETED)."
    - "concurrent.futures.Future.__dict__.__contains__('result') returns True — Future.result() is defined directly in the _base.py class body."
    - "concurrent.futures.Future.__dict__.__contains__('cancel') returns True — Future.cancel() is defined directly on the Future class."
    - "concurrent.futures.Executor.__dict__.__contains__('submit') returns True — Executor.submit() is defined in the abstract base class in _base.py."
    - "concurrent.futures.Future public non-dunder dict keys: cancel, cancelled, running, done, add_done_callback, result, exception, set_running_or_notify_cancel, set_result, set_exception."
    - "concurrent.futures.Executor dict keys: __module__, __firstlineno__, __doc__, submit, map, shutdown, __enter__, __exit__, __static_attributes__, __dict__, __weakref__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

