    - [executor_dict_has_map,       "concurrent.futures.Executor.__dict__.__contains__",   ["map"],       true, "concurrent.futures.Executor.__dict__.__contains__('map') == True; verified Python 3.14.3"]
    - [executor_dict_has_shutdown,  "concurrent.futures.Executor.__dict__.__contains__",   ["shutdown"],  true, "concurrent.futures.Executor.__dict__.__contains__('shutdown') == True; verified Python 3.14.3"]
    - [executor_dict_has_enter,     "concurrent.futures.Executor.__dict__.__contains__",   ["__enter__"], true, "concurrent.futures.Executor.__dict__.__contains__('__enter__') == True; verified Python 3.14.3"]

