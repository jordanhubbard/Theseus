table concurrent_futures_extra205.executor_dict_membership:
  description: "concurrent.futures.Executor.__dict__ membership checks in cfcovarnames205 namespace — Executor.__dict__.__contains__('submit')==True (Executor.submit() is the abstract method to be overridden by ThreadPoolExecutor and ProcessPoolExecutor; defined in _base.Executor); Executor.__dict__.__contains__('map')==True (Executor.map() is a concrete method defined on the base class); Executor.__dict__.__contains__('shutdown')==True; Executor.__dict__.__contains__('__enter__')==True (Executor implements context manager protocol); all methods defined directly on Executor in _base.py on Python 3.14.3; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: cfcovarnames205b

  columns: [id, function, args, expected, description]
