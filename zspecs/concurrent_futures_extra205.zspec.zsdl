invariant concurrent_futures_extra205.wait_covarnames_class_name_tuple:
  description: "concurrent.futures.wait.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — concurrent.futures.wait.__code__.co_varnames is always a tuple of local variable name strings; wait co_varnames on Python 3.14.3 is ('fs', 'timeout', 'return_when', 'f', 'done', 'not_done', 'waiter') (length 7); co_varnames.__class__.__name__ is 'tuple' (len=5: t-u-p-l-e); NEW in extra205: first standalone cf.wait co_varnames class name invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: covarnames
  kind: python_call_eq
  function: concurrent.futures.wait.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant concurrent_futures_extra205.wait_covarnames_contains_fs:
  description: "concurrent.futures.wait.__code__.co_varnames.__contains__('fs') returns True — 'fs' is the first positional parameter of concurrent.futures.wait(fs, timeout=None, return_when=ALL_COMPLETED); fs is the collection of Future instances to wait on; 'fs' appears as the first element in co_varnames ('fs', 'timeout', 'return_when', 'f', 'done', 'not_done', 'waiter') on Python 3.14.3; NEW in extra205; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: covarnames
  kind: python_call_eq
  function: concurrent.futures.wait.__code__.co_varnames.__contains__
  args: ["fs"]
  expected: true

invariant concurrent_futures_extra205.future_dict_contains_result:
  description: "concurrent.futures.Future.__dict__.__contains__('result') returns True — concurrent.futures.Future defines result() directly in its class body in Lib/concurrent/futures/_base.py; Future.result(timeout=None) blocks until the future completes and then returns the result or raises the stored exception; 'result' is in Future.__dict__ (not inherited); NEW in extra205; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["result"]
  expected: true

invariant concurrent_futures_extra205.future_dict_contains_cancel:
  description: "concurrent.futures.Future.__dict__.__contains__('cancel') returns True — concurrent.futures.Future defines cancel() directly on the class; Future.cancel() attempts to cancel the future — returns True if the future was successfully cancelled (only possible if it has not started running yet); 'cancel' is in Future.__dict__ (not inherited); NEW in extra205; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["cancel"]
  expected: true

invariant concurrent_futures_extra205.executor_dict_contains_submit:
  description: "concurrent.futures.Executor.__dict__.__contains__('submit') returns True — concurrent.futures.Executor defines submit() directly in its class body in Lib/concurrent/futures/_base.py; Executor.submit(fn, /, *args, **kwargs) is the primary method for scheduling a callable to be executed; ThreadPoolExecutor and ProcessPoolExecutor override it; 'submit' is in Executor.__dict__; NEW in extra205; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.Executor.__dict__.__contains__
  args: ["submit"]
  expected: true

invariant concurrent_futures_extra205.wait_covarnames_len:
  description: "concurrent.futures.wait.__code__.co_varnames.__len__() returns 7 — wait co_varnames has exactly 7 entries on Python 3.14.3: ('fs', 'timeout', 'return_when', 'f', 'done', 'not_done', 'waiter'); 'fs', 'timeout', 'return_when' are parameters; 'f', 'done', 'not_done', 'waiter' are local variables; len==7 confirms the exact tuple length; NEW in extra205; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: covarnames
  kind: python_call_eq
  function: concurrent.futures.wait.__code__.co_varnames.__len__
  args: []
  expected: 7

invariant concurrent_futures_extra205.future_dict_contains_done:
  description: "concurrent.futures.Future.__dict__.__contains__('done') returns True — concurrent.futures.Future defines done() directly on the class; Future.done() returns True when the future has finished executing (completed normally, raised an exception, or was cancelled); 'done' is in Future.__dict__ (not inherited from a base class); NEW in extra205; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["done"]
  expected: true

invariant concurrent_futures_extra205.executor_dict_contains_map:
  description: "concurrent.futures.Executor.__dict__.__contains__('map') returns True — concurrent.futures.Executor defines map() directly on the abstract base class; Executor.map(fn, *iterables, timeout=None, chunksize=1) is a concrete method that applies fn to every element of iterables concurrently using submit(); 'map' is in Executor.__dict__; Executor.map is not abstract — subclasses do not need to override it; NEW in extra205; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.Executor.__dict__.__contains__
  args: ["map"]
  expected: true

