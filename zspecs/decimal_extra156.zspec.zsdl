spec: decimal_extra156
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal __format__ and __round__ method qualnames, decimal.Context __init__ and __repr__ qualnames, and rounding constants ROUND_CEILING and ROUND_FLOOR."
    - "All Decimal and Context method qualnames follow the 'ClassName.<method>' pattern. 'Decimal.' prefix is 8 characters; 'Context.' prefix is 8 characters."
    - "decimal.Decimal.__format__.__qualname__ == 'Decimal.__format__' (len=18; 'Decimal.' (8) + '__format__' (10) = 18)."
    - "decimal.Decimal.__round__.__qualname__ == 'Decimal.__round__' (len=17; 'Decimal.' (8) + '__round__' (9) = 17)."
    - "decimal.Context.__init__.__qualname__ == 'Context.__init__' (len=16; 'Context.' (8) + '__init__' (8) = 16)."
    - "decimal.Context.__repr__.__qualname__ == 'Context.__repr__' (len=16; 'Context.' (8) + '__repr__' (8) = 16; tied with __init__ at 16)."
    - "decimal.ROUND_CEILING == 'ROUND_CEILING' (len=13; a string constant for rounding away from zero)."
    - "decimal.ROUND_FLOOR == 'ROUND_FLOOR' (len=11; a string constant for rounding towards negative infinity)."
    - "Two-way tie at 16: Context.__init__ and Context.__repr__ — both 8-character dunder names."
    - "ROUND_CEILING (13) and ROUND_FLOOR (11) differ by 2 characters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal __format__ and __round__ method __qualname__ values
# __format__ = 'Decimal.__format__' (len=18)
# __round__  = 'Decimal.__round__'  (len=17)
# __format__ is longer than __round__ by 1 character.
# 'Decimal.' prefix is 8 characters.
# ---------------------------------------------------------------------------

table decimal_extra156.Decimal_format_round_qualnames:
  description: "decimal.Decimal __format__ and __round__ __qualname__ values: __format__='Decimal.__format__' (len=18), __round__='Decimal.__round__' (len=17); __format__ is longer by 1 character; both use 'Decimal.' prefix"
  kind: python_call_eq
  category: qualname
  id_prefix: decfmtq156

  columns: [id, function, args, expected, description]
  rows:
    - [format_qeq,    "Decimal.__format__.__qualname__.__eq__",  ["Decimal.__format__"],  true, "decimal.Decimal.__format__.__qualname__ == 'Decimal.__format__' (Decimal.__format__() implements the format() built-in and f-string formatting for Decimal objects; supports format specifications like 'f', 'e', 'g', 'n', '%' for various numeric representations; 'Decimal.__format__' has 18 characters: 'Decimal.' (8) + '__format__' (10) = 18; the longest Decimal method qualname in this spec; '__format__' (10 chars) is longer than '__round__' (9 chars), __init__ (8 chars), and '__repr__' (8 chars) because 'format' (6 chars) is longer than 'round' (5 chars), 'init' (4 chars), and 'repr' (4 chars))"]
    - [round_qeq,    "Decimal.__round__.__qualname__.__eq__",   ["Decimal.__round__"],   true, "decimal.Decimal.__round__.__qualname__ == 'Decimal.__round__' (Decimal.__round__() implements the round() built-in for Decimal objects; round(Decimal('2.5'), 0) uses the current decimal context rounding mode, which defaults to ROUND_HALF_EVEN (banker's rounding), unlike the ROUND_HALF_UP behavior most users expect; 'Decimal.__round__' has 17 characters: 'Decimal.' (8) + '__round__' (9) = 17; one character shorter than 'Decimal.__format__' (18) because 'round' (5 chars) is one character shorter than 'format' (6 chars))"]
    - [format_qlen,  "Decimal.__format__.__qualname__.__len__", [],                      18,   "decimal.Decimal.__format__.__qualname__.__len__() == 18 ('Decimal.__format__' has 18 characters: 'Decimal.' (8) + '__format__' (10) = 18; the longest qualname in this spec; '__format__' (10 chars) is the longest dunder name in this spec — 'format' (6 chars) wrapped in double underscores produces a 10-char name; compare: Decimal.__truediv__.__qualname__ (19) from decimal_extra155 — one character longer because '__truediv__' (11 chars) is one character longer than '__format__' (10 chars))"]
    - [round_qlen,   "Decimal.__round__.__qualname__.__len__",  [],                      17,   "decimal.Decimal.__round__.__qualname__.__len__() == 17 ('Decimal.__round__' has 17 characters: 'Decimal.' (8) + '__round__' (9) = 17; one shorter than '__format__' (18) in this spec; '__round__' (9 chars) sandwiches 'round' (5 chars) between double underscores; length 17 for '__round__' falls between '__truediv__' qualname length (19 from decimal_extra155) and the comparison dunders (14 from decimal_extra154); '__round__' does not appear in the arithmetic or comparison dunder specs because it is a numeric conversion dunder, not an arithmetic operator)"]

# ---------------------------------------------------------------------------
# decimal.Context __init__ and __repr__ method __qualname__ values
# __init__ = 'Context.__init__' (len=16)
# __repr__ = 'Context.__repr__' (len=16)
# Two-way tie at 16 — both have 8-character dunder names.
# 'Context.' prefix is 8 characters.
# ---------------------------------------------------------------------------

table decimal_extra156.Context_init_repr_qualnames:
  description: "decimal.Context __init__ and __repr__ __qualname__ values: __init__=__repr__='Context.__init__'/'Context.__repr__' (both len=16); two-way tie at 16; both use 'Context.' prefix (8 chars)"
  kind: python_call_eq
  category: qualname
  id_prefix: ctxq156

  columns: [id, function, args, expected, description]
  rows:
    - [ctx_init_qeq,  "Context.__init__.__qualname__.__eq__",  ["Context.__init__"],  true, "decimal.Context.__init__.__qualname__ == 'Context.__init__' (Context.__init__() initializes a decimal arithmetic context with parameters such as prec (precision), rounding (rounding mode), traps (exception flags), and Emax/Emin (exponent limits); 'Context.__init__' has 16 characters: 'Context.' (8) + '__init__' (8) = 16; tied with 'Context.__repr__' (also 16) — both __init__ and __repr__ have 8-character dunder names; the 'Context.' prefix (8 chars) is the same length as the 'Decimal.' prefix, but the methods differ)"]
    - [ctx_repr_qeq,  "Context.__repr__.__qualname__.__eq__",  ["Context.__repr__"],  true, "decimal.Context.__repr__.__qualname__ == 'Context.__repr__' (Context.__repr__() returns a string representation of the Context showing all its settings; the repr of a default Context looks like Context(prec=28, rounding=ROUND_HALF_EVEN, ...); 'Context.__repr__' has 16 characters: 'Context.' (8) + '__repr__' (8) = 16; tied with 'Context.__init__' (also 16); the tie occurs because '__init__' (8 chars) and '__repr__' (8 chars) have the same length; 'Context.' (8 chars) matches 'Decimal.' (8 chars) — both prefixes have the same length)"]
    - [ctx_init_qlen, "Context.__init__.__qualname__.__len__", [],                    16,   "decimal.Context.__init__.__qualname__.__len__() == 16 ('Context.__init__' has 16 characters: 'Context.' (8) + '__init__' (8) = 16; the two-way tie at 16 with Context.__repr__ is the defining pattern for Context method qualnames in this spec; note that Decimal.__hash__.__qualname__ (16) from decimal_extra154 is also 16 characters — but uses the 'Decimal.' prefix; both 'Context.__init__' and 'Decimal.__hash__' have 16-char qualnames because both prefixes are 8 chars and both method names are 8 chars)"]
    - [ctx_repr_qlen, "Context.__repr__.__qualname__.__len__", [],                    16,   "decimal.Context.__repr__.__qualname__.__len__() == 16 ('Context.__repr__' has 16 characters: 'Context.' (8) + '__repr__' (8) = 16; tied with 'Context.__init__' (also 16); the qualname length 16 for both Context methods reflects the equal 8-char lengths of both the 'Context.' prefix and the '__init__'/'__repr__' dunder names; 'Context.__repr__' (16) matches 'Decimal.__hash__' (16) and 'Decimal.__repr__' (16) from decimal_extra154 — three different qualnames all at 16 characters)"]

# ---------------------------------------------------------------------------
# Standalone invariants: decimal rounding constants ROUND_CEILING and ROUND_FLOOR
# ROUND_CEILING = 'ROUND_CEILING' (len=13)
# ROUND_FLOOR   = 'ROUND_FLOOR'   (len=11)
# Both are plain Python strings.
# ---------------------------------------------------------------------------

invariant decimal_extra156.Decimal_format_qualname_len_18:
  description: "decimal.Decimal.__format__.__qualname__.__len__() == 18 — 'Decimal.__format__' has 18 characters: 'Decimal.' (8) + '__format__' (10) = 18; this is the longest Decimal method qualname in this spec; '__format__' (10 chars) is the longest dunder method name in this spec; Decimal.__format__() is called by format() and f-strings to produce locale-aware or specification-controlled string representations of Decimal values; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "Decimal.__format__.__qualname__.__len__"
  args: []
  expected: 18

invariant decimal_extra156.Context_init_repr_tied_at_16:
  description: "decimal.Context.__init__.__qualname__.__len__() == 16 — 'Context.__init__' has 16 characters: 'Context.' (8) + '__init__' (8) = 16; tied with 'Context.__repr__' (also 16: 'Context.' (8) + '__repr__' (8) = 16); the two-way tie at 16 occurs because '__init__' and '__repr__' are both 8-character dunders; the 'Context.' prefix itself is also 8 characters, making the combined qualname length 8+8=16 for both; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "Context.__init__.__qualname__.__len__"
  args: []
  expected: 16

invariant decimal_extra156.ROUND_CEILING_is_string_len_13:
  description: "decimal.ROUND_CEILING.__len__() == 13 — 'ROUND_CEILING' has 13 characters: 'ROUND_' (6) + 'CEILING' (7) = 13; ROUND_CEILING is a string constant that specifies rounding away from zero towards positive infinity for positive values; Decimal('1.1').quantize(Decimal('1'), rounding=ROUND_CEILING) == Decimal('2'); ROUND_CEILING (13 chars) is the same length as ROUND_HALF_UP (13 chars) from decimal_extra155 — coincidental equality of two differently-named rounding constants; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_CEILING.__len__
  args: []
  expected: 13

invariant decimal_extra156.ROUND_FLOOR_is_string_len_11:
  description: "decimal.ROUND_FLOOR.__len__() == 11 — 'ROUND_FLOOR' has 11 characters: 'ROUND_' (6) + 'FLOOR' (5) = 11; ROUND_FLOOR is a string constant for rounding towards negative infinity (floor division semantics); Decimal('1.9').quantize(Decimal('1'), rounding=ROUND_FLOOR) == Decimal('1'); ROUND_FLOOR (11) is 2 characters shorter than ROUND_CEILING (13) because 'FLOOR' (5 chars) is 2 characters shorter than 'CEILING' (7 chars); decimal rounding mode constants are plain Python strings verified by __len__() and __eq__(); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_FLOOR.__len__
  args: []
  expected: 11
