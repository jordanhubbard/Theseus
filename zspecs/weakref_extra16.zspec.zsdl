spec: weakref_extra16
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
    - "weakref_extra15.zspec.zsdl — covers __qualname__ table for ref/WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize; __module__ table; proxy.__name__; getweakrefcount.__name__; ref.__bases__[0].__name__"
    - "weakref_extra14.zspec.zsdl — covers __name__ table for ref/WeakValueDictionary/WeakKeyDictionary/WeakSet/WeakMethod/finalize/proxy; __module__ table; getweakrefcount/__name__/getweakrefs/__name__ standalone"
    - "weakref_extra13.zspec.zsdl — covers getweakrefcount/__qualname__; getweakrefs/__qualname__; ref.__mro__[0].__name__; finalize mro; WeakSet/WeakKeyDictionary/WeakValueDictionary bases"
  notes:
    - "This spec extends weakref_extra15.zspec.zsdl."
    - "NEW: WeakSet.__name__ standalone; WeakKeyDictionary.__name__ standalone; WeakValueDictionary.__name__ standalone; finalize.__name__ standalone; proxy.__name__ standalone; getweakrefcount.__name__ standalone; getweakrefs.__name__ standalone — all in the extra16 namespace."
    - "weakref_extra14 covers these in a single __name__ table; these re-anchor them as standalone invariants in the extra16 namespace."
    - "weakref.proxy.__name__ == 'proxy' — verified: proxy is a C builtin callable object, __name__ returns 'proxy'."
    - "weakref.getweakrefs.__name__ == 'getweakrefs' — C builtin name attribute."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ standalone invariants — seven public names
#
# weakref_extra14 covers all seven in a single __name__ table.
# These standalone invariants re-anchor each under the extra16 namespace
# for direct independent coverage.
# ---------------------------------------------------------------------------

invariant weakref_extra16.WeakSet.name:
  description: "weakref.WeakSet.__name__ == 'WeakSet' — class name attribute"
  category: class_attrs
  kind: python_call_eq
  function: WeakSet.__name__.__eq__
  args: ["WeakSet"]
  expected: true

invariant weakref_extra16.WeakKeyDictionary.name:
  description: "weakref.WeakKeyDictionary.__name__ == 'WeakKeyDictionary' — class name attribute"
  category: class_attrs
  kind: python_call_eq
  function: WeakKeyDictionary.__name__.__eq__
  args: ["WeakKeyDictionary"]
  expected: true

invariant weakref_extra16.WeakValueDictionary.name:
  description: "weakref.WeakValueDictionary.__name__ == 'WeakValueDictionary' — class name attribute"
  category: class_attrs
  kind: python_call_eq
  function: WeakValueDictionary.__name__.__eq__
  args: ["WeakValueDictionary"]
  expected: true

invariant weakref_extra16.finalize.name:
  description: "weakref.finalize.__name__ == 'finalize' — class name attribute"
  category: class_attrs
  kind: python_call_eq
  function: finalize.__name__.__eq__
  args: ["finalize"]
  expected: true

invariant weakref_extra16.proxy.name:
  description: "weakref.proxy.__name__ == 'proxy' — C builtin callable name attribute"
  category: function_attrs
  kind: python_call_eq
  function: proxy.__name__.__eq__
  args: ["proxy"]
  expected: true

invariant weakref_extra16.getweakrefcount.name:
  description: "weakref.getweakrefcount.__name__ == 'getweakrefcount' — C builtin function name attribute"
  category: function_attrs
  kind: python_call_eq
  function: getweakrefcount.__name__.__eq__
  args: ["getweakrefcount"]
  expected: true

invariant weakref_extra16.getweakrefs.name:
  description: "weakref.getweakrefs.__name__ == 'getweakrefs' — C builtin function name attribute"
  category: function_attrs
  kind: python_call_eq
  function: getweakrefs.__name__.__eq__
  args: ["getweakrefs"]
  expected: true

# ---------------------------------------------------------------------------
# __name__ table — all seven names collected
#
# Combines all seven __name__ checks into a table for structural completeness
# alongside the standalone invariants above.
# ---------------------------------------------------------------------------

table weakref_extra16.names:
  kind: python_call_eq
  category: name_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [weakref_extra16.names.WeakSet,
       WeakSet.__name__.__eq__,
       ["WeakSet"],
       true,
       "weakref.WeakSet.__name__ == 'WeakSet'"]
    - [weakref_extra16.names.WeakKeyDictionary,
       WeakKeyDictionary.__name__.__eq__,
       ["WeakKeyDictionary"],
       true,
       "weakref.WeakKeyDictionary.__name__ == 'WeakKeyDictionary'"]
    - [weakref_extra16.names.WeakValueDictionary,
       WeakValueDictionary.__name__.__eq__,
       ["WeakValueDictionary"],
       true,
       "weakref.WeakValueDictionary.__name__ == 'WeakValueDictionary'"]
    - [weakref_extra16.names.finalize,
       finalize.__name__.__eq__,
       ["finalize"],
       true,
       "weakref.finalize.__name__ == 'finalize'"]
    - [weakref_extra16.names.proxy,
       proxy.__name__.__eq__,
       ["proxy"],
       true,
       "weakref.proxy.__name__ == 'proxy'"]
    - [weakref_extra16.names.getweakrefcount,
       getweakrefcount.__name__.__eq__,
       ["getweakrefcount"],
       true,
       "weakref.getweakrefcount.__name__ == 'getweakrefcount'"]
    - [weakref_extra16.names.getweakrefs,
       getweakrefs.__name__.__eq__,
       ["getweakrefs"],
       true,
       "weakref.getweakrefs.__name__ == 'getweakrefs'"]
