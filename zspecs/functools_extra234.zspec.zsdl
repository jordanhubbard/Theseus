spec: functools_extra234
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools.lru_cache and functools.cache behavioral contracts: __name__, __qualname__, __module__, doc contracts, and WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES length contracts."
    - "functools.lru_cache.__name__ == 'lru_cache' — lru_cache is a Python function in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache' — top-level function with unqualified qualname. Verified with Python 3.14.3."
    - "functools.lru_cache.__module__ == 'functools' — defined in the functools module. Verified with Python 3.14.3."
    - "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters. Verified with Python 3.14.3."
    - "functools.cache.__name__ == 'cache' — cache is a simpler alias for lru_cache(maxsize=None). Verified with Python 3.14.3."
    - "functools.cache.__name__.__len__() == 5 — 'cache' has 5 characters. Verified with Python 3.14.3."
    - "functools.lru_cache.__doc__.__contains__('maxsize') == True — docstring describes the maxsize parameter. Verified with Python 3.14.3."
    - "functools.lru_cache.__doc__.__contains__('typed') == True — docstring describes the typed parameter. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — tuple contains 6 items: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__len__() == 1 — tuple contains 1 item: __dict__. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.lru_cache identity contracts
#
# functools.lru_cache.__name__ == 'lru_cache'
# functools.lru_cache.__qualname__ == 'lru_cache'
# functools.lru_cache.__module__ == 'functools'
# functools.lru_cache.__name__.__len__() == 9
# functools.lru_cache.__class__.__name__ == 'function'
#
# lru_cache is a Python-level decorator function, not a C type.
# New to extra234.
# ---------------------------------------------------------------------------

table functools_extra234.lru_cache_identity:
  description: "functools.lru_cache identity contracts: __name__, __qualname__, __module__, name length; new to extra234"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra234lrucacheid

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_name_eq,
       lru_cache.__name__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__name__ == 'lru_cache' — lru_cache is a Python function in Lib/functools.py; its __name__ attribute is 'lru_cache'; __name__.__eq__('lru_cache') returns True; new to extra234"]
    - [lru_cache_qualname_eq,
       lru_cache.__qualname__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__ == 'lru_cache' — lru_cache is a top-level function with unqualified qualname 'lru_cache'; __qualname__.__eq__('lru_cache') returns True; new to extra234"]
    - [lru_cache_module_eq,
       lru_cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.lru_cache.__module__ == 'functools' — lru_cache is defined in the functools module; __module__.__eq__('functools') returns True; new to extra234"]
    - [lru_cache_name_len_9,
       lru_cache.__name__.__len__,
       [],
       9,
       "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has exactly 9 characters (l-r-u-_-c-a-c-h-e); __len__() returns 9; new to extra234"]
    - [lru_cache_qualname_len_9,
       lru_cache.__qualname__.__len__,
       [],
       9,
       "functools.lru_cache.__qualname__.__len__() == 9 — qualname 'lru_cache' has exactly 9 characters; __len__() returns 9; new to extra234"]

# ---------------------------------------------------------------------------
# Table 2: functools.cache identity contracts
#
# functools.cache.__name__ == 'cache'
# functools.cache.__qualname__ == 'cache'
# functools.cache.__module__ == 'functools'
# functools.cache.__name__.__len__() == 5
# functools.cache.__class__.__name__ == 'function'
#
# cache is a simple unbounded cache (lru_cache with maxsize=None).
# New to extra234.
# ---------------------------------------------------------------------------

table functools_extra234.cache_identity:
  description: "functools.cache identity contracts: __name__, __qualname__, __module__, name length; new to extra234"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra234cacheid

  columns: [id, function, args, expected, description]
  rows:
    - [cache_name_eq,
       cache.__name__.__eq__,
       ["cache"],
       true,
       "functools.cache.__name__ == 'cache' — cache is an alias for lru_cache(maxsize=None) defined in functools.py; __name__.__eq__('cache') returns True; new to extra234"]
    - [cache_qualname_eq,
       cache.__qualname__.__eq__,
       ["cache"],
       true,
       "functools.cache.__qualname__ == 'cache' — cache is a top-level function with unqualified qualname 'cache'; __qualname__.__eq__('cache') returns True; new to extra234"]
    - [cache_module_eq,
       cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.cache.__module__ == 'functools' — cache is defined in the functools module; __module__.__eq__('functools') returns True; new to extra234"]
    - [cache_name_len_5,
       cache.__name__.__len__,
       [],
       5,
       "functools.cache.__name__.__len__() == 5 — 'cache' has exactly 5 characters (c-a-c-h-e); __len__() returns 5; new to extra234"]
    - [cache_qualname_len_5,
       cache.__qualname__.__len__,
       [],
       5,
       "functools.cache.__qualname__.__len__() == 5 — qualname 'cache' has exactly 5 characters; __len__() returns 5; new to extra234"]

# ---------------------------------------------------------------------------
# Table 3: functools.lru_cache docstring contracts
#
# functools.lru_cache.__doc__.__contains__('maxsize') == True
# functools.lru_cache.__doc__.__contains__('typed') == True
# functools.WRAPPER_ASSIGNMENTS.__len__() == 6
# functools.WRAPPER_UPDATES.__len__() == 1
# functools.lru_cache.__module__.__len__() == 9
#
# New to extra234.
# ---------------------------------------------------------------------------

table functools_extra234.lru_cache_doc_and_wrapper:
  description: "functools.lru_cache doc contains maxsize/typed; WRAPPER_ASSIGNMENTS len=6; WRAPPER_UPDATES len=1; new to extra234"
  kind: python_call_eq
  category: behavioral
  id_prefix: functoolsextra234lcachedc

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_doc_has_maxsize,
       lru_cache.__doc__.__contains__,
       ["maxsize"],
       true,
       "functools.lru_cache.__doc__.__contains__('maxsize') == True — lru_cache docstring describes the maxsize parameter that controls the LRU cache size; __contains__('maxsize') returns True; new to extra234"]
    - [lru_cache_doc_has_typed,
       lru_cache.__doc__.__contains__,
       ["typed"],
       true,
       "functools.lru_cache.__doc__.__contains__('typed') == True — lru_cache docstring describes the typed parameter for type-aware caching; __contains__('typed') returns True; new to extra234"]
    - [wrapper_assignments_len_6,
       WRAPPER_ASSIGNMENTS.__len__,
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — tuple contains 6 attribute names: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__; __len__() returns 6; new to extra234"]
    - [wrapper_updates_len_1,
       WRAPPER_UPDATES.__len__,
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — tuple contains 1 attribute name: __dict__; __len__() returns 1; new to extra234"]
    - [lru_cache_module_len_9,
       lru_cache.__module__.__len__,
       [],
       9,
       "functools.lru_cache.__module__.__len__() == 9 — 'functools' has exactly 9 characters; __len__() returns 9; new to extra234"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra234
# ---------------------------------------------------------------------------

invariant functools_extra234.lru_cache_name_eq:
  description: "functools.lru_cache.__name__ == 'lru_cache'; new to extra234"
  kind: python_call_eq
  function: lru_cache.__name__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra234.lru_cache_qualname_eq:
  description: "functools.lru_cache.__qualname__ == 'lru_cache'; new to extra234"
  kind: python_call_eq
  function: lru_cache.__qualname__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra234.lru_cache_module_eq:
  description: "functools.lru_cache.__module__ == 'functools'; new to extra234"
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra234.lru_cache_name_len_9:
  description: "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters; new to extra234"
  kind: python_call_eq
  function: lru_cache.__name__.__len__
  args: []
  expected: 9

invariant functools_extra234.cache_name_eq:
  description: "functools.cache.__name__ == 'cache'; new to extra234"
  kind: python_call_eq
  function: cache.__name__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra234.cache_qualname_eq:
  description: "functools.cache.__qualname__ == 'cache'; new to extra234"
  kind: python_call_eq
  function: cache.__qualname__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra234.cache_module_eq:
  description: "functools.cache.__module__ == 'functools'; new to extra234"
  kind: python_call_eq
  function: cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra234.cache_name_len_5:
  description: "functools.cache.__name__.__len__() == 5 — 'cache' has 5 characters; new to extra234"
  kind: python_call_eq
  function: cache.__name__.__len__
  args: []
  expected: 5

invariant functools_extra234.lru_cache_doc_has_maxsize:
  description: "functools.lru_cache.__doc__.__contains__('maxsize') == True; new to extra234"
  kind: python_call_eq
  function: lru_cache.__doc__.__contains__
  args: ["maxsize"]
  expected: true

invariant functools_extra234.lru_cache_doc_has_typed:
  description: "functools.lru_cache.__doc__.__contains__('typed') == True; new to extra234"
  kind: python_call_eq
  function: lru_cache.__doc__.__contains__
  args: ["typed"]
  expected: true

invariant functools_extra234.wrapper_assignments_len_6:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — 6 attribute names copied by wraps; new to extra234"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra234.wrapper_updates_len_1:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — 1 attribute updated by wraps (__dict__); new to extra234"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra234.lru_cache_module_len_9:
  description: "functools.lru_cache.__module__.__len__() == 9 — 'functools' has 9 characters; new to extra234"
  kind: python_call_eq
  function: lru_cache.__module__.__len__
  args: []
  expected: 9
