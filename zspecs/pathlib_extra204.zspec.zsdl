spec: pathlib_extra204
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath name/stem/suffix/parts/parent/joinpath/str/as_posix/relative_to"
    - "pathlib_extra.zspec.zsdl — covers Path class name/module, PurePosixPath component/parent/truediv/parts/is_absolute"
    - "pathlib_extra203.zspec.zsdl — covers Path stat/glob/iterdir/rglob/rename/replace/symlink_to/resolve qualnames"
  notes:
    - "This spec covers pathlib.Path with_name/with_suffix/with_stem/relative_to/is_relative_to/joinpath/is_dir/is_file method qualnames."
    - "pathlib.Path.with_name.__qualname__ == 'PurePath.with_name' — method defined on PurePath (len=18)."
    - "pathlib.Path.with_suffix.__qualname__ == 'PurePath.with_suffix' — method defined on PurePath (len=20)."
    - "pathlib.Path.with_stem.__qualname__ == 'PurePath.with_stem' — method defined on PurePath (len=18)."
    - "pathlib.Path.relative_to.__qualname__ == 'PurePath.relative_to' — method defined on PurePath (len=20)."
    - "pathlib.Path.is_relative_to.__qualname__ == 'PurePath.is_relative_to' — method defined on PurePath (len=23)."
    - "pathlib.Path.joinpath.__qualname__ == 'PurePath.joinpath' — method defined on PurePath (len=17)."
    - "pathlib.Path.is_dir.__qualname__ == 'Path.is_dir' — method defined on Path (len=11)."
    - "pathlib.Path.is_file.__qualname__ == 'Path.is_file' — method defined on Path (len=12)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path with_* method qualnames — with_name, with_suffix, with_stem
# ---------------------------------------------------------------------------

table pathlib_extra204.path_with_method_qualnames:
  description: "pathlib.Path with_* method qualnames in pathlibwith204 namespace — with_name, with_suffix, with_stem are defined on PurePath; qualnames use 'PurePath.' prefix; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pathlibwith204

  columns: [id, function, args, expected, description]
  rows:
    - [with_name_qn,   Path.with_name.__qualname__.__eq__,   ["PurePath.with_name"],   true, "pathlib.Path.with_name.__qualname__ == 'PurePath.with_name' (len=18); verified with Python 3.14.3"]
    - [with_suffix_qn, Path.with_suffix.__qualname__.__eq__, ["PurePath.with_suffix"], true, "pathlib.Path.with_suffix.__qualname__ == 'PurePath.with_suffix' (len=20); verified with Python 3.14.3"]
    - [with_stem_qn,   Path.with_stem.__qualname__.__eq__,   ["PurePath.with_stem"],   true, "pathlib.Path.with_stem.__qualname__ == 'PurePath.with_stem' (len=18); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# pathlib.Path relative_to/is_relative_to/joinpath method qualnames
# ---------------------------------------------------------------------------

table pathlib_extra204.path_relative_qualnames:
  description: "pathlib.Path relative_to, is_relative_to, joinpath method qualnames in pathlibwith204b namespace — all defined on PurePath; qualnames use 'PurePath.' prefix; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pathlibwith204b

  columns: [id, function, args, expected, description]
  rows:
    - [relative_to_qn,    Path.relative_to.__qualname__.__eq__,    ["PurePath.relative_to"],    true, "pathlib.Path.relative_to.__qualname__ == 'PurePath.relative_to' (len=20); verified with Python 3.14.3"]
    - [is_relative_to_qn, Path.is_relative_to.__qualname__.__eq__, ["PurePath.is_relative_to"], true, "pathlib.Path.is_relative_to.__qualname__ == 'PurePath.is_relative_to' (len=23); verified with Python 3.14.3"]
    - [joinpath_qn,        Path.joinpath.__qualname__.__eq__,        ["PurePath.joinpath"],        true, "pathlib.Path.joinpath.__qualname__ == 'PurePath.joinpath' (len=17); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# pathlib.Path is_dir/is_file method qualnames — defined on Path (not PurePath)
# ---------------------------------------------------------------------------

table pathlib_extra204.path_predicate_qualnames:
  description: "pathlib.Path is_dir and is_file method qualnames in pathlibwith204c namespace — is_dir and is_file are filesystem-aware methods defined on Path (not PurePath); qualnames use 'Path.' prefix; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pathlibwith204c

  columns: [id, function, args, expected, description]
  rows:
    - [is_dir_qn,  Path.is_dir.__qualname__.__eq__,  ["Path.is_dir"],  true, "pathlib.Path.is_dir.__qualname__ == 'Path.is_dir' (len=11); defined on Path, not PurePath; verified with Python 3.14.3"]
    - [is_file_qn, Path.is_file.__qualname__.__eq__, ["Path.is_file"], true, "pathlib.Path.is_file.__qualname__ == 'Path.is_file' (len=12); defined on Path, not PurePath; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — pathlibwith204
# ---------------------------------------------------------------------------

invariant pathlib_extra204.Path.with_name_qualname_eq:
  description: "pathlib.Path.with_name.__qualname__.__eq__('PurePath.with_name') returns True — with_name() returns a new path with the name changed; qualname 'PurePath.with_name' has len=18 ('PurePath.'=9+'with_name'=9=18); method is inherited from PurePath, so qualname uses 'PurePath.' prefix; compare: with_stem qualname='PurePath.with_stem' also len=18; with_suffix qualname='PurePath.with_suffix' len=20; NEW in pathlib_extra204: first standalone Path.with_name qualname invariant in pathlibwith204 namespace; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Path.with_name.__qualname__.__eq__
  args: ["PurePath.with_name"]
  expected: true

invariant pathlib_extra204.Path.with_suffix_qualname_len:
  description: "pathlib.Path.with_suffix.__qualname__.__len__() == 20 — 'PurePath.with_suffix' has 20 chars ('PurePath.'=9+'with_suffix'=11=20); with_suffix() returns a new path with the suffix changed; compare: with_name qualname='PurePath.with_name' len=18; relative_to qualname='PurePath.relative_to' also len=20; is_relative_to qualname='PurePath.is_relative_to' len=23 (longest); verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Path.with_suffix.__qualname__.__len__
  args: []
  expected: 20

invariant pathlib_extra204.Path.with_stem_qualname_len:
  description: "pathlib.Path.with_stem.__qualname__.__len__() == 18 — 'PurePath.with_stem' has 18 chars ('PurePath.'=9+'with_stem'=9=18); with_stem() returns a new path with the stem changed (added in Python 3.9); compare: with_name qualname='PurePath.with_name' also len=18; with_suffix qualname='PurePath.with_suffix' len=20; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Path.with_stem.__qualname__.__len__
  args: []
  expected: 18

invariant pathlib_extra204.Path.relative_to_qualname_eq:
  description: "pathlib.Path.relative_to.__qualname__.__eq__('PurePath.relative_to') returns True — relative_to() computes the relative path from the given path; qualname 'PurePath.relative_to' has len=20 ('PurePath.'=9+'relative_to'=11=20); method is defined on PurePath; compare: is_relative_to qualname='PurePath.is_relative_to' len=23 (longest PurePath qualname in spec); joinpath qualname='PurePath.joinpath' len=17; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Path.relative_to.__qualname__.__eq__
  args: ["PurePath.relative_to"]
  expected: true

invariant pathlib_extra204.Path.is_relative_to_qualname_len:
  description: "pathlib.Path.is_relative_to.__qualname__.__len__() == 23 — 'PurePath.is_relative_to' has 23 chars ('PurePath.'=9+'is_relative_to'=14=23) — longest qualname in this spec; is_relative_to() returns True if the path is relative to the given path (added in Python 3.9); compare: relative_to qualname='PurePath.relative_to' len=20; with_suffix qualname='PurePath.with_suffix' len=20; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Path.is_relative_to.__qualname__.__len__
  args: []
  expected: 23

invariant pathlib_extra204.Path.joinpath_qualname_len:
  description: "pathlib.Path.joinpath.__qualname__.__len__() == 17 — 'PurePath.joinpath' has 17 chars ('PurePath.'=9+'joinpath'=8=17) — shortest PurePath qualname in this spec; joinpath() combines path components; compare: with_name len=18, with_stem len=18, with_suffix len=20; is_dir/is_file qualnames use 'Path.' prefix (shorter at 11 and 12); verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Path.joinpath.__qualname__.__len__
  args: []
  expected: 17

invariant pathlib_extra204.Path.is_dir_qualname_eq:
  description: "pathlib.Path.is_dir.__qualname__.__eq__('Path.is_dir') returns True — is_dir() returns True if the path points to a directory; qualname 'Path.is_dir' has len=11 ('Path.'=5+'is_dir'=6=11); is_dir is filesystem-aware so it is defined on Path (not PurePath) — note the 'Path.' prefix instead of 'PurePath.'; compare: is_file qualname='Path.is_file' len=12; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Path.is_dir.__qualname__.__eq__
  args: ["Path.is_dir"]
  expected: true

invariant pathlib_extra204.Path.is_file_qualname_eq:
  description: "pathlib.Path.is_file.__qualname__.__eq__('Path.is_file') returns True — is_file() returns True if the path points to a regular file; qualname 'Path.is_file' has len=12 ('Path.'=5+'is_file'=7=12); is_file is filesystem-aware so it is defined on Path (not PurePath); compare: is_dir qualname='Path.is_dir' len=11; with_* qualnames use 'PurePath.' prefix (longer); verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Path.is_file.__qualname__.__eq__
  args: ["Path.is_file"]
  expected: true
