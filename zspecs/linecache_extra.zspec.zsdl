spec: linecache_extra
version: ">=3.2"
backend: python_module(linecache)

docs: https://docs.python.org/3/library/linecache.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/linecache.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/linecache.py (internal implementation)"
  notes:
    - "This spec covers aspects not in linecache.zspec.zsdl."
    - "linecache.cache is the module-level dict mapping filenames to cached line data."
    - "cache.__class__.__name__ == 'dict' confirms it is a plain dict."
    - "getline('', 1) == '' — empty string as filename is treated as non-existent."
    - "getline.__module__ == 'linecache' confirms the function belongs to this module."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant linecache_extra.functions.getline_name:
  description: "getline.__name__ == 'getline'"
  category: functions
  kind: python_call_eq
  function: getline.__name__.__eq__
  args: ["getline"]
  expected: true

invariant linecache_extra.functions.getline_module:
  description: "getline.__module__ == 'linecache'"
  category: functions
  kind: python_call_eq
  function: getline.__module__.__eq__
  args: ["linecache"]
  expected: true

invariant linecache_extra.functions.getlines_name:
  description: "getlines.__name__ == 'getlines'"
  category: functions
  kind: python_call_eq
  function: getlines.__name__.__eq__
  args: ["getlines"]
  expected: true

invariant linecache_extra.functions.clearcache_name:
  description: "clearcache.__name__ == 'clearcache'"
  category: functions
  kind: python_call_eq
  function: clearcache.__name__.__eq__
  args: ["clearcache"]
  expected: true

invariant linecache_extra.functions.checkcache_name:
  description: "checkcache.__name__ == 'checkcache'"
  category: functions
  kind: python_call_eq
  function: checkcache.__name__.__eq__
  args: ["checkcache"]
  expected: true

# ---------------------------------------------------------------------------
# cache — module-level dict
# ---------------------------------------------------------------------------

invariant linecache_extra.cache.is_dict:
  description: "cache.__class__.__name__ == 'dict' — linecache.cache is a plain dict"
  category: cache
  kind: python_call_eq
  function: cache.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# getline — empty filename returns empty string
# ---------------------------------------------------------------------------

invariant linecache_extra.getline.empty_filename:
  description: "getline('', 1) == '' — empty filename treated as non-existent"
  category: behavior
  kind: python_call_eq
  function: getline
  args: ["", 1]
  expected: ""
