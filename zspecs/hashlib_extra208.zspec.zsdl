spec: hashlib_extra208
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/md5module.c"
    - "hashlib_extra207.zspec.zsdl — covers algorithms_guaranteed membership and cardinality"
  notes:
    - "hashlib.new.__defaults__ is None — hashlib.new is a Python-level wrapper function whose signature has no default values for positional args; __defaults__ is None (not missing). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.new.__defaults__.__class__.__name__ == 'NoneType' — confirmed by Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.pbkdf2_hmac.__defaults__ raises AttributeError — pbkdf2_hmac is a builtin_function_or_method (C-level) with no __defaults__ attribute. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.md5.__defaults__ raises AttributeError — md5 is a builtin_function_or_method (C-level) with no __defaults__ attribute. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.new.__code__.co_argcount == 1 — hashlib.new code object has 1 positional arg ('name'). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.new.__code__.co_name == '__hash_new' — the internal code object name of hashlib.new. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.new.__code__.__class__.__name__ == 'code' — the code object type name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.new.__kwdefaults__.__class__.__name__ == 'NoneType' — hashlib.new has no keyword-only defaults. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new __defaults__ and __code__ identity
#
# hashlib.new is a Python-level wrapper (Lib/hashlib.py). Its __defaults__
# is None because it has no default values for positional args. Its __code__
# is a real code object with co_argcount==1 and co_name=='__hash_new'.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra208.new_defaults_and_code:
  description: "hashlib.new.__defaults__.__class__.__name__ and hashlib.new.__code__ identity — new is a Python wrapper with no positional defaults; __defaults__ is None; code object has co_argcount==1 and co_name=='__hash_new'"
  kind: python_call_eq
  category: function_defaults
  id_prefix: hashlibdefaults208

  columns: [id, function, args, expected, description]
  rows:
    - [new_defaults_classname,    new.__defaults__.__class__.__name__.__eq__,    ["NoneType"],    true,  "hashlib.new.__defaults__.__class__.__name__ == 'NoneType' — new has no positional defaults so __defaults__ is None"]
    - [new_code_classname,        new.__code__.__class__.__name__.__eq__,         ["code"],        true,  "hashlib.new.__code__.__class__.__name__ == 'code' — the code object type name is 'code'"]
    - [new_code_co_argcount,      new.__code__.co_argcount.__eq__,                [1],             true,  "hashlib.new.__code__.co_argcount == 1 — new takes one positional arg ('name')"]
    - [new_code_co_name,          new.__code__.co_name.__eq__,                    ["__hash_new"],  true,  "hashlib.new.__code__.co_name == '__hash_new' — the internal name of the hashlib.new code object"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac and hashlib.md5 __defaults__ raise AttributeError
#
# Both pbkdf2_hmac and md5 are C-level builtins. They have no __defaults__
# attribute. Accessing it raises AttributeError.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra208.builtin_no_defaults_raises:
  description: "hashlib.pbkdf2_hmac.__defaults__ and hashlib.md5.__defaults__ raise AttributeError — both are builtin_function_or_method C-level objects with no __defaults__ attribute"
  kind: python_call_raises
  category: builtin_no_defaults
  id_prefix: hashlibdefaults208

  columns: [id, function, args, expected]
  rows:
    - [pbkdf2_no_defaults,    pbkdf2_hmac.__getattribute__,    ["__defaults__"],    AttributeError]
    - [md5_no_defaults,       md5.__getattribute__,            ["__defaults__"],    AttributeError]
    - [sha1_no_defaults,      sha1.__getattribute__,           ["__defaults__"],    AttributeError]
    - [sha256_no_defaults,    sha256.__getattribute__,         ["__defaults__"],    AttributeError]

# ---------------------------------------------------------------------------
# hashlib.new __kwdefaults__ and __doc__ class names
#
# hashlib.new.__kwdefaults__ is None (no kw-only defaults).
# hashlib.new.__doc__ is a str (it has a docstring).
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra208.new_kwdefaults_and_doc:
  description: "hashlib.new.__kwdefaults__.__class__.__name__ and __doc__ identity — new has no keyword-only defaults (__kwdefaults__ is None); __doc__ is a str; __doc__ len is 147"
  kind: python_call_eq
  category: function_defaults
  id_prefix: hashlibdefaults208

  columns: [id, function, args, expected, description]
  rows:
    - [new_kwdefaults_classname,  new.__kwdefaults__.__class__.__name__.__eq__,    ["NoneType"],  true,  "hashlib.new.__kwdefaults__.__class__.__name__ == 'NoneType' — new has no keyword-only defaults"]
    - [new_doc_classname,         new.__doc__.__class__.__name__.__eq__,           ["str"],       true,  "hashlib.new.__doc__.__class__.__name__ == 'str' — new has a docstring"]
    - [new_doc_len,               new.__doc__.__len__,                             [],            147,   "hashlib.new.__doc__.__len__() == 147 — the docstring is 147 characters long"]
    - [new_name_eq,               new.__name__.__eq__,                             ["__hash_new"], true, "hashlib.new.__name__ == '__hash_new' — the internal function name"]

# ---------------------------------------------------------------------------
# Standalone invariants (8 total)
# ---------------------------------------------------------------------------

invariant hashlib_extra208.new_defaults_is_nonetype:
  description: "hashlib.new.__defaults__.__class__.__name__ == 'NoneType' — new is a Python wrapper with no positional default values; __defaults__ is None; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: function_defaults
  kind: python_call_eq
  function: new.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant hashlib_extra208.new_code_co_argcount:
  description: "hashlib.new.__code__.co_argcount == 1 — the new wrapper takes exactly one positional argument ('name'); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: function_code
  kind: python_call_eq
  function: new.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant hashlib_extra208.new_code_co_name:
  description: "hashlib.new.__code__.co_name == '__hash_new' — the internal code object name for hashlib.new; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: function_code
  kind: python_call_eq
  function: new.__code__.co_name.__eq__
  args: ["__hash_new"]
  expected: true

invariant hashlib_extra208.new_code_classname:
  description: "hashlib.new.__code__.__class__.__name__ == 'code' — the code object type is named 'code'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: function_code
  kind: python_call_eq
  function: new.__code__.__class__.__name__.__eq__
  args: ["code"]
  expected: true

invariant hashlib_extra208.pbkdf2_no_defaults_raises:
  description: "hashlib.pbkdf2_hmac.__defaults__ raises AttributeError — pbkdf2_hmac is a C-level builtin_function_or_method with no __defaults__ attribute; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: builtin_no_defaults
  kind: python_call_raises
  function: pbkdf2_hmac.__getattribute__
  args: ["__defaults__"]
  expected_exception: AttributeError

invariant hashlib_extra208.md5_no_defaults_raises:
  description: "hashlib.md5.__defaults__ raises AttributeError — md5 is a C-level builtin_function_or_method with no __defaults__ attribute; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: builtin_no_defaults
  kind: python_call_raises
  function: md5.__getattribute__
  args: ["__defaults__"]
  expected_exception: AttributeError

invariant hashlib_extra208.new_kwdefaults_nonetype:
  description: "hashlib.new.__kwdefaults__.__class__.__name__ == 'NoneType' — new has no keyword-only defaults; __kwdefaults__ is None; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: function_defaults
  kind: python_call_eq
  function: new.__kwdefaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant hashlib_extra208.new_doc_len:
  description: "hashlib.new.__doc__.__len__() == 147 — the docstring of hashlib.new is 147 characters long; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: function_doc
  kind: python_call_eq
  function: new.__doc__.__len__
  args: []
  expected: 147
