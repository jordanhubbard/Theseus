spec: pathlib_extra410
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "pathlib.PurePath properties parts, drive, root, anchor, parents are each exposed as 'property' descriptors at the class level"
    - "pathlib.PurePath.__bytes__ exists and reports __name__ == '__bytes__'"
    - "pathlib.PurePath.__format__ exists and reports __name__ == '__format__'"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath property descriptor types
# ---------------------------------------------------------------------------

table pathlib_extra410.purepath_property_types:
  description: "pathlib.PurePath property descriptor types — parts, drive, root, anchor, parents; each is a 'property' descriptor object at the class level; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpurep410

  columns: [id, function, args, expected]
  rows:
    - [parts_class,   pathlib.PurePath.parts.__class__.__name__.__eq__,   ["property"], true]
    - [drive_class,   pathlib.PurePath.drive.__class__.__name__.__eq__,   ["property"], true]
    - [root_class,    pathlib.PurePath.root.__class__.__name__.__eq__,    ["property"], true]
    - [anchor_class,  pathlib.PurePath.anchor.__class__.__name__.__eq__,  ["property"], true]
    - [parents_class, pathlib.PurePath.parents.__class__.__name__.__eq__, ["property"], true]

# ---------------------------------------------------------------------------
# pathlib.PurePath magic method __name__ identity
# ---------------------------------------------------------------------------

table pathlib_extra410.purepath_magic_method_names:
  description: "pathlib.PurePath magic method __name__ identity — __bytes__, __format__; each method's __name__ matches its Python-level dunder name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpurem410

  columns: [id, function, args, expected]
  rows:
    - [bytes_name,  pathlib.PurePath.__bytes__.__name__.__eq__,  ["__bytes__"],  true]
    - [format_name, pathlib.PurePath.__format__.__name__.__eq__, ["__format__"], true]
