spec: fnmatch_extra13
version: ">=3.9"
backend: python_module(fnmatch)

docs: https://docs.python.org/3/library/fnmatch.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fnmatch.html — Python fnmatch module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fnmatch.py"
    - "fnmatch_extra12.zspec.zsdl — covers prior fnmatch module attributes"
  notes:
    - "This spec extends fnmatch.zspec.zsdl and all prior fnmatch_extra specs through fnmatch_extra12.zspec.zsdl."
    - "fnmatch.fnmatch.__module__ == 'fnmatch' — defined in the fnmatch module; verified at runtime."
    - "fnmatch.fnmatchcase.__module__ == 'fnmatch' — case-sensitive variant in same module; verified at runtime."
    - "fnmatch.filter.__module__ == 'fnmatch' — list filter helper in same module; verified at runtime."
    - "fnmatch.translate.__module__ == 'fnmatch' — shell-pattern-to-regex helper in same module; verified at runtime."
    - "All four public functions are top-level callables; __qualname__ equals __name__ for each; verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ table for fnmatch public functions
#
# All four public fnmatch functions (fnmatch, fnmatchcase, filter, translate)
# are defined directly in the fnmatch module. This table groups them for a
# single coherent check. No prior fnmatch_extra spec covers __module__ for
# all four in one table.
# ---------------------------------------------------------------------------

table fnmatch_extra13.function_modules:
  description: "__module__ for fnmatch public functions (all should be 'fnmatch')"
  kind: python_call_eq
  category: module_identity
  id_prefix: fnmod13

  columns: [id, function, args, expected]
  rows:
    - [fnmatch,      "fnmatch.__module__.__eq__",      ["fnmatch"], true]
    - [fnmatchcase,  "fnmatchcase.__module__.__eq__",  ["fnmatch"], true]
    - [filter,       "filter.__module__.__eq__",       ["fnmatch"], true]
    - [translate,    "translate.__module__.__eq__",    ["fnmatch"], true]

# ---------------------------------------------------------------------------
# Standalone __qualname__ invariants for fnmatch public functions
#
# For top-level module functions, __qualname__ equals the simple function name.
# These invariants confirm each function is a plain module-level callable.
# ---------------------------------------------------------------------------

invariant fnmatch_extra13.fnmatch.qualname:
  description: "fnmatch.fnmatch.__qualname__ == 'fnmatch' — top-level function, qualname equals function name"
  category: qualname
  kind: python_call_eq
  function: fnmatch.__qualname__.__eq__
  args: ["fnmatch"]
  expected: true

invariant fnmatch_extra13.fnmatchcase.qualname:
  description: "fnmatch.fnmatchcase.__qualname__ == 'fnmatchcase' — top-level function, qualname equals function name"
  category: qualname
  kind: python_call_eq
  function: fnmatchcase.__qualname__.__eq__
  args: ["fnmatchcase"]
  expected: true

invariant fnmatch_extra13.filter.qualname:
  description: "fnmatch.filter.__qualname__ == 'filter' — top-level function, qualname equals function name"
  category: qualname
  kind: python_call_eq
  function: filter.__qualname__.__eq__
  args: ["filter"]
  expected: true

invariant fnmatch_extra13.translate.qualname:
  description: "fnmatch.translate.__qualname__ == 'translate' — top-level function, qualname equals function name"
  category: qualname
  kind: python_call_eq
  function: translate.__qualname__.__eq__
  args: ["translate"]
  expected: true

invariant fnmatch_extra13.fnmatch.name:
  description: "fnmatch.fnmatch.__name__ == 'fnmatch' — simple name attribute of the function"
  category: function_identity
  kind: python_call_eq
  function: fnmatch.__name__.__eq__
  args: ["fnmatch"]
  expected: true

invariant fnmatch_extra13.translate.name:
  description: "fnmatch.translate.__name__ == 'translate' — simple name attribute of the regex-conversion helper"
  category: function_identity
  kind: python_call_eq
  function: translate.__name__.__eq__
  args: ["translate"]
  expected: true
