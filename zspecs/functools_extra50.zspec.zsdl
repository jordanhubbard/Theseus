spec: functools_extra50
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra49.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps/partial/lru_cache/total_ordering/singledispatch/cached_property/reduce/cmp_to_key/partialmethod/singledispatchmethod/update_wrapper; __qualname__.__len__() for update_wrapper/partialmethod/singledispatchmethod/cache/total_ordering/singledispatch/cmp_to_key/cached_property/lru_cache/wraps/reduce/partial; WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES lengths; __all__ lengths; partial/__class__.__name__; cached_property/__set_name__/__get__/__init__.__qualname__; partial/__new__.__qualname__; class __dict__.__class__.__name__.__len__ for partial/partialmethod/singledispatchmethod/cached_property; reduce with initial value; lru_cache(128).__ne__(None)==True; lru_cache(maxsize=2) behavioral; reduce.__qualname__=='reduce'; lru_cache.__qualname__=='lru_cache'; cache/__name__/__qualname__/__module__; cached_property/__name__/__qualname__/__module__/__bases__[0].__name__; total_ordering/__name__/__qualname__/__module__; singledispatch/__name__/__qualname__/__module__; wraps/__name__/__qualname__/__module__; update_wrapper/__name__/__qualname__/__module__; partial/__bases__[0].__name__=='object'; partial/__name__/'partial'; partial/__qualname__/'partial'; partial/__module__/'functools'; lru_cache/__name__/__module__; cmp_to_key/__name__=='cmp_to_key'; cmp_to_key.__module__=='_functools'; partialmethod/__name__/__qualname__/__module__/__bases__[0].__name__; singledispatchmethod/__name__/__module__/__qualname__; singledispatchmethod/__mro__.__len__()==2; partial/__mro__.__len__()==2; partialmethod/__mro__.__len__()==2; cached_property/__mro__.__len__()==2; lru_cache/__qualname__.__len__()==9; cache/__qualname__.__len__()==5."
    - "This spec covers: functools.cached_property.__bases__[0].__qualname__ == 'object'; functools.partialmethod.__bases__[0].__qualname__ == 'object'; functools.partial.__bases__[0].__qualname__ == 'object'; functools.singledispatchmethod.__bases__[0].__qualname__ == 'object'."
    - "Key findings: All four functools classes (cached_property, partialmethod, partial, singledispatchmethod) have __bases__[0].__qualname__ == 'object'. cached_property and partialmethod are pure-Python classes defined at module level in Lib/functools.py; partial is a C-extension type defined in Modules/_functoolsmodule.c; singledispatchmethod is a pure-Python class also in Lib/functools.py. All four inherit directly from object as their sole base class, so __bases__ is a 1-tuple containing object. Prior specs recorded __bases__[0].__name__ == 'object' (string equality via __name__) for these classes, but no prior spec recorded __bases__[0].__qualname__ equality. For the built-in object type, __qualname__ == __name__ == 'object', so both attributes yield the same string. All four invariants are new to extra50."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools class __bases__[0].__qualname__ — extra50 namespace
#
# functools.cached_property, partialmethod, partial, and singledispatchmethod
# each have __bases__[0].__qualname__ == 'object'. All four types inherit
# directly from object as their only base class. For the built-in object type,
# __qualname__ equals __name__ (both are 'object'). Prior specs recorded
# __bases__[0].__name__ == 'object' for these classes (confirmed via __name__
# string equality), but no prior spec recorded the __qualname__ attribute on
# the base class. These four invariants are new to extra50.
#
# partial is a C-extension type (Modules/_functoolsmodule.c); the other three
# are pure-Python classes in Lib/functools.py. Despite the implementation
# difference, all four have the same single base class: object.
# ---------------------------------------------------------------------------

table functools_extra50.class_bases_qualname:
  description: "functools class __bases__[0].__qualname__ == 'object' — cached_property/partialmethod/partial/singledispatchmethod all inherit directly from object; __qualname__ == __name__ == 'object' for built-in object type"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cbq50

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_bases_qualname,
       "cached_property.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__bases__[0].__qualname__ == 'object' — pure-Python class in Lib/functools.py; inherits directly from object; descriptor that caches the result of a method as a property on the instance"]
    - [partialmethod_bases_qualname,
       "partialmethod.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__bases__[0].__qualname__ == 'object' — pure-Python class in Lib/functools.py; inherits directly from object; descriptor that behaves like partial but is designed for use in class bodies"]
    - [partial_bases_qualname,
       "partial.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__qualname__ == 'object' — C-extension type in Modules/_functoolsmodule.c; inherits directly from object; creates partial application of a callable with fixed positional or keyword arguments"]
    - [singledispatchmethod_bases_qualname,
       "singledispatchmethod.__bases__[0].__qualname__.__eq__",
       ["object"],
       true,
       "functools.singledispatchmethod.__bases__[0].__qualname__ == 'object' — pure-Python class in Lib/functools.py; inherits directly from object; enables single-dispatch on the first non-self argument of a method (as opposed to singledispatch which targets plain functions)"]
