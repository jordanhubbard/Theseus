    - "inspect.signature.__code__.co_argcount == 1 — takes one positional argument (obj). Verified with Python 3.14.3."
    - "len(inspect.signature.__code__.co_varnames) == 6 — local vars: obj, follow_wrapped, globals, locals, eval_str, annotation_format. Verified with Python 3.14.3."
    - "inspect.signature.__code__.co_varnames[0] == 'obj'. Verified with Python 3.14.3."
    - "inspect.signature.__code__.co_varnames[1] == 'follow_wrapped'. Verified with Python 3.14.3."
    - "inspect.signature.__code__.co_varnames[2] == 'globals'. Verified with Python 3.14.3."
    - "inspect.Parameter.__name__ == 'Parameter' (len 9). Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Parameter.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "inspect.Parameter.__qualname__ == 'Parameter' (len 9). Verified with Python 3.14.3."
    - "len(inspect.Parameter.__mro__) == 2 — MRO is [Parameter, object]. Verified with Python 3.14.3."
    - "inspect.Parameter.__init__.__qualname__ == 'Parameter.__init__' (len 18). Verified with Python 3.14.3."
    - "inspect.Parameter.__init__.__code__.co_argcount == 3 — takes self, name, kind. Verified with Python 3.14.3."
    - "len(inspect.Parameter.__init__.__code__.co_varnames) == 7. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.signature qualname and code attributes
#
# Wave 262 theme: inspect.signature function qualname and code.
#
# inspect.signature.__qualname__ == 'signature' (len 9)
# inspect.signature.__module__ == 'inspect'
# inspect.signature.__class__.__name__ == 'function'
# inspect.signature.__code__.co_argcount == 1
# len(inspect.signature.__code__.co_varnames) == 6
# inspect.signature.__code__.co_varnames[0] == 'obj'
# inspect.signature.__code__.co_varnames[1] == 'follow_wrapped'
#
# inspect.signature is defined in Lib/inspect.py taking (obj, *, follow_wrapped=True,
# globals=None, locals=None, eval_str=False, annotation_format=...). The positional
# parameter is only obj; the rest are keyword-only (not counted in co_argcount). New to extra134.
# ---------------------------------------------------------------------------

table inspect_extra134.signature_code_attrs:
  description: "inspect.signature code attributes: __qualname__ len 9, __module__=='inspect', co_argcount==1, co_varnames len 6, co_varnames[0]=='obj', co_varnames[1]=='follow_wrapped'; wave 262; new to extra134"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectsig134

  columns: [id, function, args, expected, description]
  rows:
    - [signature_qualname_eq,
       "signature.__qualname__.__eq__",
       ["signature"],
       true,
       "inspect.signature.__qualname__.__eq__('signature') == True — signature is defined at module scope in Lib/inspect.py; its __qualname__ is 'signature'; str.__eq__('signature') returns True; new to extra134"]
    - [signature_qualname_len_eq_9,
       "signature.__qualname__.__len__",
       [],
       9,
       "inspect.signature.__qualname__.__len__() == 9 — __qualname__ is 'signature' which has 9 characters; len('signature') == 9; new to extra134"]
    - [signature_module_eq_inspect,
       "signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.signature.__module__.__eq__('inspect') == True — signature is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra134"]
    - [signature_class_name_eq_function,
       "signature.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.signature.__class__.__name__.__eq__('function') == True — signature is a plain Python function defined in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra134"]
    - [signature_co_argcount_eq_1,
       "signature.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.signature.__code__.co_argcount.__eq__(1) == True — signature has one positional argument (obj); the remaining parameters are keyword-only and not counted in co_argcount; int.__eq__(1) returns True; new to extra134"]
    - [signature_co_varnames_len_eq_6,
       "signature.__code__.co_varnames.__len__",
       [],
       6,
       "inspect.signature.__code__.co_varnames.__len__() == 6 — signature has 6 local variables: obj, follow_wrapped, globals, locals, eval_str, annotation_format; len(co_varnames) == 6; new to extra134"]
    - [signature_co_varnames_0_eq_obj,
       "signature.__code__.co_varnames[0].__eq__",
       ["obj"],
       true,
       "inspect.signature.__code__.co_varnames[0].__eq__('obj') == True — the first local variable of signature is 'obj', the object whose signature is to be retrieved; str.__eq__('obj') returns True; new to extra134"]
    - [signature_co_varnames_1_eq_follow_wrapped,
       "signature.__code__.co_varnames[1].__eq__",
       ["follow_wrapped"],
       true,
       "inspect.signature.__code__.co_varnames[1].__eq__('follow_wrapped') == True — the second local variable of signature is 'follow_wrapped', a keyword-only parameter controlling whether __wrapped__ is followed; str.__eq__('follow_wrapped') returns True; new to extra134"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter class identity
#
# Wave 262 theme: inspect.Parameter class identity.
#
# inspect.Parameter.__name__ == 'Parameter' (len 9)
# inspect.Parameter.__module__ == 'inspect'
# inspect.Parameter.__class__.__name__ == 'type'
# inspect.Parameter.__qualname__ == 'Parameter' (len 9)
# len(inspect.Parameter.__mro__) == 2
# inspect.Parameter.__bases__[0].__name__ == 'object'
#
# inspect.Parameter is a Python class defined in Lib/inspect.py that
# represents a parameter of a callable. New to extra134.
# ---------------------------------------------------------------------------

table inspect_extra134.parameter_class_identity:
  description: "inspect.Parameter class identity: __name__ len 9, __module__=='inspect', __class__.__name__=='type', __qualname__ len 9, MRO len 2; wave 262; new to extra134"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparam134

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_name_eq,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter is a Python class defined in Lib/inspect.py; its __name__ attribute is 'Parameter'; str.__eq__('Parameter') returns True; new to extra134"]
    - [parameter_name_len_eq_9,
       "Parameter.__name__.__len__",
       [],
       9,
       "inspect.Parameter.__name__.__len__() == 9 — __name__ is 'Parameter' which has 9 characters; len('Parameter') == 9; new to extra134"]
    - [parameter_module_eq_inspect,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra134"]
    - [parameter_class_name_eq_type,
       "Parameter.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.__class__.__name__.__eq__('type') == True — Parameter is a Python class; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra134"]
    - [parameter_qualname_eq,
       "Parameter.__qualname__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__.__eq__('Parameter') == True — Parameter is defined at module scope in Lib/inspect.py; its __qualname__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra134"]
    - [parameter_qualname_len_eq_9,
       "Parameter.__qualname__.__len__",
       [],
       9,
       "inspect.Parameter.__qualname__.__len__() == 9 — __qualname__ is 'Parameter' which has 9 characters; len('Parameter') == 9; new to extra134"]
    - [parameter_mro_len_eq_2,
       "Parameter.__mro__.__len__",
       [],
       2,
       "inspect.Parameter.__mro__.__len__() == 2 — Parameter's MRO is [Parameter, object]; it inherits only from object; len(__mro__) is 2; new to extra134"]
    - [parameter_bases_first_eq_object,
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter inherits only from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra134"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter.__init__ qualname and code attributes
#
# Wave 262 theme: inspect.Parameter.__init__ qualname and co_argcount.
#
# inspect.Parameter.__init__.__qualname__ == 'Parameter.__init__' (len 18)
# inspect.Parameter.__init__.__class__.__name__ == 'function'
# inspect.Parameter.__init__.__code__.co_argcount == 3
# len(inspect.Parameter.__init__.__code__.co_varnames) == 7
# inspect.Parameter.__init__.__code__.co_varnames[0] == 'self'
# inspect.Parameter.__init__.__code__.co_varnames[1] == 'name'
# inspect.Parameter.__init__.__code__.co_varnames[2] == 'kind'
#
# Parameter.__init__ takes (self, name, kind, *, default=..., annotation=...).
# co_argcount is 3 (self, name, kind); default and annotation are keyword-only.
# co_varnames has 7 entries: self, name, kind, default, annotation, msg, is_keyword.
# New to extra134.
# ---------------------------------------------------------------------------

table inspect_extra134.parameter_init_attrs:
  description: "inspect.Parameter.__init__ qualname len 18, co_argcount==3, co_varnames len 7, co_varnames[0..2]==(self, name, kind); wave 262; new to extra134"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparaminit134

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_init_qualname_eq,
       "Parameter.__init__.__qualname__.__eq__",
       ["Parameter.__init__"],
       true,
       "inspect.Parameter.__init__.__qualname__.__eq__('Parameter.__init__') == True — Parameter.__init__ is a method defined inside the Parameter class body in Lib/inspect.py; its __qualname__ is 'Parameter.__init__'; str.__eq__('Parameter.__init__') returns True; new to extra134"]
    - [parameter_init_qualname_len_eq_18,
       "Parameter.__init__.__qualname__.__len__",
       [],
       18,
       "inspect.Parameter.__init__.__qualname__.__len__() == 18 — __qualname__ is 'Parameter.__init__' which has 18 characters; len('Parameter.__init__') == 18; new to extra134"]
    - [parameter_init_class_name_eq_function,
       "Parameter.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.Parameter.__init__.__class__.__name__.__eq__('function') == True — Parameter.__init__ is a regular Python function defined inside the class body; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra134"]
    - [parameter_init_co_argcount_eq_3,
       "Parameter.__init__.__code__.co_argcount.__eq__",
       [3],
       true,
       "inspect.Parameter.__init__.__code__.co_argcount.__eq__(3) == True — Parameter.__init__ takes 3 positional arguments (self, name, kind); default and annotation are keyword-only and not counted; co_argcount is 3; int.__eq__(3) returns True; new to extra134"]
    - [parameter_init_co_varnames_len_eq_7,
       "Parameter.__init__.__code__.co_varnames.__len__",
       [],
       7,
       "inspect.Parameter.__init__.__code__.co_varnames.__len__() == 7 — Parameter.__init__ has 7 local variables: self, name, kind, default, annotation, msg, is_keyword; len(co_varnames) == 7; new to extra134"]
    - [parameter_init_co_varnames_0_eq_self,
       "Parameter.__init__.__code__.co_varnames[0].__eq__",
       ["self"],
       true,
       "inspect.Parameter.__init__.__code__.co_varnames[0].__eq__('self') == True — the first local variable of Parameter.__init__ is 'self'; str.__eq__('self') returns True; new to extra134"]
    - [parameter_init_co_varnames_1_eq_name,
       "Parameter.__init__.__code__.co_varnames[1].__eq__",
       ["name"],
       true,
       "inspect.Parameter.__init__.__code__.co_varnames[1].__eq__('name') == True — the second local variable of Parameter.__init__ is 'name', the parameter name string; str.__eq__('name') returns True; new to extra134"]
    - [parameter_init_co_varnames_2_eq_kind,
       "Parameter.__init__.__code__.co_varnames[2].__eq__",
       ["kind"],
       true,
       "inspect.Parameter.__init__.__code__.co_varnames[2].__eq__('kind') == True — the third local variable of Parameter.__init__ is 'kind', an integer constant from the ParameterKind enum specifying the parameter kind; str.__eq__('kind') returns True; new to extra134"]

