# Standalone invariants — extra134
# ---------------------------------------------------------------------------

invariant inspect_extra134.signature_qualname_len:
  description: "len(inspect.signature.__qualname__) == 9 — __qualname__ is 'signature'; wave 262; new to extra134"
  kind: python_call_eq
  function: signature.__qualname__.__len__
  args: []
  expected: 9

invariant inspect_extra134.signature_co_varnames_len:
  description: "len(inspect.signature.__code__.co_varnames) == 6 — local vars: obj, follow_wrapped, globals, locals, eval_str, annotation_format; wave 262; new to extra134"
  kind: python_call_eq
  function: signature.__code__.co_varnames.__len__
  args: []
  expected: 6

invariant inspect_extra134.parameter_class_is_type:
  description: "inspect.Parameter.__class__.__name__ == 'type' — Parameter is a Python class, not a function; wave 262; new to extra134"
  kind: python_call_eq
  function: Parameter.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra134.parameter_mro_len:
  description: "len(inspect.Parameter.__mro__) == 2 — Parameter MRO is [Parameter, object]; wave 262; new to extra134"
  kind: python_call_eq
  function: Parameter.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra134.parameter_init_qualname_len:
  description: "len(inspect.Parameter.__init__.__qualname__) == 18 — __qualname__ is 'Parameter.__init__'; wave 262; new to extra134"
  kind: python_call_eq
  function: Parameter.__init__.__qualname__.__len__
