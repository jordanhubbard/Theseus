spec: pathlib_extra152
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path class method __qualname__ values (cwd, home, stat, exists, is_file, is_dir, resolve, absolute) and pathlib.PurePath property getter __qualname__ values (parent, stem, suffix, name, drive, root, anchor, parts, parents)."
    - "pathlib.Path.cwd.__qualname__ == 'Path.cwd' (len=8; shortest among Path method qualnames covered here)."
    - "pathlib.Path.home.__qualname__ == 'Path.home' (len=9); cwd and home are classmethods."
    - "pathlib.Path.resolve.__qualname__ == 'Path.resolve' (len=12); pathlib.Path.absolute.__qualname__ == 'Path.absolute' (len=13)."
    - "pathlib.Path.stat.__qualname__ == 'Path.stat' (len=9); tied with home."
    - "pathlib.Path.exists.__qualname__ == 'Path.exists' (len=11); is_file=12, is_dir=11."
    - "pathlib.PurePath property getter qualnames follow 'PurePath.<prop>' pattern: name/stem/root=13, drive/parts=14, suffix/anchor/parent=15, parents=16."
    - "pathlib.PurePath.parent.fget.__qualname__ == 'PurePath.parent' (len=15); the parent property getter is defined on PurePath, not Path."
    - "pathlib.PurePath.parts.fget.__qualname__ == 'PurePath.parts' (len=14)."
    - "pathlib.PurePath.parents.fget.__qualname__ == 'PurePath.parents' (len=16; longest PurePath property getter qualname)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path class method __qualname__ values and lengths
# cwd=8 (shortest), home/stat=9, exists/is_dir=11, resolve/is_file=12, absolute=13.
# All have __module__ == 'pathlib'.
# ---------------------------------------------------------------------------

table pathlib_extra152.Path_method_qualnames:
  description: "pathlib.Path method __qualname__ values: cwd=8, home/stat=9, exists/is_dir=11, resolve/is_file=12, absolute=13; all have __module__=='pathlib'"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibmeth152

  columns: [id, function, args, expected, description]
  rows:
    - [cwd_qeq,       Path.cwd.__qualname__.__eq__,       ["Path.cwd"],       true, "pathlib.Path.cwd.__qualname__ == 'Path.cwd' (len=8; classmethod returning the current working directory as a Path object)"]
    - [cwd_qlen,      Path.cwd.__qualname__.__len__,      [],                  8,    "pathlib.Path.cwd.__qualname__.__len__() == 8 ('Path.cwd' has 8 characters; the shortest Path method qualname covered in this spec)"]
    - [home_qeq,      Path.home.__qualname__.__eq__,      ["Path.home"],      true, "pathlib.Path.home.__qualname__ == 'Path.home' (len=9; classmethod returning the user's home directory as a Path object)"]
    - [home_qlen,     Path.home.__qualname__.__len__,     [],                  9,    "pathlib.Path.home.__qualname__.__len__() == 9 ('Path.home' has 9 characters; tied with stat)"]
    - [stat_qeq,      Path.stat.__qualname__.__eq__,      ["Path.stat"],      true, "pathlib.Path.stat.__qualname__ == 'Path.stat' (len=9; returns an os.stat_result for the path; tied with home)"]
    - [stat_qlen,     Path.stat.__qualname__.__len__,     [],                  9,    "pathlib.Path.stat.__qualname__.__len__() == 9 (tied with home at 9)"]
    - [exists_qeq,    Path.exists.__qualname__.__eq__,    ["Path.exists"],    true, "pathlib.Path.exists.__qualname__ == 'Path.exists' (len=11; returns True if the path points to an existing file or directory)"]
    - [exists_qlen,   Path.exists.__qualname__.__len__,   [],                  11,   "pathlib.Path.exists.__qualname__.__len__() == 11 ('Path.exists' has 11 characters; tied with is_dir)"]
    - [isdir_qeq,     Path.is_dir.__qualname__.__eq__,    ["Path.is_dir"],    true, "pathlib.Path.is_dir.__qualname__ == 'Path.is_dir' (len=11; returns True if the path is a directory; tied with exists)"]
    - [isdir_qlen,    Path.is_dir.__qualname__.__len__,   [],                  11,   "pathlib.Path.is_dir.__qualname__.__len__() == 11 (tied with exists at 11)"]
    - [resolve_qeq,   Path.resolve.__qualname__.__eq__,   ["Path.resolve"],   true, "pathlib.Path.resolve.__qualname__ == 'Path.resolve' (len=12; makes the path absolute, resolving symlinks; tied with is_file)"]
    - [resolve_qlen,  Path.resolve.__qualname__.__len__,  [],                  12,   "pathlib.Path.resolve.__qualname__.__len__() == 12 ('Path.resolve' has 12 characters; tied with is_file)"]
    - [isfile_qeq,    Path.is_file.__qualname__.__eq__,   ["Path.is_file"],   true, "pathlib.Path.is_file.__qualname__ == 'Path.is_file' (len=12; returns True if the path is a regular file; tied with resolve)"]
    - [absolute_qeq,  Path.absolute.__qualname__.__eq__,  ["Path.absolute"],  true, "pathlib.Path.absolute.__qualname__ == 'Path.absolute' (len=13; makes the path absolute without resolving symlinks; 1 character longer than resolve)"]
    - [absolute_qlen, Path.absolute.__qualname__.__len__, [],                  13,   "pathlib.Path.absolute.__qualname__.__len__() == 13 ('Path.absolute' has 13 characters; the longest Path method qualname covered in this spec)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath property getter __qualname__ values and lengths
# All follow 'PurePath.<prop>' pattern.
# name/stem/root=13, drive/parts=14, suffix/anchor/parent=15, parents=16.
# ---------------------------------------------------------------------------

table pathlib_extra152.PurePath_property_getter_qualnames:
  description: "pathlib.PurePath property getter __qualname__ values: name/stem/root=13, drive/parts=14, suffix/anchor/parent=15, parents=16; all follow 'PurePath.<prop>' pattern"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibmeth152

  columns: [id, function, args, expected, description]
  rows:
    - [name_fget_qeq,    PurePath.name.fget.__qualname__.__eq__,    ["PurePath.name"],    true, "pathlib.PurePath.name.fget.__qualname__ == 'PurePath.name' (len=13; final path component without its parent directory)"]
    - [name_fget_qlen,   PurePath.name.fget.__qualname__.__len__,   [],                   13,   "pathlib.PurePath.name.fget.__qualname__.__len__() == 13 ('PurePath.name' has 13 characters; tied with stem and root)"]
    - [stem_fget_qeq,    PurePath.stem.fget.__qualname__.__eq__,    ["PurePath.stem"],    true, "pathlib.PurePath.stem.fget.__qualname__ == 'PurePath.stem' (len=13; final component without its suffix; tied with name and root)"]
    - [root_fget_qeq,    PurePath.root.fget.__qualname__.__eq__,    ["PurePath.root"],    true, "pathlib.PurePath.root.fget.__qualname__ == 'PurePath.root' (len=13; the root of the path, e.g. '/' on POSIX; tied with name and stem)"]
    - [root_fget_qlen,   PurePath.root.fget.__qualname__.__len__,   [],                   13,   "pathlib.PurePath.root.fget.__qualname__.__len__() == 13 (tied with name and stem at 13)"]
    - [drive_fget_qeq,   PurePath.drive.fget.__qualname__.__eq__,   ["PurePath.drive"],   true, "pathlib.PurePath.drive.fget.__qualname__ == 'PurePath.drive' (len=14; the drive letter or name, if any)"]
    - [drive_fget_qlen,  PurePath.drive.fget.__qualname__.__len__,  [],                   14,   "pathlib.PurePath.drive.fget.__qualname__.__len__() == 14 ('PurePath.drive' has 14 characters; tied with parts)"]
    - [parts_fget_qeq,   PurePath.parts.fget.__qualname__.__eq__,   ["PurePath.parts"],   true, "pathlib.PurePath.parts.fget.__qualname__ == 'PurePath.parts' (len=14; an immutable sequence of the path components; tied with drive)"]
    - [suffix_fget_qeq,  PurePath.suffix.fget.__qualname__.__eq__,  ["PurePath.suffix"],  true, "pathlib.PurePath.suffix.fget.__qualname__ == 'PurePath.suffix' (len=15; the file extension of the final component, e.g. '.py')"]
    - [suffix_fget_qlen, PurePath.suffix.fget.__qualname__.__len__, [],                   15,   "pathlib.PurePath.suffix.fget.__qualname__.__len__() == 15 ('PurePath.suffix' has 15 characters; tied with anchor and parent)"]
    - [anchor_fget_qeq,  PurePath.anchor.fget.__qualname__.__eq__,  ["PurePath.anchor"],  true, "pathlib.PurePath.anchor.fget.__qualname__ == 'PurePath.anchor' (len=15; concatenation of drive and root, e.g. '/' on POSIX; tied with suffix and parent)"]
    - [parent_fget_qeq,  PurePath.parent.fget.__qualname__.__eq__,  ["PurePath.parent"],  true, "pathlib.PurePath.parent.fget.__qualname__ == 'PurePath.parent' (len=15; the logical parent of the path; tied with suffix and anchor)"]
    - [parent_fget_qlen, PurePath.parent.fget.__qualname__.__len__, [],                   15,   "pathlib.PurePath.parent.fget.__qualname__.__len__() == 15 (tied with suffix and anchor at 15)"]
    - [parents_fget_qeq, PurePath.parents.fget.__qualname__.__eq__, ["PurePath.parents"], true, "pathlib.PurePath.parents.fget.__qualname__ == 'PurePath.parents' (len=16; an immutable sequence of the path's logical ancestors; longest PurePath property getter qualname)"]
    - [parents_fget_len, PurePath.parents.fget.__qualname__.__len__,[],                   16,   "pathlib.PurePath.parents.fget.__qualname__.__len__() == 16 ('PurePath.parents' has 16 characters; the longest PurePath property getter qualname — 'parents' is 7 chars vs 'parent' 6)"]

# ---------------------------------------------------------------------------
# pathlib.Path class method module checks and property class checks
# cwd and home are classmethods; their __module__ == 'pathlib'.
# PurePath properties have __class__.__name__ == 'property'.
# ---------------------------------------------------------------------------

table pathlib_extra152.Path_method_module_and_property_class:
  description: "pathlib.Path class method __module__=='pathlib'; PurePath properties __class__.__name__=='property'"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmeth152

  columns: [id, function, args, expected, description]
  rows:
    - [cwd_mod_eq,       Path.cwd.__module__.__eq__,                     ["pathlib"], true, "pathlib.Path.cwd.__module__ == 'pathlib'"]
    - [home_mod_eq,      Path.home.__module__.__eq__,                    ["pathlib"], true, "pathlib.Path.home.__module__ == 'pathlib'"]
    - [resolve_mod_eq,   Path.resolve.__module__.__eq__,                 ["pathlib"], true, "pathlib.Path.resolve.__module__ == 'pathlib' (all Path methods have __module__ == 'pathlib')"]
    - [absolute_mod_eq,  Path.absolute.__module__.__eq__,                ["pathlib"], true, "pathlib.Path.absolute.__module__ == 'pathlib'"]
    - [parent_cls_eq,    PurePath.parent.__class__.__name__.__eq__,      ["property"],true, "pathlib.PurePath.parent.__class__.__name__ == 'property' (parent is a Python property descriptor)"]
    - [parts_cls_eq,     PurePath.parts.__class__.__name__.__eq__,       ["property"],true, "pathlib.PurePath.parts.__class__.__name__ == 'property' (parts is a Python property descriptor)"]
    - [suffix_cls_eq,    PurePath.suffix.__class__.__name__.__eq__,      ["property"],true, "pathlib.PurePath.suffix.__class__.__name__ == 'property' (suffix is a Python property descriptor)"]
    - [parents_cls_eq,   PurePath.parents.__class__.__name__.__eq__,     ["property"],true, "pathlib.PurePath.parents.__class__.__name__ == 'property' (parents is a Python property descriptor)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra152.Path.cwd_qualname_eq:
  description: "pathlib.Path.cwd.__qualname__ == 'Path.cwd' (len=8) — cwd is a classmethod that returns the current working directory; at 8 characters it is the shortest Path method qualname covered in this spec, shorter than home (9), stat (9), and all others"
  category: qualname
  kind: python_call_eq
  function: Path.cwd.__qualname__.__eq__
  args: ["Path.cwd"]
  expected: true

invariant pathlib_extra152.Path.absolute_qualname_len_13:
  description: "pathlib.Path.absolute.__qualname__.__len__() == 13 ('Path.absolute' has 13 characters; the longest Path method qualname in this spec; absolute() makes the path absolute without resolving symlinks, unlike resolve() which does follow symlinks)"
  category: qualname
  kind: python_call_eq
  function: Path.absolute.__qualname__.__len__
  args: []
  expected: 13

invariant pathlib_extra152.PurePath.parent_fget_qualname_eq:
  description: "pathlib.PurePath.parent.fget.__qualname__ == 'PurePath.parent' (len=15) — the parent property is a Python property descriptor defined on PurePath; Path.parent is the same object, confirming inheritance from PurePath; the .fget attribute accesses the underlying getter function"
  category: qualname
  kind: python_call_eq
  function: PurePath.parent.fget.__qualname__.__eq__
  args: ["PurePath.parent"]
  expected: true

invariant pathlib_extra152.PurePath.parents_fget_qualname_len_16:
  description: "pathlib.PurePath.parents.fget.__qualname__.__len__() == 16 ('PurePath.parents' has 16 characters; the longest PurePath property getter qualname; 'parents' (7 chars) is 1 character longer than 'parent' (6 chars), making its qualname 16 vs 15)"
  category: qualname
  kind: python_call_eq
  function: PurePath.parents.fget.__qualname__.__len__
  args: []
  expected: 16

invariant pathlib_extra152.PurePath.name_fget_qualname_len_13:
  description: "pathlib.PurePath.name.fget.__qualname__.__len__() == 13 ('PurePath.name' has 13 characters; tied with stem (13) and root (13); all three have 4-character property names: 'name', 'stem', 'root' plus 'PurePath.' (9) = 13)"
  category: qualname
  kind: python_call_eq
  function: PurePath.name.fget.__qualname__.__len__
  args: []
  expected: 13

invariant pathlib_extra152.PurePath.suffix_fget_qualname_len_15:
  description: "pathlib.PurePath.suffix.fget.__qualname__.__len__() == 15 ('PurePath.suffix' has 15 characters; tied with anchor (15) and parent (15); 'suffix', 'anchor', 'parent' each have 6 characters, giving 'PurePath.' (9) + 6 = 15)"
  category: qualname
  kind: python_call_eq
  function: PurePath.suffix.fget.__qualname__.__len__
  args: []
  expected: 15

invariant pathlib_extra152.Path.home_qualname_len_9:
  description: "pathlib.Path.home.__qualname__.__len__() == 9 ('Path.home' has 9 characters; home is a classmethod that returns the user's home directory as a Path; tied with stat (9); both have 4-character method names: 'home', 'stat' plus 'Path.' (5) = 9)"
  category: qualname
  kind: python_call_eq
  function: Path.home.__qualname__.__len__
  args: []
  expected: 9

invariant pathlib_extra152.PurePath.drive_fget_qualname_len_14:
  description: "pathlib.PurePath.drive.fget.__qualname__.__len__() == 14 ('PurePath.drive' has 14 characters; tied with parts (14); 'drive' and 'parts' each have 5 characters, giving 'PurePath.' (9) + 5 = 14)"
  category: qualname
  kind: python_call_eq
  function: PurePath.drive.fget.__qualname__.__len__
  args: []
  expected: 14
