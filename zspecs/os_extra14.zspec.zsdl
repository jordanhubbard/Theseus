spec: os_extra14
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "CPython source: Lib/os.py"
  notes:
    - "This spec extends os.zspec.zsdl and prior extras through os_extra13.zspec.zsdl."
    - "os_extra13 covers: pathsep == ':'/isascii/__len__; getenv default variant; strerror nonempty/__module__; cpu_count/__module__; extsep.isascii; getenv/__module__; listdir/__module__; makedirs/__module__; devnull.startswith('/dev')."
    - "os_extra10 covers: stat_result/__qualname__; DirEntry/__qualname__/__module__; terminal_size/__qualname__/__module__; PathLike/__qualname__."
    - "os_extra7 covers: PathLike/__module__; stat_result/__module__; terminal_size/__name__."
    - "os_extra4 covers: stat_result/__name__; DirEntry/__name__; times_result class name via os.times().__class__.__name__."
    - "os_extra8 covers: environ.__class__.__qualname__ == '_Environ'; environ.__class__.__module__ == 'os'."
    - "os_environ.zspec.zsdl covers: environ.__class__.__name__ == '_Environ'."
    - "No prior spec covers: os.stat_result.__bases__[0].__name__ == 'tuple' — stat_result is a tuple subclass."
    - "No prior spec covers: os.DirEntry.__bases__[0].__name__ == 'object' — DirEntry inherits directly from object."
    - "No prior spec covers: os.PathLike.__bases__[0].__name__ == 'ABC' — PathLike is an abstract base class via ABCMeta."
    - "No prior spec covers: os.terminal_size.__bases__[0].__name__ == 'tuple' — terminal_size is a tuple subclass."
    - "No prior spec covers: os.times_result.__name__ == 'times_result' as a direct attribute read."
    - "No prior spec covers: os.times_result.__module__ == 'posix' — times_result is defined in the posix C extension."
    - "No prior spec covers: os.scandir.__module__ == 'posix' — scandir is implemented in the posix C extension."
    - "No prior spec covers: os.environ.__class__.__mro__[1].__name__ == 'MutableMapping' — _Environ inherits from MutableMapping."
    - "os.stat_result and os.terminal_size are tuple subclasses (C-level struct sequences)."
    - "os.DirEntry is a C-extension type inheriting from object; its bases are (object,)."
    - "os.PathLike is an ABC defined in os.py; its first base is ABC from the abc module."
    - "os.times_result is the C-extension named-tuple type returned by os.times(); __module__ == 'posix'."
    - "os.scandir is implemented in the posix C extension; its __module__ == 'posix'."
    - "os.environ.__class__.__mro__[1].__name__ == 'MutableMapping' — _Environ is a MutableMapping subclass."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# stat_result and terminal_size — tuple subclass bases
#
# os_extra4 and os_extra7 cover stat_result/__name__ and __module__.
# os_extra10 covers stat_result/__qualname__.
# No prior spec checks stat_result.__bases__[0].__name__ == 'tuple'.
# Both stat_result and terminal_size are C-level struct_sequence types that
# subclass tuple.
# ---------------------------------------------------------------------------

invariant os_extra14.stat_result.base:
  description: "os.stat_result.__bases__[0].__name__ == 'tuple' — stat_result is a tuple subclass"
  category: class_hierarchy
  kind: python_call_eq
  function: stat_result.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "tuple"

invariant os_extra14.terminal_size.base:
  description: "os.terminal_size.__bases__[0].__name__ == 'tuple' — terminal_size is a tuple subclass"
  category: class_hierarchy
  kind: python_call_eq
  function: terminal_size.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "tuple"

# ---------------------------------------------------------------------------
# DirEntry — inherits directly from object
#
# os_extra7 covers DirEntry/__name__; os_extra10 covers DirEntry/__qualname__ and __module__.
# No prior spec checks DirEntry.__bases__[0].__name__.
# DirEntry is a C-extension type; its bases are (object,).
# ---------------------------------------------------------------------------

invariant os_extra14.DirEntry.base:
  description: "os.DirEntry.__bases__[0].__name__ == 'object' — DirEntry inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: DirEntry.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# PathLike — abstract base class inheriting from ABC
#
# os_extra6 covers PathLike/__name__; os_extra7 covers PathLike/__module__;
# os_extra10 covers PathLike/__qualname__.
# No prior spec checks PathLike.__bases__[0].__name__ == 'ABC'.
# PathLike is defined in os.py using ABCMeta; its first base is abc.ABC.
# ---------------------------------------------------------------------------

invariant os_extra14.PathLike.base:
  description: "os.PathLike.__bases__[0].__name__ == 'ABC' — PathLike extends abc.ABC"
  category: class_hierarchy
  kind: python_call_eq
  function: PathLike.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ABC"

# ---------------------------------------------------------------------------
# times_result — __name__ and __module__
#
# os_extra4 checks os.times().__class__.__name__ == 'times_result' (via a call result).
# No prior spec checks os.times_result.__name__ as a direct class attribute read.
# No prior spec checks os.times_result.__module__ == 'posix'.
# times_result is a C-extension struct_sequence type in the posix module.
# ---------------------------------------------------------------------------

invariant os_extra14.times_result.name:
  description: "os.times_result.__name__ == 'times_result' — class name of the times() result"
  category: class_names
  kind: python_call_eq
  function: times_result.__name__.__eq__
  args: ["times_result"]
  expected: true

invariant os_extra14.times_result.module:
  description: "os.times_result.__module__ == 'posix' — times_result is defined in the posix C extension"
  category: class_modules
  kind: python_call_eq
  function: times_result.__module__.__eq__
  args: ["posix"]
  expected: true

# ---------------------------------------------------------------------------
# os.scandir — __module__ check
#
# os_extra9 covers scandir/__qualname__; os.zspec covers scandir/__name__.
# No prior spec checks scandir.__module__ == 'posix'.
# scandir is implemented in the posix C extension (Modules/posixmodule.c).
# ---------------------------------------------------------------------------

invariant os_extra14.scandir.module:
  description: "os.scandir.__module__ == 'posix' — scandir is implemented in the posix C extension"
  category: function_modules
  kind: python_call_eq
  function: scandir.__module__.__eq__
  args: ["posix"]
  expected: true

# ---------------------------------------------------------------------------
# os.environ — _Environ MRO depth 1 is MutableMapping
#
# os_environ.zspec.zsdl covers environ.__class__.__name__ == '_Environ'.
# os_extra8 covers environ.__class__.__qualname__ == '_Environ' and __module__ == 'os'.
# No prior spec checks environ.__class__.__mro__[1].__name__ == 'MutableMapping'.
# _Environ inherits from MutableMapping (from collections.abc), which provides
# the dict-like interface for os.environ.
# ---------------------------------------------------------------------------

invariant os_extra14.environ._Environ.mro_index1:
  description: "os.environ.__class__.__mro__[1].__name__ == 'MutableMapping' — _Environ inherits from MutableMapping"
  category: class_hierarchy
  kind: python_call_eq
  function: environ.__class__.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "MutableMapping"
