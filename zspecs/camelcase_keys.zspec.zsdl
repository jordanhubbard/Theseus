spec: camelcase_keys
version: ">=10.0.2"
backend: node(camelcase-keys)

docs: https://www.npmjs.com/package/camelcase-keys

provenance:
  derived_from:
    - "camelcase-keys README — https://www.npmjs.com/package/camelcase-keys"
    - "Test vectors verified with camelcase-keys via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "camelcase-keys source"
  notes:
    - "camelcase-keys is an npm package. Install: npm install camelcase-keys"
    - "Converts object keys from snake_case to camelCase. ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new object with camelCase keys."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table camelcase_keys.camelcaseKeys:
  kind: node_module_call_eq
  function: "default"
  category: transform
  id_prefix: cckeys

  columns: [id, args, expected]
  rows:
    - [snake_keys, [{"foo_bar": 1, "baz_qux": 2}], {"fooBar": 1, "bazQux": 2}]
    - [single,     [{"hello_world": "hi"}],          {"helloWorld": "hi"}]
