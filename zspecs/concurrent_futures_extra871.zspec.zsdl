  notes:
    - concurrent.futures class type identity checks via __class__.__name__
  created_at: "2026-04-12"

table concurrent_futures_extra871.class_type_identity:
  description: Verify that concurrent.futures class objects have __class__.__name__ equal to 'type' and function/attribute types
  kind: python_call_eq
  category: type_identity
  id_prefix: as871xx
  columns: [id, function, args, expected]
  rows:
    - [as871xx001, concurrent.futures.Future.__class__.__name__.__eq__, ["type"], true]
    - [as871xx002, concurrent.futures.ThreadPoolExecutor.__class__.__name__.__eq__, ["type"], true]
    - [as871xx003, concurrent.futures.ProcessPoolExecutor.__class__.__name__.__eq__, ["type"], true]
    - [as871xx004, concurrent.futures.Executor.__class__.__name__.__eq__, ["type"], true]
    - [as871xx005, concurrent.futures.BrokenExecutor.__class__.__name__.__eq__, ["type"], true]
    - [as871xx006, concurrent.futures.CancelledError.__class__.__name__.__eq__, ["type"], true]
    - [as871xx007, concurrent.futures.TimeoutError.__class__.__name__.__eq__, ["type"], true]
    - [as871xx008, concurrent.futures.InvalidStateError.__class__.__name__.__eq__, ["type"], true]
    - [as871xx009, concurrent.futures.as_completed.__class__.__name__.__eq__, ["function"], true]
    - [as871xx010, concurrent.futures.wait.__class__.__name__.__eq__, ["function"], true]
    - [as871xx011, concurrent.futures.__all__.__class__.__name__.__eq__, ["list"], true]
    - [as871xx012, concurrent.futures.Future.__doc__.__class__.__name__.__eq__, ["str"], true]
