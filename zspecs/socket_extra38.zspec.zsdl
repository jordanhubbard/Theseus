spec: socket_extra38
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra37.zspec.zsdl — covers socket.socket recvfrom/sendto/makefile/connect_ex/recv_into/recvfrom_into __name__.__len__(); dup/get_inheritable/set_inheritable __name__.__len__(); gaierror/herror/timeout __module__.__len__()."
    - "socket_extra35.zspec.zsdl — covers AddressFamily/SocketKind __mro__.__len__()==6; AF_INET/SOCK_STREAM __class__.__qualname__.__len__()."
    - "socket_extra30.zspec.zsdl — covers socket.__all__.__len__()==238; AF_INET/AF_INET6 __class__.__name__=='AddressFamily'; SOCK_STREAM/SOCK_DGRAM __class__.__name__=='SocketKind'."
    - "socket_extra16.zspec.zsdl — covers AddressFamily/__name__.__len__()==13; SocketKind/__name__.__len__()==10; AF_INET6/__class__.__name__.__len__()==13; SOCK_DGRAM/__class__.__name__.__len__()==10."
  notes:
    - "This spec extends socket through socket_extra37; it does NOT duplicate invariants present in those files."
    - "Platform portability: AF_INET6==30 (macOS) vs AF_INET6==10 (Linux); SOL_SOCKET==65535 (macOS) vs SOL_SOCKET==1 (Linux) — both are EXCLUDED as non-portable. AF_INET==2, SOCK_STREAM==1, and SOCK_DGRAM==2 are the same on both macOS and Linux and are included."
    - "socket.AF_INET == 2. AF_INET is the IPv4 address family constant. Its integer value is 2 on all major platforms (macOS, Linux). No prior spec checks AF_INET's integer value directly (extra30 covers AF_INET/__class__/__name__=='AddressFamily'; extra35 covers __class__/__qualname__.__len__()). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM == 1. SOCK_STREAM is the TCP socket type constant. Its integer value is 1 on all major platforms. No prior spec checks SOCK_STREAM's integer value directly. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM == 2. SOCK_DGRAM is the UDP socket type constant. Its integer value is 2 on all major platforms. No prior spec checks SOCK_DGRAM's integer value directly. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily'. Covered by socket_extra30 — EXCLUDED from this spec."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'. Covered by socket_extra30 — EXCLUDED from this spec."
    - "socket.getfqdn.__name__ == 'getfqdn'. getfqdn returns the fully qualified domain name. No prior spec checks getfqdn.__name__ as a string eq value (extra33 covers module-level function __name__.__len__() only for htonl/htons/ntohl/ntohs/create_server/gethostbyname; getfqdn is absent). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__module__ == 'socket'. getfqdn is a pure-Python function defined in Lib/socket.py. No prior spec checks getfqdn.__module__ in any capacity. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET, socket.SOCK_STREAM, socket.SOCK_DGRAM integer values
#
# These address family and socket type constants have well-known, portable
# integer values defined by POSIX and consistent across macOS and Linux:
#   AF_INET     == 2  (IPv4 address family)
#   SOCK_STREAM == 1  (TCP stream socket)
#   SOCK_DGRAM  == 2  (UDP datagram socket)
#
# extra30 covers __class__/__name__ string checks for these constants.
# extra35 covers __class__/__qualname__.__len__() for AF_INET/SOCK_STREAM.
# No prior spec checks the integer VALUES of these constants directly.
#
# NOTE: AF_INET6 (macOS:30, Linux:10) and SOL_SOCKET (macOS:65535, Linux:1)
# are platform-dependent and are intentionally NOT included in this spec.
# ---------------------------------------------------------------------------

table socket_extra38.portable_constant_values:
  description: "socket.AF_INET==2, SOCK_STREAM==1, SOCK_DGRAM==2 — portable integer values; novel: no prior spec checks these constants' integer values (extra30 covers __class__/__name__ only; extra35 covers __qualname__.__len__() only)"
  kind: python_call_eq
  category: behavioral
  id_prefix: spcv38

  columns: [id, function, args, expected]
  rows:
    - [AF_INET_value,     AF_INET.__eq__,     [2], true]
    - [SOCK_STREAM_value, SOCK_STREAM.__eq__,  [1], true]
    - [SOCK_DGRAM_value,  SOCK_DGRAM.__eq__,   [2], true]

# ---------------------------------------------------------------------------
# socket.getfqdn.__name__ and socket.getfqdn.__module__
#
# socket.getfqdn returns the fully qualified domain name for the current host.
# It is a pure-Python function defined in Lib/socket.py.
#
# getfqdn.__name__ == 'getfqdn': no prior spec checks getfqdn.__name__ as a
# string eq value (extra33 covers __name__.__len__() only for htonl/htons/
# ntohl/ntohs/create_server/gethostbyname; getfqdn is absent from all prior
# __name__ and __qualname__ checks).
#
# getfqdn.__module__ == 'socket': no prior spec checks getfqdn.__module__ in
# any capacity.
# ---------------------------------------------------------------------------

table socket_extra38.getfqdn_identity:
  description: "socket.getfqdn.__name__=='getfqdn' and socket.getfqdn.__module__=='socket' — novel: no prior spec checks getfqdn.__name__ or __module__ in any form"
  kind: python_call_eq
  category: function_names
  id_prefix: sgfqi38

  columns: [id, function, args, expected]
  rows:
    - [getfqdn_name_eq,   getfqdn.__name__.__eq__,   ["getfqdn"], true]
    - [getfqdn_module_eq, getfqdn.__module__.__eq__,  ["socket"],  true]
