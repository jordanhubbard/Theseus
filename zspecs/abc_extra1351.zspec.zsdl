spec: abc_extra1351
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Abstract Base Classes"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "Wave 537 (_extra1351): focuses on __slots__ and __weakref__ attribute checks at the class __dict__ level."
    - "abc.ABC defines __slots__ = () in its own class body, making __slots__ present in ABC.__dict__."
    - "abc.ABC does not define __weakref__ directly (slots=() suppresses weakref support by default, unless inherited)."
    - "abc.ABCMeta is a metaclass (subclass of type); it defines neither __slots__, __weakref__, nor __dict__ in its own __dict__."
    - "abc.abstractmethod does not define __slots__ or __weakref__ in its own __dict__."
    - "abc.abstractclassmethod and abstractstaticmethod define __weakref__ in their own __dict__ (top-level classes)."
    - "abc.abstractproperty defines both __weakref__ and __dict__ in its own __dict__ (top-level class with full instance support)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra1351.ABCMeta_ABC_slots_weakref_dict:
  description: "abc.ABCMeta and abc.ABC __slots__, __weakref__, __dict__ checks: ABC defines __slots__ = (), ABCMeta defines none"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: ab1351am
  columns: [id, function, args, expected]
  rows:
    - [ab1351am001, abc.ABCMeta.__dict__.__contains__, ["__slots__"],   false]
    - [ab1351am002, abc.ABCMeta.__dict__.__contains__, ["__weakref__"], false]
    - [ab1351am003, abc.ABCMeta.__dict__.__contains__, ["__dict__"],    false]
    - [ab1351am004, abc.ABC.__dict__.__contains__,     ["__slots__"],   true]
    - [ab1351am005, abc.ABC.__dict__.__contains__,     ["__weakref__"], false]
    - [ab1351am006, abc.ABC.__dict__.__contains__,     ["__dict__"],    false]

table abc_extra1351.abstractmethod_slots_weakref_dict:
  description: "abc.abstractmethod, abstractclassmethod, abstractstaticmethod __slots__, __weakref__, __dict__ checks"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: ab1351ab
  columns: [id, function, args, expected]
  rows:
    - [ab1351ab001, abc.abstractmethod.__dict__.__contains__,       ["__slots__"],   false]
    - [ab1351ab002, abc.abstractmethod.__dict__.__contains__,       ["__weakref__"], false]
    - [ab1351ab003, abc.abstractmethod.__dict__.__contains__,       ["__dict__"],    false]
    - [ab1351ab004, abc.abstractclassmethod.__dict__.__contains__,  ["__slots__"],   false]
    - [ab1351ab005, abc.abstractclassmethod.__dict__.__contains__,  ["__weakref__"], true]
    - [ab1351ab006, abc.abstractstaticmethod.__dict__.__contains__,  ["__weakref__"], true]

table abc_extra1351.abstractproperty_slots_weakref_dict:
  description: "abc.abstractproperty defines both __weakref__ and __dict__ in its own __dict__; abstractstaticmethod does not define __slots__"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: ab1351ap
  columns: [id, function, args, expected]
  rows:
    - [ab1351ap001, abc.abstractproperty.__dict__.__contains__,      ["__slots__"],   false]
    - [ab1351ap002, abc.abstractproperty.__dict__.__contains__,      ["__weakref__"], true]
    - [ab1351ap003, abc.abstractproperty.__dict__.__contains__,      ["__dict__"],    true]
    - [ab1351ap004, abc.abstractstaticmethod.__dict__.__contains__,  ["__slots__"],   false]
    - [ab1351ap005, abc.abstractstaticmethod.__dict__.__contains__,  ["__dict__"],    false]
    - [ab1351ap006, abc.abstractclassmethod.__dict__.__contains__,   ["__dict__"],    false]
