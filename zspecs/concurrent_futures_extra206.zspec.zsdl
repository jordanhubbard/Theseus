spec: concurrent_futures_extra206
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py, Lib/concurrent/futures/thread.py, Lib/concurrent/futures/process.py"
  notes:
    - "concurrent.futures.wait.__annotations__.__class__.__name__ == 'dict' — annotations is always a plain dict; cf.wait has no type annotations on Python 3.14.3, so the dict is empty ({}) but its class is 'dict'."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit') returns True — ThreadPoolExecutor.submit() is defined directly on the class in Lib/concurrent/futures/thread.py."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('map') returns False — map() is NOT in ThreadPoolExecutor.__dict__; it is inherited from the base class Executor defined in _base.py."
    - "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('submit') returns True — ProcessPoolExecutor.submit() is defined directly on the class in Lib/concurrent/futures/process.py."
    - "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('map') returns True — ProcessPoolExecutor overrides map() directly on its class body (unlike ThreadPoolExecutor which inherits it)."
    - "concurrent.futures.ThreadPoolExecutor.__dict__ keys: __module__, __firstlineno__, BROKEN, _counter, prepare_context, __init__, submit, _adjust_thread_count, _initializer_failed, shutdown, __static_attributes__, __doc__."
    - "concurrent.futures.ProcessPoolExecutor.__dict__ keys: __module__, __firstlineno__, __init__, _start_executor_manager_thread, _adjust_process_count, _launch_processes, _spawn_process, submit, map, shutdown, _force_shutdown, terminate_workers, kill_workers, __static_attributes__, __doc__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.wait __annotations__ class name and len checks
#
# concurrent.futures.wait.__annotations__.__class__.__name__  == 'dict'
# concurrent.futures.wait.__annotations__.__len__()           == 0
# concurrent.futures.wait.__annotations__.__contains__('return') == False
# concurrent.futures.wait.__annotations__.__contains__('fs')     == False
# ---------------------------------------------------------------------------

table concurrent_futures_extra206.wait_annotations:
  description: "concurrent.futures.wait __annotations__ class name and membership checks in cfannotations206 namespace — wait.__annotations__.__class__.__name__=='dict' (annotations is always a plain dict; cf.wait has no type annotations on Python 3.14.3 so the dict is empty); wait.__annotations__.__len__()==0 (empty dict, no annotated parameters or return); wait.__annotations__.__contains__('return')==False (no return annotation); wait.__annotations__.__contains__('fs')==False ('fs' is the first parameter but carries no annotation); cf.wait(fs, timeout=None, return_when=ALL_COMPLETED) blocks until the futures complete; verified with Python 3.14.3"
  kind: python_call_eq
  category: annotations
  id_prefix: cfannotations206

  columns: [id, function, args, expected, description]
  rows:
    - [wait_annotations_class_name,      "concurrent.futures.wait.__annotations__.__class__.__name__.__eq__",   ["dict"],     true,  "concurrent.futures.wait.__annotations__.__class__.__name__ == 'dict'; verified Python 3.14.3"]
    - [wait_annotations_len,             "concurrent.futures.wait.__annotations__.__len__",                     [],           0,     "concurrent.futures.wait.__annotations__.__len__() == 0 (no annotations); verified Python 3.14.3"]
    - [wait_annotations_no_return,       "concurrent.futures.wait.__annotations__.__contains__",                ["return"],   false, "concurrent.futures.wait.__annotations__.__contains__('return') == False; verified Python 3.14.3"]
    - [wait_annotations_no_fs,           "concurrent.futures.wait.__annotations__.__contains__",                ["fs"],       false, "concurrent.futures.wait.__annotations__.__contains__('fs') == False; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures.ThreadPoolExecutor.__dict__ membership checks
#
# concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit')   == True
# concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('map')      == False
# concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('shutdown') == True
# concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__init__') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra206.tpe_dict_membership:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__ membership checks in cfannotations206 namespace — TPE.__dict__.__contains__('submit')==True (submit() is defined directly on ThreadPoolExecutor in Lib/concurrent/futures/thread.py; it schedules callable to be executed and returns a Future); TPE.__dict__.__contains__('map')==False (map() is NOT in ThreadPoolExecutor.__dict__ — it is inherited from the base Executor class in _base.py; this is an important asymmetry: ProcessPoolExecutor overrides map() but ThreadPoolExecutor does not); TPE.__dict__.__contains__('shutdown')==True (shutdown() is defined on ThreadPoolExecutor); TPE.__dict__.__contains__('__init__')==True (__init__ is defined on ThreadPoolExecutor); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: cfannotations206a

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_dict_has_submit,    "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",   ["submit"],   true,  "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit') == True; verified Python 3.14.3"]
    - [tpe_dict_no_map,        "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",   ["map"],      false, "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('map') == False (map inherited from Executor); verified Python 3.14.3"]
    - [tpe_dict_has_shutdown,  "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",   ["shutdown"], true,  "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('shutdown') == True; verified Python 3.14.3"]
    - [tpe_dict_has_init,      "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",   ["__init__"], true,  "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__init__') == True; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: concurrent.futures.ProcessPoolExecutor.__dict__ membership checks
#
# concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('submit')   == True
# concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('map')      == True
# concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('shutdown') == True
# concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__init__') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra206.ppe_dict_membership:
  description: "concurrent.futures.ProcessPoolExecutor.__dict__ membership checks in cfannotations206 namespace — PPE.__dict__.__contains__('submit')==True (submit() is defined directly on ProcessPoolExecutor in Lib/concurrent/futures/process.py; it submits a callable for execution in a worker process); PPE.__dict__.__contains__('map')==True (map() IS overridden directly on ProcessPoolExecutor, unlike ThreadPoolExecutor which inherits map() from Executor; this asymmetry is notable); PPE.__dict__.__contains__('shutdown')==True (shutdown() is defined on ProcessPoolExecutor for clean process pool teardown); PPE.__dict__.__contains__('__init__')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: cfannotations206b

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_dict_has_submit,    "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",   ["submit"],   true, "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('submit') == True; verified Python 3.14.3"]
    - [ppe_dict_has_map,       "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",   ["map"],      true, "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('map') == True (PPE overrides map; TPE does not); verified Python 3.14.3"]
    - [ppe_dict_has_shutdown,  "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",   ["shutdown"], true, "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('shutdown') == True; verified Python 3.14.3"]
    - [ppe_dict_has_init,      "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",   ["__init__"], true, "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__init__') == True; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra206
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra206.wait_annotations_class_name_dict:
  description: "concurrent.futures.wait.__annotations__.__class__.__name__.__eq__('dict') returns True — cf.wait.__annotations__ is a plain dict; on Python 3.14.3 concurrent.futures.wait carries no PEP-3107 type annotations so the dict is empty ({}), but __annotations__.__class__.__name__ is 'dict' (len=4: d-i-c-t); __annotations__ is always a dict even when empty; NEW in extra206: first standalone cf.wait annotations class name invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: annotations
  kind: python_call_eq
  function: concurrent.futures.wait.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant concurrent_futures_extra206.wait_annotations_len_zero:
  description: "concurrent.futures.wait.__annotations__.__len__() returns 0 — cf.wait has no type annotations on Python 3.14.3; __annotations__ is an empty dict with length 0; concurrent.futures.wait(fs, timeout=None, return_when=ALL_COMPLETED) takes three parameters but none are annotated; compare: __code__.co_varnames includes parameter names while __annotations__ remains empty; NEW in extra206; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: annotations
  kind: python_call_eq
  function: concurrent.futures.wait.__annotations__.__len__
  args: []
  expected: 0

invariant concurrent_futures_extra206.tpe_dict_contains_submit:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit') returns True — ThreadPoolExecutor defines submit() directly in its class body in Lib/concurrent/futures/thread.py; TPE.submit(fn, *args, **kwargs) schedules fn to be called with the given arguments and returns a Future object; 'submit' is in TPE.__dict__ (not inherited from Executor); both ThreadPoolExecutor and ProcessPoolExecutor define their own submit() implementations; NEW in extra206; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__dict__.__contains__
  args: ["submit"]
  expected: true

invariant concurrent_futures_extra206.tpe_dict_no_map:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('map') returns False — ThreadPoolExecutor does NOT override map(); map() is inherited from the base Executor class defined in Lib/concurrent/futures/_base.py; this is an important asymmetry: ProcessPoolExecutor.__dict__ DOES contain 'map' (it overrides map()) while ThreadPoolExecutor.__dict__ does NOT contain 'map'; 'map' is absent from TPE.__dict__; NEW in extra206; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__dict__.__contains__
  args: ["map"]
  expected: false

invariant concurrent_futures_extra206.ppe_dict_contains_submit:
  description: "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('submit') returns True — ProcessPoolExecutor defines submit() directly in its class body in Lib/concurrent/futures/process.py; PPE.submit(fn, *args, **kwargs) schedules fn to be executed in a worker process and returns a Future; 'submit' is in PPE.__dict__ (not inherited from Executor); PPE.submit() serialises the call using pickle and sends it to a worker process; NEW in extra206; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__dict__.__contains__
  args: ["submit"]
  expected: true

invariant concurrent_futures_extra206.ppe_dict_contains_map:
  description: "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('map') returns True — ProcessPoolExecutor overrides map() directly in its class body; PPE.map() is present in PPE.__dict__, unlike ThreadPoolExecutor which does not override map() and inherits it from Executor; this asymmetry reflects the process executor's need for chunked dispatch (chunksize parameter); 'map' is in PPE.__dict__; NEW in extra206; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__dict__.__contains__
  args: ["map"]
  expected: true

invariant concurrent_futures_extra206.tpe_dict_contains_shutdown:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('shutdown') returns True — ThreadPoolExecutor defines shutdown() directly in its class body; TPE.shutdown(wait=True, *, cancel_futures=False) signals the executor to free resources after all pending futures complete; 'shutdown' is in TPE.__dict__ (not inherited from Executor, though Executor also defines a shutdown stub); NEW in extra206; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__dict__.__contains__
  args: ["shutdown"]
  expected: true

invariant concurrent_futures_extra206.ppe_dict_contains_shutdown:
  description: "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('shutdown') returns True — ProcessPoolExecutor defines shutdown() directly in its class body; PPE.shutdown(wait=True, *, cancel_futures=False) cleans up worker processes and the executor manager thread; 'shutdown' is in PPE.__dict__; both ThreadPoolExecutor and ProcessPoolExecutor define their own shutdown() implementations rather than inheriting; NEW in extra206; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__dict__.__contains__
  args: ["shutdown"]
  expected: true

