spec: telnetlib_extra
version: ">=3.9,<3.13"
backend: python_module(telnetlib)

docs: https://docs.python.org/3.12/library/telnetlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/telnetlib.html — Python telnetlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/telnetlib.py"
  notes:
    - "Extends telnetlib.zspec.zsdl with additional class name, module, DEBUGLEVEL, and method name invariants."
    - "telnetlib was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13; this spec applies to >=3.9,<3.13."
    - "telnetlib.Telnet.__name__ == 'Telnet' and telnetlib.Telnet.__module__ == 'telnetlib'."
    - "DEBUGLEVEL is a module-level integer constant defaulting to 0; it controls debug output verbosity."
    - "Telnet.read_all reads data until EOF; Telnet.write sends a byte string to the server."
    - "Telnet.open opens the connection; Telnet.close closes it; Telnet.read_until reads until a match."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Telnet class — name and module
# ---------------------------------------------------------------------------

invariant telnetlib_extra.Telnet.name:
  description: "telnetlib.Telnet.__name__ == 'Telnet'"
  category: classnames
  kind: python_call_eq
  function: Telnet.__name__.__eq__
  args: ["Telnet"]
  expected: true

invariant telnetlib_extra.Telnet.module:
  description: "telnetlib.Telnet.__module__ == 'telnetlib'"
  category: classnames
  kind: python_call_eq
  function: Telnet.__module__.__eq__
  args: ["telnetlib"]
  expected: true

# ---------------------------------------------------------------------------
# DEBUGLEVEL constant — type and value
# ---------------------------------------------------------------------------

invariant telnetlib_extra.DEBUGLEVEL.is_int:
  description: "telnetlib.DEBUGLEVEL.__class__.__name__ == 'int' — DEBUGLEVEL is a plain integer"
  category: constants
  kind: python_call_eq
  function: DEBUGLEVEL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant telnetlib_extra.DEBUGLEVEL.value:
  description: "telnetlib.DEBUGLEVEL == 0 — default debug level is 0 (no debug output)"
  category: constants
  kind: python_call_eq
  function: DEBUGLEVEL.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# Telnet method names
# ---------------------------------------------------------------------------

invariant telnetlib_extra.Telnet.read_all_name:
  description: "telnetlib.Telnet.read_all.__name__ == 'read_all'"
  category: methods
  kind: python_call_eq
  function: Telnet.read_all.__name__.__eq__
  args: ["read_all"]
  expected: true

invariant telnetlib_extra.Telnet.write_name:
  description: "telnetlib.Telnet.write.__name__ == 'write'"
  category: methods
  kind: python_call_eq
  function: Telnet.write.__name__.__eq__
  args: ["write"]
  expected: true

invariant telnetlib_extra.Telnet.open_name:
  description: "telnetlib.Telnet.open.__name__ == 'open'"
  category: methods
  kind: python_call_eq
  function: Telnet.open.__name__.__eq__
  args: ["open"]
  expected: true

invariant telnetlib_extra.Telnet.close_name:
  description: "telnetlib.Telnet.close.__name__ == 'close'"
  category: methods
  kind: python_call_eq
  function: Telnet.close.__name__.__eq__
  args: ["close"]
  expected: true

invariant telnetlib_extra.Telnet.read_until_name:
  description: "telnetlib.Telnet.read_until.__name__ == 'read_until'"
  category: methods
  kind: python_call_eq
  function: Telnet.read_until.__name__.__eq__
  args: ["read_until"]
  expected: true

# ---------------------------------------------------------------------------
# Additional method names (table form)
# ---------------------------------------------------------------------------

table telnetlib_extra.method_names:
  kind: python_call_eq
  category: methods
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [read_very_eager, "Telnet.read_very_eager.__name__.__eq__", ["read_very_eager"], true]
    - [read_eager,      "Telnet.read_eager.__name__.__eq__",      ["read_eager"],      true]
    - [read_lazy,       "Telnet.read_lazy.__name__.__eq__",       ["read_lazy"],       true]
    - [read_some,       "Telnet.read_some.__name__.__eq__",       ["read_some"],       true]
    - [interact,        "Telnet.interact.__name__.__eq__",        ["interact"],        true]
