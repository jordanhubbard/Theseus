spec: socket_extra1981
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#object.__sizeof__"
    - "https://docs.python.org/3/reference/datamodel.html#object.__length_hint__"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 579 (_extra1981): __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence checks."
    - "socket.socket does not define __sizeof__ in its Python-level dict — memory reporting uses object.__sizeof__."
    - "socket.error, socket.timeout, socket.gaierror, socket.herror are all OSError subclasses; none define __sizeof__ in own dict."
    - "None of the socket types define __length_hint__ — they are not iterators."
    - "None of the socket types define __floor__, __ceil__, or __trunc__ — socket is not a numeric type."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra1981.sizeof_protocol:
  description: "socket types __sizeof__ dict-presence checks — none define __sizeof__ in Python-level dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1981
  columns: [id, function, args, expected]
  rows:
    - ["sk1981001", "socket.socket.__dict__.__contains__",   ["__sizeof__"], false]
    - ["sk1981002", "socket.error.__dict__.__contains__",    ["__sizeof__"], false]
    - ["sk1981003", "socket.timeout.__dict__.__contains__",  ["__sizeof__"], false]
    - ["sk1981004", "socket.gaierror.__dict__.__contains__", ["__sizeof__"], false]
    - ["sk1981005", "socket.herror.__dict__.__contains__",   ["__sizeof__"], false]

