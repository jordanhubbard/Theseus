spec: theseus_email_mime_text_cr
version: ">=3.0"
backend: python_cleanroom(theseus_email_mime_text_cr)
blocks: email.mime.text

docs: https://docs.python.org/3/library/email.mime.text.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/email.mime.text.html"
  not_derived_from:
    - "CPython source: Lib/email/mime/text.py"
  notes:
    - "Clean-room email.mime.text module. Do NOT import email.mime.text."

error_model: python_exceptions

invariant theseus_email_mime_text_cr.mimetext2_create:
  description: "MIMEText('hello') creates a text/plain MIME message"
  category: behavior
  kind: python_call_eq
  function: mimetext2_create
  args: []
  expected: true

invariant theseus_email_mime_text_cr.mimetext2_html:
  description: "MIMEText('<p>hi</p>', 'html') has content-type text/html"
  category: behavior
  kind: python_call_eq
  function: mimetext2_html
  args: []
  expected: true

invariant theseus_email_mime_text_cr.mimetext2_as_string:
  description: "as_string() returns a properly formatted MIME message"
  category: behavior
  kind: python_call_eq
  function: mimetext2_as_string
  args: []
  expected: true
