spec: as3121
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 655 (as3121): __ge__, __repr__, __str__ dict-presence for asyncio types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: asyncio.Task, asyncio.Future, asyncio.Queue, asyncio.Event, asyncio.Semaphore, asyncio.Lock, asyncio.Condition, asyncio.BoundedSemaphore, asyncio.Handle, asyncio.TimerHandle, asyncio.Timeout, asyncio.TaskGroup, asyncio.StreamReader, asyncio.StreamWriter."
    - "Key finding (__ge__): asyncio.TimerHandle defines __ge__ in its own __dict__ (true). This completes the full rich-comparison set for TimerHandle: wave 654 (as3106) confirmed __lt__/__le__/__gt__; wave 653 (as3091) confirmed __eq__/__hash__; this wave confirms __ge__. All other 13 asyncio classes return false for __ge__."
    - "Key finding (__repr__): asyncio.Task, asyncio.Future, asyncio.Queue, asyncio.Event, asyncio.Semaphore, asyncio.Lock, asyncio.Condition, asyncio.Handle, asyncio.Timeout, asyncio.TaskGroup, asyncio.StreamReader, asyncio.StreamWriter all define __repr__ in their own __dict__ (true). asyncio.BoundedSemaphore and asyncio.TimerHandle do not (false). BoundedSemaphore inherits __repr__ from Semaphore; TimerHandle inherits from Handle."
    - "Key finding (__str__): only asyncio.Queue defines __str__ in its own __dict__ (true). All other 13 classes return false — they rely on the default object.__str__ which delegates to __repr__."
    - "asyncio.Queue defines both __repr__ and __str__; this is unusual — most asyncio classes provide only __repr__. Queue's __str__ gives a human-readable summary for use in logging and print statements."
    - "asyncio.BoundedSemaphore does not define __repr__ directly — it inherits from asyncio.Semaphore. This is why BoundedSemaphore returns false while Semaphore returns true."
    - "asyncio.TimerHandle does not define __repr__ directly — it inherits from asyncio.Handle. Handle defines __repr__ (true); TimerHandle adds only the ordering methods."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __ge__ dict-presence — operator.contains(Cls.__dict__, '__ge__')
#
# asyncio.TimerHandle: TRUE — defines __ge__ as the final piece of its
#   rich-comparison set (__lt__, __le__, __eq__, __gt__, __ge__, __hash__).
#   TimerHandle uses these to support min-heap scheduling in the event loop;
#   __ge__ enables "greater-than-or-equal" comparisons between scheduled times.
# All other 13 asyncio classes: false — no ordering semantics defined.
# ---------------------------------------------------------------------------

table as3121.ge:
  description: "asyncio types __ge__ dict-presence checks; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: as3121

  columns: [id, function, args, expected]
  rows:
    - ["as3121001", operator.contains, [asyncio.Task.__dict__,             "__ge__"], false]
    - ["as3121002", operator.contains, [asyncio.Future.__dict__,           "__ge__"], false]
    - ["as3121003", operator.contains, [asyncio.Queue.__dict__,            "__ge__"], false]
    - ["as3121004", operator.contains, [asyncio.Event.__dict__,            "__ge__"], false]
    - ["as3121005", operator.contains, [asyncio.Semaphore.__dict__,        "__ge__"], false]
    - ["as3121006", operator.contains, [asyncio.Lock.__dict__,             "__ge__"], false]
    - ["as3121007", operator.contains, [asyncio.Condition.__dict__,        "__ge__"], false]
    - ["as3121008", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__ge__"], false]
    - ["as3121009", operator.contains, [asyncio.Handle.__dict__,           "__ge__"], false]
    - ["as3121010", operator.contains, [asyncio.TimerHandle.__dict__,      "__ge__"], true]
    - ["as3121011", operator.contains, [asyncio.Timeout.__dict__,          "__ge__"], false]
    - ["as3121012", operator.contains, [asyncio.TaskGroup.__dict__,        "__ge__"], false]
    - ["as3121013", operator.contains, [asyncio.StreamReader.__dict__,     "__ge__"], false]
    - ["as3121014", operator.contains, [asyncio.StreamWriter.__dict__,     "__ge__"], false]

# ---------------------------------------------------------------------------
# __repr__ dict-presence — operator.contains(Cls.__dict__, '__repr__')
#
# Twelve asyncio classes define __repr__ in their own __dict__ (true):
#   Task, Future, Queue, Event, Semaphore, Lock, Condition, Handle, Timeout,
#   TaskGroup, StreamReader, StreamWriter.
# Two do not (false):
#   BoundedSemaphore — inherits __repr__ from Semaphore (its base class).
#   TimerHandle — inherits __repr__ from Handle (its base class).
# Defining __repr__ is the standard practice for asyncio objects to show
# their internal state (loop, cancelled flag, result, etc.) for debugging.
# ---------------------------------------------------------------------------

table as3121.repr:
  description: "asyncio types __repr__ dict-presence checks; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: as3121

  columns: [id, function, args, expected]
  rows:
    - ["as3121015", operator.contains, [asyncio.Task.__dict__,             "__repr__"], true]
    - ["as3121016", operator.contains, [asyncio.Future.__dict__,           "__repr__"], true]
    - ["as3121017", operator.contains, [asyncio.Queue.__dict__,            "__repr__"], true]
    - ["as3121018", operator.contains, [asyncio.Event.__dict__,            "__repr__"], true]
    - ["as3121019", operator.contains, [asyncio.Semaphore.__dict__,        "__repr__"], true]
    - ["as3121020", operator.contains, [asyncio.Lock.__dict__,             "__repr__"], true]
    - ["as3121021", operator.contains, [asyncio.Condition.__dict__,        "__repr__"], true]
    - ["as3121022", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__repr__"], false]
    - ["as3121023", operator.contains, [asyncio.Handle.__dict__,           "__repr__"], true]
    - ["as3121024", operator.contains, [asyncio.TimerHandle.__dict__,      "__repr__"], false]
    - ["as3121025", operator.contains, [asyncio.Timeout.__dict__,          "__repr__"], true]
    - ["as3121026", operator.contains, [asyncio.TaskGroup.__dict__,        "__repr__"], true]
    - ["as3121027", operator.contains, [asyncio.StreamReader.__dict__,     "__repr__"], true]
    - ["as3121028", operator.contains, [asyncio.StreamWriter.__dict__,     "__repr__"], true]

# ---------------------------------------------------------------------------
# __str__ dict-presence — operator.contains(Cls.__dict__, '__str__')
#
# asyncio.Queue: TRUE — the only asyncio class that defines __str__ directly
#   in its own __dict__. Queue.__str__ provides a human-readable summary used
#   in print() and str() calls, complementing its __repr__.
# All other 13 asyncio classes: false — they rely on the default
#   object.__str__, which delegates to __repr__ at runtime.
# ---------------------------------------------------------------------------

