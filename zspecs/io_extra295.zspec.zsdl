spec: io_extra295
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — TextIOWrapper class reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/textio.c, Modules/_io/_iomodule.c"
  notes:
    - "io.TextIOWrapper.__module__ is '_io' (the C accelerator), not 'io'"
    - "io.TextIOWrapper.__bases__[0].__name__ is '_TextIOBase' (C level base)"
    - "name and newlines are getset_descriptor; encoding and line_buffering are member_descriptor"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table io_extra295.method_qualnames:
  description: "TextIOWrapper method __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: ioe295

  columns: [id, function, args, expected, description]
  rows:
    - [ioe295001, io.TextIOWrapper.read.__qualname__,     [], "TextIOWrapper.read",     "read qualname"]
    - [ioe295002, io.TextIOWrapper.readline.__qualname__, [], "TextIOWrapper.readline", "readline qualname"]
    - [ioe295003, io.TextIOWrapper.write.__qualname__,    [], "TextIOWrapper.write",    "write qualname"]
    - [ioe295004, io.TextIOWrapper.flush.__qualname__,    [], "TextIOWrapper.flush",    "flush qualname"]
    - [ioe295005, io.TextIOWrapper.seek.__qualname__,     [], "TextIOWrapper.seek",     "seek qualname"]
    - [ioe295006, io.TextIOWrapper.tell.__qualname__,     [], "TextIOWrapper.tell",     "tell qualname"]
    - [ioe295007, io.TextIOWrapper.close.__qualname__,    [], "TextIOWrapper.close",    "close qualname"]
    - [ioe295008, io.TextIOWrapper.readable.__qualname__, [], "TextIOWrapper.readable", "readable qualname"]
    - [ioe295009, io.TextIOWrapper.writable.__qualname__, [], "TextIOWrapper.writable", "writable qualname"]
    - [ioe295010, io.TextIOWrapper.seekable.__qualname__, [], "TextIOWrapper.seekable", "seekable qualname"]

table io_extra295.attr_descriptor_classes:
  description: "TextIOWrapper attribute descriptor __class__.__name__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: ioe295d

  columns: [id, function, args, expected, description]
  rows:
    - [ioe295d001, io.TextIOWrapper.name.__class__.__name__,           [], "getset_descriptor", "name descriptor class"]
    - [ioe295d002, io.TextIOWrapper.errors.__class__.__name__,         [], "getset_descriptor", "errors descriptor class"]
    - [ioe295d003, io.TextIOWrapper.newlines.__class__.__name__,       [], "getset_descriptor", "newlines descriptor class"]
    - [ioe295d004, io.TextIOWrapper.encoding.__class__.__name__,       [], "member_descriptor",  "encoding descriptor class"]
    - [ioe295d005, io.TextIOWrapper.line_buffering.__class__.__name__, [], "member_descriptor",  "line_buffering descriptor class"]

invariant io_extra295.class_name:
  description: "TextIOWrapper __name__ is 'TextIOWrapper'"
  category: identity
  kind: python_call_eq
  function: io.TextIOWrapper.__name__
  args: []
  expected: "TextIOWrapper"

invariant io_extra295.class_module:
  description: "TextIOWrapper __module__ is '_io' (C accelerator)"
  category: identity
  kind: python_call_eq
  function: io.TextIOWrapper.__module__
  args: []
  expected: "_io"

invariant io_extra295.base_class_name:
  description: "TextIOWrapper first base class is '_TextIOBase'"
  category: identity
  kind: python_call_eq
  function: io.TextIOWrapper.__bases__[0].__name__
  args: []
  expected: "_TextIOBase"
