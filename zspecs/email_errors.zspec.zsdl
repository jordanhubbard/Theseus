  method_args: []
  expected: "MessageParseError"

invariant email_errors.MultipartConversionError_base:
  description: "MultipartConversionError.__bases__[0].__name__ == 'MessageError'"
  category: inheritance
  kind: python_call_eq
  function: MultipartConversionError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
