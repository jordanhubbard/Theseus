spec: email_errors
version: ">=3.3"
backend: python_module(email.errors)

docs: https://docs.python.org/3/library/email.errors.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/email.errors.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "email.errors source: Lib/email/errors.py (PSF; source inspection permitted)"
  not_derived_from:
    - "email.errors source: parser defect-detection internals"
  notes:
    - "email.errors defines the exception and defect hierarchy used by the email package."
    - "MessageError is the root exception; it inherits from Exception."
    - "MessageParseError inherits from MessageError and is the base for parse-time exceptions."
    - "HeaderParseError and BoundaryError both inherit from MessageParseError."
    - "MultipartConversionError and CharsetError inherit from MessageError."
    - "HeaderDefect is the base class for header-level defects found during parsing."
    - "MalformedHeaderDefect, FirstHeaderLineIsContinuationDefect, MissingHeaderBodySeparatorDefect, and InvalidMultilineHeaderDefect all inherit from HeaderDefect."
    - "NoBoundaryInMultipartDefect, StartBoundaryNotFoundDefect, CloseBoundaryNotFoundDefect, and MultipartInvariantViolationDefect inherit from MessageDefect (not HeaderDefect)."
    - "InvalidBase64PaddingDefect, InvalidBase64CharactersDefect, and InvalidBase64LengthDefect inherit from MessageDefect."
    - "All expected values verified by running Python 3.12 email.errors module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

table email_errors.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [MessageError,          MessageError.__name__.__eq__,          ["MessageError"],          true]
    - [MessageParseError,     MessageParseError.__name__.__eq__,     ["MessageParseError"],     true]
    - [HeaderParseError,      HeaderParseError.__name__.__eq__,      ["HeaderParseError"],      true]
    - [BoundaryError,         BoundaryError.__name__.__eq__,         ["BoundaryError"],         true]
    - [MultipartConversionError, MultipartConversionError.__name__.__eq__, ["MultipartConversionError"], true]
    - [CharsetError,          CharsetError.__name__.__eq__,          ["CharsetError"],          true]
    - [HeaderDefect,          HeaderDefect.__name__.__eq__,          ["HeaderDefect"],          true]
    - [MalformedHeaderDefect, MalformedHeaderDefect.__name__.__eq__, ["MalformedHeaderDefect"], true]

# ---------------------------------------------------------------------------
# Module checks
# ---------------------------------------------------------------------------

table email_errors.module_checks:
  kind: python_call_eq
  category: module_checks
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [MessageError,      MessageError.__module__.__eq__,      ["email.errors"], true]
    - [MessageParseError, MessageParseError.__module__.__eq__, ["email.errors"], true]
    - [HeaderParseError,  HeaderParseError.__module__.__eq__,  ["email.errors"], true]
    - [HeaderDefect,      HeaderDefect.__module__.__eq__,      ["email.errors"], true]

# ---------------------------------------------------------------------------
# Inheritance chain
# ---------------------------------------------------------------------------

invariant email_errors.MessageError_base:
  description: "MessageError.__bases__[0].__name__ == 'Exception' — MessageError is rooted at Exception"
  category: inheritance
  kind: python_call_eq
  function: MessageError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

