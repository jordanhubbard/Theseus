spec: struct_extra93
version: ">=3.9"
backend: python_module(struct)
extends: struct_extra92

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra92.zspec.zsdl — covers struct module-level function __class__.__name__ / Struct method __class__.__name__ / struct.error inheritance (__bases__[0].__name__) and __module__/__qualname__ / Struct method __qualname__ cross-check (table + invariants)."
    - "struct_extra91.zspec.zsdl — covers struct.calcsize return values for format codes / struct.pack/__qualname__ / struct.Struct.__doc__/__class__.__name__ / struct.error/__class__.__name__ (table + invariants)."
    - "struct_extra90.zspec.zsdl — covers struct module-level function __qualname__ / Struct method __qualname__ / Struct method class names (table + invariants)."
    - "struct_extra89.zspec.zsdl — covers Struct.__dict__ membership / module-level function __module__ cross-checks (table + invariants)."
    - "struct_extra78.zspec.zsdl — covers Struct.format/__class__.__name__=='getset_descriptor' / Struct.size/__class__.__name__=='getset_descriptor' (invariants)."
    - "struct_extra39.zspec.zsdl — covers Struct.size.__qualname__.__eq__('Struct.size') (invariant)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra92; it does NOT duplicate invariants present in those files."
    - "Wave 260 theme: struct Struct method __name__ identity and error base class module — Struct.pack/unpack/pack_into/unpack_from/iter_unpack __name__ / Struct.format.__qualname__ / error.__bases__[0].__module__.__eq__('builtins') / Struct.__module__.__eq__('_struct')."
    - "struct.Struct.pack.__name__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__name__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__name__ == 'pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__name__ == 'unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__name__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__qualname__ == 'Struct.format'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__qualname__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__mro__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Struct method_descriptor __name__ values equal the unqualified method name (e.g., 'pack' not 'Struct.pack'); this is distinct from __qualname__ which is 'Struct.pack'."
    - "Note: error.__bases__[0].__module__ == 'builtins' because Exception is a built-in exception class defined in the builtins module (not in any stdlib module)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack.__name__.__eq__('pack')
# struct.Struct.unpack.__name__.__eq__('unpack')
# struct.Struct.pack_into.__name__.__eq__('pack_into')
# struct.Struct.unpack_from.__name__.__eq__('unpack_from')
# struct.Struct.iter_unpack.__name__.__eq__('iter_unpack')
#
# Wave 260 theme: Struct instance method __name__ identity.
#
# The five Struct instance methods are C-level method_descriptor objects from
# Modules/_struct.c. Their __name__ is the unqualified method name (e.g., 'pack'),
# distinct from __qualname__ (e.g., 'Struct.pack'). struct_extra92 and struct_extra90
# anchor __qualname__ and __class__.__name__ for these methods; no prior struct spec
# anchors Struct method __name__.__eq__ under structmethid93.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra93.struct_Struct_method_names:
  description: "struct.Struct.pack/__name__.__eq__('pack')==True / Struct.unpack/__name__.__eq__('unpack')==True / Struct.pack_into/__name__.__eq__('pack_into')==True / Struct.unpack_from/__name__.__eq__('unpack_from')==True / Struct.iter_unpack/__name__.__eq__('iter_unpack')==True — all five Struct instance methods are C-level method_descriptor objects; __name__ is the unqualified method name (distinct from __qualname__ which includes 'Struct.'); struct_extra92/90 anchor __qualname__/__class__.__name__; no prior struct spec anchors Struct method __name__.__eq__; first structmethid93 anchor for Struct method __name__ identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmethid93

  columns: [id, function, args, expected]
  rows:
    - [pack_name,        "Struct.pack.__name__.__eq__",        ["pack"],        true]
    - [unpack_name,      "Struct.unpack.__name__.__eq__",      ["unpack"],      true]
    - [pack_into_name,   "Struct.pack_into.__name__.__eq__",   ["pack_into"],   true]
    - [unpack_from_name, "Struct.unpack_from.__name__.__eq__", ["unpack_from"], true]
    - [iter_unpack_name, "Struct.iter_unpack.__name__.__eq__", ["iter_unpack"], true]

# ---------------------------------------------------------------------------
# struct.Struct.format.__qualname__.__eq__('Struct.format')
# struct.error.__bases__[0].__module__.__eq__('builtins')
# struct.Struct.__module__.__eq__('_struct')
# struct.Struct.__qualname__.__eq__('Struct')
# struct.Struct.__bases__[0].__name__.__eq__('object')
# struct.Struct.__mro__.__len__()==2
#
# Wave 260 theme: Struct class identity and error base module cross-check.
#
# Struct.format is a getset_descriptor whose __qualname__ is 'Struct.format',
# confirming it is bound to the Struct class. struct.error inherits from Exception
# whose __module__ is 'builtins' (all built-in exceptions are in the builtins module).
# struct.Struct.__module__ is '_struct' (the C extension), __qualname__ is 'Struct',
# __bases__[0].__name__ is 'object', and its MRO has 2 entries (Struct, object).
# No prior struct spec anchors these six checks together under structmethid93.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra93.struct_Struct_class_identity_and_error_base:
  description: "struct.Struct.format/__qualname__.__eq__('Struct.format')==True / error/__bases__[0]/__module__.__eq__('builtins')==True / Struct/__module__.__eq__('_struct')==True / Struct/__qualname__.__eq__('Struct')==True / Struct/__bases__[0]/__name__.__eq__('object')==True / Struct/__mro__/__len__()==2 — Struct.format descriptor qualname confirms class binding; error inherits from Exception (builtins); Struct is a C-extension type (_struct module) with a 2-entry MRO; no prior struct spec anchors these together; first structmethid93 anchor for Struct class identity and error base module cross-check"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmethid93

  columns: [id, function, args, expected]
  rows:
    - [format_qualname,   "Struct.format.__qualname__.__eq__",    ["Struct.format"], true]
    - [error_base_module, "error.__bases__[0].__module__.__eq__", ["builtins"],      true]
    - [struct_module,     Struct.__module__.__eq__,               ["_struct"],       true]
    - [struct_qualname,   Struct.__qualname__.__eq__,             ["Struct"],        true]
    - [struct_base_name,  "Struct.__bases__[0].__name__.__eq__",  ["object"],        true]
    - [struct_mro_len,    Struct.__mro__.__len__,                 [],                2]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__name__.__eq__('pack') — standalone
#
# struct.Struct.pack.__name__ is 'pack'. Struct.pack is the primary instance
# method for packing values into a bytes object according to the format stored
# in the Struct instance. As a C-level method_descriptor, its __name__ is the
# unqualified method name 'pack' (not 'Struct.pack' which is the __qualname__).
# struct_extra92 anchors Struct.pack.__qualname__; no prior struct spec anchors
# Struct.pack.__name__.__eq__ as a standalone under structmethid93.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra93.struct_pack_name:
  description: "struct.Struct.pack.__name__.__eq__('pack') == True — Struct.pack is a C-level method_descriptor; its __name__ is the unqualified 'pack' (not 'Struct.pack' which is __qualname__); struct_extra92 anchors __qualname__; no prior struct spec anchors Struct.pack.__name__.__eq__ as a standalone; first standalone for Struct.pack __name__ under structmethid93"
  category: type_identity
  kind: python_call_eq
  function: "Struct.pack.__name__.__eq__"
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__module__.__eq__('builtins') — standalone
#
# struct.error.__bases__[0].__module__ is 'builtins'. struct.error inherits from
# Exception. Exception is a built-in exception class defined in the builtins module
# (the Python builtins namespace), so its __module__ is 'builtins'. This is distinct
# from Exception's C implementation in Objects/exceptions.c — the Python-visible
# __module__ attribute is 'builtins'. struct_extra92 anchors error.__bases__[0].__name__;
# no prior struct spec anchors error.__bases__[0].__module__.__eq__ as a standalone
# under structmethid93. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra93.error_base_module_builtins:
  description: "struct.error.__bases__[0].__module__.__eq__('builtins') == True — struct.error inherits from Exception; Exception is a built-in exception whose __module__ is 'builtins' (not a stdlib module); struct_extra92 anchors error.__bases__[0].__name__; no prior struct spec anchors error bases __module__ as a standalone; first standalone for error.__bases__[0].__module__ under structmethid93"
  category: type_identity
  kind: python_call_eq
  function: "error.__bases__[0].__module__.__eq__"
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__module__.__eq__('_struct') — standalone
#
# struct.Struct.__module__ is '_struct'. Struct is a C extension type defined in
# Modules/_struct.c. Python resolves its __module__ to the C extension module
# '_struct', not to the Python-level 'struct' shim module. This is different from
# struct.error.__module__ which is 'struct' (because error is re-exported at the
# Python level). struct_extra85 and struct_extra87 first anchor Struct class identity;
# no prior struct spec anchors Struct.__module__.__eq__('_struct') as a standalone
# under structmethid93. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra93.struct_module_c_struct:
  description: "struct.Struct.__module__.__eq__('_struct') == True — Struct is a C extension type (Modules/_struct.c); its __module__ is '_struct', not the Python-level 'struct' shim; struct.error.__module__ is 'struct' (re-exported at Python level); struct_extra85/87 anchor Struct class identity; no prior struct spec anchors Struct.__module__.__eq__ as a standalone; first standalone for Struct.__module__ under structmethid93"
  category: type_identity
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__name__.__eq__('iter_unpack') — standalone
#
# struct.Struct.iter_unpack.__name__ is 'iter_unpack'. Struct.iter_unpack (Python
# 3.4+) returns an iterator that yields successive tuples from the buffer, each
# according to the format stored in the Struct instance. As a C-level
# method_descriptor, its __name__ is the unqualified 'iter_unpack'. struct_extra92
# anchors Struct.iter_unpack.__class__.__name__; struct_extra90 anchors
# Struct.iter_unpack.__qualname__; no prior struct spec anchors
# Struct.iter_unpack.__name__.__eq__ as a standalone under structmethid93.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra93.struct_iter_unpack_name:
  description: "struct.Struct.iter_unpack.__name__.__eq__('iter_unpack') == True — Struct.iter_unpack (Python 3.4+) yields successive tuples from a buffer; as a C-level method_descriptor its __name__ is unqualified 'iter_unpack'; struct_extra92 anchors __class__.__name__; struct_extra90 anchors __qualname__; no prior struct spec anchors Struct.iter_unpack.__name__.__eq__ as a standalone; first standalone for Struct.iter_unpack __name__ under structmethid93"
  category: type_identity
  kind: python_call_eq
  function: "Struct.iter_unpack.__name__.__eq__"
  args: ["iter_unpack"]
  expected: true
