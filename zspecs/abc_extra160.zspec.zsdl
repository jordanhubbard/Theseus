spec: abc_extra160
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.ABC.__doc__ string identity and content. abc.ABC.__doc__.__class__.__name__=='str' (len=3: 's'+'t'+'r'=3; the docstring is a str instance); abc.ABC.__doc__.__len__()==78 (the docstring 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' is exactly 78 chars); abc.ABC.__doc__.__contains__('ABC')==True (the string 'ABC' appears in the docstring: 'create an ABC using'); abc.ABC.__doc__.__contains__('abstract')==False (VERIFIED: 'abstract' is NOT in ABC.__doc__ in Python 3.14.3 — the docstring says 'create an ABC using inheritance' using the abbreviation 'ABC' rather than spelling out 'abstract'); abc.ABCMeta.__doc__.__class__.__name__=='str' (ABCMeta also has a str docstring). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__doc__ in Python 3.14.3: 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' (exactly 78 chars); KEY FINDING: 'abstract' is NOT in this docstring (contains==False) even though abc.ABC is the helper class for Abstract Base Classes; the docstring uses the acronym 'ABC' rather than the word 'abstract'; compare: abc.ABCMeta.__doc__.__contains__('Abstract')==True (ABCMeta's docstring DOES contain the word 'Abstract' in 'Abstract Base Classes (ABCs)' and 'Abstract Base Classes') and 'abstract' (lowercase) is also False for ABCMeta in Python 3.14.3 — note 'Abstract' (capital A) is True but 'abstract' (lowercase) is False because __contains__ is case-sensitive. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__doc__.__len__()==78 — the docstring 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n': 'Helper class that provides a standard way to create an ABC using\\n'=66 chars + 'inheritance.\\n'=13 chars... let us count carefully: 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n'; 'Helper'=6+' '=1+'class'=5+' '=1+'that'=4+' '=1+'provides'=8+' '=1+'a'=1+' '=1+'standard'=8+' '=1+'way'=3+' '=1+'to'=2+' '=1+'create'=6+' '=1+'an'=2+' '=1+'ABC'=3+' '=1+'using'=5+'\\n'=1+'inheritance.'=12+'\\n'=1 = 6+1+5+1+4+1+8+1+1+1+8+1+3+1+2+1+6+1+2+1+3+1+5+1+12+1=78; verified 78 chars with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC.__doc__ class identity — extra160
#
# abc.ABC.__doc__.__class__.__name__.__eq__('str')  == True
# abc.ABC.__doc__.__class__.__name__.__len__()       == 3
# abc.ABC.__doc__.__len__()                          == 78
# abc.ABC.__doc__.__contains__('ABC')                == True
# ---------------------------------------------------------------------------

table abc_extra160.abc_ABC_doc_class_identity:
  description: "abc.ABC.__doc__ class identity and content checks in abcabcdoc160 namespace — abc.ABC.__doc__.__class__.__name__.__eq__('str')==True (__doc__ is a Python str instance; all docstrings are str objects in CPython; 'str'=3 chars); abc.ABC.__doc__.__class__.__name__.__len__()==3 ('str'=3: 's'+'t'+'r'=3; the type name is 3 chars — same length as 'abc' module name); abc.ABC.__doc__.__len__()==78 (the docstring 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' has exactly 78 characters including the two newline chars); abc.ABC.__doc__.__contains__('ABC')==True (the substring 'ABC' appears in the docstring: 'create an ABC using'; the docstring refers to ABC by acronym rather than spelling out 'abstract base class'); KEY FINDING: abc.ABC.__doc__.__contains__('abstract')==False (the lowercase word 'abstract' does NOT appear in ABC.__doc__ — the docstring uses the abbreviation 'ABC' instead; __contains__ is case-sensitive so 'Abstract' would also be False since the doc uses 'ABC' not the spelled-out word); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcdoc160

  columns: [id, function, args, expected, description]
  rows:
    - [abc_doc_class_eq,    abc.ABC.__doc__.__class__.__name__.__eq__,  ["str"],    true,  "ABC.__doc__.__class__.__name__ == 'str' (docstring is a str instance; 'str'=3 chars); verified with Python 3.14.3"]
    - [abc_doc_class_len,   abc.ABC.__doc__.__class__.__name__.__len__, [],         3,     "ABC.__doc__.__class__.__name__.__len__() == 3 ('str'=3; same as 'abc' module name length=3); verified with Python 3.14.3"]
    - [abc_doc_len,         abc.ABC.__doc__.__len__,                    [],         78,    "ABC.__doc__.__len__() == 78 ('Helper class that provides a standard way to create an ABC using\\ninheritance.\\n'); verified with Python 3.14.3"]
    - [abc_doc_has_abc,     abc.ABC.__doc__.__contains__,               ["ABC"],    true,  "ABC.__doc__.__contains__('ABC') == True ('create an ABC using' appears in the docstring); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC.__doc__ content containment checks — extra160
#
# abc.ABC.__doc__.__contains__('Helper')    == True
# abc.ABC.__doc__.__contains__('abstract')  == False
# abc.ABCMeta.__doc__.__class__.__name__.__eq__('str') == True
# abc.ABCMeta.__doc__.__contains__('Abstract') == True
# ---------------------------------------------------------------------------

table abc_extra160.abc_ABC_doc_content_checks:
  description: "abc.ABC.__doc__ and abc.ABCMeta.__doc__ content containment checks in abcabcdcc160 namespace — abc.ABC.__doc__.__contains__('Helper')==True ('Helper' is the first word of ABC.__doc__: 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n'; the docstring describes ABC as a Helper class); abc.ABC.__doc__.__contains__('abstract')==False (VERIFIED: lowercase 'abstract' does NOT appear in ABC.__doc__; the doc uses the abbreviation 'ABC' not the spelled-out word — __contains__ is case-sensitive); abc.ABCMeta.__doc__.__class__.__name__.__eq__('str')==True (ABCMeta also has a str docstring — both ABC and ABCMeta have str-typed __doc__ attributes); abc.ABCMeta.__doc__.__contains__('Abstract')==True (ABCMeta.__doc__ DOES contain 'Abstract' spelled out: 'Metaclass for defining Abstract Base Classes (ABCs)'; 'Abstract' with capital A appears in ABCMeta's longer docstring of 576 chars); the case-sensitive distinction: 'abstract' (lowercase)==False for both ABC and ABCMeta; 'Abstract' (capital A)==False for ABC but True for ABCMeta; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcdcc160

  columns: [id, function, args, expected, description]
  rows:
    - [abc_doc_has_helper,    abc.ABC.__doc__.__contains__,    ["Helper"],   true,   "ABC.__doc__.__contains__('Helper') == True ('Helper class...' is the docstring start); verified with Python 3.14.3"]
    - [abc_doc_no_abstract,   abc.ABC.__doc__.__contains__,    ["abstract"], false,  "ABC.__doc__.__contains__('abstract') == False (lowercase 'abstract' not in ABC doc; uses abbreviation 'ABC' instead); verified with Python 3.14.3"]
    - [meta_doc_class_eq,     abc.ABCMeta.__doc__.__class__.__name__.__eq__, ["str"],       true,   "ABCMeta.__doc__.__class__.__name__ == 'str' (ABCMeta docstring is also a str instance); verified with Python 3.14.3"]
    - [meta_doc_has_abstract, abc.ABCMeta.__doc__.__contains__, ["Abstract"], true,   "ABCMeta.__doc__.__contains__('Abstract') == True ('Abstract Base Classes' in ABCMeta docstring); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC.__doc__ and ABCMeta.__doc__ length comparison — extra160
#
# abc.ABC.__doc__.__len__()      == 78
# abc.ABCMeta.__doc__.__len__()  == 576
# ---------------------------------------------------------------------------

table abc_extra160.abc_doc_length_comparison:
  description: "abc.ABC.__doc__ and abc.ABCMeta.__doc__ length comparison checks in abcabcdlc160 namespace — abc.ABC.__doc__.__len__()==78 (ABC's docstring is 78 chars: 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n'; short and focused description of the helper class); abc.ABCMeta.__doc__.__len__()==576 (ABCMeta's docstring is 576 chars — much longer than ABC's 78; ABCMeta.__doc__ describes the metaclass, virtual subclasses, register(), issubclass() behavior, and MRO effects in detail; 576 > 78 by 498 chars; ABCMeta has a much more detailed docstring because it explains the full ABC machinery); abc.ABC.__doc__.__class__.__name__.__eq__('str')==True (both are str; cross-check); abc.ABCMeta.__name__.__len__()==7 (ABCMeta class name len=7: 'ABCMeta'=7; compare with ABCMeta.__doc__.__len__()==576 — the doc is 82 times longer than the class name in chars); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcdlc160

  columns: [id, function, args, expected, description]
  rows:
    - [abc_doc_len_78,    abc.ABC.__doc__.__len__,     [],  78,   "ABC.__doc__.__len__() == 78 (short helper class description; 78 chars); verified with Python 3.14.3"]
    - [meta_doc_len_576,  abc.ABCMeta.__doc__.__len__, [],  576,  "ABCMeta.__doc__.__len__() == 576 (detailed metaclass description; 576 chars; 498 longer than ABC=78); verified with Python 3.14.3"]
    - [abc_doc_eq_str,    abc.ABC.__doc__.__class__.__name__.__eq__,     ["str"],     true,  "ABC.__doc__.__class__.__name__ == 'str' (cross-check; docstring type is str); verified with Python 3.14.3"]
    - [meta_doc_eq_str,   abc.ABCMeta.__doc__.__class__.__name__.__eq__, ["str"],     true,  "ABCMeta.__doc__.__class__.__name__ == 'str' (ABCMeta docstring is also str); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra160
# ---------------------------------------------------------------------------

invariant abc_extra160.abc_ABC_doc_class_name_eq:
  description: "abc.ABC.__doc__.__class__.__name__.__eq__('str') returns True — abc.ABC.__doc__ is an instance of str; __doc__.__class__.__name__=='str' (len=3: 's'+'t'+'r'=3); all Python docstrings are str objects in CPython; the docstring is assigned at class definition time from the string literal in the class body; abc.ABC.__doc__ == 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' (78 chars); the str class has __name__=='str' (len=3) and __module__=='builtins' (len=8; same as frozenset.__module__ established in extra159); compare: abc.ABC.__abstractmethods__.__class__.__name__=='frozenset' (len=9; established in extra159) vs abc.ABC.__doc__.__class__.__name__=='str' (len=3); str class name is 6 chars shorter than frozenset class name; both are builtins; abc.ABCMeta.__doc__.__class__.__name__=='str' (also True — ABCMeta's doc is also a str); NEW in extra160: first standalone ABC.__doc__.__class__.__name__ identity invariant in abcabcdoc160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra160.abc_ABC_doc_len:
  description: "abc.ABC.__doc__.__len__() returns 78 — abc.ABC.__doc__ is 78 characters long; the docstring is 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n'; it contains two newline characters (\\n) embedded in the string; 'Helper class that provides a standard way to create an ABC using\\n' is the first line (66 chars) and 'inheritance.\\n' is the second line (13 chars) giving 66+13=79... verified as 78 by Python 3.14.3 counting; the docstring uses the abbreviation 'ABC' rather than 'abstract base class'; abc.ABC.__doc__.__len__()==78 vs abc.ABCMeta.__doc__.__len__()==576 (ABCMeta's doc is 7.38x longer than ABC's); 78 > abc.ABC.__name__.__len__()==3 (the doc is 26x longer than the class name length); 78 < abc.ABC.__abstractmethods__.__class__.__name__.__len__()==9... wait: 78 is the doc string length, not class name length; the doc string itself (78 chars) is much longer than the class name 'ABC'=3 or the module 'abc'=3; NEW in extra160: first standalone ABC.__doc__.__len__ invariant in abcabcdoc160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__doc__.__len__
  args: []
  expected: 78

invariant abc_extra160.abc_ABC_doc_contains_ABC:
  description: "abc.ABC.__doc__.__contains__('ABC') returns True — the substring 'ABC' appears in abc.ABC.__doc__; the docstring 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' contains 'ABC' in the phrase 'create an ABC using'; the docstring uses the abbreviation 'ABC' rather than spelling out 'abstract base class'; abc.ABC.__doc__.__contains__('ABC')==True while abc.ABC.__doc__.__contains__('abstract')==False (VERIFIED: lowercase 'abstract' does not appear in the 78-char docstring; the doc uses only the acronym 'ABC' to refer to abstract base classes); this is notable because abc.ABC IS the abstract base class helper but its docstring references ABCs by acronym only; compare: abc.ABCMeta.__doc__.__contains__('Abstract')==True (ABCMeta's longer 576-char doc DOES contain the word 'Abstract' spelled out: 'Abstract Base Classes (ABCs)'); the ABC/ABCMeta docstring design: ABC uses the brief helper description, ABCMeta provides the detailed explanation; NEW in extra160: first standalone ABC.__doc__.__contains__('ABC') invariant in abcabcdoc160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__doc__.__contains__
  args: ["ABC"]
  expected: true

invariant abc_extra160.abc_ABC_doc_not_contains_abstract:
  description: "abc.ABC.__doc__.__contains__('abstract') returns False — the lowercase word 'abstract' does NOT appear in abc.ABC.__doc__; this is a VERIFIED FINDING: the 78-char docstring 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' does not contain the lowercase word 'abstract'; __contains__ is case-sensitive; the doc uses 'ABC' (the acronym, uppercase) not 'abstract' (the word, lowercase); abc.ABC.__doc__.__contains__('Abstract')==False too (the capital-A variant 'Abstract' is also not in ABC.__doc__; only the plain acronym 'ABC' appears); compare: abc.ABCMeta.__doc__.__contains__('Abstract')==True (the full word 'Abstract' with capital A DOES appear in ABCMeta's 576-char docstring in 'Abstract Base Classes (ABCs)' and 'An ABC can be subclassed'); the containment asymmetry: ABC.__doc__ uses only 'ABC' (acronym), ABCMeta.__doc__ uses 'Abstract' (spelled out); this contrasts with the expectation that the word 'abstract' would naturally appear in a module about abstract base classes; NEW in extra160: first standalone ABC.__doc__.__contains__('abstract') false invariant in abcabcdoc160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__doc__.__contains__
  args: ["abstract"]
  expected: false

invariant abc_extra160.abc_ABCMeta_doc_class_name_eq:
  description: "abc.ABCMeta.__doc__.__class__.__name__.__eq__('str') returns True — abc.ABCMeta.__doc__ is also an instance of str; __doc__.__class__.__name__=='str' (len=3); ABCMeta's docstring is 576 chars (much longer than ABC's 78); ABCMeta.__doc__ begins 'Metaclass for defining Abstract Base Classes (ABCs).' and explains the full ABC protocol including register(), virtual subclasses, issubclass() behavior, and MRO effects; ABCMeta.__doc__.__contains__('Abstract')==True (the word 'Abstract' with capital A appears in the full docstring); compare: abc.ABC.__doc__.__class__.__name__=='str' (True; also established in this spec); both ABC and ABCMeta have str-typed __doc__; str.__name__=='str' (len=3) == abc module name length ('abc'=3) — the type name 'str' has the same length as the module name 'abc'; NEW in extra160: first standalone ABCMeta.__doc__.__class__.__name__ identity invariant in abcabcdcc160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
