spec: lowercase_keys
version: ">=4.0.0"
backend: node(lowercase-keys)
esm: true

docs: https://github.com/sindresorhus/lowercase-keys#readme

provenance:
  derived_from:
    - "lowercase-keys README — https://github.com/sindresorhus/lowercase-keys#readme"
    - "Test vectors verified with lowercase-keys via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "lowercase-keys source"
  notes:
    - "Returns a new object whose top-level keys are lowercased. Common in HTTP-header normalization."
    - "Install: npm install lowercase-keys"
    - "v4 ESM only; default export IS the function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; returns new object."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant lowercase_keys.default_export_is_function:
  description: "Default export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "Function"

invariant lowercase_keys.default_name:
  description: "Default export function name is 'lowercaseKeys'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.name"}
  expected: "lowercaseKeys"

invariant lowercase_keys.default_arity:
  description: "Default export has arity 1"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 1

invariant lowercase_keys.simple_lowercases:
  description: "{Foo: 1, BAR: 2} -> {foo: 1, bar: 2} via JSON round-trip"
  category: transform
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: [{"Foo": 1, "BAR": 2}]}
    - {get: foo}
  expected: 1

invariant lowercase_keys.preserves_already_lower:
  description: "{foo: 'a', bar: 'b'}.foo stays 'a' after transform"
  category: transform
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: [{"foo": "a", "bar": "b"}]}
    - {get: foo}
  expected: "a"

invariant lowercase_keys.bar_value_after_uppercase:
  description: "{Foo: 1, BAR: 2}.bar after lowercaseKeys is 2"
  category: transform
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: [{"Foo": 1, "BAR": 2}]}
    - {get: bar}
  expected: 2

invariant lowercase_keys.empty_input:
  description: "lowercaseKeys({}) returns an empty object"
  category: edge
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: [{}]}
  expected: {}

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:54:05Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
