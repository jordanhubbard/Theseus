spec: traceback_extra2
version: ">=3.5"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "Python 3 traceback documentation — https://docs.python.org/3/library/traceback.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "Complements traceback_extra.zspec.zsdl with module membership and class hierarchy coverage."
    - "traceback_extra.zspec.zsdl covers __name__ checks for classes and function names."
    - "This spec adds __module__ checks for TracebackException, StackSummary, FrameSummary."
    - "Covers __bases__ checks: TracebackException inherits from object, StackSummary from list, FrameSummary from object."
    - "Covers __module__ checks for format_exc, format_tb, extract_tb, extract_stack, print_exc, print_tb."
    - "TracebackException.__module__ == 'traceback' — defined in Lib/traceback.py."
    - "StackSummary.__bases__[0].__name__ == 'list' — StackSummary is a subclass of list."
    - "FrameSummary.__bases__[0].__name__ == 'object' — FrameSummary inherits directly from object."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __module__ checks
# ---------------------------------------------------------------------------

table traceback_extra2.class_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [tracebackexception, TracebackException.__module__.__eq__, ["traceback"], true]
    - [stacksummary,       StackSummary.__module__.__eq__,       ["traceback"], true]
    - [framesummary,       FrameSummary.__module__.__eq__,       ["traceback"], true]

# ---------------------------------------------------------------------------
# Class hierarchy — base class checks
# ---------------------------------------------------------------------------

invariant traceback_extra2.TracebackException.base_is_object:
  description: "traceback.TracebackException.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: TracebackException.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant traceback_extra2.StackSummary.base_is_list:
  description: "traceback.StackSummary.__bases__[0].__name__ == 'list' — StackSummary subclasses list"
  category: hierarchy
  kind: python_call_eq
  function: StackSummary.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "list"

invariant traceback_extra2.FrameSummary.base_is_object:
  description: "traceback.FrameSummary.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: FrameSummary.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Function __module__ checks
# ---------------------------------------------------------------------------

table traceback_extra2.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [format_exc,    format_exc.__module__.__eq__,    ["traceback"], true]
    - [format_tb,     format_tb.__module__.__eq__,     ["traceback"], true]
    - [extract_tb,    extract_tb.__module__.__eq__,    ["traceback"], true]
    - [extract_stack, extract_stack.__module__.__eq__, ["traceback"], true]
    - [print_exc,     print_exc.__module__.__eq__,     ["traceback"], true]
    - [print_tb,      print_tb.__module__.__eq__,      ["traceback"], true]
