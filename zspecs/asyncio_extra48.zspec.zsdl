spec: asyncio_extra48
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio coroutines and tasks"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec extends asyncio_extra47.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, QueueFull/__name__.__len__()==9, QueueEmpty/QueueFull __qualname__.__len__(), Runner method __name__/__qualname__.__len__() tables, various function and class lengths, MRO depths for all queue/lock/sync classes, AbstractEventLoop/__name__/__len__() tables, BaseEventLoop/Handle/TimerHandle/Protocol/StreamReader lengths, Event method __qualname__ string values and lengths, Semaphore acquire/release __qualname__ string values and lengths, BoundedSemaphore/__name__/__module__/inherited acquire qualname, Condition/__name__/__module__/wait qualname, TaskGroup/__name__/__module__/__bases__[0].__name__, Runner/__name__/__module__, shield/ensure_future/create_task __name__/__module__, get_event_loop/__name__/__module__, get_running_loop/__name__/__module__, new_event_loop/__name__/__module__, run/__name__/__module__, iscoroutine/__name__/__module__, iscoroutinefunction/__name__/__module__, get_event_loop/__qualname__=='get_event_loop', get_running_loop/__qualname__=='get_running_loop', run/__qualname__=='run', sleep/__qualname__=='sleep', gather/__qualname__=='gather', wait/__qualname__=='wait', Queue/Lock/Event __qualname__ string equality, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/TaskGroup __qualname__.__len__(), CancelledError/__qualname__=='CancelledError', TimeoutError/__qualname__=='TimeoutError', TaskGroup/Runner/Task/Future __mro__.__len__(), Semaphore/BoundedSemaphore/Condition/TaskGroup/Runner __qualname__ string equality, Task/__qualname__.__len__()==4, Future/__qualname__.__len__()==6, Runner/__qualname__.__len__()==6 (extra45), Task/__name__=='Task'/__module__=='_asyncio'/__qualname__=='Task', Future/__name__=='Future'/__module__=='_asyncio'/__qualname__=='Future', Task/__bases__[0].__name__=='Future', Task/__module__.__len__()==8, Future/__module__.__len__()==8, Task/__name__.__len__()==4, Future/__name__.__len__()==6 (extra46), Queue/__class__.__name__=='type', Lock/__class__.__name__=='type', Event/__class__.__name__=='type', Semaphore/__class__.__name__=='type', Task/__class__.__name__=='type', Future/__class__.__name__=='type', gather/__class__.__name__=='function', sleep/__class__.__name__=='function', run/__class__.__name__=='function', class __class__.__name__.__len__()==4, function __class__.__name__.__len__()==8 (extra47)."
    - "This spec covers: Queue/__class__.__qualname__=='type'; Lock/__class__.__qualname__=='type'; Event/__class__.__qualname__=='type'; Semaphore/__class__.__qualname__=='type'; Task/__class__.__qualname__=='type'; Future/__class__.__qualname__=='type'; gather/__class__.__qualname__=='function'; sleep/__class__.__qualname__=='function'; run/__class__.__qualname__=='function'; class __class__.__qualname__.__len__()==4 for all six classes; function __class__.__qualname__.__len__()==8 for all three functions."
    - "asyncio.Queue.__class__.__qualname__ == 'type'. Queue is a plain Python class; its metaclass is the built-in 'type'. The built-in type has no enclosing class or function, so __qualname__ == __name__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__class__.__qualname__ == 'type'. Lock is a plain Python class; its metaclass is the built-in 'type'. __class__.__qualname__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__class__.__qualname__ == 'type'. Event is a plain Python class; its metaclass is the built-in 'type'. __class__.__qualname__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__class__.__qualname__ == 'type'. Semaphore is a plain Python class; its metaclass is the built-in 'type'. __class__.__qualname__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__class__.__qualname__ == 'type'. Task is a C-extension type in _asyncio; despite its C implementation, its metaclass is still the built-in 'type'. __class__.__qualname__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__class__.__qualname__ == 'type'. Future is a C-extension type in _asyncio; its metaclass is the built-in 'type'. __class__.__qualname__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__class__.__qualname__ == 'function'. gather is a plain Python coroutine function in asyncio.tasks; its __class__ is the built-in 'function' type, whose __qualname__ == 'function' (8 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__class__.__qualname__ == 'function'. sleep is a plain Python coroutine function in asyncio.tasks; its __class__.__qualname__ == 'function' (8 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.run.__class__.__qualname__ == 'function'. run is a plain Python function in asyncio; its __class__.__qualname__ == 'function' (8 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "For all Python built-in types, __qualname__ == __name__ (there is no enclosing scope). Therefore __class__.__qualname__ and __class__.__name__ are identical for all asyncio classes (both == 'type') and all asyncio functions (both == 'function'). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio class __class__.__qualname__ string equality — extra48
#
# All six asyncio classes are instances of the built-in 'type' metaclass.
# The built-in type has __qualname__ == __name__ == 'type' (no enclosing scope):
#   Queue.__class__.__qualname__     == 'type'
#   Lock.__class__.__qualname__      == 'type'
#   Event.__class__.__qualname__     == 'type'
#   Semaphore.__class__.__qualname__ == 'type'
#   Task.__class__.__qualname__      == 'type'
#   Future.__class__.__qualname__    == 'type'
# Prior specs captured __class__.__name__ (extra47). Extra48 captures
# __class__.__qualname__ for the first time.
# ---------------------------------------------------------------------------

table asyncio_extra48.class_metaclass_qualname_eq:
  description: "asyncio class __class__.__qualname__ string equality in extra48 namespace — six asyncio classes all have metaclass qualname 'type'"
  kind: python_call_eq
  category: class_names
  id_prefix: asyncioclsqual48

  columns: [id, function, args, expected, description]
  rows:
    - [Queue,     Queue.__class__.__qualname__.__eq__,     ["type"], true, "Queue.__class__.__qualname__ == 'type' — plain Python class; metaclass is built-in type whose __qualname__ == 'type' (4 chars)"]
    - [Lock,      Lock.__class__.__qualname__.__eq__,      ["type"], true, "Lock.__class__.__qualname__ == 'type' — plain Python class; metaclass is built-in type whose __qualname__ == 'type' (4 chars)"]
    - [Event,     Event.__class__.__qualname__.__eq__,     ["type"], true, "Event.__class__.__qualname__ == 'type' — plain Python class; metaclass is built-in type whose __qualname__ == 'type' (4 chars)"]
    - [Semaphore, Semaphore.__class__.__qualname__.__eq__, ["type"], true, "Semaphore.__class__.__qualname__ == 'type' — plain Python class; metaclass is built-in type whose __qualname__ == 'type' (4 chars)"]
    - [Task,      Task.__class__.__qualname__.__eq__,      ["type"], true, "Task.__class__.__qualname__ == 'type' — C-extension class in _asyncio; metaclass is built-in type whose __qualname__ == 'type' (4 chars)"]
    - [Future,    Future.__class__.__qualname__.__eq__,    ["type"], true, "Future.__class__.__qualname__ == 'type' — C-extension class in _asyncio; metaclass is built-in type whose __qualname__ == 'type' (4 chars)"]

# ---------------------------------------------------------------------------
# asyncio function __class__.__qualname__ string equality — extra48
#
# All three asyncio functions have __class__.__qualname__ == 'function':
#   gather.__class__.__qualname__ == 'function'
#   sleep.__class__.__qualname__  == 'function'
#   run.__class__.__qualname__    == 'function'
# gather and sleep are coroutine functions (async def); run is a regular
# function. All are instances of the built-in 'function' type whose
# __qualname__ == 'function'.
# ---------------------------------------------------------------------------

table asyncio_extra48.function_class_qualname_eq:
  description: "asyncio function __class__.__qualname__ string equality in extra48 namespace — gather, sleep, run all have __class__.__qualname__ == 'function'"
  kind: python_call_eq
  category: class_names
  id_prefix: asynciofuncclsqual48

  columns: [id, function, args, expected, description]
  rows:
    - [gather, gather.__class__.__qualname__.__eq__, ["function"], true, "gather.__class__.__qualname__ == 'function' — plain Python coroutine function in asyncio.tasks; __class__.__qualname__ == 'function' (8 chars)"]
    - [sleep,  sleep.__class__.__qualname__.__eq__,  ["function"], true, "sleep.__class__.__qualname__ == 'function' — plain Python coroutine function in asyncio.tasks; __class__.__qualname__ == 'function' (8 chars)"]
    - [run,    run.__class__.__qualname__.__eq__,    ["function"], true, "run.__class__.__qualname__ == 'function' — plain Python function in asyncio; __class__.__qualname__ == 'function' (8 chars)"]

# ---------------------------------------------------------------------------
# asyncio class and function __class__.__qualname__.__len__() — extra48
#
# All six classes share __class__.__qualname__.__len__() == 4 ('type'):
#   Queue/Lock/Event/Semaphore/Task/Future.__class__.__qualname__.__len__() == 4
# All three functions share __class__.__qualname__.__len__() == 8 ('function'):
#   gather/sleep/run.__class__.__qualname__.__len__() == 8
# ---------------------------------------------------------------------------

table asyncio_extra48.class_qualname_lengths:
  description: "asyncio class and function __class__.__qualname__.__len__() in extra48 namespace — classes == 4, functions == 8"
  kind: python_call_eq
  category: class_names
  id_prefix: asyncioclsquallen48

  columns: [id, function, args, expected, description]
  rows:
    - [Queue,     Queue.__class__.__qualname__.__len__,     [], 4, "Queue.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [Lock,      Lock.__class__.__qualname__.__len__,      [], 4, "Lock.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [Event,     Event.__class__.__qualname__.__len__,     [], 4, "Event.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [Semaphore, Semaphore.__class__.__qualname__.__len__, [], 4, "Semaphore.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [Task,      Task.__class__.__qualname__.__len__,      [], 4, "Task.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters; C-extension class in _asyncio"]
    - [Future,    Future.__class__.__qualname__.__len__,    [], 4, "Future.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters; C-extension class in _asyncio"]
    - [gather,    gather.__class__.__qualname__.__len__,    [], 8, "gather.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"]
    - [sleep,     sleep.__class__.__qualname__.__len__,     [], 8, "sleep.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"]
    - [run,       run.__class__.__qualname__.__len__,       [], 8, "run.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra48
# ---------------------------------------------------------------------------

invariant asyncio_extra48.Queue_class_qualname_eq:
  description: "asyncio.Queue.__class__.__qualname__ == 'type' — Queue is a plain Python class; its metaclass is the built-in type whose __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: Queue.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant asyncio_extra48.Lock_class_qualname_eq:
  description: "asyncio.Lock.__class__.__qualname__ == 'type' — Lock is a plain Python class; its metaclass is the built-in type whose __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: Lock.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant asyncio_extra48.Event_class_qualname_eq:
  description: "asyncio.Event.__class__.__qualname__ == 'type' — Event is a plain Python class; its metaclass is the built-in type whose __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: Event.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant asyncio_extra48.Semaphore_class_qualname_eq:
  description: "asyncio.Semaphore.__class__.__qualname__ == 'type' — Semaphore is a plain Python class; its metaclass is the built-in type whose __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: Semaphore.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant asyncio_extra48.Task_class_qualname_eq:
  description: "asyncio.Task.__class__.__qualname__ == 'type' — Task is a C-extension class in _asyncio; despite C implementation, its metaclass is the built-in type whose __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: Task.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant asyncio_extra48.Future_class_qualname_eq:
  description: "asyncio.Future.__class__.__qualname__ == 'type' — Future is a C-extension class in _asyncio; its metaclass is the built-in type whose __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: Future.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant asyncio_extra48.gather_class_qualname_eq:
  description: "asyncio.gather.__class__.__qualname__ == 'function' — gather is a plain Python coroutine function; __class__.__qualname__ == 'function' (8 chars)"
  category: class_names
  kind: python_call_eq
  function: gather.__class__.__qualname__.__eq__
  args: ["function"]
  expected: true

invariant asyncio_extra48.sleep_class_qualname_eq:
  description: "asyncio.sleep.__class__.__qualname__ == 'function' — sleep is a plain Python coroutine function; __class__.__qualname__ == 'function' (8 chars)"
  category: class_names
  kind: python_call_eq
  function: sleep.__class__.__qualname__.__eq__
  args: ["function"]
  expected: true

invariant asyncio_extra48.run_class_qualname_eq:
  description: "asyncio.run.__class__.__qualname__ == 'function' — run is a plain Python function; __class__.__qualname__ == 'function' (8 chars)"
  category: class_names
  kind: python_call_eq
  function: run.__class__.__qualname__.__eq__
  args: ["function"]
  expected: true

invariant asyncio_extra48.Queue_class_qualname_len:
  description: "asyncio.Queue.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"
  category: class_names
  kind: python_call_eq
  function: Queue.__class__.__qualname__.__len__
  args: []
  expected: 4

invariant asyncio_extra48.Task_class_qualname_len:
  description: "asyncio.Task.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters; Task is C-extension class in _asyncio"
  category: class_names
  kind: python_call_eq
  function: Task.__class__.__qualname__.__len__
  args: []
  expected: 4

invariant asyncio_extra48.gather_class_qualname_len:
  description: "asyncio.gather.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"
  category: class_names
  kind: python_call_eq
  function: gather.__class__.__qualname__.__len__
  args: []
  expected: 8

invariant asyncio_extra48.run_class_qualname_len:
  description: "asyncio.run.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"
  category: class_names
  kind: python_call_eq
  function: run.__class__.__qualname__.__len__
  args: []
  expected: 8
