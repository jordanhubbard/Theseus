spec: functools_extra10
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec extends functools.zspec.zsdl and prior extras through functools_extra9.zspec.zsdl."
    - "Prior specs cover: __name__, __module__, __qualname__ for all public functions and classes; __bases__[0].__name__ for partial and cached_property (extra5/extra6); __bases__.__len__() for partial, cached_property (extra9); WRAPPER_ASSIGNMENTS[0]=='__module__', WRAPPER_UPDATES[0]=='__dict__' (extra9); __class__.__name__ type checks for reduce/partial/lru_cache/etc (base functools spec)."
    - "NEW in this spec: WRAPPER_ASSIGNMENTS[1]=='__name__', [2]=='__qualname__', [3]=='__doc__' (specific index access not yet tested); WRAPPER_ASSIGNMENTS[-1]=='__type_params__' (last element); singledispatchmethod.__bases__[0].__name__=='object' and __bases__.__len__()==1 (never tested); partialmethod.__bases__[0].__name__=='object' and __bases__.__len__()==1 (partialmethod bases not tested in any prior spec)."
    - "functools.WRAPPER_ASSIGNMENTS[1] == '__name__' — second element of the assignments tuple."
    - "functools.WRAPPER_ASSIGNMENTS[2] == '__qualname__' — third element of the assignments tuple."
    - "functools.WRAPPER_ASSIGNMENTS[3] == '__doc__' — fourth element of the assignments tuple."
    - "functools.WRAPPER_ASSIGNMENTS[-1] == '__type_params__' — last element (Python 3.14+)."
    - "functools.singledispatchmethod.__bases__[0].__name__ == 'object' — singledispatchmethod inherits from object."
    - "functools.singledispatchmethod.__bases__.__len__() == 1 — exactly one direct base."
    - "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod inherits from object."
    - "functools.partialmethod.__bases__.__len__() == 1 — exactly one direct base."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS — elements at indices 1, 2, 3, and -1
#
# functools_extra9 verified WRAPPER_ASSIGNMENTS[0] == '__module__' and
# WRAPPER_UPDATES[0] == '__dict__'. No prior spec verified the values at
# positions 1, 2, 3, or the last position (-1) of WRAPPER_ASSIGNMENTS.
# ---------------------------------------------------------------------------

invariant functools_extra10.WRAPPER_ASSIGNMENTS.index1:
  description: "functools.WRAPPER_ASSIGNMENTS[1] == '__name__' — second attribute copied by wraps()"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__getitem__
  args: [1]
  method: __eq__
  method_args: ["__name__"]
  expected: true

invariant functools_extra10.WRAPPER_ASSIGNMENTS.index2:
  description: "functools.WRAPPER_ASSIGNMENTS[2] == '__qualname__' — third attribute copied by wraps()"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__getitem__
  args: [2]
  method: __eq__
  method_args: ["__qualname__"]
  expected: true

invariant functools_extra10.WRAPPER_ASSIGNMENTS.index3:
  description: "functools.WRAPPER_ASSIGNMENTS[3] == '__doc__' — fourth attribute copied by wraps()"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__getitem__
  args: [3]
  method: __eq__
  method_args: ["__doc__"]
  expected: true

invariant functools_extra10.WRAPPER_ASSIGNMENTS.last:
  description: "functools.WRAPPER_ASSIGNMENTS[-1] == '__type_params__' — last element (Python 3.14+)"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__getitem__
  args: [-1]
  method: __eq__
  method_args: ["__type_params__"]
  expected: true

# ---------------------------------------------------------------------------
# singledispatchmethod.__bases__ and __bases__.__len__
#
# functools_extra3 verified singledispatchmethod.__name__, __module__, and
# __qualname__. No prior spec tested __bases__ for singledispatchmethod.
# ---------------------------------------------------------------------------

invariant functools_extra10.singledispatchmethod.bases_len:
  description: "functools.singledispatchmethod.__bases__.__len__() == 1 — exactly one direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: singledispatchmethod.__bases__.__len__
  args: []
  expected: 1

invariant functools_extra10.singledispatchmethod.base_is_object:
  description: "functools.singledispatchmethod.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: singledispatchmethod.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# partialmethod.__bases__ and __bases__.__len__
#
# functools_extra8's qualname table covers partialmethod.__qualname__. No prior
# spec tested __bases__ or __bases__.__len__ for partialmethod specifically.
# (functools_extra5/extra6 cover partial and cached_property bases, not partialmethod.)
# ---------------------------------------------------------------------------

invariant functools_extra10.partialmethod.bases_len:
  description: "functools.partialmethod.__bases__.__len__() == 1 — exactly one direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: partialmethod.__bases__.__len__
  args: []
  expected: 1

invariant functools_extra10.partialmethod.base_is_object:
  description: "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: partialmethod.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS contains checks for Python 3.14 additions
#
# Python 3.14 added '__annotate__' and '__type_params__' to WRAPPER_ASSIGNMENTS.
# functools_extra7 notes these are covered via a __contains__ check on the full
# tuple, but searching the spec confirms these two specific entries were NOT
# verified with __contains__. The base functools spec covers __module__, __name__,
# __qualname__, __doc__; no spec covers __annotate__ or __type_params__.
# ---------------------------------------------------------------------------

invariant functools_extra10.WRAPPER_ASSIGNMENTS.contains_annotate:
  description: "functools.WRAPPER_ASSIGNMENTS contains '__annotate__' (Python 3.14+)"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__annotate__"]
  expected: true

invariant functools_extra10.WRAPPER_ASSIGNMENTS.contains_type_params:
  description: "functools.WRAPPER_ASSIGNMENTS contains '__type_params__' (Python 3.14+)"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__type_params__"]
  expected: true
