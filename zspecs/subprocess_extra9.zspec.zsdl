spec: subprocess_extra9
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
  notes:
    - "This spec extends subprocess.zspec.zsdl and prior extras through subprocess_extra8.zspec.zsdl."
    - "subprocess_extra8 covers: PIPE/STDOUT/DEVNULL __abs__(); PIPE.__add__(-2)==-3; PIPE.__ne__(-2)/STDOUT.__ne__(-1); CalledProcessError output/stderr kwargs; SubprocessError/CalledProcessError/TimeoutExpired __mro__[2]; getoutput/getstatusoutput __name__ standalone."
    - "subprocess_extra6 covers: __qualname__ for CalledProcessError/TimeoutExpired/SubprocessError/getoutput/getstatusoutput/run/call/check_call/check_output/Popen/CompletedProcess."
    - "No prior spec checks Popen method __qualname__ (communicate/wait/poll/kill/terminate/send_signal)."
    - "No prior spec checks CalledProcessError/TimeoutExpired/SubprocessError __mro__[3]."
    - "No prior spec checks PIPE/__neg__(), STDOUT/__neg__(), DEVNULL/__neg__()."
    - "No prior spec checks PIPE/__le__(-1) (equality via __le__) or PIPE/__ge__(-1)."
    - "No prior spec checks CompletedProcess.__module__ or Popen.__mro__[1].__name__."
    - "No prior spec checks subprocess function __class__.__name__ ('function')."
    - "subprocess.Popen.communicate.__qualname__ == 'Popen.communicate'."
    - "subprocess.Popen.wait.__qualname__ == 'Popen.wait'."
    - "subprocess.Popen.poll.__qualname__ == 'Popen.poll'."
    - "subprocess.Popen.kill.__qualname__ == 'Popen.kill'."
    - "subprocess.Popen.terminate.__qualname__ == 'Popen.terminate'."
    - "subprocess.CalledProcessError.__mro__[3].__name__ == 'BaseException' — full MRO."
    - "subprocess.TimeoutExpired.__mro__[3].__name__ == 'BaseException' — full MRO."
    - "subprocess.SubprocessError.__mro__[3].__name__ == 'object' — MRO terminates at object."
    - "subprocess.PIPE.__neg__() == 1 — negating -1 yields positive 1."
    - "subprocess.STDOUT.__neg__() == 2 — negating -2 yields positive 2."
    - "subprocess.DEVNULL.__neg__() == 3 — negating -3 yields positive 3."
    - "subprocess.CompletedProcess.__module__ == 'subprocess' — defined in subprocess.py."
    - "subprocess.run.__class__.__name__ == 'function' — run is a plain Python function."
    - "subprocess.call.__class__.__name__ == 'function' — call is a plain Python function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Popen method __qualname__ checks
#
# subprocess_extra6 checks __qualname__ for Popen as a class.
# No prior spec has checked __qualname__ for Popen instance methods.
# Each method's __qualname__ includes the class name prefix: 'Popen.<method>'.
# ---------------------------------------------------------------------------

table subprocess_extra9.Popen_method_qualnames:
  description: "Popen instance methods have __qualname__ == 'Popen.<method>'"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pqname

  columns: [id, function, args, expected]
  rows:
    - [communicate, Popen.communicate.__qualname__.__eq__, ["Popen.communicate"], true]
    - [wait,        Popen.wait.__qualname__.__eq__,        ["Popen.wait"],        true]
    - [poll,        Popen.poll.__qualname__.__eq__,        ["Popen.poll"],        true]
    - [kill,        Popen.kill.__qualname__.__eq__,        ["Popen.kill"],        true]
    - [terminate,   Popen.terminate.__qualname__.__eq__,   ["Popen.terminate"],   true]

# ---------------------------------------------------------------------------
# Exception MRO — index 3 (not yet covered)
#
# subprocess_extra8 adds MRO[2] for all three exception classes.
# This spec adds MRO[3], reaching the next level:
#   CalledProcessError.__mro__[3] == BaseException
#   TimeoutExpired.__mro__[3] == BaseException
#   SubprocessError.__mro__[3] == object (MRO terminates here)
# ---------------------------------------------------------------------------

invariant subprocess_extra9.CalledProcessError.mro_index3:
  description: "subprocess.CalledProcessError.__mro__[3].__name__ == 'BaseException' — MRO depth 3"
  category: class_hierarchy
  kind: python_call_eq
  function: CalledProcessError.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "BaseException"

invariant subprocess_extra9.TimeoutExpired.mro_index3:
  description: "subprocess.TimeoutExpired.__mro__[3].__name__ == 'BaseException' — MRO depth 3"
  category: class_hierarchy
  kind: python_call_eq
  function: TimeoutExpired.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "BaseException"

invariant subprocess_extra9.SubprocessError.mro_index3:
  description: "subprocess.SubprocessError.__mro__[3].__name__ == 'object' — MRO terminates at object"
  category: class_hierarchy
  kind: python_call_eq
  function: SubprocessError.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# PIPE, STDOUT, DEVNULL — __neg__() checks
#
# subprocess_extra8 covers __abs__() (unsigned magnitudes: 1, 2, 3).
# This spec adds __neg__(): negating a negative integer yields its positive
# counterpart. PIPE(-1).__neg__() == 1, STDOUT(-2).__neg__() == 2,
# DEVNULL(-3).__neg__() == 3.  __neg__ is independent from __abs__.
# ---------------------------------------------------------------------------

table subprocess_extra9.sentinel_neg:
  description: "PIPE/STDOUT/DEVNULL __neg__() returns their positive counterparts 1, 2, 3"
  kind: python_call_eq
  category: constants
  id_prefix: neg

  columns: [id, function, args, expected]
  rows:
    - [PIPE,    PIPE.__neg__,    [], 1]
    - [STDOUT,  STDOUT.__neg__,  [], 2]
    - [DEVNULL, DEVNULL.__neg__, [], 3]

# ---------------------------------------------------------------------------
# CompletedProcess.__module__ — not yet covered
#
# subprocess_extra covers __module__ for SubprocessError/CalledProcessError/
# TimeoutExpired. subprocess_extra2 covers Popen/__module__. No prior spec
# has checked CompletedProcess.__module__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant subprocess_extra9.CompletedProcess.module:
  description: "subprocess.CompletedProcess.__module__ == 'subprocess' — defined in subprocess.py"
  category: class_modules
  kind: python_call_eq
  function: CompletedProcess.__module__.__eq__
  args: ["subprocess"]
  expected: true

# ---------------------------------------------------------------------------
# subprocess function __class__.__name__ type checks
#
# Prior specs cover __name__, __qualname__, __module__ for all major functions.
# No prior spec has checked __class__.__name__ ('function') for subprocess
# functions to confirm they are plain Python function objects.
# ---------------------------------------------------------------------------

table subprocess_extra9.function_types:
  description: "subprocess functions have __class__.__name__ == 'function'"
  kind: python_call_eq
  category: function_types
  id_prefix: ftype

  columns: [id, function, args, expected]
  rows:
    - [run,             run.__class__.__name__.__eq__,             ["function"], true]
    - [call,            call.__class__.__name__.__eq__,            ["function"], true]
    - [check_call,      check_call.__class__.__name__.__eq__,      ["function"], true]
    - [check_output,    check_output.__class__.__name__.__eq__,    ["function"], true]
    - [getoutput,       getoutput.__class__.__name__.__eq__,       ["function"], true]
    - [getstatusoutput, getstatusoutput.__class__.__name__.__eq__, ["function"], true]
