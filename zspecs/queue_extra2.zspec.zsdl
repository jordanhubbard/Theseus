spec: queue_extra2
version: ">=3.9"
backend: python_module(queue)

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/queue.html — Python queue module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/queue.py"
    - "queue_extra.zspec.zsdl — covers Queue/LifoQueue/PriorityQueue/SimpleQueue/Empty/Full class names, Queue constructor/instance behaviour"
  notes:
    - "This spec extends queue_extra.zspec.zsdl with coverage not already present."
    - "Queue.__name__ == 'Queue', LifoQueue.__name__ == 'LifoQueue', etc. — class identity checks."
    - "Empty.__bases__[0].__name__ == 'Exception' — Empty inherits directly from Exception."
    - "Full.__bases__[0].__name__ == 'Exception' — Full inherits directly from Exception."
    - "Queue.__module__ == 'queue' — the class is defined in the queue module."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name invariants — Queue, LifoQueue, PriorityQueue, SimpleQueue
# ---------------------------------------------------------------------------

table queue_extra2.class_names:
  description: "Queue, LifoQueue, PriorityQueue, SimpleQueue __name__ checks"
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Queue,         Queue.__name__.__eq__,         ["Queue"],         true]
    - [LifoQueue,     LifoQueue.__name__.__eq__,     ["LifoQueue"],     true]
    - [PriorityQueue, PriorityQueue.__name__.__eq__, ["PriorityQueue"], true]
    - [SimpleQueue,   SimpleQueue.__name__.__eq__,   ["SimpleQueue"],   true]

# ---------------------------------------------------------------------------
# Exception class name invariants — Empty, Full
# ---------------------------------------------------------------------------

table queue_extra2.exception_names:
  description: "Empty and Full __name__ checks"
  kind: python_call_eq
  category: exceptions
  id_prefix: ename

  columns: [id, function, args, expected]
  rows:
    - [Empty, Empty.__name__.__eq__, ["Empty"], true]
    - [Full,  Full.__name__.__eq__,  ["Full"],  true]

# ---------------------------------------------------------------------------
# Exception base class — both inherit from Exception
# ---------------------------------------------------------------------------

invariant queue_extra2.exceptions.Empty_base:
  description: "queue.Empty.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: Empty.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant queue_extra2.exceptions.Full_base:
  description: "queue.Full.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: Full.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Module attribute — Queue.__module__ == 'queue'
# ---------------------------------------------------------------------------

invariant queue_extra2.Queue.module:
  description: "queue.Queue.__module__ == 'queue'"
  category: class_names
  kind: python_call_eq
  function: Queue.__module__.__eq__
  args: ["queue"]
  expected: true
