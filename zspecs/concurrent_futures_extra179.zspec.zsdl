spec: concurrent_futures_extra179
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures exception class identity — CancelledError.__name__=='CancelledError' (len=14); CancelledError.__module__=='concurrent.futures._base'; TimeoutError.__name__=='TimeoutError' (len=12); TimeoutError.__module__=='builtins' (aliased to built-in TimeoutError in Python 3.11+); InvalidStateError.__name__=='InvalidStateError' (len=17); InvalidStateError.__module__=='concurrent.futures._base'; BrokenExecutor.__name__=='BrokenExecutor' (len=14); BrokenExecutor.__bases__[0].__name__=='RuntimeError'."
    - "concurrent.futures.CancelledError.__name__ == 'CancelledError' (len=14). This exception is raised when a Future is cancelled. Defined in concurrent.futures._base. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.TimeoutError.__module__ == 'builtins'. As of Python 3.11+, concurrent.futures.TimeoutError is an alias for the built-in TimeoutError, so its __module__ is 'builtins', not 'concurrent.futures._base'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'. BrokenExecutor inherits from RuntimeError and is raised when an executor is in a broken state due to a worker process crash. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: CancelledError and InvalidStateError class identity
#
# concurrent.futures.CancelledError.__name__ == 'CancelledError' (len=14)
# concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base'
# concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError' (len=17)
# concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'
#
# Both are defined in concurrent.futures._base.
# ---------------------------------------------------------------------------

table concurrent_futures_extra179.cancelled_invalid_identity:
  description: "concurrent.futures CancelledError and InvalidStateError class identity; both from concurrent.futures._base; new to concurrent_futures_extra179"
  kind: python_call_eq
  category: identity
  id_prefix: cfexcept179

  columns: [id, function, args, expected, description]
  rows:
    - [cancelled_name_eq,
       CancelledError.__name__.__eq__,
       ["CancelledError"],
       true,
       "concurrent.futures.CancelledError.__name__.__eq__('CancelledError') == True — raised when a Future or Task is cancelled; __name__ is 'CancelledError' (14 chars: C-a-n-c-e-l-l-e-d-E-r-r-o-r); str.__eq__('CancelledError') returns True; new to concurrent_futures_extra179"]
    - [cancelled_name_len_14,
       CancelledError.__name__.__len__,
       [],
       14,
       "concurrent.futures.CancelledError.__name__.__len__() == 14 — 'CancelledError' has 14 characters: C-a-n-c-e-l-l-e-d-E-r-r-o-r; NAME LENGTHS: TimeoutError=12 < CancelledError=BrokenExecutor=14 < InvalidStateError=17; str.__len__() returns 14; new to concurrent_futures_extra179"]
    - [cancelled_module_eq,
       CancelledError.__module__.__eq__,
       ["concurrent.futures._base"],
       true,
       "concurrent.futures.CancelledError.__module__.__eq__('concurrent.futures._base') == True — CancelledError is defined in the _base submodule of concurrent.futures; str.__eq__('concurrent.futures._base') returns True; new to concurrent_futures_extra179"]
    - [invalid_name_eq,
       InvalidStateError.__name__.__eq__,
       ["InvalidStateError"],
       true,
       "concurrent.futures.InvalidStateError.__name__.__eq__('InvalidStateError') == True — raised when a Future is in an invalid state for the requested operation; __name__ is 'InvalidStateError' (17 chars); str.__eq__('InvalidStateError') returns True; new to concurrent_futures_extra179"]
    - [invalid_name_len_17,
       InvalidStateError.__name__.__len__,
       [],
       17,
       "concurrent.futures.InvalidStateError.__name__.__len__() == 17 — 'InvalidStateError' has 17 characters: I-n-v-a-l-i-d-S-t-a-t-e-E-r-r-o-r; longest exception name in this spec; str.__len__() returns 17; new to concurrent_futures_extra179"]
    - [invalid_module_eq,
       InvalidStateError.__module__.__eq__,
       ["concurrent.futures._base"],
       true,
       "concurrent.futures.InvalidStateError.__module__.__eq__('concurrent.futures._base') == True — InvalidStateError is defined in concurrent.futures._base; str.__eq__('concurrent.futures._base') returns True; new to concurrent_futures_extra179"]

# ---------------------------------------------------------------------------
# Table 2: TimeoutError class identity
#
# concurrent.futures.TimeoutError.__name__ == 'TimeoutError' (len=12)
# concurrent.futures.TimeoutError.__module__ == 'builtins'
#
# As of Python 3.11+, concurrent.futures.TimeoutError is an alias for the
# built-in TimeoutError, so __module__ is 'builtins'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra179.timeout_identity:
  description: "concurrent.futures.TimeoutError class identity; aliased to built-in TimeoutError in Python 3.11+; __module__=='builtins'; new to concurrent_futures_extra179"
  kind: python_call_eq
  category: identity
  id_prefix: cfexcept179

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_name_eq,
       TimeoutError.__name__.__eq__,
       ["TimeoutError"],
       true,
       "concurrent.futures.TimeoutError.__name__.__eq__('TimeoutError') == True — raised when a Future operation exceeds its timeout; __name__ is 'TimeoutError' (12 chars: T-i-m-e-o-u-t-E-r-r-o-r); str.__eq__('TimeoutError') returns True; new to concurrent_futures_extra179"]
    - [timeout_name_len_12,
       TimeoutError.__name__.__len__,
       [],
       12,
       "concurrent.futures.TimeoutError.__name__.__len__() == 12 — 'TimeoutError' has 12 characters: T-i-m-e-o-u-t-E-r-r-o-r; shortest exception name in this spec; str.__len__() returns 12; new to concurrent_futures_extra179"]
    - [timeout_module_eq,
       TimeoutError.__module__.__eq__,
       ["builtins"],
       true,
       "concurrent.futures.TimeoutError.__module__.__eq__('builtins') == True — since Python 3.11, concurrent.futures.TimeoutError is an alias for the built-in TimeoutError; its __module__ is 'builtins' (not 'concurrent.futures._base'); str.__eq__('builtins') returns True; new to concurrent_futures_extra179"]
    - [timeout_module_len_8,
       TimeoutError.__module__.__len__,
       [],
       8,
       "concurrent.futures.TimeoutError.__module__.__len__() == 8 — 'builtins' has 8 characters: b-u-i-l-t-i-n-s; str.__len__() returns 8; new to concurrent_futures_extra179"]
    - [timeout_lt_invalid_len,
       TimeoutError.__name__.__len__,
       [],
       12,
       "concurrent.futures.TimeoutError.__name__.__len__() == 12 < InvalidStateError len 17 — TimeoutError is shorter than InvalidStateError; str.__len__() returns 12; new to concurrent_futures_extra179"]

# ---------------------------------------------------------------------------
# Table 3: BrokenExecutor class identity
#
# concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor' (len=14)
# concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'
# concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'
#
# BrokenExecutor is raised when an executor is in a broken/unrecoverable state.
# ---------------------------------------------------------------------------

table concurrent_futures_extra179.broken_executor_identity:
  description: "concurrent.futures.BrokenExecutor class identity; inherits from RuntimeError; new to concurrent_futures_extra179"
  kind: python_call_eq
  category: identity
  id_prefix: cfexcept179

  columns: [id, function, args, expected, description]
  rows:
    - [broken_name_eq,
       BrokenExecutor.__name__.__eq__,
       ["BrokenExecutor"],
       true,
       "concurrent.futures.BrokenExecutor.__name__.__eq__('BrokenExecutor') == True — raised when a thread or process pool executor is in a broken, unrecoverable state; __name__ is 'BrokenExecutor' (14 chars: B-r-o-k-e-n-E-x-e-c-u-t-o-r); str.__eq__('BrokenExecutor') returns True; new to concurrent_futures_extra179"]
    - [broken_name_len_14,
       BrokenExecutor.__name__.__len__,
       [],
       14,
       "concurrent.futures.BrokenExecutor.__name__.__len__() == 14 — 'BrokenExecutor' has 14 characters: B-r-o-k-e-n-E-x-e-c-u-t-o-r; equal in length to CancelledError; str.__len__() returns 14; new to concurrent_futures_extra179"]
    - [broken_module_eq,
       BrokenExecutor.__module__.__eq__,
       ["concurrent.futures._base"],
       true,
       "concurrent.futures.BrokenExecutor.__module__.__eq__('concurrent.futures._base') == True — BrokenExecutor is defined in concurrent.futures._base; str.__eq__('concurrent.futures._base') returns True; new to concurrent_futures_extra179"]
    - ["broken_base0_name_eq",
       "BrokenExecutor.__bases__[0].__name__.__eq__",
       ["RuntimeError"],
       true,
       "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError') == True — BrokenExecutor inherits directly from RuntimeError, the appropriate base for unrecoverable runtime failures; str.__eq__('RuntimeError') returns True; new to concurrent_futures_extra179"]
    - [broken_bases_len_1,
       "BrokenExecutor.__bases__.__len__",
       [],
       1,
       "concurrent.futures.BrokenExecutor.__bases__.__len__() == 1 — BrokenExecutor has exactly one direct base class: RuntimeError; tuple.__len__() returns 1; new to concurrent_futures_extra179"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra179
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra179.cancelled_name_eq:
  description: "concurrent.futures.CancelledError.__name__ == 'CancelledError' — raised when a Future is cancelled; len=14; new to concurrent_futures_extra179"
  category: identity
  kind: python_call_eq
  function: CancelledError.__name__.__eq__
  args: ["CancelledError"]
  expected: true

invariant concurrent_futures_extra179.cancelled_module_eq:
  description: "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base' — defined in the _base submodule; new to concurrent_futures_extra179"
  category: identity
  kind: python_call_eq
  function: CancelledError.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra179.timeout_name_eq:
  description: "concurrent.futures.TimeoutError.__name__ == 'TimeoutError' — raised on timeout; len=12; aliased to built-in TimeoutError in Python 3.11+; new to concurrent_futures_extra179"
  category: identity
  kind: python_call_eq
  function: TimeoutError.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant concurrent_futures_extra179.timeout_module_eq:
  description: "concurrent.futures.TimeoutError.__module__ == 'builtins' — aliased to built-in TimeoutError since Python 3.11; __module__ is 'builtins' not 'concurrent.futures._base'; new to concurrent_futures_extra179"
  category: identity
  kind: python_call_eq
  function: TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant concurrent_futures_extra179.invalid_name_eq:
  description: "concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError' — raised when Future is in an invalid state; len=17; longest name in spec; new to concurrent_futures_extra179"
  category: identity
  kind: python_call_eq
  function: InvalidStateError.__name__.__eq__
  args: ["InvalidStateError"]
  expected: true

invariant concurrent_futures_extra179.invalid_module_eq:
  description: "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base' — defined in the _base submodule; new to concurrent_futures_extra179"
  category: identity
  kind: python_call_eq
  function: InvalidStateError.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra179.broken_name_eq:
  description: "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor' — raised when an executor is in an unrecoverable broken state; len=14; new to concurrent_futures_extra179"
  category: identity
  kind: python_call_eq
  function: BrokenExecutor.__name__.__eq__
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra179.broken_base0_name_eq:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' — BrokenExecutor directly inherits from RuntimeError; new to concurrent_futures_extra179"
  category: identity
  kind: python_call_eq
  function: "BrokenExecutor.__bases__[0].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true
