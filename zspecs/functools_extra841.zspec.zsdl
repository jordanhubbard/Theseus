spec: functools_extra841
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - functools module standard library documentation
    - Python 3.9+ functools API
  not_derived_from:
    - any third-party functools extensions
    - functools32 backport
  notes:
    - Covers __doc__ class names and __qualname__ identity for core functools callables
    - Validates that doc strings are of type str (not NoneType or bytes)
    - OrderedDict context refers to the wrapped/decorated pattern use cases
  created_at: "2026-04-12"

table functools_extra841.doc_and_qualname:
  description: Verify __doc__ class names and __qualname__ identity for functools callables
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: ft841xx
  columns: [id, function, args, expected]
  rows:
    - [ft841xx001, functools.reduce.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ft841xx002, functools.reduce.__qualname__.__eq__, ["reduce"], true]
    - [ft841xx003, functools.wraps.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ft841xx004, functools.wraps.__qualname__.__eq__, ["wraps"], true]
    - [ft841xx005, functools.update_wrapper.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ft841xx006, functools.update_wrapper.__qualname__.__eq__, ["update_wrapper"], true]
    - [ft841xx007, functools.total_ordering.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ft841xx008, functools.cmp_to_key.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ft841xx009, functools.lru_cache.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ft841xx010, functools.cache.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ft841xx011, functools.singledispatch.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ft841xx012, functools.cached_property.__doc__.__class__.__name__.__eq__, ["str"], true]
