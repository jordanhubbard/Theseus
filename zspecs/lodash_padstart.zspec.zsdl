spec: lodash_padstart
version: ">=4.0.0"
backend: node(lodash.padstart)

docs: https://lodash.com/docs/#padStart

provenance:
  derived_from:
    - "lodash.padstart README — https://www.npmjs.com/package/lodash.padstart"
    - "Test vectors verified with lodash.padstart@4.6.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.padstart exports the _.padStart function directly as module.exports."
    - "padStart(string, length, chars) pads string at the start."
    - "Pads with spaces by default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a left-padded string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_padstart.padstart:
  kind: node_module_call_eq
  function: ~
  category: padstart
  id_prefix: lpads

  columns: [id, args, expected]
  rows:
    - [zero_pad,    ["5", 3, "0"],    "005"]
    - [space_pad,   ["abc", 6],       "   abc"]
    - [no_padding,  ["hello", 3],     "hello"]
    - [multi_char,  ["1", 5, "xo"],   "xoxo1"]
