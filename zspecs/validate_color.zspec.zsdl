spec: validate_color
version: ">=2.0.0"
backend: node(validate-color)

docs: https://www.npmjs.com/package/validate-color

provenance:
  derived_from:
    - "validate-color README — https://www.npmjs.com/package/validate-color"
    - "Test vectors verified with validate-color via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "validate-color source"
  notes:
    - "validate-color is an npm package. Install: npm install validate-color"
    - "The default export validateColor(str) returns true if the string is a valid CSS color."
    - "Accepts hex, rgb(), rgba(), named colors, hsl(), etc."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table validate_color.validate:
  kind: node_module_call_eq
  function: "default"
  category: validate
  id_prefix: vc

  columns: [id, args, expected]
  rows:
    - [hex,      ["#ff0000"],       true]
    - [named,    ["red"],           true]
    - [rgb,      ["rgb(255,0,0)"],  true]
    - [invalid,  ["not-a-color"],   false]
