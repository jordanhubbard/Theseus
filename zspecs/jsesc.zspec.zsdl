spec: jsesc
version: ">=3.0.0"
backend: node(jsesc)

docs: https://github.com/mathiasbynens/jsesc#readme

provenance:
  derived_from:
    - "jsesc README — https://github.com/mathiasbynens/jsesc#readme"
    - "Test vectors verified with jsesc via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "jsesc source"
  notes:
    - "jsesc generates valid JavaScript or JSON string literals from arbitrary inputs (Mathias Bynens)."
    - "Install: npm install jsesc"
    - "Module export IS the function. Default mode generates a JS literal (no surrounding quotes); {json: true} produces JSON output."
    - "Non-ASCII characters are escaped to \\xHH or \\uHHHH; quotes inside strings are escaped per the active mode."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on serializable inputs."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table jsesc.escape:
  kind: node_module_call_eq
  category: escape
  function: ~
  id_prefix: esc

  columns: [id, args, expected]
  rows:
    - [ascii_passthrough,    ["hello"],       "hello"]
    - [empty_string,         [""],             ""]
    - [non_ascii_unicode,    ["Café"],         "Caf\\xE9"]
    - [tab_char,             ["a\tb"],         "a\\tb"]
    - [newline_char,         ["a\nb"],         "a\\nb"]
    - [backslash,            ["a\\b"],         "a\\\\b"]

table jsesc.json_mode:
  kind: node_module_call_eq
  category: json
  function: ~
  id_prefix: json

  columns: [id, args, expected]
  rows:
    - [object_simple,
       [{a: 1}, {json: true}],
       "{\"a\":1}"]

    - [array,
       [[1, 2, 3], {json: true}],
       "[1,2,3]"]

    - [string_with_quotes,
       ["it\"s", {json: true}],
       "\"it\\\"s\""]

    - [nested_object,
       [{a: {b: 2}}, {json: true}],
       "{\"a\":{\"b\":2}}"]
