spec: concurrent_futures_extra1726
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 562 (_extra1726): comparison/ordering protocol dict-presence checks."
    - "Theme: which concurrent.futures stdlib types define __lt__, __le__, __gt__, __ge__, __ne__ in their own __dict__."
    - "concurrent.futures.Future: pure Python class representing an async computation result; no ordering operators defined in own __dict__ -> all False."
    - "concurrent.futures.Future.__dict__.__contains__('__lt__') -> False."
    - "concurrent.futures.ThreadPoolExecutor: executor class; no comparison operators in own __dict__ -> all False."
    - "concurrent.futures.ProcessPoolExecutor: executor class; no comparison operators in own __dict__ -> all False."
    - "concurrent.futures.Executor: abstract base class; no comparison operators in own __dict__ -> all False."
    - "Cross-check: __eq__ and __hash__ are also absent from the own __dict__ of all listed concurrent.futures types (inherited from object) -> all False."
    - "Note: concurrent.futures.Future is conceptually similar to asyncio.Future but there is no ordering between Future instances in either module."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: comparison operator dict-presence checks (__lt__, __le__, __gt__, __ge__, __ne__)
#
# Wave 562 theme: do concurrent.futures types define ordering/comparison dunders
# in their own __dict__? concurrent.futures.Future represents an eventual
# computation result and carries no ordering semantics — two Future objects
# cannot be compared as greater-than or less-than. Executor subclasses similarly
# have no notion of ordering. All checks return False.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1726.comparison_protocol:
  description: "concurrent.futures types: __lt__, __le__, __gt__, __ge__, __ne__ dict-presence checks (all False — no ordering semantics)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1726

  columns: [id, function, args, expected]
  rows:
    - ["cf1726001", "concurrent.futures.Future.__dict__.__contains__",              ["__lt__"], false]
    - ["cf1726002", "concurrent.futures.Future.__dict__.__contains__",              ["__le__"], false]
    - ["cf1726003", "concurrent.futures.Future.__dict__.__contains__",              ["__gt__"], false]
    - ["cf1726004", "concurrent.futures.Future.__dict__.__contains__",              ["__ge__"], false]
    - ["cf1726005", "concurrent.futures.Future.__dict__.__contains__",              ["__ne__"], false]
    - ["cf1726006", "concurrent.futures.Executor.__dict__.__contains__",            ["__lt__"], false]
    - ["cf1726007", "concurrent.futures.Executor.__dict__.__contains__",            ["__le__"], false]
    - ["cf1726008", "concurrent.futures.Executor.__dict__.__contains__",            ["__gt__"], false]
    - ["cf1726009", "concurrent.futures.Executor.__dict__.__contains__",            ["__ge__"], false]
    - ["cf1726010", "concurrent.futures.Executor.__dict__.__contains__",            ["__ne__"], false]

# ---------------------------------------------------------------------------
# Table 2: __eq__ and __hash__ dict-presence cross-checks
#
# Wave 562 cross-check: concurrent.futures types do not override __eq__ or
# __hash__ in their own __dict__. Future objects are compared by identity,
# not by state (whether the result is ready, cancelled, or pending). Executor
# objects are singletons in practice and also rely on identity comparison.
# Both __eq__ and __hash__ are inherited from object for all four public types.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1726.eq_hash_protocol:
  description: "concurrent.futures types: __eq__ and __hash__ dict-presence cross-check (all inherited from object — not in own __dict__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1726

  columns: [id, function, args, expected]
  rows:
    - ["cf1726011", "concurrent.futures.Future.__dict__.__contains__",              ["__eq__"],   false]
    - ["cf1726012", "concurrent.futures.Future.__dict__.__contains__",              ["__hash__"], false]
    - ["cf1726013", "concurrent.futures.Executor.__dict__.__contains__",            ["__eq__"],   false]
    - ["cf1726014", "concurrent.futures.Executor.__dict__.__contains__",            ["__hash__"], false]
    - ["cf1726015", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__eq__"],   false]
    - ["cf1726016", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__hash__"], false]
    - ["cf1726017", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__eq__"],   false]
    - ["cf1726018", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__hash__"], false]

# ---------------------------------------------------------------------------
# Table 3: ordering operator dict-presence for ThreadPoolExecutor and ProcessPoolExecutor
#
# Wave 562 extension: extend the comparison/ordering protocol checks to
# ThreadPoolExecutor and ProcessPoolExecutor. These executor types manage
# thread pools and process pools respectively, and have no meaningful ordering
# relationship between instances. Neither defines __lt__, __le__, __gt__,
# __ge__, or __ne__ in its own __dict__. The checks confirm the complete
# absence of ordering protocol support across all four concurrent.futures types.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1726.executor_comparison_protocol:
  description: "concurrent.futures executors: __lt__, __le__, __gt__, __ge__, __ne__ dict-presence (all False — no ordering semantics)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1726

  columns: [id, function, args, expected]
  rows:
    - ["cf1726019", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__lt__"], false]
    - ["cf1726020", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__le__"], false]
    - ["cf1726021", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__gt__"], false]
    - ["cf1726022", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__ge__"], false]
    - ["cf1726023", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__ne__"], false]
    - ["cf1726024", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__lt__"], false]
    - ["cf1726025", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__le__"], false]
    - ["cf1726026", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__gt__"], false]
    - ["cf1726027", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__ge__"], false]
    - ["cf1726028", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__ne__"], false]
