spec: hashlib_extra163
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "CPython source: Modules/_blake2module.c"
    - "hashlib_extra162.zspec.zsdl — covers hashlib.sha256.__name__.__eq__('openssl_sha256') / md5.__name__.__eq__('openssl_md5') / sha256.__module__.__eq__('_hashlib') / md5.__module__.__eq__('_hashlib') / sha256/__doc__/__len__() / md5/__doc__/__len__() ordering (table + invariants)."
    - "hashlib_extra161.zspec.zsdl — covers hashlib.sha256() HASH method qualnames: sha256().update/__qualname__.__eq__('HASH.update') / sha256().digest/__qualname__.__eq__('HASH.digest') / sha256().hexdigest/__qualname__.__eq__('HASH.hexdigest') / sha256().copy.__qualname__.__eq__('HASH.copy') and qualname lengths (table + invariants)."
    - "hashlib_extra160.zspec.zsdl — covers hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') / new.__qualname__.__eq__('__hash_new') / new.__class__.__name__.__eq__('function') / algorithms_guaranteed.__class__.__name__.__eq__('set') (table + invariants)."
    - "hashlib_extra158.zspec.zsdl — covers hashlib.sha256/__qualname__.__len__()==14 / sha3_256/__qualname__.__len__()==16 / sha256/__doc__/__class__.__name__.__eq__('str') (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra162."
    - "Wave 342 theme: hashlib sha3 family and blake2 family constructor __name__ and __module__ identity — sha3_256.__name__.__eq__('openssl_sha3_256') / sha3_256.__module__.__eq__('_hashlib') / sha3_512.__name__.__eq__('openssl_sha3_512') / sha3_512.__module__.__eq__('_hashlib') / blake2b.__name__.__eq__('blake2b') / blake2s.__name__.__eq__('blake2s') / blake2b.__module__.__eq__('_blake2') / blake2s.__module__.__eq__('_blake2')."
    - "hashlib.sha3_256.__name__ == 'openssl_sha3_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__name__ == 'openssl_sha3_512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__name__ == 'blake2b'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__name__ == 'blake2s'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__ == '_blake2'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__module__ == '_blake2'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__name__.__len__() == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__name__.__len__() == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__name__.__len__() == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__name__.__len__() == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.sha3_256.__name__ == 'openssl_sha3_256' (16 chars = 'openssl_'=8 + 'sha3_256'=8). sha3_256 is a builtin_function_or_method defined in the _hashlib C extension (same as sha256, md5, sha512). It uses the same 'openssl_' prefix pattern. 'sha3_256' (8 chars) is longer than 'sha256' (6 chars), making 'openssl_sha3_256' (16 chars) longer than 'openssl_sha256' (14 chars). sha3_512 also has 16-char name ('openssl_sha3_512' = 'openssl_'=8 + 'sha3_512'=8). Both sha3_256 and sha3_512 tie at 16 chars. extra158 anchors sha3_256.__qualname__.__len__()==16 but NOT the __name__ string value."
    - "Note: hashlib.blake2b.__name__ == 'blake2b' (7 chars). hashlib.blake2s.__name__ == 'blake2s' (7 chars). Unlike sha3_256/sha3_512 which are builtin_function_or_method objects, blake2b and blake2s are 'type' objects (C extension types defined in Modules/_blake2module.c). Their __module__ is '_blake2' (7 chars = '_'=1 + 'blake2'=6; distinct from '_hashlib'). blake2b.__name__ == blake2b.__qualname__ == 'blake2b' (7 chars; NO 'openssl_' prefix because blake2 is not an OpenSSL algorithm). blake2s.__name__ == 'blake2s' (7 chars; ties blake2b). Both have __module__ == '_blake2' (7 chars)."
    - "Note: hashlib.blake2b.__module__ == '_blake2' (7 chars = '_'=1 + 'blake2'=6). The BLAKE2 hash functions (blake2b and blake2s) are implemented in a separate C extension module '_blake2', not in '_hashlib'. This is because BLAKE2 is not based on the OpenSSL EVP API used by sha256/md5/sha3_256 etc. The '_blake2' module provides type objects (blake2b and blake2s) rather than builtin_function_or_method objects. '_blake2' is 7 chars (same as '_socket' from socket module)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__name__.__eq__('openssl_sha3_256')
# hashlib.sha3_256.__module__.__eq__('_hashlib')
# hashlib.sha3_512.__name__.__eq__('openssl_sha3_512')
# hashlib.sha3_512.__module__.__eq__('_hashlib')
#
# Wave 342 theme: sha3 family constructor __name__ strings and module identity.
#
# sha3_256.__name__ == 'openssl_sha3_256' (16 chars = 'openssl_'=8 + 'sha3_256'=8).
# sha3_256.__module__ == '_hashlib' (8 chars; same C extension as sha256/md5).
# sha3_512.__name__ == 'openssl_sha3_512' (16 chars = 'openssl_'=8 + 'sha3_512'=8).
# sha3_512.__module__ == '_hashlib' (8 chars; ties sha3_256).
# extra158 anchors sha3_256/__qualname__.__len__()==16 but NOT the string value as __name__.
# No prior hashlib spec anchors sha3_256/__name__ string as a table under sha3id163.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra163.sha3_constructor_name_and_module:
  description: "hashlib.sha3_256.__name__.__eq__('openssl_sha3_256')==True / sha3_256.__module__.__eq__('_hashlib')==True / sha3_512.__name__.__eq__('openssl_sha3_512')==True / sha3_512.__module__.__eq__('_hashlib')==True — sha3_256.__name__ is 'openssl_sha3_256' (16 chars = 'openssl_'=8 + 'sha3_256'=8; 'sha3_256'=8 chars vs 'sha256'=6 chars in sha256.__name__; 2 chars longer); sha3_256.__module__ is '_hashlib' (8 chars; same C extension as sha256/md5/sha512; OpenSSL EVP API); sha3_512.__name__ is 'openssl_sha3_512' (16 chars = 'openssl_'=8 + 'sha3_512'=8; ties sha3_256 at 16 chars); sha3_512.__module__ is '_hashlib' (8 chars; same extension as sha3_256); extra158 anchors qualname len 16 but NOT __name__ string; first sha3id163 anchor for sha3_256/__name__ and sha3_512/__name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: sha3id163

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_name_str,    "sha3_256.__name__.__eq__",    ["openssl_sha3_256"], true, "hashlib.sha3_256.__name__ == 'openssl_sha3_256' (16 chars = 'openssl_'=8 + 'sha3_256'=8; C-level name in _hashlib; OpenSSL EVP API wrapper)"]
    - [sha3_256_module_str,  "sha3_256.__module__.__eq__",  ["_hashlib"],         true, "hashlib.sha3_256.__module__ == '_hashlib' (8 chars; same C extension as sha256/md5; leading underscore = implementation module)"]
    - [sha3_512_name_str,    "sha3_512.__name__.__eq__",    ["openssl_sha3_512"], true, "hashlib.sha3_512.__name__ == 'openssl_sha3_512' (16 chars = 'openssl_'=8 + 'sha3_512'=8; ties sha3_256 at 16 chars; same prefix pattern)"]
    - [sha3_512_module_str,  "sha3_512.__module__.__eq__",  ["_hashlib"],         true, "hashlib.sha3_512.__module__ == '_hashlib' (8 chars; ties sha3_256.__module__; both sha3 family constructors in same C extension)"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__name__.__eq__('blake2b')
# hashlib.blake2s.__name__.__eq__('blake2s')
# hashlib.blake2b.__module__.__eq__('_blake2')
# hashlib.blake2s.__module__.__eq__('_blake2')
#
# Wave 342 theme: blake2 family constructor __name__ and module identity.
#
# blake2b.__name__ == 'blake2b' (7 chars; NO 'openssl_' prefix; type, not builtin_function).
# blake2s.__name__ == 'blake2s' (7 chars; ties blake2b; 'blake2s'=7 chars).
# blake2b.__module__ == '_blake2' (7 chars; distinct from '_hashlib'; BLAKE2-specific C extension).
# blake2s.__module__ == '_blake2' (7 chars; same module as blake2b).
# blake2b and blake2s are 'type' objects (not builtin_function_or_method like sha256/sha3_256).
# No prior hashlib spec anchors blake2b/__name__ string as a table under sha3id163.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra163.blake2_constructor_name_and_module:
  description: "hashlib.blake2b.__name__.__eq__('blake2b')==True / blake2s.__name__.__eq__('blake2s')==True / blake2b.__module__.__eq__('_blake2')==True / blake2s.__module__.__eq__('_blake2')==True — blake2b.__name__ is 'blake2b' (7 chars; NO 'openssl_' prefix; blake2b is a 'type' object, not builtin_function_or_method like sha256/sha3_256; BLAKE2 not based on OpenSSL EVP API); blake2s.__name__ is 'blake2s' (7 chars; ties blake2b; 'blake2s' vs 'blake2b' differ only in last char); blake2b.__module__ is '_blake2' (7 chars = '_'=1 + 'blake2'=6; separate C extension from '_hashlib'; BLAKE2-specific module); blake2s.__module__ is '_blake2' (7 chars; ties blake2b; both BLAKE2 variants in same extension); length ordering: blake2b==blake2s(7) < sha256==sha512==sha3_256(14/14/16) in __name__; first sha3id163 anchor for blake2b/__name__ and blake2b/__module__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: sha3id163

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_name_str,    "blake2b.__name__.__eq__",    ["blake2b"],  true, "hashlib.blake2b.__name__ == 'blake2b' (7 chars; 'type' object not builtin_function; NO 'openssl_' prefix; BLAKE2 not OpenSSL EVP-based)"]
    - [blake2s_name_str,    "blake2s.__name__.__eq__",    ["blake2s"],  true, "hashlib.blake2s.__name__ == 'blake2s' (7 chars; ties blake2b; 'blake2s' vs 'blake2b' differ only in 'b' vs 's' suffix)"]
    - [blake2b_module_str,  "blake2b.__module__.__eq__",  ["_blake2"],  true, "hashlib.blake2b.__module__ == '_blake2' (7 chars = '_'=1 + 'blake2'=6; separate C extension from '_hashlib'; BLAKE2-specific)"]
    - [blake2s_module_str,  "blake2s.__module__.__eq__",  ["_blake2"],  true, "hashlib.blake2s.__module__ == '_blake2' (7 chars; ties blake2b.__module__; both BLAKE2 variants share the '_blake2' C extension)"]

# ---------------------------------------------------------------------------
# sha3 and blake2 __name__ length comparison table
#
# Wave 342 theme: __name__ length ordering across sha3 and blake2 families.
#
# sha3_256.__name__.__len__() == 16 ('openssl_sha3_256').
# sha3_512.__name__.__len__() == 16 ('openssl_sha3_512'; ties sha3_256).
# blake2b.__name__.__len__() == 7 ('blake2b'; NO openssl_ prefix).
# blake2s.__name__.__len__() == 7 ('blake2s'; ties blake2b).
# Length ordering: blake2b==blake2s(7) < sha3_256==sha3_512(16).
# No prior hashlib spec anchors sha3_256/__name__.__len__() as a table under sha3id163.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra163.sha3_blake2_name_lengths:
  description: "hashlib.sha3_256.__name__.__len__()==16 / sha3_512.__name__.__len__()==16 / blake2b.__name__.__len__()==7 / blake2s.__name__.__len__()==7 — sha3_256.__name__ is 16 chars ('openssl_sha3_256' = 'openssl_'=8 + 'sha3_256'=8; extra158 anchors qualname len 16 but NOT __name__ len 16); sha3_512.__name__ is 16 chars ('openssl_sha3_512'; ties sha3_256; 'sha3_512'=8 chars); blake2b.__name__ is 7 chars ('blake2b' = 7 chars; NO openssl_ prefix; 7 < 16); blake2s.__name__ is 7 chars ('blake2s'; ties blake2b; both BLAKE2 variants have 7-char names); length ordering: blake2b==blake2s(7) < sha256==sha512(14) < sha3_256==sha3_512(16); first sha3id163 anchor for sha3_256/__name__.__len__() and blake2b/__name__.__len__()"
  kind: python_call_eq
  category: identity
  id_prefix: sha3id163

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_name_len_16,  "sha3_256.__name__.__len__",  [], 16, "hashlib.sha3_256.__name__.__len__() is 16 ('openssl_sha3_256' = 'openssl_'=8 + 'sha3_256'=8; extra158 anchors qualname len 16 but not __name__ len)"]
    - [sha3_512_name_len_16,  "sha3_512.__name__.__len__",  [], 16, "hashlib.sha3_512.__name__.__len__() is 16 ('openssl_sha3_512' = 'openssl_'=8 + 'sha3_512'=8; ties sha3_256 at 16 chars)"]
    - [blake2b_name_len_7,    "blake2b.__name__.__len__",   [], 7,  "hashlib.blake2b.__name__.__len__() is 7 ('blake2b' = 7 chars; NO openssl_ prefix; type object not builtin_function; 7 < 16)"]
    - [blake2s_name_len_7,    "blake2s.__name__.__len__",   [], 7,  "hashlib.blake2s.__name__.__len__() is 7 ('blake2s' = 7 chars; ties blake2b; BLAKE2s shorter digest than BLAKE2b)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__name__.__eq__('openssl_sha3_256') — standalone
#
# hashlib.sha3_256.__name__ is 'openssl_sha3_256' (16 chars = 'openssl_'=8 + 'sha3_256'=8).
# sha3_256 is a builtin_function_or_method from the _hashlib C extension. Like sha256 and
# md5, it uses the 'openssl_' prefix in its C-level name, reflecting that it wraps OpenSSL's
# EVP API. 'sha3_256' (8 chars) is 2 chars longer than 'sha256' (6 chars), making
# 'openssl_sha3_256' (16 chars) 2 chars longer than 'openssl_sha256' (14 chars). Name length
# ordering: openssl_md5(11) < openssl_sha1(12) < openssl_sha256==openssl_sha512(14) <
# openssl_sha3_256==openssl_sha3_512(16). extra158 anchors sha3_256/__qualname__.__len__()==16;
# no prior hashlib spec anchors sha3_256.__name__ string as a standalone under sha3id163.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra163.sha3_256_name_openssl_sha3_256:
  description: "hashlib.sha3_256.__name__.__eq__('openssl_sha3_256') == True — 16 chars = 'openssl_'=8 + 'sha3_256'=8; builtin_function_or_method from _hashlib C extension; 'openssl_' prefix (8 chars) reflects OpenSSL EVP API wrapper; 'sha3_256'=8 chars (vs 'sha256'=6 chars; 2 chars longer); name length ordering: openssl_md5(11) < openssl_sha256==openssl_sha512(14) < openssl_sha3_256==openssl_sha3_512(16); extra158 anchors __qualname__.__len__()==16 but NOT __name__ string; sha3_256.__name__==sha3_256.__qualname__=='openssl_sha3_256'; no prior hashlib spec anchors this as a standalone; first standalone under sha3id163"
  category: identity
  kind: python_call_eq
  function: sha3_256.__name__.__eq__
  args: ["openssl_sha3_256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__name__.__eq__('blake2b') — standalone
#
# hashlib.blake2b.__name__ is 'blake2b' (7 chars). Unlike sha3_256 and sha256, blake2b
# is a 'type' object (a C extension type, not a builtin_function_or_method). blake2b is
# implemented in Modules/_blake2module.c, which provides the BLAKE2 family independently
# of the OpenSSL EVP API used by the hashlib._hashlib extension. The lack of 'openssl_'
# prefix in blake2b.__name__ reflects this different implementation path: blake2b's C-level
# type name is simply 'blake2b'. blake2b.__module__ == '_blake2' (7 chars), distinct from
# sha3_256.__module__ == '_hashlib' (8 chars). blake2b and blake2s both have 7-char names.
# No prior hashlib spec anchors blake2b.__name__ string as a standalone under sha3id163.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra163.blake2b_name_blake2b:
  description: "hashlib.blake2b.__name__.__eq__('blake2b') == True — 7 chars; 'type' object (C extension type) not builtin_function_or_method; implemented in Modules/_blake2module.c separate from _hashlib; NO 'openssl_' prefix (BLAKE2 not based on OpenSSL EVP API); blake2b.__module__=='_blake2' (7 chars; distinct from '_hashlib'=8 chars for sha256/sha3_256); blake2b.__name__==blake2b.__qualname__=='blake2b' (7 chars); blake2b(7) < openssl_sha256(14) < openssl_sha3_256(16) in __name__ length; no prior hashlib spec anchors this as a standalone; first standalone under sha3id163"
  category: identity
  kind: python_call_eq
  function: blake2b.__name__.__eq__
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__module__.__eq__('_blake2') — standalone
#
# hashlib.blake2b.__module__ is '_blake2' (7 chars = '_'=1 + 'blake2'=6). blake2b and
# blake2s both belong to the '_blake2' C extension module, which is separate from '_hashlib'.
# '_blake2' (7 chars) differs from '_hashlib' (8 chars): same length as '_socket' (7 chars)
# from the socket module. The leading underscore convention indicates a private C extension.
# Both BLAKE2b and BLAKE2s are implemented in '_blake2' because they share the same
# underlying C library (the reference BLAKE2 implementation, not OpenSSL). This contrasts
# with sha256, sha512, sha3_256, and sha3_512, all of which have __module__ == '_hashlib'
# because they use OpenSSL's EVP message digest API.
# No prior hashlib spec anchors blake2b.__module__ string as a standalone under sha3id163.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra163.blake2b_module_blake2:
  description: "hashlib.blake2b.__module__.__eq__('_blake2') == True — 7 chars = '_'=1 + 'blake2'=6; separate C extension from '_hashlib' (8 chars); same length as '_socket' (7 chars); BLAKE2 uses reference C implementation (not OpenSSL EVP); blake2s.__module__=='_blake2' (same module; both BLAKE2 variants share the extension); leading underscore = private implementation module convention; '_blake2'(7) != '_hashlib'(8) despite both being private C extensions; no prior hashlib spec anchors this as a standalone; first standalone under sha3id163"
  category: identity
  kind: python_call_eq
  function: blake2b.__module__.__eq__
  args: ["_blake2"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_512.__name__.__len__()==16 — standalone
#
# hashlib.sha3_512.__name__.__len__() is 16. 'openssl_sha3_512' = 'openssl_'=8 +
# 'sha3_512'=8 = 16 chars. sha3_512 is a builtin_function_or_method from _hashlib,
# following the same 'openssl_' prefix pattern as sha256, md5, sha1, and sha3_256.
# 'sha3_512' (8 chars) is the longest algorithm name suffix among the common hashlib
# constructors (sha256=6, sha512=6, sha3_256=8, sha3_512=8). sha3_256 and sha3_512
# both tie at 16 chars for __name__ length. This is 2 chars longer than sha256/sha512
# (14 chars each) and 4 chars longer than sha1 (12 chars). sha3_512.__module__ == '_hashlib'
# (same as sha3_256). No prior hashlib spec anchors sha3_512.__name__.__len__() as a
# standalone under sha3id163. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra163.sha3_512_name_len_16:
  description: "hashlib.sha3_512.__name__.__len__() == 16 — 'openssl_sha3_512' = 'openssl_'=8 + 'sha3_512'=8 = 16 chars; builtin_function_or_method from _hashlib; 'sha3_512'=8 chars (longest algorithm name suffix among common constructors); sha3_256 and sha3_512 tie at 16; ordering: openssl_md5(11) < openssl_sha1(12) < openssl_sha256==openssl_sha512(14) < openssl_sha3_256==openssl_sha3_512(16); sha3_512.__module__=='_hashlib' (8 chars); no prior hashlib spec anchors this as a standalone; first standalone under sha3id163"
  category: identity
  kind: python_call_eq
  function: sha3_512.__name__.__len__
  args: []
  expected: 16

