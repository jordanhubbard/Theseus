spec: abc_extra2731
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 629 (_extra2731): __trunc__, __floor__, __ceil__ dict-presence checks (rounding/truncation operators)."
    - "abc.ABCMeta is a metaclass; abc.ABC is a helper base class; abc.abstractmethod and abc.abstractproperty are decorators."
    - "None of these abc constructs define truncation, floor, or ceiling rounding protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __trunc__ dict-presence checks
#
# Wave 629 theme: abc module types do not implement the truncation operator.
# __trunc__ does not appear in any of these classes' own __dict__.
# ---------------------------------------------------------------------------

table abc_extra2731.trunc_protocol:
  description: "abc.ABCMeta, abc.ABC, abc.abstractmethod, abc.abstractproperty __trunc__ dict-presence checks — none define truncation in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2731

  columns: [id, function, args, expected]
  rows:
    - ["ab2731001", "abc.ABCMeta.__dict__.__contains__",          ["__trunc__"], false]
    - ["ab2731002", "abc.ABC.__dict__.__contains__",              ["__trunc__"], false]
    - ["ab2731003", "abc.abstractmethod.__dict__.__contains__",   ["__trunc__"], false]
    - ["ab2731004", "abc.abstractproperty.__dict__.__contains__", ["__trunc__"], false]

