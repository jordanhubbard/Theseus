# ---------------------------------------------------------------------------
# Table 4: combined __trunc__/__floor__/__ceil__ checks for ABCMeta and
#          abstractproperty
#
# Wave 629 theme: ABCMeta is a metaclass that enforces abstract method
# contracts; abstractproperty is a deprecated decorator combining
# abstractmethod and property. Neither construct participates in numeric
# protocols, so all three rounding/truncation dunder methods are absent from
# their own __dict__.
# ---------------------------------------------------------------------------

table abc_extra2731.abcmeta_abstractproperty_rounding:
  description: "abc.ABCMeta and abc.abstractproperty combined __trunc__/__floor__/__ceil__ dict-presence checks — metaclass and deprecated decorator define no rounding/truncation"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2731

  columns: [id, function, args, expected]
  rows:
    - ["ab2731013", "abc.ABCMeta.__dict__.__contains__",          ["__trunc__"], false]
    - ["ab2731014", "abc.ABCMeta.__dict__.__contains__",          ["__floor__"], false]
    - ["ab2731015", "abc.ABCMeta.__dict__.__contains__",          ["__ceil__"],  false]
    - ["ab2731016", "abc.abstractproperty.__dict__.__contains__", ["__trunc__"], false]
    - ["ab2731017", "abc.abstractproperty.__dict__.__contains__", ["__floor__"], false]
    - ["ab2731018", "abc.abstractproperty.__dict__.__contains__", ["__ceil__"],  false]
