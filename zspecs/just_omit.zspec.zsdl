spec: just_omit
version: ">=2.2.0"
backend: node(just-omit)

docs: https://www.npmjs.com/package/just-omit

provenance:
  derived_from:
    - "just-omit README — https://www.npmjs.com/package/just-omit"
    - "Test vectors verified with just-omit via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-omit source"
  notes:
    - "just-omit is an npm package. Install: npm install just-omit"
    - "The module exports a single function: omit(obj, keys) returns a new object without the specified keys."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new object with the specified keys removed."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_omit.omit:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: jomit

  columns: [id, args, expected]
  rows:
    - [one_key,   [{"a": 1, "b": 2, "c": 3}, ["b"]],       {"a": 1, "c": 3}]
    - [two_keys,  [{"x": 10, "y": 20, "z": 30}, ["x", "z"]], {"y": 20}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:09:20Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
