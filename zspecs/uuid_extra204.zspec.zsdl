spec: uuid_extra204
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 9562 — Universally Unique IDentifiers (UUID)"
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "All __doc__ contains checks verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.UUID.__doc__ contains 'UUID', 'RFC', 'immutable'."
    - "uuid.uuid1.__doc__ contains 'host' and 'time'."
    - "uuid.uuid3.__doc__ contains 'MD5' and 'namespace'."
    - "uuid.uuid4.__doc__ contains 'random' and 'UUID'."
    - "uuid.uuid5.__doc__ contains 'SHA' and 'namespace'."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID — __doc__ contains checks
#
# uuid.UUID.__doc__ contains 'UUID', 'RFC', 'immutable'
# ---------------------------------------------------------------------------

table uuid_extra204.UUID_doc_contains:
  description: "uuid.UUID __doc__ contains checks in uuiddoc204 namespace — wave 259 theme: uuid.UUID.__doc__.__contains__('UUID')==True; uuid.UUID.__doc__.__contains__('RFC')==True; uuid.UUID.__doc__.__contains__('immutable')==True; uuid.UUID is defined per RFC 4122/9562 and its docstring describes it as an immutable class; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddoc204

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_doc_has_UUID,      UUID.__doc__.__contains__, ["UUID"],      true, "uuid.UUID.__doc__ contains 'UUID'; class name appears in doc; verified with Python 3.14.3"]
    - [UUID_doc_has_RFC,       UUID.__doc__.__contains__, ["RFC"],       true, "uuid.UUID.__doc__ contains 'RFC'; references RFC 4122 specification; verified with Python 3.14.3"]
    - [UUID_doc_has_immutable, UUID.__doc__.__contains__, ["immutable"], true, "uuid.UUID.__doc__ contains 'immutable'; UUID objects are immutable; verified with Python 3.14.3"]
    - [UUID_doc_not_mutable,   UUID.__doc__.__contains__, ["mutable"],   false, "uuid.UUID.__doc__ does not contain 'mutable' (without 'im' prefix); only 'immutable' appears; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid.uuid1 and uuid.uuid3 — __doc__ contains checks
#
# uuid.uuid1.__doc__ contains 'host', 'time'
# uuid.uuid3.__doc__ contains 'MD5', 'namespace'
# ---------------------------------------------------------------------------

table uuid_extra204.uuid1_uuid3_doc_contains:
  description: "uuid.uuid1 and uuid.uuid3 __doc__ contains checks in uuiddoc204a namespace — wave 259 theme: uuid.uuid1.__doc__.__contains__('host')==True (uses host ID); uuid.uuid1.__doc__.__contains__('time')==True (uses current time); uuid.uuid3.__doc__.__contains__('MD5')==True (uses MD5 hash); uuid.uuid3.__doc__.__contains__('namespace')==True (takes namespace UUID); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddoc204a

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_doc_has_host,      uuid1.__doc__.__contains__, ["host"],      true, "uuid.uuid1.__doc__ contains 'host'; UUID generated from host ID; verified with Python 3.14.3"]
    - [uuid1_doc_has_time,      uuid1.__doc__.__contains__, ["time"],      true, "uuid.uuid1.__doc__ contains 'time'; UUID generated using current time; verified with Python 3.14.3"]
    - [uuid3_doc_has_MD5,       uuid3.__doc__.__contains__, ["MD5"],       true, "uuid.uuid3.__doc__ contains 'MD5'; uses MD5 hash for name-based UUID; verified with Python 3.14.3"]
    - [uuid3_doc_has_namespace, uuid3.__doc__.__contains__, ["namespace"], true, "uuid.uuid3.__doc__ contains 'namespace'; takes a namespace UUID input; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid.uuid4 and uuid.uuid5 — __doc__ contains checks
#
# uuid.uuid4.__doc__ contains 'random', 'UUID'
# uuid.uuid5.__doc__ contains 'SHA', 'namespace'
# ---------------------------------------------------------------------------

table uuid_extra204.uuid4_uuid5_doc_contains:
  description: "uuid.uuid4 and uuid.uuid5 __doc__ contains checks in uuiddoc204b namespace — wave 259 theme: uuid.uuid4.__doc__.__contains__('random')==True (generates random UUID); uuid.uuid4.__doc__.__contains__('UUID')==True; uuid.uuid5.__doc__.__contains__('SHA')==True (uses SHA-1 hash); uuid.uuid5.__doc__.__contains__('namespace')==True (takes namespace UUID); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddoc204b

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_doc_has_random,    uuid4.__doc__.__contains__, ["random"],    true, "uuid.uuid4.__doc__ contains 'random'; generates a random UUID; verified with Python 3.14.3"]
    - [uuid4_doc_has_UUID,      uuid4.__doc__.__contains__, ["UUID"],      true, "uuid.uuid4.__doc__ contains 'UUID'; doc reads 'Generate a random UUID'; verified with Python 3.14.3"]
    - [uuid5_doc_has_SHA,       uuid5.__doc__.__contains__, ["SHA"],       true, "uuid.uuid5.__doc__ contains 'SHA'; uses SHA-1 hash; verified with Python 3.14.3"]
    - [uuid5_doc_has_namespace, uuid5.__doc__.__contains__, ["namespace"], true, "uuid.uuid5.__doc__ contains 'namespace'; takes a namespace UUID input; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — uuid_extra204
# ---------------------------------------------------------------------------

invariant uuid_extra204.UUID_doc_contains_UUID:
  description: "uuid.UUID.__doc__.__contains__('UUID') returns True — uuid.UUID's docstring begins 'Instances of the UUID class represent UUIDs as specified in RFC 4122'; the word 'UUID' appears throughout the doc; the class name appears in both the class description and the attribute descriptions; __contains__ is case-sensitive so 'UUID' (all caps) matches the docstring correctly; this is the most fundamental word in the UUID module's primary class documentation; NEW in uuid_extra204: first standalone UUID.__doc__.__contains__('UUID') invariant in uuiddoc204 namespace; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: UUID.__doc__.__contains__
  args: ["UUID"]
  expected: true

invariant uuid_extra204.UUID_doc_contains_RFC:
  description: "uuid.UUID.__doc__.__contains__('RFC') returns True — uuid.UUID's docstring references 'RFC 4122' directly: 'Instances of the UUID class represent UUIDs as specified in RFC 4122'; RFC 4122 is the original UUID specification (superseded by RFC 9562); the presence of 'RFC' in the doc confirms the class is standards-compliant and references its normative specification; compare: uuid.uuid1.__doc__ does not mention RFC directly; NEW in uuid_extra204: first standalone UUID.__doc__.__contains__('RFC') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: UUID.__doc__.__contains__
  args: ["RFC"]
  expected: true

invariant uuid_extra204.UUID_doc_contains_immutable:
  description: "uuid.UUID.__doc__.__contains__('immutable') returns True — uuid.UUID's docstring reads 'UUID objects are immutable, hashable, and usable as dictionary keys'; the word 'immutable' directly describes a key behavioral property of UUID instances; UUID objects cannot be modified after creation; their immutability makes them hashable and safe to use as dict keys; the presence of 'immutable' in the doc is a behavioral contract; compare: uuid.uuid4.__doc__ contains 'random' but not 'immutable'; NEW in uuid_extra204: first standalone UUID.__doc__.__contains__('immutable') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: UUID.__doc__.__contains__
  args: ["immutable"]
  expected: true

invariant uuid_extra204.uuid1_doc_contains_host:
  description: "uuid.uuid1.__doc__.__contains__('host') returns True — uuid.uuid1's docstring reads 'Generate a UUID from a host ID, sequence number, and the current time'; the word 'host' refers to the host ID (typically the MAC address of the network interface); uuid1 generates version-1 time-based UUIDs per RFC 9562 section 5.1; the host ID is used to make UUIDs unique across different machines generated at the same timestamp; NEW in uuid_extra204: first standalone uuid1.__doc__.__contains__('host') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: uuid1.__doc__.__contains__
  args: ["host"]
  expected: true

invariant uuid_extra204.uuid3_doc_contains_MD5:
  description: "uuid.uuid3.__doc__.__contains__('MD5') returns True — uuid.uuid3's docstring reads 'Generate a UUID from the MD5 hash of a namespace UUID and a name'; 'MD5' (all caps) appears explicitly naming the hash algorithm; uuid3 generates version-3 name-based UUIDs per RFC 9562 section 5.3; it computes MD5(namespace_bytes + name_bytes) and sets the UUID version to 3; __contains__ is case-sensitive so 'MD5' (all caps) must be used; 'md5' (lowercase) would return False; compare: uuid5 uses SHA-1 instead; NEW in uuid_extra204: first standalone uuid3.__doc__.__contains__('MD5') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: uuid3.__doc__.__contains__
  args: ["MD5"]
  expected: true

invariant uuid_extra204.uuid4_doc_contains_random:
  description: "uuid.uuid4.__doc__.__contains__('random') returns True — uuid.uuid4's docstring reads 'Generate a random UUID'; the word 'random' is the defining characteristic of version-4 UUIDs per RFC 9562 section 5.4; uuid4 uses os.urandom(16) to generate 16 cryptographically random bytes then sets the version (4) and variant bits; it requires no namespace, name, or host ID — only randomness; the entire docstring is only 3 words so 'random' appears in 1 of 3 words; NEW in uuid_extra204: first standalone uuid4.__doc__.__contains__('random') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: uuid4.__doc__.__contains__
  args: ["random"]
  expected: true

invariant uuid_extra204.uuid5_doc_contains_SHA:
  description: "uuid.uuid5.__doc__.__contains__('SHA') returns True — uuid.uuid5's docstring reads 'Generate a UUID from the SHA-1 hash of a namespace UUID and a name'; 'SHA' appears as part of 'SHA-1' naming the hash algorithm; uuid5 generates version-5 name-based UUIDs per RFC 9562 section 5.5; it uses SHA-1 instead of MD5 (as in uuid3) because SHA-1 is cryptographically stronger; RFC 9562 section 6.5 recommends uuid5 over uuid3 for new applications; __contains__ matches 'SHA' within 'SHA-1'; NEW in uuid_extra204: first standalone uuid5.__doc__.__contains__('SHA') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: uuid5.__doc__.__contains__
  args: ["SHA"]
  expected: true

invariant uuid_extra204.uuid5_doc_contains_namespace:
  description: "uuid.uuid5.__doc__.__contains__('namespace') returns True — uuid.uuid5's docstring reads 'Generate a UUID from the SHA-1 hash of a namespace UUID and a name'; the word 'namespace' refers to the first argument, which is a UUID serving as a namespace identifier; standard namespace UUIDs are defined in RFC 9562: NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500; the namespace UUID combined with the name string uniquely identifies a UUID in a deterministic way; the same namespace+name always produces the same uuid5; compare: uuid3 also uses 'namespace' in its doc; NEW in uuid_extra204: first standalone uuid5.__doc__.__contains__('namespace') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: uuid5.__doc__.__contains__
  args: ["namespace"]
  expected: true

