spec: threading_extra246
version: ">=3.0"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra245.zspec.zsdl — covers Barrier class identity and method names"
    - "threading_extra244.zspec.zsdl — covers TIMEOUT_MAX and local class identity"
    - "threading_extra243.zspec.zsdl — covers current_thread, active_count, enumerate function identity"
    - "threading_extra.zspec.zsdl — covers module checks for synchronization primitives"
    - "threading.zspec.zsdl — covers class __name__ checks and function names"
  notes:
    - "This spec covers threading.Thread daemon and ident property identity contracts."
    - "threading.Thread.daemon.__class__.__name__ == 'property' — daemon is a property descriptor on Thread. Verified with Python 3.14.3."
    - "threading.Thread.daemon.__class__.__module__ == 'builtins' — property is defined in the builtins module. Verified with Python 3.14.3."
    - "threading.Thread.daemon.fget.__name__ == 'daemon' — the fget function for daemon is named 'daemon'. Verified with Python 3.14.3."
    - "threading.Thread.daemon.fget.__qualname__ == 'Thread.daemon' (len=13) — qualname includes the class name. Verified with Python 3.14.3."
    - "threading.Thread.daemon.fget.__module__ == 'threading' — fget is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Thread.daemon.fset.__name__ == 'daemon' — the fset function for daemon is also named 'daemon'. Verified with Python 3.14.3."
    - "threading.Thread.daemon.fset.__qualname__ == 'Thread.daemon' (len=13) — qualname includes the class name. Verified with Python 3.14.3."
    - "threading.Thread.ident.__class__.__name__ == 'property' — ident is a property descriptor on Thread. Verified with Python 3.14.3."
    - "threading.Thread.ident.fget.__name__ == 'ident' — the fget function for ident is named 'ident'. Verified with Python 3.14.3."
    - "threading.Thread.ident.fget.__qualname__ == 'Thread.ident' (len=12) — qualname includes the class name. Verified with Python 3.14.3."
    - "threading.Thread.ident.fget.__module__ == 'threading' — fget is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread.daemon property identity contracts
#
# threading.Thread.daemon.__class__.__name__ == 'property'
# threading.Thread.daemon.__class__.__module__ == 'builtins'
# threading.Thread.daemon.fget.__name__ == 'daemon' (len=6)
# threading.Thread.daemon.fget.__qualname__ == 'Thread.daemon' (len=13)
# threading.Thread.daemon.fget.__module__ == 'threading'
#
# daemon is a property descriptor on Thread in Lib/threading.py. New to extra246.
# ---------------------------------------------------------------------------

table threading_extra246.thr246prop_daemon_identity:
  description: "threading.Thread.daemon property identity: class, fget name, qualname, module; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: thr246prop

  columns: [id, function, args, expected, description]
  rows:
    - [daemon_class_is_property,
       Thread.daemon.__class__.__name__.__eq__,
       ["property"],
       true,
       "threading.Thread.daemon.__class__.__name__.__eq__('property') == True — daemon is a property descriptor on Thread; __class__.__name__ is 'property'; new to extra246"]
    - [daemon_class_module_builtins,
       Thread.daemon.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "threading.Thread.daemon.__class__.__module__.__eq__('builtins') == True — property is defined in the builtins module; new to extra246"]
    - [daemon_fget_name_eq,
       Thread.daemon.fget.__name__.__eq__,
       ["daemon"],
       true,
       "threading.Thread.daemon.fget.__name__.__eq__('daemon') == True — the fget function for the daemon property is named 'daemon' (len=6); new to extra246"]
    - [daemon_fget_qualname_eq,
       Thread.daemon.fget.__qualname__.__eq__,
       ["Thread.daemon"],
       true,
       "threading.Thread.daemon.fget.__qualname__.__eq__('Thread.daemon') == True — fget __qualname__ is 'Thread.daemon' (len=13); includes the class name; new to extra246"]
    - [daemon_fget_module_eq,
       Thread.daemon.fget.__module__.__eq__,
       ["threading"],
       true,
       "threading.Thread.daemon.fget.__module__.__eq__('threading') == True — fget is defined in Lib/threading.py; __module__ is 'threading'; new to extra246"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread.daemon fget/fset lengths and class checks
#
# threading.Thread.daemon.fget.__name__.__len__() == 6
# threading.Thread.daemon.fget.__qualname__.__len__() == 13
# threading.Thread.daemon.fget.__class__.__name__ == 'function'
# threading.Thread.daemon.fset.__name__ == 'daemon' (len=6)
# threading.Thread.daemon.fset.__qualname__ == 'Thread.daemon' (len=13)
#
# New to extra246.
# ---------------------------------------------------------------------------

table threading_extra246.thr246prop_daemon_extra:
  description: "threading.Thread.daemon fget/fset name lengths and fset identity; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: thr246propb

  columns: [id, function, args, expected, description]
  rows:
    - [daemon_fget_name_len_6,
       Thread.daemon.fget.__name__.__len__,
       [],
       6,
       "threading.Thread.daemon.fget.__name__.__len__() == 6 — 'daemon' has exactly 6 characters; str.__len__() returns 6; new to extra246"]
    - [daemon_fget_qualname_len_13,
       Thread.daemon.fget.__qualname__.__len__,
       [],
       13,
       "threading.Thread.daemon.fget.__qualname__.__len__() == 13 — 'Thread.daemon' has exactly 13 characters; str.__len__() returns 13; new to extra246"]
    - [daemon_fget_class_is_function,
       Thread.daemon.fget.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Thread.daemon.fget.__class__.__name__.__eq__('function') == True — fget is a plain Python function; __class__.__name__ is 'function'; new to extra246"]
    - [daemon_fset_name_eq,
       Thread.daemon.fset.__name__.__eq__,
       ["daemon"],
       true,
       "threading.Thread.daemon.fset.__name__.__eq__('daemon') == True — the fset function for the daemon property is also named 'daemon' (len=6); new to extra246"]
    - [daemon_fset_qualname_eq,
       Thread.daemon.fset.__qualname__.__eq__,
       ["Thread.daemon"],
       true,
       "threading.Thread.daemon.fset.__qualname__.__eq__('Thread.daemon') == True — fset __qualname__ is 'Thread.daemon' (len=13); same qualified name as fget; new to extra246"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread.ident property identity contracts
#
# threading.Thread.ident.__class__.__name__ == 'property'
# threading.Thread.ident.fget.__name__ == 'ident' (len=5)
# threading.Thread.ident.fget.__qualname__ == 'Thread.ident' (len=12)
# threading.Thread.ident.fget.__module__ == 'threading'
# threading.Thread.ident.fget.__class__.__name__ == 'function'
#
# ident is a read-only property descriptor on Thread (no fset). New to extra246.
# ---------------------------------------------------------------------------

table threading_extra246.thr246prop_ident_identity:
  description: "threading.Thread.ident property identity: class, fget name, qualname, module; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: thr246propc

  columns: [id, function, args, expected, description]
  rows:
    - [ident_class_is_property,
       Thread.ident.__class__.__name__.__eq__,
       ["property"],
       true,
       "threading.Thread.ident.__class__.__name__.__eq__('property') == True — ident is a property descriptor on Thread; __class__.__name__ is 'property'; new to extra246"]
    - [ident_fget_name_eq,
       Thread.ident.fget.__name__.__eq__,
       ["ident"],
       true,
       "threading.Thread.ident.fget.__name__.__eq__('ident') == True — the fget function for the ident property is named 'ident' (len=5); new to extra246"]
    - [ident_fget_qualname_eq,
       Thread.ident.fget.__qualname__.__eq__,
       ["Thread.ident"],
       true,
       "threading.Thread.ident.fget.__qualname__.__eq__('Thread.ident') == True — fget __qualname__ is 'Thread.ident' (len=12); includes the class name; new to extra246"]
    - [ident_fget_module_eq,
       Thread.ident.fget.__module__.__eq__,
       ["threading"],
       true,
       "threading.Thread.ident.fget.__module__.__eq__('threading') == True — fget is defined in Lib/threading.py; __module__ is 'threading'; new to extra246"]
    - [ident_fget_class_is_function,
       Thread.ident.fget.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Thread.ident.fget.__class__.__name__.__eq__('function') == True — fget is a plain Python function; __class__.__name__ is 'function'; new to extra246"]

# ---------------------------------------------------------------------------
# Table 4: threading.Thread.ident fget lengths and content checks
#
# threading.Thread.ident.fget.__name__.__len__() == 5
# threading.Thread.ident.fget.__qualname__.__len__() == 12
# threading.Thread.ident.fget.__name__.__contains__('ident') == True
# threading.Thread.daemon.fget.__qualname__.__contains__('Thread') == True
# threading.Thread.ident.fget.__qualname__.__contains__('Thread') == True
#
# New to extra246.
# ---------------------------------------------------------------------------

table threading_extra246.thr246prop_ident_extra:
  description: "threading.Thread.ident fget name lengths and content checks; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: thr246propd

  columns: [id, function, args, expected, description]
  rows:
    - [ident_fget_name_len_5,
       Thread.ident.fget.__name__.__len__,
       [],
       5,
       "threading.Thread.ident.fget.__name__.__len__() == 5 — 'ident' has exactly 5 characters; str.__len__() returns 5; new to extra246"]
    - [ident_fget_qualname_len_12,
       Thread.ident.fget.__qualname__.__len__,
       [],
       12,
       "threading.Thread.ident.fget.__qualname__.__len__() == 12 — 'Thread.ident' has exactly 12 characters; str.__len__() returns 12; new to extra246"]
    - [ident_fget_name_contains_ident,
       Thread.ident.fget.__name__.__contains__,
       ["ident"],
       true,
       "threading.Thread.ident.fget.__name__.__contains__('ident') == True — 'ident' contains 'ident'; new to extra246"]
    - [daemon_fget_qualname_contains_thread,
       Thread.daemon.fget.__qualname__.__contains__,
       ["Thread"],
       true,
       "threading.Thread.daemon.fget.__qualname__.__contains__('Thread') == True — 'Thread.daemon' contains 'Thread'; confirms the property fget is scoped to Thread; new to extra246"]
    - [ident_fget_qualname_contains_thread,
       Thread.ident.fget.__qualname__.__contains__,
       ["Thread"],
       true,
       "threading.Thread.ident.fget.__qualname__.__contains__('Thread') == True — 'Thread.ident' contains 'Thread'; confirms the property fget is scoped to Thread; new to extra246"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra246
# ---------------------------------------------------------------------------

invariant threading_extra246.daemon_class_is_property:
  description: "threading.Thread.daemon.__class__.__name__ == 'property'; new to extra246"
  kind: python_call_eq
  function: Thread.daemon.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra246.daemon_fget_name_eq:
  description: "threading.Thread.daemon.fget.__name__ == 'daemon' (len=6); new to extra246"
  kind: python_call_eq
  function: Thread.daemon.fget.__name__.__eq__
  args: ["daemon"]
  expected: true

invariant threading_extra246.daemon_fget_qualname_eq:
  description: "threading.Thread.daemon.fget.__qualname__ == 'Thread.daemon' (len=13); new to extra246"
  kind: python_call_eq
  function: Thread.daemon.fget.__qualname__.__eq__
  args: ["Thread.daemon"]
  expected: true

invariant threading_extra246.daemon_fget_module_eq:
  description: "threading.Thread.daemon.fget.__module__ == 'threading' — defined in Lib/threading.py; new to extra246"
  kind: python_call_eq
  function: Thread.daemon.fget.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra246.daemon_fget_name_len_6:
  description: "threading.Thread.daemon.fget.__name__.__len__() == 6; new to extra246"
  kind: python_call_eq
  function: Thread.daemon.fget.__name__.__len__
  args: []
  expected: 6

invariant threading_extra246.daemon_fset_name_eq:
  description: "threading.Thread.daemon.fset.__name__ == 'daemon' (len=6); new to extra246"
  kind: python_call_eq
  function: Thread.daemon.fset.__name__.__eq__
  args: ["daemon"]
  expected: true

invariant threading_extra246.ident_class_is_property:
  description: "threading.Thread.ident.__class__.__name__ == 'property'; new to extra246"
  kind: python_call_eq
  function: Thread.ident.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra246.ident_fget_name_eq:
  description: "threading.Thread.ident.fget.__name__ == 'ident' (len=5); new to extra246"
  kind: python_call_eq
  function: Thread.ident.fget.__name__.__eq__
  args: ["ident"]
  expected: true

invariant threading_extra246.ident_fget_qualname_eq:
  description: "threading.Thread.ident.fget.__qualname__ == 'Thread.ident' (len=12); new to extra246"
  kind: python_call_eq
  function: Thread.ident.fget.__qualname__.__eq__
  args: ["Thread.ident"]
  expected: true

invariant threading_extra246.ident_fget_module_eq:
  description: "threading.Thread.ident.fget.__module__ == 'threading' — defined in Lib/threading.py; new to extra246"
  kind: python_call_eq
  function: Thread.ident.fget.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra246.ident_fget_name_len_5:
  description: "threading.Thread.ident.fget.__name__.__len__() == 5; new to extra246"
  kind: python_call_eq
  function: Thread.ident.fget.__name__.__len__
  args: []
  expected: 5

invariant threading_extra246.ident_fget_qualname_len_12:
  description: "threading.Thread.ident.fget.__qualname__.__len__() == 12; new to extra246"
