spec: heapq_extra22
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
  notes:
    - "This spec extends heapq_extra21.zspec.zsdl."
    - "Prior specs covered: heapq.__name__/__package__, heappush/heappop/heapify/heapreplace/heappushpop/nlargest/nsmallest/merge __name__/__module__, name length table, heapq.__all__ type/length/element type, various __qualname__ checks, __qualname__.__eq__ table (extra21), __module__.__len__() for heappush/heappop/heapify/merge (extra21)."
    - "This spec covers: __name__.__len__() table for all 8 heapq callables; __module__.__len__() for heapreplace, heappushpop, nlargest, nsmallest standalone; __qualname__.__len__() table for C builtins vs pure-Python; module string cross-check (C builtins have len 6, pure-Python have len 5)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "heapq.heappush.__name__.__len__() == 8. Verified."
    - "heapq.heappop.__name__.__len__() == 7. Verified."
    - "heapq.heapify.__name__.__len__() == 7. Verified."
    - "heapq.heapreplace.__name__.__len__() == 11. Verified."
    - "heapq.heappushpop.__name__.__len__() == 11. Verified."
    - "heapq.nlargest.__name__.__len__() == 8. Verified."
    - "heapq.nsmallest.__name__.__len__() == 9. Verified."
    - "heapq.merge.__name__.__len__() == 5. Verified."
    - "heapq.heapreplace.__module__.__len__() == 6 (C builtin from _heapq). Verified."
    - "heapq.heappushpop.__module__.__len__() == 6 (C builtin from _heapq). Verified."
    - "heapq.nlargest.__module__.__len__() == 5 (pure Python from heapq). Verified."
    - "heapq.nsmallest.__module__.__len__() == 5 (pure Python from heapq). Verified."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() for all 8 heapq callables — extra22 namespace
#
# C builtins (heappush=8, heappop=7, heapify=7, heapreplace=11, heappushpop=11)
# and pure-Python (nlargest=8, nsmallest=9, merge=5). No prior heapq spec
# collects all 8 __name__.__len__() values in a single table in the extra22
# namespace. id_prefix hqnl22 is novel.
# ---------------------------------------------------------------------------

table heapq_extra22.name_lens:
  description: "__name__.__len__() for all 8 heapq callables — C builtins and pure-Python functions"
  kind: python_call_eq
  category: function_name
  id_prefix: hqnl22

  columns: [id, function, method, method_args, expected]
  rows:
    - [heappush_nl,    heappush.__name__,    __len__, [], 8]
    - [heappop_nl,     heappop.__name__,     __len__, [], 7]
    - [heapify_nl,     heapify.__name__,     __len__, [], 7]
    - [heapreplace_nl, heapreplace.__name__, __len__, [], 11]
    - [heappushpop_nl, heappushpop.__name__, __len__, [], 11]
    - [nlargest_nl,    nlargest.__name__,    __len__, [], 8]
    - [nsmallest_nl,   nsmallest.__name__,   __len__, [], 9]
    - [merge_nl,       merge.__name__,       __len__, [], 5]

# ---------------------------------------------------------------------------
# __module__.__len__() cross-check — C builtins (len 6) vs pure-Python (len 5)
#
# All 5 C builtins imported from _heapq have __module__ == '_heapq' (len 6).
# All 3 pure-Python callables defined in Lib/heapq.py have __module__ == 'heapq'
# (len 5). The one-character difference (the leading underscore) is a reliable
# indicator of C extension vs pure-Python origin. heapq_extra21 covers
# heappush/heappop/heapify/merge in that namespace; this table adds heapreplace,
# heappushpop, nlargest, nsmallest and re-anchors all 8 in extra22. id_prefix
# hqml22 is novel.
# ---------------------------------------------------------------------------

table heapq_extra22.module_lens:
  description: "__module__.__len__() for all 8 heapq callables — C builtins report 6 (_heapq), pure Python report 5 (heapq)"
  kind: python_call_eq
  category: function_module
  id_prefix: hqml22

  columns: [id, function, method, method_args, expected]
  rows:
    - [heappush_ml,    heappush.__module__,    __len__, [], 6]
    - [heappop_ml,     heappop.__module__,     __len__, [], 6]
    - [heapify_ml,     heapify.__module__,     __len__, [], 6]
    - [heapreplace_ml, heapreplace.__module__, __len__, [], 6]
    - [heappushpop_ml, heappushpop.__module__, __len__, [], 6]
    - [nlargest_ml,    nlargest.__module__,    __len__, [], 5]
    - [nsmallest_ml,   nsmallest.__module__,   __len__, [], 5]
    - [merge_ml,       merge.__module__,       __len__, [], 5]

# ---------------------------------------------------------------------------
# heapq.heapreplace.__module__.__len__() — standalone, extra22 namespace
#
# heapreplace is a C builtin from _heapq. Its __module__ == '_heapq' (len 6).
# heapq_extra21 covers heappush/heappop/heapify/merge as standalone invariants;
# this fills the heapreplace gap in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant heapq_extra22.heapreplace.module_len:
  description: "heapq.heapreplace.__module__.__len__() == 6 — len('_heapq') == 6; C builtin"
  category: function_module
  kind: python_call_eq
  function: heapreplace.__module__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# heapq.heappushpop.__module__.__len__() — standalone, extra22 namespace
#
# heappushpop is a C builtin from _heapq. Its __module__ == '_heapq' (len 6).
# Separate standalone invariant for heappushpop confirming the same C extension
# origin as heapreplace.
# ---------------------------------------------------------------------------

invariant heapq_extra22.heappushpop.module_len:
  description: "heapq.heappushpop.__module__.__len__() == 6 — len('_heapq') == 6; C builtin"
  category: function_module
  kind: python_call_eq
  function: heappushpop.__module__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# heapq.nlargest.__module__.__len__() — standalone, extra22 namespace
#
# nlargest is a pure-Python function defined in Lib/heapq.py. Its __module__
# == 'heapq' (len 5). This contrasts with the C builtins above (len 6).
# heapq_extra21 covers merge.__module__.__len__() as the pure-Python
# representative; nlargest provides a second pure-Python anchor in extra22.
# ---------------------------------------------------------------------------

invariant heapq_extra22.nlargest.module_len:
  description: "heapq.nlargest.__module__.__len__() == 5 — len('heapq') == 5; pure-Python unlike C builtins"
  category: function_module
  kind: python_call_eq
  function: nlargest.__module__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# heapq.nsmallest.__module__.__len__() — standalone, extra22 namespace
#
# nsmallest is also a pure-Python function from Lib/heapq.py. Its __module__
# == 'heapq' (len 5). Standalone invariant for nsmallest mirrors nlargest
# above and confirms the symmetry of the two selection functions.
# ---------------------------------------------------------------------------

invariant heapq_extra22.nsmallest.module_len:
  description: "heapq.nsmallest.__module__.__len__() == 5 — len('heapq') == 5; pure-Python unlike C builtins"
  category: function_module
  kind: python_call_eq
  function: nsmallest.__module__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# heapq.heapreplace.__name__.__len__() — length of 'heapreplace' (11 chars)
#
# heapreplace.__name__ == 'heapreplace'; len == 11. Among heapq functions this
# ties with heappushpop for the longest name. No prior heapq spec checks
# __name__.__len__() for heapreplace as a standalone invariant in extra22.
# ---------------------------------------------------------------------------

invariant heapq_extra22.heapreplace.name_len:
  description: "heapq.heapreplace.__name__.__len__() == 11 — len('heapreplace') == 11"
  category: function_name
  kind: python_call_eq
  function: heapreplace.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# heapq.heappushpop.__name__.__len__() — length of 'heappushpop' (11 chars)
#
# heappushpop.__name__ == 'heappushpop'; len == 11. Ties with heapreplace for
# the longest heapq function name. Standalone invariant in extra22 namespace.
# ---------------------------------------------------------------------------

invariant heapq_extra22.heappushpop.name_len:
  description: "heapq.heappushpop.__name__.__len__() == 11 — len('heappushpop') == 11"
  category: function_name
  kind: python_call_eq
  function: heappushpop.__name__.__len__
  args: []
  expected: 11
