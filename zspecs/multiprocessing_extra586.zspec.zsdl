spec: multiprocessing_extra586
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Process method qualname and module identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__ and __module__ identity for multiprocessing.Process and related classes"
  created_at: "2026-04-12T00:00:00Z"

table mp_process_method_qualname:
  description: "__qualname__ identity for multiprocessing.Process methods"
  columns: [id, function, args, expected]
  rows:
    - [mp586qn01, multiprocessing.Process.__init__.__qualname__.__eq__, ["Process.__init__"], true]
    - [mp586qn02, multiprocessing.Process.__repr__.__qualname__.__eq__, ["Process.__repr__"], true]
    - [mp586qn03, multiprocessing.Process.start.__qualname__.__eq__, ["Process.start"], true]
    - [mp586qn04, multiprocessing.Process.run.__qualname__.__eq__, ["Process.run"], true]
    - [mp586qn05, multiprocessing.Process.join.__qualname__.__eq__, ["Process.join"], true]
    - [mp586qn06, multiprocessing.Process.terminate.__qualname__.__eq__, ["Process.terminate"], true]
    - [mp586qn07, multiprocessing.Process.kill.__qualname__.__eq__, ["Process.kill"], true]
    - [mp586qn08, multiprocessing.Process.is_alive.__qualname__.__eq__, ["Process.is_alive"], true]

table mp_class_module:
  description: "__module__ identity for multiprocessing classes and exceptions"
  columns: [id, function, args, expected]
  rows:
    - [mp586md01, multiprocessing.Process.__module__.__eq__, ["multiprocessing.process"], true]
    - [mp586md02, multiprocessing.Queue.__module__.__eq__, ["multiprocessing.queues"], true]
    - [mp586md03, multiprocessing.AuthenticationError.__module__.__eq__, ["multiprocessing.context"], true]
    - [mp586md04, multiprocessing.ProcessError.__module__.__eq__, ["multiprocessing.context"], true]
