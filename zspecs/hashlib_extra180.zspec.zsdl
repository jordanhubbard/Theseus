spec: hashlib_extra180
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 7693 — The BLAKE2 Cryptographic Hash and Message Authentication Code (MAC)"
  - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "RFC 7693 — The BLAKE2 Cryptographic Hash and Message Authentication Code (MAC)"
    - "FIPS 202 — SHA-3 Standard, NIST, August 2015"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/_sha512module.c"
    - "CPython source: Modules/md5module.c"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "CPython source: Modules/_sha3/sha3module.c"
  notes:
    - "This spec covers: block_size attributes for md5, sha1, sha224, sha256, sha384, sha512, sha3_256, sha3_512, blake2b, blake2s."
    - "block_size is the internal compression block size in bytes, distinct from digest_size."
    - "MD5 and SHA-1 block_size == 64 (512-bit Merkle–Damgård blocks, RFC 1321 / FIPS 180-4)."
    - "SHA-224 and SHA-256 share the same 512-bit (64-byte) block size (FIPS 180-4 Section 1)."
    - "SHA-384 and SHA-512 share the 1024-bit (128-byte) block size (FIPS 180-4 Section 1)."
    - "SHA3-256 block_size == 136: rate = 1600 - 2*256 = 1088 bits = 136 bytes (FIPS 202)."
    - "SHA3-512 block_size == 72: rate = 1600 - 2*512 = 576 bits = 72 bytes (FIPS 202)."
    - "BLAKE2b block_size == 128 (1024-bit internal block, RFC 7693 Section 2.1)."
    - "BLAKE2s block_size == 64 (512-bit internal block, RFC 7693 Section 2.1)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# block_size: MD5, SHA-1, SHA-224, SHA-256 (all 64-byte Merkle-Damgard blocks)
# ---------------------------------------------------------------------------

table hashlib_extra180.block_size.md_family:
  description: "MD5, SHA-1, SHA-224, SHA-256 all use 512-bit (64-byte) compression blocks"
  kind: python_call_eq
  category: properties
  id_prefix: hashlibblock180

  columns: [id, function, args, expected, description]
  rows:
    - [md5_bs,    md5.__call__().block_size.__eq__,    [64],  true, "hashlib.md5().block_size == 64 (FIPS 180-4 / RFC 1321)"]
    - [sha1_bs,   sha1.__call__().block_size.__eq__,   [64],  true, "hashlib.sha1().block_size == 64 (FIPS 180-4)"]
    - [sha224_bs, sha224.__call__().block_size.__eq__, [64],  true, "hashlib.sha224().block_size == 64 (FIPS 180-4)"]
    - [sha256_bs, sha256.__call__().block_size.__eq__, [64],  true, "hashlib.sha256().block_size == 64 (FIPS 180-4)"]

# ---------------------------------------------------------------------------
# block_size: SHA-384, SHA-512 (128-byte / 1024-bit blocks)
# ---------------------------------------------------------------------------

table hashlib_extra180.block_size.sha512_family:
  description: "SHA-384 and SHA-512 use 1024-bit (128-byte) compression blocks"
  kind: python_call_eq
  category: properties
  id_prefix: hashlibblock180

  columns: [id, function, args, expected, description]
  rows:
    - [sha384_bs, sha384.__call__().block_size.__eq__, [128], true, "hashlib.sha384().block_size == 128 (FIPS 180-4)"]
    - [sha512_bs, sha512.__call__().block_size.__eq__, [128], true, "hashlib.sha512().block_size == 128 (FIPS 180-4)"]

# ---------------------------------------------------------------------------
# block_size: SHA-3 family (sponge rate in bytes)
# ---------------------------------------------------------------------------

table hashlib_extra180.block_size.sha3_family:
  description: "SHA-3 block_size equals the sponge rate (FIPS 202): sha3_256=136, sha3_512=72"
  kind: python_call_eq
  category: properties
  id_prefix: hashlibblock180

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_bs, sha3_256.__call__().block_size.__eq__, [136], true, "hashlib.sha3_256().block_size == 136 (rate=1600-2*256 bits / 8, FIPS 202)"]
    - [sha3_512_bs, sha3_512.__call__().block_size.__eq__, [72],  true, "hashlib.sha3_512().block_size == 72 (rate=1600-2*512 bits / 8, FIPS 202)"]

# ---------------------------------------------------------------------------
# Standalone invariants — blake2b and blake2s block_size; cross-checks
# ---------------------------------------------------------------------------

invariant hashlib_extra180.blake2b.block_size:
  description: "hashlib.blake2b().block_size == 128 (1024-bit internal block, RFC 7693 Section 2.1)"
  category: properties
  kind: python_call_eq
  function: blake2b
  args: []
  method: block_size.__eq__
  method_args: [128]
  expected: true

invariant hashlib_extra180.blake2s.block_size:
  description: "hashlib.blake2s().block_size == 64 (512-bit internal block, RFC 7693 Section 2.1)"
  category: properties
  kind: python_call_eq
  function: blake2s
  args: []
  method: block_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra180.sha3_256.block_size_not_sha256:
  description: "sha3_256 block_size (136) differs from sha256 block_size (64) — sponge rate != Merkle-Damgard block"
  category: properties
  kind: python_call_eq
  function: sha3_256
  args: []
  method: block_size.__eq__
  method_args: [136]
  expected: true

invariant hashlib_extra180.sha3_512.block_size_lt_sha512:
  description: "sha3_512 block_size (72) is less than sha512 block_size (128) — sponge rate shrinks with larger capacity"
  category: properties
  kind: python_call_eq
  function: sha3_512
  args: []
  method: block_size.__eq__
  method_args: [72]
  expected: true

invariant hashlib_extra180.sha256.block_size_eq_md5:
  description: "sha256 block_size (64) equals md5 block_size (64) — both use 512-bit Merkle-Damgard compression"
  category: properties
  kind: python_call_eq
  function: sha256
  args: []
  method: block_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra180.blake2b.block_size_eq_sha384:
  description: "blake2b block_size (128) equals sha384/sha512 block_size (128) — same 1024-bit block width"
  category: properties
  kind: python_call_eq
  function: blake2b
  args: []
  method: block_size.__eq__
  method_args: [128]
  expected: true

