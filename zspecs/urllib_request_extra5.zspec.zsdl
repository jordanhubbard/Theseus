spec: urllib_request_extra5
version: ">=3.0"
backend: python_module(urllib.request)

docs: https://docs.python.org/3/library/urllib.request.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.request.html — Python urllib.request module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/request.py"
  notes:
    - "This spec extends urllib_request.zspec.zsdl through urllib_request_extra4.zspec.zsdl."
    - "urllib_request.zspec.zsdl covers: class_names table, function_names table, Request construction (type/host/full_url/get_method), pathname2url, URLError reason, HTTPError code/msg."
    - "urllib_request_extra.zspec.zsdl covers: urlretrieve/__name__, url2pathname/__name__, pathname2url/__name__, urlopen/__name__, Request/__name__, HTTPError/__name__, URLError/__name__, Request/__module__, URLError/__module__, HTTPError/__module__, HTTPError.__bases__[0].__name__."
    - "urllib_request_extra2.zspec.zsdl covers: function __qualname__ table (urlopen/build_opener/install_opener/urlretrieve), class __qualname__ table (Request/BaseHandler/HTTPHandler/FileHandler/OpenerDirector), urlopen/urlretrieve/build_opener __module__."
    - "urllib_request_extra3.zspec.zsdl covers: HTTPDefaultErrorHandler/__qualname__, HTTPRedirectHandler/__qualname__, url2pathname/__qualname__, pathname2url/__qualname__, class __module__ table, install_opener/__module__, HTTPRedirectHandler base, Request.selector, url2pathname round-trip."
    - "urllib_request_extra4.zspec.zsdl covers: Request.get_method() POST/PUT, Request.get_header(), HTTPHandler/FileHandler/AbstractHTTPHandler/OpenerDirector/Request base classes, AbstractHTTPHandler __name__/__module__/__qualname__, Request.type for https."
    - "Focus: __qualname__ for Request instance methods — a new axis not in any prior urllib.request spec."
    - "Request.add_header.__qualname__ == 'Request.add_header' — method qualname includes class name."
    - "Request.get_header.__qualname__ == 'Request.get_header' — method qualname includes class name."
    - "Request.get_method.__qualname__ == 'Request.get_method' — method qualname includes class name."
    - "Request.has_header.__qualname__ == 'Request.has_header' — method qualname includes class name."
    - "Request.__class__.__name__ == 'type' — Request is a class object."
    - "OpenerDirector.__class__.__name__ == 'type' — OpenerDirector is a class object."
    - "BaseHandler.__class__.__name__ == 'type' — BaseHandler is a class object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Request instance method __qualname__ — class.method pattern
#
# No prior urllib.request spec checks __qualname__ for Request instance methods.
# For methods defined inside a class, __qualname__ == 'ClassName.method_name'.
# urllib_request_extra2 covers class-level __qualname__ (Request.__qualname__);
# these are method-level qualnames, which are a distinct new axis.
# Verified at runtime with Python 3.12.
# ---------------------------------------------------------------------------

table urllib_request_extra5.Request_method_qualnames:
  description: "__qualname__ for Request instance methods"
  kind: python_call_eq
  category: qualnames
  id_prefix: reqmq

  columns: [id, function, args, expected]
  rows:
    - [add_header,  Request.add_header.__qualname__.__eq__,  ["Request.add_header"],  true]
    - [get_header,  Request.get_header.__qualname__.__eq__,  ["Request.get_header"],  true]
    - [get_method,  Request.get_method.__qualname__.__eq__,  ["Request.get_method"],  true]
    - [has_header,  Request.has_header.__qualname__.__eq__,  ["Request.has_header"],  true]

# ---------------------------------------------------------------------------
# Class identity — __class__.__name__ for key urllib.request classes
#
# urllib_request_extra4 checks AbstractHTTPHandler identity.
# No prior spec checks Request.__class__.__name__, OpenerDirector.__class__.__name__,
# or BaseHandler.__class__.__name__ in the urllib_request_extra namespace.
# Verified at runtime: all three are plain type objects.
# ---------------------------------------------------------------------------

table urllib_request_extra5.class_identity:
  description: "__class__.__name__ == 'type' for Request, OpenerDirector, BaseHandler"
  kind: python_call_eq
  category: class_type
  id_prefix: clsid

  columns: [id, function, args, expected]
  rows:
    - [Request,         Request.__class__.__name__.__eq__,         ["type"], true]
    - [OpenerDirector,  OpenerDirector.__class__.__name__.__eq__,  ["type"], true]
    - [BaseHandler,     BaseHandler.__class__.__name__.__eq__,     ["type"], true]

# ---------------------------------------------------------------------------
# Function identity — __class__.__name__ for urlopen and urlretrieve
#
# urllib_request_extra2 covers urlopen/urlretrieve __qualname__ and __module__.
# No prior spec checks their __class__.__name__ (== 'function').
# Verified at runtime: both are plain Python functions.
# ---------------------------------------------------------------------------

invariant urllib_request_extra5.urlopen.class_name:
  description: "urllib.request.urlopen.__class__.__name__ == 'function'"
  category: function_type
  kind: python_call_eq
  function: urlopen.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant urllib_request_extra5.urlretrieve.class_name:
  description: "urllib.request.urlretrieve.__class__.__name__ == 'function'"
  category: function_type
  kind: python_call_eq
  function: urlretrieve.__class__.__name__.__eq__
  args: ["function"]
  expected: true
