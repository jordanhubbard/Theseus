spec: re_extra2806
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers existing re invariants"
    - "re_extra2791.zspec.zsdl — covers __iand__/__ior__/__ixor__ dict-presence"
    - "re_extra2776.zspec.zsdl — covers __isub__/__imul__/__itruediv__ dict-presence"
    - "re_extra2761.zspec.zsdl — covers __matmul__/__truediv__/__iadd__ dict-presence"
    - "re_extra2746.zspec.zsdl — covers __round__/__divmod__/__pow__ dict-presence"
    - "re_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
  notes:
    - "Wave 634 (re_extra2806) theme: __ilshift__, __irshift__, and __ipow__ dict-presence checks."
    - "Neither re.Pattern nor re.Match defines __ilshift__, __irshift__, or __ipow__ in its own __dict__."
    - "__ilshift__ supports the <<= operator; regex objects are pattern-matching types, not integer or numeric types."
    - "__irshift__ supports the >>= operator; regex objects do not implement in-place right-shift semantics."
    - "__ipow__ supports the **= operator; regex objects do not implement in-place exponentiation semantics."
    - "Covers re.Pattern (type(re.compile(''))) and re.Match (type(re.match('', '')))."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __ilshift__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2806.no_ilshift_in_re_classes:
  description: "__ilshift__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the <<= in-place left-shift protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2806

  columns: [id, function, args, expected]
  rows:
    - ["re2806001", "re.Pattern.__dict__.__contains__", ["__ilshift__"], false]
    - ["re2806002", "re.Match.__dict__.__contains__",   ["__ilshift__"], false]

# ---------------------------------------------------------------------------
# __irshift__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2806.no_irshift_in_re_classes:
  description: "__irshift__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the >>= in-place right-shift protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2806

  columns: [id, function, args, expected]
  rows:
    - ["re2806003", "re.Pattern.__dict__.__contains__", ["__irshift__"], false]
    - ["re2806004", "re.Match.__dict__.__contains__",   ["__irshift__"], false]

# ---------------------------------------------------------------------------
# __ipow__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2806.no_ipow_in_re_classes:
  description: "__ipow__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the **= in-place exponentiation protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2806

  columns: [id, function, args, expected]
  rows:
    - ["re2806005", "re.Pattern.__dict__.__contains__", ["__ipow__"], false]
    - ["re2806006", "re.Match.__dict__.__contains__",   ["__ipow__"], false]

# ---------------------------------------------------------------------------
# Complementary: re.Pattern and re.Match have regex methods but not in-place shift or exponentiation hooks
# Confirms that regex objects are pattern-matching types, not integer or numeric types
# ---------------------------------------------------------------------------

table re_extra2806.re_has_regex_methods_not_inplace_shift_pow_hooks:
  description: "re.Pattern defines match/search/sub/findall but NOT __ilshift__/__irshift__/__ipow__; re.Match defines group/groups/start/end but NOT __ilshift__/__irshift__/__ipow__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2806

  columns: [id, function, args, expected]
  rows:
    - ["re2806007", "re.Pattern.__dict__.__contains__", ["match"],      true]
    - ["re2806008", "re.Pattern.__dict__.__contains__", ["search"],     true]
    - ["re2806009", "re.Pattern.__dict__.__contains__", ["sub"],        true]
    - ["re2806010", "re.Pattern.__dict__.__contains__", ["findall"],    true]
    - ["re2806011", "re.Pattern.__dict__.__contains__", ["__ilshift__"], false]
    - ["re2806012", "re.Pattern.__dict__.__contains__", ["__irshift__"], false]
    - ["re2806013", "re.Pattern.__dict__.__contains__", ["__ipow__"],    false]
    - ["re2806014", "re.Match.__dict__.__contains__",   ["group"],      true]
    - ["re2806015", "re.Match.__dict__.__contains__",   ["groups"],     true]
    - ["re2806016", "re.Match.__dict__.__contains__",   ["start"],      true]
    - ["re2806017", "re.Match.__dict__.__contains__",   ["end"],        true]
    - ["re2806018", "re.Match.__dict__.__contains__",   ["__ilshift__"], false]
    - ["re2806019", "re.Match.__dict__.__contains__",   ["__irshift__"], false]
    - ["re2806020", "re.Match.__dict__.__contains__",   ["__ipow__"],    false]
