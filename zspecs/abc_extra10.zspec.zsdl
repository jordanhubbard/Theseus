spec: abc_extra10
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc.zspec.zsdl through abc_extra9.zspec.zsdl."
    - "Prior specs cover: ABC/ABCMeta __name__/__qualname__/__module__/__class__/__bases__/__mro__; abstractmethod name/module/qualname/isabstractmethod/doc; get_cache_token type/nonneg/qualname/class; ABC dict_class_name/bases_len/abstractmethods; ABCMeta dict_class_name/bases_len; deprecated decorators name/module/qualname/class_type; update_abstractmethods name."
    - "NEW axes: update_abstractmethods __module__ and __qualname__; ABCMeta.__mro__[2].__name__ == 'object'; ABC.__mro__[1].__name__ == 'object'; ABCMeta.__subclasscheck__.__qualname__; ABC.__subclasshook__.__qualname__; ABC.__doc__.__len__ > 0; ABCMeta.__doc__.__len__ > 0."
    - "abc.update_abstractmethods.__module__ == 'abc' — pure-Python helper lives in abc."
    - "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods' — top-level function."
    - "abc.ABCMeta.__mro__[2].__name__ == 'object' — last MRO entry before end; MRO is [ABCMeta, type, object]."
    - "abc.ABC.__mro__[1].__name__ == 'object' — second and final MRO entry after ABC itself."
    - "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' — qualified name includes class."
    - "abc.ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' — qualified name includes class."
    - "len(abc.ABC.__doc__) > 0 — ABC has a non-empty docstring."
    - "len(abc.ABCMeta.__doc__) > 0 — ABCMeta has a non-empty docstring."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# update_abstractmethods — module and qualname
#
# abc_extra2 checks update_abstractmethods.__name__ == 'update_abstractmethods'.
# No prior spec checks __module__ or __qualname__ for this function.
# ---------------------------------------------------------------------------

invariant abc_extra10.update_abstractmethods.module:
  description: "abc.update_abstractmethods.__module__ == 'abc' — pure-Python helper lives in abc"
  category: update_abstractmethods
  kind: python_call_eq
  function: update_abstractmethods.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra10.update_abstractmethods.qualname:
  description: "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods' — top-level function"
  category: update_abstractmethods
  kind: python_call_eq
  function: update_abstractmethods.__qualname__.__eq__
  args: ["update_abstractmethods"]
  expected: true

invariant abc_extra10.update_abstractmethods.class_name:
  description: "type(abc.update_abstractmethods).__name__ == 'function' — implemented in Python"
  category: update_abstractmethods
  kind: python_call_eq
  function: update_abstractmethods.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# ABCMeta.__mro__[2] and ABC.__mro__[1] — object as final ancestor
#
# abc_extra8 covers ABCMeta.__mro__ length (3) and first (ABCMeta) / last (object).
# abc_extra9 covers ABCMeta.__mro__[1] == 'type' and ABC.__mro__[0] == 'ABC'.
# New here: ABCMeta.__mro__[2] == 'object' and ABC.__mro__[1] == 'object' —
# the last entry is object for both, confirmed as standalone invariants.
# ---------------------------------------------------------------------------

invariant abc_extra10.ABCMeta.mro_last_is_object:
  description: "abc.ABCMeta.__mro__[2].__name__ == 'object' — last MRO entry is object; MRO is [ABCMeta, type, object]"
  category: abcmeta_mro
  kind: python_call_eq
  function: ABCMeta.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "object"

invariant abc_extra10.ABC.mro_last_is_object:
  description: "abc.ABC.__mro__[1].__name__ == 'object' — second MRO entry is object; MRO is [ABC, object]"
  category: abc_mro
  kind: python_call_eq
  function: ABC.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# ABCMeta.__subclasscheck__.__qualname__ and ABC.__subclasshook__.__qualname__
#
# abc_extra8 confirms ABCMeta.__subclasscheck__ is a method_wrapper (by name).
# abc_extra covers ABC.__subclasshook__ returns NotImplemented.
# No prior spec checks the __qualname__ attribute of either method.
# ---------------------------------------------------------------------------

invariant abc_extra10.ABCMeta.subclasscheck_qualname:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' — qualified name includes class"
  category: abcmeta_class
  kind: python_call_eq
  function: ABCMeta.__subclasscheck__.__qualname__.__eq__
  args: ["ABCMeta.__subclasscheck__"]
  expected: true

invariant abc_extra10.ABC.subclasshook_qualname:
  description: "abc.ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' — qualified name includes class"
  category: abc_class
  kind: python_call_eq
  function: ABC.__subclasshook__.__qualname__.__eq__
  args: ["ABC.__subclasshook__"]
  expected: true

# ---------------------------------------------------------------------------
# ABC.__doc__ and ABCMeta.__doc__ — non-empty docstrings
#
# abc_extra9 confirms abstractmethod.__doc__.__len__() > 0.
# No prior spec checks that ABC or ABCMeta themselves have non-empty docstrings.
# ---------------------------------------------------------------------------

invariant abc_extra10.ABC.doc_nonempty:
  description: "len(abc.ABC.__doc__) > 0 — ABC has a non-empty docstring"
  category: abc_class
  kind: python_call_eq
  function: ABC.__doc__.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true

invariant abc_extra10.ABCMeta.doc_nonempty:
  description: "len(abc.ABCMeta.__doc__) > 0 — ABCMeta has a non-empty docstring"
  category: abcmeta_class
  kind: python_call_eq
  function: ABCMeta.__doc__.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# abstractmethod.__qualname__ — covered via __name__ but not __qualname__
#
# abc_extra2 checks abstractmethod.__name__ == 'abstractmethod'.
# abc_extra5 checks abstractmethod.__qualname__ == 'abstractmethod'.
# No prior spec confirms it as a standalone __eq__ invariant using
# function: abstractmethod.__qualname__.__eq__ form.
# ---------------------------------------------------------------------------

invariant abc_extra10.abstractmethod.qualname_eq:
  description: "abc.abstractmethod.__qualname__ == 'abstractmethod' — top-level; qualname equals name"
  category: abstractmethod
  kind: python_call_eq
  function: abstractmethod.__qualname__.__eq__
  args: ["abstractmethod"]
  expected: true

# ---------------------------------------------------------------------------
# ABCMeta.__name__ length
#
# abc_extra9 confirms ABC.__name__.__len__() == 3.
# No prior spec checks ABCMeta.__name__.__len__(). 'ABCMeta' has 7 characters.
# ---------------------------------------------------------------------------

invariant abc_extra10.ABCMeta.name_length:
  description: "len(abc.ABCMeta.__name__) == 7 — 'ABCMeta' has exactly 7 characters"
  category: abcmeta_class
  kind: python_call_eq
  function: ABCMeta.__name__.__len__
  args: []
  expected: 7
