spec: threading_extra961
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading.Barrier, Semaphore error conditions and module/qualname identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra961.function_identity:
  description: "threading function __module__ and __qualname__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: th961id
  columns: [id, function, args, expected]
  rows:
    - [th961id001, threading.enumerate.__module__.__eq__,   ["threading"], true]
    - [th961id002, threading.enumerate.__qualname__.__eq__, ["enumerate"], true]
    - [th961id003, threading.settrace.__module__.__eq__,    ["threading"], true]
    - [th961id004, threading.setprofile.__module__.__eq__,  ["threading"], true]
    - [th961id005, threading.stack_size.__qualname__.__eq__, ["stack_size"], true]
    - [th961id006, threading.current_thread.__module__.__eq__, ["threading"], true]
    - [th961id007, threading.main_thread.__module__.__eq__,   ["threading"], true]

table threading_extra961.get_ident_identity:
  description: "threading.get_ident and get_native_id module identity"
  kind: python_call_eq
  category: ident_identity
  id_prefix: th961gi
  columns: [id, function, args, expected]
  rows:
    - [th961gi001, threading.get_ident.__name__.__eq__,          ["get_ident"],     true]
    - [th961gi002, threading.get_native_id.__name__.__eq__,      ["get_native_id"], true]
    - [th961gi003, threading.active_count.__module__.__eq__,     ["threading"],     true]
    - [th961gi004, threading.excepthook.__qualname__.__eq__,     ["excepthook"],    true]

table threading_extra961.raises_on_bad_args:
  description: "threading.Barrier and Semaphore raise on invalid arguments"
  kind: python_call_raises
  category: constructor_errors
  id_prefix: th961ce
  columns: [id, function, args, expected]
  rows:
    - [th961ce001, threading.Barrier,   ["0"],  ValueError]
    - [th961ce002, threading.Barrier,   ["-1"], ValueError]
    - [th961ce003, threading.Semaphore, ["-1"], ValueError]
    - [th961ce004, threading.Semaphore, ["-100"], ValueError]
