spec: pathlib_extra260
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers pathlib module identity and WindowsPath class hierarchy."
    - "pathlib.__name__ == 'pathlib' — the module's qualified name."
    - "pathlib.__package__ == 'pathlib' — pathlib is a package (directory with __init__.py)."
    - "pathlib.__all__ is a list of 7 public names: ['UnsupportedOperation', 'PurePath', 'PurePosixPath', 'PureWindowsPath', 'Path', 'PosixPath', 'WindowsPath']."
    - "pathlib.WindowsPath.__name__ == 'WindowsPath' — the concrete Windows path class."
    - "pathlib.WindowsPath.__module__ == 'pathlib' — defined in the pathlib package."
    - "pathlib.WindowsPath has two bases: Path and PureWindowsPath (multiple inheritance)."
    - "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' — first base is the concrete Path class."
    - "pathlib.WindowsPath.__bases__[1].__name__ == 'PureWindowsPath' — second base provides Windows-specific pure path logic."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' — the pure (non-I/O) Windows path class."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — PureWindowsPath inherits from PurePath."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib module identity attributes
#
# pathlib.__name__, __package__, and __all__ identity.
# pathlib is a package so __package__ == 'pathlib' (not '').
# ---------------------------------------------------------------------------

table pathlib_extra260.module_identity:
  description: "pathlib module identity — __name__, __package__, and __all__ membership; new to extra260"
  kind: python_call_eq
  category: identity
  id_prefix: plxmi260

  columns: [id, function, args, expected, description]
  rows:
    - [module_name,
       "__name__.__eq__",
       ["pathlib"],
       true,
       "pathlib.__name__.__eq__('pathlib') == True — the module's qualified name is 'pathlib'; str.__eq__('pathlib') returns True; new to extra260"]
    - [module_package,
       "__package__.__eq__",
       ["pathlib"],
       true,
       "pathlib.__package__.__eq__('pathlib') == True — pathlib is a package (directory-based module); its __package__ is 'pathlib', not ''; str.__eq__('pathlib') returns True; new to extra260"]
    - [all_contains_windowspath,
       "__all__.__contains__",
       ["WindowsPath"],
       true,
       "pathlib.__all__.__contains__('WindowsPath') == True — WindowsPath is one of the 7 public names exported in pathlib.__all__; list.__contains__('WindowsPath') returns True; new to extra260"]
    - [all_contains_purewindowspath,
       "__all__.__contains__",
       ["PureWindowsPath"],
       true,
       "pathlib.__all__.__contains__('PureWindowsPath') == True — PureWindowsPath is listed in pathlib.__all__; list.__contains__('PureWindowsPath') returns True; new to extra260"]
    - [all_contains_purepath,
       "__all__.__contains__",
       ["PurePath"],
       true,
       "pathlib.__all__.__contains__('PurePath') == True — PurePath is the abstract base for all pure path classes; it is listed in pathlib.__all__; list.__contains__('PurePath') returns True; new to extra260"]
    - [all_contains_path,
       "__all__.__contains__",
       ["Path"],
       true,
       "pathlib.__all__.__contains__('Path') == True — Path is the concrete cross-platform path class; it is listed in pathlib.__all__; list.__contains__('Path') returns True; new to extra260"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.WindowsPath class hierarchy
#
# WindowsPath uses multiple inheritance: (Path, PureWindowsPath).
# __bases__[0] is Path (the concrete I/O class).
# __bases__[1] is PureWindowsPath (the pure Windows path mixin).
# PureWindowsPath itself inherits from PurePath.
# ---------------------------------------------------------------------------

table pathlib_extra260.windowspath_hierarchy:
  description: "pathlib.WindowsPath class hierarchy — __name__, __module__, and base class names; new to extra260"
  kind: python_call_eq
  category: identity
  id_prefix: plxwph260

  columns: [id, function, args, expected, description]
  rows:
    - [windowspath_name,
       "WindowsPath.__name__.__eq__",
       ["WindowsPath"],
       true,
       "pathlib.WindowsPath.__name__.__eq__('WindowsPath') == True — WindowsPath is the concrete Windows path class; its __name__ is 'WindowsPath'; str.__eq__('WindowsPath') returns True; new to extra260"]
    - [windowspath_module,
       "WindowsPath.__module__.__eq__",
       ["pathlib"],
       true,
       "pathlib.WindowsPath.__module__.__eq__('pathlib') == True — WindowsPath is defined in the pathlib package; its __module__ is 'pathlib'; str.__eq__('pathlib') returns True; new to extra260"]
    - [windowspath_base0_name,
       "WindowsPath.__bases__.__getitem__",
       [0],
       "Path",
       "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' — the first base of WindowsPath is the concrete Path class (which provides I/O operations); __getitem__(0).__name__ is 'Path'; new to extra260"]
    - [purewindowspath_name,
       "PureWindowsPath.__name__.__eq__",
       ["PureWindowsPath"],
       true,
       "pathlib.PureWindowsPath.__name__.__eq__('PureWindowsPath') == True — PureWindowsPath is the pure (non-I/O) Windows path class; its __name__ is 'PureWindowsPath'; str.__eq__('PureWindowsPath') returns True; new to extra260"]
    - [purewindowspath_base0_name,
       "PureWindowsPath.__bases__.__getitem__",
       [0],
       "PurePath",
       "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — PureWindowsPath inherits directly from PurePath (the abstract pure path base); __getitem__(0).__name__ is 'PurePath'; new to extra260"]

# ---------------------------------------------------------------------------
# Standalone invariants — pathlib_extra260
# ---------------------------------------------------------------------------

invariant pathlib_extra260.module_name:
  description: "pathlib.__name__ == 'pathlib' — the module's qualified name; new to extra260"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra260.module_package:
  description: "pathlib.__package__ == 'pathlib' — pathlib is a package, not a simple top-level module; new to extra260"
  kind: python_call_eq
  function: __package__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra260.windowspath_name:
  description: "pathlib.WindowsPath.__name__ == 'WindowsPath' — the concrete Windows path class name; new to extra260"
  kind: python_call_eq
  function: WindowsPath.__name__.__eq__
  args: ["WindowsPath"]
  expected: true

invariant pathlib_extra260.windowspath_module:
  description: "pathlib.WindowsPath.__module__ == 'pathlib' — WindowsPath is defined in the pathlib package; new to extra260"
  kind: python_call_eq
  function: WindowsPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra260.purewindowspath_name:
  description: "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' — the pure (non-I/O) Windows path class name; new to extra260"
  kind: python_call_eq
  function: PureWindowsPath.__name__.__eq__
  args: ["PureWindowsPath"]
  expected: true

invariant pathlib_extra260.purewindowspath_base_is_purepath:
  description: "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — PureWindowsPath directly inherits from PurePath; new to extra260"
  kind: python_call_eq
  function: "PureWindowsPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra260.all_contains_windowspath:
  description: "pathlib.__all__.__contains__('WindowsPath') == True — WindowsPath is exported in pathlib.__all__; new to extra260"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["WindowsPath"]
  expected: true
