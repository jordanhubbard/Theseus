spec: uuid_extra1111
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid.__name__ and class attrs, uuid.__spec__.name, uuid.UUID.__doc__ class attrs, uuid.UUID.__weakref__ class name, uuid.NAMESPACE_DNS/NAMESPACE_URL class attrs, uuid.RFC_4122 class name, uuid.uuid1/uuid4 class and module attrs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1111.module_name_and_spec:
  description: "uuid.__name__ and uuid.__spec__.name identity and class attributes"
  kind: python_call_eq
  category: module_name_spec
  id_prefix: uu1111mn
  columns: [id, function, args, expected]
  rows:
    - [uu1111mn001, uuid.__name__.__eq__,                              ["uuid"],     true]
    - [uu1111mn002, uuid.__name__.__class__.__name__.__eq__,           ["str"],      true]
    - [uu1111mn003, uuid.__name__.__class__.__qualname__.__eq__,       ["str"],      true]
    - [uu1111mn004, uuid.__name__.__class__.__module__.__eq__,         ["builtins"], true]
    - [uu1111mn005, uuid.__spec__.name.__eq__,                         ["uuid"],     true]
    - [uu1111mn006, uuid.__spec__.name.__class__.__name__.__eq__,      ["str"],      true]
    - [uu1111mn007, uuid.UUID.__doc__.__class__.__name__.__eq__,       ["str"],      true]
    - [uu1111mn008, uuid.UUID.__doc__.__class__.__qualname__.__eq__,   ["str"],      true]
    - [uu1111mn009, uuid.UUID.__doc__.__class__.__module__.__eq__,     ["builtins"], true]
    - [uu1111mn010, uuid.UUID.__weakref__.__class__.__name__.__eq__,   ["getset_descriptor"], true]

table uuid_extra1111.namespace_constants_class_attrs:
  description: "uuid.NAMESPACE_DNS, uuid.NAMESPACE_URL, uuid.RFC_4122 class name identity"
  kind: python_call_eq
  category: namespace_constant_classnames
  id_prefix: uu1111nc
  columns: [id, function, args, expected]
  rows:
    - [uu1111nc001, uuid.NAMESPACE_DNS.__class__.__name__.__eq__,       ["UUID"],  true]
    - [uu1111nc002, uuid.NAMESPACE_URL.__class__.__name__.__eq__,       ["UUID"],  true]
    - [uu1111nc003, uuid.NAMESPACE_DNS.__class__.__qualname__.__eq__,   ["UUID"],  true]
    - [uu1111nc004, uuid.NAMESPACE_URL.__class__.__qualname__.__eq__,   ["UUID"],  true]
    - [uu1111nc005, uuid.NAMESPACE_DNS.__class__.__module__.__eq__,     ["uuid"],  true]
    - [uu1111nc006, uuid.NAMESPACE_URL.__class__.__module__.__eq__,     ["uuid"],  true]
    - [uu1111nc007, uuid.RFC_4122.__class__.__name__.__eq__,            ["str"],   true]
    - [uu1111nc008, uuid.RFC_4122.__class__.__qualname__.__eq__,        ["str"],   true]
    - [uu1111nc009, uuid.RFC_4122.__class__.__module__.__eq__,          ["builtins"], true]

table uuid_extra1111.generator_function_class_and_module:
  description: "uuid.uuid1 and uuid.uuid4 __class__.__name__ and __module__ identity"
  kind: python_call_eq
  category: generator_function_class_module
  id_prefix: uu1111gf
  columns: [id, function, args, expected]
  rows:
    - [uu1111gf001, uuid.uuid1.__class__.__name__.__eq__,              ["function"], true]
    - [uu1111gf002, uuid.uuid4.__class__.__name__.__eq__,              ["function"], true]
    - [uu1111gf003, uuid.uuid3.__class__.__name__.__eq__,              ["function"], true]
    - [uu1111gf004, uuid.uuid5.__class__.__name__.__eq__,              ["function"], true]
    - [uu1111gf005, uuid.uuid1.__module__.__eq__,                      ["uuid"],     true]
    - [uu1111gf006, uuid.uuid4.__module__.__eq__,                      ["uuid"],     true]
    - [uu1111gf007, uuid.uuid3.__module__.__eq__,                      ["uuid"],     true]
    - [uu1111gf008, uuid.uuid5.__module__.__eq__,                      ["uuid"],     true]
    - [uu1111gf009, uuid.uuid1.__module__.__class__.__name__.__eq__,   ["str"],      true]
    - [uu1111gf010, uuid.uuid4.__module__.__class__.__name__.__eq__,   ["str"],      true]
