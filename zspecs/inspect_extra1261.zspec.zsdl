spec: inspect_extra1261
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 531: checks inspect.__all__ membership (contains true/false) for public names, private names, and imported symbols; verifies __all__ is a list"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1261.all_contains_true:
  description: "inspect.__all__.__contains__ returns true for public names that are in __all__"
  kind: python_call_eq
  category: all_membership_true
  id_prefix: in1261at
  columns: [id, function, args, expected]
  rows:
    - [in1261at001, inspect.__all__.__contains__, ["isfunction"],    true]
    - [in1261at002, inspect.__all__.__contains__, ["isclass"],       true]
    - [in1261at003, inspect.__all__.__contains__, ["ismodule"],      true]
    - [in1261at004, inspect.__all__.__contains__, ["getmembers"],    true]
    - [in1261at005, inspect.__all__.__contains__, ["signature"],     true]
    - [in1261at006, inspect.__all__.__contains__, ["getsource"],     true]
    - [in1261at007, inspect.__all__.__contains__, ["isbuiltin"],     true]
    - [in1261at008, inspect.__all__.__contains__, ["ismethod"],      true]
    - [in1261at009, inspect.__all__.__contains__, ["getdoc"],        true]
    - [in1261at010, inspect.__all__.__contains__, ["getfile"],       true]
    - [in1261at011, inspect.__all__.__contains__, ["Parameter"],     true]
    - [in1261at012, inspect.__all__.__contains__, ["Signature"],     true]
    - [in1261at013, inspect.__all__.__contains__, ["stack"],         true]
    - [in1261at014, inspect.__all__.__contains__, ["currentframe"],  true]
    - [in1261at015, inspect.__all__.__contains__, ["FrameInfo"],     true]
    - [in1261at016, inspect.__all__.__contains__, ["BoundArguments"], true]
    - [in1261at017, inspect.__all__.__contains__, ["getmro"],        true]
    - [in1261at018, inspect.__all__.__contains__, ["getclosurevars"], true]

table inspect_extra1261.all_contains_false:
  description: "inspect.__all__.__contains__ returns false for private names and imported symbols not in __all__"
  kind: python_call_eq
  category: all_membership_false
  id_prefix: in1261af
  columns: [id, function, args, expected]
  rows:
    - [in1261af001, inspect.__all__.__contains__, ["_empty"],       false]
    - [in1261af002, inspect.__all__.__contains__, ["os"],           false]
    - [in1261af003, inspect.__all__.__contains__, ["sys"],          false]
    - [in1261af004, inspect.__all__.__contains__, ["re"],           false]
    - [in1261af005, inspect.__all__.__contains__, ["types"],        false]
    - [in1261af006, inspect.__all__.__contains__, ["__builtins__"], false]
    - [in1261af007, inspect.__all__.__contains__, ["tokenize"],     false]
    - [in1261af008, inspect.__all__.__contains__, ["linecache"],    false]
    - [in1261af009, inspect.__all__.__contains__, ["abc"],          false]
    - [in1261af010, inspect.__all__.__contains__, ["ast"],          false]
    - [in1261af011, inspect.__all__.__contains__, ["dis"],          false]
    - [in1261af012, inspect.__all__.__contains__, ["importlib"],    false]

table inspect_extra1261.all_class_and_type_checks:
  description: "inspect.__all__ is a list and class name identity checks"
  kind: python_call_eq
  category: all_class_checks
  id_prefix: in1261ac
  columns: [id, function, args, expected]
  rows:
    - [in1261ac001, inspect.__all__.__class__.__name__.__eq__,         ["list"],      true]
    - [in1261ac002, inspect.__all__.__class__.__name__.__eq__,         ["tuple"],     false]
    - [in1261ac003, inspect.__all__.__class__.__name__.__eq__,         ["set"],       false]
    - [in1261ac004, inspect.__all__.__class__.__name__.__eq__,         ["frozenset"], false]
    - [in1261ac005, inspect.__all__.__class__.__name__.__eq__,         ["dict"],      false]
    - [in1261ac006, inspect.__all__.__class__.__qualname__.__eq__,     ["list"],      true]
    - [in1261ac007, inspect.__all__.__class__.__module__.__eq__,       ["builtins"],  true]
    - [in1261ac008, inspect.__name__.__eq__,                           ["inspect"],   true]
    - [in1261ac009, inspect.__spec__.name.__eq__,                      ["inspect"],   true]
    - [in1261ac010, inspect.__all__.__len__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
