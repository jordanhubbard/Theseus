spec: threading_extra991
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading.Condition, Semaphore, and Barrier method __qualname__ identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra991.condition_qualnames:
  description: "threading.Condition method __qualname__ identity"
  kind: python_call_eq
  category: condition_qualnames
  id_prefix: th991co
  columns: [id, function, args, expected]
  rows:
    - [th991co001, threading.Condition.__qualname__.__eq__,                        ["Condition"],                        true]
    - [th991co002, threading.Condition.__init__.__qualname__.__eq__,               ["Condition.__init__"],               true]
    - [th991co003, threading.Condition.acquire.__qualname__.__eq__,                ["Condition.acquire"],                true]
    - [th991co004, threading.Condition.release.__qualname__.__eq__,                ["Condition.release"],                true]
    - [th991co005, threading.Condition.wait.__qualname__.__eq__,                   ["Condition.wait"],                   true]
    - [th991co006, threading.Condition.notify.__qualname__.__eq__,                 ["Condition.notify"],                 true]
    - [th991co007, threading.Condition.notify_all.__qualname__.__eq__,             ["Condition.notify_all"],             true]

table threading_extra991.semaphore_qualnames:
  description: "threading.Semaphore method __qualname__ identity"
  kind: python_call_eq
  category: semaphore_qualnames
  id_prefix: th991se
  columns: [id, function, args, expected]
  rows:
    - [th991se001, threading.Semaphore.__qualname__.__eq__,                        ["Semaphore"],                        true]
    - [th991se002, threading.Semaphore.__init__.__qualname__.__eq__,               ["Semaphore.__init__"],               true]
    - [th991se003, threading.Semaphore.acquire.__qualname__.__eq__,                ["Semaphore.acquire"],                true]
    - [th991se004, threading.Semaphore.release.__qualname__.__eq__,                ["Semaphore.release"],                true]
    - [th991se005, threading.Semaphore.__module__.__eq__,                          ["threading"],                        true]

table threading_extra991.barrier_and_module_qualnames:
  description: "threading.Barrier method __qualname__ identity and module identity"
  kind: python_call_eq
  category: barrier_qualnames
  id_prefix: th991ba
  columns: [id, function, args, expected]
  rows:
    - [th991ba001, threading.Barrier.__qualname__.__eq__,                          ["Barrier"],                          true]
    - [th991ba002, threading.Barrier.__init__.__qualname__.__eq__,                 ["Barrier.__init__"],                 true]
    - [th991ba003, threading.Barrier.wait.__qualname__.__eq__,                     ["Barrier.wait"],                     true]
    - [th991ba004, threading.Barrier.reset.__qualname__.__eq__,                    ["Barrier.reset"],                    true]
    - [th991ba005, threading.Barrier.abort.__qualname__.__eq__,                    ["Barrier.abort"],                    true]
    - [th991ba006, threading.__spec__.name.__eq__,                                 ["threading"],                        true]
    - [th991ba007, threading.__name__.__eq__,                                      ["threading"],                        true]
