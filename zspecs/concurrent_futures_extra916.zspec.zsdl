spec: concurrent_futures_extra916
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module Future, ThreadPoolExecutor, ProcessPoolExecutor, exception documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks concurrent.futures class __qualname__ and __module__ identity for executors and exceptions"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra916.future_executor_qualnames:
  description: "concurrent.futures.Future, ThreadPoolExecutor, ProcessPoolExecutor __qualname__ identity"
  kind: python_call_eq
  category: future_executor_qualnames
  id_prefix: cf916fe
  columns: [id, function, args, expected]
  rows:
    - [cf916fe001, concurrent.futures.Future.__qualname__.__eq__,                  ["Future"],                          true]
    - [cf916fe002, concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__,      ["ThreadPoolExecutor"],              true]
    - [cf916fe003, concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__,     ["ProcessPoolExecutor"],             true]
    - [cf916fe004, concurrent.futures.Future.__module__.__eq__,                    ["concurrent.futures._base"],        true]
    - [cf916fe005, concurrent.futures.ThreadPoolExecutor.__module__.__eq__,        ["concurrent.futures.thread"],       true]
    - [cf916fe006, concurrent.futures.ProcessPoolExecutor.__module__.__eq__,       ["concurrent.futures.process"],      true]
    - [cf916fe007, concurrent.futures.Future.__class__.__name__.__eq__,            ["type"],                            true]

table concurrent_futures_extra916.exception_modules:
  description: "concurrent.futures exception __module__ identity"
  kind: python_call_eq
  category: exception_modules
  id_prefix: cf916ex
  columns: [id, function, args, expected]
  rows:
    - [cf916ex001, concurrent.futures.CancelledError.__module__.__eq__,            ["concurrent.futures._base"],        true]
    - [cf916ex002, concurrent.futures.TimeoutError.__module__.__eq__,              ["concurrent.futures._base"],        true]
    - [cf916ex003, concurrent.futures.BrokenExecutor.__module__.__eq__,            ["concurrent.futures._base"],        true]
    - [cf916ex004, concurrent.futures.CancelledError.__qualname__.__eq__,          ["CancelledError"],                  true]
    - [cf916ex005, concurrent.futures.TimeoutError.__qualname__.__eq__,            ["TimeoutError"],                    true]
    - [cf916ex006, concurrent.futures.BrokenExecutor.__qualname__.__eq__,          ["BrokenExecutor"],                  true]
    - [cf916ex007, concurrent.futures.CancelledError.__class__.__name__.__eq__,    ["type"],                            true]

table concurrent_futures_extra916.class_identity:
  description: "concurrent.futures class identity and string type checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: cf916ci
  columns: [id, function, args, expected]
  rows:
    - [cf916ci001, concurrent.futures.Future.__qualname__.__class__.__name__.__eq__,             ["str"], true]
    - [cf916ci002, concurrent.futures.ThreadPoolExecutor.__qualname__.__class__.__name__.__eq__,  ["str"], true]
    - [cf916ci003, concurrent.futures.ProcessPoolExecutor.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [cf916ci004, concurrent.futures.BrokenExecutor.__qualname__.__class__.__name__.__eq__,      ["str"], true]
    - [cf916ci005, concurrent.futures.Executor.__qualname__.__eq__,                               ["Executor"],                   true]
    - [cf916ci006, concurrent.futures.Executor.__module__.__eq__,                                 ["concurrent.futures._base"],   true]
