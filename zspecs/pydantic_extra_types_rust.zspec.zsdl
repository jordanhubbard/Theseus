    - "pydantic_extra_types.color.Color is a class."
    - "pydantic_extra_types.phone_numbers.PhoneNumber is a class."
    - "pydantic_extra_types.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pydantic_extra_types_rust.has_color:
  description: "pydantic_extra_types.color.Color is a class"
  category: presence
  kind: python_call_eq
  function: pydantic_extra_types_has_color
  args: []
  expected: true

invariant pydantic_extra_types_rust.has_phone_number:
  description: "pydantic_extra_types has phone_numbers module"
  category: presence
  kind: python_call_eq
  function: pydantic_extra_types_has_phone_numbers
  args: []
  expected: true

invariant pydantic_extra_types_rust.version_nonempty:
  description: "pydantic_extra_types.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pydantic_extra_types_version_nonempty
  args: []
  expected: true

