table is_alphanumerical.isAlphanumerical:
  kind: node_module_call_eq
  function: isAlphanumerical
  category: predicate
  id_prefix: isalnum

  columns: [id, args, expected]
  rows:
    - [letter,  ["a"],  true]
    - [digit,   ["1"],  true]
    - [upper,   ["A"],  true]
    - [space,   [" "],  false]
    - [symbol,  ["!"],  false]

