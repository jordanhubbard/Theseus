spec: is_alphanumerical
version: ">=2.0.1"
backend: node(is-alphanumerical)

docs: https://www.npmjs.com/package/is-alphanumerical

provenance:
  derived_from:
    - "is-alphanumerical README — https://www.npmjs.com/package/is-alphanumerical"
    - "Test vectors verified with is-alphanumerical via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-alphanumerical source"
  notes:
    - "is-alphanumerical is an npm package. Install: npm install is-alphanumerical"
    - "Checks a single character: returns true if it is a letter (a-z, A-Z) or digit (0-9)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_alphanumerical.isAlphanumerical:
  kind: node_module_call_eq
  function: isAlphanumerical
  category: predicate
  id_prefix: isalnum

  columns: [id, args, expected]
  rows:
    - [letter,  ["a"],  true]
    - [digit,   ["1"],  true]
    - [upper,   ["A"],  true]
    - [space,   [" "],  false]
    - [symbol,  ["!"],  false]
