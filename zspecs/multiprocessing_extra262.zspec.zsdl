spec: multiprocessing_extra262
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "multiprocessing.Queue and multiprocessing.Pipe are bound methods on the context object; __module__ == 'multiprocessing.context'."
    - "multiprocessing.Process.__module__ == 'multiprocessing.context'; it inherits from BaseProcess."
    - "Process.start and Process.join carry __qualname__ == 'BaseProcess.start' / 'BaseProcess.join' because they are defined on the base class."
    - "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool'; it inherits from object."
    - "Pool method __qualname__ values are prefixed with 'Pool.' (map, apply, close, terminate)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process class identity — table
#
# Process is defined in multiprocessing.context and inherits from BaseProcess.
# ---------------------------------------------------------------------------

table multiprocessing_extra262.process_identity:
  description: "multiprocessing.Process class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: pid

  columns: [id, function, args, expected, description]
  rows:
    - [proc_name,      Process.__name__.__eq__,           ["Process"],                  true, "multiprocessing.Process.__name__ == 'Process'"]
    - [proc_module,    Process.__module__.__eq__,         ["multiprocessing.context"],  true, "multiprocessing.Process.__module__ == 'multiprocessing.context'"]
    - [proc_base,      "Process.__bases__[0].__name__.__eq__", ["BaseProcess"],         true, "multiprocessing.Process inherits from BaseProcess"]
    - [proc_start,     Process.start.__name__.__eq__,     ["start"],                    true, "multiprocessing.Process.start.__name__ == 'start'"]
    - [proc_join,      Process.join.__name__.__eq__,      ["join"],                     true, "multiprocessing.Process.join.__name__ == 'join'"]
    - [proc_terminate, Process.terminate.__name__.__eq__, ["terminate"],                true, "multiprocessing.Process.terminate.__name__ == 'terminate'"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool class identity — table
#
# Pool is defined in multiprocessing.pool and inherits from object.
# ---------------------------------------------------------------------------

table multiprocessing_extra262.pool_identity:
  description: "multiprocessing.pool.Pool class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: plid

  columns: [id, function, args, expected, description]
  rows:
    - [pool_name,      pool.Pool.__name__.__eq__,           ["Pool"],                   true, "multiprocessing.pool.Pool.__name__ == 'Pool'"]
    - [pool_module,    pool.Pool.__module__.__eq__,         ["multiprocessing.pool"],   true, "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool'"]
    - [pool_base,      "pool.Pool.__bases__[0].__name__.__eq__", ["object"],            true, "multiprocessing.pool.Pool inherits from object"]
    - [pool_map,       pool.Pool.map.__name__.__eq__,       ["map"],                    true, "multiprocessing.pool.Pool.map.__name__ == 'map'"]
    - [pool_apply,     pool.Pool.apply.__name__.__eq__,     ["apply"],                  true, "multiprocessing.pool.Pool.apply.__name__ == 'apply'"]
    - [pool_close,     pool.Pool.close.__name__.__eq__,     ["close"],                  true, "multiprocessing.pool.Pool.close.__name__ == 'close'"]
    - [pool_terminate, pool.Pool.terminate.__name__.__eq__, ["terminate"],              true, "multiprocessing.pool.Pool.terminate.__name__ == 'terminate'"]

# ---------------------------------------------------------------------------
# multiprocessing.Queue and Pipe module identity — standalone invariants
# ---------------------------------------------------------------------------

invariant multiprocessing_extra262.Queue.name:
  description: "multiprocessing.Queue.__name__ == 'Queue'"
  category: identity
  kind: python_call_eq
  function: Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

invariant multiprocessing_extra262.Queue.module:
  description: "multiprocessing.Queue.__module__ == 'multiprocessing.context'"
  category: identity
  kind: python_call_eq
  function: Queue.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra262.Pipe.name:
  description: "multiprocessing.Pipe.__name__ == 'Pipe'"
  category: identity
  kind: python_call_eq
  function: Pipe.__name__.__eq__
  args: ["Pipe"]
  expected: true

invariant multiprocessing_extra262.Pipe.module:
  description: "multiprocessing.Pipe.__module__ == 'multiprocessing.context'"
  category: identity
  kind: python_call_eq
  function: Pipe.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing.Process method __qualname__ — standalone invariants
#
# start and join are inherited from BaseProcess, so __qualname__ reflects that.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra262.Process.start_qualname:
  description: "multiprocessing.Process.start.__qualname__ == 'BaseProcess.start'"
  category: identity
  kind: python_call_eq
  function: Process.start.__qualname__.__eq__
  args: ["BaseProcess.start"]
  expected: true

invariant multiprocessing_extra262.Process.join_qualname:
  description: "multiprocessing.Process.join.__qualname__ == 'BaseProcess.join'"
  category: identity
  kind: python_call_eq
  function: Process.join.__qualname__.__eq__
  args: ["BaseProcess.join"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool method __qualname__ — standalone invariants
# ---------------------------------------------------------------------------

invariant multiprocessing_extra262.pool.Pool.map_qualname:
  description: "multiprocessing.pool.Pool.map.__qualname__ == 'Pool.map'"
  category: identity
  kind: python_call_eq
  function: pool.Pool.map.__qualname__.__eq__
  args: ["Pool.map"]
  expected: true

invariant multiprocessing_extra262.pool.Pool.close_qualname:
  description: "multiprocessing.pool.Pool.close.__qualname__ == 'Pool.close'"
  category: identity
  kind: python_call_eq
  function: pool.Pool.close.__qualname__.__eq__
  args: ["Pool.close"]
  expected: true

invariant multiprocessing_extra262.pool.Pool.terminate_qualname:
  description: "multiprocessing.pool.Pool.terminate.__qualname__ == 'Pool.terminate'"
  category: identity
  kind: python_call_eq
  function: pool.Pool.terminate.__qualname__.__eq__
  args: ["Pool.terminate"]
  expected: true
