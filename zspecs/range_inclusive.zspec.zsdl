spec: range_inclusive
version: ">=1.0.2"
backend: node(range-inclusive)

docs: https://www.npmjs.com/package/range-inclusive

provenance:
  derived_from:
    - "range-inclusive README — https://www.npmjs.com/package/range-inclusive"
    - "Test vectors verified with range-inclusive via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "range-inclusive source"
  notes:
    - "range-inclusive is an npm package. Install: npm install range-inclusive"
    - "Returns an array of integers from start to end, inclusive."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table range_inclusive.range:
  kind: node_module_call_eq
  function: ~
  category: arrays
  id_prefix: rinc

  columns: [id, args, expected]
  rows:
    - [one_to_five, [1, 5], [1, 2, 3, 4, 5]]
    - [zero_to_four,[0, 4], [0, 1, 2, 3, 4]]
    - [same,        [5, 5], [5]]

