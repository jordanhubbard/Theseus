spec: decamelize
version: ">=4.0.0"
backend: node(decamelize)

docs: https://github.com/sindresorhus/decamelize#readme

provenance:
  derived_from:
    - "decamelize README — https://github.com/sindresorhus/decamelize#readme"
    - "Test vectors verified with decamelize@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "decamelize source"
  notes:
    - "decamelize@4 (CJS) exports the function directly as module.exports."
    - "Converts camelCase strings to snake_case by inserting an underscore before uppercase letters."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns string. No errors for valid string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table decamelize.decamelize:
  kind: node_module_call_eq
  function: ~
  category: decamelize
  id_prefix: decamelize

  columns: [id, args, expected]
  rows:
    - [hello_world,  ["helloWorld"],  "hello_world"]
    - [camel_case,   ["camelCase"],   "camel_case"]
    - [already,      ["foo_bar"],     "foo_bar"]
