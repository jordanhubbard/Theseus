spec: hashlib_extra94
version: ">=3.9"
extends: hashlib_extra93
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra93.zspec.zsdl — covers hashlib.blake2b and blake2b.blake2s integer class constants MAX_DIGEST_SIZE/MAX_KEY_SIZE/SALT_SIZE/PERSON_SIZE class identity and values (table + invariants)."
    - "hashlib_extra92.zspec.zsdl — covers hashlib.sha256/sha512/md5/sha1/sha224/sha384 class identity (__class__.__name__=='builtin_function_or_method', __module__=='_hashlib', __qualname__) (table + invariants)."
    - "hashlib_extra91.zspec.zsdl — covers hashlib.new function identity / algorithms_available/algorithms_guaranteed set identity / blake2b BLAKE2 constant attrs / blake2b and blake2s doc class identity (table + invariants)."
    - "hashlib_extra90.zspec.zsdl — covers blake2b/blake2s class identity __name__/__module__/__bases__[0].__name__/__mro__.__len__() / blake2b/blake2s __dict__.__contains__ for copy/digest/hexdigest/update (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra93; it does NOT duplicate invariants present in those files."
    - "Wave 256 theme: hashlib algorithms_available and algorithms_guaranteed set class identity and membership."
    - "hashlib.algorithms_available.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha256' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha512' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha1' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'md5' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha224' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha384' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha3_256' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'blake2b' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'blake2s' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_available/__class__/__name__.__eq__('set')
# hashlib.algorithms_guaranteed/__class__.__name__.__eq__('set')
# hashlib.algorithms_available/__class__/__name__.__eq__('set') (cross-check)
# hashlib.algorithms_guaranteed/__class__.__name__.__eq__('set') (cross-check)
#
# Wave 256 theme: algorithms_available and algorithms_guaranteed class identity.
#
# Both hashlib.algorithms_available and hashlib.algorithms_guaranteed are plain
# Python set objects. Their __class__.__name__ is 'set'. No prior hashlib spec
# anchors these __class__.__name__.__eq__ calls under hashlibalgsets94.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra94.alg_set_class_names:
  description: "hashlib.algorithms_available/__class__.__name__.__eq__('set')==True / algorithms_guaranteed/__class__.__name__.__eq__('set')==True — both algorithms_available and algorithms_guaranteed are plain Python set objects; their __class__.__name__ is 'set'; no prior hashlib spec anchors these __eq__ calls under hashlibalgsets94; first hashlibalgsets94 anchor for set class identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibalgsets94

  columns: [id, function, args, expected]
  rows:
    - [algorithms_available_class,   algorithms_available.__class__.__name__.__eq__,  ["set"], true]
    - [algorithms_guaranteed_class,  algorithms_guaranteed.__class__.__name__.__eq__,  ["set"], true]
    - [algorithms_available_class2,  algorithms_available.__class__.__name__.__eq__,  ["set"], true]
    - [algorithms_guaranteed_class2, algorithms_guaranteed.__class__.__name__.__eq__,  ["set"], true]

# ---------------------------------------------------------------------------
# 'sha256' in algorithms_guaranteed
# 'sha512' in algorithms_guaranteed
# 'sha1' in algorithms_guaranteed
# 'md5' in algorithms_guaranteed
# 'sha224' in algorithms_guaranteed
# 'sha384' in algorithms_guaranteed
#
# Wave 256 theme: core algorithm membership in algorithms_guaranteed.
#
# The core cryptographic algorithms sha256, sha512, sha1, md5, sha224, and sha384
# are all guaranteed to be present in hashlib.algorithms_guaranteed across all
# Python 3.x implementations. Their membership is checked via __contains__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra94.alg_guaranteed_core_membership:
  description: "algorithms_guaranteed.__contains__('sha256')==True / __contains__('sha512')==True / __contains__('sha1')==True / __contains__('md5')==True / __contains__('sha224')==True / __contains__('sha384')==True — core hash algorithms sha256/sha512/sha1/md5/sha224/sha384 are guaranteed present in hashlib across all Python 3 implementations; first hashlibalgsets94 anchor for algorithms_guaranteed core membership"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibalgsets94

  columns: [id, function, args, expected]
  rows:
    - [guaranteed_has_sha256,  algorithms_guaranteed.__contains__,  ["sha256"],  true]
    - [guaranteed_has_sha512,  algorithms_guaranteed.__contains__,  ["sha512"],  true]
    - [guaranteed_has_sha1,    algorithms_guaranteed.__contains__,  ["sha1"],    true]
    - [guaranteed_has_md5,     algorithms_guaranteed.__contains__,  ["md5"],     true]
    - [guaranteed_has_sha224,  algorithms_guaranteed.__contains__,  ["sha224"],  true]
    - [guaranteed_has_sha384,  algorithms_guaranteed.__contains__,  ["sha384"],  true]

# ---------------------------------------------------------------------------
# 'sha3_256' in algorithms_guaranteed
# 'sha3_512' in algorithms_guaranteed
# 'blake2b' in algorithms_guaranteed
# 'blake2s' in algorithms_guaranteed
#
# Wave 256 theme: newer algorithm membership in algorithms_guaranteed.
#
# The SHA-3 and BLAKE2 algorithms sha3_256, sha3_512, blake2b, and blake2s
# are all guaranteed present in Python 3.6+ implementations. Their membership
# is checked via __contains__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra94.alg_guaranteed_newer_membership:
  description: "algorithms_guaranteed.__contains__('sha3_256')==True / __contains__('sha3_512')==True / __contains__('blake2b')==True / __contains__('blake2s')==True — newer hash algorithms sha3_256/sha3_512/blake2b/blake2s are guaranteed present in Python 3.6+ hashlib; first hashlibalgsets94 anchor for algorithms_guaranteed newer algorithm membership"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibalgsets94

  columns: [id, function, args, expected]
  rows:
    - [guaranteed_has_sha3_256,  algorithms_guaranteed.__contains__,  ["sha3_256"],  true]
    - [guaranteed_has_sha3_512,  algorithms_guaranteed.__contains__,  ["sha3_512"],  true]
    - [guaranteed_has_blake2b,   algorithms_guaranteed.__contains__,  ["blake2b"],   true]
    - [guaranteed_has_blake2s,   algorithms_guaranteed.__contains__,  ["blake2s"],   true]

# ---------------------------------------------------------------------------
# hashlib.sha256/__class__/__name__.__eq__('builtin_function_or_method')
# hashlib.sha512/__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha1/__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.md5/__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 256 theme: hashlib constructor function __class__.__name__ identity.
#
# The hashlib constructor shortcuts sha256, sha512, sha1, and md5 are all
# C-level builtin_function_or_method objects. Their __class__.__name__ is
# 'builtin_function_or_method'. hashlib_extra92 anchors __qualname__ and
# __module__; this table anchors __class__.__name__ under hashlibalgsets94.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra94.constructor_class_names:
  description: "hashlib.sha256/__class__.__name__.__eq__('builtin_function_or_method')==True / sha512/__class__.__name__.__eq__('builtin_function_or_method')==True / sha1/__class__.__name__.__eq__('builtin_function_or_method')==True / md5/__class__.__name__.__eq__('builtin_function_or_method')==True — sha256/sha512/sha1/md5 are C-level builtin_function_or_method objects; hashlib_extra92 anchors __qualname__/__module__; this table anchors __class__.__name__; first hashlibalgsets94 anchor for constructor class identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibalgsets94

  columns: [id, function, args, expected]
  rows:
    - [sha256_class_builtin,  sha256.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [sha512_class_builtin,  sha512.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [sha1_class_builtin,    sha1.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [md5_class_builtin,     md5.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# hashlib.algorithms_available/__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_available is a plain Python set. Its __class__.__name__
# is 'set'. No prior hashlib spec anchors algorithms_available.__class__.__name__.__eq__
# as a standalone under hashlibalgsets94. First standalone for algorithms_available
# class identity. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra94.algorithms_available_class:
  description: "hashlib.algorithms_available.__class__.__name__.__eq__('set') == True — algorithms_available is a plain Python set containing all hash algorithm names available on the current platform; its __class__.__name__ is 'set'; no prior hashlib spec anchors this __eq__ call; first standalone for algorithms_available class identity under hashlibalgsets94"
  category: type_identity
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed/__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_guaranteed is a plain Python set. Its __class__.__name__
# is 'set'. No prior hashlib spec anchors algorithms_guaranteed.__class__.__name__.__eq__
# as a standalone under hashlibalgsets94. First standalone for algorithms_guaranteed
# class identity. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra94.algorithms_guaranteed_class:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True — algorithms_guaranteed is a plain Python set containing hash algorithm names guaranteed on all Python 3 implementations; its __class__.__name__ is 'set'; no prior hashlib spec anchors this __eq__ call; first standalone for algorithms_guaranteed class identity under hashlibalgsets94"
  category: type_identity
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# 'sha256' in hashlib.algorithms_guaranteed — standalone
#
# 'sha256' is in hashlib.algorithms_guaranteed. The SHA-256 algorithm is
# mandated to be present in all Python 3 hashlib implementations. No prior
# hashlib spec anchors algorithms_guaranteed.__contains__('sha256') as a
# standalone under hashlibalgsets94. First standalone for sha256 membership.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra94.guaranteed_has_sha256:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256') == True — sha256 is guaranteed present in hashlib.algorithms_guaranteed across all Python 3 implementations; it is the most widely used secure hash algorithm; no prior hashlib spec anchors this __contains__ call; first standalone for sha256 in algorithms_guaranteed under hashlibalgsets94"
  category: type_identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# 'blake2b' in hashlib.algorithms_guaranteed — standalone
#
# 'blake2b' is in hashlib.algorithms_guaranteed. BLAKE2b is guaranteed present
# in Python 3.6+ hashlib. No prior hashlib spec anchors
# algorithms_guaranteed.__contains__('blake2b') as a standalone under
# hashlibalgsets94. First standalone for blake2b membership.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra94.guaranteed_has_blake2b:
  description: "hashlib.algorithms_guaranteed.__contains__('blake2b') == True — blake2b is guaranteed present in hashlib.algorithms_guaranteed in Python 3.6+; it is the 512-bit BLAKE2 variant optimised for 64-bit platforms; no prior hashlib spec anchors this __contains__ call; first standalone for blake2b in algorithms_guaranteed under hashlibalgsets94"
  category: type_identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256/__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.sha256 is a C-level builtin_function_or_method. Its __class__.__name__
# is 'builtin_function_or_method'. No prior hashlib spec anchors this exact
# sha256.__class__.__name__.__eq__ call as a standalone under hashlibalgsets94.
# First standalone for sha256 constructor class identity.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra94.sha256_class_builtin:
  description: "hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method') == True — hashlib.sha256 is a C-level shortcut function implemented in the _hashlib C extension; its __class__.__name__ is 'builtin_function_or_method'; hashlib_extra92 anchors __qualname__/__module__ for sha256; this standalone anchors __class__.__name__; first standalone for sha256 constructor class identity under hashlibalgsets94"
  category: type_identity
  kind: python_call_eq
  function: sha256.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
