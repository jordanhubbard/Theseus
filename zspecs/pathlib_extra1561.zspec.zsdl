spec: pathlib_extra1561
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 551 (_extra1561): numeric type conversion protocol dict-presence checks for pathlib classes."
    - "pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path are not numeric types."
    - "None of these classes define __bool__, __int__, __float__, __complex__, __index__, __trunc__, __floor__, __ceil__, or __round__ in their own __dict__."
    - "pathlib.PurePath.__dict__ contains path-specific dunders: __bytes__, __eq__, __fspath__, __ge__, __gt__, __hash__, __init__, __le__, __lt__, __new__, __reduce__, __repr__, __rtruediv__, __slots__, __str__, __truediv__."
    - "pathlib.Path.__dict__ contains: __doc__, __firstlineno__, __module__, __new__, __slots__, __static_attributes__."
    - "pathlib.PurePosixPath and PureWindowsPath define no numeric conversion dunders in their own __dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePath — numeric type conversion protocol dict-presence (all False)
# ---------------------------------------------------------------------------

table pathlib_extra1561.purepath_numeric_protocol:
  description: "pathlib.PurePath.__dict__ does not contain any numeric type conversion dunder"
  kind: python_call_eq
  category: numeric_presence
  id_prefix: pl1561pp

  columns: [id, function, args, expected]
  rows:
    - [pl1561pp001, pathlib.PurePath.__dict__.__contains__, ["__bool__"],    false]
    - [pl1561pp002, pathlib.PurePath.__dict__.__contains__, ["__int__"],     false]
    - [pl1561pp003, pathlib.PurePath.__dict__.__contains__, ["__float__"],   false]
    - [pl1561pp004, pathlib.PurePath.__dict__.__contains__, ["__complex__"], false]
    - [pl1561pp005, pathlib.PurePath.__dict__.__contains__, ["__index__"],   false]
    - [pl1561pp006, pathlib.PurePath.__dict__.__contains__, ["__trunc__"],   false]
    - [pl1561pp007, pathlib.PurePath.__dict__.__contains__, ["__floor__"],   false]
    - [pl1561pp008, pathlib.PurePath.__dict__.__contains__, ["__ceil__"],    false]
    - [pl1561pp009, pathlib.PurePath.__dict__.__contains__, ["__round__"],   false]

