spec: pathlib_extra340
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All invariants use PurePosixPath — a pure, platform-independent class requiring no filesystem access."
    - "PurePosixPath objects support comparison operators (__eq__, __lt__, __gt__) lexicographically by string representation."
    - "__hash__() returns an int — PurePosixPath objects are hashable."
    - "__str__() returns the POSIX string form of the path."
    - "__repr__() returns a string containing 'PurePosixPath' and the quoted path."
    - "PurePosixPath('/a/b/c').parents.__class__.__name__ == '_PathParents' — verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __eq__ — path equality comparison
# ---------------------------------------------------------------------------

invariant pathlib_extra340.PurePosixPath.eq.true:
  description: "PurePosixPath('/a/b').__eq__(PurePosixPath('/a/b')) == True — identical paths are equal"
  category: comparison
  kind: python_call_eq
  function: "PurePosixPath('/a/b').__eq__"
  args: ["/a/b"]
  expected: true

# ---------------------------------------------------------------------------
# __lt__ — path less-than comparison
# ---------------------------------------------------------------------------

invariant pathlib_extra340.PurePosixPath.lt.true:
  description: "PurePosixPath('/a/b').__lt__(PurePosixPath('/a/c')) == True — '/a/b' sorts before '/a/c'"
  category: comparison
  kind: python_call_eq
  function: "PurePosixPath('/a/b').__lt__"
  args: ["/a/c"]
  expected: true

# ---------------------------------------------------------------------------
# __gt__ — path greater-than comparison
# ---------------------------------------------------------------------------

invariant pathlib_extra340.PurePosixPath.gt.true:
  description: "PurePosixPath('/a/b').__gt__(PurePosixPath('/a/a')) == True — '/a/b' sorts after '/a/a'"
  category: comparison
  kind: python_call_eq
  function: "PurePosixPath('/a/b').__gt__"
  args: ["/a/a"]
  expected: true

# ---------------------------------------------------------------------------
# __hash__() — returns an int
# ---------------------------------------------------------------------------

invariant pathlib_extra340.PurePosixPath.hash.class_name:
  description: "PurePosixPath('/a/b').__hash__().__class__.__name__ == 'int' — hash value is an integer"
  category: hashing
  kind: python_call_eq
  function: "PurePosixPath('/a/b').__hash__().__class__.__name__.__eq__"
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# __str__() — POSIX string representation
# ---------------------------------------------------------------------------

invariant pathlib_extra340.PurePosixPath.str.eq:
  description: "PurePosixPath('/a/b').__str__().__eq__('/a/b') == True — __str__ returns the POSIX path string"
  category: string_repr
  kind: python_call_eq
  function: "PurePosixPath('/a/b').__str__().__eq__"
  args: ["/a/b"]
  expected: true

# ---------------------------------------------------------------------------
# __repr__() — contains 'PurePosixPath'
# ---------------------------------------------------------------------------

invariant pathlib_extra340.PurePosixPath.repr.contains:
  description: "PurePosixPath('/a/b').__repr__().__contains__('PurePosixPath') == True — repr includes the class name"
  category: string_repr
  kind: python_call_eq
  function: "PurePosixPath('/a/b').__repr__().__contains__"
  args: ["PurePosixPath"]
  expected: true

# ---------------------------------------------------------------------------
# .parents — class name is '_PathParents'
# ---------------------------------------------------------------------------

invariant pathlib_extra340.PurePosixPath.parents.class_name:
  description: "PurePosixPath('/a/b/c').parents.__class__.__name__ == '_PathParents' — the parents sequence is a _PathParents object"
  category: components
  kind: python_call_eq
  function: "PurePosixPath('/a/b/c').parents.__class__.__name__.__eq__"
  args: ["_PathParents"]
  expected: true
