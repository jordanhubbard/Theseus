spec: pathlib_extra277
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "pathlib.PurePath.drive, root, anchor, name, suffix, suffixes, stem, parent, parents are all Python property objects."
    - "Each property has a fget function whose __name__ matches the property name."
    - "Each fget __qualname__ follows the 'PurePath.<prop_name>' pattern."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: PurePath property type names (all 'property')
# ---------------------------------------------------------------------------

table pathlib_extra277.purepath_property_types:
  description: "pathlib.PurePath property attributes: drive, root, anchor, name, suffix, suffixes, stem, parent, parents all have type 'property'"
  kind: python_call_eq
  category: identity
  id_prefix: pt

  columns: [id, function, args, expected, description]
  rows:
    - [drive_type,   PurePath.drive.__class__.__name__.__eq__,   ["property"], true, "type(pathlib.PurePath.drive).__name__ == 'property'"]
    - [root_type,    PurePath.root.__class__.__name__.__eq__,    ["property"], true, "type(pathlib.PurePath.root).__name__ == 'property'"]
    - [anchor_type,  PurePath.anchor.__class__.__name__.__eq__,  ["property"], true, "type(pathlib.PurePath.anchor).__name__ == 'property'"]
    - [name_type,    PurePath.name.__class__.__name__.__eq__,    ["property"], true, "type(pathlib.PurePath.name).__name__ == 'property'"]
    - [suffix_type,  PurePath.suffix.__class__.__name__.__eq__,  ["property"], true, "type(pathlib.PurePath.suffix).__name__ == 'property'"]
    - [suffixes_type, PurePath.suffixes.__class__.__name__.__eq__, ["property"], true, "type(pathlib.PurePath.suffixes).__name__ == 'property'"]
    - [stem_type,    PurePath.stem.__class__.__name__.__eq__,    ["property"], true, "type(pathlib.PurePath.stem).__name__ == 'property'"]
    - [parent_type,  PurePath.parent.__class__.__name__.__eq__,  ["property"], true, "type(pathlib.PurePath.parent).__name__ == 'property'"]
    - [parents_type, PurePath.parents.__class__.__name__.__eq__, ["property"], true, "type(pathlib.PurePath.parents).__name__ == 'property'"]

# ---------------------------------------------------------------------------
# Table: PurePath property fget __name__ values
# ---------------------------------------------------------------------------

table pathlib_extra277.purepath_property_fget_names:
  description: "pathlib.PurePath property fget __name__ for drive, root, anchor, name, suffix, suffixes, stem, parent, parents"
  kind: python_call_eq
  category: identity
  id_prefix: fn

  columns: [id, function, args, expected, description]
  rows:
    - [drive_fget_name,    PurePath.drive.fget.__name__.__eq__,    ["drive"],    true, "pathlib.PurePath.drive.fget.__name__ == 'drive'"]
    - [root_fget_name,     PurePath.root.fget.__name__.__eq__,     ["root"],     true, "pathlib.PurePath.root.fget.__name__ == 'root'"]
    - [anchor_fget_name,   PurePath.anchor.fget.__name__.__eq__,   ["anchor"],   true, "pathlib.PurePath.anchor.fget.__name__ == 'anchor'"]
    - [name_fget_name,     PurePath.name.fget.__name__.__eq__,     ["name"],     true, "pathlib.PurePath.name.fget.__name__ == 'name'"]
    - [suffix_fget_name,   PurePath.suffix.fget.__name__.__eq__,   ["suffix"],   true, "pathlib.PurePath.suffix.fget.__name__ == 'suffix'"]
    - [suffixes_fget_name, PurePath.suffixes.fget.__name__.__eq__, ["suffixes"], true, "pathlib.PurePath.suffixes.fget.__name__ == 'suffixes'"]
    - [stem_fget_name,     PurePath.stem.fget.__name__.__eq__,     ["stem"],     true, "pathlib.PurePath.stem.fget.__name__ == 'stem'"]
    - [parent_fget_name,   PurePath.parent.fget.__name__.__eq__,   ["parent"],   true, "pathlib.PurePath.parent.fget.__name__ == 'parent'"]
    - [parents_fget_name,  PurePath.parents.fget.__name__.__eq__,  ["parents"],  true, "pathlib.PurePath.parents.fget.__name__ == 'parents'"]

# ---------------------------------------------------------------------------
# Standalone invariants: fget qualnames
# ---------------------------------------------------------------------------

invariant pathlib_extra277.PurePath.drive.fget.qualname:
  description: "pathlib.PurePath.drive.fget.__qualname__ == 'PurePath.drive'"
  category: identity
  kind: python_call_eq
  function: PurePath.drive.fget.__qualname__.__eq__
  args: ["PurePath.drive"]
  expected: true

