spec: json_extra19
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json.zspec.zsdl and prior extras through json_extra18.zspec.zsdl."
    - "json_extra18 covers: JSONEncoder encode/iterencode/default __module__; JSONDecoder decode/raw_decode __module__."
    - "json_extra17 covers: JSONEncoder encode/iterencode/default __qualname__; JSONDecoder decode/raw_decode __qualname__."
    - "json_extra16 covers: JSONEncoder/__qualname__; JSONDecoder/__qualname__; JSONDecodeError/__qualname__."
    - "json_extra15 covers: JSONDecodeError/__module__; JSONEncoder/__module__; JSONDecoder/__module__."
    - "json_extra12 covers: JSONEncoder/JSONDecoder __module__; JSONDecodeError __bases__[0].__name__."
    - "json_extra8 covers: JSONDecoder/JSONEncoder __bases__[0].__name__."
    - "Focus: __qualname__ and __module__ for JSONEncoder.__init__ and JSONDecoder.__init__."
    - "No prior json spec checks JSONEncoder.__init__.__qualname__."
    - "No prior json spec checks JSONDecoder.__init__.__qualname__."
    - "No prior json spec checks JSONEncoder.__init__.__module__."
    - "No prior json spec checks JSONDecoder.__init__.__module__."
    - "json.JSONEncoder.__init__.__qualname__ == 'JSONEncoder.__init__' — compound dunder method qualname."
    - "json.JSONDecoder.__init__.__qualname__ == 'JSONDecoder.__init__' — compound dunder method qualname."
    - "json.JSONEncoder.__init__.__module__ == 'json.encoder' — __init__ defined in json/encoder.py."
    - "json.JSONDecoder.__init__.__module__ == 'json.decoder' — __init__ defined in json/decoder.py."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# JSONEncoder.__init__ and JSONDecoder.__init__ — __qualname__ and __module__
#
# json_extra16 checks JSONEncoder.__qualname__ == 'JSONEncoder' for the class.
# json_extra17 checks encode, iterencode, and default __qualname__ values.
# json_extra18 checks encode, iterencode, default, decode, and raw_decode
# __module__ values.
# No prior json spec checks __qualname__ or __module__ for __init__ on either
# class.  Methods defined in a class carry the __qualname__ 'ClassName.__init__'
# and the __module__ of the defining submodule.
# ---------------------------------------------------------------------------

invariant json_extra19.JSONEncoder.__init__.qualname:
  description: "json.JSONEncoder.__init__.__qualname__ == 'JSONEncoder.__init__' — compound dunder method qualname"
  category: method_attrs
  kind: python_call_eq
  function: "JSONEncoder.__init__.__qualname__.__eq__"
  args: ["JSONEncoder.__init__"]
  expected: true

invariant json_extra19.JSONDecoder.__init__.qualname:
  description: "json.JSONDecoder.__init__.__qualname__ == 'JSONDecoder.__init__' — compound dunder method qualname"
  category: method_attrs
  kind: python_call_eq
  function: "JSONDecoder.__init__.__qualname__.__eq__"
  args: ["JSONDecoder.__init__"]
  expected: true

invariant json_extra19.JSONEncoder.__init__.module:
  description: "json.JSONEncoder.__init__.__module__ == 'json.encoder' — __init__ lives in the json.encoder submodule"
  category: method_attrs
  kind: python_call_eq
  function: "JSONEncoder.__init__.__module__.__eq__"
  args: ["json.encoder"]
  expected: true

invariant json_extra19.JSONDecoder.__init__.module:
  description: "json.JSONDecoder.__init__.__module__ == 'json.decoder' — __init__ lives in the json.decoder submodule"
  category: method_attrs
  kind: python_call_eq
  function: "JSONDecoder.__init__.__module__.__eq__"
  args: ["json.decoder"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table: JSONEncoder and JSONDecoder __init__ qualname and module
#
# All four invariants are first covered in this spec (json_extra19).
# ---------------------------------------------------------------------------

table json_extra19.init_method_attrs:
  description: "json JSONEncoder/JSONDecoder __init__ method __qualname__ and __module__"
  kind: python_call_eq
  category: method_attrs
  id_prefix: jin19

  columns: [id, function, args, expected]
  rows:
    - [encoder_init_qn,  "JSONEncoder.__init__.__qualname__.__eq__", ["JSONEncoder.__init__"], true]
    - [decoder_init_qn,  "JSONDecoder.__init__.__qualname__.__eq__", ["JSONDecoder.__init__"], true]
    - [encoder_init_mod, "JSONEncoder.__init__.__module__.__eq__",   ["json.encoder"],         true]
    - [decoder_init_mod, "JSONDecoder.__init__.__module__.__eq__",   ["json.decoder"],         true]
