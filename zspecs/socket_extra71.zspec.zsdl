spec: socket_extra71
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra70.zspec.zsdl — covers socket.socket.accept/__qualname__=='socket.accept' / accept/__class__/__name__=='function' / connect/__qualname__=='socket.connect' / bind/__qualname__=='socket.bind' / listen/__qualname__=='socket.listen' / AF_INET/__class__/__name__=='AddressFamily' / SOCK_STREAM/__class__/__name__=='SocketKind' / connect/bind/__class__/__name__=='method_descriptor' (table + invariants)."
    - "socket_extra69.zspec.zsdl — covers socket module __name__/__spec__.name/__spec__.__class__/__loader__.__class__ / socket.socket.__dict__.__class__=='mappingproxy' / socket.__dict__.__contains__ accept/makefile/setblocking/settimeout (table + invariants)."
    - "socket_extra68.zspec.zsdl — covers socket.connect/bind/sendall/recv __class__/__name__=='method_descriptor' / __qualname__ eq and len / socket.__doc__/__class__/__name__=='str' (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra70; it does NOT duplicate invariants present in those files."
    - "Wave 238 theme: socket exception hierarchy + gaierror/herror/timeout identity."
    - "socket.gaierror.__name__ == 'gaierror' — the exception class name. No prior socket spec checks gaierror.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__module__ == 'socket' — gaierror is defined in Lib/socket.py. No prior socket spec checks gaierror.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__bases__[0].__name__ == 'OSError' — gaierror inherits directly from OSError. No prior socket spec checks gaierror.__bases__[0].__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__mro__.__len__() == 5 — MRO is [gaierror, OSError, Exception, BaseException, object]. No prior socket spec checks gaierror.__mro__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__name__ == 'herror' — the exception class name. No prior socket spec checks herror.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__module__ == 'socket' — herror is defined in Lib/socket.py. No prior socket spec checks herror.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__bases__[0].__name__ == 'OSError' — herror inherits directly from OSError. No prior socket spec checks herror.__bases__[0].__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__name__ == 'TimeoutError' — in Python 3.11+, socket.timeout is an alias for the built-in TimeoutError. Its __name__ is 'TimeoutError'. No prior socket spec checks timeout.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__bases__[0].__name__ == 'OSError' — TimeoutError inherits directly from OSError. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__name__ == 'OSError' — socket.error is an alias for the built-in OSError; __name__ is 'OSError'. No prior socket spec checks error.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.gaierror __name__ and __module__
#
# Wave 238 theme: gaierror exception class identity.
#
# socket.gaierror is the exception raised for address-related errors returned
# by getaddrinfo() and getnameinfo(). Its __name__ is 'gaierror' and its
# __module__ is 'socket'. No prior socket spec checks gaierror.__name__ or
# gaierror.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra71.gaierror_name_module:
  description: "socket.gaierror/__name__.__eq__('gaierror')==True / gaierror/__module__.__eq__('socket')==True — gaierror is the exception for address-related errors; defined in Lib/socket.py; no prior socket spec checks gaierror.__name__ or gaierror.__module__; first name+module anchor for socket.gaierror"
  kind: python_call_eq
  category: error_class
  id_prefix: socketmore71

  columns: [id, function, args, expected]
  rows:
    - [gaierror_name_gaierror,   gaierror.__name__.__eq__,   ["gaierror"], true]
    - [gaierror_module_socket,   gaierror.__module__.__eq__,  ["socket"],   true]

# ---------------------------------------------------------------------------
# socket.gaierror base class and MRO length
#
# Wave 238 theme: gaierror exception hierarchy.
#
# socket.gaierror inherits directly from OSError. Its MRO is
# [gaierror, OSError, Exception, BaseException, object] — length 5.
# No prior socket spec checks gaierror.__bases__[0].__name__ or
# gaierror.__mro__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra71.gaierror_hierarchy:
  description: "socket.gaierror/__bases__[0].__name__.__eq__('OSError')==True / gaierror/__mro__.__len__()==5 — gaierror inherits directly from OSError; MRO is [gaierror, OSError, Exception, BaseException, object]; no prior socket spec checks gaierror.__bases__[0].__name__ or gaierror.__mro__.__len__(); first hierarchy anchor for socket.gaierror"
  kind: python_call_eq
  category: error_class
  id_prefix: socketmore71

  columns: [id, function, args, expected]
  rows:
    - [gaierror_bases0_OSError, "gaierror.__bases__[0].__name__.__eq__", ["OSError"], true]
    - [gaierror_mro_len_5,       gaierror.__mro__.__len__,                [],          5]

# ---------------------------------------------------------------------------
# socket.herror __name__ / __module__ / base class
#
# Wave 238 theme: herror exception class identity and hierarchy.
#
# socket.herror is raised for host-related address errors. Its __name__ is
# 'herror', __module__ is 'socket', and it inherits directly from OSError.
# No prior socket spec checks herror.__name__, herror.__module__, or
# herror.__bases__[0].__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra71.herror_identity:
  description: "socket.herror/__name__.__eq__('herror')==True / herror/__module__.__eq__('socket')==True / herror/__bases__[0].__name__.__eq__('OSError')==True — herror is defined in Lib/socket.py and inherits from OSError; no prior socket spec checks herror.__name__, __module__, or __bases__[0].__name__; first identity+hierarchy anchor for socket.herror"
  kind: python_call_eq
  category: error_class
  id_prefix: socketmore71

  columns: [id, function, args, expected]
  rows:
    - [herror_name_herror,      herror.__name__.__eq__,   ["herror"], true]
    - [herror_module_socket,    herror.__module__.__eq__,  ["socket"], true]
    - [herror_bases0_OSError,   "herror.__bases__[0].__name__.__eq__", ["OSError"], true]

# ---------------------------------------------------------------------------
# socket.timeout and socket.error __name__
#
# Wave 238 theme: socket.timeout and socket.error alias identity.
#
# In Python 3.11+, socket.timeout is an alias for the built-in TimeoutError.
# Its __name__ is 'TimeoutError' (not 'timeout'). socket.error is an alias
# for the built-in OSError; its __name__ is 'OSError'. No prior socket spec
# checks timeout.__name__ or error.__name__. Verified Python 3.14.3 macOS/Darwin.
# ---------------------------------------------------------------------------

table socket_extra71.timeout_error_names:
  description: "socket.timeout/__name__.__eq__('TimeoutError')==True / socket.error/__name__.__eq__('OSError')==True — socket.timeout is an alias for built-in TimeoutError in Python 3.11+; socket.error is an alias for built-in OSError; no prior socket spec checks timeout.__name__ or error.__name__; first __name__ anchor for socket.timeout and socket.error aliases"
  kind: python_call_eq
  category: error_class
  id_prefix: socketmore71

  columns: [id, function, args, expected]
  rows:
    - [timeout_name_TimeoutError, timeout.__name__.__eq__, ["TimeoutError"], true]
    - [error_name_OSError,        error.__name__.__eq__,   ["OSError"],      true]

# ---------------------------------------------------------------------------
# socket.gaierror.__name__.__eq__('gaierror') — standalone
#
# socket.gaierror is the exception for address-related errors. Its __name__
# is 'gaierror'. No prior socket spec checks gaierror.__name__. First __name__
# standalone for socket.gaierror. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra71.gaierror_name:
  description: "socket.gaierror.__name__.__eq__('gaierror') == True — gaierror is the exception for address-related errors; __name__ is 'gaierror'; no prior socket spec checks gaierror.__name__; first __name__ standalone for socket.gaierror"
  category: error_class
  kind: python_call_eq
  function: gaierror.__name__.__eq__
  args: ["gaierror"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gaierror.__mro__.__len__() == 5 — standalone
#
# socket.gaierror MRO is [gaierror, OSError, Exception, BaseException, object]
# — length 5. No prior socket spec checks gaierror.__mro__.__len__(). First
# MRO length standalone for socket.gaierror. Verified Python 3.14.3 macOS/Darwin.
# ---------------------------------------------------------------------------

invariant socket_extra71.gaierror_mro_len:
  description: "socket.gaierror.__mro__.__len__() == 5 — MRO is [gaierror, OSError, Exception, BaseException, object]; no prior socket spec checks gaierror.__mro__.__len__(); first MRO length standalone for socket.gaierror"
  category: error_class
  kind: python_call_eq
  function: gaierror.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# socket.herror.__name__.__eq__('herror') — standalone
#
# socket.herror is the exception for host-related address errors. Its __name__
# is 'herror'. No prior socket spec checks herror.__name__. First __name__
# standalone for socket.herror. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra71.herror_name:
  description: "socket.herror.__name__.__eq__('herror') == True — herror is the exception for host-related address errors; __name__ is 'herror'; no prior socket spec checks herror.__name__; first __name__ standalone for socket.herror"
  category: error_class
  kind: python_call_eq
  function: herror.__name__.__eq__
  args: ["herror"]
  expected: true

# ---------------------------------------------------------------------------
# socket.timeout.__name__.__eq__('TimeoutError') — standalone
#
# socket.timeout is an alias for the built-in TimeoutError in Python 3.11+.
# Its __name__ is 'TimeoutError'. No prior socket spec checks timeout.__name__.
# First __name__ standalone for socket.timeout.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra71.timeout_name_TimeoutError:
  description: "socket.timeout.__name__.__eq__('TimeoutError') == True — socket.timeout is an alias for the built-in TimeoutError in Python 3.11+; __name__ is 'TimeoutError' (not 'timeout'); no prior socket spec checks timeout.__name__; first __name__ standalone for socket.timeout"
  category: error_class
  kind: python_call_eq
  function: timeout.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.error.__name__.__eq__('OSError') — standalone
#
# socket.error is an alias for the built-in OSError. Its __name__ is 'OSError'.
# No prior socket spec checks error.__name__. First __name__ standalone for
# socket.error. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra71.error_name_OSError:
  description: "socket.error.__name__.__eq__('OSError') == True — socket.error is an alias for the built-in OSError; __name__ is 'OSError'; no prior socket spec checks error.__name__; first __name__ standalone for socket.error"
  category: error_class
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true
