spec: struct_extra2176
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/struct.html"
    - "CPython source: Modules/_struct.c"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2176: iterator/sequence protocol dict-presence — __iter__, __next__, __aiter__, __anext__, __await__, __length_hint__, __reversed__, __missing__."
    - "struct.Struct is a C extension type for compiled format strings. It is not an iterator, awaitable, or mapping."
    - "struct.error is a plain exception subclass with an empty own __dict__ (no methods defined directly on it)."
    - "Neither struct.Struct nor struct.error defines any of the 8 iterator/sequence protocol dunders in its own __dict__."
    - "struct.Struct.__dict__ contains: pack, unpack, pack_into, unpack_from, iter_unpack, format, size, __sizeof__."
    - "struct.error.__dict__ contains: __module__, __weakref__, __doc__ — nothing else."
    - "All expected values (false) verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2176.struct_iterator_protocol:
  description: "struct.Struct iterator/sequence protocol dict-presence — Struct is a C extension format-compiler type, not an iterator or awaitable"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2176

  columns: [id, function, args, expected]
  rows:
    - ["st2176001", "struct.Struct.__dict__.__contains__", ["__iter__"], false]
    - ["st2176002", "struct.Struct.__dict__.__contains__", ["__next__"], false]
    - ["st2176003", "struct.Struct.__dict__.__contains__", ["__aiter__"], false]
    - ["st2176004", "struct.Struct.__dict__.__contains__", ["__anext__"], false]
    - ["st2176005", "struct.Struct.__dict__.__contains__", ["__await__"], false]
    - ["st2176006", "struct.Struct.__dict__.__contains__", ["__length_hint__"], false]
    - ["st2176007", "struct.Struct.__dict__.__contains__", ["__reversed__"], false]
    - ["st2176008", "struct.Struct.__dict__.__contains__", ["__missing__"], false]

table struct_extra2176.error_iterator_protocol:
  description: "struct.error iterator/sequence protocol dict-presence — error is a plain exception subclass, not an iterator or awaitable"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2176

  columns: [id, function, args, expected]
  rows:
    - ["st2176009", "struct.error.__dict__.__contains__", ["__iter__"], false]
    - ["st2176010", "struct.error.__dict__.__contains__", ["__next__"], false]
    - ["st2176011", "struct.error.__dict__.__contains__", ["__aiter__"], false]
    - ["st2176012", "struct.error.__dict__.__contains__", ["__anext__"], false]
    - ["st2176013", "struct.error.__dict__.__contains__", ["__await__"], false]
    - ["st2176014", "struct.error.__dict__.__contains__", ["__length_hint__"], false]
    - ["st2176015", "struct.error.__dict__.__contains__", ["__reversed__"], false]
    - ["st2176016", "struct.error.__dict__.__contains__", ["__missing__"], false]

table struct_extra2176.struct_dict_keys:
  description: "struct.Struct.__dict__ positive presence — known C-extension method and attribute keys are present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2176

  columns: [id, function, args, expected]
  rows:
    - ["st2176017", "struct.Struct.__dict__.__contains__", ["pack"], true]
    - ["st2176018", "struct.Struct.__dict__.__contains__", ["unpack"], true]
    - ["st2176019", "struct.Struct.__dict__.__contains__", ["pack_into"], true]
    - ["st2176020", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st2176021", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st2176022", "struct.Struct.__dict__.__contains__", ["format"], true]
    - ["st2176023", "struct.Struct.__dict__.__contains__", ["size"], true]
    - ["st2176024", "struct.Struct.__dict__.__contains__", ["__sizeof__"], true]

table struct_extra2176.error_dict_keys:
  description: "struct.error.__dict__ positive presence — minimal own keys (__module__, __weakref__, __doc__) are present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2176

  columns: [id, function, args, expected]
  rows:
    - ["st2176025", "struct.error.__dict__.__contains__", ["__module__"], true]
    - ["st2176026", "struct.error.__dict__.__contains__", ["__weakref__"], true]
    - ["st2176027", "struct.error.__dict__.__contains__", ["__doc__"], true]
    - ["st2176028", "struct.error.__dict__.__contains__", ["__init__"], false]
    - ["st2176029", "struct.error.__dict__.__contains__", ["pack"], false]
    - ["st2176030", "struct.error.__dict__.__contains__", ["format"], false]
