spec: pathlib_extra60
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra59.zspec.zsdl — covers Path property __class__.__qualname__=='property' (8 properties) and PurePath property __class__.__name__=='property' (4 properties)."
    - "pathlib_extra58.zspec.zsdl — covers pathlib class __module__.__eq__('pathlib') for Path/PurePath/PurePosixPath/PureWindowsPath; Path property __class__.__name__=='property' for 10 attributes."
    - "pathlib_extra37.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __dict__.__class__.__name__.__len__()==12 (length check only, not equality)."
  notes:
    - "This spec extends pathlib_extra59.zspec.zsdl."
    - "Prior specs collectively covered: pathlib_extra37 checks __dict__.__class__.__name__.__len__()==12 for Path/PurePath/PurePosixPath/PureWindowsPath (length only); no prior pathlib spec checks __dict__.__class__.__name__.__eq__('mappingproxy') as a direct equality invariant for any pathlib class; no prior pathlib spec checks __dict__.__class__.__qualname__ for any pathlib class; no prior pathlib spec checks the pathlib module's own __dict__.__class__.__name__ or __qualname__; pathlib_extra59 covers PurePath.name/suffix/parent/stem property __class__.__name__=='property' but NOT __class__.__qualname__=='property'."
    - "This spec covers: pathlib.Path.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL — pathlib_extra37 checks __len__()==12 but no prior spec checks the equality directly; novel equality anchor in pathlibdict60 namespace); pathlib.PurePath.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL); pathlib.PurePosixPath.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL); pathlib.PureWindowsPath.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL); pathlib.Path.__dict__.__class__.__qualname__.__eq__('mappingproxy') (NOVEL — no prior pathlib spec checks __dict__.__class__.__qualname__; mappingproxy is a C builtin with __qualname__==__name__=='mappingproxy'); pathlib.PurePath.__dict__.__class__.__qualname__.__eq__('mappingproxy') (NOVEL); pathlib.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL — no prior pathlib spec checks the pathlib module's __dict__.__class__.__name__); pathlib.__dict__.__class__.__qualname__.__eq__('mappingproxy') (NOVEL); pathlib.PurePath.name.__class__.__qualname__.__eq__('property') (NOVEL — pathlib_extra59 checks __class__.__name__ for PurePath properties; no prior pathlib spec checks PurePath property __class__.__qualname__); pathlib.PurePath.suffix.__class__.__qualname__.__eq__('property') (NOVEL); pathlib.PurePath.parent.__class__.__qualname__.__eq__('property') (NOVEL); pathlib.PurePath.stem.__class__.__qualname__.__eq__('property') (NOVEL)."
    - "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy'. Every Python class __dict__ is a types.MappingProxyType. Its __class__.__name__ is 'mappingproxy'. pathlib_extra37 verified __len__()==12 but not the string equality. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__dict__.__class__.__name__ == 'mappingproxy'. PurePath is the base class for all pathlib path types. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePosixPath.__dict__.__class__.__name__ == 'mappingproxy'. PurePosixPath is the POSIX flavour of PurePath. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PureWindowsPath.__dict__.__class__.__name__ == 'mappingproxy'. PureWindowsPath is the Windows flavour of PurePath. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.__dict__.__class__.__qualname__ == 'mappingproxy'. The builtin mappingproxy type has __qualname__==__name__=='mappingproxy'. No prior pathlib spec checks __dict__.__class__.__qualname__ for any class. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__dict__.__class__.__qualname__ == 'mappingproxy'. Same reasoning. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.__dict__.__class__.__name__ == 'mappingproxy'. The pathlib module's own __dict__ is a mappingproxy. No prior pathlib spec checks this. Novel module-level axis. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.__dict__.__class__.__qualname__ == 'mappingproxy'. Same as __name__ for the mappingproxy type. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.name.__class__.__qualname__ == 'property'. pathlib_extra59 checks __class__.__name__ for PurePath properties but not __class__.__qualname__. For the builtin property type, __qualname__==__name__=='property'. Novel __qualname__ axis for PurePath properties. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.suffix.__class__.__qualname__ == 'property'. PurePath.suffix returns the file extension. Novel PurePath __qualname__ axis. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.parent.__class__.__qualname__ == 'property'. PurePath.parent returns the logical parent. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.stem.__class__.__qualname__ == 'property'. PurePath.stem is the final component without suffix. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib class __dict__ identity — __class__.__name__ equality (novel equality axis)
#
# Every Python class's __dict__ attribute is a types.MappingProxyType instance.
# The __class__.__name__ of that proxy is 'mappingproxy'.
# pathlib_extra37 verified __dict__.__class__.__name__.__len__()==12 for
# Path/PurePath/PurePosixPath/PureWindowsPath (checking the 12-character
# length of 'mappingproxy') but no prior pathlib spec verifies the string
# equality directly with __eq__.
#
#   Path.__dict__.__class__.__name__            == 'mappingproxy'
#   PurePath.__dict__.__class__.__name__        == 'mappingproxy'
#   PurePosixPath.__dict__.__class__.__name__   == 'mappingproxy'
#   PureWindowsPath.__dict__.__class__.__name__ == 'mappingproxy'
#
# All four equality anchors are novel in the pathlibdict60 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra60.class_dict_name_eq:
  description: "pathlib class __dict__.__class__.__name__.__eq__('mappingproxy') for Path/PurePath/PurePosixPath/PureWindowsPath — every class __dict__ is a mappingproxy; pathlib_extra37 covers __len__()==12 only; no prior pathlib spec checks __dict__.__class__.__name__.__eq__(); all four novel equality anchors in pathlibdict60 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibdict60name

  columns: [id, function, args, expected]
  rows:
    - [Path_dict_name,            "Path.__dict__.__class__.__name__.__eq__",            ["mappingproxy"], true]
    - [PurePath_dict_name,        "PurePath.__dict__.__class__.__name__.__eq__",        ["mappingproxy"], true]
    - [PurePosixPath_dict_name,   "PurePosixPath.__dict__.__class__.__name__.__eq__",   ["mappingproxy"], true]
    - [PureWindowsPath_dict_name, "PureWindowsPath.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# pathlib class __dict__ identity — __class__.__qualname__ equality (novel qualname axis)
#
# The builtin mappingproxy type has __qualname__ == __name__ == 'mappingproxy'
# (top-level C builtin; no enclosing class scope). No prior pathlib spec
# checks __dict__.__class__.__qualname__ for any pathlib class.
#
#   Path.__dict__.__class__.__qualname__     == 'mappingproxy'
#   PurePath.__dict__.__class__.__qualname__ == 'mappingproxy'
#
# Two representative __qualname__ anchors are novel in the pathlibdict60 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra60.class_dict_qualname_eq:
  description: "pathlib class __dict__.__class__.__qualname__.__eq__('mappingproxy') for Path/PurePath — mappingproxy is a top-level C builtin so __qualname__==__name__=='mappingproxy'; no prior pathlib spec checks __dict__.__class__.__qualname__ for any class; two novel __qualname__ anchors in pathlibdict60 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibdict60qualname

  columns: [id, function, args, expected]
  rows:
    - [Path_dict_qualname,     "Path.__dict__.__class__.__qualname__.__eq__",     ["mappingproxy"], true]
    - [PurePath_dict_qualname, "PurePath.__dict__.__class__.__qualname__.__eq__", ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# pathlib module __dict__ identity (novel module-level axis)
#
# The pathlib module's own __dict__ attribute is a mappingproxy at runtime.
# No prior pathlib spec checks the module's __dict__.__class__.__name__ or
# __dict__.__class__.__qualname__.
#
#   pathlib.__dict__.__class__.__name__     == 'mappingproxy'
#   pathlib.__dict__.__class__.__qualname__ == 'mappingproxy'
#
# Both anchors are novel in the pathlibdict60 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra60.module_dict_identity:
  description: "pathlib module __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy') — the pathlib module namespace is itself a mappingproxy; no prior pathlib spec checks pathlib.__dict__.__class__.__name__ or __qualname__; both novel anchors in pathlibdict60 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibdict60mod

  columns: [id, function, args, expected]
  rows:
    - [module_dict_name,     "__dict__.__class__.__name__.__eq__",     ["mappingproxy"], true]
    - [module_dict_qualname, "__dict__.__class__.__qualname__.__eq__", ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# pathlib.PurePath property descriptor __class__.__qualname__ (novel qualname axis)
#
# pathlib_extra59 verified that PurePath's named-component attributes are
# property descriptors by checking __class__.__name__ == 'property'. The
# builtin property type has __qualname__ == __name__ == 'property'. No prior
# pathlib spec checks __class__.__qualname__ for any PurePath property.
#
#   PurePath.name.__class__.__qualname__   == 'property'
#   PurePath.suffix.__class__.__qualname__ == 'property'
#   PurePath.parent.__class__.__qualname__ == 'property'
#   PurePath.stem.__class__.__qualname__   == 'property'
#
# All four __qualname__ anchors are novel in the pathlibdict60 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra60.purepath_property_qualnames:
  description: "pathlib.PurePath attribute descriptor __class__.__qualname__.__eq__('property') for name/suffix/parent/stem — property type __qualname__=='property' (same as __name__ for builtin types); pathlib_extra59 covers __class__.__name__ for PurePath properties; no prior pathlib spec checks PurePath property __class__.__qualname__; all four novel __qualname__ anchors in pathlibdict60 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibdict60pq

  columns: [id, function, args, expected]
  rows:
    - [PurePath_name_class_qualname,   "PurePath.name.__class__.__qualname__.__eq__",   ["property"], true]
    - [PurePath_suffix_class_qualname, "PurePath.suffix.__class__.__qualname__.__eq__", ["property"], true]
    - [PurePath_parent_class_qualname, "PurePath.parent.__class__.__qualname__.__eq__", ["property"], true]
    - [PurePath_stem_class_qualname,   "PurePath.stem.__class__.__qualname__.__eq__",   ["property"], true]
