spec: escape_string_regexp
version: ">=4.0.0"
backend: node(escape-string-regexp)

docs: https://github.com/sindresorhus/escape-string-regexp#readme

provenance:
  derived_from:
    - "escape-string-regexp README — https://github.com/sindresorhus/escape-string-regexp#readme"
    - "MDN: RegExp — Special characters in regular expressions — https://developer.mozilla.org/en-US/docs/Web/JavaScript/Guide/Regular_expressions#using_special_characters"
    - "Test vectors verified with escape-string-regexp@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "escape-string-regexp source: index.js"
  notes:
    - "escape-string-regexp exports the escape function as the module default (CJS-compatible in Node 22+)."
    - "require('escape-string-regexp') returns the function directly; fn_name is null (call module itself)."
    - "Escapes the 12 characters that have special meaning in RegExp: . * + ? ^ $ { } [ ] | ( ) \\"
    - "Plain strings with no special characters are returned unchanged."
    - "The module has no version property; version check uses package.json."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "No errors thrown for valid string inputs. Returns the escaped string directly."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Escape special regex metacharacters
# ---------------------------------------------------------------------------

table escape_string_regexp.plain:
  kind: node_module_call_eq
  function: ~
  category: plain
  id_prefix: plain

  columns: [id, args, expected]
  rows:
    - [no_special,  ["hello"],        "hello"]
    - [digits,      ["abc123"],       "abc123"]
    - [empty,       [""],             ""]

table escape_string_regexp.metacharacters:
  kind: node_module_call_eq
  function: ~
  category: metacharacters
  id_prefix: esc

  columns: [id, args, expected]
  rows:
    - [dot,      ["hello.world"],   "hello\\.world"]
    - [star,     ["a*b"],           "a\\*b"]
    - [plus,     ["a+b"],           "a\\+b"]
    - [qmark,    ["a?b"],           "a\\?b"]
    - [caret,    ["^start"],        "\\^start"]
    - [dollar,   ["end$"],          "end\\$"]
    - [lbrace,   ["{a}"],           "\\{a\\}"]
    - [bracket,  ["[a]"],           "\\[a\\]"]
    - [paren,    ["(a)"],           "\\(a\\)"]
    - [pipe,     ["a|b"],           "a\\|b"]

table escape_string_regexp.practical:
  kind: node_module_call_eq
  function: ~
  category: practical
  id_prefix: practical

  columns: [id, args, expected]
  rows:
    - [url_dot,   ["example.com"],              "example\\.com"]
    - [semver,    ["1.2.3"],                    "1\\.2\\.3"]
    - [price,     ["$9.99"],                    "\\$9\\.99"]
    - [filepath,  ["/path/to/file.txt"],        "/path/to/file\\.txt"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:42:47Z
  iterations: 1
  pass_count: 17
  fail_count: 0
  total_invariants: 17
  notes: Synthesis succeeded in 1 iteration(s). 17 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
