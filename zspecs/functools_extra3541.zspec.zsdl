spec: ft3541
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 683 (ft3541): __format__, __sizeof__, __dir__ dict-presence checks for functools types."
    - "All values false — functools.partial, functools.partialmethod, functools.cached_property, and the lru_cache wrapper type do not define __format__, __sizeof__, or __dir__ in their own __dict__."
    - "These methods are inherited from object and not overridden in functools types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __format__ dict-presence — operator.contains(Cls.__dict__, '__format__')
# ---------------------------------------------------------------------------

table ft3541.format:
  description: "functools types __format__ dict-presence checks; wave 683"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3541
  columns: [id, function, args, expected]
  rows:
    - ["ft3541001", operator.contains, [functools.partial.__dict__,                       "__format__"], false]
    - ["ft3541002", operator.contains, [functools.partialmethod.__dict__,                 "__format__"], false]
    - ["ft3541003", operator.contains, [functools.cached_property.__dict__,               "__format__"], false]
    - ["ft3541004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__, "__format__"], false]

