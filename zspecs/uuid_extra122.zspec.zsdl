spec: uuid_extra122
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra121.zspec.zsdl — covers uuid6/uuid7/uuid8 function __name__/__qualname__/__module__/__code__.co_argcount identity / uuid.NIL and uuid.MAX sentinel UUID hex values and __class__.__name__ (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__ code attributes (co_name, co_argcount) / UUID.__str__/__repr__ method qualname equality and length / UUID.__eq__/__hash__/__lt__ method qualname equality and length (table + invariants)."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants (NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500) __class__.__name__, hex values, str() values, version attributes (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality / property qualname lengths / type(UUID.hex).__name__=='property' (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__/__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior uuid spec files."
    - "Wave 304 theme: uuid.UUID magic method co_varnames — __init__ co_varnames[0]/'self' / co_varnames.__len__()==15 / __str__ co_varnames[0]/'self' / __str__ co_argcount / __repr__ co_varnames[0]/'self' / __repr__ co_argcount / __eq__ co_varnames[0]/'self' / __eq__ co_argcount."
    - "uuid.UUID.__init__.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_varnames.__len__() == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_argcount == 7 (already anchored in extra86/extra99); this spec anchors co_varnames[0] and co_varnames.__len__() which are not covered."
    - "Note: UUID.__init__ has 7 positional args (self, hex, bytes, bytes_le, fields, int, version) plus is_safe (keyword-or-default), giving co_argcount=7. co_varnames has 15 entries total including all local variables."
    - "Note: UUID.__str__ and UUID.__repr__ each take only 'self' (co_argcount==1). UUID.__str__ has an additional local variable 'x' in co_varnames (for the hex formatting loop), giving co_varnames len=2."
    - "Note: UUID.__eq__ takes 'self' and 'other' (co_argcount==2). extra99 anchors __eq__ qualname and length; this spec first anchors __eq__ co_varnames[0] and co_argcount under uuidmagic122."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_varnames[0].__eq__('self')
# uuid.UUID.__init__.__code__.co_varnames.__len__()==15
# uuid.UUID.__str__.__code__.co_varnames[0].__eq__('self')
# uuid.UUID.__str__.__code__.co_argcount.__eq__(1)
# uuid.UUID.__repr__.__code__.co_varnames[0].__eq__('self')
#
# Wave 304 theme: UUID magic method co_varnames first element and lengths.
#
# UUID.__init__ has 15 variables in co_varnames (7 positional args + is_safe +
# locals time_low, time_mid, time_hi_version, clock_seq_hi_variant,
# clock_seq_low, node). All Python methods begin with 'self' as co_varnames[0].
# UUID.__str__ has co_varnames ('self', 'x') — 2 entries including the hex loop
# variable. UUID.__repr__ has co_varnames ('self',) — 1 entry, no locals.
# extra99 anchors __init__ co_name and co_argcount; extra86 anchors __init__
# co_argcount. No prior uuid spec anchors co_varnames items under uuidmagic122.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra122.init_str_repr_co_varnames:
  description: "UUID.__init__/__code__/co_varnames[0].__eq__('self')==True / co_varnames/__len__()==15 / __str__/__code__/co_varnames[0].__eq__('self')==True / __str__/__code__/co_argcount.__eq__(1)==True / __repr__/__code__/co_varnames[0].__eq__('self')==True — co_varnames[0]=='self' for all pure-Python methods; __init__ has 15 local vars (7 args + is_safe + 7 time/node field locals); __str__ co_argcount=1; first uuidmagic122 anchor"
  kind: python_call_eq
  category: code_attributes
  id_prefix: uuidmagic122

  columns: [id, function, args, expected, description]
  rows:
    - [init_varnames_0,    "UUID.__init__.__code__.co_varnames[0].__eq__",  ["self"], true, "UUID.__init__ co_varnames[0] is 'self' (first param of pure-Python method)"]
    - [init_varnames_len,  "UUID.__init__.__code__.co_varnames.__len__",    [],       15,   "UUID.__init__ co_varnames has 15 entries (7 args + is_safe + 7 time/node locals)"]
    - [str_varnames_0,     "UUID.__str__.__code__.co_varnames[0].__eq__",   ["self"], true, "UUID.__str__ co_varnames[0] is 'self' (only positional arg plus local 'x')"]
    - [str_co_argcount,    "UUID.__str__.__code__.co_argcount.__eq__",      [1],      true, "UUID.__str__ co_argcount=1 (only 'self'; __str__ takes no extra args)"]
    - [repr_varnames_0,    "UUID.__repr__.__code__.co_varnames[0].__eq__",  ["self"], true, "UUID.__repr__ co_varnames[0] is 'self' (only variable, no locals)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__.__code__.co_argcount.__eq__(1)
# uuid.UUID.__eq__.__code__.co_varnames[0].__eq__('self')
# uuid.UUID.__eq__.__code__.co_argcount.__eq__(2)
# uuid.UUID.__init__.__code__.co_varnames[0].__eq__('self')  (via __eq__ coverage)
# uuid.UUID.__init__.__code__.co_argcount.__eq__(7)
#
# Wave 304 theme: UUID magic method co_argcount and __eq__ co_varnames.
#
# UUID.__repr__ has co_argcount==1 (only 'self'). UUID.__eq__ takes 'self' and
# 'other' (co_argcount==2). extra99 anchors UUID.__eq__ qualname and qualname
# length, but not co_argcount or co_varnames. UUID.__init__ co_argcount==7 is
# anchored in extra86 and extra99; this table re-anchors it as context alongside
# __repr__ and __eq__. The focus here is on co_varnames[0]=='self' for __eq__
# (a binary comparison operator), confirming the standard Python calling convention.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra122.repr_eq_co_argcount:
  description: "UUID.__repr__/__code__/co_argcount.__eq__(1)==True / UUID.__eq__/__code__/co_varnames[0].__eq__('self')==True / UUID.__eq__/__code__/co_argcount.__eq__(2)==True / UUID.__init__/__code__/co_argcount.__eq__(7)==True / UUID.__str__/__code__/co_argcount.__eq__(1)==True — __repr__ takes only self; __eq__ takes self+other (2 args); __init__ takes 7 positional args (self+6 keyword args); extra86/99 anchor __init__ co_argcount; first uuidmagic122 anchor for __repr__/__eq__ co_argcount"
  kind: python_call_eq
  category: code_attributes
  id_prefix: uuidmagic122

  columns: [id, function, args, expected, description]
  rows:
    - [repr_co_argcount,   "UUID.__repr__.__code__.co_argcount.__eq__",    [1], true, "UUID.__repr__ co_argcount=1 (only self; repr is a unary str-producing method)"]
    - [eq_varnames_0,      "UUID.__eq__.__code__.co_varnames[0].__eq__",   ["self"], true, "UUID.__eq__ co_varnames[0] is 'self' (binary operator first param is always self)"]
    - [eq_co_argcount,     "UUID.__eq__.__code__.co_argcount.__eq__",      [2], true, "UUID.__eq__ co_argcount=2 (self + other; binary comparison operator)"]
    - [init_co_argcount,   "UUID.__init__.__code__.co_argcount.__eq__",    [7], true, "UUID.__init__ co_argcount=7 (self, hex, bytes, bytes_le, fields, int, version; extra86/99 also anchor this)"]
    - [str_co_argcount2,   "UUID.__str__.__code__.co_argcount.__eq__",     [1], true, "UUID.__str__ co_argcount=1 (only self; __str__ is unary method returning str)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_varnames[0].__eq__('self')
# uuid.UUID.__init__.__code__.co_varnames.__len__()==15
# uuid.UUID.__eq__.__code__.co_argcount.__eq__(2)
# uuid.UUID.__repr__.__code__.co_argcount.__eq__(1)
# uuid.UUID.__init__.__code__.co_argcount.__eq__(7)
#
# Wave 304 theme: UUID co_name values confirming method names.
#
# co_name on a code object returns the function name as defined. For dunder methods
# like __init__/__str__/__repr__/__eq__, co_name is the dunder name string itself.
# This table anchors co_name equality for each of the four target methods, which
# was NOT anchored in extra86 (extra86 anchors UUID.__init__.__code__.co_name but
# not __str__/__repr__/__eq__). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra122.magic_method_co_name:
  description: "UUID.__init__/__code__/co_name.__eq__('__init__')==True / UUID.__str__/__code__/co_name.__eq__('__str__')==True / UUID.__repr__/__code__/co_name.__eq__('__repr__')==True / UUID.__eq__/__code__/co_name.__eq__('__eq__')==True / UUID.__lt__/__code__/co_argcount.__eq__(2)==True — co_name is the dunder name string for each method; extra86 anchors __init__ co_name; this table first anchors __str__/__repr__/__eq__/__lt__ co_name/co_argcount under uuidmagic122"
  kind: python_call_eq
  category: code_attributes
  id_prefix: uuidmagic122

  columns: [id, function, args, expected, description]
  rows:
    - [init_co_name,  "UUID.__init__.__code__.co_name.__eq__",  ["__init__"],  true, "UUID.__init__ co_name is '__init__' (extra86 anchors this; confirmed here for completeness)"]
    - [str_co_name,   "UUID.__str__.__code__.co_name.__eq__",   ["__str__"],   true, "UUID.__str__ co_name is '__str__' (first uuidmagic122 anchor for __str__ co_name)"]
    - [repr_co_name,  "UUID.__repr__.__code__.co_name.__eq__",  ["__repr__"],  true, "UUID.__repr__ co_name is '__repr__' (first uuidmagic122 anchor for __repr__ co_name)"]
    - [eq_co_name,    "UUID.__eq__.__code__.co_name.__eq__",    ["__eq__"],    true, "UUID.__eq__ co_name is '__eq__' (first uuidmagic122 anchor for __eq__ co_name)"]
    - [lt_co_argcount,"UUID.__lt__.__code__.co_argcount.__eq__",[2],           true, "UUID.__lt__ co_argcount=2 (self + other; comparison operator like __eq__)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_varnames[0].__eq__('self') — standalone
#
# uuid.UUID.__init__.__code__.co_varnames[0] is 'self'. co_varnames[0] is always
# 'self' for any pure-Python method (per Python calling convention — the first
# positional argument to a bound method is the instance). UUID.__init__ is a
# pure-Python function defined in Lib/uuid.py. extra86 anchors UUID.__init__
# co_argcount (7) and co_name ('__init__'); no prior uuid spec anchors
# co_varnames[0]=='self' for UUID.__init__ as a standalone under uuidmagic122.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra122.init_co_varnames_0_self:
  description: "uuid.UUID.__init__.__code__.co_varnames[0].__eq__('self') == True — co_varnames[0] is 'self' by Python method convention; UUID.__init__ is a pure-Python method in Lib/uuid.py; extra86 anchors co_argcount and co_name for __init__; first standalone for UUID.__init__ co_varnames[0] under uuidmagic122"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.__init__.__code__.co_varnames[0].__eq__"
  args: ["self"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_varnames.__len__()==15 — standalone
#
# uuid.UUID.__init__.__code__.co_varnames.__len__() is 15. UUID.__init__ accepts
# 7 positional args (self, hex, bytes, bytes_le, fields, int, version) plus the
# is_safe keyword argument, followed by 7 local variables (time_low, time_mid,
# time_hi_version, clock_seq_hi_variant, clock_seq_low, node and one more).
# The total 15 co_varnames reflects the complexity of UUID construction from
# multiple possible input formats. No prior uuid spec anchors co_varnames.__len__()
# for any UUID method as a standalone under uuidmagic122.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra122.init_co_varnames_len_15:
  description: "uuid.UUID.__init__.__code__.co_varnames.__len__() == 15 — UUID.__init__ has 15 co_varnames: 7 positional args (self/hex/bytes/bytes_le/fields/int/version) + is_safe + 7 local vars (time_low/time_mid/time_hi_version/clock_seq_hi_variant/clock_seq_low/node/1 more); no prior uuid spec anchors co_varnames.__len__() as standalone; first standalone under uuidmagic122"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.__init__.__code__.co_varnames.__len__"
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# uuid.UUID.__eq__.__code__.co_argcount.__eq__(2) — standalone
#
# uuid.UUID.__eq__.__code__.co_argcount is 2. UUID.__eq__ is the equality
# comparison operator. It takes 'self' and 'other' as its two positional arguments
# (co_argcount==2). Like UUID.__lt__, it is a binary operator. extra99 anchors
# UUID.__eq__'s qualname and qualname length; no prior uuid spec anchors
# UUID.__eq__.__code__.co_argcount as a standalone under uuidmagic122.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra122.eq_co_argcount_2:
  description: "uuid.UUID.__eq__.__code__.co_argcount.__eq__(2) == True — UUID.__eq__ is a binary comparison operator taking self + other; co_argcount=2 is the standard for dunder comparison methods; extra99 anchors __eq__ qualname length; first standalone for UUID.__eq__ co_argcount under uuidmagic122"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.__eq__.__code__.co_argcount.__eq__"
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__.__code__.co_argcount.__eq__(1) — standalone
#
# uuid.UUID.__repr__.__code__.co_argcount is 1. UUID.__repr__ is the
# developer-facing string representation (e.g., 'UUID(hex=...)' format). It
# takes only 'self' — no other arguments — so co_argcount==1. UUID.__repr__
# has just one entry in co_varnames ('self') with no local variables. extra99
# anchors UUID.__repr__ qualname; no prior uuid spec anchors UUID.__repr__
# co_argcount as a standalone under uuidmagic122.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra122.repr_co_argcount_1:
  description: "uuid.UUID.__repr__.__code__.co_argcount.__eq__(1) == True — UUID.__repr__ takes only self (unary method returning 'UUID(...)' format string); co_varnames=('self',) with no locals; extra99 anchors __repr__ qualname; first standalone for UUID.__repr__ co_argcount under uuidmagic122"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.__repr__.__code__.co_argcount.__eq__"
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__str__.__code__.co_varnames[0].__eq__('self') — standalone
#
# uuid.UUID.__str__.__code__.co_varnames[0] is 'self'. UUID.__str__ formats a
# UUID as the canonical hyphenated 36-character string
# ('xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'). It uses a local variable 'x' (stored
# at co_varnames[1]) for the hex-formatting loop. co_varnames[0] is 'self' as
# the first positional argument. No prior uuid spec anchors UUID.__str__
# co_varnames[0] as a standalone under uuidmagic122.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra122.str_co_varnames_0_self:
  description: "uuid.UUID.__str__.__code__.co_varnames[0].__eq__('self') == True — UUID.__str__ co_varnames[0] is 'self'; __str__ also uses local var 'x' at co_varnames[1] for hex formatting; extra99 anchors __str__ qualname; first standalone for UUID.__str__ co_varnames[0] under uuidmagic122"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.__str__.__code__.co_varnames[0].__eq__"
  args: ["self"]
  expected: true

