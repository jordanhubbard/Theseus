spec: struct_extra199
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra99.zspec.zsdl — covers struct module attributes up through extra99."
  notes:
    - "struct.__dict__.__contains__('pack') == True — pack is a top-level name in the struct module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.__dict__.__contains__('unpack') == True — unpack is a top-level name in the struct module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.__dict__.__contains__('calcsize') == True — calcsize is a top-level name in the struct module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.__dict__.__contains__('Struct') == True — Struct class is a top-level name in the struct module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.__dict__.__contains__('error') == True — error exception class is a top-level name in the struct module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.__dict__.__contains__('pack_into') == True — pack_into is a top-level name in the struct module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.__dict__.__contains__('unpack_from') == True — unpack_from is a top-level name in the struct module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.__dict__.__contains__('iter_unpack') == True — iter_unpack is a top-level name in the struct module namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.__mro__.__len__() == 2 — Struct is a C extension type inheriting only from object (Struct, object). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.__mro__[0].__name__ == 'Struct' — the first MRO entry is Struct itself. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module __dict__.__contains__ for core pack/unpack functions
# ---------------------------------------------------------------------------

table struct_extra199.module_dict_pack_unpack:
  description: "struct.__dict__.__contains__ checks for pack, unpack, calcsize, Struct — core struct module functions and the Struct compiled-format class"
  kind: python_call_eq
  category: module_dict
  id_prefix: structdict199

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_pack,      __dict__.__contains__, ["pack"],      true, "struct.__dict__.__contains__('pack') — pack() function is in struct module namespace"]
    - [dict_has_unpack,    __dict__.__contains__, ["unpack"],    true, "struct.__dict__.__contains__('unpack') — unpack() function is in struct module namespace"]
    - [dict_has_calcsize,  __dict__.__contains__, ["calcsize"],  true, "struct.__dict__.__contains__('calcsize') — calcsize() function is in struct module namespace"]
    - [dict_has_Struct,    __dict__.__contains__, ["Struct"],    true, "struct.__dict__.__contains__('Struct') — Struct compiled-format class is in struct module namespace"]

# ---------------------------------------------------------------------------
# struct module __dict__.__contains__ for error, pack_into, unpack_from, iter_unpack
# ---------------------------------------------------------------------------

table struct_extra199.module_dict_error_and_variants:
  description: "struct.__dict__.__contains__ checks for error, pack_into, unpack_from, iter_unpack — error exception and buffer-oriented / iterator variants of pack/unpack"
  kind: python_call_eq
  category: module_dict
  id_prefix: structdict199

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_error,        __dict__.__contains__, ["error"],        true, "struct.__dict__.__contains__('error') — struct.error exception class is in struct module namespace"]
    - [dict_has_pack_into,    __dict__.__contains__, ["pack_into"],    true, "struct.__dict__.__contains__('pack_into') — pack_into() writes packed bytes into a buffer at an offset"]
    - [dict_has_unpack_from,  __dict__.__contains__, ["unpack_from"],  true, "struct.__dict__.__contains__('unpack_from') — unpack_from() reads from a buffer at an offset"]
    - [dict_has_iter_unpack,  __dict__.__contains__, ["iter_unpack"],  true, "struct.__dict__.__contains__('iter_unpack') — iter_unpack() yields successive values from a buffer"]

# ---------------------------------------------------------------------------
# struct.Struct.__mro__ length and first entry name
# ---------------------------------------------------------------------------

table struct_extra199.Struct_mro_and_dict:
  description: "struct.Struct.__mro__.__len__()==2 and struct.Struct.__mro__[0].__name__=='Struct' — Struct's MRO is (Struct, object); first entry is Struct itself"
  kind: python_call_eq
  category: class_mro
  id_prefix: structdict199

  columns: [id, function, args, expected, description]
  rows:
    - [mro_len,         Struct.__mro__.__len__,          [],         2,    "struct.Struct.__mro__.__len__() == 2 — Struct inherits from object only (Struct, object)"]
    - ["mro0_name",     "Struct.__mro__[0].__name__.__eq__", ["Struct"], true, "struct.Struct.__mro__[0].__name__ == 'Struct' — first MRO entry is Struct itself"]
    - [dict_has_pack2,  __dict__.__contains__,           ["pack"],    true, "struct.__dict__.__contains__('pack') re-anchored in mro table"]
    - [dict_has_error2, __dict__.__contains__,           ["error"],   true, "struct.__dict__.__contains__('error') re-anchored in mro table"]

# ---------------------------------------------------------------------------
# Standalone invariants (8 total)
# ---------------------------------------------------------------------------

invariant struct_extra199.dict_has_pack:
  description: "struct.__dict__.__contains__('pack') == True — pack() is a top-level name in the struct module namespace"
  category: module_dict
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["pack"]
  expected: true

invariant struct_extra199.dict_has_unpack:
  description: "struct.__dict__.__contains__('unpack') == True — unpack() is a top-level name in the struct module namespace"
  category: module_dict
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["unpack"]
  expected: true

invariant struct_extra199.dict_has_Struct:
  description: "struct.__dict__.__contains__('Struct') == True — the Struct compiled-format class is a top-level name in the struct module namespace"
  category: module_dict
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Struct"]
  expected: true

invariant struct_extra199.dict_has_error:
  description: "struct.__dict__.__contains__('error') == True — the struct.error exception class is a top-level name in the struct module namespace"
  category: module_dict
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["error"]
  expected: true

invariant struct_extra199.dict_has_iter_unpack:
  description: "struct.__dict__.__contains__('iter_unpack') == True — iter_unpack() iterator function is a top-level name in the struct module namespace"
  category: module_dict
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["iter_unpack"]
  expected: true

invariant struct_extra199.dict_has_calcsize:
  description: "struct.__dict__.__contains__('calcsize') == True — calcsize() function is a top-level name in the struct module namespace"
  category: module_dict
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["calcsize"]
  expected: true

invariant struct_extra199.Struct_mro_len:
  description: "struct.Struct.__mro__.__len__() == 2 — Struct's MRO is (Struct, object); it is a C extension type with no intermediate base classes"
  category: class_mro
  kind: python_call_eq
  function: Struct.__mro__.__len__
  args: []
  expected: 2

invariant struct_extra199.Struct_mro0_name:
  description: "struct.Struct.__mro__[0].__name__ == 'Struct' — first entry in Struct's MRO is Struct itself"
  category: class_mro
  kind: python_call_eq
  function: "Struct.__mro__[0].__name__.__eq__"
  args: ["Struct"]
  expected: true
