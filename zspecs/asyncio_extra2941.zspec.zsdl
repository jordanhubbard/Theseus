spec: as2941
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/asyncio-task.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-sync.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-eventloop.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "asyncio source: internal C-level accelerators (_asyncio extension)"
  notes:
    - "Wave 643 — theme: __neg__, __pos__, __abs__ dict-presence (unary operator slots)."
    - "Tests operator.contains(SomeClass.__dict__, '__neg__') etc. for asyncio classes."
    - "None of the asyncio classes (Task, Future, Queue, Event, Semaphore, BoundedSemaphore, Lock, Condition, Handle, TimerHandle, Timeout, TaskGroup) define __neg__, __pos__, or __abs__ in their own __dict__."
    - "These are concurrency/IO primitives; numeric dunder absence is the expected invariant."
    - "Task and Future are C-accelerated (_asyncio); the __dict__ check still correctly returns False for unary numeric slots."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __neg__ dict-presence — operator.contains(Cls.__dict__, '__neg__')
#
# None of the asyncio classes define __neg__; all results are false.
# ---------------------------------------------------------------------------

table as2941.neg:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_neg
  id_prefix: neg

  columns: [id, function, args, expected]
  rows:
    - ["neg_Task",            operator.contains, [Task.__dict__,            "__neg__"], false]
    - ["neg_Future",          operator.contains, [Future.__dict__,          "__neg__"], false]
    - ["neg_Queue",           operator.contains, [Queue.__dict__,           "__neg__"], false]
    - ["neg_Event",           operator.contains, [Event.__dict__,           "__neg__"], false]
    - ["neg_Semaphore",       operator.contains, [Semaphore.__dict__,       "__neg__"], false]
    - ["neg_BoundedSemaphore",operator.contains, [BoundedSemaphore.__dict__,"__neg__"], false]
    - ["neg_Lock",            operator.contains, [Lock.__dict__,            "__neg__"], false]
    - ["neg_Condition",       operator.contains, [Condition.__dict__,       "__neg__"], false]
    - ["neg_Handle",          operator.contains, [Handle.__dict__,          "__neg__"], false]
    - ["neg_TimerHandle",     operator.contains, [TimerHandle.__dict__,     "__neg__"], false]
    - ["neg_Timeout",         operator.contains, [Timeout.__dict__,         "__neg__"], false]
    - ["neg_TaskGroup",       operator.contains, [TaskGroup.__dict__,       "__neg__"], false]

