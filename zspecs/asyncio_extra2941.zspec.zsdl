# ---------------------------------------------------------------------------
# combined — all three operators for a cross-class sample
#
# Spot-checks __neg__, __pos__, __abs__ absence across a representative
# selection of asyncio classes in a single table for concise coverage.
# ---------------------------------------------------------------------------

table as2941.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
