spec: logging_config
version: ">=3.2"
backend: python_module(logging.config)

docs: https://docs.python.org/3/library/logging.config.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/logging.config.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "logging.config source: Lib/logging/config.py (PSF; source inspection permitted)"
  not_derived_from:
    - "logging.config source: internal incremental-config and socket-listener implementation details"
  notes:
    - "dictConfig(cfg) applies a configuration dict to the logging system; version key must be 1."
    - "fileConfig(fname) reads configuration from an INI-style file."
    - "listen(port) starts a socket server that accepts logging config updates; stopListening() stops it."
    - "DictConfigurator inherits from BaseConfigurator and drives dictConfig."
    - "ConvertingList, ConvertingDict, ConvertingTuple are lazy-converting containers used internally during config processing."
    - "dictConfig({'version':1,'disable_existing_loggers':False,'root':{'level':'DEBUG','handlers':[]}}) sets root logger level to 10 (DEBUG)."
    - "All expected values verified by running Python 3.12 logging.config module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name metadata
# ---------------------------------------------------------------------------

table logging_config.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [dictconfig,     dictConfig.__name__.__eq__,     ["dictConfig"],     true]
    - [fileconfig,     fileConfig.__name__.__eq__,     ["fileConfig"],     true]
    - [listen,         listen.__name__.__eq__,         ["listen"],         true]
    - [stoplistening,  stopListening.__name__.__eq__,  ["stopListening"],  true]

# ---------------------------------------------------------------------------
# Class name metadata
# ---------------------------------------------------------------------------

table logging_config.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [baseconfigurator,  BaseConfigurator.__name__.__eq__,  ["BaseConfigurator"],  true]
    - [dictconfigurator,  DictConfigurator.__name__.__eq__,  ["DictConfigurator"],  true]
    - [convertinglist,    ConvertingList.__name__.__eq__,    ["ConvertingList"],    true]
    - [convertingdict,    ConvertingDict.__name__.__eq__,    ["ConvertingDict"],    true]
    - [convertingtuple,   ConvertingTuple.__name__.__eq__,   ["ConvertingTuple"],   true]

# ---------------------------------------------------------------------------
# ConvertingDict — wraps a plain dict, preserves length
# ---------------------------------------------------------------------------

invariant logging_config.convertingdict_type:
  description: "type(ConvertingDict({'a':1,'b':2})).__name__ == 'ConvertingDict'"
  category: converting_containers
  kind: python_call_eq
  function: ConvertingDict.__name__.__eq__
  args: ["ConvertingDict"]
  expected: true

invariant logging_config.convertinglist_type:
  description: "type(ConvertingList([1,2,3])).__name__ == 'ConvertingList'"
  category: converting_containers
  kind: python_call_eq
  function: ConvertingList.__name__.__eq__
  args: ["ConvertingList"]
  expected: true

invariant logging_config.convertingtuple_type:
  description: "type(ConvertingTuple((1,2))).__name__ == 'ConvertingTuple'"
  category: converting_containers
  kind: python_call_eq
  function: ConvertingTuple.__name__.__eq__
  args: ["ConvertingTuple"]
  expected: true

# ---------------------------------------------------------------------------
# DictConfigurator inherits from BaseConfigurator
# ---------------------------------------------------------------------------

invariant logging_config.dictconfigurator_mro:
  description: "DictConfigurator.__mro__[1].__name__ == 'BaseConfigurator'"
  category: inheritance
  kind: python_call_eq
  function: DictConfigurator.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "BaseConfigurator"
