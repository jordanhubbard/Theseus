spec: http_client_extra15
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
    - "http_client_extra2.zspec.zsdl — covers __qualname__.__eq__ for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException/NotConnected/InvalidURL; __module__.__eq__ for HTTPException/HTTPResponse/NotConnected/InvalidURL."
    - "http_client_extra9.zspec.zsdl — covers __name__.__len__() for several classes; __bases__[0].__name__ for HTTPSConnection/HTTPResponse/LineTooLong."
    - "http_client_extra10.zspec.zsdl — covers __qualname__.__len__() for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException/NotConnected; __module__.__len__()==11."
    - "http_client_extra11.zspec.zsdl — covers __qualname__.__eq__ and __len__() for HTTPConnection.request/getresponse/connect/close and HTTPResponse.read/getheader."
    - "http_client_extra12.zspec.zsdl — covers __qualname__.__eq__ and __len__() for HTTPResponse.getheaders/geturl/info; HTTPSConnection.connect __qualname__; HTTPException.__bases__[0].__name__; cross-namespace anchors."
    - "http_client_extra13.zspec.zsdl — covers HTTPResponse __qualname__/__module__, HTTPMessage __qualname__/__module__/__bases__[0].__name__, responses.__class__.__name__, HTTPException __qualname__ cross-namespace anchor."
    - "http_client_extra14.zspec.zsdl — covers HTTPConnection/__qualname__/__module__, HTTPSConnection/__qualname__/__module__, HTTPConnection/__bases__[0].__name__=='object', HTTPSConnection/__bases__[0].__name__=='HTTPConnection', method qualname cross-namespace anchors, HTTP_PORT/HTTPS_PORT constants, BadStatusLine/CannotSendRequest exception attributes."
  notes:
    - "This spec extends the http.client chain through http_client_extra14; it does NOT duplicate invariants in any prior spec."
    - "Focus: (1) http.client.HTTPConnection.__init__.__name__ == '__init__' — the constructor method name; (2) http.client.HTTPResponse.__bases__[0].__name__ == 'BufferedIOBase' — extra9 covers HTTPSConnection/LineTooLong bases but not HTTPResponse; (3) http.client.HTTPResponse.__module__ as standalone cross-namespace anchor — extra13 covers; (4) http.client.NotConnected.__name__ and __bases__[0].__name__ — extra2 covers __qualname__ and __module__ but not __name__ or __bases__; (5) http.client.InvalidURL.__name__ and __bases__[0].__name__ — same situation; (6) http.client.UnknownProtocol.__name__ — no prior spec checks UnknownProtocol; (7) http.client.RemoteDisconnected.__name__ and __bases__[0].__name__ — no prior spec checks RemoteDisconnected; (8) http.client.IncompleteRead.__name__ — no prior spec checks IncompleteRead."
    - "http.client.HTTPConnection.__init__.__name__ == '__init__' — len 8. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.__bases__[0].__name__ == 'BufferedIOBase' — len 14. HTTPResponse inherits from io.BufferedIOBase. extra9 covers HTTPSConnection/LineTooLong but NOT HTTPResponse. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.__module__ == 'http.client' — len 11. extra13 covers as standalone; cross-namespace anchor here in extra15."
    - "http.client.NotConnected.__name__ == 'NotConnected' — len 12. extra2 covers __qualname__/__module__ but not __name__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.NotConnected.__bases__[0].__name__ == 'HTTPException' — len 13. No prior spec checks NotConnected inheritance. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.InvalidURL.__name__ == 'InvalidURL' — len 10. extra2 covers __qualname__/__module__ but not __name__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.InvalidURL.__bases__[0].__name__ == 'HTTPException' — len 13. No prior spec checks InvalidURL inheritance. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.UnknownProtocol.__name__ == 'UnknownProtocol' — len 15. No prior spec checks any UnknownProtocol attribute. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.RemoteDisconnected.__name__ == 'RemoteDisconnected' — len 18. No prior spec checks RemoteDisconnected. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.RemoteDisconnected.__bases__[0].__name__ == 'ConnectionResetError' — len 20. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.IncompleteRead.__name__ == 'IncompleteRead' — len 14. No prior spec checks IncompleteRead. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# http.client.HTTPConnection.__init__.__name__
#
# No prior spec checks the __name__ attribute of HTTPConnection.__init__.
# The constructor method is named '__init__' (len 8, standard Python dunder).
# ---------------------------------------------------------------------------

invariant http_client_extra15.HTTPConnection.init_name_eq:
  description: "http.client.HTTPConnection.__init__.__name__ == '__init__' — no prior spec checks this constructor method name attribute"
  category: method_names
  kind: python_call_eq
  "function": "HTTPConnection.__init__.__name__.__eq__"
  args: ["__init__"]
  expected: true

invariant http_client_extra15.HTTPConnection.init_name_len:
  description: "len(http.client.HTTPConnection.__init__.__name__) == 8 — len('__init__') == 8"
  category: method_names
  kind: python_call_eq
  "function": "HTTPConnection.__init__.__name__.__len__"
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# http.client.HTTPResponse.__bases__[0].__name__ and __module__
#
# http_client_extra9 covers __bases__[0].__name__ for HTTPSConnection and
# LineTooLong, but NOT for HTTPResponse. HTTPResponse inherits from
# io.BufferedIOBase. __bases__[0].__name__ == 'BufferedIOBase' (len 14).
# http_client_extra13 covers HTTPResponse.__module__ as standalone.
# This spec provides a cross-namespace anchor for __module__ from extra15.
# ---------------------------------------------------------------------------

invariant http_client_extra15.HTTPResponse.bases0_name_eq:
  description: "http.client.HTTPResponse.__bases__[0].__name__ == 'BufferedIOBase' — HTTPResponse inherits from io.BufferedIOBase; no prior spec checks this"
  category: class_hierarchy
  kind: python_call_eq
  "function": "HTTPResponse.__bases__[0].__name__.__eq__"
  args: ["BufferedIOBase"]
  expected: true

invariant http_client_extra15.HTTPResponse.bases0_name_len:
  description: "len(http.client.HTTPResponse.__bases__[0].__name__) == 14 — len('BufferedIOBase') == 14"
  category: class_hierarchy
  kind: python_call_eq
  "function": "HTTPResponse.__bases__[0].__name__.__len__"
  args: []
  expected: 14

invariant http_client_extra15.HTTPResponse.module_eq:
  description: "http.client.HTTPResponse.__module__ == 'http.client' — cross-namespace anchor from extra15; extra13 covers originally"
  category: class_module
  kind: python_call_eq
  function: HTTPResponse.__module__.__eq__
  args: ["http.client"]
  expected: true

# ---------------------------------------------------------------------------
# http.client.NotConnected and InvalidURL — __name__ and __bases__[0].__name__
#
# http_client_extra2 covers __qualname__.__eq__ and __module__.__eq__ for both
# NotConnected and InvalidURL in tables. No prior spec checks __name__ (which
# equals __qualname__ for these top-level classes) or __bases__[0].__name__.
# Both inherit from HTTPException (len 13).
# ---------------------------------------------------------------------------

table http_client_extra15.simple_exception_names:
  description: "__name__.__eq__ for NotConnected and InvalidURL — extra2 covers __qualname__ but not __name__"
  kind: python_call_eq
  category: class_names
  id_prefix: sen15

  columns: [id, function, args, expected]
  rows:
    - [NotConnected, NotConnected.__name__.__eq__, ["NotConnected"], true]
    - [InvalidURL,   InvalidURL.__name__.__eq__,   ["InvalidURL"],   true]

table http_client_extra15.simple_exception_name_lengths:
  description: "len(__name__) for NotConnected (12) and InvalidURL (10)"
  kind: python_call_eq
  category: class_names
  id_prefix: senlen15

  columns: [id, function, args, expected]
  rows:
    - [NotConnected, NotConnected.__name__.__len__, [], 12]
    - [InvalidURL,   InvalidURL.__name__.__len__,   [], 10]

table http_client_extra15.simple_exception_bases0_names:
  description: "__bases__[0].__name__.__eq__ for NotConnected and InvalidURL — both inherit from HTTPException"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: sebn15

  columns: [id, function, args, expected]
  rows:
    - [NotConnected, "NotConnected.__bases__[0].__name__.__eq__", ["HTTPException"], true]
    - [InvalidURL,   "InvalidURL.__bases__[0].__name__.__eq__",   ["HTTPException"], true]

# ---------------------------------------------------------------------------
# http.client.UnknownProtocol — __name__
#
# No prior spec checks any attribute of UnknownProtocol.
# UnknownProtocol.__name__ == 'UnknownProtocol' (len 15).
# ---------------------------------------------------------------------------

invariant http_client_extra15.UnknownProtocol.name_eq:
  description: "http.client.UnknownProtocol.__name__ == 'UnknownProtocol' — no prior spec checks any UnknownProtocol attribute"
  category: class_names
  kind: python_call_eq
  function: UnknownProtocol.__name__.__eq__
  args: ["UnknownProtocol"]
  expected: true

invariant http_client_extra15.UnknownProtocol.name_len:
  description: "len(http.client.UnknownProtocol.__name__) == 15 — len('UnknownProtocol') == 15"
  category: class_names
  kind: python_call_eq
  function: UnknownProtocol.__name__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# http.client.RemoteDisconnected — __name__ and __bases__[0].__name__
#
# No prior spec checks any attribute of RemoteDisconnected.
# RemoteDisconnected is raised when a remote end closes the connection before
# sending a complete response. It inherits from ConnectionResetError.
# __name__ == 'RemoteDisconnected' (len 18).
# __bases__[0].__name__ == 'ConnectionResetError' (len 20).
# ---------------------------------------------------------------------------

invariant http_client_extra15.RemoteDisconnected.name_eq:
  description: "http.client.RemoteDisconnected.__name__ == 'RemoteDisconnected' — no prior spec checks any RemoteDisconnected attribute"
  category: class_names
  kind: python_call_eq
  function: RemoteDisconnected.__name__.__eq__
  args: ["RemoteDisconnected"]
  expected: true

invariant http_client_extra15.RemoteDisconnected.name_len:
  description: "len(http.client.RemoteDisconnected.__name__) == 18 — len('RemoteDisconnected') == 18"
  category: class_names
  kind: python_call_eq
  function: RemoteDisconnected.__name__.__len__
  args: []
  expected: 18

invariant http_client_extra15.RemoteDisconnected.bases0_name_eq:
  description: "http.client.RemoteDisconnected.__bases__[0].__name__ == 'ConnectionResetError' — RemoteDisconnected inherits from ConnectionResetError"
  category: class_hierarchy
  kind: python_call_eq
  "function": "RemoteDisconnected.__bases__[0].__name__.__eq__"
  args: ["ConnectionResetError"]
  expected: true

invariant http_client_extra15.RemoteDisconnected.bases0_name_len:
  description: "len(http.client.RemoteDisconnected.__bases__[0].__name__) == 20 — len('ConnectionResetError') == 20"
  category: class_hierarchy
  kind: python_call_eq
  "function": "RemoteDisconnected.__bases__[0].__name__.__len__"
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# http.client.IncompleteRead — __name__
#
# No prior spec checks any attribute of IncompleteRead.
# IncompleteRead is raised when partial data is received from the server.
# __name__ == 'IncompleteRead' (len 14).
# ---------------------------------------------------------------------------

invariant http_client_extra15.IncompleteRead.name_eq:
  description: "http.client.IncompleteRead.__name__ == 'IncompleteRead' — no prior spec checks any IncompleteRead attribute"
  category: class_names
  kind: python_call_eq
  function: IncompleteRead.__name__.__eq__
  args: ["IncompleteRead"]
  expected: true

invariant http_client_extra15.IncompleteRead.name_len:
  description: "len(http.client.IncompleteRead.__name__) == 14 — len('IncompleteRead') == 14"
  category: class_names
  kind: python_call_eq
  function: IncompleteRead.__name__.__len__
  args: []
  expected: 14
