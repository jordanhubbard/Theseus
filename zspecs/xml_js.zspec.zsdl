spec: xml_js
version: ">=1.6.0"
backend: node(xml-js)

docs: https://github.com/nashwaan/xml-js#readme

provenance:
  derived_from:
    - "xml-js README — https://github.com/nashwaan/xml-js#readme"
    - "Test vectors verified with xml-js via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "xml-js source"
  notes:
    - "xml-js is a bidirectional XML <-> JS converter (alternative to xml2js / fast-xml-parser)."
    - "Install: npm install xml-js"
    - "Two output modes: 'compact' (simpler nested object) vs 'non-compact' (preserves attributes/text/comments separately)."
    - "Compact mode uses _text/_attributes/_cdata as reserved keys."
    - "xml2json returns a JSON STRING; json2xml takes either a string or object."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; throws only on malformed XML for xml2json."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# xml2json compact mode — XML to JSON-string
table xml_js.xml2json:
  kind: node_module_call_eq
  category: xml2json
  function: xml2json
  id_prefix: x2j

  columns: [id, args, expected]
  rows:
    - [single_text_element,
       ["<a>hi</a>", {compact: true}],
       "{\"a\":{\"_text\":\"hi\"}}"]

    - [empty_element,
       ["<a></a>", {compact: true}],
       "{\"a\":{}}"]

    - [self_closing,
       ["<a/>", {compact: true}],
       "{\"a\":{}}"]

    - [nested,
       ["<a><b>hi</b></a>", {compact: true}],
       "{\"a\":{\"b\":{\"_text\":\"hi\"}}}"]

# json2xml — JS object to XML string
table xml_js.json2xml:
  kind: node_module_call_eq
  category: json2xml
  function: json2xml
  id_prefix: j2x

  columns: [id, args, expected]
  rows:
    - [single_text,
       [{a: {_text: "hi"}}, {compact: true}],
       "<a>hi</a>"]

    - [empty_element,
       [{a: {}}, {compact: true}],
       "<a/>"]

    - [nested,
       [{a: {b: {_text: "hi"}}}, {compact: true}],
       "<a><b>hi</b></a>"]
