spec: theseus_pathlib_extra_cr
version: ">=3.8"
backend: python_cleanroom(theseus_pathlib_extra_cr)
blocks: pathlib

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
  notes:
    - "Clean-room pathlib module. Do NOT import pathlib."
    - "PurePosixPath and PureWindowsPath for path manipulation."

error_model: python_exceptions

invariant theseus_pathlib_extra_cr.pathlib2_parts:
  description: "PurePosixPath splits path into parts correctly"
  category: behavior
  kind: python_call_eq
  function: pathlib2_parts
  args: []
  expected: true

invariant theseus_pathlib_extra_cr.pathlib2_stem:
  description: "PurePosixPath.stem returns filename without extension"
  category: behavior
  kind: python_call_eq
  function: pathlib2_stem
  args: []
  expected: true

invariant theseus_pathlib_extra_cr.pathlib2_joinpath:
  description: "PurePosixPath / operator joins paths"
  category: behavior
  kind: python_call_eq
  function: pathlib2_joinpath
  args: []
  expected: true
