spec: hashlib_extra2386
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 606 (_extra2386): __str__ and __repr__ implementation type classification."
    - "hashlib.blake2b and hashlib.blake2s are C types; both __repr__ and __str__ are wrapper_descriptor."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2386.blake2b_str_repr:
  description: "hashlib.blake2b __repr__ and __str__ implementation type via .__class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl2386
  columns: [id, function, args, expected]
  rows:
    - ["hl2386001", "hashlib.blake2b.__repr__.__class__.__name__", [], "wrapper_descriptor"]
    - ["hl2386002", "hashlib.blake2b.__str__.__class__.__name__", [], "wrapper_descriptor"]

table hashlib_extra2386.blake2s_str_repr:
  description: "hashlib.blake2s __repr__ and __str__ implementation type via .__class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl2386
  columns: [id, function, args, expected]
  rows:
    - ["hl2386003", "hashlib.blake2s.__repr__.__class__.__name__", [], "wrapper_descriptor"]
    - ["hl2386004", "hashlib.blake2s.__str__.__class__.__name__", [], "wrapper_descriptor"]

table hashlib_extra2386.blake2b_repr_is_wrapper_descriptor:
  description: "C-implemented blake2b has __repr__ of kind wrapper_descriptor (inherited from object)"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl2386
  columns: [id, function, args, expected]
  rows:
    - ["hl2386005", "hashlib.blake2b.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["hl2386006", "hashlib.blake2b.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

table hashlib_extra2386.blake2s_repr_is_wrapper_descriptor:
  description: "C-implemented blake2s has __repr__ and __str__ of kind wrapper_descriptor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl2386
  columns: [id, function, args, expected]
  rows:
    - ["hl2386007", "hashlib.blake2s.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["hl2386008", "hashlib.blake2s.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

table hashlib_extra2386.blake2_not_function:
  description: "Neither blake2b nor blake2s defines __repr__/__str__ in Python; both return non-'function'"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl2386
  columns: [id, function, args, expected]
  rows:
    - ["hl2386009", "hashlib.blake2b.__repr__.__class__.__name__.__eq__", ["function"], false]
    - ["hl2386010", "hashlib.blake2b.__str__.__class__.__name__.__eq__", ["function"], false]
    - ["hl2386011", "hashlib.blake2s.__repr__.__class__.__name__.__eq__", ["function"], false]
    - ["hl2386012", "hashlib.blake2s.__str__.__class__.__name__.__eq__", ["function"], false]

table hashlib_extra2386.blake2_consistency:
  description: "Cross-check: blake2b and blake2s are consistent — both C types, same descriptor kind for __repr__ and __str__"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl2386
  columns: [id, function, args, expected]
  rows:
    - ["hl2386013", "hashlib.blake2b.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["hl2386014", "hashlib.blake2b.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["hl2386015", "hashlib.blake2s.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["hl2386016", "hashlib.blake2s.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

table hashlib_extra2386.blake2_repr_eq_str_kind:
  description: "For C-type blake2b and blake2s, __repr__ and __str__ are the same implementation kind"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl2386
  columns: [id, function, args, expected]
  rows:
    - ["hl2386017", "hashlib.blake2b.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["hl2386018", "hashlib.blake2s.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["hl2386019", "hashlib.blake2b.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["hl2386020", "hashlib.blake2s.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
