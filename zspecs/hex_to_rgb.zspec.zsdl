spec: hex_to_rgb
version: ">=1.0.1"
backend: node(hex-to-rgb)

docs: https://www.npmjs.com/package/hex-to-rgb

provenance:
  derived_from:
    - "hex-to-rgb README — https://www.npmjs.com/package/hex-to-rgb"
    - "Test vectors verified with hex-to-rgb via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "hex-to-rgb source"
  notes:
    - "hex-to-rgb is an npm package. Install: npm install hex-to-rgb"
    - "Converts a hex color string to an [R, G, B] array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of three integers [R, G, B]."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table hex_to_rgb.convert:
  kind: node_module_call_eq
  function: ~
  category: color
  id_prefix: h2rgb

  columns: [id, args, expected]
  rows:
    - [red,    ["#ff0000"],  [255, 0, 0]]
    - [blue,   ["#0000ff"],  [0, 0, 255]]
    - [white,  ["#ffffff"],  [255, 255, 255]]

