spec: struct_extra1096
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.Struct.__new__/__init__/__repr__ qualnames, struct.Struct.__doc__.__class__.__name__, and module-level pack/unpack/calcsize __qualname__"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1096.struct_class_lifecycle_qualnames:
  description: "struct.Struct.__new__, __init__, __repr__ qualname identity"
  kind: python_call_eq
  category: struct_class_lifecycle_qualnames
  id_prefix: st1096lq
  columns: [id, function, args, expected]
  rows:
    - [st1096lq001, struct.Struct.__new__.__qualname__.__eq__,              ["Struct.__new__"],   true]
    - [st1096lq002, struct.Struct.__init__.__qualname__.__eq__,             ["Struct.__init__"],  true]
    - [st1096lq003, struct.Struct.__repr__.__qualname__.__eq__,             ["Struct.__repr__"],  true]
    - [st1096lq004, struct.Struct.__new__.__qualname__.__class__.__name__.__eq__,   ["str"],      true]
    - [st1096lq005, struct.Struct.__init__.__qualname__.__class__.__name__.__eq__,  ["str"],      true]
    - [st1096lq006, struct.Struct.__repr__.__qualname__.__class__.__name__.__eq__,  ["str"],      true]
    - [st1096lq007, struct.Struct.__new__.__class__.__name__.__eq__,        ["slot_wrapper"],     true]
    - [st1096lq008, struct.Struct.__init__.__class__.__name__.__eq__,       ["slot_wrapper"],     true]
    - [st1096lq009, struct.Struct.__repr__.__class__.__name__.__eq__,       ["slot_wrapper"],     true]

table struct_extra1096.struct_class_doc_classname:
  description: "struct.Struct.__doc__.__class__.__name__ and related identity"
  kind: python_call_eq
  category: struct_class_doc_classname
  id_prefix: st1096dc
  columns: [id, function, args, expected]
  rows:
    - [st1096dc001, struct.Struct.__doc__.__class__.__name__.__eq__,            ["str"],      true]
    - [st1096dc002, struct.Struct.__doc__.__class__.__module__.__eq__,          ["builtins"], true]
    - [st1096dc003, struct.Struct.__doc__.__class__.__qualname__.__eq__,        ["str"],      true]
    - [st1096dc004, struct.Struct.__doc__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
    - [st1096dc005, struct.Struct.__name__.__eq__,                              ["Struct"],   true]
    - [st1096dc006, struct.Struct.__name__.__class__.__name__.__eq__,           ["str"],      true]
    - [st1096dc007, struct.Struct.__qualname__.__eq__,                          ["Struct"],   true]
    - [st1096dc008, struct.Struct.__module__.__eq__,                            ["struct"],   true]

table struct_extra1096.module_function_qualnames:
  description: "struct module-level pack, unpack, calcsize __qualname__ identity"
  kind: python_call_eq
  category: module_function_qualnames
  id_prefix: st1096fq
  columns: [id, function, args, expected]
  rows:
    - [st1096fq001, struct.pack.__qualname__.__eq__,        ["pack"],          true]
    - [st1096fq002, struct.unpack.__qualname__.__eq__,      ["unpack"],        true]
    - [st1096fq003, struct.calcsize.__qualname__.__eq__,    ["calcsize"],      true]
    - [st1096fq004, struct.pack_into.__qualname__.__eq__,   ["pack_into"],     true]
    - [st1096fq005, struct.unpack_from.__qualname__.__eq__, ["unpack_from"],   true]
    - [st1096fq006, struct.iter_unpack.__qualname__.__eq__, ["iter_unpack"],   true]
    - [st1096fq007, struct.pack.__qualname__.__class__.__name__.__eq__,     ["str"], true]
    - [st1096fq008, struct.unpack.__qualname__.__class__.__name__.__eq__,   ["str"], true]
    - [st1096fq009, struct.calcsize.__qualname__.__class__.__name__.__eq__, ["str"], true]
