spec: pathlib_extra132
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib class __name__ string lengths and __qualname__ equality for the full hierarchy."
    - "pathlib.Path.__name__ == 'Path' (length 4); __qualname__ == 'Path' (length 4)."
    - "pathlib.PurePath.__name__ == 'PurePath' (length 8); __qualname__ == 'PurePath' (length 8)."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath' (length 13)."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' (length 15)."
    - "pathlib.PosixPath.__name__ == 'PosixPath' (length 9)."
    - "pathlib.WindowsPath.__name__ == 'WindowsPath' (length 11)."
    - "For all pathlib classes defined at module level, __qualname__ == __name__ (no nested scope prefix)."
    - "pathlib.Path.__module__ == 'pathlib' (length 7); same for all pathlib classes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path and pathlib.PurePath __name__ lengths and __qualname__ equality
# Path.__name__ == 'Path' (len 4); PurePath.__name__ == 'PurePath' (len 8).
# For module-level classes, __qualname__ == __name__.
# __module__ == 'pathlib' for both.
# ---------------------------------------------------------------------------

table pathlib_extra132.Path_PurePath_name_lengths:
  description: "pathlib.Path and PurePath __name__ lengths and __qualname__ equality"
  kind: python_call_eq
  category: class_names
  id_prefix: pathlibnamelen132

  columns: [id, function, args, expected, description]
  rows:
    - [path_name_len,     Path.__name__.__len__,           [], 4,        "pathlib.Path.__name__.__len__() == 4 ('Path' has 4 characters)"]
    - [path_qname_eq,     Path.__qualname__.__eq__,        ["Path"],     true,  "pathlib.Path.__qualname__ == 'Path' (no enclosing scope prefix)"]
    - [path_qname_len,    Path.__qualname__.__len__,       [], 4,        "pathlib.Path.__qualname__.__len__() == 4"]
    - [path_mod_len,      Path.__module__.__len__,         [], 7,        "pathlib.Path.__module__.__len__() == 7 ('pathlib' has 7 characters)"]
    - [pp_name_len,       PurePath.__name__.__len__,       [], 8,        "pathlib.PurePath.__name__.__len__() == 8 ('PurePath' has 8 characters)"]
    - [pp_qname_eq,       PurePath.__qualname__.__eq__,    ["PurePath"], true,  "pathlib.PurePath.__qualname__ == 'PurePath'"]
    - [pp_qname_len,      PurePath.__qualname__.__len__,   [], 8,        "pathlib.PurePath.__qualname__.__len__() == 8"]
    - [path_mod_eq,       Path.__module__.__eq__,          ["pathlib"],  true,  "pathlib.Path.__module__ == 'pathlib'"]
    - [path_mod_neq,      Path.__module__.__eq__,          ["pathlib2"], false, "pathlib.Path.__module__ != 'pathlib2'"]

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath and PureWindowsPath __name__ lengths
# PurePosixPath.__name__ == 'PurePosixPath' (length 13).
# PureWindowsPath.__name__ == 'PureWindowsPath' (length 15).
# Both have __module__ == 'pathlib' and __qualname__ == __name__.
# ---------------------------------------------------------------------------

table pathlib_extra132.PurePosixPath_PureWindowsPath_name_lengths:
  description: "pathlib.PurePosixPath and PureWindowsPath __name__ lengths and __qualname__ equality"
  kind: python_call_eq
  category: class_names
  id_prefix: pathlibnamelen132

  columns: [id, function, args, expected, description]
  rows:
    - [ppp_name_len,   PurePosixPath.__name__.__len__,             [], 13,                  "pathlib.PurePosixPath.__name__.__len__() == 13 ('PurePosixPath' has 13 characters)"]
    - [ppp_qname_eq,   PurePosixPath.__qualname__.__eq__,          ["PurePosixPath"],       true,  "pathlib.PurePosixPath.__qualname__ == 'PurePosixPath'"]
    - [ppp_mod_eq,     PurePosixPath.__module__.__eq__,            ["pathlib"],             true,  "pathlib.PurePosixPath.__module__ == 'pathlib'"]
    - [pwp_name_len,   PureWindowsPath.__name__.__len__,           [], 15,                  "pathlib.PureWindowsPath.__name__.__len__() == 15 ('PureWindowsPath' has 15 characters)"]
    - [pwp_qname_eq,   PureWindowsPath.__qualname__.__eq__,        ["PureWindowsPath"],     true,  "pathlib.PureWindowsPath.__qualname__ == 'PureWindowsPath'"]
    - [pwp_mod_eq,     PureWindowsPath.__module__.__eq__,          ["pathlib"],             true,  "pathlib.PureWindowsPath.__module__ == 'pathlib'"]
    - [ppp_not_pwp,    PurePosixPath.__name__.__eq__,              ["PureWindowsPath"],     false, "pathlib.PurePosixPath.__name__ != 'PureWindowsPath'"]
    - [pwp_len_gt_ppp, PureWindowsPath.__name__.__len__,           [], 15,                  "PureWindowsPath.__name__ is longer (15) than PurePosixPath (13) by 2 characters"]

# ---------------------------------------------------------------------------
# pathlib.PosixPath and WindowsPath __name__ lengths
# PosixPath.__name__ == 'PosixPath' (length 9).
# WindowsPath.__name__ == 'WindowsPath' (length 11).
# Both have __module__ == 'pathlib'.
# ---------------------------------------------------------------------------

table pathlib_extra132.PosixPath_WindowsPath_name_lengths:
  description: "pathlib.PosixPath and WindowsPath __name__ lengths and __qualname__ equality"
  kind: python_call_eq
  category: class_names
  id_prefix: pathlibnamelen132

  columns: [id, function, args, expected, description]
  rows:
    - [posp_name_len,   PosixPath.__name__.__len__,   [], 9,             "pathlib.PosixPath.__name__.__len__() == 9 ('PosixPath' has 9 characters)"]
    - [posp_qname_eq,   PosixPath.__qualname__.__eq__, ["PosixPath"],    true,  "pathlib.PosixPath.__qualname__ == 'PosixPath'"]
    - [posp_mod_eq,     PosixPath.__module__.__eq__,   ["pathlib"],      true,  "pathlib.PosixPath.__module__ == 'pathlib'"]
    - [winp_name_len,   WindowsPath.__name__.__len__,  [], 11,           "pathlib.WindowsPath.__name__.__len__() == 11 ('WindowsPath' has 11 characters)"]
    - [winp_qname_eq,   WindowsPath.__qualname__.__eq__,["WindowsPath"], true,  "pathlib.WindowsPath.__qualname__ == 'WindowsPath'"]
    - [winp_mod_eq,     WindowsPath.__module__.__eq__, ["pathlib"],      true,  "pathlib.WindowsPath.__module__ == 'pathlib'"]
    - [winp_not_posp,   WindowsPath.__name__.__eq__,   ["PosixPath"],   false, "pathlib.WindowsPath.__name__ != 'PosixPath'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra132.Path.name_len_4:
  description: "pathlib.Path.__name__.__len__() == 4 ('Path' has exactly 4 characters: P-a-t-h)"
  category: class_names
  kind: python_call_eq
  function: Path.__name__.__len__
  args: []
  expected: 4

invariant pathlib_extra132.PurePath.name_len_8:
  description: "pathlib.PurePath.__name__.__len__() == 8 ('PurePath' has 8 characters: P-u-r-e-P-a-t-h)"
  category: class_names
  kind: python_call_eq
  function: PurePath.__name__.__len__
  args: []
  expected: 8

invariant pathlib_extra132.PurePosixPath.name_len_13:
  description: "pathlib.PurePosixPath.__name__.__len__() == 13 ('PurePosixPath' has 13 characters)"
  category: class_names
  kind: python_call_eq
  function: PurePosixPath.__name__.__len__
  args: []
  expected: 13

invariant pathlib_extra132.PureWindowsPath.name_len_15:
  description: "pathlib.PureWindowsPath.__name__.__len__() == 15 ('PureWindowsPath' has 15 characters)"
  category: class_names
  kind: python_call_eq
  function: PureWindowsPath.__name__.__len__
  args: []
  expected: 15

invariant pathlib_extra132.PosixPath.qualname_eq_name:
  description: "pathlib.PosixPath.__qualname__ == 'PosixPath' (for module-level classes, __qualname__ equals the bare class __name__ with no enclosing scope prefix)"
  category: class_names
  kind: python_call_eq
  function: PosixPath.__qualname__.__eq__
  args: ["PosixPath"]
  expected: true
