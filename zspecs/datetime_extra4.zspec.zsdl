spec: datetime_extra4
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
  notes:
    - "This spec extends datetime.zspec.zsdl, datetime_extra.zspec.zsdl, datetime_extra2.zspec.zsdl, datetime_extra3.zspec.zsdl, and datetime_timedelta.zspec.zsdl."
    - "datetime_extra3.zspec.zsdl covers: timezone.__name__/__module__ standalone; timezone.utc.__class__.__name__; date.fromisoformat/__name__; datetime.fromisoformat/__name__; datetime.now/__name__; date.today/__name__; datetime.utcnow/__name__; datetime.combine/__name__; fromisoformat round-trip parses."
    - "This spec adds: __module__ checks for datetime/date/time/timedelta/timezone/tzinfo; __bases__[0].__name__ checks for datetime/timedelta/timezone/tzinfo; MINYEAR/MAXYEAR __class__.__name__ and equality; date.min.__class__.__name__."
    - "datetime.datetime.__module__ == 'datetime' — datetime class is defined in the datetime module."
    - "datetime.date.__module__ == 'datetime' — date class is defined in the datetime module."
    - "datetime.time.__module__ == 'datetime' — time class is defined in the datetime module."
    - "datetime.timedelta.__module__ == 'datetime' — timedelta class is defined in the datetime module."
    - "datetime.timezone.__module__ == 'datetime' — covered in datetime_extra3; this spec adds tzinfo.__module__."
    - "datetime.datetime.__bases__[0].__name__ == 'date' — datetime inherits from date."
    - "datetime.timedelta.__bases__[0].__name__ == 'object' — timedelta is a direct subclass of object."
    - "datetime.timezone.__bases__[0].__name__ == 'tzinfo' — timezone is a direct subclass of tzinfo."
    - "datetime.tzinfo.__name__ == 'tzinfo' — the abstract base class for timezone info."
    - "datetime.tzinfo.__module__ == 'datetime' — tzinfo is defined in the datetime module."
    - "datetime.MINYEAR.__class__.__name__ == 'int' — MINYEAR is a plain int."
    - "datetime.MAXYEAR.__class__.__name__ == 'int' — MAXYEAR is a plain int."
    - "datetime.MINYEAR == 1 — the minimum representable year."
    - "datetime.MAXYEAR == 9999 — the maximum representable year."
    - "datetime.date.min.__class__.__name__ == 'date' — date.min is a date instance."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks — datetime, date, time, timedelta, tzinfo
#
# All core datetime classes are defined in the 'datetime' module (either as
# C extension types or as pure-Python classes). This section covers the
# remaining classes not yet added as standalone invariants in earlier specs.
# datetime_extra3 already covers timezone.__module__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant datetime_extra4.datetime.module:
  description: "datetime.datetime.__module__ == 'datetime'"
  category: class_modules
  kind: python_call_eq
  function: datetime.__module__.__eq__
  args: ["datetime"]
  expected: true

invariant datetime_extra4.date.module:
  description: "datetime.date.__module__ == 'datetime'"
  category: class_modules
  kind: python_call_eq
  function: date.__module__.__eq__
  args: ["datetime"]
  expected: true

invariant datetime_extra4.time.module:
  description: "datetime.time.__module__ == 'datetime'"
  category: class_modules
  kind: python_call_eq
  function: time.__module__.__eq__
  args: ["datetime"]
  expected: true

invariant datetime_extra4.timedelta.module:
  description: "datetime.timedelta.__module__ == 'datetime'"
  category: class_modules
  kind: python_call_eq
  function: timedelta.__module__.__eq__
  args: ["datetime"]
  expected: true

invariant datetime_extra4.tzinfo.module:
  description: "datetime.tzinfo.__module__ == 'datetime'"
  category: class_modules
  kind: python_call_eq
  function: tzinfo.__module__.__eq__
  args: ["datetime"]
  expected: true

# ---------------------------------------------------------------------------
# tzinfo — class name
#
# datetime.tzinfo is the abstract base class for timezone info objects.
# Its __name__ is 'tzinfo'.
# ---------------------------------------------------------------------------

invariant datetime_extra4.tzinfo.name:
  description: "datetime.tzinfo.__name__ == 'tzinfo'"
  category: class_names
  kind: python_call_eq
  function: tzinfo.__name__.__eq__
  args: ["tzinfo"]
  expected: true

# ---------------------------------------------------------------------------
# __bases__[0].__name__ — class hierarchy checks
#
# datetime.datetime is a subclass of datetime.date.
# datetime.timedelta is a direct subclass of object.
# datetime.timezone is a direct subclass of tzinfo.
# ---------------------------------------------------------------------------

invariant datetime_extra4.datetime.base_is_date:
  description: "datetime.datetime.__bases__[0].__name__ == 'date' — datetime inherits from date"
  category: class_hierarchy
  kind: python_call_eq
  function: datetime.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "date"

invariant datetime_extra4.timedelta.base_is_object:
  description: "datetime.timedelta.__bases__[0].__name__ == 'object' — timedelta is a direct subclass of object"
  category: class_hierarchy
  kind: python_call_eq
  function: timedelta.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant datetime_extra4.timezone.base_is_tzinfo:
  description: "datetime.timezone.__bases__[0].__name__ == 'tzinfo' — timezone is a direct subclass of tzinfo"
  category: class_hierarchy
  kind: python_call_eq
  function: timezone.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "tzinfo"

# ---------------------------------------------------------------------------
# MINYEAR and MAXYEAR — type checks
#
# datetime.MINYEAR and datetime.MAXYEAR are plain Python int constants.
# Their __class__.__name__ must be 'int'.
# ---------------------------------------------------------------------------

invariant datetime_extra4.MINYEAR.class_name:
  description: "datetime.MINYEAR.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: MINYEAR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant datetime_extra4.MAXYEAR.class_name:
  description: "datetime.MAXYEAR.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: MAXYEAR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# MINYEAR and MAXYEAR — value checks
#
# MINYEAR == 1 and MAXYEAR == 9999 are the boundaries of the representable
# range for date and datetime objects. Documented in the Python data model.
# ---------------------------------------------------------------------------

invariant datetime_extra4.MINYEAR.value:
  description: "datetime.MINYEAR == 1 — minimum representable year"
  category: constants
  kind: python_call_eq
  function: MINYEAR.__eq__
  args: [1]
  expected: true

invariant datetime_extra4.MAXYEAR.value:
  description: "datetime.MAXYEAR == 9999 — maximum representable year"
  category: constants
  kind: python_call_eq
  function: MAXYEAR.__eq__
  args: [9999]
  expected: true

# ---------------------------------------------------------------------------
# date.min — class name
#
# datetime.date.min is the earliest representable date (January 1, MINYEAR).
# It is a date instance, so its __class__.__name__ must be 'date'.
# ---------------------------------------------------------------------------

invariant datetime_extra4.date.min_class_name:
  description: "datetime.date.min.__class__.__name__ == 'date'"
  category: class_bounds
  kind: python_call_eq
  function: date.min.__class__.__name__.__eq__
  args: ["date"]
  expected: true
