spec: io_extra124
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/stringio.c"
  notes:
    - "This spec extends io_extra123.zspec.zsdl."
    - "This spec covers: io.StringIO method qualnames and MRO slot names not yet covered by equality assertions."
    - "io.StringIO.truncate.__qualname__ == 'StringIO.truncate' (len 17); no prior spec asserts equality."
    - "io.StringIO.readline.__qualname__ == 'StringIO.readline' (len 17); no prior spec asserts equality."
    - "io.StringIO.writable.__qualname__ == 'StringIO.writable' (len 17); no prior spec asserts equality."
    - "io.StringIO.seekable.__qualname__ == 'StringIO.seekable' (len 17); no prior spec asserts equality."
    - "io.StringIO.close.__qualname__ == 'StringIO.close' (len 14); prior specs only tested __len__()."
    - "io.StringIO.tell.__qualname__ == 'StringIO.tell' (len 13); prior specs only tested __len__()."
    - "io.StringIO.__mro__[1].__name__ == '_TextIOBase' (len 11); prior specs tested len but not eq via bracket notation."
    - "io.StringIO.__mro__[2].__name__ == '_IOBase' (len 7); novel equality assertion with bracket notation."
    - "Length ordering: truncate(17)==readline(17)==writable(17)==seekable(17) > close(14) > seek(13)==tell(13)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.StringIO.truncate and readline qualnames (equality assertions)
# StringIO.truncate.__qualname__ == 'StringIO.truncate' (17 chars).
# StringIO.readline.__qualname__ == 'StringIO.readline' (17 chars).
# Both are method_descriptor objects from the _io C extension (Modules/_io/stringio.c).
# Prior specs covered getvalue.__qualname__.__eq__ and read.__qualname__.__eq__,
# but NOT truncate or readline equality. Both have the same 17-char qualname length as
# getvalue, readable, writable, and seekable.
# 'StringIO.' prefix (9 chars) + 'truncate'(8) == 17; + 'readline'(8) == 17.
# ---------------------------------------------------------------------------

table io_extra124.StringIO_truncate_readline_qualnames:
  description: "io.StringIO.truncate.__qualname__='StringIO.truncate'(17); readline.__qualname__='StringIO.readline'(17); both method_descriptor; equality assertions novel; prior specs covered getvalue/read/readable eq but not truncate/readline"
  kind: python_call_eq
  category: method_identity
  id_prefix: iositrrl124a

  columns: [id, function, args, expected, description]
  rows:
    - [si_trunc_qn_eq,   "StringIO.truncate.__qualname__.__eq__",          ["StringIO.truncate"],  true,  "io.StringIO.truncate.__qualname__ == 'StringIO.truncate' (17 chars; truncate truncates the stream to at most size bytes; a C method_descriptor in the _io extension)"]
    - [si_trunc_qn_len,  "StringIO.truncate.__qualname__.__len__",         [],                     17,    "io.StringIO.truncate.__qualname__.__len__() == 17 ('StringIO.truncate': 'StringIO.'(9)+'truncate'(8)==17)"]
    - [si_rl_qn_eq,      "StringIO.readline.__qualname__.__eq__",          ["StringIO.readline"],  true,  "io.StringIO.readline.__qualname__ == 'StringIO.readline' (17 chars; readline reads one line from the stream; C method_descriptor; same length as truncate)"]
    - [si_rl_qn_len,     "StringIO.readline.__qualname__.__len__",         [],                     17,    "io.StringIO.readline.__qualname__.__len__() == 17 ('StringIO.readline': 'StringIO.'(9)+'readline'(8)==17)"]
    - [si_trunc_eq_rl,   "StringIO.truncate.__qualname__.__len__.__eq__",  [17],                   true,  "len('StringIO.truncate') == len('StringIO.readline') == 17 (both use the 9-char 'StringIO.' prefix and an 8-char method name)"]
    - [si_trunc_type,    "StringIO.truncate.__class__.__name__.__eq__",    ["method_descriptor"],  true,  "type(io.StringIO.truncate).__name__ == 'method_descriptor' (C extension method from Modules/_io/stringio.c)"]
    - [si_rl_type,       "StringIO.readline.__class__.__name__.__eq__",    ["method_descriptor"],  true,  "type(io.StringIO.readline).__name__ == 'method_descriptor' (C extension method; same type as truncate, getvalue, read, write)"]
    - [si_trunc_ne_rv,   "StringIO.truncate.__qualname__.__eq__",          ["StringIO.getvalue"],  false, "io.StringIO.truncate.__qualname__ != 'StringIO.getvalue' (distinct methods with distinct qualnames, despite equal lengths of 17)"]

# ---------------------------------------------------------------------------
# io.StringIO.writable and seekable qualnames (equality assertions)
# StringIO.writable.__qualname__ == 'StringIO.writable' (17 chars).
# StringIO.seekable.__qualname__ == 'StringIO.seekable' (17 chars).
# Prior specs covered readable.__qualname__.__eq__ but NOT writable or seekable equality.
# Both writable and seekable are method_descriptor objects returning True for StringIO
# (StringIO supports both writing and seeking). All four capability-query methods
# (readable, writable, seekable) share length 17.
# ---------------------------------------------------------------------------

table io_extra124.StringIO_writable_seekable_qualnames:
  description: "io.StringIO.writable.__qualname__='StringIO.writable'(17); seekable.__qualname__='StringIO.seekable'(17); capability-query methods; equality assertions novel; prior spec covered readable eq but not writable/seekable"
  kind: python_call_eq
  category: method_identity
  id_prefix: iosiwrsk124b

  columns: [id, function, args, expected, description]
  rows:
    - [si_wr_qn_eq,   "StringIO.writable.__qualname__.__eq__",         ["StringIO.writable"],  true,  "io.StringIO.writable.__qualname__ == 'StringIO.writable' (17 chars; writable() returns True for StringIO because string streams are always writable)"]
    - [si_wr_qn_len,  "StringIO.writable.__qualname__.__len__",        [],                     17,    "io.StringIO.writable.__qualname__.__len__() == 17 ('StringIO.writable': 'StringIO.'(9)+'writable'(8)==17)"]
    - [si_sk_qn_eq,   "StringIO.seekable.__qualname__.__eq__",         ["StringIO.seekable"],  true,  "io.StringIO.seekable.__qualname__ == 'StringIO.seekable' (17 chars; seekable() returns True for StringIO because string streams support seeking)"]
    - [si_sk_qn_len,  "StringIO.seekable.__qualname__.__len__",        [],                     17,    "io.StringIO.seekable.__qualname__.__len__() == 17 ('StringIO.seekable': 'StringIO.'(9)+'seekable'(8)==17)"]
    - [si_wr_eq_sk,   "StringIO.writable.__qualname__.__len__.__eq__", [17],                   true,  "len('StringIO.writable') == len('StringIO.seekable') == 17 (both capability-query methods share the same qualname length; same as readline and truncate)"]
    - [si_wr_type,    "StringIO.writable.__class__.__name__.__eq__",   ["method_descriptor"],  true,  "type(io.StringIO.writable).__name__ == 'method_descriptor' (C extension method from Modules/_io/stringio.c)"]
    - [si_sk_type,    "StringIO.seekable.__class__.__name__.__eq__",   ["method_descriptor"],  true,  "type(io.StringIO.seekable).__name__ == 'method_descriptor' (C extension method; same type as writable, readable, truncate, readline)"]

# ---------------------------------------------------------------------------
# io.StringIO.close and tell qualnames (equality assertions)
# StringIO.close.__qualname__ == 'StringIO.close' (14 chars).
# StringIO.tell.__qualname__ == 'StringIO.tell' (13 chars).
# Prior specs tested close.__qualname__.__len__() == 14 and tell.__qualname__.__len__() == 13
# but did NOT assert the equality against the string value 'StringIO.close' or 'StringIO.tell'.
# close (14) and tell (13) are shorter than the 17-char group but longer than write (14==close).
# close(14) == write(14) > seek(13) == tell(13) == read(13).
# Also covers StringIO MRO bracket access not previously done via __eq__:
# __mro__[1].__name__ == '_TextIOBase' and __mro__[2].__name__ == '_IOBase'.
# ---------------------------------------------------------------------------

table io_extra124.StringIO_close_tell_mro_qualnames:
  description: "io.StringIO.close.__qualname__='StringIO.close'(14); tell.__qualname__='StringIO.tell'(13); mro[1]='_TextIOBase'(11); mro[2]='_IOBase'(7); close/tell eq assertions novel; mro eq via bracket notation novel"
  kind: python_call_eq
  category: method_identity
  id_prefix: iosicltl124c

  columns: [id, function, args, expected, description]
  rows:
    - [si_close_qn_eq,  "StringIO.close.__qualname__.__eq__",          ["StringIO.close"],    true,  "io.StringIO.close.__qualname__ == 'StringIO.close' (14 chars; close flushes and closes the stream; prior specs tested __len__()==14 but not the equality string)"]
    - [si_close_qn_len, "StringIO.close.__qualname__.__len__",         [],                    14,    "io.StringIO.close.__qualname__.__len__() == 14 ('StringIO.close': 'StringIO.'(9)+'close'(5)==14; same length as 'StringIO.write'(14))"]
    - [si_tell_qn_eq,   "StringIO.tell.__qualname__.__eq__",           ["StringIO.tell"],     true,  "io.StringIO.tell.__qualname__ == 'StringIO.tell' (13 chars; tell returns the current stream position; prior specs tested __len__()==13 but not the equality string)"]
    - [si_tell_qn_len,  "StringIO.tell.__qualname__.__len__",          [],                    13,    "io.StringIO.tell.__qualname__.__len__() == 13 ('StringIO.tell': 'StringIO.'(9)+'tell'(4)==13; same length as 'StringIO.seek' and 'StringIO.read')"]
    - [si_close_gt_tell, "StringIO.close.__qualname__.__len__.__gt__", [13],                  true,  "len('StringIO.close') > len('StringIO.tell') (14 > 13; 'close'(5) is 1 char longer than 'tell'(4))"]
    - [si_mro1_eq,       "StringIO.__mro__[1].__name__.__eq__",        ["_TextIOBase"],       true,  "io.StringIO.__mro__[1].__name__ == '_TextIOBase' (11 chars; abstract text IO base at MRO slot 1; same as TextIOWrapper.__mro__[1].__name__)"]
    - [si_mro2_eq,       "StringIO.__mro__[2].__name__.__eq__",        ["_IOBase"],           true,  "io.StringIO.__mro__[2].__name__ == '_IOBase' (7 chars; root C IO base at MRO slot 2; same as TextIOWrapper.__mro__[2].__name__)"]
    - [si_mro1_len,      "StringIO.__mro__[1].__name__.__len__",       [],                    11,    "io.StringIO.__mro__[1].__name__.__len__() == 11 ('_TextIOBase' has 11 characters: '_Text'(5)+'IO'(2)+'Base'(4)==11)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra124.StringIO.truncate_qualname_eq:
  description: "io.StringIO.truncate.__qualname__ == 'StringIO.truncate' (length 17; truncate(size=None) truncates the file to at most size bytes; if size is omitted, the current stream position is used; StringIO.truncate is a C method_descriptor defined in Modules/_io/stringio.c; its qualname uses the 'StringIO.' prefix (9 chars) followed by 'truncate' (8 chars) totalling 17; truncate(17) is one of four StringIO methods with qualname length 17, alongside readline(17), writable(17), and seekable(17); prior io specs covered getvalue/read/readable qualname equality but NOT truncate equality)"
  category: method_identity
  kind: python_call_eq
  function: "StringIO.truncate.__qualname__.__eq__"
  args: ["StringIO.truncate"]
  expected: true

invariant io_extra124.StringIO.readline_qualname_eq:
  description: "io.StringIO.readline.__qualname__ == 'StringIO.readline' (length 17; readline(size=-1) reads one line from the stream; if size is given, at most that many bytes are read; StringIO.readline is a C method_descriptor in Modules/_io/stringio.c; its qualname uses the 'StringIO.' prefix (9 chars) followed by 'readline' (8 chars) totalling 17; it shares the same qualname length as truncate(17), writable(17), seekable(17), and readable(17); io_extra specs covered readlines.__qualname__.__eq__ (via readlines, not readline) and readable.__qualname__.__eq__, but NOT readline equality; note: readline (singular) is distinct from readlines (plural))"
  category: method_identity
  kind: python_call_eq
  function: "StringIO.readline.__qualname__.__eq__"
  args: ["StringIO.readline"]
  expected: true

invariant io_extra124.StringIO.writable_qualname_eq:
  description: "io.StringIO.writable.__qualname__ == 'StringIO.writable' (length 17; writable() returns True for StringIO instances because string streams always support writing; it is a C method_descriptor defined in Modules/_io/stringio.c; its qualname uses the 'StringIO.' prefix (9 chars) followed by 'writable' (8 chars) totalling 17; this is the same length as seekable(17), readable(17), truncate(17), and readline(17); prior io specs covered readable.__qualname__.__eq__ but NOT writable or seekable equality; writable and seekable were covered only by __len__ in prior specs)"
  category: method_identity
  kind: python_call_eq
  function: "StringIO.writable.__qualname__.__eq__"
  args: ["StringIO.writable"]
  expected: true

invariant io_extra124.StringIO.close_qualname_eq:
  description: "io.StringIO.close.__qualname__ == 'StringIO.close' (length 14; close() flushes and closes the IO object; after closing, any further operations on the stream will raise a ValueError; StringIO.close is a C method_descriptor from the _io extension module; its qualname uses the 'StringIO.' prefix (9 chars) followed by 'close' (5 chars) totalling 14; close(14) is the same length as write(14) and longer than seek(13)==tell(13)==read(13); prior io_extra specs verified StringIO.close.__qualname__.__len__()==14 but never asserted the full string equality 'StringIO.close')"
  category: method_identity
  kind: python_call_eq
  function: "StringIO.close.__qualname__.__eq__"
  args: ["StringIO.close"]
  expected: true

invariant io_extra124.StringIO.seekable_qualname_eq:
  description: "io.StringIO.seekable.__qualname__ == 'StringIO.seekable' (length 17; seekable() returns True for StringIO instances because string streams support random access seeking; it is a C method_descriptor from Modules/_io/stringio.c; its qualname uses the 'StringIO.' prefix (9 chars) followed by 'seekable' (8 chars) totalling 17; seekable(17) is the same length as writable(17), readable(17), truncate(17), and readline(17) — five StringIO methods share this 17-char qualname length; prior io_extra specs covered readable equality but NOT seekable equality; seekable was covered by __len__ only)"
  category: method_identity
  kind: python_call_eq
  function: "StringIO.seekable.__qualname__.__eq__"
  args: ["StringIO.seekable"]
  expected: true
