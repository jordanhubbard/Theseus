spec: functools_extra260
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.__all__ membership checks and functools.reduce error handling behavioral contracts."
    - "functools.__all__.__contains__('reduce') == True — 'reduce' is a public API member listed in __all__. Verified with Python 3.14.3."
    - "functools.__all__.__contains__('partial') == True — 'partial' is a public API member listed in __all__. Verified with Python 3.14.3."
    - "functools.__all__.__contains__('lru_cache') == True — 'lru_cache' is a public API member listed in __all__. Verified with Python 3.14.3."
    - "functools.__all__.__contains__('wraps') == True — 'wraps' is a public API member listed in __all__. Verified with Python 3.14.3."
    - "functools.__all__.__contains__('total_ordering') == True — 'total_ordering' is a public API member listed in __all__. Verified with Python 3.14.3."
    - "functools.__all__.__contains__('cache') == True — 'cache' is a public API member listed in __all__. Verified with Python 3.14.3."
    - "functools.__all__.__len__() == 15 — __all__ has exactly 15 public members. Verified with Python 3.14.3."
    - "functools.reduce(lambda x, y: x+y, []) raises TypeError: 'reduce() of empty iterable with no initial value'. Verified with Python 3.14.3."
    - "functools.lru_cache(maxsize='invalid') raises TypeError immediately: 'Expected first argument to be an integer, a callable, or None'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.__all__ membership
#
# functools.__all__ contains 'reduce', 'partial', 'lru_cache', 'wraps',
# 'total_ordering', 'cache'. __len__ is 15.
#
# These are the core public API members of the functools module. New to extra260.
# ---------------------------------------------------------------------------

table functools_extra260.all_membership:
  description: "functools.__all__ contains core public API members and has length 15; new to extra260"
  kind: python_call_eq
  category: identity
  id_prefix: ftall260

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_reduce,
       "__all__.__contains__",
       ["reduce"],
       true,
       "functools.__all__.__contains__('reduce') == True — 'reduce' is a public API member of functools listed in __all__; new to extra260"]
    - [all_contains_partial,
       "__all__.__contains__",
       ["partial"],
       true,
       "functools.__all__.__contains__('partial') == True — 'partial' is a public API member of functools listed in __all__; new to extra260"]
    - [all_contains_lru_cache,
       "__all__.__contains__",
       ["lru_cache"],
       true,
       "functools.__all__.__contains__('lru_cache') == True — 'lru_cache' is a public API member of functools listed in __all__; new to extra260"]
    - [all_contains_wraps,
       "__all__.__contains__",
       ["wraps"],
       true,
       "functools.__all__.__contains__('wraps') == True — 'wraps' is a public API member of functools listed in __all__; new to extra260"]
    - [all_len_15,
       "__all__.__len__",
       [],
       15,
       "functools.__all__.__len__() == 15 — __all__ has exactly 15 public members; new to extra260"]

# ---------------------------------------------------------------------------
# Table 2: functools.__all__ additional membership
#
# functools.__all__ also contains 'total_ordering' and 'cache'.
# New to extra260.
# ---------------------------------------------------------------------------

table functools_extra260.all_membership_ext:
  description: "functools.__all__ contains total_ordering and cache; new to extra260"
  kind: python_call_eq
  category: identity
  id_prefix: ftallext260

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_total_ordering,
       "__all__.__contains__",
       ["total_ordering"],
       true,
       "functools.__all__.__contains__('total_ordering') == True — 'total_ordering' is a public API member of functools listed in __all__; new to extra260"]
    - [all_contains_cache,
       "__all__.__contains__",
       ["cache"],
       true,
       "functools.__all__.__contains__('cache') == True — 'cache' is a public API member of functools listed in __all__ (added in 3.9); new to extra260"]
    - [all_contains_cmp_to_key,
       "__all__.__contains__",
       ["cmp_to_key"],
       true,
       "functools.__all__.__contains__('cmp_to_key') == True — 'cmp_to_key' is a public API member of functools listed in __all__; new to extra260"]
    - [all_contains_singledispatch,
       "__all__.__contains__",
       ["singledispatch"],
       true,
       "functools.__all__.__contains__('singledispatch') == True — 'singledispatch' is a public API member of functools listed in __all__; new to extra260"]
    - [all_contains_cached_property,
       "__all__.__contains__",
       ["cached_property"],
       true,
       "functools.__all__.__contains__('cached_property') == True — 'cached_property' is a public API member of functools listed in __all__; new to extra260"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra260
# ---------------------------------------------------------------------------

invariant functools_extra260.all.contains_reduce:
  description: "functools.__all__.__contains__('reduce') == True — 'reduce' is in the functools public API; new to extra260"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["reduce"]
  expected: true

invariant functools_extra260.all.contains_partial:
  description: "functools.__all__.__contains__('partial') == True — 'partial' is in the functools public API; new to extra260"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["partial"]
  expected: true

invariant functools_extra260.all.contains_lru_cache:
  description: "functools.__all__.__contains__('lru_cache') == True — 'lru_cache' is in the functools public API; new to extra260"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["lru_cache"]
  expected: true

invariant functools_extra260.all.contains_wraps:
  description: "functools.__all__.__contains__('wraps') == True — 'wraps' is in the functools public API; new to extra260"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["wraps"]
  expected: true

invariant functools_extra260.all.len_15:
  description: "functools.__all__.__len__() == 15 — exactly 15 public members in __all__; new to extra260"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 15

invariant functools_extra260.reduce.empty_raises_typeerror:
  description: "functools.reduce(lambda x,y: x+y, []) raises TypeError — reduce of empty iterable with no initial value is undefined; new to extra260"
  category: errors
  kind: python_call_raises
  function: reduce
  args: ["lambda x,y: x+y", []]
  raises: TypeError

invariant functools_extra260.lru_cache.invalid_maxsize_raises_typeerror:
  description: "functools.lru_cache(maxsize='invalid') raises TypeError immediately — maxsize must be an integer, callable, or None; new to extra260"
  category: errors
  kind: python_call_raises
  function: lru_cache
  args: ["invalid"]
  raises: TypeError
