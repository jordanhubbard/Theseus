spec: multiprocessing_extra77
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra76.zspec.zsdl."
    - "This spec covers: wave 244 theme — multiprocessing Queue/Pipe/Manager/Pool function identity + Process/exception hierarchy. NEW in extra77: multiprocessing.Queue.__class__.__name__=='method' (Queue is a bound method of the default context, not a class); multiprocessing.Pipe.__class__.__name__=='method'; multiprocessing.Manager.__class__.__name__=='method'; multiprocessing.Pool.__class__.__name__=='method'; multiprocessing.Process.__bases__[0].__name__=='BaseProcess'; multiprocessing.Process.__mro__.__len__()==3; multiprocessing.AuthenticationError.__bases__[0].__name__=='ProcessError'; multiprocessing.AuthenticationError.__mro__.__len__()==5; multiprocessing.ProcessError.__bases__[0].__name__=='Exception'; multiprocessing.ProcessError.__mro__.__len__()==4; multiprocessing.BufferTooShort.__bases__[0].__name__=='ProcessError'; multiprocessing.TimeoutError.__bases__[0].__name__=='ProcessError'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Queue.__class__.__name__ == 'method'. multiprocessing.Queue is a bound method on the default process context (BaseContext.Queue), not a class directly. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pipe.__class__.__name__ == 'method'. multiprocessing.Pipe is a bound method on the default process context, not a class directly. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Manager.__class__.__name__ == 'method'. multiprocessing.Manager is a bound method on the default process context. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__class__.__name__ == 'method'. multiprocessing.Pool is a bound method on the default process context, not a class directly. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess'. multiprocessing.Process inherits from BaseProcess defined in multiprocessing/process.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__mro__.__len__() == 3. MRO is [Process, BaseProcess, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError'. AuthenticationError extends ProcessError in the multiprocessing exception hierarchy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__mro__.__len__() == 5. MRO is [AuthenticationError, ProcessError, Exception, BaseException, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception'. ProcessError is the root of the multiprocessing exception hierarchy, extending Exception. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__mro__.__len__() == 4. MRO is [ProcessError, Exception, BaseException, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'. BufferTooShort extends ProcessError in the multiprocessing exception hierarchy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError'. multiprocessing.TimeoutError extends ProcessError in the multiprocessing exception hierarchy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Queue/Pipe/Manager/Pool function identity — extra77
#
# Wave 244 theme: Queue/Pipe/Manager/Pool class name identity (all 'method').
#
# multiprocessing.Queue.__class__.__name__ == 'method'
# multiprocessing.Pipe.__class__.__name__ == 'method'
# multiprocessing.Manager.__class__.__name__ == 'method'
# multiprocessing.Pool.__class__.__name__ == 'method'
# ---------------------------------------------------------------------------

table multiprocessing_extra77.Queue_Pipe_Manager_Pool_class_names:
  description: "multiprocessing Queue/Pipe/Manager/Pool __class__.__name__ checks in mpmore77 namespace — wave 244 theme: Queue/Pipe/Manager/Pool function identity; all are bound methods on the default process context (BaseContext), not classes; Queue.__class__.__name__=='method'; Pipe.__class__.__name__=='method'; Manager.__class__.__name__=='method'; Pool.__class__.__name__=='method'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmore77

  columns: [id, function, args, expected, description]
  rows:
    - [queue_class_name,   Queue.__class__.__name__.__eq__,   ["method"], true, "Queue.__class__.__name__ == 'method' — multiprocessing.Queue is a bound method of the default context; verified with Python 3.14.3"]
    - [pipe_class_name,    Pipe.__class__.__name__.__eq__,    ["method"], true, "Pipe.__class__.__name__ == 'method' — multiprocessing.Pipe is a bound method of the default context; verified with Python 3.14.3"]
    - [manager_class_name, Manager.__class__.__name__.__eq__, ["method"], true, "Manager.__class__.__name__ == 'method' — multiprocessing.Manager is a bound method of the default context; verified with Python 3.14.3"]
    - [pool_class_name,    Pool.__class__.__name__.__eq__,    ["method"], true, "Pool.__class__.__name__ == 'method' — multiprocessing.Pool is a bound method of the default context; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process bases and MRO length — extra77
#
# Process.__bases__[0].__name__ == 'BaseProcess'
# Process.__mro__.__len__() == 3
# ---------------------------------------------------------------------------

table multiprocessing_extra77.Process_bases_and_mro:
  description: "multiprocessing Process.__bases__[0].__name__ and __mro__.__len__ checks in mpmore77 namespace — wave 244 theme: Process inheritance hierarchy; Process.__bases__[0].__name__=='BaseProcess' (Process inherits from BaseProcess in multiprocessing/process.py); Process.__mro__.__len__()==3 (MRO is [Process, BaseProcess, object]); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmore77a

  columns: [id, function, args, expected, description]
  rows:
    - [proc_bases_name,  "Process.__bases__[0].__name__.__eq__", ["BaseProcess"], true, "Process.__bases__[0].__name__ == 'BaseProcess' — Process inherits from BaseProcess; verified with Python 3.14.3"]
    - [proc_mro_len,     Process.__mro__.__len__,                [],               3,    "Process.__mro__.__len__() == 3 — MRO is [Process, BaseProcess, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing AuthenticationError and ProcessError hierarchy — extra77
#
# AuthenticationError.__bases__[0].__name__ == 'ProcessError'
# AuthenticationError.__mro__.__len__() == 5
# ProcessError.__bases__[0].__name__ == 'Exception'
# ProcessError.__mro__.__len__() == 4
# ---------------------------------------------------------------------------

table multiprocessing_extra77.AuthenticationError_and_ProcessError_hierarchy:
  description: "multiprocessing AuthenticationError and ProcessError hierarchy checks in mpmore77 namespace — wave 244 theme: exception hierarchy; AuthenticationError.__bases__[0].__name__=='ProcessError' (AuthenticationError extends ProcessError); AuthenticationError.__mro__.__len__()==5 (MRO: AuthenticationError, ProcessError, Exception, BaseException, object); ProcessError.__bases__[0].__name__=='Exception' (root of multiprocessing exception hierarchy); ProcessError.__mro__.__len__()==4 (MRO: ProcessError, Exception, BaseException, object); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmore77b

  columns: [id, function, args, expected, description]
  rows:
    - [auth_err_bases_name,   "AuthenticationError.__bases__[0].__name__.__eq__", ["ProcessError"], true, "AuthenticationError.__bases__[0].__name__ == 'ProcessError' — AuthenticationError extends ProcessError; verified with Python 3.14.3"]
    - [auth_err_mro_len,      AuthenticationError.__mro__.__len__,                [],               5,    "AuthenticationError.__mro__.__len__() == 5 — MRO: AuthenticationError, ProcessError, Exception, BaseException, object; verified with Python 3.14.3"]
    - [proc_err_bases_name,   "ProcessError.__bases__[0].__name__.__eq__",        ["Exception"],    true, "ProcessError.__bases__[0].__name__ == 'Exception' — ProcessError is root of multiprocessing exception hierarchy; verified with Python 3.14.3"]
    - [proc_err_mro_len,      ProcessError.__mro__.__len__,                       [],               4,    "ProcessError.__mro__.__len__() == 4 — MRO: ProcessError, Exception, BaseException, object; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing BufferTooShort/TimeoutError hierarchy + cross-check — extra77
# ---------------------------------------------------------------------------

table multiprocessing_extra77.BufferTooShort_TimeoutError_and_cross_check:
  description: "multiprocessing BufferTooShort and TimeoutError hierarchy checks plus cross-check in mpmore77 namespace — wave 244 theme: BufferTooShort/TimeoutError hierarchy + cross-check; BufferTooShort.__bases__[0].__name__=='ProcessError'; TimeoutError.__bases__[0].__name__=='ProcessError'; Queue.__class__.__name__=='method' (cross-check); Process.__bases__[0].__name__=='BaseProcess' (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmore77c

  columns: [id, function, args, expected, description]
  rows:
    - [buf_short_bases_name,  "BufferTooShort.__bases__[0].__name__.__eq__", ["ProcessError"], true, "BufferTooShort.__bases__[0].__name__ == 'ProcessError' — BufferTooShort extends ProcessError; verified with Python 3.14.3"]
    - [timeout_err_bases_name, "TimeoutError.__bases__[0].__name__.__eq__",  ["ProcessError"], true, "TimeoutError.__bases__[0].__name__ == 'ProcessError' — multiprocessing.TimeoutError extends ProcessError; verified with Python 3.14.3"]
    - [queue_class_cross,     Queue.__class__.__name__.__eq__,               ["method"],       true, "Queue.__class__.__name__ == 'method' — cross-check; verified with Python 3.14.3"]
    - [proc_base_cross,       "Process.__bases__[0].__name__.__eq__",        ["BaseProcess"],  true, "Process.__bases__[0].__name__ == 'BaseProcess' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra77
# ---------------------------------------------------------------------------

invariant multiprocessing_extra77.Queue_class_name:
  description: "multiprocessing.Queue.__class__.__name__.__eq__('method') returns True — multiprocessing.Queue is a bound method of the default process context (BaseContext.Queue), not a class directly; this differs from e.g. multiprocessing.Process which is a class; NEW in extra77: first standalone __class__.__name__ invariant for Queue in mpmore77 namespace; wave 244; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Queue.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra77.Pipe_class_name:
  description: "multiprocessing.Pipe.__class__.__name__.__eq__('method') returns True — multiprocessing.Pipe is a bound method of the default process context, not a class directly; NEW in extra77: first standalone __class__.__name__ invariant for Pipe in mpmore77 namespace; wave 244; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Pipe.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra77.Process_mro_len:
  description: "multiprocessing.Process.__mro__.__len__() == 3 — MRO is [Process, BaseProcess, object]; Process directly inherits from BaseProcess with no intermediary; NEW in extra77: first standalone __mro__.__len__ invariant for Process in mpmore77 namespace; wave 244; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__mro__.__len__
  args: []
  expected: 3

invariant multiprocessing_extra77.AuthenticationError_mro_len:
  description: "multiprocessing.AuthenticationError.__mro__.__len__() == 5 — MRO is [AuthenticationError, ProcessError, Exception, BaseException, object]; four-level inheritance chain; NEW in extra77: first standalone __mro__.__len__ invariant for AuthenticationError in mpmore77 namespace; wave 244; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: AuthenticationError.__mro__.__len__
  args: []
  expected: 5

invariant multiprocessing_extra77.ProcessError_bases_name:
  description: "multiprocessing.ProcessError.__bases__[0].__name__.__eq__('Exception') returns True — ProcessError is the root of the multiprocessing exception hierarchy, extending Exception directly; NEW in extra77: first standalone __bases__[0].__name__ invariant for ProcessError in mpmore77 namespace; wave 244; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ProcessError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true
