spec: threading_extra131
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.__all__ list class identity, length, and membership for key names (Wave 260)."
    - "threading.__all__.__class__.__name__ == 'list' — __all__ is a plain Python list. Verified with Python 3.14.3."
    - "len(threading.__all__) == 28 — 28 exported names on Python 3.14.3. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('Thread') == True. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('Lock') == True. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('Event') == True. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('Semaphore') == True. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('Condition') == True. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('Timer') == True. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('Barrier') == True. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('RLock') == True. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('BoundedSemaphore') == True. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('local') == True. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.__all__ class identity and length
#
# Wave 260 theme: threading.__all__ list identity and length.
#
# threading.__all__.__class__.__name__ == 'list'
# len(threading.__all__) == 28
# threading.__all__.__class__.__bases__[0].__name__ == 'object'
#
# threading.__all__ is a plain Python list. On Python 3.14.3 it contains 28
# entries. New to extra131.
# ---------------------------------------------------------------------------

table threading_extra131.all_list_identity:
  description: "threading.__all__ __class__.__name__ == 'list' and __len__() == 28; module-level list of exported names; wave 260; new to extra131"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingall131

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_name_eq_list,
       "__all__.__class__.__name__.__eq__",
       ["list"],
       true,
       "threading.__all__.__class__.__name__.__eq__('list') == True — __all__ in threading is a plain Python list defined at module scope in Lib/threading.py; it controls what names are exported by 'from threading import *'; __class__.__name__ is 'list'; str.__eq__('list') returns True; new to extra131"]
    - [all_len_eq_28,
       "__all__.__len__",
       [],
       28,
       "threading.__all__.__len__() == 28 — on Python 3.14.3 threading.__all__ contains 28 names including Thread, Lock, RLock, Event, Semaphore, BoundedSemaphore, Condition, Barrier, Timer, local, get_ident, active_count, and others; list.__len__() returns 28; new to extra131"]
    - [all_class_bases_first_eq_object,
       "__all__.__class__.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.__all__.__class__.__bases__[0].__name__.__eq__('object') == True — list inherits directly from object; __class__.__bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra131"]

# ---------------------------------------------------------------------------
# Table 2: threading.__all__ membership for synchronization primitive names
#
# Wave 260 theme: threading.__all__ contains synchronization primitive class names.
#
# 'Thread' in threading.__all__ == True
# 'Lock' in threading.__all__ == True
# 'Event' in threading.__all__ == True
# 'Semaphore' in threading.__all__ == True
# 'Condition' in threading.__all__ == True
# 'Timer' in threading.__all__ == True
# 'Barrier' in threading.__all__ == True
#
# New to extra131.
# ---------------------------------------------------------------------------

table threading_extra131.all_membership_primitives:
  description: "threading.__all__.__contains__ for Thread, Lock, Event, Semaphore, Condition, Timer, Barrier; sync primitive names; wave 260; new to extra131"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingall131

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_Thread,
       "__all__.__contains__",
       ["Thread"],
       true,
       "threading.__all__.__contains__('Thread') == True — 'Thread' is listed in threading.__all__; Thread is the main thread class representing a thread of control; list.__contains__('Thread') returns True; new to extra131"]
    - [all_contains_Lock,
       "__all__.__contains__",
       ["Lock"],
       true,
       "threading.__all__.__contains__('Lock') == True — 'Lock' is listed in threading.__all__; Lock (alias for _thread.lock) is the primitive mutual-exclusion lock; list.__contains__('Lock') returns True; new to extra131"]
    - [all_contains_Event,
       "__all__.__contains__",
       ["Event"],
       true,
       "threading.__all__.__contains__('Event') == True — 'Event' is listed in threading.__all__; Event is a thread synchronization primitive for signaling between threads; list.__contains__('Event') returns True; new to extra131"]
    - [all_contains_Semaphore,
       "__all__.__contains__",
       ["Semaphore"],
       true,
       "threading.__all__.__contains__('Semaphore') == True — 'Semaphore' is listed in threading.__all__; Semaphore is a counting synchronization primitive; list.__contains__('Semaphore') returns True; new to extra131"]
    - [all_contains_Condition,
       "__all__.__contains__",
       ["Condition"],
       true,
       "threading.__all__.__contains__('Condition') == True — 'Condition' is listed in threading.__all__; Condition is a condition variable for producer-consumer coordination; list.__contains__('Condition') returns True; new to extra131"]
    - [all_contains_Timer,
       "__all__.__contains__",
       ["Timer"],
       true,
       "threading.__all__.__contains__('Timer') == True — 'Timer' is listed in threading.__all__; Timer is a Thread subclass that runs a function after a specified delay; list.__contains__('Timer') returns True; new to extra131"]
    - [all_contains_Barrier,
       "__all__.__contains__",
       ["Barrier"],
       true,
       "threading.__all__.__contains__('Barrier') == True — 'Barrier' is listed in threading.__all__; Barrier is a synchronization primitive that blocks threads until a fixed number have arrived; list.__contains__('Barrier') returns True; new to extra131"]

# ---------------------------------------------------------------------------
# Table 3: threading.__all__ membership for additional names
#
# Wave 260 theme: threading.__all__ contains additional threading utility names.
#
# 'RLock' in threading.__all__ == True
# 'BoundedSemaphore' in threading.__all__ == True
# 'local' in threading.__all__ == True
# 'get_ident' in threading.__all__ == True
# 'active_count' in threading.__all__ == True
# 'current_thread' in threading.__all__ == True
#
# New to extra131.
# ---------------------------------------------------------------------------

table threading_extra131.all_membership_extra:
  description: "threading.__all__.__contains__ for RLock, BoundedSemaphore, local, get_ident, active_count, current_thread; additional exported names; wave 260; new to extra131"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingall131

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_RLock,
       "__all__.__contains__",
       ["RLock"],
       true,
       "threading.__all__.__contains__('RLock') == True — 'RLock' is listed in threading.__all__; RLock is the reentrant lock factory function; list.__contains__('RLock') returns True; new to extra131"]
    - [all_contains_BoundedSemaphore,
       "__all__.__contains__",
       ["BoundedSemaphore"],
       true,
       "threading.__all__.__contains__('BoundedSemaphore') == True — 'BoundedSemaphore' is listed in threading.__all__; BoundedSemaphore is a Semaphore subclass that raises ValueError when released more times than acquired; list.__contains__('BoundedSemaphore') returns True; new to extra131"]
    - [all_contains_local,
       "__all__.__contains__",
       ["local"],
       true,
       "threading.__all__.__contains__('local') == True — 'local' is listed in threading.__all__; local is the thread-local storage class that provides per-thread attribute namespaces; list.__contains__('local') returns True; new to extra131"]
    - [all_contains_get_ident,
       "__all__.__contains__",
       ["get_ident"],
       true,
       "threading.__all__.__contains__('get_ident') == True — 'get_ident' is listed in threading.__all__; get_ident returns the thread identifier of the current thread as a nonzero integer; list.__contains__('get_ident') returns True; new to extra131"]
    - [all_contains_active_count,
       "__all__.__contains__",
       ["active_count"],
       true,
       "threading.__all__.__contains__('active_count') == True — 'active_count' is listed in threading.__all__; active_count returns the number of Thread objects currently alive; list.__contains__('active_count') returns True; new to extra131"]
    - [all_contains_current_thread,
       "__all__.__contains__",
       ["current_thread"],
       true,
       "threading.__all__.__contains__('current_thread') == True — 'current_thread' is listed in threading.__all__; current_thread returns the Thread object representing the calling thread; list.__contains__('current_thread') returns True; new to extra131"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra131
# ---------------------------------------------------------------------------

invariant threading_extra131.all_class_name_list:
  description: "threading.__all__.__class__.__name__ == 'list' — __all__ is a plain Python list; wave 260; new to extra131"
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant threading_extra131.all_len_28:
  description: "len(threading.__all__) == 28 — 28 exported names on Python 3.14.3; wave 260; new to extra131"
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 28

invariant threading_extra131.all_contains_Thread:
  description: "threading.__all__.__contains__('Thread') == True — 'Thread' is in threading.__all__; wave 260; new to extra131"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Thread"]
  expected: true

invariant threading_extra131.all_contains_Lock:
  description: "threading.__all__.__contains__('Lock') == True — 'Lock' is in threading.__all__; wave 260; new to extra131"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Lock"]
  expected: true

invariant threading_extra131.all_contains_Semaphore:
  description: "threading.__all__.__contains__('Semaphore') == True — 'Semaphore' is in threading.__all__; wave 260; new to extra131"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Semaphore"]
  expected: true

