spec: concurrent_futures_extra57
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "https://docs.python.org/3/library/importlib.html#importlib.machinery.SourceFileLoader — SourceFileLoader documentation"
    - "https://docs.python.org/3/reference/import.html#module-spec — ModuleSpec documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/_bootstrap_external.py"
    - "CPython source: Lib/importlib/_bootstrap_external.py"
  notes:
    - "This spec extends concurrent_futures_extra56.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__.__class__.__name__/__qualname__ tables, wait/__name__=='wait', as_completed/__name__=='as_completed', wait/__qualname__.__len__()==4, as_completed/__qualname__.__len__()==12 (extra51), class __class__.__name__/__qualname__ equality (extra44/extra45), wait/__class__.__module__=='builtins' and ThreadPoolExecutor/__class__.__module__=='builtins' (extra45), class __doc__/__class__/__module__=='builtins' tables (extra47/extra49), ProcessPoolExecutor/Future/Executor __class__.__module__.__eq__('builtins') (extra52), as_completed/__class__.__module__.__eq__('builtins') (extra52), ThreadPoolExecutor/ProcessPoolExecutor/Future __init__.__class__.__name__.__eq__('function') (extra52), class __repr__.__class__.__name__ tables (extra53), class __weakref__.__class__.__name__ tables (extra53), exception __repr__.__class__.__name__ tables (extra53), cf.__all__.__class__.__name__.__eq__('list') (extra54), cf.__all__.__len__()==14 (extra54), ThreadPoolExecutor/ProcessPoolExecutor/Future/CancelledError/TimeoutError/BrokenExecutor __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra54), cf.__all__.__contains__ membership checks (extra55), cf.__package__.__eq__('concurrent.futures') (extra55), Future/Executor __doc__.__class__.__name__.__eq__('str') (extra55), __loader__.__class__.__name__.__eq__('SourceFileLoader') (extra56), __spec__.__class__.__name__.__eq__('ModuleSpec') (extra56), __file__.__class__.__name__.__eq__('str') (extra56), __cached__.__class__.__name__.__eq__('str') (extra56)."
    - "This spec covers (cfspec57 namespace): wave 226 theme — __spec__.origin values + __spec__.submodule_search_locations checks + __loader__.__name__ length checks. concurrent.futures.__loader__.__class__.__name__.__len__() == 16 — len('SourceFileLoader') == 16. concurrent.futures.__spec__.origin.__class__.__name__.__eq__('str') — the origin is the file path to concurrent/futures/__init__.py; it is a plain str. concurrent.futures.__spec__.submodule_search_locations.__class__.__name__.__eq__('list') — concurrent.futures IS a subpackage; submodule_search_locations is NOT None; __class__.__name__ == 'list' in Python 3.14.3. concurrent.futures.__spec__.has_location == True — True for file-based packages. No prior concurrent.futures spec has captured these checks."
    - "concurrent.futures.__loader__.__class__.__name__.__len__() == 16. 'SourceFileLoader' has 16 characters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__spec__.origin.__class__.__name__ == 'str'. The spec origin is the absolute path to concurrent/futures/__init__.py, which is a plain Python str. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__spec__.submodule_search_locations.__class__.__name__ == 'list'. concurrent.futures is a subpackage; its submodule_search_locations is a list containing the futures package directory path. __class__.__name__ == 'list'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__spec__.has_location == True. concurrent.futures is a file-based subpackage (Lib/concurrent/futures/__init__.py exists on disk); has_location is True for all SourceFileLoader-loaded modules. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures __spec__.origin + submodule_search_locations + loader
# name len — extra57
#
# Wave 226 theme: __spec__.origin values + __spec__.submodule_search_locations
# checks + __loader__.__name__ length checks.
#
# concurrent.futures is a subpackage (Lib/concurrent/futures/__init__.py), so:
#   cf.__spec__.origin.__class__.__name__ == 'str'   (file path)
#   cf.__spec__.submodule_search_locations is NOT None
#   cf.__spec__.submodule_search_locations.__class__.__name__ == 'list'
#   cf.__spec__.has_location == True
#   cf.__loader__.__class__.__name__.__len__() == 16  (len of 'SourceFileLoader')
#
# No prior concurrent.futures spec has captured these checks. Extra57 introduces
# the wave 226 theme in the cfspec57 namespace.
# ---------------------------------------------------------------------------

table concurrent_futures_extra57.spec_origin_locations:
  description: "concurrent.futures __spec__.origin + submodule_search_locations + loader name length checks in cfspec57 namespace — cf is a subpackage (Lib/concurrent/futures/__init__.py); __spec__.origin is a str (file path); submodule_search_locations is NOT None and has __class__.__name__ == 'list'; has_location is True; __loader__.__class__.__name__.__len__() == 16 for 'SourceFileLoader'; wave 226 theme: __spec__.origin values + submodule_search_locations + loader name length; first origin/locations/has_location checks in any concurrent.futures spec"
  kind: python_call_eq
  category: spec_origin
  id_prefix: cfspec57

  columns: [id, function, args, expected, description]
  rows:
    - [loader_name_len,    concurrent.futures.__loader__.__class__.__name__.__len__,                   [],               16,   "cf.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters; cross-checks the __loader__.__class__.__name__.__eq__('SourceFileLoader') assertion in extra56; wave 226 first __loader__.__class__.__name__.__len__ check in any concurrent.futures spec"]
    - [origin_class_name,  concurrent.futures.__spec__.origin.__class__.__name__.__eq__,               ["str"],          true, "cf.__spec__.origin.__class__.__name__ == 'str' — the spec origin is the absolute file path to concurrent/futures/__init__.py; it is a plain Python str; __spec__.origin.__class__.__name__.__eq__('str') returns True; wave 226 first __spec__.origin type check in any concurrent.futures spec"]
    - [locations_cls_name, concurrent.futures.__spec__.submodule_search_locations.__class__.__name__.__eq__, ["list"],   true, "cf.__spec__.submodule_search_locations.__class__.__name__ == 'list' — concurrent.futures IS a subpackage; submodule_search_locations is a list containing the futures package directory path (NOT None); __class__.__name__ == 'list' in Python 3.14.3; wave 226 first submodule_search_locations class name check in any concurrent.futures spec"]
    - [has_location,       concurrent.futures.__spec__.has_location.__eq__,                            [true],           true, "cf.__spec__.has_location == True — concurrent.futures is a file-based subpackage (Lib/concurrent/futures/__init__.py); SourceFileLoader sets has_location to True for all disk-backed modules; __spec__.has_location.__eq__(True) returns True; wave 226 first has_location check in any concurrent.futures spec"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra57
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra57.loader_name_len:
  description: "cf.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters; cross-checks the string equality assertion established in extra56; wave 226 first __loader__.__class__.__name__.__len__ invariant in any concurrent.futures spec"
  category: spec_origin
  kind: python_call_eq
  function: concurrent.futures.__loader__.__class__.__name__.__len__
  args: []
  expected: 16

invariant concurrent_futures_extra57.origin_class_name_eq:
  description: "cf.__spec__.origin.__class__.__name__.__eq__('str') returns True — the spec origin is the absolute file path to concurrent/futures/__init__.py; it is a plain Python str; wave 226 first __spec__.origin type invariant in any concurrent.futures spec"
  category: spec_origin
  kind: python_call_eq
  function: concurrent.futures.__spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra57.locations_class_name_eq:
  description: "cf.__spec__.submodule_search_locations.__class__.__name__.__eq__('list') returns True — concurrent.futures IS a subpackage; submodule_search_locations is a list (NOT None); __class__.__name__ == 'list' in Python 3.14.3; wave 226 first submodule_search_locations class name invariant in any concurrent.futures spec"
  category: spec_origin
  kind: python_call_eq
  function: concurrent.futures.__spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant concurrent_futures_extra57.has_location_eq:
  description: "cf.__spec__.has_location.__eq__(True) returns True — concurrent.futures is a file-based subpackage loaded by SourceFileLoader; has_location is True for all disk-backed modules; wave 226 first has_location invariant in any concurrent.futures spec"
  category: spec_origin
  kind: python_call_eq
  function: concurrent.futures.__spec__.has_location.__eq__
  args: [true]
  expected: true
