    - ["th2776mx_ev_is",  Event.__dict__.__contains__,            ["__isub__"],      false]
    - ["th2776mx_ev_im",  Event.__dict__.__contains__,            ["__imul__"],      false]
    - ["th2776mx_ev_it",  Event.__dict__.__contains__,            ["__itruediv__"],  false]
    - ["th2776mx_cn_is",  Condition.__dict__.__contains__,        ["__isub__"],      false]
    - ["th2776mx_cn_im",  Condition.__dict__.__contains__,        ["__imul__"],      false]
    - ["th2776mx_cn_it",  Condition.__dict__.__contains__,        ["__itruediv__"],  false]
    - ["th2776mx_se_is",  Semaphore.__dict__.__contains__,        ["__isub__"],      false]
    - ["th2776mx_se_im",  Semaphore.__dict__.__contains__,        ["__imul__"],      false]
