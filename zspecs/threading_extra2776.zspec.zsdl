  description: "threading.Timer, Barrier, local — __isub__, __imul__, __itruediv__ dict-presence all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: th2776tbl

  columns: [id, function, args, expected]
  rows:
    - ["th2776tbl_ti_is",  Timer.__dict__.__contains__,   ["__isub__"],      false]
    - ["th2776tbl_ti_im",  Timer.__dict__.__contains__,   ["__imul__"],      false]
    - ["th2776tbl_ti_it",  Timer.__dict__.__contains__,   ["__itruediv__"],  false]
    - ["th2776tbl_ba_is",  Barrier.__dict__.__contains__,  ["__isub__"],      false]
    - ["th2776tbl_ba_im",  Barrier.__dict__.__contains__,  ["__imul__"],      false]
