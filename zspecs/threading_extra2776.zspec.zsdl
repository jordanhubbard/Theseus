    - ["th2776csb_cn_im",  Condition.__dict__.__contains__,        ["__imul__"],      false]
    - ["th2776csb_cn_it",  Condition.__dict__.__contains__,        ["__itruediv__"],  false]
    - ["th2776csb_se_is",  Semaphore.__dict__.__contains__,        ["__isub__"],      false]
    - ["th2776csb_se_im",  Semaphore.__dict__.__contains__,        ["__imul__"],      false]
