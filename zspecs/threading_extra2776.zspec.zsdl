# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra2776
# ---------------------------------------------------------------------------

invariant threading_extra2776.thread_no_isub:
  description: "'__isub__' not in threading.Thread.__dict__ — Thread is a pure-Python class for managing threads and does not implement the -= operator"
  category: behavior
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__isub__"]
  expected: false

invariant threading_extra2776.thread_no_imul:
  description: "'__imul__' not in threading.Thread.__dict__ — Thread does not implement the *= operator"
  category: behavior
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__imul__"]
  expected: false

invariant threading_extra2776.thread_no_itruediv:
  description: "'__itruediv__' not in threading.Thread.__dict__ — Thread does not implement the /= operator"
  category: behavior
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__itruediv__"]
  expected: false

invariant threading_extra2776.lock_no_isub:
  description: "'__isub__' not in threading.Lock.__dict__ — Lock is a C-level synchronization primitive with no -= operator support"
  category: behavior
  kind: python_call_eq
  function: Lock.__dict__.__contains__
  args: ["__isub__"]
  expected: false

invariant threading_extra2776.semaphore_no_imul:
  description: "'__imul__' not in threading.Semaphore.__dict__ — Semaphore does not implement the *= operator despite managing a counter internally"
  category: behavior
  kind: python_call_eq
  function: Semaphore.__dict__.__contains__
  args: ["__imul__"]
  expected: false

invariant threading_extra2776.barrier_no_itruediv:
  description: "'__itruediv__' not in threading.Barrier.__dict__ — Barrier does not implement the /= operator"
  category: behavior
  kind: python_call_eq
  function: Barrier.__dict__.__contains__
  args: ["__itruediv__"]
  expected: false
