spec: threading_extra2776
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "Wave 632 theme: __isub__, __imul__, and __itruediv__ dict-presence checks (in-place subtraction -=, in-place multiplication *=, in-place true division /=)."
    - "threading.Thread, Event, Condition, Semaphore, BoundedSemaphore, Timer, Barrier are pure-Python classes."
    - "threading.Lock is a C-level type (_thread.lock); its __name__ == 'lock' (lowercase)."
    - "threading.local is exposed as threading.local but the underlying class is _thread._local; __name__ == '_local'."
    - "None of the nine threading types define __isub__, __imul__, or __itruediv__ in their __dict__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Thread, Lock, Event — __isub__/__imul__/__itruediv__ dict-presence
#
# Thread and Event are pure-Python classes; Lock is a C-level type (_thread.lock).
# None defines in-place arithmetic operator dunders.
# All nine checks return False.
# ---------------------------------------------------------------------------

table threading_extra2776.thread_lock_event_operator_dict:
  description: "threading.Thread, Lock, Event — __isub__, __imul__, __itruediv__ dict-presence all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: th2776tle

  columns: [id, function, args, expected]
  rows:
    - ["th2776tle_th_is",  Thread.__dict__.__contains__, ["__isub__"],      false]
    - ["th2776tle_th_im",  Thread.__dict__.__contains__, ["__imul__"],      false]
    - ["th2776tle_th_it",  Thread.__dict__.__contains__, ["__itruediv__"],  false]
    - ["th2776tle_lk_is",  Lock.__dict__.__contains__,   ["__isub__"],      false]
    - ["th2776tle_lk_im",  Lock.__dict__.__contains__,   ["__imul__"],      false]
    - ["th2776tle_lk_it",  Lock.__dict__.__contains__,   ["__itruediv__"],  false]
    - ["th2776tle_ev_is",  Event.__dict__.__contains__,  ["__isub__"],      false]
    - ["th2776tle_ev_im",  Event.__dict__.__contains__,  ["__imul__"],      false]
    - ["th2776tle_ev_it",  Event.__dict__.__contains__,  ["__itruediv__"],  false]

