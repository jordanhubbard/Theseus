spec: re_extra2161
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "Theme: descriptor protocol dict-presence — checks for __get__, __set__, __delete__, __set_name__, fget, fset, fdel, __objclass__, __func__ in class __dict__."
    - "re.Pattern does not define __get__, __set__, __delete__, fget, fset, fdel, __set_name__, __objclass__, or __func__ in its own __dict__."
    - "re.Pattern exposes C-level member_descriptor instances (pattern, flags, groups) and a getset_descriptor instance (groupindex). These descriptor types define __get__, __set__, __delete__, and __objclass__ — but on the descriptor TYPE, not in re.Pattern.__dict__ itself."
    - "re.Match similarly exposes member_descriptor (string, re, pos, endpos) and getset_descriptor (lastindex, lastgroup, regs) instances but does not define descriptor protocol keys in its own __dict__."
    - "re.RegexFlag is an IntFlag subclass and does not define any descriptor protocol keys in its own __dict__."
    - "re.error is a plain exception subclass with no descriptor protocol keys in its __dict__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern — descriptor protocol dict-presence
#
# re.Pattern holds member_descriptor instances (pattern, flags, groups) and
# a getset_descriptor instance (groupindex) for its C-level attributes.
# The class does NOT define __get__, __set__, __delete__, fget, __objclass__,
# or __func__ as keys in its own __dict__.
# ---------------------------------------------------------------------------

table re_extra2161.Pattern_descriptor_presence:
  kind: python_call_eq
  category: descriptor_presence
  columns: [id, function, args, expected]
  rows:
    - ["re2161001", "re.Pattern.__dict__.__contains__", ["__get__"], false]
    - ["re2161002", "re.Pattern.__dict__.__contains__", ["__set__"], false]
    - ["re2161003", "re.Pattern.__dict__.__contains__", ["__delete__"], false]
    - ["re2161004", "re.Pattern.__dict__.__contains__", ["__set_name__"], false]
    - ["re2161005", "re.Pattern.__dict__.__contains__", ["fget"], false]
    - ["re2161006", "re.Pattern.__dict__.__contains__", ["fset"], false]
    - ["re2161007", "re.Pattern.__dict__.__contains__", ["fdel"], false]
    - ["re2161008", "re.Pattern.__dict__.__contains__", ["__objclass__"], false]
    - ["re2161009", "re.Pattern.__dict__.__contains__", ["__func__"], false]
    - ["re2161010", "re.Pattern.__dict__.__contains__", ["pattern"], true]
    - ["re2161011", "re.Pattern.__dict__.__contains__", ["flags"], true]
    - ["re2161012", "re.Pattern.__dict__.__contains__", ["groups"], true]
    - ["re2161013", "re.Pattern.__dict__.__contains__", ["groupindex"], true]
    - ["re2161014", "re.Pattern.__dict__.__contains__", ["match"], true]
    - ["re2161015", "re.Pattern.__dict__.__contains__", ["search"], true]
    - ["re2161016", "re.Pattern.__dict__.__contains__", ["findall"], true]

