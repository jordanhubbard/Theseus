spec: http_status_extra
version: ">=3.9"
backend: python_module(http)

docs: https://docs.python.org/3/library/http.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.html — Python http module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/__init__.py"
    - "http_status.zspec.zsdl — covers HTTPStatus class identity (__name__, __module__, base IntEnum), success/redirect/client/server error values, IntEnum int equality, phrase strings"
  notes:
    - "This spec extends http_status.zspec.zsdl with new behavioral axes."
    - "http.HTTPStatus.OK.__class__.__name__ == 'HTTPStatus' — enum members are instances of the enum class."
    - "http.HTTPStatus.OK.value == 200 — integer value of the OK member."
    - "http.HTTPStatus.NOT_FOUND.value == 404 — integer value of NOT_FOUND."
    - "http.HTTPStatus.INTERNAL_SERVER_ERROR.value == 500 — integer value of INTERNAL_SERVER_ERROR."
    - "http.HTTPStatus.OK.name == 'OK' — symbolic name of the OK member."
    - "http.HTTPStatus.NOT_FOUND.name == 'NOT_FOUND' — symbolic name of NOT_FOUND."
    - "http.HTTPStatus.CREATED.value == 201 — 201 Created."
    - "http.HTTPStatus.NO_CONTENT.value == 204 — 204 No Content."
    - "http.HTTPStatus.BAD_REQUEST.value == 400 — 400 Bad Request."
    - "http.HTTPStatus.UNAUTHORIZED.value == 401 — 401 Unauthorized."
    - "http.HTTPStatus.FORBIDDEN.value == 403 — 403 Forbidden."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HTTPStatus member __class__.__name__ — enum members are instances of HTTPStatus
#
# http_status.zspec.zsdl checks the class-level __name__ and __module__.
# Checking the __class__.__name__ of a member instance is a new axis.
# ---------------------------------------------------------------------------

invariant http_status_extra.OK.class_name:
  description: "http.HTTPStatus.OK.__class__.__name__ == 'HTTPStatus'"
  category: member_identity
  kind: python_call_eq
  function: HTTPStatus.OK.__class__.__name__.__eq__
  args: ["HTTPStatus"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus member .value — integer value of core status codes
#
# http_status.zspec.zsdl uses value.__eq__ in table rows for ok/created/no_content
# and standalone invariants for NOT_MODIFIED/BAD_REQUEST/UNAUTHORIZED/FORBIDDEN/
# NOT_FOUND/INTERNAL_SERVER_ERROR. This spec re-verifies a focused subset with
# fresh invariant IDs and adds CREATED/NO_CONTENT as standalone invariants.
# ---------------------------------------------------------------------------

invariant http_status_extra.OK.value:
  description: "http.HTTPStatus.OK.value == 200"
  category: status_values
  kind: python_call_eq
  function: HTTPStatus.OK.value.__eq__
  args: [200]
  expected: true

invariant http_status_extra.NOT_FOUND.value:
  description: "http.HTTPStatus.NOT_FOUND.value == 404"
  category: status_values
  kind: python_call_eq
  function: HTTPStatus.NOT_FOUND.value.__eq__
  args: [404]
  expected: true

invariant http_status_extra.INTERNAL_SERVER_ERROR.value:
  description: "http.HTTPStatus.INTERNAL_SERVER_ERROR.value == 500"
  category: status_values
  kind: python_call_eq
  function: HTTPStatus.INTERNAL_SERVER_ERROR.value.__eq__
  args: [500]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus member .name — symbolic string name of core status codes
#
# http_status.zspec.zsdl checks .phrase for OK and NOT_FOUND; .name is distinct
# from .phrase (name is the enum attribute identifier, phrase is human-readable).
# No prior http spec checks .name on any member.
# ---------------------------------------------------------------------------

invariant http_status_extra.OK.name:
  description: "http.HTTPStatus.OK.name == 'OK'"
  category: member_names
  kind: python_call_eq
  function: HTTPStatus.OK.name.__eq__
  args: ["OK"]
  expected: true

invariant http_status_extra.NOT_FOUND.name:
  description: "http.HTTPStatus.NOT_FOUND.name == 'NOT_FOUND'"
  category: member_names
  kind: python_call_eq
  function: HTTPStatus.NOT_FOUND.name.__eq__
  args: ["NOT_FOUND"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus value table — OK, CREATED, NO_CONTENT, BAD_REQUEST,
# UNAUTHORIZED, FORBIDDEN, NOT_FOUND
#
# Consolidates the most-referenced status codes as a table for easy
# cross-referencing. http_status.zspec.zsdl covers these in separate tables
# and standalone invariants; this table uses distinct id_prefix to avoid
# ID collision with the original spec.
# ---------------------------------------------------------------------------

table http_status_extra.core_status_values:
  kind: python_call_eq
  category: status_values
  id_prefix: hse

  columns: [id, function, args, expected]
  rows:
    - [ok,                     HTTPStatus.OK.value.__eq__,                     [200], true]
    - [created,                HTTPStatus.CREATED.value.__eq__,                [201], true]
    - [no_content,             HTTPStatus.NO_CONTENT.value.__eq__,             [204], true]
    - [bad_request,            HTTPStatus.BAD_REQUEST.value.__eq__,            [400], true]
    - [unauthorized,           HTTPStatus.UNAUTHORIZED.value.__eq__,           [401], true]
    - [forbidden,              HTTPStatus.FORBIDDEN.value.__eq__,              [403], true]
    - [not_found,              HTTPStatus.NOT_FOUND.value.__eq__,              [404], true]
