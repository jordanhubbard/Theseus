spec: pathlib_extra156
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.__dict__.__contains__ membership for the six public pathlib classes plus the re-exported os module."
    - "pathlib.__dict__ is a plain dict (len==154 on Python 3.14.3). All six public classes — Path, PurePath, PosixPath, WindowsPath, PurePosixPath, PureWindowsPath — are present in pathlib.__dict__."
    - "pathlib.__dict__.__contains__('os') == True — the pathlib module imports and re-exports the os module at module level, making pathlib.os an alias for the standard os module."
    - "pathlib.__dict__.__contains__('__version__') == False — pathlib does not define a __version__ attribute; version information comes from sys.version / importlib.metadata."
    - "pathlib.__dict__.__contains__('sep') == False — pathlib does not export a sep constant; path separators are accessed via os.sep or Path('/').root."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.__dict__.__contains__ — the six public pathlib classes
# Path, PurePath, PosixPath, WindowsPath, PurePosixPath, PureWindowsPath
# all True.
# ---------------------------------------------------------------------------

table pathlib_extra156.dict_contains_public_classes:
  description: "pathlib.__dict__.__contains__: all six public pathlib classes (Path, PurePath, PosixPath, WindowsPath, PurePosixPath, PureWindowsPath) are True"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibdict156

  columns: [id, function, args, expected, description]
  rows:
    - [has_Path,             __dict__.__contains__, ["Path"],             true, "pathlib.__dict__.__contains__('Path') == True (Path is the main concrete path class; on POSIX systems it resolves to PosixPath at instantiation time)"]
    - [has_PurePath,         __dict__.__contains__, ["PurePath"],         true, "pathlib.__dict__.__contains__('PurePath') == True (PurePath is the pure abstract base of the pathlib hierarchy; it supports path manipulation without filesystem access)"]
    - [has_PosixPath,        __dict__.__contains__, ["PosixPath"],        true, "pathlib.__dict__.__contains__('PosixPath') == True (PosixPath is the POSIX-specific concrete path class; instantiating it on Windows raises NotImplementedError)"]
    - [has_WindowsPath,      __dict__.__contains__, ["WindowsPath"],      true, "pathlib.__dict__.__contains__('WindowsPath') == True (WindowsPath is the Windows-specific concrete path class; instantiating it on non-Windows raises NotImplementedError)"]
    - [has_PurePosixPath,    __dict__.__contains__, ["PurePosixPath"],    true, "pathlib.__dict__.__contains__('PurePosixPath') == True (PurePosixPath is a pure POSIX path that can be used on any OS for path manipulation without filesystem access)"]
    - [has_PureWindowsPath,  __dict__.__contains__, ["PureWindowsPath"],  true, "pathlib.__dict__.__contains__('PureWindowsPath') == True (PureWindowsPath is a pure Windows path that can be used on any OS for Windows-style path manipulation without filesystem access)"]

# ---------------------------------------------------------------------------
# pathlib.__dict__.__contains__ — os re-export and absent attributes
# pathlib.__dict__.__contains__('os') == True.
# pathlib.__dict__.__contains__('__version__') == False.
# pathlib.__dict__.__contains__('sep') == False.
# pathlib.__dict__.__len__() == 154.
# pathlib.__dict__.__class__.__name__ == 'dict'.
# ---------------------------------------------------------------------------

table pathlib_extra156.dict_contains_misc_and_absent:
  description: "pathlib.__dict__.__contains__: os==True; __version__==False, sep==False; __dict__.__len__()==154; __dict__.__class__.__name__=='dict'"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibdict156

  columns: [id, function, args, expected, description]
  rows:
    - [has_os,          __dict__.__contains__, ["os"],           true,  "pathlib.__dict__.__contains__('os') == True — pathlib imports and exposes the os module at module level; pathlib.os is the standard os module (used internally for os.fspath, os.getcwd, os.stat, etc.)"]
    - [no_version,      __dict__.__contains__, ["__version__"],  false, "pathlib.__dict__.__contains__('__version__') == False — pathlib does not define a __version__ attribute; it is part of the standard library and does not carry its own version string"]
    - [no_sep,          __dict__.__contains__, ["sep"],          false, "pathlib.__dict__.__contains__('sep') == False — pathlib does not export a top-level sep constant; the separator is accessed as os.sep or via PurePosixPath('/').root or PureWindowsPath('C:\\\\').drive"]
    - [dict_len,        __dict__.__len__,      [],               154,   "pathlib.__dict__.__len__() == 154 — the pathlib module exports 154 names at module level on Python 3.14.3; this large count reflects the many internal helpers, ABC classes, and re-exported names from submodules"]
    - [dict_cls_eq,     __dict__.__class__.__name__.__eq__, ["dict"], true, "pathlib.__dict__.__class__.__name__ == 'dict' — module __dict__ attributes are plain dicts (unlike class __dict__ which are mappingproxy); the pathlib module dict is a regular mutable dict"]

# ---------------------------------------------------------------------------
# pathlib.__dict__.__contains__ name string lengths
# 'Path' (4), 'PurePath' (8), 'PosixPath' (9), 'WindowsPath' (11),
# 'PurePosixPath' (13), 'PureWindowsPath' (15).
# ---------------------------------------------------------------------------

table pathlib_extra156.class_name_lengths:
  description: "pathlib public class name lengths via __dict__.__contains__ strings: Path=4, PurePath=8, PosixPath=9, WindowsPath=11, PurePosixPath=13, PureWindowsPath=15"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibdict156

  columns: [id, function, args, expected, description]
  rows:
    - [path_namelen,        Path.__name__.__len__,            [], 4,  "pathlib.Path.__name__.__len__() == 4 ('Path' has 4 characters; shortest public pathlib class name)"]
    - [purepath_namelen,    PurePath.__name__.__len__,        [], 8,  "pathlib.PurePath.__name__.__len__() == 8 ('PurePath' has 8 characters)"]
    - [posixpath_namelen,   PosixPath.__name__.__len__,       [], 9,  "pathlib.PosixPath.__name__.__len__() == 9 ('PosixPath' has 9 characters)"]
    - [winpath_namelen,     WindowsPath.__name__.__len__,     [], 11, "pathlib.WindowsPath.__name__.__len__() == 11 ('WindowsPath' has 11 characters)"]
    - [pureposix_namelen,   PurePosixPath.__name__.__len__,   [], 13, "pathlib.PurePosixPath.__name__.__len__() == 13 ('PurePosixPath' has 13 characters)"]
    - [purewin_namelen,     PureWindowsPath.__name__.__len__, [], 15, "pathlib.PureWindowsPath.__name__.__len__() == 15 ('PureWindowsPath' has 15 characters; longest public pathlib class name)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra156.dict.has_Path:
  description: "pathlib.__dict__.__contains__('Path') == True — Path is the primary entry point for the pathlib module; on POSIX systems Path() instantiates a PosixPath, on Windows it instantiates a WindowsPath; Path provides a full set of filesystem operations (stat, open, read_text, write_text, mkdir, glob, iterdir, rename, unlink, etc.)"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Path"]
  expected: true

invariant pathlib_extra156.dict.has_PurePath:
  description: "pathlib.__dict__.__contains__('PurePath') == True — PurePath is the pure (no filesystem access) abstract base of the pathlib hierarchy; it provides path parsing, joining, and comparison operations without any OS calls; PurePath is the direct base of Path, PurePosixPath, and PureWindowsPath"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra156.dict.has_PureWindowsPath:
  description: "pathlib.__dict__.__contains__('PureWindowsPath') == True — PureWindowsPath is a pure Windows path that can be used on any operating system; it understands Windows drive letters, UNC paths, and backslash separators without making any filesystem calls; useful for cross-platform path manipulation"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["PureWindowsPath"]
  expected: true

invariant pathlib_extra156.dict.has_os:
  description: "pathlib.__dict__.__contains__('os') == True — the pathlib module imports the os module and exposes it at module level; pathlib.os is identical to the standard os module and is used internally by pathlib for low-level OS operations such as os.fspath(), os.getcwd(), os.stat(), and os.listdir()"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["os"]
  expected: true

invariant pathlib_extra156.dict.no_version:
  description: "pathlib.__dict__.__contains__('__version__') == False — pathlib is part of the Python standard library and does not carry a __version__ attribute; version tracking is done through Python's own version (sys.version) or via importlib.metadata for third-party packages"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["__version__"]
  expected: false

invariant pathlib_extra156.dict.class_is_dict:
  description: "pathlib.__dict__.__class__.__name__ == 'dict' — module __dict__ attributes are plain mutable Python dicts, contrasting with class __dict__ attributes which are read-only mappingproxy objects; this is true for all Python modules including pathlib"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true
