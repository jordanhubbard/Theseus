spec: decimal_extra149
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal arithmetic operator dunder method __qualname__ values (__add__, __mul__, __sub__); decimal.Context class identity (__name__, __module__); and Decimal.__name__.__len__() and Context.__name__.__len__() (both 7)."
    - "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (len=16; 'Decimal.' (8) + '__add__' (7) = 15... wait: 'Decimal.__add__' = 7 + 1 + 7 = 15 chars). Verified: len('Decimal.__add__') == 15."
    - "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__' (len=15). decimal.Decimal.__sub__.__qualname__ == 'Decimal.__sub__' (len=15). All three arithmetic dunder qualnames have length 15."
    - "decimal.Context.__name__ == 'Context' (len=7) and decimal.Context.__module__ == 'decimal'. Both primary decimal classes (Decimal and Context) have the same 7-character name length."
    - "decimal.Decimal.__name__.__len__() == 7 and decimal.Context.__name__.__len__() == 7 — these are equal, an unusual property where the module's two primary classes have identical name lengths."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal arithmetic operator dunder __qualname__ values
# Decimal prefix = 'Decimal.' = 8 chars.
# __add__.__qualname__ == 'Decimal.__add__' (len=15; 8 + 7 = 15)
# __mul__.__qualname__ == 'Decimal.__mul__' (len=15; 8 + 7 = 15)
# __sub__.__qualname__ == 'Decimal.__sub__' (len=15; 8 + 7 = 15)
# All three arithmetic dunders have identical qualname length (15).
# ---------------------------------------------------------------------------

table decimal_extra149.Decimal_arith_dunder_qualnames:
  description: "decimal.Decimal arithmetic dunder __qualname__ values: __add__/__mul__/__sub__ all equal 'Decimal.<op>' with len=15; the 'Decimal.' prefix (8) + 7-char dunder name = 15"
  kind: python_call_eq
  category: qualname
  id_prefix: decarith149

  columns: [id, function, args, expected, description]
  rows:
    - [add_qeq,  Decimal.__add__.__qualname__.__eq__,  ["Decimal.__add__"], true, "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (len=15; 'Decimal.' (8) + '__add__' (7) = 15; __add__ implements the '+' operator for Decimal arithmetic; returns NotImplemented for non-Decimal/int arguments; Decimal arithmetic is exact and follows the General Decimal Arithmetic specification)"]
    - [add_qlen, Decimal.__add__.__qualname__.__len__,  [],                  15,   "decimal.Decimal.__add__.__qualname__.__len__() == 15 ('Decimal.__add__' has 15 characters; tied with __mul__ and __sub__ at 15; all three primary arithmetic dunder methods share the same qualname length because their names are all 7 characters)"]
    - [mul_qeq,  Decimal.__mul__.__qualname__.__eq__,  ["Decimal.__mul__"], true, "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__' (len=15; 'Decimal.' (8) + '__mul__' (7) = 15; __mul__ implements the '*' operator; Decimal multiplication is exact up to the context precision; tied with __add__ and __sub__ at qualname length 15)"]
    - [mul_qlen, Decimal.__mul__.__qualname__.__len__,  [],                  15,   "decimal.Decimal.__mul__.__qualname__.__len__() == 15 ('Decimal.__mul__' has 15 characters; same as __add__ (15) and __sub__ (15); all three have 7-character dunder names combined with the 8-character 'Decimal.' prefix)"]
    - [sub_qeq,  Decimal.__sub__.__qualname__.__eq__,  ["Decimal.__sub__"], true, "decimal.Decimal.__sub__.__qualname__ == 'Decimal.__sub__' (len=15; 'Decimal.' (8) + '__sub__' (7) = 15; __sub__ implements the '-' operator; Decimal subtraction avoids floating-point cancellation issues common with binary floats; tied with __add__ and __mul__ at 15)"]
    - [sub_qlen, Decimal.__sub__.__qualname__.__len__,  [],                  15,   "decimal.Decimal.__sub__.__qualname__.__len__() == 15 ('Decimal.__sub__' has 15 characters; all three arithmetic dunders (__add__, __mul__, __sub__) have identical qualname lengths of 15 because they all use 7-letter dunder names with the 8-char 'Decimal.' prefix)"]

# ---------------------------------------------------------------------------
# decimal.Context class identity and decimal.Decimal name length
# Context.__name__ == 'Context' (len=7)
# Context.__module__ == 'decimal' (not '_decimal')
# Decimal.__name__.__len__() == 7 (same as Context)
# Context.__name__.__len__() == 7 (same as Decimal)
# ---------------------------------------------------------------------------

table decimal_extra149.Context_identity_and_name_lengths:
  description: "decimal.Context identity: __name__=='Context' (len=7), __module__=='decimal'; Decimal.__name__.__len__()==7 and Context.__name__.__len__()==7 are equal — both primary decimal class names are 7 chars"
  kind: python_call_eq
  category: identity
  id_prefix: decarith149

  columns: [id, function, args, expected, description]
  rows:
    - [ctx_name_eq,    Context.__name__.__eq__,    ["Context"], true, "decimal.Context.__name__ == 'Context' (len=7; the arithmetic context class that controls precision, rounding mode, and signal trapping; 'Context' has 7 characters — same as 'Decimal', and notably also the same as the module name 'decimal' (7))"]
    - [ctx_module_eq,  Context.__module__.__eq__,  ["decimal"], true, "decimal.Context.__module__ == 'decimal' (Context's __module__ is the public 'decimal' module, not '_decimal'; the C extension sets __module__ = 'decimal' for correct public attribution; same pattern as Decimal.__module__ == 'decimal')"]
    - [dec_name_len,   Decimal.__name__.__len__,   [],          7,    "decimal.Decimal.__name__.__len__() == 7 ('Decimal' has 7 characters; this equals Context.__name__.__len__() (7); both primary decimal classes share the same name length — an unusual symmetry in the decimal module)"]
    - [ctx_name_len,   Context.__name__.__len__,   [],          7,    "decimal.Context.__name__.__len__() == 7 ('Context' has 7 characters; equal to Decimal.__name__.__len__() (7); the module name 'decimal' also has 7 characters — the entire decimal module has a 7-character naming theme across module, Decimal class, and Context class)"]
    - [dec_name_eq_ctx_name_len, Decimal.__name__.__len__.__eq__, [7], true, "decimal.Decimal.__name__.__len__() == 7 (cross-check: both Decimal and Context have 7-character class names; this confirms the 7-char naming symmetry: 'decimal' (module, 7), 'Decimal' (class, 7), 'Context' (class, 7) — all seven characters)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra149.Decimal_add_qualname_eq:
  description: "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' — the __add__ method qualname follows the standard 'ClassName.method' pattern; len('Decimal.__add__') == 15 ('Decimal.' (8) + '__add__' (7) = 15); Decimal's __add__ implements IEEE 754-2008 decimal addition with exact results up to the current context precision; unlike float addition, Decimal.__add__ can produce exact results for decimal fractions like 0.1 + 0.2"
  category: qualname
  kind: python_call_eq
  function: Decimal.__add__.__qualname__.__eq__
  args: ["Decimal.__add__"]
  expected: true

invariant decimal_extra149.Decimal_mul_qualname_eq:
  description: "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__' — the __mul__ method qualname has length 15 ('Decimal.' (8) + '__mul__' (7) = 15); all three primary arithmetic dunder methods (__add__, __mul__, __sub__) share this length because they all have 7-character names; Decimal multiplication uses the current context precision and rounding mode specified by decimal.getcontext()"
  category: qualname
  kind: python_call_eq
  function: Decimal.__mul__.__qualname__.__eq__
  args: ["Decimal.__mul__"]
  expected: true

invariant decimal_extra149.Context_name_len_7:
  description: "decimal.Context.__name__.__len__() == 7 — 'Context' has 7 characters; this equals decimal.Decimal.__name__.__len__() (7) and also the module name 'decimal'.__len__() (7); the decimal module has a consistent 7-character naming theme across its module name and two primary public classes; Context objects control the precision, rounding, and signal-trapping behavior for all decimal arithmetic operations in a thread"
  category: identity
  kind: python_call_eq
  function: Context.__name__.__len__
  args: []
  expected: 7

invariant decimal_extra149.Context_module_is_decimal:
  description: "decimal.Context.__module__ == 'decimal' — Context's __module__ is 'decimal' (not '_decimal'); the C extension sets __module__ on both Decimal and Context to the public module name; this means repr(decimal.getcontext()) shows 'decimal.Context(...)' and type annotations referencing 'decimal.Context' resolve correctly; same public attribution pattern as decimal.Decimal.__module__ == 'decimal'"
  category: identity
  kind: python_call_eq
  function: Context.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra149.Decimal_sub_qualname_len_15:
  description: "decimal.Decimal.__sub__.__qualname__.__len__() == 15 — 'Decimal.__sub__' has 15 characters; all three arithmetic dunders (__add__, __mul__, __sub__) have qualname length 15 because all three method names are exactly 7 characters (the double-underscore prefix and suffix each contribute 2 chars: '__' + 3-char op + '__' = 7 for add/mul/sub); combined with 'Decimal.' (8): 8 + 7 = 15"
  category: qualname
  kind: python_call_eq
  function: Decimal.__sub__.__qualname__.__len__
  args: []
  expected: 15

