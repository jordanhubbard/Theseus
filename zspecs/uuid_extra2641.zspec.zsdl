spec: uuid_extra2641
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 623: checks uuid.UUID and uuid.SafeUUID __dict__ for __copy__, __deepcopy__, __sizeof__ presence. uuid.UUID is a plain Python class; uuid.SafeUUID is an IntEnum subclass. All return False — neither defines __copy__, __deepcopy__, nor __sizeof__ in its own __dict__."]
  created_at: "2026-04-13"
error_model: python_exceptions

table uuid_extra2641.UUID_dict_presence:
  description: "uuid.UUID __dict__ does not contain __copy__, __deepcopy__, or __sizeof__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu2641ud
  columns: [id, function, args, expected]
  rows:
    - ["uu2641ud001", uuid.UUID.__dict__.__contains__, ["__copy__"],     false]
    - ["uu2641ud002", uuid.UUID.__dict__.__contains__, ["__deepcopy__"], false]
    - ["uu2641ud003", uuid.UUID.__dict__.__contains__, ["__sizeof__"],   false]

