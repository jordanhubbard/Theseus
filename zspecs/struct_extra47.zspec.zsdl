spec: struct_extra47
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra46.zspec.zsdl — covers pack/unpack/calcsize/Struct/error __module__.__class__.__name__/__qualname__ and __module__.__len__()."
    - "struct_extra45.zspec.zsdl — covers Struct/pack/error __doc__.__class__.__qualname__.__eq__('str'), module __doc__.__class__.__name__/__qualname__/__module__, and Struct.pack/unpack/pack_into/unpack_from __qualname__.__eq__ via method call."
    - "struct_extra44.zspec.zsdl — covers Struct/pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/error __doc__.__class__.__name__.__eq__('str')."
    - "struct_extra43.zspec.zsdl — covers Struct/error __class__.__qualname__.__eq__('type') and pack/unpack/calcsize/pack_into/unpack_from/iter_unpack __class__.__qualname__.__eq__('builtin_function_or_method') and Struct/pack/error __class__.__module__.__eq__('builtins')."
    - "struct_extra42.zspec.zsdl — covers Struct/__class__.__name__.__eq__('type'), error.__class__.__name__.__eq__('type'), pack/unpack/calcsize/pack_into/unpack_from/iter_unpack.__class__.__name__.__eq__('builtin_function_or_method')."
    - "struct_extra41.zspec.zsdl — covers Struct.size/__name__.__eq__('size') and Struct.format/__name__/__qualname__.__eq__; Struct.size/format __class__.__name__.__eq__('getset_descriptor')."
    - "struct_extra39.zspec.zsdl — covers Struct/__mro__[1]/__name__.__eq__('object') and error/__mro__[3]/__name__.__eq__('object'); Struct.size.__qualname__.__eq__('Struct.size') and __qualname__.__len__()==11."
    - "struct_extra38.zspec.zsdl — covers Struct/error __bases__[0].__qualname__.__eq__; error/__mro__[1]/__name__.__eq__('Exception') and error/__mro__[2]/__name__.__eq__('BaseException')."
    - "struct_extra18.zspec.zsdl — covers Struct/__module__.__eq__('_struct') and all six module-level functions __module__.__eq__('_struct') and error/__module__.__eq__('struct')."
    - "struct_extra9.zspec.zsdl — covers Struct method pack/unpack/pack_into/unpack_from/iter_unpack __name__.__eq__ and __qualname__.__eq__."
    - "struct_extra4.zspec.zsdl — covers Struct.__name__.__eq__('Struct'), all module-level function __qualname__.__eq__ and error.__qualname__.__eq__."
  notes:
    - "This spec extends struct through struct_extra46; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: No prior struct spec checks __mro__[0].__name__.__eq__ for either Struct or error. struct_extra38 covers error/__mro__[1] ('Exception') and error/__mro__[2] ('BaseException'). struct_extra39 covers error/__mro__[3] ('object') and Struct/__mro__[1] ('object'). But mro[0] is always the class itself — Struct.__mro__[0].__name__ == 'Struct' and error.__mro__[0].__name__ == 'error'. These are novel: no prior spec checks the self-referential mro[0] entry. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__mro__[0].__name__ == 'Struct'. The first mro entry of a class is always the class itself; Struct.__mro__[0] is Struct. No prior spec checks Struct.__mro__[0].__name__.__eq__('Struct'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[0].__name__ == 'error'. error.__mro__[0] is the error class itself; its __name__ is 'error'. extra38 covers mro[1] and mro[2]; extra39 covers mro[3]. No prior spec checks error.__mro__[0].__name__.__eq__('error'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior struct spec checks __class__.__qualname__.__eq__('getset_descriptor') or __class__.__module__.__eq__('builtins') for Struct.size or Struct.format. struct_extra41 covers __class__.__name__.__eq__('getset_descriptor') for both (the __name__ axis). But __class__.__qualname__ is a distinct chain — for non-nested types, __qualname__ == __name__, but the access path is independent. Additionally, __class__.__module__ confirms that the getset_descriptor type lives in 'builtins'; this axis has never been checked for these descriptors. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__class__.__qualname__ == 'getset_descriptor'. Struct.size is a getset_descriptor; its type's __qualname__ is 'getset_descriptor'. struct_extra41 covers __class__.__name__.__eq__('getset_descriptor') (different chain). No prior spec checks Struct.size.__class__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__class__.__qualname__ == 'getset_descriptor'. Struct.format is also a getset_descriptor. struct_extra41 covers __class__.__name__.__eq__('getset_descriptor') (different chain). No prior spec checks Struct.format.__class__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__class__.__module__ == 'builtins'. The getset_descriptor type is defined in the Python C implementation; its __module__ is 'builtins'. No prior spec checks Struct.size.__class__.__module__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__class__.__module__ == 'builtins'. Same type as Struct.size. No prior spec checks Struct.format.__class__.__module__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior struct spec checks __mro__[0].__qualname__.__eq__ for Struct or error. struct_extra39 and struct_extra38 check __name__ for mro entries, but __qualname__ is a distinct axis. For top-level (non-nested) classes, __qualname__ == __name__, so Struct.__mro__[0].__qualname__ == 'Struct' and error.__mro__[0].__qualname__ == 'error'. These are novel on the __qualname__ axis. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__mro__[0].__qualname__ == 'Struct'. Struct is a non-nested class; its __qualname__ equals its __name__. No prior spec checks Struct.__mro__[0].__qualname__.__eq__('Struct'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[0].__qualname__ == 'error'. error is a non-nested exception class; its __qualname__ equals its __name__. No prior spec checks error.__mro__[0].__qualname__.__eq__('error'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__mro__[0] and struct.error.__mro__[0] __name__.__eq__
#
# struct_extra38 covers error/__mro__[1]/__name__.__eq__('Exception') and
#   error/__mro__[2]/__name__.__eq__('BaseException').
# struct_extra39 covers error/__mro__[3]/__name__.__eq__('object') and
#   Struct/__mro__[1]/__name__.__eq__('object').
# No prior spec checks __mro__[0].__name__.__eq__ for either Struct or error.
# __mro__[0] is always the class itself — a self-referential invariant that
# anchors the mro coverage. Contains '[' in access path so must be quoted.
# ---------------------------------------------------------------------------

table struct_extra47.mro0_name_eq:
  description: "struct.Struct/__mro__[0]/__name__.__eq__('Struct') and error/__mro__[0]/__name__.__eq__('error') — mro[0] is always the class itself; extra38 covers error mro[1]/mro[2]; extra39 covers error mro[3] and Struct mro[1]; no prior spec checks mro[0] __name__.__eq__ for Struct or error"
  kind: python_call_eq
  category: type_structure
  id_prefix: structexc47

  columns: [id, function, args, expected]
  rows:
    - [Struct_mro0_name_eq, "Struct.__mro__[0].__name__.__eq__", ["Struct"], true]
    - [error_mro0_name_eq,  "error.__mro__[0].__name__.__eq__",  ["error"],  true]

# ---------------------------------------------------------------------------
# struct.Struct.size and struct.Struct.format __class__.__qualname__ and
# __class__.__module__
#
# struct_extra41 covers Struct.size/__class__/__name__.__eq__('getset_descriptor')
#   and Struct.format/__class__/__name__.__eq__('getset_descriptor') (__name__ axis).
# No prior spec checks __class__.__qualname__ or __class__.__module__ for these
# descriptors. __qualname__ is a distinct attribute chain from __name__; for
# non-nested types like getset_descriptor, __qualname__ == __name__, but the
# access path is independent. __class__.__module__ == 'builtins' confirms the
# descriptor type belongs to the C implementation's built-in namespace.
# ---------------------------------------------------------------------------

table struct_extra47.descriptor_class_qualnames:
  description: "struct.Struct.size/format __class__.__qualname__.__eq__('getset_descriptor') — novel __class__.__qualname__ axis; struct_extra41 covers __class__.__name__.__eq__('getset_descriptor') (different chain); no prior spec checks __class__.__qualname__ for Struct.size or Struct.format"
  kind: python_call_eq
  category: type_structure
  id_prefix: structexc47

  columns: [id, function, args, expected]
  rows:
    - [size_class_qualname_eq,   Struct.size.__class__.__qualname__.__eq__,   ["getset_descriptor"], true]
    - [format_class_qualname_eq, Struct.format.__class__.__qualname__.__eq__, ["getset_descriptor"], true]

table struct_extra47.descriptor_class_modules:
  description: "struct.Struct.size/format __class__.__module__.__eq__('builtins') — getset_descriptor type lives in the C built-in namespace; no prior struct spec checks __class__.__module__ for Struct.size or Struct.format; struct_extra43 covers Struct/pack/error __class__.__module__.__eq__('builtins') (different objects)"
  kind: python_call_eq
  category: type_structure
  id_prefix: structexc47

  columns: [id, function, args, expected]
  rows:
    - [size_class_module_eq,   Struct.size.__class__.__module__.__eq__,   ["builtins"], true]
    - [format_class_module_eq, Struct.format.__class__.__module__.__eq__, ["builtins"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__mro__[0] and struct.error.__mro__[0] __qualname__.__eq__
#
# Distinct axis from __name__: __qualname__ for non-nested top-level classes
# equals __name__, but the attribute chain .__qualname__ is independent.
# No prior spec checks __mro__[0].__qualname__.__eq__ for either Struct or error.
# Complements the __name__ axis in the mro0_name_eq table above.
# Contains '[' in access path so must be quoted.
# ---------------------------------------------------------------------------

table struct_extra47.mro0_qualname_eq:
  description: "struct.Struct/__mro__[0]/__qualname__.__eq__('Struct') and error/__mro__[0]/__qualname__.__eq__('error') — mro[0] is the class itself; for non-nested classes, __qualname__ == __name__; novel __qualname__ axis on mro[0]; no prior spec checks mro[0].__qualname__ for any struct class"
  kind: python_call_eq
  category: type_structure
  id_prefix: structexc47

  columns: [id, function, args, expected]
  rows:
    - [Struct_mro0_qualname_eq, "Struct.__mro__[0].__qualname__.__eq__", ["Struct"], true]
    - [error_mro0_qualname_eq,  "error.__mro__[0].__qualname__.__eq__",  ["error"],  true]
