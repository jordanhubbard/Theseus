spec: functools_extra1951
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 577 (_extra1951): __contains__, __iter__, __next__, __aiter__, __anext__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "functools.partial, functools.partialmethod, functools.cached_property, and functools.lru_cache do NOT define __contains__ in their own __dict__."
    - "None of the functools classes define __iter__ or __next__ — they are not iterators."
    - "None of the functools classes define __aiter__ or __anext__ — functools has no async iterator types."
    - "functools.partial.__dict__.__contains__ returns False for all five membership/iteration dunder names."
  created_at: "2026-04-12"
error_model: python_exceptions

table functools_extra1951.contains_protocol:
  description: "functools types __contains__ dict-presence checks — none define __contains__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft1951
  columns: [id, function, args, expected]
  rows:
    - ["ft1951001", "functools.partial.__dict__.__contains__",         ["__contains__"], false]
    - ["ft1951002", "functools.partialmethod.__dict__.__contains__",   ["__contains__"], false]
    - ["ft1951003", "functools.cached_property.__dict__.__contains__", ["__contains__"], false]
    - ["ft1951004", "functools.lru_cache.__dict__.__contains__",       ["__contains__"], false]

