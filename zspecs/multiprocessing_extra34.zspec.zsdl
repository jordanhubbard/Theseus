spec: multiprocessing_extra34
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — Pool class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra33.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() for Pool/Queue/Lock/Event/Semaphore/Barrier, Process method __qualname__.__len__() for start/run/join/terminate/is_alive/kill, Pool method __qualname__.__eq__() tables (extra11 — only for old Python; fail on 3.14), AuthenticationError/ProcessError/BufferTooShort __bases__[0].__name__, Process/AuthenticationError/ProcessError __mro__.__len__(), __all__ metadata, class __dict__.__class__.__name__.__len__() tables, DefaultContext method qualname lengths, BufferTooShort/TimeoutError qualname lengths, synchronize.Lock/Event/Semaphore identity and hierarchy, queues.Queue identity and hierarchy, Process.__bases__[0].__name__.__len__()==11, Process.__dict__.__class__.__name__.__len__()==12, exception __name__.__len__() and __mro__.__len__() tables, cpu_count/__name__.__len__()==9, current_process/__name__.__len__()==15, BaseProcess class metadata, Process.__init__.__qualname__.__len__()==20."
    - "This spec covers: pool.Pool.map.__qualname__.__len__()==8; pool.Pool.apply.__qualname__.__len__()==10; pool.Pool.apply_async.__qualname__.__len__()==16; pool.Pool.map_async.__qualname__.__len__()==14; pool.Pool.starmap.__qualname__.__len__()==12; pool.Pool.close.__qualname__.__len__()==10; pool.Pool.starmap_async.__qualname__.__len__()==18; pool.Pool.terminate.__qualname__.__len__()==14."
    - "The Pool class in multiprocessing.pool (accessed as pool.Pool in the backend) defines all of its methods directly, so every __qualname__ has the 'Pool.' prefix."
    - "pool.Pool.map.__qualname__ == 'Pool.map' (8 chars): 'Pool' (4) + '.' (1) + 'map' (3) = 8."
    - "pool.Pool.apply and pool.Pool.close share the same __qualname__ length (10): 'Pool.apply' and 'Pool.close' both have 10 characters."
    - "pool.Pool.map_async and pool.Pool.terminate share the same __qualname__ length (14): 'Pool.map_async' and 'Pool.terminate' both have 14 characters."
    - "pool.Pool.starmap_async.__qualname__.__len__() == 18 — the longest Pool method qualname in this spec: 'Pool.starmap_async' = 'Pool' (4) + '.' (1) + 'starmap_async' (13) = 18."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool method __qualname__.__len__() — extra34 namespace
#
# The Pool class in the multiprocessing.pool submodule defines all its key
# methods directly. Their __qualname__ values carry the 'Pool.' prefix.
# Accessed via the 'pool' attribute of the multiprocessing module (submodule
# import), these are resolved as pool.Pool.<method>:
#   pool.Pool.map.__qualname__          == 'Pool.map'          ( 8 chars)
#   pool.Pool.apply.__qualname__        == 'Pool.apply'        (10 chars)
#   pool.Pool.close.__qualname__        == 'Pool.close'        (10 chars)
#   pool.Pool.starmap.__qualname__      == 'Pool.starmap'      (12 chars)
#   pool.Pool.map_async.__qualname__    == 'Pool.map_async'    (14 chars)
#   pool.Pool.terminate.__qualname__    == 'Pool.terminate'    (14 chars)
#   pool.Pool.apply_async.__qualname__  == 'Pool.apply_async'  (16 chars)
#   pool.Pool.starmap_async.__qualname__ == 'Pool.starmap_async' (18 chars)
# apply/close share length 10; map_async/terminate share length 14.
# No prior multiprocessing spec has captured these __qualname__.__len__()
# values as table rows or invariants that pass verification on Python 3.14.
# ---------------------------------------------------------------------------

table multiprocessing_extra34.pool_method_qualname_lengths:
  description: "multiprocessing.pool.Pool method __qualname__.__len__() in extra34 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: poolmqlen34

  columns: [id, function, args, expected]
  rows:
    - [map,          "pool.Pool.map.__qualname__.__len__",          [], 8]
    - [apply,        "pool.Pool.apply.__qualname__.__len__",        [], 10]
    - [close,        "pool.Pool.close.__qualname__.__len__",        [], 10]
    - [starmap,      "pool.Pool.starmap.__qualname__.__len__",      [], 12]
    - [map_async,    "pool.Pool.map_async.__qualname__.__len__",    [], 14]
    - [terminate,    "pool.Pool.terminate.__qualname__.__len__",    [], 14]
    - [apply_async,  "pool.Pool.apply_async.__qualname__.__len__",  [], 16]
    - [starmap_async,"pool.Pool.starmap_async.__qualname__.__len__",[], 18]

# ---------------------------------------------------------------------------
# Standalone invariants — extra34
# ---------------------------------------------------------------------------

invariant multiprocessing_extra34.pool_Pool_map_qualname_len:
  description: "multiprocessing.pool.Pool.map.__qualname__.__len__() == 8 — 'Pool.map' has 8 characters; the shortest Pool method qualname in this spec"
  category: method_names
  kind: python_call_eq
  function: "pool.Pool.map.__qualname__.__len__"
  args: []
  expected: 8

invariant multiprocessing_extra34.pool_Pool_starmap_async_qualname_len:
  description: "multiprocessing.pool.Pool.starmap_async.__qualname__.__len__() == 18 — 'Pool.starmap_async' has 18 characters; the longest Pool method qualname in this spec"
  category: method_names
  kind: python_call_eq
  function: "pool.Pool.starmap_async.__qualname__.__len__"
  args: []
  expected: 18

invariant multiprocessing_extra34.pool_Pool_apply_async_qualname_len:
  description: "multiprocessing.pool.Pool.apply_async.__qualname__.__len__() == 16 — 'Pool.apply_async' has 16 characters"
  category: method_names
  kind: python_call_eq
  function: "pool.Pool.apply_async.__qualname__.__len__"
  args: []
  expected: 16
