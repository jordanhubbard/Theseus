# ProcessPoolExecutor.__init__.__code__.co_varnames[5] == 'max_tasks_per_child' (len=19, longest)
# ProcessPoolExecutor.__init__.__code__.co_varnames[6] == 'queue_size'         (len=10)
# ---------------------------------------------------------------------------

table concurrent_futures_extra118.ppe_init_co_varnames_last3:
  description: "concurrent.futures.ProcessPoolExecutor.__init__ co_varnames elements [4]-[6] equality checks in cfppe118a namespace — wave 260 theme: last three elements of ProcessPoolExecutor.__init__ co_varnames; co_varnames[4].__eq__('initargs')==True (len=8: initargs is the tuple of arguments passed to the initializer callable in each worker process; same name as ThreadPoolExecutor.__init__ co_varnames[4]='initargs' at the same index with same length=8; 'initargs'=8: 'init'=4+'args'=4=8); co_varnames[5].__eq__('max_tasks_per_child')==True (len=19: max_tasks_per_child limits the number of tasks each worker process executes before being replaced; added in Python 3.11; this is the longest parameter name in ProcessPoolExecutor.__init__ at 19 chars: 'max'=3+'_'=1+'tasks'=5+'_'=1+'per'=3+'_'=1+'child'=5=19; unique to ProcessPoolExecutor — ThreadPoolExecutor has no equivalent); co_varnames[6].__eq__('queue_size')==True (len=10: queue_size controls the size of the call queue between the main process and workers; added in Python 3.14; 'queue_size'=10: 'queue'=5+'_'=1+'size'=4=10; tied with 'mp_context'=10 at index 2); element length ordering: self=4 < initargs=8 < mp_context==queue_size=10 (tied) < max_workers==initializer=11 (tied) < max_tasks_per_child=19 (longest, 8 more than max_workers=11); co_qualname.__len__()==28 ('ProcessPoolExecutor.__init__'=28: 1 more than ThreadPoolExecutor.__init__=27); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfppe118a

  columns: [id, function, args, expected, description]
  rows:
    - [v4_eq,    "ProcessPoolExecutor.__init__.__code__.co_varnames[4].__eq__",  ["initargs"],             true, "ProcessPoolExecutor.__init__ co_varnames[4] == 'initargs' (len=8; args for initializer); verified with Python 3.14.3"]
    - [v4_len,   "ProcessPoolExecutor.__init__.__code__.co_varnames[4].__len__", [],                       8,    "ProcessPoolExecutor.__init__ co_varnames[4].__len__() == 8 ('initargs'=8); verified with Python 3.14.3"]
    - [v5_eq,    "ProcessPoolExecutor.__init__.__code__.co_varnames[5].__eq__",  ["max_tasks_per_child"],  true, "ProcessPoolExecutor.__init__ co_varnames[5] == 'max_tasks_per_child' (len=19, longest in spec); verified with Python 3.14.3"]
    - [v5_len,   "ProcessPoolExecutor.__init__.__code__.co_varnames[5].__len__", [],                       19,   "ProcessPoolExecutor.__init__ co_varnames[5].__len__() == 19 ('max_tasks_per_child'=19, longest element); verified with Python 3.14.3"]
    - [v6_eq,    "ProcessPoolExecutor.__init__.__code__.co_varnames[6].__eq__",  ["queue_size"],           true, "ProcessPoolExecutor.__init__ co_varnames[6] == 'queue_size' (len=10; tied with mp_context=10); verified with Python 3.14.3"]
    - [v6_len,   "ProcessPoolExecutor.__init__.__code__.co_varnames[6].__len__", [],                       10,   "ProcessPoolExecutor.__init__ co_varnames[6].__len__() == 10 ('queue_size'=10; tied with 'mp_context'=10 at index 2); verified with Python 3.14.3"]
    - [qn_len,   "ProcessPoolExecutor.__init__.__code__.co_qualname.__len__",    [],                       28,   "ProcessPoolExecutor.__init__ co_qualname.__len__() == 28 ('ProcessPoolExecutor.__init__': 'ProcessPoolExecutor.'=20+'__init__'=8=28); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ProcessPoolExecutor vs ThreadPoolExecutor __init__ co_varnames comparison — extra118
#
# Wave 260 theme: compare ProcessPoolExecutor and ThreadPoolExecutor __init__ parameters.
#
# Both share: max_workers[1], initializer[3], initargs[4] — same name and index.
# ProcessPoolExecutor unique: mp_context[2], max_tasks_per_child[5], queue_size[6].
# ThreadPoolExecutor unique: thread_name_prefix[2], ctxkwargs[5].
# ProcessPoolExecutor co_varnames len=7 vs ThreadPoolExecutor len=6.
# ---------------------------------------------------------------------------

table concurrent_futures_extra118.ppe_vs_tpe_init_compare:
  description: "concurrent.futures ProcessPoolExecutor vs ThreadPoolExecutor __init__ co_varnames comparison in cfppe118b namespace — wave 260 theme: structural comparison of ProcessPoolExecutor and ThreadPoolExecutor __init__ co_varnames; both share co_varnames[0]='self', co_varnames[1]='max_workers' (len=11), co_varnames[3]='initializer' (len=11), co_varnames[4]='initargs' (len=8) at the same indices with the same values; ProcessPoolExecutor co_varnames[2]='mp_context' (len=10) while ThreadPoolExecutor co_varnames[2]='thread_name_prefix' (len=18, 8 longer); ProcessPoolExecutor co_varnames[5]='max_tasks_per_child' (len=19, longest in spec) while ThreadPoolExecutor co_varnames[5]='ctxkwargs' (len=9, 10 shorter); ProcessPoolExecutor has co_varnames[6]='queue_size' (len=10) with no ThreadPoolExecutor counterpart (TPE has only 6 co_varnames total); co_varnames.__len__(): PPE=7 > TPE=6 (1 more: queue_size is unique to PPE); co_qualname len: PPE=28 > TPE=27 (1 more: 'ProcessPoolExecutor'=19 vs 'ThreadPoolExecutor'=18, diff=1); ProcessPoolExecutor.__init__.__code__.co_argcount==5 (self, max_workers, mp_context, initializer, initargs); ThreadPoolExecutor.__init__.__code__.co_argcount==5 (same count: self, max_workers, thread_name_prefix, initializer, initargs; ctxkwargs is VAR_KEYWORD and not counted); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfppe118b

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_v1_len,  "ProcessPoolExecutor.__init__.__code__.co_varnames[1].__len__", [], 11, "PPE.__init__ co_varnames[1]='max_workers' len=11 (same as TPE co_varnames[1]='max_workers'=11); verified with Python 3.14.3"]
    - [ppe_v3_len,  "ProcessPoolExecutor.__init__.__code__.co_varnames[3].__len__", [], 11, "PPE.__init__ co_varnames[3]='initializer' len=11 (same as TPE co_varnames[3]='initializer'=11; tied with max_workers=11); verified with Python 3.14.3"]
    - [ppe_v4_len,  "ProcessPoolExecutor.__init__.__code__.co_varnames[4].__len__", [], 8,  "PPE.__init__ co_varnames[4]='initargs' len=8 (same as TPE co_varnames[4]='initargs'=8); verified with Python 3.14.3"]
    - [ppe_v2_len,  "ProcessPoolExecutor.__init__.__code__.co_varnames[2].__len__", [], 10, "PPE.__init__ co_varnames[2]='mp_context' len=10 (vs TPE co_varnames[2]='thread_name_prefix' len=18; 8 shorter); verified with Python 3.14.3"]
    - [ppe_v5_len,  "ProcessPoolExecutor.__init__.__code__.co_varnames[5].__len__", [], 19, "PPE.__init__ co_varnames[5]='max_tasks_per_child' len=19 (longest in spec; vs TPE co_varnames[5]='ctxkwargs' len=9; 10 longer); verified with Python 3.14.3"]
    - [ppe_vlen_7,  "ProcessPoolExecutor.__init__.__code__.co_varnames.__len__",    [], 7,  "PPE.__init__ co_varnames.__len__()==7 (1 more than TPE=6; queue_size is PPE-unique at index 6); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra118
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra118.ppe_init_v1_max_workers:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames[1].__eq__('max_workers') returns True — ProcessPoolExecutor.__init__ co_varnames[1]='max_workers' (len=11); 'max_workers' also appears in ThreadPoolExecutor.__init__ co_varnames[1] at the same index with the same length (common interface for both executor types); max_workers for ProcessPoolExecutor controls the maximum number of worker processes in the pool; when None the default is os.cpu_count() or 1 (whichever is larger); ProcessPoolExecutor.__init__.__code__.co_varnames.__len__()==7 (most in spec; 1 more than ThreadPoolExecutor.__init__=6); co_varnames[1].__len__()==11 is tied with co_varnames[3]='initializer'=11 (both are 11-char parameter names); compare: co_varnames[5]='max_tasks_per_child'=19 (8 more than max_workers=11) is the longest element; co_varnames[4]='initargs'=8 (3 shorter than max_workers=11); ProcessPoolExecutor.__init__.__code__.co_qualname=='ProcessPoolExecutor.__init__' (len=28); first standalone ProcessPoolExecutor.__init__ co_varnames[1] equality invariant in cfppe118 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "ProcessPoolExecutor.__init__.__code__.co_varnames[1].__eq__"
  args: ["max_workers"]
  expected: true

invariant concurrent_futures_extra118.ppe_init_v2_mp_context:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames[2].__eq__('mp_context') returns True — ProcessPoolExecutor.__init__ co_varnames[2]='mp_context' (len=10); mp_context is unique to ProcessPoolExecutor (ThreadPoolExecutor.__init__ co_varnames[2]='thread_name_prefix'=18, completely different parameter); mp_context accepts a multiprocessing start context ('fork', 'spawn', 'forkserver') or a multiprocessing.context.BaseContext instance; when None (default) the context chosen by multiprocessing.get_context() is used; 'mp_context'=10: 'mp'=2+'_'=1+'context'=7=10; co_varnames[2].__len__()==10 is tied with co_varnames[6]='queue_size'=10; compare: co_varnames[1]='max_workers'=11 (1 more), co_varnames[4]='initargs'=8 (2 fewer); ProcessPoolExecutor.__init__.__code__.co_argcount==5 (self, max_workers, mp_context, initializer, initargs are the 5 positional params; max_tasks_per_child and queue_size are keyword-only); first standalone ProcessPoolExecutor.__init__ co_varnames[2] equality invariant in cfppe118 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "ProcessPoolExecutor.__init__.__code__.co_varnames[2].__eq__"
  args: ["mp_context"]
  expected: true

invariant concurrent_futures_extra118.ppe_init_v5_max_tasks_per_child:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames[5].__eq__('max_tasks_per_child') returns True — ProcessPoolExecutor.__init__ co_varnames[5]='max_tasks_per_child' (len=19; the longest element in ProcessPoolExecutor.__init__ co_varnames and in this spec); max_tasks_per_child was added in Python 3.11; it limits the number of tasks each worker process executes before being replaced by a fresh worker process; this helps recover from memory leaks in worker processes; when None (default) worker processes are never replaced; 'max_tasks_per_child'=19: 'max'=3+'_tasks_per_child'=16=19; 'max_tasks_per_child'=19 is longer than ThreadPoolExecutor.__init__'s longest parameter 'thread_name_prefix'=18 (1 more); co_varnames[5].__len__()==19 (unique: no other element in this spec is within 8 chars of it; compare co_varnames[1]='max_workers'=11 and co_varnames[3]='initializer'=11, both 8 shorter); ProcessPoolExecutor.__init__.__code__.co_varnames.__len__()==7; first standalone ProcessPoolExecutor.__init__ co_varnames[5] equality invariant in cfppe118a namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "ProcessPoolExecutor.__init__.__code__.co_varnames[5].__eq__"
  args: ["max_tasks_per_child"]
  expected: true

invariant concurrent_futures_extra118.ppe_init_v6_queue_size:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames[6].__eq__('queue_size') returns True — ProcessPoolExecutor.__init__ co_varnames[6]='queue_size' (len=10); queue_size is unique to ProcessPoolExecutor — there is no equivalent in ThreadPoolExecutor (which has only 6 co_varnames, ending at index 5); queue_size controls the size of the call queue between the main process and worker processes; when None (default) the queue is unbounded; 'queue_size'=10: 'queue'=5+'_'=1+'size'=4=10; tied with co_varnames[2]='mp_context'=10 at the same length; index 6 is the last element in co_varnames (co_varnames.__len__()==7, so index 6 is the final entry); ProcessPoolExecutor.__init__.__code__.co_qualname.__len__()==28 ('ProcessPoolExecutor.__init__'=28: 1 more than ThreadPoolExecutor.__init__=27); first standalone ProcessPoolExecutor.__init__ co_varnames[6] equality invariant in cfppe118a namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "ProcessPoolExecutor.__init__.__code__.co_varnames[6].__eq__"
  args: ["queue_size"]
  expected: true

invariant concurrent_futures_extra118.ppe_init_co_varnames_len_7:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames.__len__() == 7 — co_varnames==('self','max_workers','mp_context','initializer','initargs','max_tasks_per_child','queue_size'); 7 elements is 1 more than ThreadPoolExecutor.__init__=6 (queue_size at index 6 is PPE-unique); ProcessPoolExecutor.__init__ has the most co_varnames among all executor __init__ methods in the concurrent.futures module; compare: ThreadPoolExecutor.__init__=6, ThreadPoolExecutor.submit=7 (tied: both have 7; submit co_varnames==('self','fn','args','kwargs','f','task','w')); 7 is also the maximum seen across submit and shutdown methods of ThreadPoolExecutor (from extra117: submit=7 > __init__=6 > shutdown=5); ProcessPoolExecutor.__init__.__code__.co_qualname=='ProcessPoolExecutor.__init__' (len=28); co_argcount==5 (5 positional params: self, max_workers, mp_context, initializer, initargs; max_tasks_per_child and queue_size are keyword-only and not counted in co_argcount); first standalone ProcessPoolExecutor.__init__ co_varnames length invariant in cfppe118 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "ProcessPoolExecutor.__init__.__code__.co_varnames.__len__"
  args: []
  expected: 7

