spec: concurrent_futures_extra118
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra117.zspec.zsdl."
    - "This spec covers: wave 260 theme — concurrent.futures.ProcessPoolExecutor.__init__ co_varnames element equality not previously covered. Prior specs covered (extra63-extra66): ProcessPoolExecutor co_varnames type identity (__class__.__name__=='tuple'), co_qualname='ProcessPoolExecutor.__init__' (extra64 and extra65 covered ThreadPoolExecutor init co_varnames element equality; extra117 covered ThreadPoolExecutor submit/shutdown co_varnames elements). NOT previously covered: ProcessPoolExecutor.__init__.__code__.co_varnames[0].__eq__('self'); co_varnames[1].__eq__('max_workers'); co_varnames[2].__eq__('mp_context'); co_varnames[3].__eq__('initializer'); co_varnames.__len__()==7; ProcessPoolExecutor.__init__.__code__.co_qualname length (len=28). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames == ('self','max_workers','mp_context','initializer','initargs','max_tasks_per_child','queue_size'): len=7. co_argcount==5 (self, max_workers, mp_context, initializer, initargs; max_tasks_per_child and queue_size are keyword-only or local depending on version). co_qualname=='ProcessPoolExecutor.__init__' (len=28: 'ProcessPoolExecutor.'=20+'__init__'=8=28). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "co_varnames elements: [0]='self'(len=4), [1]='max_workers'(len=11), [2]='mp_context'(len=10), [3]='initializer'(len=11), [4]='initargs'(len=8), [5]='max_tasks_per_child'(len=19, longest), [6]='queue_size'(len=10). co_varnames.__len__()==7 (same as ThreadPoolExecutor.submit.__len__()==7; both are the longest co_varnames in their respective specs). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ProcessPoolExecutor.__init__ co_varnames elements [0]-[3] — extra118
#
# Wave 260 theme: ProcessPoolExecutor.__init__ co_varnames first four elements.
#
# ProcessPoolExecutor.__init__.__code__.co_varnames[0] == 'self'        (len=4)
# ProcessPoolExecutor.__init__.__code__.co_varnames[1] == 'max_workers' (len=11)
# ProcessPoolExecutor.__init__.__code__.co_varnames[2] == 'mp_context'  (len=10)
# ProcessPoolExecutor.__init__.__code__.co_varnames[3] == 'initializer' (len=11, tied with [1])
# ---------------------------------------------------------------------------

table concurrent_futures_extra118.ppe_init_co_varnames_first4:
  description: "concurrent.futures.ProcessPoolExecutor.__init__ co_varnames elements [0]-[3] equality checks in cfppe118 namespace — wave 260 theme: first element-level coverage of ProcessPoolExecutor.__init__ co_varnames; co_varnames==('self','max_workers','mp_context','initializer','initargs','max_tasks_per_child','queue_size') len=7; co_varnames[0].__eq__('self')==True (len=4: first param; same as all __init__ methods); co_varnames[1].__eq__('max_workers')==True (len=11: max_workers is the maximum number of worker processes; when None the default is os.cpu_count() or less; also appears in ThreadPoolExecutor.__init__ co_varnames[1]='max_workers' at the same index with same length; tied with 'initializer'=11 at index 3); co_varnames[2].__eq__('mp_context')==True (len=10: mp_context is the multiprocessing context used to start worker processes; accepted values are 'fork', 'spawn', or 'forkserver' or a multiprocessing.context.BaseContext; ProcessPoolExecutor is unique vs ThreadPoolExecutor in having this parameter; 'mp_context'=10 chars: 'mp'=2+'_'=1+'context'=7=10; 1 shorter than 'max_workers'=11); co_varnames[3].__eq__('initializer')==True (len=11: initializer is an optional callable invoked in each worker process at start; tied with 'max_workers'=11 at index 1; same name and length as ThreadPoolExecutor.__init__ co_varnames[3]='initializer'=11); co_varnames.__len__()==7 (most elements in ProcessPoolExecutor.__init__: 7 > ThreadPoolExecutor.__init__=6); co_qualname=='ProcessPoolExecutor.__init__' (len=28: 'ProcessPoolExecutor.'=20+'__init__'=8=28; compare ThreadPoolExecutor.__init__ len=27: 'ThreadPoolExecutor.'=19+'__init__'=8=27; 1 more because 'ProcessPoolExecutor'=19 vs... wait: 'ProcessPoolExecutor'=19 chars and 'ThreadPoolExecutor'=18 chars, diff=1); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfppe118

  columns: [id, function, args, expected, description]
  rows:
    - [vlen,     "ProcessPoolExecutor.__init__.__code__.co_varnames.__len__",    [],                7,    "ProcessPoolExecutor.__init__ co_varnames.__len__() == 7 (most in spec; ('self','max_workers','mp_context','initializer','initargs','max_tasks_per_child','queue_size')); verified with Python 3.14.3"]
    - [v0_eq,    "ProcessPoolExecutor.__init__.__code__.co_varnames[0].__eq__",  ["self"],          true, "ProcessPoolExecutor.__init__ co_varnames[0] == 'self' (len=4; first param); verified with Python 3.14.3"]
    - [v0_len,   "ProcessPoolExecutor.__init__.__code__.co_varnames[0].__len__", [],                4,    "ProcessPoolExecutor.__init__ co_varnames[0].__len__() == 4 ('self'=4); verified with Python 3.14.3"]
    - [v1_eq,    "ProcessPoolExecutor.__init__.__code__.co_varnames[1].__eq__",  ["max_workers"],   true, "ProcessPoolExecutor.__init__ co_varnames[1] == 'max_workers' (len=11; max worker processes); verified with Python 3.14.3"]
    - [v1_len,   "ProcessPoolExecutor.__init__.__code__.co_varnames[1].__len__", [],                11,   "ProcessPoolExecutor.__init__ co_varnames[1].__len__() == 11 ('max_workers'=11; tied with 'initializer'=11); verified with Python 3.14.3"]
    - [v2_eq,    "ProcessPoolExecutor.__init__.__code__.co_varnames[2].__eq__",  ["mp_context"],    true, "ProcessPoolExecutor.__init__ co_varnames[2] == 'mp_context' (len=10; multiprocessing context); verified with Python 3.14.3"]
    - [v2_len,   "ProcessPoolExecutor.__init__.__code__.co_varnames[2].__len__", [],                10,   "ProcessPoolExecutor.__init__ co_varnames[2].__len__() == 10 ('mp_context'=10; 1 shorter than max_workers=11); verified with Python 3.14.3"]
    - [v3_eq,    "ProcessPoolExecutor.__init__.__code__.co_varnames[3].__eq__",  ["initializer"],   true, "ProcessPoolExecutor.__init__ co_varnames[3] == 'initializer' (len=11; tied with max_workers=11); verified with Python 3.14.3"]
    - [v3_len,   "ProcessPoolExecutor.__init__.__code__.co_varnames[3].__len__", [],                11,   "ProcessPoolExecutor.__init__ co_varnames[3].__len__() == 11 ('initializer'=11; tied with max_workers=11 at index 1); verified with Python 3.14.3"]

