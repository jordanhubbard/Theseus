spec: itertools_extra386
version: ">=3.12"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "itertools.batched is a C iterator type added in Python 3.12 (PEP 718). __name__ == 'batched', __module__ == 'itertools'. Verified with Python 3.14.4."
    - "itertools.pairwise is a C iterator type added in Python 3.10. __name__ == 'pairwise', __module__ == 'itertools'. Verified with Python 3.14.4."
    - "itertools.pairwise.__doc__.__class__.__name__ == 'str' — pairwise carries a plain string docstring. Verified with Python 3.14.4."
    - "itertools.batched.__doc__.__class__.__name__ == 'str' — batched carries a plain string docstring. Verified with Python 3.14.4."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.pairwise and itertools.batched identity
#
# itertools.pairwise.__name__ == 'pairwise'
# itertools.pairwise.__module__ == 'itertools'
# itertools.batched.__name__ == 'batched'
# itertools.batched.__module__ == 'itertools'
#
# pairwise (Python 3.10+) is a C iterator type that yields successive
# overlapping pairs from an iterable. batched (Python 3.12+) is a C iterator
# type that yields non-overlapping batches of a given size. Both are defined
# in the itertools C extension module.
# ---------------------------------------------------------------------------

table itertools_extra386.pairwise_and_batched_identity:
  description: "itertools.pairwise and itertools.batched C iterator type __name__ and __module__; new to extra386"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolspb386

  columns: [id, function, args, expected, description]
  rows:
    - [pairwise_name_eq,
       "pairwise.__name__.__eq__",
       ["pairwise"],
       true,
       "itertools.pairwise.__name__.__eq__('pairwise') == True — pairwise is a C iterator type added in Python 3.10 (bpo-2213) that yields successive overlapping pairs from an iterable; __name__ is 'pairwise'; str.__eq__('pairwise') returns True; new to extra386"]
    - [pairwise_module_eq,
       "pairwise.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.pairwise.__module__.__eq__('itertools') == True — pairwise is implemented in the itertools C extension; __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra386"]
    - [batched_name_eq,
       "batched.__name__.__eq__",
       ["batched"],
       true,
       "itertools.batched.__name__.__eq__('batched') == True — batched is a C iterator type added in Python 3.12 that yields non-overlapping batches of a given size from an iterable; __name__ is 'batched'; str.__eq__('batched') returns True; new to extra386"]
    - [batched_module_eq,
       "batched.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.batched.__module__.__eq__('itertools') == True — batched is implemented in the itertools C extension; __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra386"]

# ---------------------------------------------------------------------------
# Table 2: itertools.pairwise and itertools.batched docstring class
#
# itertools.pairwise.__doc__.__class__.__name__ == 'str'
# itertools.batched.__doc__.__class__.__name__ == 'str'
#
# Both C iterator types expose their documentation as plain string docstrings
# (__doc__.__class__.__name__ == 'str').
# ---------------------------------------------------------------------------

table itertools_extra386.pairwise_and_batched_doc_class:
  description: "itertools.pairwise and itertools.batched docstring class names (both 'str'); new to extra386"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsdoc386

  columns: [id, function, args, expected, description]
  rows:
    - [pairwise_doc_class_name_eq,
       "pairwise.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.pairwise.__doc__.__class__.__name__.__eq__('str') == True — pairwise carries a plain string docstring; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra386"]
    - [batched_doc_class_name_eq,
       "batched.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.batched.__doc__.__class__.__name__.__eq__('str') == True — batched carries a plain string docstring; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra386"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra386
# ---------------------------------------------------------------------------

invariant itertools_extra386.pairwise_name:
  description: "itertools.pairwise.__name__ == 'pairwise' — C iterator type added in Python 3.10; new to extra386"
  kind: python_call_eq
  function: pairwise.__name__.__eq__
  args: ["pairwise"]
  expected: true

invariant itertools_extra386.pairwise_module:
  description: "itertools.pairwise.__module__ == 'itertools' — implemented in the itertools C extension; new to extra386"
  kind: python_call_eq
  function: pairwise.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra386.batched_name:
  description: "itertools.batched.__name__ == 'batched' — C iterator type added in Python 3.12; new to extra386"
  kind: python_call_eq
  function: batched.__name__.__eq__
  args: ["batched"]
  expected: true

invariant itertools_extra386.batched_module:
  description: "itertools.batched.__module__ == 'itertools' — implemented in the itertools C extension; new to extra386"
  kind: python_call_eq
  function: batched.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra386.pairwise_doc_class_name:
  description: "itertools.pairwise.__doc__.__class__.__name__ == 'str' — C iterator type with plain string docstring; new to extra386"
  kind: python_call_eq
  function: pairwise.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra386.batched_doc_class_name:
  description: "itertools.batched.__doc__.__class__.__name__ == 'str' — C iterator type with plain string docstring; new to extra386"
  kind: python_call_eq
  function: batched.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
