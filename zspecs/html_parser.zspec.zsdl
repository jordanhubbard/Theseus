spec: html_parser
version: ">=3.4"
backend: python_module(html.parser)

docs: https://docs.python.org/3/library/html.parser.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/html.parser.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "html.parser source: Lib/html/parser.py (PSF; source inspection permitted)"
  not_derived_from:
    - "html.parser source: internal tokenizer state machine details"
  notes:
    - "html.parser exposes a single public class: HTMLParser."
    - "HTMLParseError was deprecated in Python 3.3 and removed in Python 3.5; it is not present."
    - "HTMLParser.convert_charrefs defaults to True (since Python 3.4), causing character references to be converted automatically."
    - "HTMLParser().getpos() returns (line, col) tuple; initial value is (1, 0) before any input is fed."
    - "HTMLParser overrideable callbacks: handle_starttag, handle_endtag, handle_data, handle_comment, handle_entityref, handle_charref."
    - "html.zspec.zsdl covers html.escape/html.unescape; this spec covers html.parser.HTMLParser only."
    - "All expected values verified by running Python 3.12 html.parser module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name check
# ---------------------------------------------------------------------------

invariant html_parser.class_name:
  description: "html.parser.HTMLParser.__name__ == 'HTMLParser'"
  category: classes
  kind: python_call_eq
  function: HTMLParser.__name__.__eq__
  args: ["HTMLParser"]
  expected: true

invariant html_parser.class_module:
  description: "html.parser.HTMLParser.__module__ == 'html.parser'"
  category: classes
  kind: python_call_eq
  function: HTMLParser.__module__.__eq__
  args: ["html.parser"]
  expected: true

# ---------------------------------------------------------------------------
# Default attribute: convert_charrefs
# ---------------------------------------------------------------------------

invariant html_parser.convert_charrefs_default:
  description: "HTMLParser().convert_charrefs == True (default since Python 3.4)"
  category: behavior
  kind: python_call_eq
  function: HTMLParser
  args: []
  method: convert_charrefs
  method_args: []
  expected: true

# ---------------------------------------------------------------------------
# Initial getpos() — (1, 0) before any input
# ---------------------------------------------------------------------------

invariant html_parser.initial_getpos:
  description: "HTMLParser().getpos() == (1, 0)"
  category: behavior
  kind: python_call_eq
  function: HTMLParser
  args: []
  method: getpos
  method_args: []
  expected: [1, 0]

# ---------------------------------------------------------------------------
# Method name checks — core HTMLParser interface
# ---------------------------------------------------------------------------

table html_parser.method_names:
  kind: python_call_eq
  category: functions
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [feed,             HTMLParser.feed.__name__.__eq__,             ["feed"],             true]
    - [reset,            HTMLParser.reset.__name__.__eq__,            ["reset"],            true]
    - [close,            HTMLParser.close.__name__.__eq__,            ["close"],            true]
    - [getpos,           HTMLParser.getpos.__name__.__eq__,           ["getpos"],           true]
    - [handle_starttag,  HTMLParser.handle_starttag.__name__.__eq__,  ["handle_starttag"],  true]
    - [handle_endtag,    HTMLParser.handle_endtag.__name__.__eq__,    ["handle_endtag"],    true]
    - [handle_data,      HTMLParser.handle_data.__name__.__eq__,      ["handle_data"],      true]
    - [handle_comment,   HTMLParser.handle_comment.__name__.__eq__,   ["handle_comment"],   true]
    - [handle_charref,   HTMLParser.handle_charref.__name__.__eq__,   ["handle_charref"],   true]
    - [handle_entityref, HTMLParser.handle_entityref.__name__.__eq__,  ["handle_entityref"], true]

# ---------------------------------------------------------------------------
# reset() — returns None
# ---------------------------------------------------------------------------

invariant html_parser.reset_returns_none:
  description: "HTMLParser().reset() == None"
  category: behavior
  kind: python_call_eq
  function: HTMLParser
  args: []
  method: reset
  method_args: []
  expected: null

# ---------------------------------------------------------------------------
# close() — returns None on a fresh (unfed) parser
# ---------------------------------------------------------------------------

invariant html_parser.close_returns_none:
  description: "HTMLParser().close() == None"
  category: behavior
  kind: python_call_eq
  function: HTMLParser
  args: []
  method: close
  method_args: []
  expected: null

