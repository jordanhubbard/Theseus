spec: compileall_extra2
version: ">=3.2"
backend: python_module(compileall)

docs: https://docs.python.org/3/library/compileall.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/compileall.html — Python compileall module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/compileall.py"
  notes:
    - "This spec covers compileall invariants not already in compileall.zspec.zsdl or compileall_extra.zspec.zsdl."
    - "compileall.zspec.zsdl covers __name__, __module__, type (function), and __qualname__ for all three public functions."
    - "compileall_extra.zspec.zsdl covers __name__ and __module__ for compile_file, compile_dir, compile_path."
    - "This spec adds __qualname__ checks for compile_dir and compile_path, docstring checks for compile_path, and callable/class checks."
    - "compile_file.__module__ == 'compileall' — function is defined at module top-level in Lib/compileall.py."
    - "compile_dir.__module__ == 'compileall' and compile_path.__module__ == 'compileall'."
    - "All three functions are plain Python functions (type 'function'), not C builtins."
    - "All three have non-empty docstrings (__doc__ is a str)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks — compile_file, compile_dir, compile_path
# ---------------------------------------------------------------------------

table compileall_extra2.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [compile_file, compile_file.__name__.__eq__, ["compile_file"], true]
    - [compile_dir,  compile_dir.__name__.__eq__,  ["compile_dir"],  true]
    - [compile_path, compile_path.__name__.__eq__, ["compile_path"], true]

# ---------------------------------------------------------------------------
# Function __module__ — all three belong to compileall
# ---------------------------------------------------------------------------

invariant compileall_extra2.compile_file.module:
  description: "compile_file.__module__ == 'compileall' — module affiliation of compile_file"
  category: module_affiliation
  kind: python_call_eq
  function: compile_file.__module__.__eq__
  args: ["compileall"]
  expected: true

invariant compileall_extra2.compile_dir.module:
  description: "compile_dir.__module__ == 'compileall'"
  category: module_affiliation
  kind: python_call_eq
  function: compile_dir.__module__.__eq__
  args: ["compileall"]
  expected: true

invariant compileall_extra2.compile_path.module:
  description: "compile_path.__module__ == 'compileall'"
  category: module_affiliation
  kind: python_call_eq
  function: compile_path.__module__.__eq__
  args: ["compileall"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__ — module-level functions have flat qualnames
# ---------------------------------------------------------------------------

table compileall_extra2.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [compile_file, compile_file.__qualname__.__eq__, ["compile_file"], true]
    - [compile_dir,  compile_dir.__qualname__.__eq__,  ["compile_dir"],  true]
    - [compile_path, compile_path.__qualname__.__eq__, ["compile_path"], true]

# ---------------------------------------------------------------------------
# Type checks — all three are plain Python functions (not C builtins)
# ---------------------------------------------------------------------------

table compileall_extra2.type_checks:
  kind: python_call_eq
  category: type_checks
  id_prefix: typecheck

  columns: [id, function, args, expected]
  rows:
    - [compile_file_is_fn, compile_file.__class__.__name__.__eq__, ["function"], true]
    - [compile_dir_is_fn,  compile_dir.__class__.__name__.__eq__,  ["function"], true]
    - [compile_path_is_fn, compile_path.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# Docstring checks — all three functions have non-empty docstrings
# ---------------------------------------------------------------------------

invariant compileall_extra2.compile_file.doc_is_str:
  description: "compile_file.__doc__.__class__.__name__ == 'str' — compile_file has a docstring"
  category: docstrings
  kind: python_call_eq
  function: compile_file.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant compileall_extra2.compile_dir.doc_is_str:
  description: "compile_dir.__doc__.__class__.__name__ == 'str' — compile_dir has a docstring"
  category: docstrings
  kind: python_call_eq
  function: compile_dir.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant compileall_extra2.compile_path.doc_is_str:
  description: "compile_path.__doc__.__class__.__name__ == 'str' — compile_path has a docstring"
  category: docstrings
  kind: python_call_eq
  function: compile_path.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
