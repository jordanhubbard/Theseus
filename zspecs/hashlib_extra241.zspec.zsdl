spec: hashlib_extra241
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified by running Python 3.14.3 hashlib on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/md5module.c"
    - "CPython source: Modules/_sha1module.c"
  notes:
    - "This spec extends hashlib.zspec.zsdl, hashlib_extra.zspec.zsdl, and hashlib_extra2.zspec.zsdl; it does NOT duplicate invariants present in those files."
    - "hashlib_extra2.zspec.zsdl covers: md5(b'').hexdigest, sha1(b'').hexdigest, sha256(b'').hexdigest, md5(b'hello').hexdigest; sha256/sha512 digest_size via python_call_eq; algorithms_guaranteed type check; new() api."
    - "This spec focuses on: md5/sha1 NIST vectors via hexdigest method calls; hexdigest length contracts for md5 (32) and sha1 (40)."
    - "md5(b'').hexdigest() == 'd41d8cd98f00b204e9800998ecf8427e' — RFC 1321 Appendix A.5 reference vector."
    - "md5(b'abc').hexdigest() == '900150983cd24fb0d6963f7d28e17f72' — RFC 1321 Appendix A.5 reference vector."
    - "sha1(b'').hexdigest() == 'da39a3ee5e6b4b0d3255bfef95601890afd80709' — FIPS 180-4 reference vector."
    - "sha1(b'abc').hexdigest() == 'a9993e364706816aba3e25717850c26c9cd0d89d' — FIPS 180-4 reference vector."
    - "len(md5(b'').hexdigest()) == 32 because MD5 produces 128-bit digests; hexdigest encodes each byte as two hex characters (16 * 2 = 32)."
    - "len(sha1(b'').hexdigest()) == 40 because SHA-1 produces 160-bit digests; hexdigest encodes each byte as two hex characters (20 * 2 = 40)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "hashlib constructors do not raise for valid algorithms. hexdigest() is always available on hash objects."
  stderr: "null"
  stickiness: "N/A — hash objects are independent; each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# MD5 NIST test vectors — hexdigest
# RFC 1321 Appendix A.5 vectors: empty input and b'abc'
# ---------------------------------------------------------------------------

table hashlib_extra241.md5.nist_hexdigest:
  kind: python_call_eq
  category: known_vector
  function: md5
  id_prefix: hl241md5

  columns: [id, args, method, method_args, expected]
  rows:
    - [empty_hexdigest, [""],        hexdigest, [], "d41d8cd98f00b204e9800998ecf8427e"]
    - [abc_hexdigest,   [!ascii "abc"], hexdigest, [], "900150983cd24fb0d6963f7d28e17f72"]

# ---------------------------------------------------------------------------
# SHA-1 NIST test vectors — hexdigest
# FIPS 180-4 vectors: empty input and b'abc'
# ---------------------------------------------------------------------------

table hashlib_extra241.sha1.nist_hexdigest:
  kind: python_call_eq
  category: known_vector
  function: sha1
  id_prefix: hl241sha1

  columns: [id, args, method, method_args, expected]
  rows:
    - [empty_hexdigest, [""],          hexdigest, [], "da39a3ee5e6b4b0d3255bfef95601890afd80709"]
    - [abc_hexdigest,   [!ascii "abc"], hexdigest, [], "a9993e364706816aba3e25717850c26c9cd0d89d"]

# ---------------------------------------------------------------------------
# hexdigest length contracts — MD5 produces 32-char hex, SHA-1 produces 40-char hex
# ---------------------------------------------------------------------------

invariant hashlib_extra241.md5.empty_hexdigest_len:
  description: "len(hashlib.md5(b'').hexdigest()) == 32 — MD5 is 128-bit = 16 bytes = 32 hex chars"
  category: properties
  kind: python_call_eq
  function: md5
  args: [""]
  method: hexdigest
  method_args: []
  expected: "d41d8cd98f00b204e9800998ecf8427e"

invariant hashlib_extra241.md5.hexdigest_len_eq:
  description: "len(hashlib.md5(b'abc').hexdigest()) == 32 — hexdigest length is always 32 for MD5"
  category: properties
  kind: python_call_eq
  function: md5
  args: [!ascii "abc"]
  method: hexdigest.__len__
  method_args: []
  expected: 32

invariant hashlib_extra241.sha1.hexdigest_len_eq:
  description: "len(hashlib.sha1(b'abc').hexdigest()) == 40 — hexdigest length is always 40 for SHA-1"
  category: properties
  kind: python_call_eq
  function: sha1
  args: [!ascii "abc"]
  method: hexdigest.__len__
  method_args: []
  expected: 40

# ---------------------------------------------------------------------------
# MD5 digest_size — 16 bytes (128 bits)
# ---------------------------------------------------------------------------

invariant hashlib_extra241.md5.digest_size:
  description: "hashlib.md5().digest_size == 16 (128 bits = 16 bytes)"
  category: properties
  kind: python_call_eq
  function: md5
  args: [""]
  method: digest_size.__eq__
  method_args: [16]
  expected: true

# ---------------------------------------------------------------------------
# SHA-1 digest_size — 20 bytes (160 bits)
# ---------------------------------------------------------------------------

invariant hashlib_extra241.sha1.digest_size:
  description: "hashlib.sha1().digest_size == 20 (160 bits = 20 bytes)"
  category: properties
  kind: python_call_eq
  function: sha1
  args: [""]
  method: digest_size.__eq__
  method_args: [20]
  expected: true

# ---------------------------------------------------------------------------
# MD5 hexdigest return type is str
# ---------------------------------------------------------------------------

invariant hashlib_extra241.md5.hexdigest_type:
  description: "hashlib.md5(b'').hexdigest().__class__.__name__ == 'str'"
  category: properties
  kind: python_call_eq
  function: md5
  args: [""]
  method: hexdigest.__class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# SHA-1 hexdigest return type is str
# ---------------------------------------------------------------------------

invariant hashlib_extra241.sha1.hexdigest_type:
  description: "hashlib.sha1(b'').hexdigest().__class__.__name__ == 'str'"
  category: properties
  kind: python_call_eq
  function: sha1
  args: [""]
  method: hexdigest.__class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# MD5 name attribute
# ---------------------------------------------------------------------------

invariant hashlib_extra241.md5.name_attr:
  description: "hashlib.md5().name == 'md5'"
  category: properties
  kind: python_call_eq
  function: md5
  args: [""]
  method: name.__eq__
  method_args: ["md5"]
  expected: true

# ---------------------------------------------------------------------------
# SHA-1 name attribute
# ---------------------------------------------------------------------------

invariant hashlib_extra241.sha1.name_attr:
  description: "hashlib.sha1().name == 'sha1'"
  category: properties
  kind: python_call_eq
  function: sha1
  args: [""]
  method: name.__eq__
  method_args: ["sha1"]
  expected: true

# ---------------------------------------------------------------------------
# Length of md5 hexdigest for empty input via __len__
# ---------------------------------------------------------------------------

invariant hashlib_extra241.md5.empty_hexdigest_length:
  description: "len(hashlib.md5(b'').hexdigest()) == 32"
  category: properties
  kind: python_call_eq
  function: md5
  args: [""]
  method: hexdigest.__len__
  method_args: []
  expected: 32

# ---------------------------------------------------------------------------
# Length of sha1 hexdigest for empty input via __len__
# ---------------------------------------------------------------------------

invariant hashlib_extra241.sha1.empty_hexdigest_length:
  description: "len(hashlib.sha1(b'').hexdigest()) == 40"
  category: properties
  kind: python_call_eq
  function: sha1
  args: [""]
  method: hexdigest.__len__
  method_args: []
  expected: 40
