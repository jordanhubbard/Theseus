spec: uuid_extra194
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "uuid.__spec__.name == 'uuid' — the ModuleSpec name matches the module name."
    - "uuid.__spec__.has_location == True — uuid is a Python source file with a known location on disk."
    - "uuid.__spec__.parent == '' — uuid is a top-level module; parent is the empty string."
    - "uuid.__spec__.__class__.__name__ == 'ModuleSpec' — the spec object is an importlib.machinery.ModuleSpec instance."
    - "uuid.__spec__.origin.__class__.__name__ == 'str' — the origin attribute (path to uuid.py) is a plain str."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.__spec__ deeper attributes — name, has_location, parent
