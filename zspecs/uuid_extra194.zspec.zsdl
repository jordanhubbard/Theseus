table uuid_extra194.spec_class_origin_type:
  description: "uuid __spec__ class name and origin type attribute checks"
  kind: python_call_eq
  category: identity
  id_prefix: uuidspec194cot

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_modulespec,    __spec__.__class__.__name__.__eq__,        ["ModuleSpec"], true, "uuid.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [spec_origin_class_str,    __spec__.origin.__class__.__name__.__eq__, ["str"],        true, "uuid.__spec__.origin.__class__.__name__ == 'str' — origin is a file path string"]
    - [spec_name_matches_module, __spec__.name.__eq__,                      ["uuid"],       true, "uuid.__spec__.name equals the module name 'uuid'"]
    - [spec_parent_not_none,     __spec__.parent.__class__.__name__.__eq__, ["str"],        true, "uuid.__spec__.parent is a str (not None)"]

# ---------------------------------------------------------------------------
# uuid.__spec__ deeper attributes — loader and submodule_search_locations
