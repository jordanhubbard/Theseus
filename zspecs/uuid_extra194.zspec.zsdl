  id_prefix: uuidspec194lsl

  columns: [id, function, args, expected, description]
  rows:
    - [spec_loader_class_eq,        __spec__.loader.__class__.__name__.__eq__,   ["SourceFileLoader"],         true, "uuid.__spec__.loader.__class__.__name__ == 'SourceFileLoader'"]
    - [spec_loader_module_eq,       __spec__.loader.__class__.__module__.__eq__,  ["_frozen_importlib_external"], true, "uuid.__spec__.loader lives in _frozen_importlib_external"]
    - [spec_has_location_is_bool2,  __spec__.has_location.__class__.__name__.__eq__, ["bool"],                  true, "uuid.__spec__.has_location type is bool (re-confirmed via loader table)"]
    - [spec_class_name_is_str,      __spec__.__class__.__name__.__class__.__name__.__eq__, ["str"],             true, "uuid.__spec__.__class__.__name__ is itself a str"]

