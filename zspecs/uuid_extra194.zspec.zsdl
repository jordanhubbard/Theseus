table uuid_extra194.spec_name_has_location_parent:
  description: "uuid __spec__ name, has_location, and parent attribute checks"
  kind: python_call_eq
  category: identity
  id_prefix: uuidspec194nhp

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,              __spec__.name.__eq__,                          ["uuid"], true, "uuid.__spec__.name == 'uuid'"]
    - [spec_name_is_str,          __spec__.name.__class__.__name__.__eq__,       ["str"],  true, "uuid.__spec__.name is a str object"]
    - [spec_has_location_true,    __spec__.has_location.__eq__,                  [true],   true, "uuid.__spec__.has_location == True — uuid.py has a known file location"]
    - [spec_has_location_is_bool, __spec__.has_location.__class__.__name__.__eq__, ["bool"], true, "uuid.__spec__.has_location is a bool object"]
    - [spec_parent_empty,         __spec__.parent.__eq__,                        [""],     true, "uuid.__spec__.parent == '' — uuid is a top-level module"]
    - [spec_parent_is_str,        __spec__.parent.__class__.__name__.__eq__,     ["str"],  true, "uuid.__spec__.parent is a str object"]

# ---------------------------------------------------------------------------
# uuid.__spec__ deeper attributes — __class__.__name__ and origin type
