    - ["as2011008", "asyncio.Event.__dict__.__contains__",  ["__radd__"], false]
    - ["as2011009", "asyncio.Lock.__dict__.__contains__",   ["__radd__"], false]
    - ["as2011010", "asyncio.Queue.__dict__.__contains__",  ["__radd__"], false]
    - ["as2011011", "asyncio.Task.__dict__.__contains__",   ["__iadd__"], false]
    - ["as2011012", "asyncio.Future.__dict__.__contains__", ["__iadd__"], false]
    - ["as2011013", "asyncio.Event.__dict__.__contains__",  ["__iadd__"], false]
