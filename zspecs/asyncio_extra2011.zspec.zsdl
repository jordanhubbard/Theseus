spec: asyncio_extra2011
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 581 (_extra2011): __add__/__radd__/__iadd__, __mul__/__rmul__/__imul__, __sub__/__rsub__/__isub__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.Task, asyncio.Future, asyncio.Event, asyncio.Lock, asyncio.Queue do not define arithmetic operators; all checks return False."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __add__ / __radd__ / __iadd__ dict-presence for asyncio types
#
# None of Task, Future, Event, Lock, Queue define addition operators.
# All checks return False.
# ---------------------------------------------------------------------------

table asyncio_extra2011.add_protocol:
  description: "asyncio types __add__/__radd__/__iadd__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2011

  columns: [id, function, args, expected]
  rows:
    - ["as2011001", "asyncio.Task.__dict__.__contains__",   ["__add__"],  false]
    - ["as2011002", "asyncio.Future.__dict__.__contains__", ["__add__"],  false]
    - ["as2011003", "asyncio.Event.__dict__.__contains__",  ["__add__"],  false]
