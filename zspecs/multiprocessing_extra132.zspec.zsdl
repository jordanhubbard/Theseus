invariant multiprocessing_extra132.Queue_module_len_22:
  description: "multiprocessing.queues.Queue.__module__.__len__() == 22 — Queue.__module__ is 'multiprocessing.queues' (22 chars: 'multiprocessing'=15 + '.'=1 + 'queues'=6 = 22); this is the longest module name among the specs in the asyncio/concurrent_futures/multiprocessing family: 'multiprocessing.queues'=22 > 'concurrent.futures._base'=24 (wait, 24 > 22); regardless, Queue.__module__ has a distinctive 22-char length; Queue.__bases__[0].__name__ is 'object' (no intermediate base); Queue.__mro__.__len__() is 2 ([Queue, object]); Queue.__qualname__.__len__() is 5; NEW in extra132: first standalone Queue module length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.queues.Queue.__module__.__len__
  args: []
  expected: 22

invariant multiprocessing_extra132.Queue_mro_len_2:
  description: "multiprocessing.queues.Queue.__mro__.__len__() == 2 — Queue's MRO is [Queue, object] (length=2); Queue directly inherits from object with no intermediate base class; JoinableQueue extends this to [JoinableQueue, Queue, object] (length=3) by subclassing Queue; Queue.__bases__[0].__name__ is 'object'; Queue.__module__ is 'multiprocessing.queues' (len=22); Queue.__init__.__code__.co_argcount is 2 (self + ctx); Queue.put.__code__.co_argcount is 4 (self, obj, block, timeout); NEW in extra132: first standalone Queue MRO length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.queues.Queue.__mro__.__len__
  args: []
  expected: 2

invariant multiprocessing_extra132.Queue_init_qualname_len_14:
  description: "multiprocessing.queues.Queue.__init__.__qualname__.__len__() == 14 — Queue.__init__.__qualname__ is 'Queue.__init__' (14 chars: 'Queue'=5 + '.'=1 + '__init__'=8 = 14); compare with JoinableQueue.__init__.__qualname__ which is 'JoinableQueue.__init__' (len=22); Queue.__init__.__code__.co_argcount is 2 (self + ctx); Queue.put and Queue.get method names are both 3 chars giving qualname lengths of 9; Queue.qsize, Queue.empty, Queue.close all have 5-char method names giving qualname lengths of 11; Queue.__module__ is 'multiprocessing.queues' (len=22); NEW in extra132: first standalone Queue.__init__ qualname length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.queues.Queue.__init__.__qualname__.__len__
  args: []
  expected: 14

invariant multiprocessing_extra132.JoinableQueue_task_done_qualname_len_23:
  description: "multiprocessing.queues.JoinableQueue.task_done.__qualname__.__len__() == 23 — JoinableQueue.task_done.__qualname__ is 'JoinableQueue.task_done' (23 chars: 'JoinableQueue'=13 + '.'=1 + 'task_done'=9 = 23); this is the longest method qualname among JoinableQueue's own methods: task_done=23 > __init__=22 > join=18; JoinableQueue.task_done.__code__.co_argcount is 1 (self only); JoinableQueue.__bases__[0].__name__ is 'Queue'; JoinableQueue.__mro__.__len__() is 3 ([JoinableQueue, Queue, object]); JoinableQueue.__module__ is 'multiprocessing.queues' (len=22); NEW in extra132: first standalone JoinableQueue.task_done qualname length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.JoinableQueue.task_done.__qualname__.__len__"
  args: []
  expected: 23

invariant multiprocessing_extra132.JoinableQueue_mro_len_3:
  description: "multiprocessing.queues.JoinableQueue.__mro__.__len__() == 3 — JoinableQueue's MRO is [JoinableQueue, Queue, object] (length=3); JoinableQueue subclasses Queue, adding the task_done() and join() methods that enable tracking when all enqueued tasks have been processed; Queue itself has MRO len=2 ([Queue, object]); JoinableQueue.__bases__[0].__name__ is 'Queue'; JoinableQueue.__name__.__len__() is 13; JoinableQueue.__module__ is 'multiprocessing.queues' (len=22, same as Queue); JoinableQueue.__init__.__qualname__.__len__() is 22; NEW in extra132: first standalone JoinableQueue MRO length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.JoinableQueue.__mro__.__len__"
  args: []
  expected: 3
