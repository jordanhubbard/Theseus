spec: multiprocessing_extra132
version: ">=3.9"
backend: python_module(multiprocessing.queues)

docs: https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Queue

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Queue — Python multiprocessing.Queue documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/queues.py"
  notes:
    - "This spec covers: wave 257 theme — multiprocessing.queues.Queue and multiprocessing.queues.JoinableQueue method qualnames and class identity. NEW in extra132: multiprocessing.queues.Queue.__init__.__qualname__=='Queue.__init__' (len=14); multiprocessing.queues.Queue.put.__qualname__=='Queue.put' (len=9); multiprocessing.queues.Queue.get.__qualname__=='Queue.get' (len=9); multiprocessing.queues.Queue.qsize.__qualname__=='Queue.qsize' (len=11); multiprocessing.queues.Queue.empty.__qualname__=='Queue.empty' (len=11); multiprocessing.queues.Queue.__module__=='multiprocessing.queues' (len=22); multiprocessing.queues.Queue.__bases__[0].__name__=='object'; multiprocessing.queues.Queue.__mro__.__len__()==2; multiprocessing.queues.JoinableQueue.__init__.__qualname__=='JoinableQueue.__init__' (len=22); multiprocessing.queues.JoinableQueue.task_done.__qualname__=='JoinableQueue.task_done' (len=23); multiprocessing.queues.JoinableQueue.__bases__[0].__name__=='Queue'; multiprocessing.queues.JoinableQueue.__mro__.__len__()==3. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.queues.Queue.__bases__[0].__name__ == 'object'. Queue does not inherit from any intermediate base class — its MRO is [Queue, object] (length=2). This is a shallow hierarchy compared to JoinableQueue (MRO len=3). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.queues.Queue.put.__code__.co_argcount == 4 (self, obj, block, timeout) and Queue.get.__code__.co_argcount == 3 (self, block, timeout). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.queues.Queue.__module__ == 'multiprocessing.queues' (len=22: 'multiprocessing'=15 + '.'=1 + 'queues'=6 = 22). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

