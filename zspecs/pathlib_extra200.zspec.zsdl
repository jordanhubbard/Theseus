spec: pathlib_extra200
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec extends pathlib_extra199.zspec.zsdl."
    - "This spec covers pathlib.Path property identity — name, suffix, stem, parent, parts, drive, root, anchor all have __class__.__name__ == 'property'."
    - "pathlib.Path.name.__class__.__name__ == 'property' (len=8); name is a descriptor that returns the final path component; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.suffix.__class__.__name__ == 'property' (len=8); suffix is the file extension including the leading dot; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.stem.__class__.__name__ == 'property' (len=8); stem is the final component without its suffix; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.parent.__class__.__name__ == 'property' (len=8); parent is the logical parent path; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.parts.__class__.__name__ == 'property' (len=8); parts is a tuple of the path's components; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.drive.__class__.__name__ == 'property' (len=8); drive is the drive letter or name (empty on POSIX); confirmed Python 3.14.3 macOS."
    - "pathlib.Path.root.__class__.__name__ == 'property' (len=8); root is the root of the path ('/' on absolute POSIX paths); confirmed Python 3.14.3 macOS."
    - "pathlib.Path.anchor.__class__.__name__ == 'property' (len=8); anchor is the concatenation of drive and root; confirmed Python 3.14.3 macOS."
    - "All eight Path properties (name, suffix, stem, parent, parts, drive, root, anchor) are plain Python property descriptors, not classmethod, cached_property, or custom descriptor types; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.Path property class names — name, suffix, stem, parent
# all __class__.__name__ == 'property' (len=8)
# ---------------------------------------------------------------------------

table pathlib_extra200.path_property_class_names_a:
  description: "pathlib.Path property class names: name, suffix, stem, parent — all __class__.__name__ == 'property' (len=8)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibprops200

  columns: [id, function, args, expected, description]
  rows:
    - [name_class_eq,   pathlib.Path.name.__class__.__name__.__eq__,   ["property"], true, "pathlib.Path.name.__class__.__name__ == 'property' (len=8); name is a property descriptor returning the final path component; confirmed Python 3.14.3 macOS"]
    - [suffix_class_eq, pathlib.Path.suffix.__class__.__name__.__eq__, ["property"], true, "pathlib.Path.suffix.__class__.__name__ == 'property' (len=8); suffix is a property descriptor returning the file extension; confirmed Python 3.14.3 macOS"]
    - [stem_class_eq,   pathlib.Path.stem.__class__.__name__.__eq__,   ["property"], true, "pathlib.Path.stem.__class__.__name__ == 'property' (len=8); stem is a property descriptor returning the final component without suffix; confirmed Python 3.14.3 macOS"]
    - [parent_class_eq, pathlib.Path.parent.__class__.__name__.__eq__, ["property"], true, "pathlib.Path.parent.__class__.__name__ == 'property' (len=8); parent is a property descriptor returning the logical parent path; confirmed Python 3.14.3 macOS"]
    - [name_class_len,  pathlib.Path.name.__class__.__name__.__len__,  [], 8, "pathlib.Path.name.__class__.__name__.__len__() == 8 — p(1)r(2)o(3)p(4)e(5)r(6)t(7)y(8); all Path properties share this class name length; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.Path property class names — parts, drive, root, anchor
# all __class__.__name__ == 'property' (len=8)
# ---------------------------------------------------------------------------

table pathlib_extra200.path_property_class_names_b:
  description: "pathlib.Path property class names: parts, drive, root, anchor — all __class__.__name__ == 'property' (len=8)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibprops200

  columns: [id, function, args, expected, description]
  rows:
    - [parts_class_eq,  pathlib.Path.parts.__class__.__name__.__eq__,  ["property"], true, "pathlib.Path.parts.__class__.__name__ == 'property' (len=8); parts is a property descriptor returning a tuple of path components; confirmed Python 3.14.3 macOS"]
    - [drive_class_eq,  pathlib.Path.drive.__class__.__name__.__eq__,  ["property"], true, "pathlib.Path.drive.__class__.__name__ == 'property' (len=8); drive is a property descriptor returning the drive letter or name; confirmed Python 3.14.3 macOS"]
    - [root_class_eq,   pathlib.Path.root.__class__.__name__.__eq__,   ["property"], true, "pathlib.Path.root.__class__.__name__ == 'property' (len=8); root is a property descriptor returning the root string; confirmed Python 3.14.3 macOS"]
    - [anchor_class_eq, pathlib.Path.anchor.__class__.__name__.__eq__, ["property"], true, "pathlib.Path.anchor.__class__.__name__ == 'property' (len=8); anchor is a property descriptor returning the concatenation of drive and root; confirmed Python 3.14.3 macOS"]
    - [parts_class_len,  pathlib.Path.parts.__class__.__name__.__len__,  [], 8, "pathlib.Path.parts.__class__.__name__.__len__() == 8; same 'property' class as name, suffix, stem, parent; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.Path property __class__.__name__ length consistency
# all eight properties report 'property' with len=8
# ---------------------------------------------------------------------------

table pathlib_extra200.path_property_class_name_lengths:
  description: "pathlib.Path property __class__.__name__ lengths — all eight properties (name, suffix, stem, parent, parts, drive, root, anchor) report len=8 for 'property'"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibprops200

  columns: [id, function, args, expected, description]
  rows:
    - [name_class_len,   pathlib.Path.name.__class__.__name__.__len__,   [], 8, "pathlib.Path.name.__class__.__name__.__len__() == 8; 'property' has 8 characters; confirmed Python 3.14.3 macOS"]
    - [suffix_class_len, pathlib.Path.suffix.__class__.__name__.__len__, [], 8, "pathlib.Path.suffix.__class__.__name__.__len__() == 8; same length as name; confirmed Python 3.14.3 macOS"]
    - [stem_class_len,   pathlib.Path.stem.__class__.__name__.__len__,   [], 8, "pathlib.Path.stem.__class__.__name__.__len__() == 8; same length as name; confirmed Python 3.14.3 macOS"]
    - [drive_class_len,  pathlib.Path.drive.__class__.__name__.__len__,  [], 8, "pathlib.Path.drive.__class__.__name__.__len__() == 8; same length as name; confirmed Python 3.14.3 macOS"]
    - [anchor_class_len, pathlib.Path.anchor.__class__.__name__.__len__, [], 8, "pathlib.Path.anchor.__class__.__name__.__len__() == 8; same length as all other Path properties; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra200.path_name_property_class:
  description: "pathlib.Path.name.__class__.__name__ == 'property' — Path.name is a plain Python property descriptor (len=8); it returns the final component of the path as a string; property descriptors are defined with @property in pure Python or as C-level slot wrappers; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.name.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra200.path_suffix_property_class:
  description: "pathlib.Path.suffix.__class__.__name__ == 'property' — Path.suffix is a plain Python property descriptor (len=8); it returns the file extension of the final path component including the leading dot; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.suffix.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra200.path_stem_property_class:
  description: "pathlib.Path.stem.__class__.__name__ == 'property' — Path.stem is a plain Python property descriptor (len=8); it returns the final path component without its suffix; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.stem.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra200.path_parent_property_class:
  description: "pathlib.Path.parent.__class__.__name__ == 'property' — Path.parent is a plain Python property descriptor (len=8); it returns the logical parent of the path; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.parent.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra200.path_parts_property_class:
  description: "pathlib.Path.parts.__class__.__name__ == 'property' — Path.parts is a plain Python property descriptor (len=8); it returns an immutable tuple of the path components; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.parts.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra200.path_drive_property_class:
  description: "pathlib.Path.drive.__class__.__name__ == 'property' — Path.drive is a plain Python property descriptor (len=8); it returns the drive letter or name string (empty on POSIX systems); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.drive.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra200.path_root_property_class:
  description: "pathlib.Path.root.__class__.__name__ == 'property' — Path.root is a plain Python property descriptor (len=8); it returns the root of the path, which is '/' on absolute POSIX paths and '' on relative paths; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.root.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra200.path_anchor_property_class:
  description: "pathlib.Path.anchor.__class__.__name__ == 'property' — Path.anchor is a plain Python property descriptor (len=8); it returns the concatenation of drive and root; on POSIX, for absolute paths this is '/'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.anchor.__class__.__name__.__eq__
  args: ["property"]
  expected: true

