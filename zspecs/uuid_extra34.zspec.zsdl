spec: uuid_extra34
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra33.zspec.zsdl — covers UUID.__repr__/__hash__/__eq__/__int__ __qualname__.__eq__; UUID.hex.fget.__qualname__.__eq__('UUID.hex')."
    - "uuid_extra28.zspec.zsdl — covers UUID.time_low/time_mid/clock_seq_low property descriptor class name lens; time_low/time_mid/clock_seq_low fget __qualname__.__len__()."
    - "uuid_extra24.zspec.zsdl — covers UUID.node/time/clock_seq/time_hi_version/clock_seq_hi_variant fget __qualname__.__len__() (length checks only, NOT string eq values)."
    - "uuid_extra18.zspec.zsdl — covers UUID.bytes/version/bytes_le/fields/variant.fget.__qualname__.__eq__ as string eq values; UUID.hex/bytes/urn/version/bytes_le/fields/variant fget __qualname__.__len__()."
  notes:
    - "This spec extends uuid through uuid_extra33; it does NOT duplicate invariants present in those files."
    - "Coverage gap: uuid_extra24 covers UUID.node.fget.__qualname__.__len__()==9, UUID.time.fget.__qualname__.__len__()==9, UUID.clock_seq.fget.__qualname__.__len__()==14, UUID.time_hi_version.fget.__qualname__.__len__()==20, and UUID.clock_seq_hi_variant.fget.__qualname__.__len__()==25 (all length checks only). uuid_extra18 covers UUID.bytes/version/bytes_le/fields/variant.fget.__qualname__.__eq__ as string eq values, and uuid_extra33 covers UUID.hex.fget.__qualname__.__eq__. But NO prior spec checks __qualname__.__eq__ string values for UUID.time/node/clock_seq/time_hi_version/clock_seq_hi_variant fget. These are the five remaining UUID property fget qualnames for which only __len__() has been verified. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__qualname__ == 'UUID.time'. UUID.time is a Python property. extra24 covers the __len__()==9 (length only). No prior spec checks __qualname__.__eq__('UUID.time') for UUID.time.fget. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.fget.__qualname__ == 'UUID.node'. UUID.node is a Python property. extra24 covers the __len__()==9 (length only). No prior spec checks __qualname__.__eq__('UUID.node'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq.fget.__qualname__ == 'UUID.clock_seq'. UUID.clock_seq is a Python property. extra24 covers __len__()==14 (length only). No prior spec checks __qualname__.__eq__('UUID.clock_seq'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_hi_version.fget.__qualname__ == 'UUID.time_hi_version'. UUID.time_hi_version is a Python property. extra24 covers __len__()==20 (length only). No prior spec checks __qualname__.__eq__('UUID.time_hi_version'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq_hi_variant.fget.__qualname__ == 'UUID.clock_seq_hi_variant'. UUID.clock_seq_hi_variant is a Python property. extra24 covers __len__()==25 (length only, noted as longest UUID property fget qualname). No prior spec checks __qualname__.__eq__('UUID.clock_seq_hi_variant'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.int is a member_descriptor (slot), not a property — it has no fget attribute. It is excluded from fget qualname checks."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID property fget __qualname__.__eq__ string values:
# time, node, clock_seq, time_hi_version, clock_seq_hi_variant
#
# uuid_extra18 covers bytes/version/bytes_le/fields/variant.fget.__qualname__.__eq__.
# uuid_extra33 covers hex.fget.__qualname__.__eq__('UUID.hex').
# uuid_extra24 covers time/node/clock_seq/time_hi_version/clock_seq_hi_variant
#   fget.__qualname__.__len__() (length checks only) but NOT __qualname__.__eq__.
# These five property fget qualname eq values are the remaining gap.
# Note: function values with '[' require double quotes per ZSDL rules, but
# these functions contain only '.', so quoting follows standard conventions.
# ---------------------------------------------------------------------------

table uuid_extra34.UUID_property_fget_qualname_eq:
  description: "uuid.UUID.time/node/clock_seq/time_hi_version/clock_seq_hi_variant fget __qualname__.__eq__ string values — novel: extra18 covers bytes/version/bytes_le/fields/variant fget qualname eq; extra33 covers hex fget qualname eq; extra24 covers these five as __len__ only; no prior spec checks __qualname__.__eq__ for time/node/clock_seq/time_hi_version/clock_seq_hi_variant"
  kind: python_call_eq
  category: function_names
  id_prefix: upfqe34

  columns: [id, function, args, expected]
  rows:
    - [time_fget_qualname_eq,              "UUID.time.fget.__qualname__.__eq__",              ["UUID.time"],              true]
    - [node_fget_qualname_eq,              "UUID.node.fget.__qualname__.__eq__",              ["UUID.node"],              true]
    - [clock_seq_fget_qualname_eq,         "UUID.clock_seq.fget.__qualname__.__eq__",         ["UUID.clock_seq"],         true]
    - [time_hi_version_fget_qualname_eq,   "UUID.time_hi_version.fget.__qualname__.__eq__",   ["UUID.time_hi_version"],   true]
    - [clock_seq_hi_variant_fget_qualname_eq, "UUID.clock_seq_hi_variant.fget.__qualname__.__eq__", ["UUID.clock_seq_hi_variant"], true]
