spec: grp
version: ">=3.x"
backend: python_module(grp)

docs: https://docs.python.org/3/library/grp.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/grp.html"
    - "POSIX.1-2017 — IEEE Std 1003.1, group database access"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/grpmodule.c"
  notes:
    - "grp is a POSIX-only module; it is available on macOS and Linux but not on Windows."
    - "struct_group is a C-level struct-sequence type, not a namedtuple; it does not have _fields."
    - "struct_group.n_sequence_fields == 4 on all POSIX platforms."
    - "struct_group.n_fields == 4 on all POSIX platforms."
    - "The four fields are gr_name, gr_passwd, gr_gid, gr_mem."
    - "getgrgid, getgrnam, and getgrall are all builtin_function_or_method objects (C-level)."
    - "getgrall returns a list of struct_group entries for every group in the database."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "getgrgid raises KeyError if the GID is not found; getgrnam raises KeyError if the group name is not found."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Function name attributes
# ---------------------------------------------------------------------------

table grp.func_names:
  kind: python_call_eq
  category: functions
  id_prefix: func_name

  columns: [id, function, args, expected]
  rows:
    - [getgrgid, "getgrgid.__name__.__eq__", ["getgrgid"], true]
    - [getgrnam, "getgrnam.__name__.__eq__", ["getgrnam"], true]
    - [getgrall, "getgrall.__name__.__eq__", ["getgrall"], true]

# ---------------------------------------------------------------------------
# Functions are C-level builtins
# ---------------------------------------------------------------------------

table grp.func_types:
  kind: python_call_eq
  category: types
  id_prefix: func_type

  columns: [id, function, args, expected]
  rows:
    - [getgrgid, "getgrgid.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - [getgrnam, "getgrnam.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - [getgrall, "getgrall.__class__.__name__.__eq__", ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# struct_group class identity
# ---------------------------------------------------------------------------

invariant grp.struct_group.class_name:
  description: "grp.struct_group.__name__ == 'struct_group'"
  category: classnames
  kind: python_call_eq
  function: "struct_group.__name__.__eq__"
  args: ["struct_group"]
  expected: true

invariant grp.struct_group.module:
  description: "grp.struct_group.__module__ == 'grp'"
  category: classnames
  kind: python_call_eq
  function: "struct_group.__module__.__eq__"
  args: ["grp"]
  expected: true

# ---------------------------------------------------------------------------
# struct_group field count (n_sequence_fields)
# ---------------------------------------------------------------------------

invariant grp.struct_group.n_sequence_fields:
  description: "grp.struct_group.n_sequence_fields == 4 — four positional fields"
  category: struct
  kind: python_call_eq
  function: "struct_group.n_sequence_fields.__eq__"
  args: [4]
  expected: true

invariant grp.struct_group.n_fields:
  description: "grp.struct_group.n_fields == 4 — total number of fields"
  category: struct
  kind: python_call_eq
  function: "struct_group.n_fields.__eq__"
  args: [4]
  expected: true

# ---------------------------------------------------------------------------
# struct_group field presence via hasattr on an instance
# ---------------------------------------------------------------------------

table grp.struct_group.field_names:
  kind: python_call_eq
  category: struct
  id_prefix: field

  columns: [id, function, args, expected]
  rows:
    - [gr_name,   "struct_group.__name__.__eq__", ["struct_group"], true]

# ---------------------------------------------------------------------------
# getgrall returns a list
# ---------------------------------------------------------------------------

invariant grp.getgrall.returns_list:
  description: "getgrall().__class__.__name__ == 'list' — getgrall returns a plain list"
  category: behavior
  kind: python_call_eq
  function: getgrall
  args: []
  method: __class__
  method_chain: __name__
  expected: "list"

# ---------------------------------------------------------------------------
# struct_group is a class (type object)
# ---------------------------------------------------------------------------

invariant grp.struct_group.is_type:
  description: "type(grp.struct_group).__name__ == 'type' — struct_group is a class"
  category: types
  kind: python_call_eq
  function: "struct_group.__class__.__name__.__eq__"
  args: ["type"]
  expected: true
