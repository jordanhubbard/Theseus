spec: object_path
version: ">=0.11.0"
backend: node(object-path)

docs: https://www.npmjs.com/package/object-path

provenance:
  derived_from:
    - "object-path README — https://www.npmjs.com/package/object-path"
    - "Test vectors verified with object-path via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "object-path source"
  notes:
    - "object-path is an npm package. Install: npm install object-path"
    - "objectPath.get(obj, path, defaultValue) reads nested values by dot-separated path."
    - "Array elements are accessed by numeric index: 'a.1' accesses a[1]."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns value at the given path, or default if not found."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table object_path.get:
  kind: node_module_call_eq
  function: get
  category: get
  id_prefix: opget

  columns: [id, args, expected]
  rows:
    - [simple,   [{"a": 1}, "a"],                     1]
    - [nested,   [{"a": {"b": 42}}, "a.b"],            42]
    - [array,    [{"a": [10, 20, 30]}, "a.1"],         20]
    - [deep,     [{"x": {"y": {"z": "hi"}}}, "x.y.z"], "hi"]
    - [default,  [{}, "missing", "fallback"],           "fallback"]
