spec: functools_extra178
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.__name__ 'functools'; functools.__package__ '' (empty string); functools.__spec__.__class__.__name__ 'ModuleSpec'; functools.__loader__.__class__.__name__ 'SourceFileLoader'; functools.__doc__.__class__.__name__ 'str'; functools.partial.__mro__.__len__() 2 (partial > object); functools.partialmethod.__mro__.__len__() 2 (partialmethod > object) (Wave 302)."
    - "functools.__name__ == 'functools' — the functools module's __name__ attribute is the string 'functools'. Verified with Python 3.14.3."
    - "functools.__package__ == '' — functools is a top-level Python module in Lib/functools.py; its __package__ attribute is the empty string '' (not 'functools' and not None). Verified with Python 3.14.3."
    - "functools.__spec__.__class__.__name__ == 'ModuleSpec' — functools.__spec__ is an importlib.machinery.ModuleSpec object; its __class__.__name__ is 'ModuleSpec'. Verified with Python 3.14.3."
    - "functools.__loader__.__class__.__name__ == 'SourceFileLoader' — functools is a pure Python module loaded from Lib/functools.py; its loader is an instance of importlib._bootstrap_external.SourceFileLoader; __loader__.__class__.__name__ is 'SourceFileLoader'. Verified with Python 3.14.3."
    - "functools.__doc__.__class__.__name__ == 'str' — functools has a module-level docstring; __doc__ is a str instance. Verified with Python 3.14.3."
    - "functools.partial.__mro__.__len__() == 2 — partial is a C extension type that inherits directly from object; its __mro__ is (partial, object) with length 2. Verified with Python 3.14.3."
    - "functools.partialmethod.__mro__.__len__() == 2 — partialmethod is a Python class that inherits directly from object; its __mro__ is (partialmethod, object) with length 2. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools module __name__ and __package__ identity
#
# Wave 302 theme: functools.__name__ is 'functools' (length 9) and
# functools.__package__ is '' (empty string, NOT 'functools').
#
# functools.__name__ == 'functools'
# functools.__name__.__len__() == 9
# functools.__package__ == ''
# functools.__package__ != 'functools'
#
# functools is a top-level Python module defined in Lib/functools.py. Its
# __name__ is 'functools'. Unlike package directories, a single module file
# at the top level has __package__ == '' (empty string). New to extra178.
# ---------------------------------------------------------------------------

table functools_extra178.module_name_and_package:
  description: "functools.__name__ 'functools', len 9; __package__ '', not 'functools'; wave 302; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsmnp178

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_functools,
       "__name__.__eq__",
       ["functools"],
       true,
       "functools.__name__.__eq__('functools') == True — the functools module's __name__ attribute is the string 'functools'; str.__eq__('functools') returns True; new to extra178"]
    - [mod_name_len_9,
       "__name__.__len__",
       [],
       9,
       "functools.__name__.__len__() == 9 — the string 'functools' has exactly 9 characters: f-u-n-c-t-o-o-l-s; str.__len__() returns 9; new to extra178"]
    - [mod_package_empty,
       "__package__.__eq__",
       [""],
       true,
       "functools.__package__.__eq__('') == True — functools is a top-level Python module in Lib/functools.py; its __package__ attribute is the empty string '' (a module-level file, not a package directory); str.__eq__('') returns True; new to extra178"]
    - [mod_package_not_functools,
       "__package__.__eq__",
       ["functools"],
       false,
       "functools.__package__.__eq__('functools') == False — functools.__package__ is the empty string '', NOT 'functools'; only if functools were a package (directory with __init__.py) would __package__ be 'functools'; str.__eq__('functools') returns False; new to extra178"]

# ---------------------------------------------------------------------------
# Table 2: functools.__spec__ and __loader__ class names
#
# Wave 302 theme: functools.__spec__.__class__.__name__ == 'ModuleSpec';
# functools.__loader__.__class__.__name__ == 'SourceFileLoader'.
#
# functools.__spec__.__class__.__name__ == 'ModuleSpec'
# functools.__spec__.__class__.__name__ != 'BuiltinImporter'
# functools.__loader__.__class__.__name__ == 'SourceFileLoader'
# functools.__loader__.__class__.__name__ != 'BuiltinImporter'
#
# functools is a Python source file (Lib/functools.py), so it is loaded by
# importlib._bootstrap_external.SourceFileLoader (not BuiltinImporter, which
# handles C extension built-ins like itertools). Its __spec__ is a ModuleSpec
# object describing it. New to extra178.
# ---------------------------------------------------------------------------

table functools_extra178.spec_and_loader_class:
  description: "functools.__spec__ class 'ModuleSpec'; __loader__ class 'SourceFileLoader'; not BuiltinImporter; wave 302; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsslc178

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "functools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — functools.__spec__ is an importlib.machinery.ModuleSpec object describing the functools module; its __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra178"]
    - [spec_class_not_builtin_importer,
       "__spec__.__class__.__name__.__eq__",
       ["BuiltinImporter"],
       false,
       "functools.__spec__.__class__.__name__.__eq__('BuiltinImporter') == False — functools is a Python source module (not a C built-in), so its __spec__.__class__.__name__ is 'ModuleSpec' (not 'BuiltinImporter'); str.__eq__('BuiltinImporter') returns False; new to extra178"]
    - [loader_class_source_file_loader,
       "__loader__.__class__.__name__.__eq__",
       ["SourceFileLoader"],
       true,
       "functools.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — functools is a pure Python module loaded from Lib/functools.py; its loader is an instance of importlib._bootstrap_external.SourceFileLoader; __loader__.__class__.__name__ is 'SourceFileLoader'; str.__eq__('SourceFileLoader') returns True; new to extra178"]
    - [loader_class_not_builtin,
       "__loader__.__class__.__name__.__eq__",
       ["BuiltinImporter"],
       false,
       "functools.__loader__.__class__.__name__.__eq__('BuiltinImporter') == False — functools is a pure Python source file, NOT a C built-in extension; its loader is SourceFileLoader, not BuiltinImporter (which loads itertools, sys, etc.); str.__eq__('BuiltinImporter') returns False; new to extra178"]

# ---------------------------------------------------------------------------
# Table 3: functools.__doc__ is a str
#
# Wave 302 theme: functools.__doc__ is a str (not NoneType or bytes); and
# functools.__name__.__class__.__name__ == 'str'.
#
# functools.__doc__.__class__.__name__ == 'str'
# functools.__doc__.__class__.__name__ != 'NoneType'
# functools.__name__.__class__.__name__ == 'str'
# functools.__package__.__class__.__name__ == 'str'
#
# functools has a module-level docstring ('functools.py - Tools for working
# with functions and callable objects'). The __doc__ attribute is always a str
# when present. Both __name__ and __package__ are also str instances. New to
# extra178.
# ---------------------------------------------------------------------------

table functools_extra178.doc_and_name_class_str:
  description: "functools.__doc__ class 'str', not NoneType; __name__ class str; __package__ class str; wave 302; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsdncs178

  columns: [id, function, args, expected, description]
  rows:
    - [doc_class_str,
       "__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.__doc__.__class__.__name__.__eq__('str') == True — functools has a module-level docstring ('functools.py - Tools for working with functions and callable objects'); its __doc__ attribute is a str instance; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra178"]
    - [doc_class_not_nonetype,
       "__doc__.__class__.__name__.__eq__",
       ["NoneType"],
       false,
       "functools.__doc__.__class__.__name__.__eq__('NoneType') == False — functools.__doc__ is a non-None str (the module has a real docstring); its __class__.__name__ is 'str', not 'NoneType'; str.__eq__('NoneType') returns False; new to extra178"]
    - [name_class_str,
       "__name__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.__name__.__class__.__name__.__eq__('str') == True — functools.__name__ is the string 'functools'; it is a str instance whose __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra178"]
    - [package_class_str,
       "__package__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.__package__.__class__.__name__.__eq__('str') == True — functools.__package__ is the empty string '' which is a str instance; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra178"]

# ---------------------------------------------------------------------------
# Table 4: functools.partial.__mro__.__len__() == 2 (partial > object)
#
# Wave 302 theme: functools.partial is a C extension type that inherits
# directly from object; its __mro__ has exactly 2 entries.
#
# functools.partial.__mro__.__len__() == 2
# functools.partial.__mro__[0].__name__ == 'partial'
# functools.partial.__mro__[1].__name__ == 'object'
# functools.partial.__mro__.__len__() != 3
#
# functools.partial is defined in Modules/_functoolsmodule.c and inherits
# directly from object with no intermediate base classes. Its method resolution
# order is therefore the minimal (partial, object) tuple of length 2. New to
# extra178.
# ---------------------------------------------------------------------------

table functools_extra178.partial_mro_len:
  description: "functools.partial.__mro__: len 2, mro[0] 'partial', mro[1] 'object'; not len 3; wave 302; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: functoolspartmro178

  columns: [id, function, args, expected, description]
  rows:
    - [partial_mro_len_2,
       "partial.__mro__.__len__",
       [],
       2,
       "functools.partial.__mro__.__len__() == 2 — functools.partial is a C extension type defined in Modules/_functoolsmodule.c that inherits directly from object with no intermediate base classes; its __mro__ is (partial, object), a tuple of length 2; tuple.__len__() returns 2; new to extra178"]
    - ["partial_mro_0_partial",
       "partial.__mro__[0].__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__mro__[0].__name__.__eq__('partial') == True — the first entry in partial.__mro__ is the class itself; its __name__ is 'partial'; str.__eq__('partial') returns True; new to extra178"]
    - ["partial_mro_1_object",
       "partial.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__mro__[1].__name__.__eq__('object') == True — the second entry in partial.__mro__ is the base class object; its __name__ is 'object'; str.__eq__('object') returns True; new to extra178"]
    - [partial_mro_not_3,
       "partial.__mro__.__len__",
       [],
       2,
       "functools.partial.__mro__.__len__() == 2 (not 3) — partial inherits only from object, so its MRO has exactly 2 entries; there is no intermediate class between partial and object; tuple.__len__() returns 2; new to extra178"]

# ---------------------------------------------------------------------------
# Table 5: functools.partialmethod.__mro__.__len__() == 2 (partialmethod > object)
#
# Wave 302 theme: functools.partialmethod is a Python class that inherits
# directly from object; its __mro__ has exactly 2 entries.
#
# functools.partialmethod.__mro__.__len__() == 2
# functools.partialmethod.__mro__[0].__name__ == 'partialmethod'
# functools.partialmethod.__mro__[1].__name__ == 'object'
# functools.partial.__mro__.__len__() == functools.partialmethod.__mro__.__len__()
#
# functools.partialmethod is defined in Lib/functools.py and inherits directly
# from object. Despite being a Python class (unlike partial which is a C extension
# type), both have the same MRO length of 2. New to extra178.
# ---------------------------------------------------------------------------

table functools_extra178.partialmethod_mro_len:
  description: "functools.partialmethod.__mro__: len 2, mro[0] 'partialmethod', mro[1] 'object'; same len as partial; wave 302; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: functoolspmthmro178

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_mro_len_2,
       "partialmethod.__mro__.__len__",
       [],
       2,
       "functools.partialmethod.__mro__.__len__() == 2 — functools.partialmethod is a Python class defined in Lib/functools.py that inherits directly from object with no intermediate base classes; its __mro__ is (partialmethod, object), a tuple of length 2; tuple.__len__() returns 2; new to extra178"]
    - ["partialmethod_mro_0_partialmethod",
       "partialmethod.__mro__[0].__name__.__eq__",
       ["partialmethod"],
       true,
       "functools.partialmethod.__mro__[0].__name__.__eq__('partialmethod') == True — the first entry in partialmethod.__mro__ is the class itself; its __name__ is 'partialmethod'; str.__eq__('partialmethod') returns True; new to extra178"]
    - ["partialmethod_mro_1_object",
       "partialmethod.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__mro__[1].__name__.__eq__('object') == True — the second entry in partialmethod.__mro__ is the base class object; its __name__ is 'object'; str.__eq__('object') returns True; new to extra178"]
    - [partialmethod_mro_same_as_partial,
       "partialmethod.__mro__.__len__",
       [],
       2,
       "functools.partialmethod.__mro__.__len__() == 2 — same as functools.partial's MRO length; both partial (C extension type) and partialmethod (Python class) inherit directly from object, so both have MRO length 2; tuple.__len__() returns 2; new to extra178"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra178
# ---------------------------------------------------------------------------

invariant functools_extra178.mod_name_functools:
  description: "functools.__name__ == 'functools' — the module's name attribute is the string 'functools'; wave 302; new to extra178"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra178.mod_package_empty:
  description: "functools.__package__ == '' — functools is a top-level Python source module; its __package__ is the empty string; wave 302; new to extra178"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant functools_extra178.spec_class_modulespec:
  description: "functools.__spec__.__class__.__name__ == 'ModuleSpec' — __spec__ is an importlib.machinery.ModuleSpec describing the functools Python source module; wave 302; new to extra178"
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant functools_extra178.loader_class_source_file_loader:
  description: "functools.__loader__.__class__.__name__ == 'SourceFileLoader' — functools is a Python source file loaded by importlib SourceFileLoader, not BuiltinImporter; wave 302; new to extra178"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant functools_extra178.doc_class_str:
  description: "functools.__doc__.__class__.__name__ == 'str' — functools has a non-None module docstring; __doc__ is a str instance; wave 302; new to extra178"
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra178.partial_mro_len_2:
  description: "functools.partial.__mro__.__len__() == 2 — partial is a C extension type inheriting directly from object; its MRO is (partial, object); wave 302; new to extra178"
  kind: python_call_eq
  function: partial.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra178.partialmethod_mro_len_2:
  description: "functools.partialmethod.__mro__.__len__() == 2 — partialmethod is a Python class inheriting directly from object; its MRO is (partialmethod, object); wave 302; new to extra178"
  kind: python_call_eq
  function: partialmethod.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra178.mod_name_len_9:
  description: "functools.__name__.__len__() == 9 — 'functools' is 9 characters long; wave 302; new to extra178"
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 9
