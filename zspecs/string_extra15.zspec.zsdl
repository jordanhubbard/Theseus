spec: string_extra15
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra14.zspec.zsdl."
    - "string_extra14 covers: Template.substitute with dict positional arg; Template.template attribute; Template base class; ascii_lowercase.__len__()==26; ascii_uppercase.__len__()==26."
    - "string_extra13 covers: ascii_lowercase.__contains__('a'/'z'); digits.__contains__('5'); octdigits.__contains__('7'/'8'); hexdigits.__contains__('9'); whitespace.__contains__(' '); ascii_lowercase[0]=='a'; ascii_uppercase[-1]=='Z'; capwords five words."
    - "string_extra8 covers: __len__ for ascii_letters(52), digits(10), hexdigits(22), octdigits(8), punctuation(32), whitespace(6), printable(100) as namespace anchors."
    - "string_extra7 covers: printable.__contains__('5'/'a'/'Z'/'!'/' ') in table; printable.__contains__('\\x00')==False."
    - "string_extra6 covers: punctuation.__contains__('!'/'@')==True; punctuation.__contains__('a')==False; ascii_letters.__contains__('z'/'Z'/''0')==False."
    - "string_extra3 covers: ascii_letters.__contains__('z'/'Z'); printable.__contains__('A'/'0'/'!'); punctuation.__contains__('!')."
    - "NOT yet covered (now covered here): string.printable.__contains__('a') — 'a' not yet in printable __contains__ in string_extra13 namespace (covered in extra7 namespace)."
    - "NOT yet covered (now covered here): string.punctuation.__contains__('.') — '.' membership not tested in any prior namespace."
    - "NOT yet covered (now covered here): string.punctuation.__contains__('_') — '_' membership not tested in any prior namespace."
    - "NOT yet covered (now covered here): string.ascii_letters.__len__() — length 52 not tested in string_extra15 namespace (covered in extra8/extra14 namespaces)."
    - "string.printable.__contains__('a') == True — lowercase letters are in printable."
    - "string.printable.__contains__('Z') == True — uppercase letters are in printable."
    - "string.printable.__contains__('0') == True — digit characters are in printable."
    - "string.printable.__contains__(' ') == True — space character is in printable."
    - "string.punctuation.__contains__('!') == True — exclamation mark is in punctuation."
    - "string.punctuation.__contains__('.') == True — period/dot is in punctuation."
    - "string.punctuation.__contains__('@') == True — at-sign is in punctuation."
    - "string.punctuation.__contains__('_') == True — underscore is in punctuation (part of '!\"#$%&\\'()*+,-./:;<=>?@[\\\\]^_`{|}~')."
    - "string.ascii_letters.__len__() == 52 — 26 lowercase + 26 uppercase (namespace anchor)."
    - "string.digits.__len__() == 10 — ten decimal digit characters (namespace anchor)."
    - "string.hexdigits.__len__() == 22 — 0-9 + a-f + A-F = 22 (namespace anchor)."
    - "string.octdigits.__len__() == 8 — octal digits 0-7 (namespace anchor)."
    - "string.punctuation.__len__() == 32 — 32 ASCII punctuation characters (namespace anchor)."
    - "string.printable.__len__() == 100 — 100 printable ASCII characters (namespace anchor)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: string.printable — __contains__ membership checks
#
# string_extra7 covers printable.__contains__ for '5','a','Z','!',' ','\\x00'
# in the string_extra7 namespace. string_extra3 covers 'A','0','!'.
# This table adds namespace-anchor vectors for string_extra15, covering
# 'a', 'Z', '0', ' ' — all printable characters.
# ---------------------------------------------------------------------------

table string_extra15.printable_contains:
  description: "string.printable.__contains__ membership — lowercase, uppercase, digit, space"
  kind: python_call_eq
  category: constants
  id_prefix: pc

  columns: [id, function, args, expected]
  rows:
    - [has_a,     printable.__contains__, ["a"], true]
    - [has_Z,     printable.__contains__, ["Z"], true]
    - [has_0,     printable.__contains__, ["0"], true]
    - [has_space, printable.__contains__, [" "], true]

# ---------------------------------------------------------------------------
# Table: string.punctuation — __contains__ membership checks
#
# string_extra3 covers punctuation.__contains__('!') as a standalone invariant.
# string_extra6 covers '!'/'@' (True) and 'a' (False) as standalone invariants.
# No prior spec tests punctuation.__contains__('.') or punctuation.__contains__('_').
# The punctuation constant is '!"#$%&\'()*+,-./:;<=>?@[\\]^_`{|}~' (32 chars).
# Period ('.') and underscore ('_') are both members.
# ---------------------------------------------------------------------------

table string_extra15.punctuation_contains:
  description: "string.punctuation.__contains__ membership — !, ., @, _ all present"
  kind: python_call_eq
  category: constants
  id_prefix: punc

  columns: [id, function, args, expected]
  rows:
    - [has_bang,       punctuation.__contains__, ["!"], true]
    - [has_period,     punctuation.__contains__, ["."], true]
    - [has_at,         punctuation.__contains__, ["@"], true]
    - [has_underscore, punctuation.__contains__, ["_"], true]

# ---------------------------------------------------------------------------
# Table: string constant __len__ checks
#
# string_extra8 covers __len__ for all these constants as namespace anchors
# in the string_extra8 namespace. This table provides namespace-anchor vectors
# for string_extra15. ascii_letters==52, digits==10, hexdigits==22,
# octdigits==8, punctuation==32, printable==100.
# ---------------------------------------------------------------------------

table string_extra15.constant_lengths:
  description: "string constant character counts — ascii_letters, digits, hexdigits, octdigits, punctuation, printable"
  kind: python_call_eq
  category: constants
  id_prefix: cl

  columns: [id, function, args, expected]
  rows:
    - [ascii_letters_len, ascii_letters.__len__, [], 52]
    - [digits_len,        digits.__len__,        [], 10]
    - [hexdigits_len,     hexdigits.__len__,     [], 22]
    - [octdigits_len,     octdigits.__len__,     [], 8]
    - [punctuation_len,   punctuation.__len__,   [], 32]
    - [printable_len,     printable.__len__,     [], 100]
