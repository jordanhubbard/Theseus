spec: warnings_extra25
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
  notes:
    - "This spec extends warnings_extra24.zspec.zsdl."
    - "Prior specs covered: warn/warn_explicit/simplefilter/filterwarnings/resetwarnings __module__.__len__() and __name__.__len__(), catch_warnings __module__.__len__()==12 and __name__.__len__()==14, catch_warnings method __qualname__.__len__() (__init__=23, __enter__=24, __exit__=23, __repr__=23), showwarning/__name__.__len__()==11 and __module__.__len__()==12, formatwarning/__name__.__len__()==13 and __module__.__len__()==12, DeprecationWarning/__name__.__len__()==18, UserWarning/__name__.__len__()==11, RuntimeWarning/__name__.__len__()==14, SyntaxWarning/__name__.__len__()==13, FutureWarning/__name__.__len__()==13."
    - "This spec covers: __mro__.__len__() for WarningMessage (2), catch_warnings (2), UserWarning (5), DeprecationWarning (5); __bases__[0].__name__ and __bases__[0].__name__.__len__() for WarningMessage ('object', 6), DeprecationWarning ('Warning', 7), UserWarning ('Warning', 7); WarningMessage.__init__.__qualname__.__len__()==23; WarningMessage.__str__.__qualname__.__len__()==22; catch_warnings.__init__.__qualname__.__len__()==23."
    - "warnings.WarningMessage.__mro__.__len__() == 2 — mro is (WarningMessage, object). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.catch_warnings.__mro__.__len__() == 2 — mro is (catch_warnings, object). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "UserWarning.__mro__.__len__() == 5 — mro is (UserWarning, Warning, Exception, BaseException, object). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "DeprecationWarning.__mro__.__len__() == 5 — mro is (DeprecationWarning, Warning, Exception, BaseException, object). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "DeprecationWarning.__bases__[0].__name__ == 'Warning' (len 7). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "UserWarning.__bases__[0].__name__ == 'Warning' (len 7). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.WarningMessage.__bases__[0].__name__ == 'object' (len 6). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.WarningMessage.__init__.__qualname__ == 'WarningMessage.__init__' (len 23). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.WarningMessage.__str__.__qualname__ == 'WarningMessage.__str__' (len 22). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.catch_warnings.__init__.__qualname__ == 'catch_warnings.__init__' (len 23). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for WarningMessage and catch_warnings
#
# No prior spec checks __mro__.__len__() for any warnings class.
# Both WarningMessage and catch_warnings directly extend only object: depth 2.
# ---------------------------------------------------------------------------

invariant warnings_extra25.WarningMessage.mro.len:
  description: "warnings.WarningMessage.__mro__.__len__() == 2 — (WarningMessage, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: WarningMessage.__mro__.__len__
  args: []
  expected: 2

invariant warnings_extra25.catch_warnings.mro.len:
  description: "warnings.catch_warnings.__mro__.__len__() == 2 — (catch_warnings, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: catch_warnings.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# __mro__.__len__() for built-in warning exception classes
#
# UserWarning and DeprecationWarning both follow the exception hierarchy:
# (SubWarning, Warning, Exception, BaseException, object) — depth 5.
# No prior spec covers __mro__.__len__() for these classes.
# ---------------------------------------------------------------------------

invariant warnings_extra25.UserWarning.mro.len:
  description: "UserWarning.__mro__.__len__() == 5 — (UserWarning, Warning, Exception, BaseException, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: UserWarning.__mro__.__len__
  args: []
  expected: 5

invariant warnings_extra25.DeprecationWarning.mro.len:
  description: "DeprecationWarning.__mro__.__len__() == 5 — (DeprecationWarning, Warning, Exception, BaseException, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: DeprecationWarning.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__() for WarningMessage, DeprecationWarning,
# UserWarning
#
# WarningMessage directly extends object (base name len 6).
# DeprecationWarning and UserWarning both directly extend Warning (len 7).
# No prior spec covers __bases__[0].__name__.__len__() for any warnings class.
# ---------------------------------------------------------------------------

invariant warnings_extra25.WarningMessage.bases0.name.len:
  description: "warnings.WarningMessage.__bases__[0].__name__.__len__() == 6 — base is 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: "WarningMessage.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant warnings_extra25.DeprecationWarning.bases0.name.len:
  description: "DeprecationWarning.__bases__[0].__name__.__len__() == 7 — base is 'Warning'"
  category: class_hierarchy
  kind: python_call_eq
  function: "DeprecationWarning.__bases__[0].__name__.__len__"
  args: []
  expected: 7

invariant warnings_extra25.UserWarning.bases0.name.len:
  description: "UserWarning.__bases__[0].__name__.__len__() == 7 — base is 'Warning'"
  category: class_hierarchy
  kind: python_call_eq
  function: "UserWarning.__bases__[0].__name__.__len__"
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# WarningMessage method __qualname__.__len__() — __init__ and __str__
#
# No prior spec covers WarningMessage method qualname lengths.
# __init__: 'WarningMessage.__init__' (len 23)
# __str__: 'WarningMessage.__str__' (len 22) — one char shorter than __init__
# ---------------------------------------------------------------------------

invariant warnings_extra25.WarningMessage.__init__.qualname.len:
  description: "warnings.WarningMessage.__init__.__qualname__.__len__() == 23 — 'WarningMessage.__init__' has 23 characters"
  category: string_length
  kind: python_call_eq
  function: "WarningMessage.__init__.__qualname__.__len__"
  args: []
  expected: 23

invariant warnings_extra25.WarningMessage.__str__.qualname.len:
  description: "warnings.WarningMessage.__str__.__qualname__.__len__() == 22 — 'WarningMessage.__str__' has 22 characters"
  category: string_length
  kind: python_call_eq
  function: "WarningMessage.__str__.__qualname__.__len__"
  args: []
  expected: 22

# ---------------------------------------------------------------------------
# catch_warnings.__init__.__qualname__.__len__()
#
# warnings_extra24 covers catch_warnings.__init__.__qualname__.__len__()==23
# as a standalone invariant. This spec re-anchors the value in a table context
# alongside WarningMessage method lengths for cross-namespace comparison.
# ---------------------------------------------------------------------------

invariant warnings_extra25.catch_warnings.__init__.qualname.len:
  description: "warnings.catch_warnings.__init__.__qualname__.__len__() == 23 — 'catch_warnings.__init__' has 23 characters"
  category: string_length
  kind: python_call_eq
  function: "catch_warnings.__init__.__qualname__.__len__"
  args: []
  expected: 23

# ---------------------------------------------------------------------------
# Table: __mro__.__len__() for all four warnings classes
#
# Groups MRO depth checks for WarningMessage, catch_warnings, UserWarning,
# and DeprecationWarning. No prior spec groups these together.
# ---------------------------------------------------------------------------

table warnings_extra25.class_mro_depths:
  description: "warnings class __mro__.__len__() — WarningMessage (2), catch_warnings (2), UserWarning (5), DeprecationWarning (5)"
  kind: python_call_eq
  category: class_hierarchy

  columns: [id, function, args, expected, description]
  rows:
    - [WarningMessage_mro_len,
       WarningMessage.__mro__.__len__,
       [],
       2,
       "len(WarningMessage.__mro__) == 2"]
    - [catch_warnings_mro_len,
       catch_warnings.__mro__.__len__,
       [],
       2,
       "len(catch_warnings.__mro__) == 2"]
    - [UserWarning_mro_len,
       UserWarning.__mro__.__len__,
       [],
       5,
       "len(UserWarning.__mro__) == 5"]
    - [DeprecationWarning_mro_len,
       DeprecationWarning.__mro__.__len__,
       [],
       5,
       "len(DeprecationWarning.__mro__) == 5"]

# ---------------------------------------------------------------------------
# Table: __bases__[0].__name__.__len__() and WarningMessage method qualnames
#
# Groups direct-base name lengths and WarningMessage/__str__/__init__ qualname
# lengths. No prior spec groups these measurements together.
# ---------------------------------------------------------------------------

table warnings_extra25.bases_and_method_qualnames:
  description: "warnings class __bases__[0].__name__.__len__() and WarningMessage method qualname lengths"
  kind: python_call_eq
  category: class_hierarchy

  columns: [id, function, args, expected, description]
  rows:
    - [WarningMessage_bases0_name_len,
       "WarningMessage.__bases__[0].__name__.__len__",
       [],
       6,
       "len('object') == 6 — WarningMessage base"]
    - [DeprecationWarning_bases0_name_len,
       "DeprecationWarning.__bases__[0].__name__.__len__",
       [],
       7,
       "len('Warning') == 7 — DeprecationWarning base"]
    - [UserWarning_bases0_name_len,
       "UserWarning.__bases__[0].__name__.__len__",
       [],
       7,
       "len('Warning') == 7 — UserWarning base"]
    - [WarningMessage_init_qualname_len,
       "WarningMessage.__init__.__qualname__.__len__",
       [],
       23,
       "len('WarningMessage.__init__') == 23"]
    - [WarningMessage_str_qualname_len,
       "WarningMessage.__str__.__qualname__.__len__",
       [],
       22,
       "len('WarningMessage.__str__') == 22"]
    - [catch_warnings_init_qualname_len,
       "catch_warnings.__init__.__qualname__.__len__",
       [],
       23,
       "len('catch_warnings.__init__') == 23"]
