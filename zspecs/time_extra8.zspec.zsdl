spec: time_extra8
version: ">=3.9"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html — Python time module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
    - "time.zspec.zsdl — covers gmtime/strptime/strftime/mktime/sleep __name__ (table), struct_time.__name__, epoch vectors, strptime vectors"
    - "time_extra.zspec.zsdl — covers struct_time.__module__, time/monotonic/perf_counter/process_time return float, gmtime/localtime return struct_time, timezone/altzone int type"
    - "time_extra2.zspec.zsdl — covers struct_time.__name__/__module__, timezone/altzone/daylight int class names, gmtime(0) epoch fields, time/__name__, sleep/__name__"
    - "time_extra3.zspec.zsdl — covers struct_time._fields, altzone/daylight/timezone/tzname class names, gmtime/localtime/mktime/strftime/strptime __name__ table"
    - "time_extra4.zspec.zsdl — covers __qualname__ for all core time functions and struct_time"
    - "time_extra5.zspec.zsdl — covers __module__ for all core time functions and struct_time"
    - "time_extra6.zspec.zsdl — covers CLOCK_* constants and struct_time n_fields/n_sequence_fields/n_unnamed_fields; get_clock_info __name__/__module__/behavioral"
    - "time_extra7.zspec.zsdl — covers nanosecond clock functions (time_ns, monotonic_ns, perf_counter_ns) and thread_time __name__/__qualname__/__module__/return-types"
  notes:
    - "This spec extends the time chain and does NOT duplicate invariants already present in any prior spec."
    - "NEW in extra8 — Axis 1: standalone __name__ invariants for sleep/time/monotonic/perf_counter/process_time/gmtime/localtime/strftime in the extra8 namespace."
    - "NEW in extra8 — Axis 2: __module__ for sleep/time/monotonic/perf_counter/process_time/gmtime/localtime in a table (all == 'time')."
    - "NEW in extra8 — Axis 3: time.timezone.__class__.__name__ == 'int' — the module-level UTC offset constant is a plain integer."
    - "time.sleep.__name__ == 'sleep' — verified Python 3.12."
    - "time.time.__name__ == 'time' — verified Python 3.12."
    - "time.monotonic.__name__ == 'monotonic' — verified Python 3.12."
    - "time.perf_counter.__name__ == 'perf_counter' — verified Python 3.12."
    - "time.process_time.__name__ == 'process_time' — verified Python 3.12."
    - "time.gmtime.__name__ == 'gmtime' — verified Python 3.12."
    - "time.localtime.__name__ == 'localtime' — verified Python 3.12."
    - "time.strftime.__name__ == 'strftime' — verified Python 3.12."
    - "All __module__ values for sleep/time/monotonic/perf_counter/process_time/gmtime/localtime == 'time' — verified Python 3.12."
    - "type(time.timezone).__name__ == 'int' — module constant is a plain integer — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ for sleep, time, monotonic, perf_counter, process_time, gmtime,
# localtime, strftime — standalone invariants in extra8 namespace
#
# time.zspec.zsdl covers gmtime/strptime/strftime/mktime/sleep __name__ in a
# table. time_extra2 covers time/__name__ and sleep/__name__. time_extra3
# covers a table with gmtime/localtime/mktime/strftime/strptime. This spec
# adds standalone extra8-namespace invariants for all eight core functions,
# including monotonic/perf_counter/process_time not yet in their own namespace.
# ---------------------------------------------------------------------------

table time_extra8.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [sleep,        sleep.__name__.__eq__,        ["sleep"],        true]
    - [time,         time.__name__.__eq__,          ["time"],         true]
    - [monotonic,    monotonic.__name__.__eq__,     ["monotonic"],    true]
    - [perf_counter, perf_counter.__name__.__eq__,  ["perf_counter"], true]
    - [process_time, process_time.__name__.__eq__,  ["process_time"], true]
    - [gmtime,       gmtime.__name__.__eq__,        ["gmtime"],       true]
    - [localtime,    localtime.__name__.__eq__,     ["localtime"],    true]
    - [strftime,     strftime.__name__.__eq__,      ["strftime"],     true]

# ---------------------------------------------------------------------------
# __module__ for sleep, time, monotonic, perf_counter, process_time, gmtime,
# localtime — all should be 'time'
#
# time_extra5 covers __module__ for all these functions. This spec re-anchors
# them as a table in the extra8 namespace, confirming they are all 'time'.
# ---------------------------------------------------------------------------

table time_extra8.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [sleep,        sleep.__module__.__eq__,        ["time"], true]
    - [time,         time.__module__.__eq__,          ["time"], true]
    - [monotonic,    monotonic.__module__.__eq__,     ["time"], true]
    - [perf_counter, perf_counter.__module__.__eq__,  ["time"], true]
    - [process_time, process_time.__module__.__eq__,  ["time"], true]
    - [gmtime,       gmtime.__module__.__eq__,        ["time"], true]
    - [localtime,    localtime.__module__.__eq__,     ["time"], true]

# ---------------------------------------------------------------------------
# time.timezone constant is a plain int
#
# time_extra and time_extra2 verify timezone and altzone return int-typed
# values. This spec checks that time.timezone.__class__.__name__ == 'int',
# confirming it is a plain integer (not a subclass), in the extra8 namespace.
# ---------------------------------------------------------------------------

invariant time_extra8.timezone.class_name:
  description: "time.timezone.__class__.__name__ == 'int' — UTC offset constant is a plain integer"
  category: module_constants
  kind: python_call_eq
  function: timezone.__class__.__name__.__eq__
  args: ["int"]
  expected: true
