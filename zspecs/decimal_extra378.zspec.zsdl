spec: decimal_extra378
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "decimal rounding mode constants are plain strings; their value equals their name (e.g. decimal.ROUND_FLOOR == 'ROUND_FLOOR')"
    - "Covered here: ROUND_FLOOR, ROUND_CEILING, ROUND_DOWN, ROUND_HALF_DOWN, ROUND_HALF_UP, ROUND_05UP"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal rounding mode string constants
# ---------------------------------------------------------------------------

table decimal_extra378.rounding_mode_values:
  description: "decimal rounding mode constants are strings equal to their own names — ROUND_FLOOR, ROUND_CEILING, ROUND_DOWN, ROUND_HALF_DOWN, ROUND_HALF_UP, ROUND_05UP; each constant's string value matches its Python attribute name; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: decrnd378

  columns: [id, function, args, expected]
  rows:
    - [round_floor,     decimal.ROUND_FLOOR.__eq__,     ["ROUND_FLOOR"],     true]
    - [round_ceiling,   decimal.ROUND_CEILING.__eq__,   ["ROUND_CEILING"],   true]
    - [round_down,      decimal.ROUND_DOWN.__eq__,      ["ROUND_DOWN"],      true]
    - [round_half_down, decimal.ROUND_HALF_DOWN.__eq__, ["ROUND_HALF_DOWN"], true]
    - [round_half_up,   decimal.ROUND_HALF_UP.__eq__,   ["ROUND_HALF_UP"],   true]
    - [round_05up,      decimal.ROUND_05UP.__eq__,      ["ROUND_05UP"],      true]
