spec: functools_extra157
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.reduce.__class__.__name__ 'builtin_function_or_method'; functools.partial.__name__ 'partial', __module__ 'functools', __bases__[0].__name__ 'object', __qualname__ len 7; functools.lru_cache.__module__ 'functools', __qualname__ 'lru_cache' len 9 (Wave 281)."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C builtin; its type is builtin_function_or_method (same type as e.g. len). Note: reduce.__module__ == '_functools' was already covered in extra155. Verified with Python 3.14.3."
    - "functools.partial.__name__ == 'partial' — partial is a C extension type; __name__ is 'partial'. Verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools' — partial is re-exported into functools and its __module__ is 'functools', unlike reduce whose __module__ is '_functools'. Verified with Python 3.14.3."
    - "functools.partial.__bases__[0].__name__ == 'object' — partial is a C extension type that inherits directly from object; __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "functools.partial.__qualname__.__len__() == 7 — __qualname__ is 'partial' which has 7 characters. Verified with Python 3.14.3."
    - "functools.lru_cache.__module__ == 'functools' — lru_cache is a Python function defined in Lib/functools.py; its __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache' (len 9) — lru_cache is defined at module scope; qualname equals name. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.reduce code attributes — class name
#
# Wave 281 theme: functools.reduce and functools.partial code attributes and
# class hierarchy.
#
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
#
# reduce is a C builtin from _functoolsmodule.c. Its __class__ is the
# builtin_function_or_method type — the same type as e.g. len, id, etc.
# reduce.__module__ == '_functools' was already covered in extra155.
# New to extra157.
# ---------------------------------------------------------------------------

table functools_extra157.reduce_class_and_partial_name:
  description: "functools.reduce: class 'builtin_function_or_method'; functools.partial: __name__ 'partial', __module__ 'functools', __bases__[0] 'object', qualname len 7; wave 281; new to extra157"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsrpcls157

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_eq_builtin_fn_or_method,
       "reduce.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C builtin function from _functoolsmodule.c; its __class__ is the builtin_function_or_method type; str.__eq__('builtin_function_or_method') returns True; new to extra157"]
    - [partial_name_eq,
       "partial.__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial is a C extension type from _functoolsmodule.c; its __name__ class attribute is 'partial'; str.__eq__('partial') returns True; new to extra157"]
    - [partial_module_eq_functools,
       "partial.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial is a C extension type but its __module__ is 'functools' (not '_functools'); this is because it is registered with __module__='functools' in _functoolsmodule.c; str.__eq__('functools') returns True; new to extra157"]
    - ["partial_bases_0_name_eq_object",
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial is a C extension type that inherits directly from object; __bases__ is (object,) so __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra157"]
    - [partial_qualname_len_eq_7,
       "partial.__qualname__.__len__",
       [],
       7,
       "functools.partial.__qualname__.__len__() == 7 — __qualname__ is 'partial' which has 7 characters; len('partial') == 7; new to extra157"]
    - [partial_mro_len_eq_2,
       "partial.__mro__.__len__",
       [],
       2,
       "functools.partial.__mro__.__len__() == 2 — partial inherits directly from object; MRO is [partial, object]; len(__mro__) == 2; new to extra157"]

# ---------------------------------------------------------------------------
# Table 2: functools.lru_cache — qualname, module, and class identity
#
# Wave 281 theme: functools.lru_cache as a Python function.
#
# functools.lru_cache.__module__ == 'functools'
# functools.lru_cache.__qualname__ == 'lru_cache' (len 9)
# functools.lru_cache.__class__.__name__ == 'function'
#
# lru_cache is a Python decorator function defined in Lib/functools.py.
# Unlike _lru_cache_wrapper which is a C extension type, lru_cache itself
# is a pure-Python wrapper. New to extra157.
# ---------------------------------------------------------------------------

table functools_extra157.lru_cache_identity:
  description: "functools.lru_cache: Python function, __module__ 'functools', __qualname__ 'lru_cache' len 9, class 'function'; wave 281; new to extra157"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolslci157

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_module_eq_functools,
       "lru_cache.__module__.__eq__",
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is a Python function defined in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra157"]
    - [lru_cache_qualname_eq,
       "lru_cache.__qualname__.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — lru_cache is defined at module scope; its __qualname__ equals its __name__ 'lru_cache'; str.__eq__('lru_cache') returns True; new to extra157"]
    - [lru_cache_qualname_len_eq_9,
       "lru_cache.__qualname__.__len__",
       [],
       9,
       "functools.lru_cache.__qualname__.__len__() == 9 — __qualname__ is 'lru_cache' which has 9 characters; len('lru_cache') == 9; new to extra157"]
    - [lru_cache_class_eq_function,
       "lru_cache.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is a Python function (not a C extension type); its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra157"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra157
# ---------------------------------------------------------------------------

invariant functools_extra157.reduce_class_builtin_fn_or_method:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C builtin type; wave 281; new to extra157"
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra157.partial_name_eq_partial:
  description: "functools.partial.__name__ == 'partial' — C extension type name; wave 281; new to extra157"
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra157.partial_module_eq_functools:
  description: "functools.partial.__module__ == 'functools' — partial __module__ is functools not _functools; wave 281; new to extra157"
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra157.partial_bases_object:
  description: "functools.partial.__bases__[0].__name__ == 'object' — partial inherits directly from object; wave 281; new to extra157"
  kind: python_call_eq
  function: "partial.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra157.partial_qualname_len:
  description: "len(functools.partial.__qualname__) == 7 — __qualname__ is 'partial', 7 characters; wave 281; new to extra157"
  kind: python_call_eq
  function: partial.__qualname__.__len__
  args: []
  expected: 7

invariant functools_extra157.lru_cache_module_functools:
  description: "functools.lru_cache.__module__ == 'functools' — lru_cache is a Python function in Lib/functools.py; wave 281; new to extra157"
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra157.lru_cache_qualname_eq:
  description: "functools.lru_cache.__qualname__ == 'lru_cache' — module-scope function qualname equals name; wave 281; new to extra157"
  kind: python_call_eq
  function: lru_cache.__qualname__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra157.lru_cache_qualname_len:
  description: "len(functools.lru_cache.__qualname__) == 9 — 'lru_cache' has 9 characters; wave 281; new to extra157"
  kind: python_call_eq
  function: lru_cache.__qualname__.__len__
  args: []
  expected: 9
