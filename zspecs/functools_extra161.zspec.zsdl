# ---------------------------------------------------------------------------
# Table 1: functools.lru_cache and functools.cache code attributes
#
# Wave 285 theme: functools.lru_cache and functools.cache __code__ attributes
# and cache __module__.
#
# functools.lru_cache.__code__.co_name == 'lru_cache'
# functools.lru_cache.__code__.co_argcount == 2
# functools.cache.__module__.__eq__('functools') == True
# functools.cache.__code__.co_name == 'cache'
# functools.cache.__code__.co_argcount == 1
#
# lru_cache(maxsize=128, typed=False) is the bounded LRU memoization decorator.
# cache is the simpler unbounded variant added in Python 3.9; it takes only the
# function to cache (1 argument), unlike lru_cache which takes 2.
# New to extra161.
# ---------------------------------------------------------------------------

table functools_extra161.lru_cache_and_cache_code_attrs:
  description: "functools.lru_cache: co_name 'lru_cache', co_argcount 2; functools.cache: __module__ 'functools', co_name 'cache', co_argcount 1; wave 285; new to extra161"
  kind: python_call_eq
  category: identity
  id_prefix: functoolslruca161

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_co_name_eq,
       "lru_cache.__code__.co_name.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__code__.co_name.__eq__('lru_cache') == True — lru_cache is a Python decorator in Lib/functools.py implementing bounded LRU memoization; its code object co_name is 'lru_cache'; str.__eq__('lru_cache') returns True; new to extra161"]
    - [lru_cache_co_argcount_eq_2,
       "lru_cache.__code__.co_argcount.__eq__",
       [2],
       true,
       "functools.lru_cache.__code__.co_argcount.__eq__(2) == True — lru_cache(maxsize=128, typed=False) takes 2 positional-or-keyword arguments; co_argcount is 2; int.__eq__(2) returns True; new to extra161"]
    - [cache_module_eq_functools,
       "cache.__module__.__eq__",
       ["functools"],
       true,
       "functools.cache.__module__.__eq__('functools') == True — cache is a simpler unbounded variant of lru_cache added in Python 3.9; it is defined in Lib/functools.py and its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra161"]
    - [cache_co_name_eq,
       "cache.__code__.co_name.__eq__",
       ["cache"],
       true,
       "functools.cache.__code__.co_name.__eq__('cache') == True — cache is a Python function in Lib/functools.py; its code object co_name is 'cache'; str.__eq__('cache') returns True; new to extra161"]
    - [cache_co_argcount_eq_1,
       "cache.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.cache.__code__.co_argcount.__eq__(1) == True — cache(user_function) takes exactly 1 argument (the function to cache); it is simpler than lru_cache with no maxsize or typed parameters; co_argcount is 1; int.__eq__(1) returns True; new to extra161"]

# ---------------------------------------------------------------------------
# Table 2: functools.total_ordering and functools.singledispatch code attributes
#
# Wave 285 theme: functools.total_ordering and functools.singledispatch
# __code__ co_name and co_argcount.
#
# functools.total_ordering.__code__.co_name == 'total_ordering'
# functools.total_ordering.__code__.co_argcount == 1
# functools.singledispatch.__code__.co_name == 'singledispatch'
# functools.singledispatch.__code__.co_argcount == 1
#
# total_ordering(cls) is a class decorator that fills in missing comparison
# methods given __eq__ and one of __lt__/__le__/__gt__/__ge__.
# singledispatch(func) transforms a function into a single-dispatch generic
# function that dispatches on the type of its first argument.
# New to extra161.
# ---------------------------------------------------------------------------

table functools_extra161.total_ordering_and_singledispatch_code_attrs:
  description: "functools.total_ordering: co_name 'total_ordering', co_argcount 1; functools.singledispatch: co_name 'singledispatch', co_argcount 1; wave 285; new to extra161"
  kind: python_call_eq
  category: identity
  id_prefix: functoolstosdc161

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_co_name_eq,
       "total_ordering.__code__.co_name.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__code__.co_name.__eq__('total_ordering') == True — total_ordering is a class decorator in Lib/functools.py that fills in missing comparison methods; its code object co_name is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra161"]
    - [total_ordering_co_argcount_eq_1,
       "total_ordering.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.total_ordering.__code__.co_argcount.__eq__(1) == True — total_ordering(cls) takes exactly 1 argument (the class to decorate); co_argcount is 1; int.__eq__(1) returns True; new to extra161"]
    - [singledispatch_co_name_eq,
       "singledispatch.__code__.co_name.__eq__",
       ["singledispatch"],
       true,
       "functools.singledispatch.__code__.co_name.__eq__('singledispatch') == True — singledispatch is a decorator in Lib/functools.py implementing single-dispatch generic functions that dispatch on the type of the first argument; its code object co_name is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra161"]
    - [singledispatch_co_argcount_eq_1,
       "singledispatch.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.singledispatch.__code__.co_argcount.__eq__(1) == True — singledispatch(func) takes exactly 1 argument (the function to transform into a generic function); co_argcount is 1; int.__eq__(1) returns True; new to extra161"]

