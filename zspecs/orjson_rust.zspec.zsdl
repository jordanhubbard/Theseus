spec: orjson_rust
version: ">=3.9"
backend: rust_module(orjson_rust)

docs: https://github.com/ijl/orjson

provenance:
  derived_from:
    - "https://github.com/ijl/orjson — orjson documentation"
  not_derived_from:
    - "orjson source: src/lib.rs"
  notes:
    - "orjson is a fast JSON library for Python."
    - "orjson.dumps({'key': 'value'}) == b'{\"key\":\"value\"}'."
    - "orjson.dumps([1, 2, 3]) == b'[1,2,3]'."
    - "orjson.loads(b'{\"key\":\"value\"}') == {'key': 'value'}."
    - "orjson.loads('[1,2,3]') == [1, 2, 3]."
    - "Expose orjson_dumps_str(obj) -> str: orjson.dumps(obj).decode()."
    - "Expose orjson_loads(s) -> any: orjson.loads(s)."
    - "All test vectors verified against orjson 3.10.16."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# orjson_dumps_str — serialize to JSON string
table orjson_rust.serialize.dumps:
  kind: python_call_eq
  category: dumps
  id_prefix: orj_d
  function: orjson_dumps_str

  columns: [id, args, expected]
  rows:
    - [dict,  [{"key": "value"}], "{\"key\":\"value\"}"]
    - [list,  [[1, 2, 3]],        "[1,2,3]"]
    - [int,   [42],               "42"]

# orjson_loads — deserialize from JSON
table orjson_rust.deserialize.loads:
  kind: python_call_eq
  category: loads
  id_prefix: orj_l
  function: orjson_loads

  columns: [id, args, expected]
  rows:
    - [list,  ["[1,2,3]"],  [1, 2, 3]]
    - [int,   ["42"],       42]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:35:08Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
