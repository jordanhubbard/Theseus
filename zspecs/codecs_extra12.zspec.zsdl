spec: codecs_extra12
version: ">=3.9"
backend: python_module(codecs)

docs: https://docs.python.org/3/library/codecs.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/codecs.html — Python codecs documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/codecs.py"
    - "codecs_extra11.zspec.zsdl — covers lookup utf-16-le/be/utf-32-le/be/cp1252; encode/decode latin-1; open/__name__; lookup/__name__; CodecInfo.__module__."
    - "codecs_extra10.zspec.zsdl — covers encode/decode hello utf-8/ascii; encode/decode non-ASCII U+00E9; lookup utf-8/ascii/latin-1/utf-32 name; CodecInfo.__name__; encode/decode __name__."
    - "codecs_extra9.zspec.zsdl — covers ROT-13 encode/decode; lookup utf-8/utf-16/cp437 name; BOM class names; StreamReader/StreamWriter __module__; CodecInfo base is tuple."
    - "codecs_extra8.zspec.zsdl — covers class_names table (cn8 prefix); C-extension function __module__ == '_codecs'; Codec/IncrementalEncoder/IncrementalDecoder __module__."
    - "codecs_extra7.zspec.zsdl — covers IncrementalEncoder/IncrementalDecoder/StreamReaderWriter/StreamRecoder base is object; BOM LE/BE variant lengths; lookup ascii/latin-1 canonical names; decode utf-8 world and ascii hello."
    - "codecs_extra4.zspec.zsdl — covers function __name__ table; encode/decode type checks; lookup codec_info_class; lookup utf-8/ascii name; CodecInfo/__name__/__module__."
    - "codecs_extra3.zspec.zsdl — covers __qualname__ for encode/decode/open/lookup/register; BOM lengths; lookup utf-32/utf-8-sig; encode ascii."
    - "codecs_extra2.zspec.zsdl — covers class __name__ for CodecInfo/BufferedIncrementalDecoder/StreamReader/StreamWriter; function __name__ for lookup/encode/decode/open; encode returns bytes; decode utf-8 hello."
  notes:
    - "This spec extends codecs through codecs_extra11; it does NOT duplicate invariants present in those files."
    - "Focus: BOM byte values, BOM lengths, and C-level function __name__ attributes."
    - "codecs.BOM_UTF8 == b'\\xef\\xbb\\xbf' — BOM_UTF8 byte value; prior specs check BOM lengths but not the raw byte values."
    - "codecs.BOM_UTF16_LE == b'\\xff\\xfe' — BOM_UTF16_LE byte value; extra7 covers BOM_UTF16_LE length but not the value."
    - "codecs.BOM_UTF16_BE == b'\\xfe\\xff' — BOM_UTF16_BE byte value; extra7 covers BOM_UTF16_BE length but not the value."
    - "codecs.BOM_UTF32_LE == b'\\xff\\xfe\\x00\\x00' — BOM_UTF32_LE byte value; no prior spec checks this value."
    - "codecs.BOM_UTF32_BE == b'\\x00\\x00\\xfe\\xff' — BOM_UTF32_BE byte value; no prior spec checks this value."
    - "codecs.BOM_UTF8.__len__() == 3 — BOM_UTF8 length 3; extra3 covers this but re-anchored in extra12 namespace."
    - "codecs.BOM_UTF16_LE.__len__() == 2 — BOM_UTF16_LE length 2; extra7 covers this but re-anchored in extra12 namespace."
    - "codecs.charmap_encode.__name__ == 'charmap_encode' — C-level codec function name; no prior spec covers charmap_encode.__name__."
    - "codecs.charmap_decode.__name__ == 'charmap_decode' — C-level codec function name; no prior spec covers charmap_decode.__name__."
    - "codecs.ascii_encode.__name__ == 'ascii_encode' — C-level codec function name; no prior spec covers ascii_encode.__name__."
    - "codecs.utf_8_encode.__name__ == 'utf_8_encode' — C-level codec function name; no prior spec covers utf_8_encode.__name__."
    - "codecs.strict_errors.__name__ == 'strict_errors' — error handler function name; no prior spec covers strict_errors.__name__."
    - "codecs.ignore_errors.__name__ == 'ignore_errors' — error handler function name; no prior spec covers ignore_errors.__name__."
    - "codecs.replace_errors.__name__ == 'replace_errors' — error handler function name; no prior spec covers replace_errors.__name__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BOM byte values — raw bytes comparison
#
# Prior specs (extra3, extra7) test BOM lengths. This table tests the actual
# byte content of each BOM constant using __eq__ on the bytes object.
# ---------------------------------------------------------------------------

table codecs_extra12.bom_values:
  kind: python_call_eq
  category: bom
  id_prefix: bom12

  columns: [id, function, args, expected]
  rows:
    - [utf8,      BOM_UTF8.__eq__,      [!hex efbbbf],   true]
    - [utf16_le,  BOM_UTF16_LE.__eq__,  [!hex fffe],     true]
    - [utf16_be,  BOM_UTF16_BE.__eq__,  [!hex feff],     true]
    - [utf32_le,  BOM_UTF32_LE.__eq__,  [!hex fffe0000], true]
    - [utf32_be,  BOM_UTF32_BE.__eq__,  [!hex 0000feff], true]

# ---------------------------------------------------------------------------
# BOM lengths — byte count for each BOM constant
#
# extra3 covers BOM_UTF8 length; extra7 covers BOM_UTF16_LE/BE lengths.
# All five BOM constants re-anchored together in the extra12 namespace.
# ---------------------------------------------------------------------------

table codecs_extra12.bom_lengths:
  kind: python_call_eq
  category: bom
  id_prefix: bomlen12

  columns: [id, function, args, expected]
  rows:
    - [utf8,      BOM_UTF8.__len__,      [], 3]
    - [utf16_le,  BOM_UTF16_LE.__len__,  [], 2]
    - [utf16_be,  BOM_UTF16_BE.__len__,  [], 2]
    - [utf32_le,  BOM_UTF32_LE.__len__,  [], 4]
    - [utf32_be,  BOM_UTF32_BE.__len__,  [], 4]

# ---------------------------------------------------------------------------
# C-level codec function __name__ attributes
#
# These low-level functions are accessible directly from the codecs module.
# No prior spec checks __name__ for charmap_encode, charmap_decode,
# ascii_encode, utf_8_encode, strict_errors, ignore_errors, or replace_errors.
# ---------------------------------------------------------------------------

table codecs_extra12.codec_func_names:
  kind: python_call_eq
  category: func_attrs
  id_prefix: cfn12

  columns: [id, function, args, expected]
  rows:
    - [charmap_encode,   charmap_encode.__name__.__eq__,   ["charmap_encode"],   true]
    - [charmap_decode,   charmap_decode.__name__.__eq__,   ["charmap_decode"],   true]
    - [ascii_encode,     ascii_encode.__name__.__eq__,     ["ascii_encode"],     true]
    - [utf_8_encode,     utf_8_encode.__name__.__eq__,     ["utf_8_encode"],     true]
    - [strict_errors,    strict_errors.__name__.__eq__,    ["strict_errors"],    true]
    - [ignore_errors,    ignore_errors.__name__.__eq__,    ["ignore_errors"],    true]
    - [replace_errors,   replace_errors.__name__.__eq__,   ["replace_errors"],   true]

