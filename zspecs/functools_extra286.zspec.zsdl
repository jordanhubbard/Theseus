spec: functools_extra286
version: ">=3.2"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.lru_cache returns a _lru_cache_wrapper; its .cache_info and .cache_clear are builtin_function_or_method instances."
    - "cache_info.__qualname__ == '_lru_cache_wrapper.cache_info' (29 chars) — encodes the owning C type."
    - "cache_clear.__qualname__ == '_lru_cache_wrapper.cache_clear' (30 chars) — encodes the owning C type."
    - "functools.wraps is a pure-Python function: __module__ == 'functools', __class__.__name__ == 'function'."
    - "wraps.__name__ == 'wraps' (5 chars); __qualname__ == 'wraps' (top-level)."
    - "functools.wraps.__doc__ is not None — wraps ships with a docstring."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools._lru_cache_wrapper — cache_info and cache_clear method qualnames
#
# lru_cache(f).cache_info.__qualname__ == '_lru_cache_wrapper.cache_info'
# lru_cache(f).cache_clear.__qualname__ == '_lru_cache_wrapper.cache_clear'
# Both methods are builtin_function_or_method (C-level).
# ---------------------------------------------------------------------------

table functools_extra286.lru_cache_method_qualnames:
  description: "functools._lru_cache_wrapper cache_info and cache_clear method qualnames and class names; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex286lm

  columns: [id, function, args, expected, description]
  rows:
    - [lm_ci_qn,   "lru_cache(lambda x: x).cache_info.__qualname__.__eq__",    ["_lru_cache_wrapper.cache_info"],  true, "cache_info.__qualname__ == '_lru_cache_wrapper.cache_info'; verified with Python 3.14.3"]
    - [lm_ci_qlen, "lru_cache(lambda x: x).cache_info.__qualname__.__len__",   [],                                  29,  "cache_info.__qualname__.__len__() == 29 — '_lru_cache_wrapper.cache_info' has 29 chars; verified with Python 3.14.3"]
    - [lm_ci_cls,  "lru_cache(lambda x: x).cache_info.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "cache_info.__class__.__name__ == 'builtin_function_or_method' (C-level method); verified with Python 3.14.3"]
    - [lm_cc_qn,   "lru_cache(lambda x: x).cache_clear.__qualname__.__eq__",   ["_lru_cache_wrapper.cache_clear"], true, "cache_clear.__qualname__ == '_lru_cache_wrapper.cache_clear'; verified with Python 3.14.3"]
    - [lm_cc_qlen, "lru_cache(lambda x: x).cache_clear.__qualname__.__len__",  [],                                  30,  "cache_clear.__qualname__.__len__() == 30 — '_lru_cache_wrapper.cache_clear' has 30 chars; verified with Python 3.14.3"]
    - [lm_cc_cls,  "lru_cache(lambda x: x).cache_clear.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "cache_clear.__class__.__name__ == 'builtin_function_or_method' (C-level method); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools.wraps — identity as a pure-Python function
#
# wraps is a pure-Python function: __module__ == 'functools', __class__.__name__ == 'function'.
# __name__ == 'wraps' (5 chars); __qualname__ == 'wraps' (top-level).
# wraps.__doc__ is not None.
# ---------------------------------------------------------------------------

table functools_extra286.wraps_identity:
  description: "functools.wraps identity — __name__, __module__, __qualname__, __class__.__name__, doc presence; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex286wi

  columns: [id, function, args, expected, description]
  rows:
    - [wi_name_eq,  wraps.__name__.__eq__,             ["wraps"],     true, "functools.wraps.__name__ == 'wraps'; verified with Python 3.14.3"]
    - [wi_name_len, wraps.__name__.__len__,              [],           5,    "functools.wraps.__name__.__len__() == 5 — 'wraps' has 5 chars; verified with Python 3.14.3"]
    - [wi_mod_eq,   wraps.__module__.__eq__,             ["functools"], true, "functools.wraps.__module__ == 'functools'; verified with Python 3.14.3"]
    - [wi_qn_eq,    wraps.__qualname__.__eq__,           ["wraps"],    true, "functools.wraps.__qualname__ == 'wraps' (top-level function); verified with Python 3.14.3"]
    - [wi_cls_eq,   wraps.__class__.__name__.__eq__,     ["function"], true, "functools.wraps.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [wi_doc_none, wraps.__doc__.__eq__,                [null],       false, "functools.wraps.__doc__ is not None — wraps ships with a docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra286
# ---------------------------------------------------------------------------

invariant functools_extra286.cache_info_qualname:
  description: "functools.lru_cache(f).cache_info.__qualname__ == '_lru_cache_wrapper.cache_info' — encodes the owning C type"
  category: identity
  kind: python_call_eq
  function: "lru_cache(lambda x: x).cache_info.__qualname__.__eq__"
  args: ["_lru_cache_wrapper.cache_info"]
  expected: true

invariant functools_extra286.cache_clear_qualname:
  description: "functools.lru_cache(f).cache_clear.__qualname__ == '_lru_cache_wrapper.cache_clear' — encodes the owning C type"
  category: identity
  kind: python_call_eq
  function: "lru_cache(lambda x: x).cache_clear.__qualname__.__eq__"
  args: ["_lru_cache_wrapper.cache_clear"]
  expected: true

invariant functools_extra286.cache_info_qualname_length_is_29:
  description: "functools.lru_cache(f).cache_info.__qualname__.__len__() == 29 — '_lru_cache_wrapper.cache_info' has 29 characters"
  category: identity
  kind: python_call_eq
  function: "lru_cache(lambda x: x).cache_info.__qualname__.__len__"
  args: []
  expected: 29

invariant functools_extra286.cache_clear_qualname_length_is_30:
  description: "functools.lru_cache(f).cache_clear.__qualname__.__len__() == 30 — '_lru_cache_wrapper.cache_clear' has 30 characters"
  category: identity
  kind: python_call_eq
  function: "lru_cache(lambda x: x).cache_clear.__qualname__.__len__"
  args: []
  expected: 30

invariant functools_extra286.cache_info_is_builtin_method:
  description: "functools.lru_cache(f).cache_info.__class__.__name__ == 'builtin_function_or_method' — cache_info is a C-level method"
  category: identity
  kind: python_call_eq
  function: "lru_cache(lambda x: x).cache_info.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra286.wraps_module_is_functools:
  description: "functools.wraps.__module__ == 'functools' — wraps is defined in the functools module"
  category: identity
  kind: python_call_eq
  function: wraps.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra286.wraps_is_function:
  description: "functools.wraps.__class__.__name__ == 'function' — wraps is a pure-Python function, not a C builtin"
  category: identity
  kind: python_call_eq
  function: wraps.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra286.wraps_name_length_is_5:
  description: "functools.wraps.__name__.__len__() == 5 — 'wraps' has 5 characters"
  category: identity
  kind: python_call_eq
  function: wraps.__name__.__len__
  args: []
  expected: 5

invariant functools_extra286.wraps_has_docstring:
  description: "functools.wraps.__doc__.__eq__(None) == False — wraps ships with a non-None docstring"
  category: identity
  kind: python_call_eq
  function: wraps.__doc__.__eq__
  args: [null]
  expected: false
