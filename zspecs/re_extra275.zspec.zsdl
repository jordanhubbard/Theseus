spec: re_extra275
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.Match.__name__ == 'Match' and __module__ == 're' — the Match class is exposed in the re namespace."
    - "re.Match.__bases__[0].__name__ == 'object' — Match inherits directly from object."
    - "re.Match.__class__.__name__ == 'type' — Match is a plain type."
    - "re.Pattern.__name__ == 'Pattern' and __module__ == 're' — the Pattern class is also exposed in the re namespace."
    - "re.Pattern.__bases__[0].__name__ == 'object' — Pattern also inherits directly from object."
    - "re.compile(r'test') returns an instance whose type().__name__ == 'Pattern'."
    - "re.error is re.PatternError — the two names refer to the same class (re.error is the legacy alias)."
    - "re.error.__name__ == 'PatternError' — in Python 3.13+ re.error was renamed PatternError."
    - "re.error.__module__ == 're' and __bases__[0].__name__ == 'Exception'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: re.Match and re.Pattern class identity
# ---------------------------------------------------------------------------

table re_extra275.match_pattern_class_identity:
  description: "re.Match and re.Pattern __name__, __module__, __bases__[0].__name__, and __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: mpi

  columns: [id, function, args, expected, description]
  rows:
    - [match_name,    Match.__name__.__eq__,                    ["Match"],    true, "re.Match.__name__ == 'Match'"]
    - [match_module,  Match.__module__.__eq__,                  ["re"],       true, "re.Match.__module__ == 're'"]
    - [match_base,    "Match.__bases__[0].__name__.__eq__",     ["object"],   true, "re.Match.__bases__[0].__name__ == 'object'"]
    - [match_meta,    Match.__class__.__name__.__eq__,          ["type"],     true, "re.Match.__class__.__name__ == 'type'"]
    - [pat_name,      Pattern.__name__.__eq__,                  ["Pattern"],  true, "re.Pattern.__name__ == 'Pattern'"]
    - [pat_module,    Pattern.__module__.__eq__,                ["re"],       true, "re.Pattern.__module__ == 're'"]
    - [pat_base,      "Pattern.__bases__[0].__name__.__eq__",   ["object"],   true, "re.Pattern.__bases__[0].__name__ == 'object'"]
    - [pat_meta,      Pattern.__class__.__name__.__eq__,        ["type"],     true, "re.Pattern.__class__.__name__ == 'type'"]

# ---------------------------------------------------------------------------
# Table: re.error (PatternError) class identity
# ---------------------------------------------------------------------------

table re_extra275.error_class_identity:
  description: "re.error (PatternError) __name__, __module__, and __bases__[0].__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: eci

  columns: [id, function, args, expected, description]
  rows:
    - [err_name,    error.__name__.__eq__,                  ["PatternError"], true, "re.error.__name__ == 'PatternError' — renamed in Python 3.13"]
    - [err_module,  error.__module__.__eq__,                ["re"],           true, "re.error.__module__ == 're'"]
    - [err_base,    "error.__bases__[0].__name__.__eq__",   ["Exception"],    true, "re.error.__bases__[0].__name__ == 'Exception'"]
    - [err_meta,    error.__class__.__name__.__eq__,        ["type"],         true, "re.error.__class__.__name__ == 'type'"]

# ---------------------------------------------------------------------------
# Standalone invariants: re.compile return type and PatternError alias
# ---------------------------------------------------------------------------

invariant re_extra275.compile_is_function:
  description: "re.compile.__class__.__name__ == 'function' — re.compile is a pure Python function"
  category: identity
  kind: python_call_eq
  function: compile.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant re_extra275.Match.name:
  description: "re.Match.__name__ == 'Match'"
  category: identity
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra275.Match.module:
  description: "re.Match.__module__ == 're'"
  category: identity
  kind: python_call_eq
  function: Match.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra275.Pattern.name:
  description: "re.Pattern.__name__ == 'Pattern'"
  category: identity
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra275.Pattern.module:
  description: "re.Pattern.__module__ == 're'"
  category: identity
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra275.error.name_is_PatternError:
  description: "re.error.__name__ == 'PatternError' — re.error is the legacy alias for re.PatternError"
  category: identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra275.error.module:
  description: "re.error.__module__ == 're'"
  category: identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra275.error.base_is_Exception:
  description: "re.error.__bases__[0].__name__ == 'Exception'"
  category: identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true
