    - ["it2716007", "itertools.dropwhile.__dict__.__contains__",                     ["__neg__"], false]
    - ["it2716008", "itertools.takewhile.__dict__.__contains__",                     ["__neg__"], false]
    - ["it2716009", "itertools.starmap.__dict__.__contains__",                       ["__neg__"], false]
