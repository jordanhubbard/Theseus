spec: itertools_extra2716
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 628 theme: __neg__, __pos__, and __abs__ dict-presence checks (unary minus, unary plus, absolute value)."
    - "All itertools iterator classes (chain, count, repeat, cycle, islice, compress, dropwhile, takewhile, starmap, groupby, filterfalse, accumulate, zip_longest, pairwise, product, permutations, combinations, combinations_with_replacement) are lazy iterators."
    - "Lazy iterators do not support unary arithmetic protocols such as __neg__, __pos__, or __abs__."
    - "itertools.repeat does have a __len__ for finite repeats, but still defines none of __neg__, __pos__, __abs__."
    - "None of the itertools classes define __neg__, __pos__, or __abs__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __neg__ dict-presence — absent from all itertools classes
# ---------------------------------------------------------------------------

table itertools_extra2716.neg_protocol:
  description: "__neg__ is absent from all itertools iterator class __dict__s — lazy iterators do not support unary minus"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2716

  columns: [id, function, args, expected]
  rows:
    - ["it2716001", "itertools.chain.__dict__.__contains__",                         ["__neg__"], false]
    - ["it2716002", "itertools.count.__dict__.__contains__",                         ["__neg__"], false]
    - ["it2716003", "itertools.repeat.__dict__.__contains__",                        ["__neg__"], false]
