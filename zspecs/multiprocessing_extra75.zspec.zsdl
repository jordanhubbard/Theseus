spec: multiprocessing_extra75
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Process — Python multiprocessing Process documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing_extra74.zspec.zsdl."
    - "This spec covers: wave 243 theme — multiprocessing Process MRO entries + cpu_count/current_process/active_children code. NEW in extra75: Process.__mro__[0].__name__=='Process'; Process.__mro__[1].__name__=='BaseProcess'; Process.__mro__[2].__name__=='object'; cpu_count.__class__.__name__=='method'; current_process.__class__.__name__=='function'; active_children.__class__.__name__=='function'; current_process.__code__.co_name=='current_process'; active_children.__code__.co_name=='active_children'; current_process.__module__=='multiprocessing.process'."
    - "multiprocessing.Process.__mro__[0].__name__ == 'Process'. First MRO entry is always the class itself. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__mro__[1].__name__ == 'BaseProcess'. Second MRO entry is the immediate base class BaseProcess (internal implementation class in multiprocessing/process.py). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__mro__[2].__name__ == 'object'. Third MRO entry is object (root of all Python classes). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.cpu_count.__class__.__name__ == 'method'. cpu_count is a bound method on the default context object; its class is 'method'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.current_process.__class__.__name__ == 'function'. current_process is a plain Python function in multiprocessing/process.py; its class is 'function'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.active_children.__class__.__name__ == 'function'. active_children is a plain Python function in multiprocessing/process.py; its class is 'function'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.current_process.__code__.co_name == 'current_process'. current_process is a Python function; co_name is 'current_process'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.active_children.__code__.co_name == 'active_children'. active_children is a Python function; co_name is 'active_children'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.current_process.__module__ == 'multiprocessing.process'. current_process is defined in Lib/multiprocessing/process.py; __module__ is 'multiprocessing.process'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Process MRO name checks — extra75
#
# Wave 243 theme: Process MRO entries + cpu_count/current_process/active_children code.
#
# Process.__mro__[0].__name__ == 'Process'
# Process.__mro__[1].__name__ == 'BaseProcess'
# Process.__mro__[2].__name__ == 'object'
# ---------------------------------------------------------------------------

table multiprocessing_extra75.Process_mro_names:
  description: "multiprocessing Process MRO name checks in mpmore75 namespace — wave 243 theme: Process MRO entries; Process.__mro__[0].__name__=='Process' (first MRO entry is the class itself); Process.__mro__[1].__name__=='BaseProcess' (immediate base class; internal implementation class in multiprocessing/process.py); Process.__mro__[2].__name__=='object' (root class); NEW in extra75: MRO name checks in mpmore75 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: mro
  id_prefix: mpmore75

  columns: [id, function, args, expected, description]
  rows:
    - [process_mro0_name, "Process.__mro__[0].__name__.__eq__", ["Process"],     true, "Process.__mro__[0].__name__ == 'Process' — first MRO entry is always the class itself; verified with Python 3.14.3"]
    - [process_mro1_name, "Process.__mro__[1].__name__.__eq__", ["BaseProcess"], true, "Process.__mro__[1].__name__ == 'BaseProcess' — second MRO entry is the immediate base class BaseProcess (internal implementation class); verified with Python 3.14.3"]
    - [process_mro2_name, "Process.__mro__[2].__name__.__eq__", ["object"],      true, "Process.__mro__[2].__name__ == 'object' — third MRO entry is object, the root of all Python classes; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing cpu_count/current_process/active_children class checks — extra75
#
# cpu_count.__class__.__name__ == 'method'
# current_process.__class__.__name__ == 'function'
# active_children.__class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table multiprocessing_extra75.function_class_names:
  description: "multiprocessing cpu_count/current_process/active_children class name checks in mpmore75 namespace — wave 243 theme: function type identity; cpu_count.__class__.__name__=='method' (cpu_count is a bound method on the default context); current_process.__class__.__name__=='function' (plain Python function in multiprocessing/process.py); active_children.__class__.__name__=='function' (plain Python function); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmore75a

  columns: [id, function, args, expected, description]
  rows:
    - [cpu_count_class_name,       cpu_count.__class__.__name__.__eq__,       ["method"],   true, "cpu_count.__class__.__name__ == 'method' — cpu_count is a bound method on the default context object; verified with Python 3.14.3"]
    - [current_process_class_name, current_process.__class__.__name__.__eq__, ["function"], true, "current_process.__class__.__name__ == 'function' — current_process is a plain Python function in multiprocessing/process.py; verified with Python 3.14.3"]
    - [active_children_class_name, active_children.__class__.__name__.__eq__, ["function"], true, "active_children.__class__.__name__ == 'function' — active_children is a plain Python function in multiprocessing/process.py; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing current_process and active_children code name checks — extra75
#
# current_process.__code__.co_name == 'current_process'
# active_children.__code__.co_name == 'active_children'
# current_process.__module__ == 'multiprocessing.process'
# ---------------------------------------------------------------------------

table multiprocessing_extra75.function_co_names_and_module:
  description: "multiprocessing current_process and active_children co_name and module checks in mpmore75 namespace — wave 243 theme: function code name and module; current_process.__code__.co_name=='current_process' (Python function; co_name matches the function name); active_children.__code__.co_name=='active_children'; current_process.__module__=='multiprocessing.process' (defined in Lib/multiprocessing/process.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpmore75b

  columns: [id, function, args, expected, description]
  rows:
    - [current_process_co_name, current_process.__code__.co_name.__eq__,  ["current_process"],          true, "current_process.__code__.co_name == 'current_process' — Python function; co_name stores the function name; verified with Python 3.14.3"]
    - [active_children_co_name, active_children.__code__.co_name.__eq__,  ["active_children"],          true, "active_children.__code__.co_name == 'active_children' — Python function; co_name stores the function name; verified with Python 3.14.3"]
    - [current_process_module,  current_process.__module__.__eq__,        ["multiprocessing.process"],  true, "current_process.__module__ == 'multiprocessing.process' — defined in Lib/multiprocessing/process.py; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process MRO + function class cross-check — extra75
# ---------------------------------------------------------------------------

table multiprocessing_extra75.Process_mro_and_function_cross_check:
  description: "multiprocessing Process MRO and function class name cross-check in mpmore75 namespace — wave 243 theme: Process MRO + function identity cross-check; Process.__mro__[1].__name__=='BaseProcess'; cpu_count.__class__.__name__=='method'; current_process.__class__.__name__=='function'; active_children.__code__.co_name=='active_children'; verified with Python 3.14.3"
  kind: python_call_eq
  category: mro
  id_prefix: mpmore75c

  columns: [id, function, args, expected, description]
  rows:
    - [process_mro1_check,         "Process.__mro__[1].__name__.__eq__",   ["BaseProcess"], true, "Process.__mro__[1].__name__ == 'BaseProcess' — cross-check; verified with Python 3.14.3"]
    - [cpu_count_method_check,     cpu_count.__class__.__name__.__eq__,    ["method"],      true, "cpu_count.__class__.__name__ == 'method' — cross-check; verified with Python 3.14.3"]
    - [current_process_func_check, current_process.__class__.__name__.__eq__, ["function"], true, "current_process.__class__.__name__ == 'function' — cross-check; verified with Python 3.14.3"]
    - [active_children_co_check,   active_children.__code__.co_name.__eq__, ["active_children"], true, "active_children.__code__.co_name == 'active_children' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra75
# ---------------------------------------------------------------------------

invariant multiprocessing_extra75.Process_mro0_name:
  description: "multiprocessing.Process.__mro__[0].__name__.__eq__('Process') returns True — first MRO entry is always the class itself; Process.__mro__[0].__name__ is 'Process'; NEW in extra75: first standalone __mro__[0].__name__ invariant for Process in mpmore75 namespace; wave 243; verified with Python 3.14.3"
  category: mro
  kind: python_call_eq
  function: "Process.__mro__[0].__name__.__eq__"
  args: ["Process"]
  expected: true

invariant multiprocessing_extra75.Process_mro2_object:
  description: "multiprocessing.Process.__mro__[2].__name__.__eq__('object') returns True — third MRO entry is object, the root of all Python classes; Process.__mro__[2].__name__ is 'object'; NEW in extra75: first standalone __mro__[2].__name__ invariant for Process in mpmore75 namespace; wave 243; verified with Python 3.14.3"
  category: mro
  kind: python_call_eq
  function: "Process.__mro__[2].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra75.cpu_count_class_method:
  description: "multiprocessing.cpu_count.__class__.__name__.__eq__('method') returns True — cpu_count is a bound method on the default context object; its __class__.__name__ is 'method'; NEW in extra75: first standalone __class__.__name__=='method' invariant for cpu_count in mpmore75 namespace; wave 243; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: cpu_count.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra75.current_process_co_name:
  description: "multiprocessing.current_process.__code__.co_name.__eq__('current_process') returns True — current_process is a plain Python function in multiprocessing/process.py; co_name is 'current_process'; NEW in extra75: first standalone co_name invariant for current_process in mpmore75 namespace; wave 243; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: current_process.__code__.co_name.__eq__
  args: ["current_process"]
  expected: true

invariant multiprocessing_extra75.current_process_module:
  description: "multiprocessing.current_process.__module__.__eq__('multiprocessing.process') returns True — current_process is defined in Lib/multiprocessing/process.py; __module__ is 'multiprocessing.process'; NEW in extra75: first standalone __module__ invariant for current_process in mpmore75 namespace; wave 243; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: current_process.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true
