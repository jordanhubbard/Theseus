spec: abc_extra2116
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "abc_extra.zspec.zsdl — covers IntEnum module/base, EnumMeta alias, Enum/IntEnum/Flag bases, auto instance, StrEnum module/base, unique type"
    - "abc_extra2056.zspec.zsdl — covers __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__, __contains__, __iter__/__next__/__reversed__ dict-presence checks"
    - "abc_extra503.zspec.zsdl"
  notes:
    - "Wave (_extra2116): __or__/__ror__/__ior__, __and__/__rand__/__iand__, __xor__/__rxor__/__ixor__ dict-presence checks."
    - "These are the set/dict merge operators (|, &, ^) and their reflected/in-place variants."
    - "ABCMeta is a metaclass; ABC is a helper base class; abstractmethod is a plain function decorator."
    - "None of ABCMeta, ABC, or abstractmethod define set/dict algebra operators in their own __dict__."
    - "ABCMeta defines __instancecheck__ and __subclasscheck__ but not any of the set/dict merge operators."
    - "abstractmethod is a simple class whose __dict__ contains only its own descriptor machinery."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra2116.or_operator:
  description: "abc.ABCMeta, abc.ABC, abc.abstractmethod __or__/__ror__/__ior__ dict-presence checks (dict-merge / set-union operators)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2116

  columns: [id, function, args, expected]
  rows:
    - ["ab2116001", "abc.ABCMeta.__dict__.__contains__", ["__or__"], false]
    - ["ab2116002", "abc.ABCMeta.__dict__.__contains__", ["__ror__"], false]
    - ["ab2116003", "abc.ABCMeta.__dict__.__contains__", ["__ior__"], false]
    - ["ab2116004", "abc.ABC.__dict__.__contains__", ["__or__"], false]
    - ["ab2116005", "abc.ABC.__dict__.__contains__", ["__ror__"], false]
    - ["ab2116006", "abc.ABC.__dict__.__contains__", ["__ior__"], false]
    - ["ab2116007", "abc.abstractmethod.__dict__.__contains__", ["__or__"], false]
    - ["ab2116008", "abc.abstractmethod.__dict__.__contains__", ["__ror__"], false]
    - ["ab2116009", "abc.abstractmethod.__dict__.__contains__", ["__ior__"], false]

