spec: operator_extra24
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator_extra23.zspec.zsdl."
    - "operator_extra23 covers: combined __qualname__ table for arithmetic functions (add/sub/mul/truediv/floordiv/mod) and combined table for callable classes (attrgetter/itemgetter/methodcaller)."
    - "operator_extra22 covers: __qualname__.__eq__ for comparison functions (lt/gt/eq/ne/le/ge)."
    - "operator_extra21 covers: __bases__[0].__name__ for attrgetter/itemgetter/methodcaller; qualname and __module__ standalone invariants for same three."
    - "No prior operator spec records __qualname__.__eq__ for attrgetter.__call__, itemgetter.__call__, methodcaller.__call__ together in the extra24 namespace."
    - "No prior operator spec records __qualname__.__eq__ for not_/truth/is_/is_not/contains together in the extra24 namespace."
    - "Focus: method-level qualnames for the three callable classes (__call__ slots) and function qualnames for logical/membership operators."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — __call__ slot qualnames for callable classes
#
# operator.attrgetter, itemgetter, and methodcaller are C-level types.
# Their __call__ slot wrappers have nested qualnames of the form
# '<class>.__call__'. operator_extra23 covers the class-level qualnames;
# this table extends coverage to the __call__ method level.
# No prior operator spec records these __call__ qualnames in the extra24 namespace.
# ---------------------------------------------------------------------------

table operator_extra24.callable_class_call_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra24.callable_class_call_qualnames.attrgetter,
       "attrgetter.__call__.__qualname__.__eq__",
       ["attrgetter.__call__"],
       true,
       "operator.attrgetter.__call__.__qualname__ == 'attrgetter.__call__'"]
    - [operator_extra24.callable_class_call_qualnames.itemgetter,
       "itemgetter.__call__.__qualname__.__eq__",
       ["itemgetter.__call__"],
       true,
       "operator.itemgetter.__call__.__qualname__ == 'itemgetter.__call__'"]
    - [operator_extra24.callable_class_call_qualnames.methodcaller,
       "methodcaller.__call__.__qualname__.__eq__",
       ["methodcaller.__call__"],
       true,
       "operator.methodcaller.__call__.__qualname__ == 'methodcaller.__call__'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — logical and membership operator functions
#
# operator.not_, truth, is_, is_not, and contains are C-level functions in
# _operator. Each has a simple qualname equal to its attribute name.
# operator_extra22 covers comparison functions; no prior spec covers these
# five logical/membership functions together in the extra24 namespace.
# ---------------------------------------------------------------------------

table operator_extra24.logical_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra24.logical_qualnames.not_,
       not_.__qualname__.__eq__,
       ["not_"],
       true,
       "operator.not_.__qualname__ == 'not_'"]
    - [operator_extra24.logical_qualnames.truth,
       truth.__qualname__.__eq__,
       ["truth"],
       true,
       "operator.truth.__qualname__ == 'truth'"]
    - [operator_extra24.logical_qualnames.is_,
       is_.__qualname__.__eq__,
       ["is_"],
       true,
       "operator.is_.__qualname__ == 'is_'"]
    - [operator_extra24.logical_qualnames.is_not,
       is_not.__qualname__.__eq__,
       ["is_not"],
       true,
       "operator.is_not.__qualname__ == 'is_not'"]
    - [operator_extra24.logical_qualnames.contains,
       contains.__qualname__.__eq__,
       ["contains"],
       true,
       "operator.contains.__qualname__ == 'contains'"]

# ---------------------------------------------------------------------------
# attrgetter.__call__.__qualname__.__eq__ — standalone method qualname
#
# operator.attrgetter is a C-level type. Its __call__ slot has a nested
# qualname 'attrgetter.__call__' confirming its scope within the type.
# No prior operator spec records this standalone in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra24.attrgetter.call.qualname:
  description: "operator.attrgetter.__call__.__qualname__ == 'attrgetter.__call__'"
  category: qualnames
  kind: python_call_eq
  function: "attrgetter.__call__.__qualname__.__eq__"
  args: ["attrgetter.__call__"]
  expected: true

# ---------------------------------------------------------------------------
# not_.__qualname__.__eq__ — standalone function qualname
#
# operator.not_ is a C-level function in _operator. Its qualname is 'not_',
# a simple name with no enclosing class scope.
# No prior operator spec records this standalone in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra24.not_.qualname:
  description: "operator.not_.__qualname__ == 'not_'"
  category: qualnames
  kind: python_call_eq
  function: not_.__qualname__.__eq__
  args: ["not_"]
  expected: true

# ---------------------------------------------------------------------------
# is_.__qualname__.__eq__ — standalone function qualname
#
# operator.is_ is a C-level function in _operator. Its qualname is 'is_'.
# No prior operator spec records this standalone in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra24.is_.qualname:
  description: "operator.is_.__qualname__ == 'is_'"
  category: qualnames
  kind: python_call_eq
  function: is_.__qualname__.__eq__
  args: ["is_"]
  expected: true

# ---------------------------------------------------------------------------
# contains.__qualname__.__eq__ — standalone function qualname
#
# operator.contains is a C-level function in _operator. Its qualname is
# 'contains', a simple name with no enclosing class scope.
# No prior operator spec records this standalone in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra24.contains.qualname:
  description: "operator.contains.__qualname__ == 'contains'"
  category: qualnames
  kind: python_call_eq
  function: contains.__qualname__.__eq__
  args: ["contains"]
  expected: true
