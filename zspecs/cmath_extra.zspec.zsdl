spec: cmath_extra
version: ">=3.2"
backend: python_module(cmath)

docs: https://docs.python.org/3/library/cmath.html

provenance:
  derived_from:
    - "Python cmath documentation — https://docs.python.org/3/library/cmath.html"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified by running Python 3.14.3 cmath module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/cmathmodule.c"
    - "cmath.zspec.zsdl — covers isfinite, isinf, isnan, isclose, phase, polar, sqrt, exp, log, constants pi/e/tau"
  notes:
    - "This spec extends cmath.zspec.zsdl with constant type checks and function identity invariants."
    - "cmath.pi, cmath.e, cmath.tau, cmath.inf, cmath.nan are module-level float constants."
    - "cmath.infj and cmath.nanj are module-level complex constants."
    - "Type checks use __class__.__name__ via dotted attribute chaining from the module root."
    - "Function identity invariants (.__name__) confirm the expected callable is present under that name."
    - "phase, polar, rect, exp, log, sqrt, sin, cos are all callable complex-math functions."
    - "isinf, isnan, isfinite, isclose are predicate functions returning bool."
    - "All expected values verified by running Python 3.14.3 cmath module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Constant type checks — pi, e, tau, inf, nan are float; infj, nanj are complex
# cmath.zspec.zsdl checks values of pi, e, tau via __eq__ and __gt__ but does
# not check their types. We add __class__.__name__ for each constant.
# ---------------------------------------------------------------------------

invariant cmath_extra.constants.pi_class:
  description: "cmath.pi.__class__.__name__ == 'float'"
  category: constants
  kind: python_call_eq
  function: pi.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant cmath_extra.constants.e_class:
  description: "cmath.e.__class__.__name__ == 'float'"
  category: constants
  kind: python_call_eq
  function: e.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant cmath_extra.constants.tau_class:
  description: "cmath.tau.__class__.__name__ == 'float'"
  category: constants
  kind: python_call_eq
  function: tau.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant cmath_extra.constants.inf_class:
  description: "cmath.inf.__class__.__name__ == 'float'"
  category: constants
  kind: python_call_eq
  function: inf.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant cmath_extra.constants.infj_class:
  description: "cmath.infj.__class__.__name__ == 'complex'"
  category: constants
  kind: python_call_eq
  function: infj.__class__.__name__.__eq__
  args: ["complex"]
  expected: true

invariant cmath_extra.constants.nan_class:
  description: "cmath.nan.__class__.__name__ == 'float'"
  category: constants
  kind: python_call_eq
  function: nan.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant cmath_extra.constants.nanj_class:
  description: "cmath.nanj.__class__.__name__ == 'complex'"
  category: constants
  kind: python_call_eq
  function: nanj.__class__.__name__.__eq__
  args: ["complex"]
  expected: true

# ---------------------------------------------------------------------------
# Function identity checks — confirm all major callable symbols by name
# cmath.zspec.zsdl does not check .__name__ on any of these functions.
# ---------------------------------------------------------------------------

invariant cmath_extra.phase.name:
  description: "cmath.phase.__name__ == 'phase'"
  category: function_identity
  kind: python_call_eq
  function: phase.__name__.__eq__
  args: ["phase"]
  expected: true

invariant cmath_extra.polar.name:
  description: "cmath.polar.__name__ == 'polar'"
  category: function_identity
  kind: python_call_eq
  function: polar.__name__.__eq__
  args: ["polar"]
  expected: true

invariant cmath_extra.rect.name:
  description: "cmath.rect.__name__ == 'rect'"
  category: function_identity
  kind: python_call_eq
  function: rect.__name__.__eq__
  args: ["rect"]
  expected: true

invariant cmath_extra.exp.name:
  description: "cmath.exp.__name__ == 'exp'"
  category: function_identity
  kind: python_call_eq
  function: exp.__name__.__eq__
  args: ["exp"]
  expected: true

invariant cmath_extra.log.name:
  description: "cmath.log.__name__ == 'log'"
  category: function_identity
  kind: python_call_eq
  function: log.__name__.__eq__
  args: ["log"]
  expected: true

invariant cmath_extra.sqrt.name:
  description: "cmath.sqrt.__name__ == 'sqrt'"
  category: function_identity
  kind: python_call_eq
  function: sqrt.__name__.__eq__
  args: ["sqrt"]
  expected: true

invariant cmath_extra.sin.name:
  description: "cmath.sin.__name__ == 'sin'"
  category: function_identity
  kind: python_call_eq
  function: sin.__name__.__eq__
  args: ["sin"]
  expected: true

invariant cmath_extra.cos.name:
  description: "cmath.cos.__name__ == 'cos'"
  category: function_identity
  kind: python_call_eq
  function: cos.__name__.__eq__
  args: ["cos"]
  expected: true

invariant cmath_extra.isinf.name:
  description: "cmath.isinf.__name__ == 'isinf'"
  category: function_identity
  kind: python_call_eq
  function: isinf.__name__.__eq__
  args: ["isinf"]
  expected: true

invariant cmath_extra.isnan.name:
  description: "cmath.isnan.__name__ == 'isnan'"
  category: function_identity
  kind: python_call_eq
  function: isnan.__name__.__eq__
  args: ["isnan"]
  expected: true

invariant cmath_extra.isfinite.name:
  description: "cmath.isfinite.__name__ == 'isfinite'"
  category: function_identity
  kind: python_call_eq
  function: isfinite.__name__.__eq__
  args: ["isfinite"]
  expected: true

invariant cmath_extra.isclose.name:
  description: "cmath.isclose.__name__ == 'isclose'"
  category: function_identity
  kind: python_call_eq
  function: isclose.__name__.__eq__
  args: ["isclose"]
  expected: true
