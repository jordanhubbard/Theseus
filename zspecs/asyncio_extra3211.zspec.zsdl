    - ["as3211006", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__and__"], false]
    - ["as3211007", operator.contains, [asyncio.Condition.__dict__,        "__and__"], false]
    - ["as3211008", operator.contains, [asyncio.Queue.__dict__,            "__and__"], false]
    - ["as3211009", operator.contains, [asyncio.PriorityQueue.__dict__,    "__and__"], false]
    - ["as3211010", operator.contains, [asyncio.LifoQueue.__dict__,        "__and__"], false]

# ---------------------------------------------------------------------------
# __or__ dict-presence — operator.contains(Cls.__dict__, '__or__')
#
# All 10 asyncio classes return false for __or__.
# The | operator gained new union-type semantics in Python 3.10 (PEP 604),
#   but this affects type annotations and the metaclass — it does not place
#   __or__ in the instance class's own __dict__. asyncio types are not
#   types-module classes; they are runtime concurrency primitives.
# asyncio.Event/Lock/Condition: synchronization guards; | is not defined
#   for composing events or locks into combined wait conditions.
# asyncio.Semaphore/BoundedSemaphore: permit-counter objects; | undefined.
# asyncio.Task/Future: coroutine result holders; | is undefined for tasks.
# asyncio.Queue/PriorityQueue/LifoQueue: FIFO/priority/LIFO data structures
#   with no set-algebra or bitwise protocol of any kind.
# ---------------------------------------------------------------------------

