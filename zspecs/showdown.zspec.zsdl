spec: showdown
version: ">=2.0.0"
backend: node(showdown)

docs: https://github.com/showdownjs/showdown#readme

provenance:
  derived_from:
    - "Showdown README — https://github.com/showdownjs/showdown#readme"
    - "Test vectors verified with showdown via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "showdown source"
  notes:
    - "Bidirectional Markdown ↔ HTML converter — older sibling of marked, ports John Gruber's perl Markdown."
    - "Install: npm install showdown"
    - "v2 CJS; module exposes Converter class plus helper / extensions / setOption / setFlavor."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure conversion; never throws."
  stderr: "null"
  stickiness: "N/A — each Converter instance independent."
  codes: {}

invariant showdown.h1_with_id:
  description: "'# Hello' renders to '<h1 id=\"hello\">Hello</h1>' (header IDs default-on)"
  category: render
  kind: node_chain_eq
  entry: constructor
  class: Converter
  entry_args: []
  chain:
    - {method: makeHtml, args: ["# Hello"]}
  expected: "<h1 id=\"hello\">Hello</h1>"

invariant showdown.bold:
  description: "'**bold**' renders to '<p><strong>bold</strong></p>'"
  category: render
  kind: node_chain_eq
  entry: constructor
  class: Converter
  entry_args: []
  chain:
    - {method: makeHtml, args: ["**bold**"]}
  expected: "<p><strong>bold</strong></p>"

invariant showdown.italic_asterisk:
  description: "'*italic*' renders to '<p><em>italic</em></p>'"
  category: render
  kind: node_chain_eq
  entry: constructor
  class: Converter
  entry_args: []
  chain:
    - {method: makeHtml, args: ["*italic*"]}
  expected: "<p><em>italic</em></p>"

invariant showdown.link:
  description: "Inline link renders to <a href=...>"
  category: render
  kind: node_chain_eq
  entry: constructor
  class: Converter
  entry_args: []
  chain:
    - {method: makeHtml, args: ["[link](http://example.com)"]}
  expected: "<p><a href=\"http://example.com\">link</a></p>"

invariant showdown.h2_with_id:
  description: "'## Sub' renders with id-derived from text"
  category: render
  kind: node_chain_eq
  entry: constructor
  class: Converter
  entry_args: []
  chain:
    - {method: makeHtml, args: ["## Sub"]}
  expected: "<h2 id=\"sub\">Sub</h2>"

invariant showdown.code_inline:
  description: "Inline code with backticks renders as <code>"
  category: render
  kind: node_chain_eq
  entry: constructor
  class: Converter
  entry_args: []
  chain:
    - {method: makeHtml, args: ["use `code` here"]}
  expected: "<p>use <code>code</code> here</p>"

invariant showdown.empty_input:
  description: "Empty input renders to empty string"
  category: edge
  kind: node_chain_eq
  entry: constructor
  class: Converter
  entry_args: []
  chain:
    - {method: makeHtml, args: [""]}
  expected: ""
