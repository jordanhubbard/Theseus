invariant inspect_extra196.BoundArguments_name_eq:
  description: "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — BoundArguments holds the result of binding arguments to a Signature; __name__ is 'BoundArguments' (len=14); verified with Python 3.14.3; new to extra196"
