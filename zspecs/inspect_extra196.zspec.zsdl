       ["BoundArguments.apply_defaults"],
       true,
       "inspect.BoundArguments.apply_defaults.__qualname__.__eq__('BoundArguments.apply_defaults') == True — apply_defaults is defined inside BoundArguments; __qualname__ is 'BoundArguments.apply_defaults' (len=29); str.__eq__('BoundArguments.apply_defaults') returns True; verified with Python 3.14.3; new to extra196"]
    - [ba_apply_defaults_qualname_len,
       BoundArguments.apply_defaults.__qualname__.__len__,
