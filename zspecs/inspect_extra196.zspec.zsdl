# ---------------------------------------------------------------------------
# Table 3: inspect.BoundArguments args, kwargs property descriptors, and class name
#
# inspect.BoundArguments.args.__class__.__name__   == 'property' (len=8)
# inspect.BoundArguments.kwargs.__class__.__name__ == 'property' (len=8)
# inspect.BoundArguments.__class__.__name__        == 'type' (len=4)
#
# args and kwargs are property descriptors. BoundArguments itself is a class
# whose metaclass is the built-in type. New to extra196.
# ---------------------------------------------------------------------------

table inspect_extra196.BoundArguments_args_kwargs_class:
  description: "inspect.BoundArguments descriptors and metaclass: args.__class__.__name__=='property'(len=8); kwargs.__class__.__name__=='property'(len=8); __class__.__name__=='type'(len=4); new to extra196"
  kind: python_call_eq
  category: identity
  id_prefix: inspectboundargs196

  columns: [id, function, args, expected, description]
  rows:
    - [ba_args_class_eq,
       BoundArguments.args.__class__.__name__.__eq__,
       ["property"],
       true,
       "inspect.BoundArguments.args.__class__.__name__.__eq__('property') == True — args is a property descriptor on BoundArguments that reconstructs a positional-argument tuple; __class__.__name__ is 'property' (len=8); str.__eq__('property') returns True; verified with Python 3.14.3; new to extra196"]
    - [ba_args_class_len,
       BoundArguments.args.__class__.__name__.__len__,
       [],
       8,
       "inspect.BoundArguments.args.__class__.__name__.__len__() == 8 — 'property' has 8 characters: p-r-o-p-e-r-t-y; str.__len__() returns 8; verified with Python 3.14.3; new to extra196"]
    - [ba_kwargs_class_eq,
       BoundArguments.kwargs.__class__.__name__.__eq__,
       ["property"],
       true,
       "inspect.BoundArguments.kwargs.__class__.__name__.__eq__('property') == True — kwargs is a property descriptor on BoundArguments that reconstructs a keyword-argument dict; __class__.__name__ is 'property' (len=8); str.__eq__('property') returns True; verified with Python 3.14.3; new to extra196"]
    - [ba_class_name_eq,
       BoundArguments.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.BoundArguments.__class__.__name__.__eq__('type') == True — BoundArguments is a class so its metaclass is the built-in type; __class__.__name__ is 'type' (len=4); str.__eq__('type') returns True; verified with Python 3.14.3; new to extra196"]
    - [ba_class_name_len,
       BoundArguments.__class__.__name__.__len__,
       [],
       4,
       "inspect.BoundArguments.__class__.__name__.__len__() == 4 — 'type' has 4 characters: t-y-p-e; str.__len__() returns 4; verified with Python 3.14.3; new to extra196"]

