  kind: python_call_eq
  function: BoundArguments.__name__.__eq__
  args: ["BoundArguments"]
  expected: true

invariant inspect_extra196.BoundArguments_module_eq:
  description: "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is defined at top level in inspect.py; __module__ is 'inspect' (len=7); verified with Python 3.14.3; new to extra196"
