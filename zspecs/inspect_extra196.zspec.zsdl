spec: inspect_extra196
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.BoundArguments.__name__ == 'BoundArguments' (len=14); BoundArguments is a Python class defined in inspect.py that holds the result of binding arguments to a Signature; verified with Python 3.14.3."
    - "inspect.BoundArguments.__module__ == 'inspect' (len=7); BoundArguments is defined at the top level of inspect.py; verified with Python 3.14.3."
    - "inspect.BoundArguments.__bases__[0].__name__ == 'object' (len=6); BoundArguments inherits directly from object; verified with Python 3.14.3."
    - "inspect.BoundArguments.__init__.__qualname__ == 'BoundArguments.__init__' (len=23); the __init__ method is defined inside the BoundArguments class; verified with Python 3.14.3."
    - "inspect.BoundArguments.apply_defaults.__qualname__ == 'BoundArguments.apply_defaults' (len=29); apply_defaults is a method defined inside the BoundArguments class; verified with Python 3.14.3."
    - "inspect.BoundArguments.args.__class__.__name__ == 'property' (len=8); args is a property descriptor on the BoundArguments class that reconstructs a positional-argument tuple; verified with Python 3.14.3."
    - "inspect.BoundArguments.kwargs.__class__.__name__ == 'property' (len=8); kwargs is a property descriptor on the BoundArguments class that reconstructs a keyword-argument dict; verified with Python 3.14.3."
    - "inspect.BoundArguments.__class__.__name__ == 'type' (len=4); BoundArguments is a class so its metaclass is the built-in type; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.BoundArguments __name__, __module__, and __bases__ identity
#
# inspect.BoundArguments.__name__              == 'BoundArguments' (len=14)
# inspect.BoundArguments.__module__            == 'inspect' (len=7)
# inspect.BoundArguments.__bases__[0].__name__ == 'object' (len=6)
#
# BoundArguments is a Python class inheriting directly from object.
# New to extra196.
# ---------------------------------------------------------------------------

table inspect_extra196.BoundArguments_name_module_base:
  description: "inspect.BoundArguments identity: __name__=='BoundArguments'(len=14); __module__=='inspect'(len=7); __bases__[0].__name__=='object'(len=6); new to extra196"
  kind: python_call_eq
  category: identity
  id_prefix: inspectboundargs196

  columns: [id, function, args, expected, description]
  rows:
    - [ba_name_eq,
       BoundArguments.__name__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — BoundArguments holds the result of binding arguments to a Signature; __name__ is 'BoundArguments' (len=14); str.__eq__('BoundArguments') returns True; verified with Python 3.14.3; new to extra196"]
    - [ba_name_len,
       BoundArguments.__name__.__len__,
       [],
       14,
       "inspect.BoundArguments.__name__.__len__() == 14 — 'BoundArguments' has 14 characters; str.__len__() returns 14; verified with Python 3.14.3; new to extra196"]
    - [ba_module_eq,
       BoundArguments.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is defined at top level in inspect.py; __module__ is 'inspect' (len=7); str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra196"]
    - [ba_module_len,
       BoundArguments.__module__.__len__,
       [],
       7,
       "inspect.BoundArguments.__module__.__len__() == 7 — 'inspect' has 7 characters: i-n-s-p-e-c-t; str.__len__() returns 7; verified with Python 3.14.3; new to extra196"]
    - [ba_base_name_eq,
       "BoundArguments.__bases__.__getitem__(0).__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__bases__[0].__name__.__eq__('object') == True — BoundArguments inherits directly from object; __bases__[0].__name__ is 'object' (len=6); str.__eq__('object') returns True; verified with Python 3.14.3; new to extra196"]

# ---------------------------------------------------------------------------
