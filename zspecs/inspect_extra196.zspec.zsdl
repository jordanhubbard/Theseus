       true,
       "inspect.BoundArguments.__init__.__qualname__.__eq__('BoundArguments.__init__') == True — __init__ is defined inside the BoundArguments class; __init__.__qualname__ is 'BoundArguments.__init__' (len=23); str.__eq__('BoundArguments.__init__') returns True; verified with Python 3.14.3; new to extra196"]
    - [ba_init_qualname_len,
       BoundArguments.__init__.__qualname__.__len__,
       [],
       23,
       "inspect.BoundArguments.__init__.__qualname__.__len__() == 23 — 'BoundArguments.__init__' has 23 characters; str.__len__() returns 23; verified with Python 3.14.3; new to extra196"]
