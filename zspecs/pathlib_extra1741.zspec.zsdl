spec: pathlib_extra1741
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib_extra1681.zspec.zsdl — covers __call__, __truediv__/__rtruediv__, __fspath__, __enter__/__exit__"
    - "pathlib_extra1666.zspec.zsdl — covers __new__ and __init__ construction protocol"
    - "pathlib_extra1651.zspec.zsdl — covers __init_subclass__, __class_getitem__, module attr presence"
  notes:
    - "Wave 563 (_extra1741): descriptor protocol — which pathlib types define __get__, __set__, __delete__, __set_name__ in their own __dict__."
    - "No pathlib type defines __get__, __set__, __delete__, or __set_name__ in its own __dict__."
    - "pathlib.Path objects are filesystem path handles, not descriptors."
    - "PurePath defines __truediv__ and __rtruediv__ for path division in its own __dict__ (confirmed in pathlib_extra1681)."
    - "Path defines __truediv__ in its own __dict__ but not __rtruediv__ — inherited from PurePath."
    - "PurePosixPath and PosixPath do NOT define __truediv__ or __rtruediv__ in their own __dict__."
    - "PureWindowsPath and WindowsPath do NOT define __truediv__ or __rtruediv__ in their own __dict__."
    - "PurePath defines __hash__ and __eq__ in its own __dict__ for structural path equality."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table pathlib_extra1741.descriptor_protocol
# __get__, __set__, __delete__, __set_name__ are absent from every pathlib
# type's own __dict__. pathlib classes are not descriptors.
# ---------------------------------------------------------------------------

table pathlib_extra1741.descriptor_protocol:
  description: "pathlib types descriptor protocol (__get__/__set__/__delete__/__set_name__) dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1741

  columns: [id, function, args, expected]
  rows:
    - ["pl1741001", PurePath.__dict__.__contains__,        ["__get__"],      false]
    - ["pl1741002", PurePath.__dict__.__contains__,        ["__set__"],      false]
    - ["pl1741003", PurePath.__dict__.__contains__,        ["__delete__"],   false]
    - ["pl1741004", PurePath.__dict__.__contains__,        ["__set_name__"], false]
    - ["pl1741005", Path.__dict__.__contains__,            ["__get__"],      false]
    - ["pl1741006", Path.__dict__.__contains__,            ["__set__"],      false]
    - ["pl1741007", Path.__dict__.__contains__,            ["__delete__"],   false]
    - ["pl1741008", Path.__dict__.__contains__,            ["__set_name__"], false]
    - ["pl1741009", PurePosixPath.__dict__.__contains__,   ["__get__"],      false]
    - ["pl1741010", PurePosixPath.__dict__.__contains__,   ["__set__"],      false]
    - ["pl1741011", PureWindowsPath.__dict__.__contains__, ["__get__"],      false]
    - ["pl1741012", PureWindowsPath.__dict__.__contains__, ["__set__"],      false]
    - ["pl1741013", PosixPath.__dict__.__contains__,       ["__get__"],      false]
    - ["pl1741014", PosixPath.__dict__.__contains__,       ["__set__"],      false]
    - ["pl1741015", WindowsPath.__dict__.__contains__,     ["__get__"],      false]
    - ["pl1741016", WindowsPath.__dict__.__contains__,     ["__set__"],      false]

# ---------------------------------------------------------------------------
# Table pathlib_extra1741.division_comparison_protocol
# PurePath defines __truediv__ and __rtruediv__ for path joining.
# Path defines __truediv__ but inherits __rtruediv__ from PurePath.
# PurePath defines __hash__ and __eq__ for structural equality.
# Path inherits __hash__ and __eq__ without re-defining them.
# ---------------------------------------------------------------------------

table pathlib_extra1741.division_comparison_protocol:
  description: "Path division operator and comparison protocol dict-presence cross-checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1741

  columns: [id, function, args, expected]
  rows:
    - ["pl1741017", PurePath.__dict__.__contains__,        ["__truediv__"],  true]
    - ["pl1741018", PurePath.__dict__.__contains__,        ["__rtruediv__"], true]
    - ["pl1741019", Path.__dict__.__contains__,            ["__truediv__"],  true]
    - ["pl1741020", Path.__dict__.__contains__,            ["__rtruediv__"], false]
    - ["pl1741021", PurePosixPath.__dict__.__contains__,   ["__truediv__"],  false]
    - ["pl1741022", PosixPath.__dict__.__contains__,       ["__truediv__"],  false]
    - ["pl1741023", PurePath.__dict__.__contains__,        ["__hash__"],     true]
    - ["pl1741024", PurePath.__dict__.__contains__,        ["__eq__"],       true]
    - ["pl1741025", Path.__dict__.__contains__,            ["__hash__"],     false]
    - ["pl1741026", Path.__dict__.__contains__,            ["__eq__"],       false]
    - ["pl1741027", PurePosixPath.__dict__.__contains__,   ["__hash__"],     false]
    - ["pl1741028", PurePosixPath.__dict__.__contains__,   ["__eq__"],       false]
