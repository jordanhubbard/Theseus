spec: dataclasses_extra22
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses documentation"
    - "PEP 557 — Data Classes"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses.zspec.zsdl, dataclasses_field.zspec.zsdl, and dataclasses_extra through dataclasses_extra21.zspec.zsdl."
    - "dataclasses_extra21 covers: combined __name__.__len__ table for InitVar/Field/FrozenInstanceError; combined __module__ table for InitVar/Field/FrozenInstanceError; FrozenInstanceError/__mro__[1].__name__ == 'AttributeError'; InitVar/__name__.__eq__ standalone."
    - "dataclasses_extra20 covers: combined __name__ table for dataclass/field/fields/asdict/astuple/make_dataclass/replace; KW_ONLY/__class__.__name__ standalone; FrozenInstanceError/__qualname__ standalone."
    - "dataclasses_extra18 covers: MISSING/__class__.__name__.__len__; KW_ONLY/__class__.__name__.__len__; various __qualname__.__len__ values."
    - "dataclasses_extra19 covers: field().__class__.__name__; fields/__qualname__.__eq__; is_dataclass/__qualname__.__eq__; asdict/__qualname__.__eq__; astuple/__qualname__.__eq__; replace/__qualname__.__eq__; make_dataclass/__qualname__.__eq__."
    - "Focus of this spec: (1) combined __qualname__.__eq__ table for Field/InitVar/FrozenInstanceError — none covered as combined table; (2) combined __bases__[0].__name__ table for Field/InitVar/FrozenInstanceError; (3) Field.__mro__.__len__() == 2 standalone; (4) MISSING.__class__.__module__ standalone."
    - "NOT yet covered (entering this spec): Field/__qualname__.__eq__('Field') in a combined table; InitVar/__qualname__.__eq__('InitVar') in a combined table; FrozenInstanceError/__qualname__.__eq__('FrozenInstanceError') in a combined table; Field/__bases__[0].__name__ == 'object'; InitVar/__bases__[0].__name__ == 'object'; FrozenInstanceError/__bases__[0].__name__ == 'AttributeError' in a combined table; Field/__mro__.__len__() == 2 standalone; MISSING/__class__.__module__ == 'dataclasses' standalone."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ for Field, InitVar, FrozenInstanceError
#
# These three are the main public type-level names in the dataclasses module.
# dataclasses_extra20 covers FrozenInstanceError/__qualname__ as a standalone
# boolean invariant. No prior spec has all three together in a combined table.
# Field.__qualname__ == 'Field', InitVar.__qualname__ == 'InitVar',
# FrozenInstanceError.__qualname__ == 'FrozenInstanceError'.
# ---------------------------------------------------------------------------

table dataclasses_extra22.type_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Field,               Field.__qualname__.__eq__,               ["Field"],               true]
    - [InitVar,             InitVar.__qualname__.__eq__,             ["InitVar"],             true]
    - [FrozenInstanceError, FrozenInstanceError.__qualname__.__eq__, ["FrozenInstanceError"], true]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ for Field, InitVar, FrozenInstanceError
#
# Field and InitVar both directly subclass object (MRO length 2).
# FrozenInstanceError subclasses AttributeError.
# No prior spec covers __bases__[0].__name__ for Field or InitVar.
# dataclasses_extra21 covers FrozenInstanceError/__mro__[1].__name__ == 'AttributeError'
# but not FrozenInstanceError.__bases__[0].__name__ in a combined table.
# ---------------------------------------------------------------------------

table dataclasses_extra22.type_bases0_names:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base0_name

  columns: [id, function, args, expected]
  rows:
    - [Field,               "Field.__bases__.__getitem__(0).__name__.__eq__",               ["object"],         true]
    - [InitVar,             "InitVar.__bases__.__getitem__(0).__name__.__eq__",             ["object"],         true]
    - [FrozenInstanceError, "FrozenInstanceError.__bases__.__getitem__(0).__name__.__eq__", ["AttributeError"], true]

# ---------------------------------------------------------------------------
# Field.__mro__.__len__() == 2
#
# dataclasses.Field directly subclasses object, giving an MRO of [Field, object].
# dataclasses_extra10 covers FrozenInstanceError/__mro__.__len__() == 5 and
# dataclasses_extra21 covers InitVar/__mro__.__len__() via table entries.
# No prior spec covers Field.__mro__.__len__() == 2 as a standalone invariant.
# ---------------------------------------------------------------------------

invariant dataclasses_extra22.Field.mro.len:
  description: "dataclasses.Field.__mro__.__len__() == 2 — Field MRO is [Field, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: Field.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# InitVar.__mro__.__len__() == 2
#
# dataclasses.InitVar directly subclasses object, giving an MRO of [InitVar, object].
# No prior spec covers InitVar.__mro__.__len__() == 2 as a standalone invariant.
# ---------------------------------------------------------------------------

invariant dataclasses_extra22.InitVar.mro.len:
  description: "dataclasses.InitVar.__mro__.__len__() == 2 — InitVar MRO is [InitVar, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: InitVar.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# MISSING.__class__.__module__ standalone
#
# dataclasses.MISSING is an instance of the private sentinel type _MISSING_TYPE,
# which is defined in the dataclasses module itself. Its __class__.__module__
# is therefore 'dataclasses'. dataclasses_extra18 covers
# MISSING/__class__.__name__.__len__ but not __class__.__module__.
# ---------------------------------------------------------------------------

invariant dataclasses_extra22.MISSING.class_module:
  description: "dataclasses.MISSING.__class__.__module__ == 'dataclasses' — sentinel type is module-private"
  category: modules
  kind: python_call_eq
  function: MISSING.__class__.__module__.__eq__
  args: ["dataclasses"]
  expected: true
