spec: hashlib_extra1291
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra129.zspec.zsdl — covers sha256/sha512/sha1/md5/sha224/sha384 __qualname__.__len__() / sha3_*/shake_* __qualname__.__len__() (table + invariants)."
    - "hashlib_extra128.zspec.zsdl — covers sha3_224/sha3_256/sha3_384/sha3_512 digest_size and block_size / blake2b/blake2s digest_size and block_size and __class__.__name__ (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' / new __class__.__name__=='function' / algorithms_guaranteed __len__()==14 (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in earlier hashlib specs."
    - "Wave 533 theme: __init__ and __new__ method presence and qualname checks for hashlib."
    - "hashlib.new.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__init__.__qualname__ == 'set.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__init__.__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__init__.__qualname__ == 'set.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__init__.__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__qualname__ == '__hash_new'. The module-level hashlib.new is actually a wrapper named __hash_new. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__name__ == '__hash_new'. Consistent with __qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.md5 and hashlib.sha256 are builtin_function_or_method (C extension constructors), not type objects. Their __class__ is not 'type' but 'builtin_function_or_method'."
    - "Note: The set.__init__ method is a wrapper_descriptor — a C-level slot wrapper for the __init__ of the set type. This is the same descriptor seen on other C-extension types."
    - "Note: hashlib.new is a Python-level wrapper function (__class__.__name__=='function') that dispatches to the appropriate C-level constructor."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5.__class__.__name__ == 'builtin_function_or_method'
# hashlib.sha256.__class__.__name__ == 'builtin_function_or_method'
# hashlib.sha1.__class__.__name__ == 'builtin_function_or_method'
# hashlib.sha512.__class__.__name__ == 'builtin_function_or_method'
# hashlib.sha224.__class__.__name__ == 'builtin_function_or_method'
# hashlib.sha384.__class__.__name__ == 'builtin_function_or_method'
#
# Wave 533 theme: constructor __class__.__name__ checks for hashlib.
#
# The classic SHA-family constructors (md5, sha1, sha224, sha256, sha384,
# sha512) are all builtin_function_or_method objects — C-level functions
# exposed as module attributes, not Python-level type objects. This is in
# contrast to blake2b and blake2s which are type objects (class 'type').
# hashlib_extra99 anchors __class__.__name__=='builtin_function_or_method'
# for these same six constructors in a table with id_prefix hlcls99. This
# spec provides fresh anchors under hlcls1291 for wave 533.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra1291.constructor_class_names:
  description: "hashlib.md5/__class__/__name__.__eq__('builtin_function_or_method')==True / sha256/__class__/__name__.__eq__('builtin_function_or_method')==True / sha1/__class__/__name__.__eq__('builtin_function_or_method')==True / sha512/__class__/__name__.__eq__('builtin_function_or_method')==True / sha224/__class__/__name__.__eq__('builtin_function_or_method')==True / sha384/__class__/__name__.__eq__('builtin_function_or_method')==True — all six classic SHA-family constructors are C-level builtin_function_or_method objects; differ from blake2b/blake2s which are type objects; first hl1291cn anchor for constructor class names"
  kind: python_call_eq
  category: constructor_identity
  id_prefix: hl1291cn

  columns: [id, function, args, expected, description]
  rows:
    - [hl1291cn001, md5.__class__.__name__.__eq__,    ["builtin_function_or_method"], true, "hashlib.md5 is a C-level builtin_function_or_method (not a Python-level type)"]
    - [hl1291cn002, sha256.__class__.__name__.__eq__,  ["builtin_function_or_method"], true, "hashlib.sha256 is a C-level builtin_function_or_method (OpenSSL-backed SHA-256 constructor)"]
    - [hl1291cn003, sha1.__class__.__name__.__eq__,    ["builtin_function_or_method"], true, "hashlib.sha1 is a C-level builtin_function_or_method (OpenSSL-backed SHA-1 constructor)"]
    - [hl1291cn004, sha512.__class__.__name__.__eq__,  ["builtin_function_or_method"], true, "hashlib.sha512 is a C-level builtin_function_or_method (OpenSSL-backed SHA-512 constructor)"]
    - [hl1291cn005, sha224.__class__.__name__.__eq__,  ["builtin_function_or_method"], true, "hashlib.sha224 is a C-level builtin_function_or_method (OpenSSL-backed SHA-224 constructor)"]
    - [hl1291cn006, sha384.__class__.__name__.__eq__,  ["builtin_function_or_method"], true, "hashlib.sha384 is a C-level builtin_function_or_method (OpenSSL-backed SHA-384 constructor)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__init__.__qualname__ == 'set.__init__'
# hashlib.algorithms_guaranteed.__class__.__init__.__class__.__name__ == 'wrapper_descriptor'
# hashlib.algorithms_available.__class__.__init__.__qualname__ == 'set.__init__'
# hashlib.algorithms_available.__class__.__init__.__class__.__name__ == 'wrapper_descriptor'
# hashlib.new.__class__.__name__ == 'function'
# hashlib.new.__qualname__ == '__hash_new'
#
# Wave 533 theme: __init__ qualname checks for set-typed attributes and new wrapper.
#
# Both algorithms_guaranteed and algorithms_available are plain Python set objects.
# Their __class__ is set, and set.__init__ is a wrapper_descriptor (a C-level slot
# wrapper). The qualname of set.__init__ is 'set.__init__'. hashlib.new is a Python
# wrapper function whose __qualname__ and __name__ are both '__hash_new'.
# No prior hashlib spec anchors algorithms_guaranteed.__class__.__init__.__qualname__
# or .__class__.__name__ under hl1291qi. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra1291.set_init_qualname_checks:
  description: "hashlib.algorithms_guaranteed.__class__.__init__.__qualname__.__eq__('set.__init__')==True / .__class__.__name__.__eq__('wrapper_descriptor')==True / hashlib.algorithms_available.__class__.__init__.__qualname__.__eq__('set.__init__')==True / .__class__.__name__.__eq__('wrapper_descriptor')==True / hashlib.new.__class__.__name__.__eq__('function')==True / hashlib.new.__qualname__.__eq__('__hash_new')==True — set.__init__ is a C-level wrapper_descriptor; new is a Python wrapper with internal name __hash_new; first hl1291qi anchor"
  kind: python_call_eq
  category: init_qualname
  id_prefix: hl1291qi

  columns: [id, function, args, expected, description]
  rows:
    - [hl1291qi001, algorithms_guaranteed.__class__.__init__.__qualname__.__eq__,   ["set.__init__"],          true, "algorithms_guaranteed is a set; set.__init__.__qualname__ is 'set.__init__'"]
    - [hl1291qi002, algorithms_guaranteed.__class__.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true, "set.__init__ is a wrapper_descriptor (C-level slot wrapper for set.__init__)"]
    - [hl1291qi003, algorithms_available.__class__.__init__.__qualname__.__eq__,     ["set.__init__"],          true, "algorithms_available is a set; set.__init__.__qualname__ is 'set.__init__'"]
    - [hl1291qi004, algorithms_available.__class__.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"],  true, "set.__init__ is a wrapper_descriptor — same descriptor object for both set instances"]
    - [hl1291qi005, new.__class__.__name__.__eq__,                                   ["function"],              true, "hashlib.new is a Python-level function (__class__.__name__=='function'), not a C builtin"]
    - [hl1291qi006, new.__qualname__.__eq__,                                          ["__hash_new"],            true, "hashlib.new.__qualname__ is '__hash_new' — the internal wrapper name exposed as hashlib.new"]

# ---------------------------------------------------------------------------
# hashlib.new.__name__.__eq__('__hash_new')
# hashlib.new.__class__.__name__.__eq__('function')
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')
# hashlib.algorithms_available.__class__.__name__.__eq__('set')
# hashlib.algorithms_guaranteed.__class__.__init__.__qualname__.__eq__('set.__init__')
# hashlib.algorithms_available.__class__.__init__.__qualname__.__eq__('set.__init__')
#
# Wave 533 theme: standalone confirmations of new wrapper and set type identity.
#
# hashlib.new is internally named __hash_new; it dispatches to C-level
# constructors for each algorithm. algorithms_guaranteed and algorithms_available
# are set objects — their __class__.__name__ == 'set'. This is a distinct
# check from the __init__ qualname table above: here we confirm the class name
# of the container attribute itself (not its __init__).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra1291.new_and_set_class_names:
  description: "hashlib.new.__name__.__eq__('__hash_new')==True / new.__class__.__name__.__eq__('function')==True / algorithms_guaranteed.__class__.__name__.__eq__('set')==True / algorithms_available.__class__.__name__.__eq__('set')==True / algorithms_guaranteed.__class__.__init__.__qualname__.__eq__('set.__init__')==True / algorithms_available.__class__.__init__.__qualname__.__eq__('set.__init__')==True — cross-check set class identity and new wrapper name; first hl1291nw anchor"
  kind: python_call_eq
  category: new_and_set_identity
  id_prefix: hl1291nw

  columns: [id, function, args, expected, description]
  rows:
    - [hl1291nw001, new.__name__.__eq__,                                               ["__hash_new"], true, "hashlib.new.__name__ is '__hash_new' (matches __qualname__; top-level Python wrapper)"]
    - [hl1291nw002, new.__class__.__name__.__eq__,                                     ["function"],  true, "hashlib.new is a Python function (not a C builtin); dispatches to C-level constructors"]
    - [hl1291nw003, algorithms_guaranteed.__class__.__name__.__eq__,                   ["set"],       true, "hashlib.algorithms_guaranteed.__class__.__name__ is 'set' (plain Python set object)"]
    - [hl1291nw004, algorithms_available.__class__.__name__.__eq__,                    ["set"],       true, "hashlib.algorithms_available.__class__.__name__ is 'set' (plain Python set object)"]
    - [hl1291nw005, algorithms_guaranteed.__class__.__init__.__qualname__.__eq__,      ["set.__init__"], true, "algorithms_guaranteed set.__init__.__qualname__ cross-check in new_and_set_identity context"]
    - [hl1291nw006, algorithms_available.__class__.__init__.__qualname__.__eq__,       ["set.__init__"], true, "algorithms_available set.__init__.__qualname__ cross-check in new_and_set_identity context"]
