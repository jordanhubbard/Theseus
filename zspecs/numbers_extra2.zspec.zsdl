spec: numbers_extra2
version: ">=3.0"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/numbers.html"
    - "PEP 3141 — A Type Hierarchy for Numbers"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "numbers source: internal C extension implementation details"
  notes:
    - "Complements numbers.zspec.zsdl and numbers_extra.zspec.zsdl."
    - "Checks __name__ of each class in the numeric tower (Number, Complex, Real, Rational, Integral)."
    - "numbers.Number.__module__ == 'numbers' — all tower classes live in the numbers module."
    - "numbers.Complex.__bases__[0].__name__ == 'Number' — Complex inherits directly from Number."
    - "numbers.Real.__bases__[0].__name__ == 'Complex' — Real inherits directly from Complex."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — each class in the numeric tower
# ---------------------------------------------------------------------------

table numbers_extra2.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, description, function, args, expected]
  rows:
    - [Number,   "numbers.Number.__name__ == 'Number'",     Number.__name__.__eq__,   ["Number"],   true]
    - [Complex,  "numbers.Complex.__name__ == 'Complex'",   Complex.__name__.__eq__,  ["Complex"],  true]
    - [Real,     "numbers.Real.__name__ == 'Real'",         Real.__name__.__eq__,     ["Real"],     true]
    - [Rational, "numbers.Rational.__name__ == 'Rational'", Rational.__name__.__eq__, ["Rational"], true]
    - [Integral, "numbers.Integral.__name__ == 'Integral'", Integral.__name__.__eq__, ["Integral"], true]

# ---------------------------------------------------------------------------
# Module checks — all tower classes live in the numbers module
# ---------------------------------------------------------------------------

invariant numbers_extra2.module.Number:
  description: "numbers.Number.__module__ == 'numbers'"
  category: module
  kind: python_call_eq
  function: Number.__module__.__eq__
  args: ["numbers"]
  expected: true

invariant numbers_extra2.module.Complex:
  description: "numbers.Complex.__module__ == 'numbers'"
  category: module
  kind: python_call_eq
  function: Complex.__module__.__eq__
  args: ["numbers"]
  expected: true

invariant numbers_extra2.module.Real:
  description: "numbers.Real.__module__ == 'numbers'"
  category: module
  kind: python_call_eq
  function: Real.__module__.__eq__
  args: ["numbers"]
  expected: true

# ---------------------------------------------------------------------------
# Inheritance checks — __bases__[0].__name__ for Complex and Real
# (these complement numbers_extra.zspec.zsdl which covers all five levels)
# ---------------------------------------------------------------------------

invariant numbers_extra2.bases.Complex_base_is_Number:
  description: "numbers.Complex.__bases__[0].__name__ == 'Number'"
  category: bases
  kind: python_call_eq
  function: Complex.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Number"]
  expected: true

invariant numbers_extra2.bases.Real_base_is_Complex:
  description: "numbers.Real.__bases__[0].__name__ == 'Complex'"
  category: bases
  kind: python_call_eq
  function: Real.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Complex"]
  expected: true
