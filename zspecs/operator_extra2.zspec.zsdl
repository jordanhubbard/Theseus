spec: operator_extra2
version: ">=3.0"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "Python operator documentation — https://docs.python.org/3/library/operator.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl and operator_extra.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "operator.zspec.zsdl covers call results: add(3,4)==7, sub(10,3)==7, mul(3,4)==12, truediv(7,2)==3.5, floordiv(7,2)==3, mod(10,3)==1, and comparison/bitwise/logical/sequence operators."
    - "operator_extra.zspec.zsdl covers itemgetter, attrgetter, methodcaller, and in-place operators (iadd, isub, imul, itruediv)."
    - "This spec adds: __name__ attribute checks for add, sub, mul, truediv, floordiv, mod (not covered anywhere else)."
    - "operator.add.__name__ == 'add'; the function names match their module-level names without the operator. prefix."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name identity — __name__ checks for arithmetic operator functions
#
# operator.zspec.zsdl tests what these functions return when called;
# this spec tests that the functions themselves carry the correct __name__.
# ---------------------------------------------------------------------------

table operator_extra2.functions.names:
  description: "Arithmetic operator functions have __name__ equal to their string identifier"
  kind: python_call_eq
  category: function_identity
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [add_name,      add.__name__.__eq__,      ["add"],      true]
    - [sub_name,      sub.__name__.__eq__,      ["sub"],      true]
    - [mul_name,      mul.__name__.__eq__,      ["mul"],      true]
    - [truediv_name,  truediv.__name__.__eq__,  ["truediv"],  true]
    - [floordiv_name, floordiv.__name__.__eq__,  ["floordiv"], true]
    - [mod_name,      mod.__name__.__eq__,      ["mod"],      true]

# ---------------------------------------------------------------------------
# Arithmetic call results — additional vectors distinct from operator.zspec.zsdl
#
# operator.zspec.zsdl rows: add(3,4)=7, sub(10,3)=7, mul(3,4)=12,
#   truediv(7,2)=3.5, floordiv(7,2)=3, mod(10,3)=1.
# This spec uses distinct argument pairs.
# ---------------------------------------------------------------------------

invariant operator_extra2.add.five_six:
  description: "operator.add(5, 6) == 11"
  category: arithmetic
  kind: python_call_eq
  function: add
  args: [5, 6]
  expected: 11

invariant operator_extra2.mul.six_seven:
  description: "operator.mul(6, 7) == 42"
  category: arithmetic
  kind: python_call_eq
  function: mul
  args: [6, 7]
  expected: 42

invariant operator_extra2.mod.seven_three:
  description: "operator.mod(7, 3) == 1"
  category: arithmetic
  kind: python_call_eq
  function: mod
  args: [7, 3]
  expected: 1
