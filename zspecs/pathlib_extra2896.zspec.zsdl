spec: pp2896
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/pathlib_extra2881.zspec.zsdl — wave 639 predecessor (covered __iadd__, __isub__, __imul__)"
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "Wave 640 theme: __itruediv__, __ifloordiv__, __imod__ dict-presence checks (in-place divide, floor-divide, modulo)."
    - "pathlib.PurePath defines __truediv__ for the / path-joining operator — but NOT __itruediv__ (in-place)."
    - "pathlib.PurePosixPath, PureWindowsPath, and Path inherit __truediv__ from PurePath and do NOT define it themselves."
    - "None of the pathlib classes define __ifloordiv__ or __imod__ — paths have no floor-division or modulo semantics."
    - "The / operator on paths uses __truediv__ to return a new path; augmented /= would require __itruediv__, which is absent."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __itruediv__ dict-presence
# PurePath defines __truediv__ but NOT __itruediv__ — /= is not supported in-place
# ---------------------------------------------------------------------------

table pp2896.itruediv:
  description: "__itruediv__ is absent from all pathlib classes — PurePath defines __truediv__ for / joining but not the in-place /= variant"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2896

  columns: [id, function, args, expected]
  rows:
    - ["pp2896001", "pathlib.PurePath.__dict__.__contains__",        ["__itruediv__"], false]
    - ["pp2896002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__itruediv__"], false]
    - ["pp2896003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__itruediv__"], false]
    - ["pp2896004", "pathlib.Path.__dict__.__contains__",            ["__itruediv__"], false]
    - ["pp2896005", "pathlib.PurePath.__dict__.__contains__",        ["__truediv__"],  true]
    - ["pp2896006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__truediv__"],  false]
    - ["pp2896007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__truediv__"],  false]
    - ["pp2896008", "pathlib.Path.__dict__.__contains__",            ["__truediv__"],  false]

