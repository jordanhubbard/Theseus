spec: http_server
version: ">=3.0"
backend: python_module(http.server)

docs: https://docs.python.org/3/library/http.server.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/http.server.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/server.py"
  notes:
    - "BaseHTTPRequestHandler.server_version == 'BaseHTTP/0.6' as of Python 3.12."
    - "BaseHTTPRequestHandler.protocol_version == 'HTTP/1.0' — the default response protocol."
    - "BaseHTTPRequestHandler.default_request_version == 'HTTP/0.9' — assumed when request line has no version."
    - "BaseHTTPRequestHandler.error_content_type == 'text/html;charset=utf-8'."
    - "SimpleHTTPRequestHandler.extensions_map is a dict mapping file extensions to MIME types."
    - "No actual HTTP server is started; all invariants use class-level attribute access only."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

table http_server.class_names:
  kind: python_call_eq
  category: classes
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [http_server,              HTTPServer.__name__.__eq__,              ["HTTPServer"],              true]
    - [threading_http_server,    ThreadingHTTPServer.__name__.__eq__,     ["ThreadingHTTPServer"],     true]
    - [base_handler,             BaseHTTPRequestHandler.__name__.__eq__,  ["BaseHTTPRequestHandler"],  true]
    - [simple_handler,           SimpleHTTPRequestHandler.__name__.__eq__, ["SimpleHTTPRequestHandler"], true]
    - [cgi_handler,              CGIHTTPRequestHandler.__name__.__eq__,   ["CGIHTTPRequestHandler"],   true]

# ---------------------------------------------------------------------------
# BaseHTTPRequestHandler class-level string constants
# ---------------------------------------------------------------------------

invariant http_server.server_version:
  description: "BaseHTTPRequestHandler.server_version == 'BaseHTTP/0.6'"
  category: constants
  kind: python_call_eq
  function: BaseHTTPRequestHandler.server_version.__eq__
  args: ["BaseHTTP/0.6"]
  expected: true

invariant http_server.protocol_version:
  description: "BaseHTTPRequestHandler.protocol_version == 'HTTP/1.0'"
  category: constants
  kind: python_call_eq
  function: BaseHTTPRequestHandler.protocol_version.__eq__
  args: ["HTTP/1.0"]
  expected: true

invariant http_server.default_request_version:
  description: "BaseHTTPRequestHandler.default_request_version == 'HTTP/0.9'"
  category: constants
  kind: python_call_eq
  function: BaseHTTPRequestHandler.default_request_version.__eq__
  args: ["HTTP/0.9"]
  expected: true

invariant http_server.error_content_type:
  description: "BaseHTTPRequestHandler.error_content_type == 'text/html;charset=utf-8'"
  category: constants
  kind: python_call_eq
  function: BaseHTTPRequestHandler.error_content_type.__eq__
  args: ["text/html;charset=utf-8"]
  expected: true

# ---------------------------------------------------------------------------
# SimpleHTTPRequestHandler — extensions_map is a dict
# ---------------------------------------------------------------------------

invariant http_server.extensions_map_type:
  description: "type(SimpleHTTPRequestHandler.extensions_map).__name__ == 'dict'"
  category: constants
  kind: python_call_eq
  function: SimpleHTTPRequestHandler.extensions_map.__class__.__name__.__eq__
  args: ["dict"]
  expected: true
