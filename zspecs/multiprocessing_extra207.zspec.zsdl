spec: multiprocessing_extra207
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/sharedctypes.py"
  notes:
    - "multiprocessing.Value, Array, Manager, Lock, Semaphore, Event, Barrier are factory methods bound to the default context."
    - "All have __module__ == 'multiprocessing.context' and qualnames like 'BaseContext.Value'."
    - "They appear as top-level names in multiprocessing but are bound methods of BaseContext."
    - "verified with Python 3.14.3."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Value and Array factory identity — extra207 namespace
#
# Value and Array are context-bound methods exposed at the top level;
# their __name__, __module__, and __qualname__ reflect this.
# ---------------------------------------------------------------------------

table multiprocessing_extra207.value_array_identity:
  description: "multiprocessing.Value and Array factory __name__ and __module__ checks in extra207 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp207valarray

  columns: [id, function, args, expected, description]
  rows:
    - [value_name,     Value.__name__.__eq__,     ["Value"],                    true, "multiprocessing.Value.__name__ == 'Value'"]
    - [value_module,   Value.__module__.__eq__,   ["multiprocessing.context"],  true, "multiprocessing.Value.__module__ == 'multiprocessing.context'"]
    - [value_qualname, Value.__qualname__.__eq__, ["BaseContext.Value"],         true, "multiprocessing.Value.__qualname__ == 'BaseContext.Value'"]
    - [array_name,     Array.__name__.__eq__,     ["Array"],                    true, "multiprocessing.Array.__name__ == 'Array'"]
    - [array_module,   Array.__module__.__eq__,   ["multiprocessing.context"],  true, "multiprocessing.Array.__module__ == 'multiprocessing.context'"]
    - [array_qualname, Array.__qualname__.__eq__, ["BaseContext.Array"],         true, "multiprocessing.Array.__qualname__ == 'BaseContext.Array'"]

