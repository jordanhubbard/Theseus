# ---------------------------------------------------------------------------
# __getitem__ dict-presence — operator.contains(Cls.__dict__, '__getitem__')
#
# re.Match defines __getitem__ (true): m[0] returns the whole match, m[1]
# returns the first capturing group — this subscript form was added in Python 3.
# re.Pattern and re.RegexFlag do not define __getitem__ in their own __dict__.
# ---------------------------------------------------------------------------

table re3136.getitem:
  description: "re types __getitem__ dict-presence checks; wave 656"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3136

  columns: [id, function, args, expected]
  rows:
    - ["re3136007", operator.contains, [re.Pattern.__dict__,   "__getitem__"], false]
    - ["re3136008", operator.contains, [re.Match.__dict__,     "__getitem__"], true]
    - ["re3136009", operator.contains, [re.RegexFlag.__dict__, "__getitem__"], false]

# ---------------------------------------------------------------------------
# combined — __call__, __len__, __getitem__ across all 3 re subjects
