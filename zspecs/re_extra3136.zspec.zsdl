spec: re3136
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 656 (re3136): __call__, __len__, __getitem__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "No re class defines __call__ in its own __dict__: re.Pattern instances are used via methods (match/search/findall etc.), not by calling the object directly."
    - "No re class defines __len__ in its own __dict__."
    - "re.Match defines __getitem__ in its own __dict__ (true): match objects support m[group] subscript syntax to retrieve groups."
    - "re.Pattern and re.RegexFlag do not define __getitem__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __call__ dict-presence — operator.contains(Cls.__dict__, '__call__')
#
# No re class defines __call__ in its own __dict__; all false.
# re.Pattern objects are used via .match()/.search() etc., not direct calls.
# re.RegexFlag is an IntFlag enum; __call__ is not defined at the class level.
# ---------------------------------------------------------------------------

table re3136.call:
  description: "re types __call__ dict-presence checks; wave 656"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3136

  columns: [id, function, args, expected]
  rows:
    - ["re3136001", operator.contains, [re.Pattern.__dict__,   "__call__"], false]
    - ["re3136002", operator.contains, [re.Match.__dict__,     "__call__"], false]
    - ["re3136003", operator.contains, [re.RegexFlag.__dict__, "__call__"], false]

