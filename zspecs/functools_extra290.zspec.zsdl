spec: functools_extra290
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools higher-order functions and callable identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py, Modules/_functoolsmodule.c"
  notes:
    - "All functools callables verified present in Python 3.9+"
    - "lru_cache and cache are distinct in 3.9+; cache added in 3.9"
    - "singledispatch is a pure-Python decorator, __module__ == 'functools'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table functools_extra290.function_names:
  description: "Verify __name__ attribute for key functools callables"
  kind: python_call_eq
  category: identity
  id_prefix: fne

  columns: [id, function, args, expected, description]
  rows:
    - [fne001, functools.reduce.__name__.__eq__, ["reduce"], true, "functools.reduce.__name__ is 'reduce'"]
    - [fne002, functools.partial.__name__.__eq__, ["partial"], true, "functools.partial.__name__ is 'partial'"]
    - [fne003, functools.lru_cache.__name__.__eq__, ["lru_cache"], true, "functools.lru_cache.__name__ is 'lru_cache'"]
    - [fne004, functools.cache.__name__.__eq__, ["cache"], true, "functools.cache.__name__ is 'cache'"]
    - [fne005, functools.total_ordering.__name__.__eq__, ["total_ordering"], true, "functools.total_ordering.__name__ is 'total_ordering'"]
    - [fne006, functools.singledispatch.__name__.__eq__, ["singledispatch"], true, "functools.singledispatch.__name__ is 'singledispatch'"]
    - [fne007, functools.wraps.__name__.__eq__, ["wraps"], true, "functools.wraps.__name__ is 'wraps'"]

table functools_extra290.function_modules:
  description: "Verify __module__ attribute for key functools callables"
  kind: python_call_eq
  category: identity
  id_prefix: fnm

  columns: [id, function, args, expected, description]
  rows:
    - [fnm001, functools.reduce.__module__.__eq__, ["functools"], true, "functools.reduce.__module__ is 'functools'"]
    - [fnm002, functools.partial.__module__.__eq__, ["functools"], true, "functools.partial.__module__ is 'functools'"]
    - [fnm003, functools.lru_cache.__module__.__eq__, ["functools"], true, "functools.lru_cache.__module__ is 'functools'"]
    - [fnm004, functools.cache.__module__.__eq__, ["functools"], true, "functools.cache.__module__ is 'functools'"]
    - [fnm005, functools.total_ordering.__module__.__eq__, ["functools"], true, "functools.total_ordering.__module__ is 'functools'"]
    - [fnm006, functools.singledispatch.__module__.__eq__, ["functools"], true, "functools.singledispatch.__module__ is 'functools'"]
    - [fnm007, functools.wraps.__module__.__eq__, ["functools"], true, "functools.wraps.__module__ is 'functools'"]

table functools_extra290.docstring_types:
  description: "Verify __doc__ attribute is a string for key functools callables"
  kind: python_call_eq
  category: identity
  id_prefix: fnd

  columns: [id, function, args, expected, description]
  rows:
    - [fnd001, functools.reduce.__doc__.__class__.__name__.__eq__, ["str"], true, "functools.reduce.__doc__ is a str"]
    - [fnd002, functools.partial.__doc__.__class__.__name__.__eq__, ["str"], true, "functools.partial.__doc__ is a str"]
    - [fnd003, functools.lru_cache.__doc__.__class__.__name__.__eq__, ["str"], true, "functools.lru_cache.__doc__ is a str"]
    - [fnd004, functools.total_ordering.__doc__.__class__.__name__.__eq__, ["str"], true, "functools.total_ordering.__doc__ is a str"]
    - [fnd005, functools.singledispatch.__doc__.__class__.__name__.__eq__, ["str"], true, "functools.singledispatch.__doc__ is a str"]
    - [fnd006, functools.wraps.__doc__.__class__.__name__.__eq__, ["str"], true, "functools.wraps.__doc__ is a str"]

invariant functools_extra290.reduce_module_check:
  description: "functools.reduce.__module__ equals 'functools'"
  category: identity
  kind: python_call_eq
  function: functools.reduce.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra290.partial_module_check:
  description: "functools.partial.__module__ equals 'functools'"
  category: identity
  kind: python_call_eq
  function: functools.partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra290.lru_cache_qualname_nonempty:
  description: "functools.lru_cache.__qualname__ is a non-empty string"
  category: identity
  kind: python_call_eq
  function: functools.lru_cache.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra290.cache_qualname_nonempty:
  description: "functools.cache.__qualname__ is a non-empty string"
  category: identity
  kind: python_call_eq
  function: functools.cache.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra290.partial_doc_is_str:
  description: "functools.partial.__doc__ is a str (not None)"
  category: identity
  kind: python_call_eq
  function: functools.partial.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
