spec: re_extra1921
version: ">=3.9"
backend: python_module(re)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "Wave 575 (_extra1921): __slots__, __abstractmethods__, __subclasshook__, __init_subclass__ checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "re.Pattern and re.Match are C extension types (_sre.SRE_Pattern, _sre.SRE_Match); they have no Python-level __slots__ in their __dict__."
    - "re.error was renamed to re.PatternError in Python 3.13; re.error remains as an alias. re.error.__name__ == 'PatternError' on Python 3.14."
    - "re.error (PatternError) is a Python exception class; it does not define __slots__ in its own __dict__."
    - "re.RegexFlag is an IntFlag enum subclass; enums do not use __slots__ in their class __dict__."
    - "None of the re types are abstract; __abstractmethods__ is absent from all their __dict__s."
    - "None of the re types define __subclasshook__ in their own __dict__."
    - "None of the re types define __init_subclass__ in their own __dict__."
    - "re.Pattern.__dict__ does not contain __slots__, __abstractmethods__, __subclasshook__, or __init_subclass__ — it is a C type."
    - "re.Match.__dict__ does not contain __slots__, __abstractmethods__, __subclasshook__, or __init_subclass__ — it is a C type."
  created_at: "2026-04-12"

error_model: python_exceptions

table re_extra1921.slots_protocol:
  description: "re types __slots__ dict-presence checks — all false, C types and exception do not define Python __slots__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1921

  columns: [id, function, args, expected]
  rows:
    - ["re1921001", "re.Pattern.__dict__.__contains__", ["__slots__"], false]
    - ["re1921002", "re.Match.__dict__.__contains__", ["__slots__"], false]
    - ["re1921003", "re.error.__dict__.__contains__", ["__slots__"], false]
    - ["re1921004", "re.RegexFlag.__dict__.__contains__", ["__slots__"], false]

