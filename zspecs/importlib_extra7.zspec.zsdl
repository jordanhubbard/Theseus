spec: importlib_extra7
version: ">=3.9"
backend: python_module(importlib)

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.html — Python importlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
    - "CPython source: Lib/importlib/_bootstrap.py"
    - "importlib_util.zspec.zsdl — covers importlib.util functions via python_module(importlib.util) backend"
    - "importlib_abc.zspec.zsdl — covers importlib.abc classes via python_module(importlib.abc) backend"
  notes:
    - "This spec extends importlib.zspec.zsdl through importlib_extra6.zspec.zsdl."
    - "Prior specs cover: function __name__/__qualname__/__module__ for import_module/reload/invalidate_caches; module __name__/__package__/__spec__.__class__.__name__; util submodule __name__/__package__; abc.__package__; util function __name__/__qualname__/__module__ for find_spec/module_from_spec/spec_from_file_location/spec_from_loader; abc.Loader __module__/__qualname__."
    - "This spec adds new axes: importlib.__loader__.__class__.__name__ (SourceFileLoader), importlib.__spec__.name, importlib.__file__.__class__.__name__ (str), importlib.__file__ ends with __init__.py."
    - "This spec also adds util.LazyLoader class attrs: __name__, __module__, __qualname__, __bases__[0].__name__."
    - "This spec also adds util.decode_source function attrs: __name__, __module__, __qualname__."
    - "importlib.__loader__.__class__.__name__ == 'SourceFileLoader' — importlib is a regular package loaded from source."
    - "importlib.__spec__.name == 'importlib' — the module spec's name matches the module name."
    - "importlib.__file__.__class__.__name__ == 'str' — __file__ is a string path."
    - "importlib.util.LazyLoader.__module__ == 'importlib.util' — LazyLoader is defined in importlib.util."
    - "importlib.util.LazyLoader.__bases__[0].__name__ == 'Loader' — LazyLoader extends abc.Loader."
    - "importlib.util.decode_source.__module__ == '_frozen_importlib_external' — defined in frozen external bootstrap."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# importlib module loader — __class__.__name__
# importlib is loaded from source (not frozen), so its __loader__ is a
# SourceFileLoader from _frozen_importlib_external.
# ---------------------------------------------------------------------------

invariant importlib_extra7.loader_class_name:
  description: "importlib.__loader__.__class__.__name__ == 'SourceFileLoader'"
  category: module_attrs
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.__spec__.name — the module spec records the canonical name
# ---------------------------------------------------------------------------

invariant importlib_extra7.spec_name:
  description: "importlib.__spec__.name == 'importlib'"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["importlib"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.__file__ — the path to the package __init__.py
# __file__ is a str and ends with __init__.py (the package root).
# ---------------------------------------------------------------------------

invariant importlib_extra7.file_is_str:
  description: "importlib.__file__.__class__.__name__ == 'str'"
  category: module_attrs
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant importlib_extra7.file_ends_with_init:
  description: "importlib.__file__.endswith('__init__.py') == True"
  category: module_attrs
  kind: python_call_eq
  function: __file__.endswith
  args: ["__init__.py"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.util.LazyLoader — class identity attributes
# LazyLoader is a concrete Loader subclass in importlib.util that defers
# module execution until the module's attributes are first accessed.
# ---------------------------------------------------------------------------

invariant importlib_extra7.util_LazyLoader.name:
  description: "importlib.util.LazyLoader.__name__ == 'LazyLoader'"
  category: class_attrs
  kind: python_call_eq
  function: util.LazyLoader.__name__.__eq__
  args: ["LazyLoader"]
  expected: true

invariant importlib_extra7.util_LazyLoader.module:
  description: "importlib.util.LazyLoader.__module__ == 'importlib.util'"
  category: class_attrs
  kind: python_call_eq
  function: util.LazyLoader.__module__.__eq__
  args: ["importlib.util"]
  expected: true

invariant importlib_extra7.util_LazyLoader.qualname:
  description: "importlib.util.LazyLoader.__qualname__ == 'LazyLoader'"
  category: class_attrs
  kind: python_call_eq
  function: util.LazyLoader.__qualname__.__eq__
  args: ["LazyLoader"]
  expected: true

invariant importlib_extra7.util_LazyLoader.base_is_Loader:
  description: "importlib.util.LazyLoader.__bases__[0].__name__ == 'Loader'"
  category: class_hierarchy
  kind: python_call_eq
  function: util.LazyLoader.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Loader"

# ---------------------------------------------------------------------------
# importlib.util.decode_source — function identity attributes
# decode_source is defined in the frozen external bootstrap; it converts
# bytes source code to a str, handling encoding declarations.
# ---------------------------------------------------------------------------

invariant importlib_extra7.util_decode_source.name:
  description: "importlib.util.decode_source.__name__ == 'decode_source'"
  category: function_attrs
  kind: python_call_eq
  function: util.decode_source.__name__.__eq__
  args: ["decode_source"]
  expected: true

invariant importlib_extra7.util_decode_source.module:
  description: "importlib.util.decode_source.__module__ == '_frozen_importlib_external'"
  category: function_attrs
  kind: python_call_eq
  function: util.decode_source.__module__.__eq__
  args: ["_frozen_importlib_external"]
  expected: true

invariant importlib_extra7.util_decode_source.qualname:
  description: "importlib.util.decode_source.__qualname__ == 'decode_source'"
  category: function_attrs
  kind: python_call_eq
  function: util.decode_source.__qualname__.__eq__
  args: ["decode_source"]
  expected: true
