spec: re_extra394
version: ">=3.11"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.NOFLAG was added in Python 3.11; its value is 0 (the null flag, representing no flags set)"
    - "re.RegexFlag.__name__ == 'RegexFlag' and __module__ == 're'; it inherits from IntFlag"
    - "re.RegexFlag.IGNORECASE.value == 2 (also accessible as re.I)"
    - "re.RegexFlag.MULTILINE.value == 8 (also accessible as re.M)"
    - "re.RegexFlag.DOTALL.value == 16 (also accessible as re.S)"
    - "re.RegexFlag.VERBOSE.value == 64 (also accessible as re.X)"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.NOFLAG — null flag value (Python 3.11+)
# ---------------------------------------------------------------------------

table re_extra394.noflag_value:
  description: "re.NOFLAG value identity — re.NOFLAG == 0; NOFLAG was added in Python 3.11 to represent the absence of any flags; it is a member of re.RegexFlag with integer value 0; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: renoflag394

  columns: [id, function, args, expected]
  rows:
    - [noflag_eq_zero, re.NOFLAG.__eq__, [0], true]

# ---------------------------------------------------------------------------
# re.RegexFlag class identity — __name__ and __module__
# ---------------------------------------------------------------------------

table re_extra394.regexflag_class_identity:
  description: "re.RegexFlag class identity — __name__ == 'RegexFlag', __module__ == 're'; RegexFlag is an IntFlag enumeration holding all re module flags; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: reregexflagid394

  columns: [id, function, args, expected]
  rows:
    - [name_val,   re.RegexFlag.__name__.__eq__,   ["RegexFlag"], true]
    - [module_val, re.RegexFlag.__module__.__eq__, ["re"],        true]

# ---------------------------------------------------------------------------
# re.RegexFlag member values — IGNORECASE, MULTILINE, DOTALL, VERBOSE
# ---------------------------------------------------------------------------

table re_extra394.regexflag_member_values:
  description: "re.RegexFlag member integer values — IGNORECASE==2, MULTILINE==8, DOTALL==16, VERBOSE==64; these are the canonical flag bit values used by the re module since Python 2; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: reregexflagvals394

  columns: [id, function, args, expected]
  rows:
    - [ignorecase_val, re.RegexFlag.IGNORECASE.value.__eq__, [2],  true]
    - [multiline_val,  re.RegexFlag.MULTILINE.value.__eq__,  [8],  true]
    - [dotall_val,     re.RegexFlag.DOTALL.value.__eq__,     [16], true]
    - [verbose_val,    re.RegexFlag.VERBOSE.value.__eq__,    [64], true]
