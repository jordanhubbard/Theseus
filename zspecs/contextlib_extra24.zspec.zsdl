spec: contextlib_extra24
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib.zspec.zsdl through contextlib_extra23.zspec.zsdl."
    - "contextlib_extra23 covers: AbstractContextManager/__module__ standalone; AbstractAsyncContextManager/__module__ standalone; nullcontext/__bases__[0].__name__ standalone; combined __bases__[0].__name__ table for five classes; contextmanager/__module__ standalone; asynccontextmanager/__module__ standalone."
    - "contextlib_extra22 covers: ExitStack/__enter__/__exit__ and AsyncExitStack/__aenter__/__aexit__ method __name__ and __qualname__."
    - "contextlib_extra21 covers: nullcontext/__name__/__qualname__/__module__; AbstractContextManager/__name__/__qualname__; AbstractAsyncContextManager/__name__/__qualname__."
    - "Focus of this spec: (1) combined __qualname__ table for contextmanager/asynccontextmanager/suppress/redirect_stdout/redirect_stderr/closing/nullcontext/ExitStack; (2) combined __qualname__.__len__ table for those eight names; (3) redirect_stdout.__mro__.__len__ == 5 standalone; (4) redirect_stderr.__mro__.__len__ == 5 standalone; (5) ExitStack.__mro__.__len__ == 5 standalone; (6) redirect_stdout.__mro__[1].__name__ == '_RedirectStream' standalone."
    - "NOT yet covered (entering this spec): combined __qualname__ table for all eight names in the extra24 namespace; combined __qualname__.__len__ table; redirect_stdout.__mro__.__len__ == 5 standalone; redirect_stderr.__mro__.__len__ == 5 standalone; ExitStack.__mro__.__len__ == 5 standalone; redirect_stdout.__mro__[1].__name__ standalone."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for eight key contextlib names
#
# No prior spec collects all eight — contextmanager, asynccontextmanager,
# suppress, redirect_stdout, redirect_stderr, closing, nullcontext, ExitStack —
# together in one combined __qualname__ table under the extra24 namespace.
# ---------------------------------------------------------------------------

table contextlib_extra24.names_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [contextmanager,      contextmanager.__qualname__.__eq__,      ["contextmanager"],      true]
    - [asynccontextmanager, asynccontextmanager.__qualname__.__eq__, ["asynccontextmanager"], true]
    - [suppress,            suppress.__qualname__.__eq__,            ["suppress"],            true]
    - [redirect_stdout,     redirect_stdout.__qualname__.__eq__,     ["redirect_stdout"],     true]
    - [redirect_stderr,     redirect_stderr.__qualname__.__eq__,     ["redirect_stderr"],     true]
    - [closing,             closing.__qualname__.__eq__,             ["closing"],             true]
    - [nullcontext,         nullcontext.__qualname__.__eq__,         ["nullcontext"],         true]
    - [ExitStack,           ExitStack.__qualname__.__eq__,           ["ExitStack"],           true]

# ---------------------------------------------------------------------------
# __qualname__.__len__ for eight key contextlib names
#
# contextmanager len 14, asynccontextmanager len 19, suppress len 8,
# redirect_stdout len 15, redirect_stderr len 15, closing len 7,
# nullcontext len 11, ExitStack len 9.
# No prior spec collects all eight lengths together in one combined table.
# ---------------------------------------------------------------------------

table contextlib_extra24.names_qualname_lens:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [contextmanager,      contextmanager.__qualname__.__len__,      [], 14]
    - [asynccontextmanager, asynccontextmanager.__qualname__.__len__, [], 19]
    - [suppress,            suppress.__qualname__.__len__,            [], 8]
    - [redirect_stdout,     redirect_stdout.__qualname__.__len__,     [], 15]
    - [redirect_stderr,     redirect_stderr.__qualname__.__len__,     [], 15]
    - [closing,             closing.__qualname__.__len__,             [], 7]
    - [nullcontext,         nullcontext.__qualname__.__len__,         [], 11]
    - [ExitStack,           ExitStack.__qualname__.__len__,           [], 9]

# ---------------------------------------------------------------------------
# redirect_stdout.__mro__.__len__() == 5
#
# redirect_stdout MRO: [redirect_stdout, _RedirectStream, AbstractContextManager,
# ABC, object]. No prior spec covers redirect_stdout.__mro__.__len__() as a
# standalone invariant.
# ---------------------------------------------------------------------------

invariant contextlib_extra24.redirect_stdout.mro.len:
  description: "contextlib.redirect_stdout.__mro__.__len__() == 5 — MRO depth through _RedirectStream and AbstractContextManager"
  category: class_hierarchy
  kind: python_call_eq
  function: redirect_stdout.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# redirect_stderr.__mro__.__len__() == 5
#
# redirect_stderr MRO: [redirect_stderr, _RedirectStream, AbstractContextManager,
# ABC, object]. No prior spec covers redirect_stderr.__mro__.__len__() as a
# standalone invariant.
# ---------------------------------------------------------------------------

invariant contextlib_extra24.redirect_stderr.mro.len:
  description: "contextlib.redirect_stderr.__mro__.__len__() == 5 — MRO depth through _RedirectStream and AbstractContextManager"
  category: class_hierarchy
  kind: python_call_eq
  function: redirect_stderr.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# ExitStack.__mro__.__len__() == 5
#
# ExitStack MRO: [ExitStack, _BaseExitStack, AbstractContextManager, ABC, object].
# No prior spec covers ExitStack.__mro__.__len__() as a standalone invariant.
# ---------------------------------------------------------------------------

invariant contextlib_extra24.ExitStack.mro.len:
  description: "contextlib.ExitStack.__mro__.__len__() == 5 — MRO depth through _BaseExitStack and AbstractContextManager"
  category: class_hierarchy
  kind: python_call_eq
  function: ExitStack.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# redirect_stdout.__mro__[1].__name__ == '_RedirectStream'
#
# The second entry in redirect_stdout's MRO is the private mix-in
# _RedirectStream. No prior spec accesses this via __getitem__ as a
# standalone invariant.
# ---------------------------------------------------------------------------

invariant contextlib_extra24.redirect_stdout.mro.index1.name:
  description: "contextlib.redirect_stdout.__mro__[1].__name__ == '_RedirectStream' — immediate base is the private _RedirectStream mixin"
  category: class_hierarchy
  kind: python_call_eq
  function: "redirect_stdout.__mro__.__getitem__(1).__name__.__eq__"
  args: ["_RedirectStream"]
  expected: true

# ---------------------------------------------------------------------------
# redirect_stderr.__mro__[1].__name__ == '_RedirectStream'
#
# redirect_stderr shares the same private mixin _RedirectStream as its
# immediate base class. No prior spec verifies this via __getitem__ as a
# standalone invariant.
# ---------------------------------------------------------------------------

invariant contextlib_extra24.redirect_stderr.mro.index1.name:
  description: "contextlib.redirect_stderr.__mro__[1].__name__ == '_RedirectStream' — immediate base is the private _RedirectStream mixin"
  category: class_hierarchy
  kind: python_call_eq
  function: "redirect_stderr.__mro__.__getitem__(1).__name__.__eq__"
  args: ["_RedirectStream"]
  expected: true
