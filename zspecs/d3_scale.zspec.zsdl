spec: d3_scale
version: ">=4.0.0"
backend: node(d3-scale)

docs: https://d3js.org/d3-scale

provenance:
  derived_from:
    - "d3-scale docs — https://d3js.org/d3-scale"
    - "Test vectors verified with d3-scale via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "d3-scale source"
  notes:
    - "Map between data domain and visual range — linear / log / pow / band / point / quantize / quantile."
    - "Install: npm install d3-scale"
    - "v4 ESM only; named exports per scale type."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factories; never throw on valid domain/range types."
  stderr: "null"
  stickiness: "N/A — each scale instance independent."
  codes: {}

invariant d3_scale.linear_default_domain_range:
  description: "scaleLinear() with default [0,1] domain → [0,1] range maps 0.5 to 0.5"
  category: linear
  kind: node_chain_eq
  entry: named
  function: scaleLinear
  entry_args: []
  chain:
    - {call: [0.5]}
  expected: 0.5

invariant d3_scale.linear_50_to_unit:
  description: "scaleLinear().domain([0,100]).range([0,1])(50) is 0.5"
  category: linear
  kind: node_chain_eq
  entry: named
  function: scaleLinear
  entry_args: []
  chain:
    - {method: domain, args: [[0, 100]]}
    - {method: range, args: [[0, 1]]}
    - {call: [50]}
  expected: 0.5

invariant d3_scale.linear_endpoints:
  description: "Linear scale endpoints map exactly"
  category: linear
  kind: node_chain_eq
  entry: named
  function: scaleLinear
  entry_args: []
  chain:
    - {method: domain, args: [[0, 100]]}
    - {method: range, args: [[0, 1]]}
    - {call: [100]}
  expected: 1

invariant d3_scale.linear_zero_endpoint:
  description: "Linear scale at lower domain endpoint"
  category: linear
  kind: node_chain_eq
  entry: named
  function: scaleLinear
  entry_args: []
  chain:
    - {method: domain, args: [[0, 100]]}
    - {method: range, args: [[0, 1]]}
    - {call: [0]}
  expected: 0

invariant d3_scale.linear_quarter:
  description: "Linear scale at 25% of domain"
  category: linear
  kind: node_chain_eq
  entry: named
  function: scaleLinear
  entry_args: []
  chain:
    - {method: domain, args: [[0, 100]]}
    - {method: range, args: [[0, 1]]}
    - {call: [25]}
  expected: 0.25

invariant d3_scale.linear_invert:
  description: ".invert(0.5) returns 50 (domain ↔ range inversion)"
  category: linear
  kind: node_chain_eq
  entry: named
  function: scaleLinear
  entry_args: []
  chain:
    - {method: domain, args: [[0, 100]]}
    - {method: range, args: [[0, 1]]}
    - {method: invert, args: [0.5]}
  expected: 50

invariant d3_scale.scaleLinear_export_present:
  description: "scaleLinear is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "scaleLinear.constructor.name"}
  expected: "Function"

invariant d3_scale.scaleLog_export_present:
  description: "scaleLog is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "scaleLog.constructor.name"}
  expected: "Function"

invariant d3_scale.scaleBand_export_present:
  description: "scaleBand is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "scaleBand.constructor.name"}
  expected: "Function"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T16:54:32Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
