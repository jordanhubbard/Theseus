spec: abc_extra2791
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "abc_extra.zspec.zsdl — covers abstractmethod.__isabstractmethod__, ABC.__subclasshook__, ABC.__abstractmethods__, ABCMeta.__instancecheck__, get_cache_token"
    - "abc_extra2.zspec.zsdl — covers __name__, __module__, __qualname__, metaclass identity for ABC, ABCMeta, abstractmethod"
    - "abc_extra2776.zspec.zsdl — covers __isub__, __imul__, __itruediv__ dict-presence checks"
  notes:
    - "Wave 633 theme: __iand__, __ior__, and __ixor__ dict-presence checks (in-place bitwise operators)."
    - "None of the abc public objects define __iand__, __ior__, or __ixor__ in their __dict__."
    - "ABCMeta is a metaclass (type of type); ABC is the abstract base class helper; abstractmethod is a decorator."
    - "abc.abstractproperty was removed in Python 3.13; it is not covered in this spec."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta — __iand__/__ior__/__ixor__ dict-presence checks
#
# ABCMeta is the metaclass for abstract base classes. Its __dict__ contains
# metaclass machinery (__instancecheck__, __subclasscheck__, register, etc.)
# but no in-place bitwise operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2791.abcmeta_operator_dict:
  description: "abc.ABCMeta __iand__, __ior__, __ixor__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2791am

  columns: [id, function, args, expected]
  rows:
    - ["ab2791am_iand",  abc.ABCMeta.__dict__.__contains__, ["__iand__"],  false]
    - ["ab2791am_ior",   abc.ABCMeta.__dict__.__contains__, ["__ior__"],   false]
    - ["ab2791am_ixor",  abc.ABCMeta.__dict__.__contains__, ["__ixor__"],  false]

# ---------------------------------------------------------------------------
# abc.ABC — __iand__/__ior__/__ixor__ dict-presence checks
#
# ABC is the convenience helper class for creating abstract base classes via
# inheritance. Its __dict__ is minimal (only __doc__ and __abstractmethods__).
# It does not define in-place bitwise operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2791.abc_operator_dict:
  description: "abc.ABC __iand__, __ior__, __ixor__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2791abc

  columns: [id, function, args, expected]
  rows:
    - ["ab2791abc_iand",  abc.ABC.__dict__.__contains__, ["__iand__"],  false]
    - ["ab2791abc_ior",   abc.ABC.__dict__.__contains__, ["__ior__"],   false]
    - ["ab2791abc_ixor",  abc.ABC.__dict__.__contains__, ["__ixor__"],  false]

# ---------------------------------------------------------------------------
# abc.abstractmethod — __iand__/__ior__/__ixor__ dict-presence checks
#
# abstractmethod is a pure-Python decorator function. Its __dict__ holds only
# __isabstractmethod__ == True and the usual function attributes. It does not
# implement in-place bitwise operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2791.abstractmethod_operator_dict:
  description: "abc.abstractmethod __iand__, __ior__, __ixor__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2791abm

  columns: [id, function, args, expected]
  rows:
    - ["ab2791abm_iand",  abc.abstractmethod.__dict__.__contains__, ["__iand__"],  false]
    - ["ab2791abm_ior",   abc.abstractmethod.__dict__.__contains__, ["__ior__"],   false]
    - ["ab2791abm_ixor",  abc.abstractmethod.__dict__.__contains__, ["__ixor__"],  false]

# ---------------------------------------------------------------------------
# Full cross-type matrix — ABCMeta, ABC, abstractmethod × three in-place bitwise operator dunders
#
# Consolidates the 3×3 dict-presence check (excluding deprecated abstractproperty)
# in one table. Every cell is False: ABCMeta, ABC, and abstractmethod do not
# define &=, |=, or ^= operator dunders in their __dict__.
# ---------------------------------------------------------------------------

table abc_extra2791.all_types_iand_ior_ixor_matrix:
  description: "Full 3×3 dict-presence matrix for abc.ABCMeta, abc.ABC, abc.abstractmethod vs __iand__/__ior__/__ixor__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2791mx

  columns: [id, function, args, expected]
  rows:
    - ["ab2791mx_am_ia",  abc.ABCMeta.__dict__.__contains__,        ["__iand__"],  false]
    - ["ab2791mx_am_io",  abc.ABCMeta.__dict__.__contains__,        ["__ior__"],   false]
    - ["ab2791mx_am_ix",  abc.ABCMeta.__dict__.__contains__,        ["__ixor__"],  false]
    - ["ab2791mx_ac_ia",  abc.ABC.__dict__.__contains__,            ["__iand__"],  false]
    - ["ab2791mx_ac_io",  abc.ABC.__dict__.__contains__,            ["__ior__"],   false]
    - ["ab2791mx_ac_ix",  abc.ABC.__dict__.__contains__,            ["__ixor__"],  false]
    - ["ab2791mx_ab_ia",  abc.abstractmethod.__dict__.__contains__, ["__iand__"],  false]
    - ["ab2791mx_ab_io",  abc.abstractmethod.__dict__.__contains__, ["__ior__"],   false]
    - ["ab2791mx_ab_ix",  abc.abstractmethod.__dict__.__contains__, ["__ixor__"],  false]
