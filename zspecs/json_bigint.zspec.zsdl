spec: json_bigint
version: ">=1.0.0"
backend: node(json-bigint)

docs: https://github.com/sidorares/json-bigint#readme

provenance:
  derived_from:
    - "json-bigint README — https://github.com/sidorares/json-bigint#readme"
    - "RFC 8259 §6 — Numbers (interoperability with arbitrary-precision integers)"
    - "Test vectors verified with json-bigint via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "json-bigint source"
  notes:
    - "JSON.parse / JSON.stringify replacement that preserves arbitrary-precision integers as BigNumber instances."
    - "Install: npm install json-bigint"
    - "v1 CJS; module export IS a configure factory but also has parse/stringify static-style attached."
    - "Default behavior: numbers larger than Number.MAX_SAFE_INTEGER become BigNumber instances on parse."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws SyntaxError on malformed JSON (parse) or unsupported value types (stringify)."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant json_bigint.has_parse:
  description: ".parse() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "parse.constructor.name"}
  expected: "Function"

invariant json_bigint.has_stringify:
  description: ".stringify() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "stringify.constructor.name"}
  expected: "Function"

invariant json_bigint.parse_safe_integer:
  description: "parse('{\"a\":1}').a is 1"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["{\"a\":1}"]
  chain:
    - {get: a}
  expected: 1

invariant json_bigint.parse_string_value:
  description: "parse('{\"name\":\"alice\"}').name is 'alice'"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["{\"name\":\"alice\"}"]
  chain:
    - {get: name}
  expected: "alice"

invariant json_bigint.parse_big_integer_returns_bignumber:
  description: "parse with a 20-digit integer yields BigNumber on .x"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["{\"x\":12345678901234567890}"]
  chain:
    - {get: "x.constructor.name"}
  expected: "BigNumber"

invariant json_bigint.stringify_object:
  description: "stringify({x:1}) returns '{\"x\":1}'"
  category: stringify
  kind: node_chain_eq
  entry: named
  function: stringify
  entry_args: [{"x": 1}]
  chain: []
  expected: "{\"x\":1}"

invariant json_bigint.stringify_array:
  description: "stringify([1,2,3]) returns '[1,2,3]'"
  category: stringify
  kind: node_chain_eq
  entry: named
  function: stringify
  entry_args: [[1, 2, 3]]
  chain: []
  expected: "[1,2,3]"
