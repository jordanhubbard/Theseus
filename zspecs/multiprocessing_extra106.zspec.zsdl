invariant multiprocessing_extra106.BaseManager_base_is_object:
  description: "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__('object') returns True — BaseManager inherits directly from object with MRO [BaseManager, object] (length=2); BaseManager.__module__=='multiprocessing.managers'; BaseManager.__qualname__=='BaseManager' (len=11); SyncManager inherits from BaseManager (mro length=3 — one more); BaseManager is the abstract base class for manager classes providing a way to create shared state across processes; type(BaseManager.start).__name__=='function' (Python-defined); type(BaseManager.connect).__name__=='function' (Python-defined); NEW in extra106: first standalone BaseManager base invariant in mpmanager106 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra106.SyncManager_base_is_BaseManager:
  description: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__('BaseManager') returns True — SyncManager inherits from BaseManager giving MRO [SyncManager, BaseManager, object] (length=3); SyncManager.__module__=='multiprocessing.managers'; SyncManager.__qualname__=='SyncManager' (len=11, same length as BaseManager.__qualname__.__len__()==11); SyncManager.__mro__.__len__()==3 vs BaseManager.__mro__.__len__()==2; SyncManager is the concrete subclass of BaseManager that provides shared proxy objects for synchronization primitives (Lock, RLock, Condition, Semaphore, Queue, etc.) and built-in collections (dict, list); NEW in extra106: first standalone SyncManager base invariant in mpmanager106 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__"
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra106.BaseManager_start_co_argcount_3:
  description: "multiprocessing.managers.BaseManager.start.__code__.co_argcount == 3 — start takes self, initializer, and initargs; BaseManager.start.__qualname__=='BaseManager.start' (len=17); type(BaseManager.start).__name__=='function' (Python-defined in Lib/multiprocessing/managers.py); compare co_argcount values: connect=1 (fewest), join=2, start=3; register=7 (most — takes typeid, callable, proxytype, exposed, method_to_typeid, create_method plus self); start() spawns a server process (or connects to one) to manage shared state; co_argcount=3 for start reflects that initializer and initargs are optional kwargs for setting up the manager server process; NEW in extra106: first standalone BaseManager.start argcount invariant in mpmanager106 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.start.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant multiprocessing_extra106.BaseManager_register_co_argcount_7:
  description: "multiprocessing.managers.BaseManager.register.__code__.co_argcount == 7 — register takes self, typeid, callable, proxytype, exposed, method_to_typeid, and create_method; this is the most arguments of any BaseManager method in this spec; BaseManager.register.__qualname__=='BaseManager.register' (len=20, longest method qualname in spec: 'BaseManager.'=12+'register'=8=20); compare co_argcount values across this spec: connect=1 (fewest), join=2, start=3, register=7 (most); the large number of register arguments reflects its role as the class method API for configuring what types the manager exposes as proxy objects; NEW in extra106: first standalone BaseManager.register argcount invariant in mpmanager106 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.register.__code__.co_argcount.__eq__
  args: [7]
  expected: true

invariant multiprocessing_extra106.SyncManager_mro_len_3:
  description: "multiprocessing.managers.SyncManager.__mro__.__len__() == 3 — SyncManager has MRO [SyncManager, BaseManager, object] (length=3); compare: BaseManager.__mro__.__len__()==2 ([BaseManager, object]) — SyncManager adds one level by inheriting from BaseManager; SyncManager.__module__=='multiprocessing.managers'; SyncManager.__qualname__=='SyncManager' (len=11); SyncManager.__bases__[0].__name__=='BaseManager'; SyncManager provides the full concrete implementation used by multiprocessing.Manager() factory function; the mro length difference (SyncManager=3, BaseManager=2) reflects the inheritance chain; both have __name__.__len__()==11 (same character count); NEW in extra106: first standalone SyncManager mro length invariant in mpmanager106 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: multiprocessing.managers.SyncManager.__mro__.__len__
  args: []
  expected: 3

