spec: multiprocessing_extra106
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "This spec extends multiprocessing_extra105.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing.managers.BaseManager and SyncManager class identity. NEW in extra106: multiprocessing.managers.BaseManager.__name__=='BaseManager', __bases__[0].__name__=='object', __mro__.__len__()==2; BaseManager.__module__=='multiprocessing.managers'; type(BaseManager.start).__name__=='function' (Python-defined); BaseManager.start.__qualname__=='BaseManager.start' (len=17, co_argcount=3: self, initializer, initargs); type(BaseManager.connect).__name__=='function'; BaseManager.connect.__qualname__=='BaseManager.connect' (len=19, co_argcount=1: self only); multiprocessing.managers.SyncManager.__name__=='SyncManager', __bases__[0].__name__=='BaseManager', __mro__.__len__()==3; SyncManager.__module__=='multiprocessing.managers'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.BaseManager.__bases__[0].__name__ == 'object'. BaseManager inherits directly from object with MRO [BaseManager, object] (length=2). BaseManager is the abstract base for manager classes. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.BaseManager.start.__code__.co_argcount == 3. The three parameters are self, initializer, and initargs. BaseManager.connect.__code__.co_argcount == 1 (self only). BaseManager.register.__code__.co_argcount == 7 (most args of any BaseManager method). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager'. SyncManager inherits from BaseManager with MRO [SyncManager, BaseManager, object] (length=3). SyncManager.__module__=='multiprocessing.managers'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

