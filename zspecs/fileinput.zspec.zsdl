spec: fileinput
version: ">=3.2"
backend: python_module(fileinput)

docs: https://docs.python.org/3/library/fileinput.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/fileinput.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fileinput.py (internal implementation)"
  notes:
    - "fileinput provides iteration over lines from multiple files or stdin."
    - "fileinput.input() returns the global FileInput instance (or creates one)."
    - "fileinput.FileInput is the underlying class; the module-level functions delegate to a global instance."
    - "fileinput.hook_compressed() and fileinput.hook_encoded() are openhook factory functions."
    - "Module-level state functions (filename, fileno, lineno, filelineno, isfirstline, isstdin, nextfile, close) operate on the active global FileInput instance."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name metadata
# ---------------------------------------------------------------------------

invariant fileinput.FileInput_name:
  description: "fileinput.FileInput.__name__ == 'FileInput'"
  category: classes
  kind: python_call_eq
  function: FileInput.__name__.__eq__
  args: ["FileInput"]
  expected: true

invariant fileinput.FileInput_module:
  description: "fileinput.FileInput.__module__ == 'fileinput'"
  category: classes
  kind: python_call_eq
  function: FileInput.__module__.__eq__
  args: ["fileinput"]
  expected: true

# ---------------------------------------------------------------------------
# Function name metadata — module-level functions
# ---------------------------------------------------------------------------

table fileinput.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [input,            input.__name__.__eq__,            ["input"],            true]
    - [filename,         filename.__name__.__eq__,          ["filename"],         true]
    - [fileno,           fileno.__name__.__eq__,            ["fileno"],           true]
    - [lineno,           lineno.__name__.__eq__,            ["lineno"],           true]
    - [filelineno,       filelineno.__name__.__eq__,        ["filelineno"],       true]
    - [isfirstline,      isfirstline.__name__.__eq__,       ["isfirstline"],      true]
    - [isstdin,          isstdin.__name__.__eq__,           ["isstdin"],          true]
    - [nextfile,         nextfile.__name__.__eq__,          ["nextfile"],         true]
    - [close,            close.__name__.__eq__,             ["close"],            true]
    - [hook_compressed,  hook_compressed.__name__.__eq__,   ["hook_compressed"],  true]
    - [hook_encoded,     hook_encoded.__name__.__eq__,      ["hook_encoded"],     true]

