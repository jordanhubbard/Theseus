spec: theseus_html_parser_cr
version: ">=3.0"
backend: python_cleanroom(theseus_html_parser_cr)
blocks: html.parser

docs: https://docs.python.org/3/library/html.parser.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/html.parser.html"
  not_derived_from:
    - "CPython source: Lib/html/parser.py"
  notes:
    - "Clean-room html.parser module. Do NOT import html.parser."

error_model: python_exceptions

invariant theseus_html_parser_cr.htmlparser2_parse:
  description: "HTMLParser can parse HTML tags"
  category: behavior
  kind: python_call_eq
  function: htmlparser2_parse
  args: []
  expected: true

invariant theseus_html_parser_cr.htmlparser2_entities:
  description: "unescape() handles HTML entities"
  category: behavior
  kind: python_call_eq
  function: htmlparser2_entities
  args: []
  expected: true

invariant theseus_html_parser_cr.htmlparser2_error:
  description: "HTMLParseError exception class exists"
  category: behavior
  kind: python_call_eq
  function: htmlparser2_error
  args: []
  expected: true
