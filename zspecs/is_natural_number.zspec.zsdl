spec: is_natural_number
version: ">=4.0.1"
backend: node(is-natural-number)

docs: https://www.npmjs.com/package/is-natural-number

provenance:
  derived_from:
    - "is-natural-number README — https://www.npmjs.com/package/is-natural-number"
    - "Test vectors verified with is-natural-number via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-natural-number source"
  notes:
    - "is-natural-number is an npm package. Install: npm install is-natural-number"
    - "Returns true if the value is a natural number (positive integer, >= 1)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_natural_number.isNaturalNumber:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: isnat

  columns: [id, args, expected]
  rows:
    - [five,     [5],    true]
    - [one,      [1],    true]
    - [zero,     [0],    false]
    - [neg,      [-1],   false]
    - [float,    [1.5],  false]
