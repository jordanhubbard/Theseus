spec: pp3406
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 674 (pp3406): __bool__, __str__, __repr__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __bool__/__str__/__repr__ dict-presence (bool(x), str(x), repr(x))."
    - "No pathlib class defines __bool__ in its own __dict__: path objects are filesystem path abstractions; bool() truthiness is not explicitly defined on any pathlib class."
    - "No pathlib class defines __str__ in its own __dict__: path objects do not implement custom string conversion in their own __dict__; str() uses inherited behavior."
    - "No pathlib class defines __repr__ in its own __dict__: path objects do not implement custom repr in their own __dict__; repr() uses inherited behavior."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all conversion operators absent from pathlib class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bool__ dict-presence — operator.contains(Cls.__dict__, '__bool__')
#
# No pathlib class defines __bool__ in its own __dict__; all false.
# pathlib path objects are filesystem path abstractions; bool() truthiness
# is not explicitly defined on any pathlib class.
# ---------------------------------------------------------------------------

table pp3406.bool:
  description: "pathlib types __bool__ dict-presence checks; wave 674"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3406

  columns: [id, function, args, expected]
  rows:
    - ["pp3406001", operator.contains, [pathlib.PurePath.__dict__,         "__bool__"], false]
    - ["pp3406002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__bool__"], false]
    - ["pp3406003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__bool__"], false]
    - ["pp3406004", operator.contains, [pathlib.Path.__dict__,             "__bool__"], false]
    - ["pp3406005", operator.contains, [pathlib.PosixPath.__dict__,        "__bool__"], false]

