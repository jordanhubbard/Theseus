spec: functools_extra57
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra56.zspec.zsdl."
    - "Prior specs covered: partialmethod.__class__.__name__ == 'type' (extra44); partialmethod.__class__.__name__.__len__()==4 for partial (extra44 via partial, not partialmethod directly); partialmethod.__module__.__eq__('functools') (extra12/extra19); partialmethod.__module__.__len__()==9 (extra19); partialmethod.__name__.__eq__('partialmethod') (extra15); partialmethod.__qualname__.__eq__('partialmethod') (extra15); partialmethod.__mro__.__len__()==2 (extra19/extra21); partialmethod.__bases__[0].__name__=='object' (extra10); cache.__class__.__name__.__eq__('function') (extra44); cache.__name__.__eq__('cache') (extra18); cache.__qualname__.__eq__('cache') (extra18); cache.__qualname__.__len__()==5 (extra18); cache.__module__.__eq__('functools') (extra19); cache.__module__.__len__()==9 (extra19); WRAPPER_ASSIGNMENTS/__class__/__qualname__/__eq__('tuple') (extra56); WRAPPER_UPDATES/__class__/__qualname__/__eq__('tuple') (extra56); __all__/__class__/__name__/__eq__('list') (extra56); functools.__name__.__eq__('functools') (extra56)."
    - "This spec covers: functools.partialmethod.__class__.__qualname__.__eq__('type')==true; functools.partialmethod.__class__.__name__.__len__()==4 (partialmethod specifically, not partial); functools.partialmethod.__class__.__qualname__.__len__()==4; functools.cache.__module__.__class__.__name__.__eq__('str')==true; functools.cache.__name__.__len__()==5; functools.cache.__qualname__.__class__.__name__.__eq__('str')==true; functools.partialmethod.__name__.__class__.__name__.__eq__('str')==true; functools.partialmethod.__qualname__.__class__.__name__.__eq__('str')==true."
    - "Key findings: functools.partialmethod is a pure-Python class (metaclass 'type') defined at module level in Lib/functools.py. The built-in 'type' metaclass has __name__ == __qualname__ == 'type' (4 chars) because it is a top-level built-in type with no enclosing class scope. Prior extra44 confirmed partialmethod.__class__.__name__ == 'type' via __eq__, but no prior spec records partialmethod.__class__.__qualname__ (the qualname form). partialmethod.__class__.__name__.__len__() == 4 was noted for partial in extra44 but not recorded as an explicit row for partialmethod. functools.cache (Python 3.9+) is a plain Python function; its __module__ string 'functools' (9 chars) is itself a Python str object. cache.__name__ 'cache' has length 5 (confirmed as qualname len in extra18 but not name len). The __class__.__name__ of string attributes ('str') is a useful coverage dimension not yet recorded for cache or partialmethod attributes specifically. All eight invariants are new to extra57."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.partialmethod.__class__.__qualname__ — extra57 namespace
#
# functools.partialmethod is a pure-Python class in Lib/functools.py. Its
# metaclass is the built-in 'type'. The type built-in has:
#   __name__     == 'type'  (4 chars)
#   __qualname__ == 'type'  (4 chars — top-level type, no enclosing scope)
# Prior extra44 confirmed partialmethod.__class__.__name__.__eq__('type') == True.
# No prior functools spec records partialmethod.__class__.__qualname__.__eq__ or
# partialmethod.__class__.__qualname__.__len__. Both are new to extra57.
# Additionally, partialmethod.__class__.__name__.__len__() == 4 was confirmed for
# the partial class in extra44 but never recorded as a dedicated row for
# partialmethod. This is recorded here alongside the qualname form.
# ---------------------------------------------------------------------------

table functools_extra57.partialmethod_class_qualname:
  description: "functools.partialmethod.__class__.__qualname__ == 'type' and __len__()==4 — partialmethod is a pure-Python class; its metaclass is the built-in 'type'; type.__qualname__ == type.__name__ == 'type' (4 chars); qualname form not recorded in any prior functools spec"
  kind: python_call_eq
  category: identity
  id_prefix: functoolspm57

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_class_qualname_eq,
       partialmethod.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "functools.partialmethod.__class__.__qualname__ == 'type' — partialmethod is a pure-Python class defined at module level in Lib/functools.py; its metaclass is the built-in 'type'; the type built-in is a top-level class so __qualname__ == __name__ == 'type' (4 chars); prior extra44 confirmed __class__.__name__.__eq__('type'); this is the first __class__.__qualname__.__eq__ check for partialmethod; new to extra57"]
    - [partialmethod_class_qualname_len,
       partialmethod.__class__.__qualname__.__len__,
       [],
       4,
       "functools.partialmethod.__class__.__qualname__.__len__() == 4 — type.__qualname__ is 'type' (4 chars); consistent with partialmethod.__class__.__name__.__len__()==4 because type.__qualname__ == type.__name__; first time this length is recorded specifically for partialmethod (extra44 recorded it for partial but not partialmethod); new to extra57"]
    - [partialmethod_class_name_len,
       partialmethod.__class__.__name__.__len__,
       [],
       4,
       "functools.partialmethod.__class__.__name__.__len__() == 4 — type.__name__ is 'type' (4 chars); extra44 confirmed partialmethod.__class__.__name__.__eq__('type') and recorded partial.__class__.__name__.__len__()==4; this records the length form specifically for partialmethod as a dedicated row; new to extra57"]

# ---------------------------------------------------------------------------
# functools.partialmethod string attribute __class__.__name__ — extra57 namespace
#
# functools.partialmethod.__name__ is 'partialmethod' (13 chars, a Python str).
# functools.partialmethod.__qualname__ is 'partialmethod' (13 chars, a Python str).
# Both are Python string objects, so __class__.__name__ == 'str' (3 chars).
# Prior specs confirmed the string values via __eq__ (extra15) and their lengths
# via __len__ (extra15), but no prior spec records __class__.__name__.__eq__ for
# these string attributes of partialmethod. Both are new to extra57.
# ---------------------------------------------------------------------------

table functools_extra57.partialmethod_string_attrs_class_name:
  description: "functools.partialmethod.__name__ and __qualname__ are Python str objects — __class__.__name__ == 'str' (3 chars); prior specs confirmed the string values and lengths but not the class-of-string form for partialmethod attributes"
  kind: python_call_eq
  category: identity
  id_prefix: functoolspm57

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_name_class_name_eq,
       partialmethod.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partialmethod.__name__.__class__.__name__ == 'str' — partialmethod.__name__ is the Python string 'partialmethod' (13 chars); Python string objects have __class__ == str; the str built-in type has __name__ == 'str' (3 chars); extra15 confirmed partialmethod.__name__.__eq__('partialmethod'); this is the first __class__.__name__.__eq__ check for partialmethod.__name__; new to extra57"]
    - [partialmethod_qualname_class_name_eq,
       partialmethod.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partialmethod.__qualname__.__class__.__name__ == 'str' — partialmethod.__qualname__ is the Python string 'partialmethod' (13 chars; qualname equals name because partialmethod is a top-level class); Python string objects have __class__ == str; str.__name__ == 'str' (3 chars); extra15 confirmed partialmethod.__qualname__.__eq__('partialmethod'); this is the first __class__.__name__.__eq__ check for partialmethod.__qualname__; new to extra57"]

# ---------------------------------------------------------------------------
# functools.cache string attribute class checks — extra57 namespace
#
# functools.cache (Python 3.9+) is a plain Python function. Its string
# attributes (__name__ == 'cache', __module__ == 'functools') are Python str
# objects. Prior specs confirmed:
#   cache.__name__.__eq__('cache') (extra18)
#   cache.__qualname__.__eq__('cache') (extra18)
#   cache.__qualname__.__len__()==5 (extra18)
#   cache.__module__.__eq__('functools') (extra19)
#   cache.__module__.__len__()==9 (extra19)
# No prior spec records cache.__name__.__len__() or the __class__.__name__ of
# any cache string attribute. Both are new to extra57.
# ---------------------------------------------------------------------------

table functools_extra57.cache_string_attrs:
  description: "functools.cache string attribute class checks — cache.__name__.__len__()==5 and __module__.__class__.__name__=='str'; cache is a pure-Python function (Python 3.9+); prior specs confirmed __name__/__qualname__/__module__ string values and lengths but not all forms"
  kind: python_call_eq
  category: identity
  id_prefix: functoolspm57

  columns: [id, function, args, expected, description]
  rows:
    - [cache_name_len,
       cache.__name__.__len__,
       [],
       5,
       "functools.cache.__name__.__len__() == 5 — 'cache' has 5 characters; cache is a pure-Python function added in Python 3.9 (PEP-3.9 stdlib additions); extra18 confirmed cache.__name__.__eq__('cache') and cache.__qualname__.__len__()==5 but the length form specifically for __name__ was not recorded as a row; new to extra57"]
    - [cache_module_class_name_eq,
       cache.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.cache.__module__.__class__.__name__ == 'str' — cache.__module__ is the string 'functools' (9 chars); Python string objects have __class__ == str; str.__name__ == 'str' (3 chars); extra19 confirmed cache.__module__.__eq__('functools') and cache.__module__.__len__()==9; this is the first __class__.__name__ check for cache.__module__; consistent with all pure-Python functools functions whose __module__ is a Python str; new to extra57"]
    - [cache_qualname_class_name_eq,
       cache.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.cache.__qualname__.__class__.__name__ == 'str' — cache.__qualname__ is the string 'cache' (5 chars; top-level function, no dotted prefix); Python string objects have __class__ == str; str.__name__ == 'str' (3 chars); extra18 confirmed cache.__qualname__.__eq__('cache') and cache.__qualname__.__len__()==5; this is the first __class__.__name__.__eq__ check for cache.__qualname__; new to extra57"]
