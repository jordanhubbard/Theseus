spec: json_extra8
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html
rfcs:
  - "RFC 8259 — The JavaScript Object Notation (JSON) Data Interchange Format"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json.zspec.zsdl and prior extras."
    - "json_extra6 covers JSONDecoder.__name__, JSONEncoder.__name__, JSONDecodeError.__name__."
    - "json_extra7 covers JSONDecoder.__module__, JSONEncoder.__module__, JSONDecoder.__qualname__, JSONEncoder.__qualname__, JSONDecodeError.__qualname__."
    - "Focus here: json.decoder.__name__ (submodule), json.encoder.__name__ (submodule), json.JSONDecodeError.__module__, json.JSONDecoder.__bases__[0].__name__, json.JSONEncoder.__bases__[0].__name__."
    - "json.decoder is a submodule; its __name__ attribute is 'json.decoder' (the fully qualified module name)."
    - "json.encoder is a submodule; its __name__ attribute is 'json.encoder' (the fully qualified module name)."
    - "json.JSONDecodeError.__module__ == 'json.decoder' — JSONDecodeError is defined in Lib/json/decoder.py."
    - "json.JSONDecoder.__bases__[0].__name__ == 'object' — JSONDecoder inherits directly from object."
    - "json.JSONEncoder.__bases__[0].__name__ == 'object' — JSONEncoder inherits directly from object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# json submodule __name__ attributes
# json.decoder and json.encoder are re-exported submodules. Their __name__
# is the fully qualified module name string.
# ---------------------------------------------------------------------------

invariant json_extra8.decoder_submodule.name:
  description: "json.decoder.__name__ == 'json.decoder' — submodule fully qualified name"
  category: submodules
  kind: python_call_eq
  function: decoder.__name__.__eq__
  args: ["json.decoder"]
  expected: true

invariant json_extra8.encoder_submodule.name:
  description: "json.encoder.__name__ == 'json.encoder' — submodule fully qualified name"
  category: submodules
  kind: python_call_eq
  function: encoder.__name__.__eq__
  args: ["json.encoder"]
  expected: true

# ---------------------------------------------------------------------------
# json.JSONDecodeError.__module__
# JSONDecodeError is defined in Lib/json/decoder.py, so __module__ == 'json.decoder'.
# json_extra7 checks JSONDecoder and JSONEncoder __module__; this adds JSONDecodeError.
# ---------------------------------------------------------------------------

invariant json_extra8.JSONDecodeError.module:
  description: "json.JSONDecodeError.__module__ == 'json.decoder'"
  category: modules
  kind: python_call_eq
  function: JSONDecodeError.__module__.__eq__
  args: ["json.decoder"]
  expected: true

# ---------------------------------------------------------------------------
# JSONDecoder and JSONEncoder base class hierarchy
# Both are top-level classes that inherit directly from object.
# json_extra7 checks JSONDecodeError base == ValueError; this adds
# JSONDecoder and JSONEncoder base checks (distinct classes, new invariants).
# ---------------------------------------------------------------------------

invariant json_extra8.JSONDecoder.base_is_object:
  description: "json.JSONDecoder.__bases__[0].__name__ == 'object' — JSONDecoder inherits from object"
  category: hierarchy
  kind: python_call_eq
  function: JSONDecoder.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant json_extra8.JSONEncoder.base_is_object:
  description: "json.JSONEncoder.__bases__[0].__name__ == 'object' — JSONEncoder inherits from object"
  category: hierarchy
  kind: python_call_eq
  function: JSONEncoder.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# json.decoder and json.encoder submodule __class__ identity
# A module's __class__.__name__ is 'module', confirming these are module objects.
# ---------------------------------------------------------------------------

invariant json_extra8.decoder_submodule.is_module:
  description: "json.decoder.__class__.__name__ == 'module' — decoder is a module object"
  category: submodules
  kind: python_call_eq
  function: decoder.__class__.__name__.__eq__
  args: ["module"]
  expected: true

invariant json_extra8.encoder_submodule.is_module:
  description: "json.encoder.__class__.__name__ == 'module' — encoder is a module object"
  category: submodules
  kind: python_call_eq
  function: encoder.__class__.__name__.__eq__
  args: ["module"]
  expected: true
