spec: theseus_typing_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_typing_cr2)
blocks: typing

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html"
  notes:
    - "Clean-room extended typing utilities. Do NOT import typing."
    - "TypeVar(name, *constraints, bound=None): type variable for generics."
    - "Generic: base class for generic types."
    - "Protocol: base class for structural subtyping (runtime_checkable)."
    - "Literal[...]: type that accepts specific literal values."
    - "Final: decorator/annotation to mark as final (no override)."
    - "typing2_typevar_name(): TypeVar('T').name == 'T'."
    - "typing2_typevar_constrained(): TypeVar('AnyStr', str, bytes).__constraints__ == (str, bytes)."
    - "typing2_literal(): Literal[1, 2, 3].__args__ == (1, 2, 3)."
    - "Export: TypeVar, Generic, Protocol, Literal, Final."
    - "For Literal: create a class with __args__ attribute set to the provided args tuple."
    - "For TypeVar: simple object storing name and constraints."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_typing_cr2.typevar_name:
  description: "TypeVar('T').name == 'T'"
  category: typevar
  kind: python_call_eq
  function: typing2_typevar_name
  args: []
  expected: "T"

invariant theseus_typing_cr2.typevar_constrained:
  description: "TypeVar('AnyStr', str, bytes).__constraints__ == (str, bytes)"
  category: typevar
  kind: python_call_eq
  function: typing2_typevar_constrained
  args: []
  expected: true

invariant theseus_typing_cr2.literal_args:
  description: "Literal[1, 2, 3].__args__ == (1, 2, 3)"
  category: literal
  kind: python_call_eq
  function: typing2_literal_args
  args: []
  expected: true
