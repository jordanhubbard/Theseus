spec: pydantic_v2_rust
version: ">=3.9"
backend: rust_module(pydantic_v2_rust)

docs: https://docs.pydantic.dev/latest/

provenance:
  derived_from:
    - "https://docs.pydantic.dev/latest/ — Pydantic v2 documentation"
  not_derived_from:
    - "pydantic source: pydantic/__init__.py"
  notes:
    - "Pydantic v2 provides data validation using Python type annotations."
    - "pydantic.BaseModel is available."
    - "class M(BaseModel): x: int; M(x=1).x == 1."
    - "class M(BaseModel): name: str; M(name='alice').name == 'alice'."
    - "pydantic.VERSION starts with '2'."
    - "Expose pydantic_v2_field_int(val) -> int: create model M with x:int, return M(x=val).x."
    - "Expose pydantic_v2_field_str(val) -> str: create model M with name:str, return M(name=val).name."
    - "Expose pydantic_v2_version_major() -> str: pydantic.VERSION.split('.')[0]."
    - "All test vectors verified against pydantic 2.11.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# pydantic_v2_field_int — integer field roundtrip
table pydantic_v2_rust.model.int_field:
  kind: python_call_eq
  category: int_field
  id_prefix: pdv2_i
  function: pydantic_v2_field_int

  columns: [id, args, expected]
  rows:
    - [one,    [1],   1]
    - [zero,   [0],   0]
    - [forty2, [42],  42]

# pydantic_v2_field_str — string field roundtrip
table pydantic_v2_rust.model.str_field:
  kind: python_call_eq
  category: str_field
  id_prefix: pdv2_s
  function: pydantic_v2_field_str

  columns: [id, args, expected]
  rows:
    - [alice, ["alice"], "alice"]
    - [bob,   ["bob"],   "bob"]

# pydantic_v2_version_major — major version is '2'
invariant pydantic_v2_rust.version.major_2:
  description: "pydantic.VERSION starts with '2'"
  category: version
  kind: python_call_eq
  function: pydantic_v2_version_major
  args: []
  expected: "2"

