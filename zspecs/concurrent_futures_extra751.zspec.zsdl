spec: concurrent_futures_extra751
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: Cover concurrent.futures exception class and symbol identity via __qualname__ and __module__ attributes
error_model: python_exceptions
provenance:
  derived_from:
    - concurrent.futures standard library documentation
    - CPython source concurrent/futures/_base.py
  not_derived_from:
    - any third-party futures or executor implementations
    - asyncio.Future (a distinct class hierarchy)
  notes:
    - exception classes in concurrent.futures._base are the canonical source
    - Future and Executor are base classes included for completeness
    - as_completed and wait are module-level convenience functions
  created_at: "2026-04-12"

table concurrent_futures_extra751.name:
  description: Identity checks for concurrent.futures exception classes and top-level symbols
  kind: python_call_eq
  category: module_identity
  id_prefix: cf751xx
  columns: [id, function, args, expected]
  rows:
    - [cf751xx001, concurrent.futures.CancelledError.__qualname__.__eq__, ["CancelledError"], true]
    - [cf751xx002, concurrent.futures.CancelledError.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf751xx003, concurrent.futures.TimeoutError.__qualname__.__eq__, ["TimeoutError"], true]
    - [cf751xx004, concurrent.futures.TimeoutError.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf751xx005, concurrent.futures.BrokenExecutor.__qualname__.__eq__, ["BrokenExecutor"], true]
    - [cf751xx006, concurrent.futures.BrokenExecutor.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf751xx007, concurrent.futures.InvalidStateError.__qualname__.__eq__, ["InvalidStateError"], true]
    - [cf751xx008, concurrent.futures.InvalidStateError.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf751xx009, concurrent.futures.Future.__qualname__.__eq__, ["Future"], true]
    - [cf751xx010, concurrent.futures.Executor.__qualname__.__eq__, ["Executor"], true]
    - [cf751xx011, concurrent.futures.as_completed.__qualname__.__eq__, ["as_completed"], true]
    - [cf751xx012, concurrent.futures.wait.__qualname__.__eq__, ["wait"], true]
