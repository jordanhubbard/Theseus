spec: struct_extra269
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/struct.py"
    - "struct_extra268.zspec.zsdl — covers Struct class identity and pack/calcsize for '!H'/'!I'/'!Q' formats."
    - "struct_extra267.zspec.zsdl — covers struct.error MRO length and struct.__all__ identity."
    - "struct_extra266.zspec.zsdl — covers struct module __spec__/__loader__ identity and _struct C extension identity."
    - "struct_extra263.zspec.zsdl — covers struct.error class identity and pack/unpack error cases."
  notes:
    - "struct.unpack('!H', b'\\x01\\x00') == (256,) — big-endian unsigned short 0x0100 decodes to integer 256. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.unpack('!I', b'\\x00\\x00\\x00\\x01') == (1,) — big-endian unsigned int 0x00000001 decodes to integer 1. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!B') == 1 — network-byte-order unsigned char requires 1 byte. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!b') == 1 — network-byte-order signed char requires 1 byte. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!H') == 2 — network-byte-order unsigned short requires 2 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!I') == 4 — network-byte-order unsigned int requires 4 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!Q') == 8 — network-byte-order unsigned long long requires 8 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "unpack returns a tuple: struct.unpack always returns a tuple even for a single field. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.unpack for network byte-order formats
# '!' means network byte order (big-endian). unpack always returns a tuple.
# unpack('!H', b'\x01\x00') == (256,): bytes [1, 0] in big-endian = 0x0100 = 256.
# unpack('!I', b'\x00\x00\x00\x01') == (1,): bytes [0,0,0,1] big-endian = 1.
# The single-element tuple form is the canonical unpack return type.
# ---------------------------------------------------------------------------

table struct_extra269.unpack_network_order_vectors:
  description: "struct.unpack network byte-order test vectors — unpack('!H',b'\\x01\\x00')==(256,); unpack('!I',b'\\x00\\x00\\x00\\x01')==(1,); result is always a tuple; verified with Python 3.14.3"
  kind: python_call_eq
  category: behavior
  id_prefix: unpack269

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_H_256,   unpack_excl_H_0100_result0.__eq__,   [256], true, "struct.unpack('!H', b'\\x01\\x00')[0] == 256 — big-endian unsigned short 0x0100 decodes to 256"]
    - [unpack_I_1,     unpack_excl_I_0001_result0.__eq__,   [1],   true, "struct.unpack('!I', b'\\x00\\x00\\x00\\x01')[0] == 1 — big-endian unsigned int 0x00000001 decodes to 1"]
    - [unpack_H_cls,   unpack_excl_H_0100_type_name.__eq__,  ["tuple"], true, "type(struct.unpack('!H', b'\\x01\\x00')).__name__ == 'tuple' — unpack always returns a tuple"]
    - [unpack_H_len,   unpack_excl_H_0100_len.__eq__,       [1],   true, "len(struct.unpack('!H', b'\\x01\\x00')) == 1 — single-field format produces one-element tuple"]
    - [unpack_I_len,   unpack_excl_I_0001_len.__eq__,       [1],   true, "len(struct.unpack('!I', b'\\x00\\x00\\x00\\x01')) == 1 — single-field format produces one-element tuple"]

# ---------------------------------------------------------------------------
# struct.calcsize for single-byte and common numeric formats
# '!B' (unsigned char) and '!b' (signed char) are both 1 byte — the smallest
# numeric format characters. '!H' is 2 bytes, '!I' is 4 bytes, '!Q' is 8 bytes.
# These sizes are fixed regardless of platform (network byte order enforces size).
# ---------------------------------------------------------------------------

table struct_extra269.calcsize_byte_and_short_formats:
  description: "struct.calcsize for single-byte and numeric formats — '!B'==1; '!b'==1; '!H'==2; '!I'==4; '!Q'==8; all platform-independent under network byte order; verified with Python 3.14.3"
  kind: python_call_eq
  category: behavior
  id_prefix: calcsize269

  columns: [id, function, args, expected, description]
  rows:
    - [calc_B,  calcsize_excl_B.__eq__,  [1], true, "struct.calcsize('!B') == 1 — unsigned char is always 1 byte"]
    - [calc_b,  calcsize_excl_b.__eq__,  [1], true, "struct.calcsize('!b') == 1 — signed char is always 1 byte"]
    - [calc_H,  calcsize_excl_H.__eq__,  [2], true, "struct.calcsize('!H') == 2 — unsigned short is 2 bytes"]
    - [calc_I,  calcsize_excl_I.__eq__,  [4], true, "struct.calcsize('!I') == 4 — unsigned int is 4 bytes"]
    - [calc_Q,  calcsize_excl_Q.__eq__,  [8], true, "struct.calcsize('!Q') == 8 — unsigned long long is 8 bytes"]

# ---------------------------------------------------------------------------
# Standalone invariants — unpack vectors and calcsize single-byte formats
# ---------------------------------------------------------------------------

invariant struct_extra269.unpack_H_256_eq:
  description: "struct.unpack('!H', b'\\x01\\x00')[0] == 256 — big-endian unsigned short: bytes [0x01, 0x00] decode to 0x0100 == 256; unpack returns a tuple so [0] extracts the integer; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: unpack_excl_H_0100_result0.__eq__
  args: [256]
  expected: true

invariant struct_extra269.unpack_I_1_eq:
  description: "struct.unpack('!I', b'\\x00\\x00\\x00\\x01')[0] == 1 — big-endian unsigned int: bytes [0x00, 0x00, 0x00, 0x01] decode to 1; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: unpack_excl_I_0001_result0.__eq__
  args: [1]
  expected: true

invariant struct_extra269.unpack_returns_tuple_eq:
  description: "type(struct.unpack('!H', b'\\x01\\x00')).__name__ == 'tuple' — struct.unpack always returns a tuple regardless of how many fields are in the format string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: unpack_excl_H_0100_type_name.__eq__
  args: ["tuple"]
  expected: true

invariant struct_extra269.calcsize_B_eq:
  description: "struct.calcsize('!B') == 1 — network-byte-order unsigned char ('B') requires exactly 1 byte; this is the smallest unsigned numeric format; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: calcsize_excl_B.__eq__
  args: [1]
  expected: true

invariant struct_extra269.calcsize_b_eq:
  description: "struct.calcsize('!b') == 1 — network-byte-order signed char ('b') requires exactly 1 byte; signed and unsigned char are both 1 byte in struct format; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: calcsize_excl_b.__eq__
  args: [1]
  expected: true

invariant struct_extra269.calcsize_H_eq:
  description: "struct.calcsize('!H') == 2 — network-byte-order unsigned short ('H') requires 2 bytes; size is fixed under '!' (network/big-endian) byte order; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: calcsize_excl_H.__eq__
  args: [2]
  expected: true

invariant struct_extra269.calcsize_I_eq:
  description: "struct.calcsize('!I') == 4 — network-byte-order unsigned int ('I') requires 4 bytes; fixed size under '!' byte order regardless of platform native int size; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: calcsize_excl_I.__eq__
  args: [4]
  expected: true

invariant struct_extra269.unpack_wrong_size_raises:
  description: "struct.unpack('!H', b'\\x01') raises struct.error — '!H' requires exactly 2 bytes but only 1 was provided; struct.error is raised for buffer size mismatches; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: errors
  kind: python_call_raises
  function: unpack
  args: ["!H", "AQ=="]
  raises: error
