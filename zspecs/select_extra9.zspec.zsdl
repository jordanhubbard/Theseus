spec: select_extra9
version: ">=3.9"
backend: python_module(select)

docs: https://docs.python.org/3/library/select.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/select.html — Python select module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/selectmodule.c"
  notes:
    - "Extends select.zspec.zsdl through select_extra8.zspec.zsdl."
    - "select_extra4 covers: kqueue/kevent __qualname__/__module__; select.__qualname__."
    - "select_extra6 covers: error.__qualname__ == 'OSError'; poll.__qualname__ == 'poll'."
    - "select.zspec covers: kqueue/__name__; kevent.__name__."
    - "This spec adds: kqueue/kevent __mro__ length (2); kqueue/kevent __bases__[0].__name__ == 'object'; __qualname__ string lengths for select/kqueue/kevent/error — no prior spec checks these lengths."
    - "kqueue and kevent are C extension types that inherit directly from object; __mro__ == [kqueue, object] — length 2."
    - "kqueue.__bases__ == (<class 'object'>,) — single direct base; __bases__[0].__name__ == 'object'."
    - "kevent.__bases__ == (<class 'object'>,) — single direct base; __bases__[0].__name__ == 'object'."
    - "select.__qualname__ == 'select' — length 6; kqueue.__qualname__ == 'kqueue' — length 6; kevent.__qualname__ == 'kevent' — length 6; error.__qualname__ == 'OSError' — length 7."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# kqueue and kevent MRO length
#
# No prior select spec checks __mro__ length for kqueue or kevent.
# Both are C extension types that inherit directly from object:
# [kqueue, object] and [kevent, object] — length 2 each.
# ---------------------------------------------------------------------------

invariant select_extra9.kqueue.mro_len:
  description: "select.kqueue.__mro__ has 2 entries — [kqueue, object]; C type with no intermediate base"
  category: class_hierarchy
  kind: python_call_eq
  function: kqueue.__mro__.__len__
  args: []
  expected: 2

invariant select_extra9.kevent.mro_len:
  description: "select.kevent.__mro__ has 2 entries — [kevent, object]; C type with no intermediate base"
  category: class_hierarchy
  kind: python_call_eq
  function: kevent.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# kqueue and kevent __bases__[0].__name__ == 'object'
#
# No prior select spec checks __bases__ for kqueue or kevent.
# Both C extension types have a single direct base: the built-in object type.
# ---------------------------------------------------------------------------

invariant select_extra9.kqueue.base_is_object:
  description: "select.kqueue.__bases__[0].__name__ == 'object' — kqueue inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: kqueue.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant select_extra9.kevent.base_is_object:
  description: "select.kevent.__bases__[0].__name__ == 'object' — kevent inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: kevent.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ string lengths for select, kqueue, kevent, error
#
# select_extra4 covers __qualname__.__eq__ for select/kqueue/kevent.
# select_extra6 covers error.__qualname__.__eq__.
# No prior spec checks the *length* of any __qualname__ string in the select module.
# select.__qualname__=='select'(6); kqueue.__qualname__=='kqueue'(6);
# kevent.__qualname__=='kevent'(6); error.__qualname__=='OSError'(7).
# ---------------------------------------------------------------------------

table select_extra9.qualname_lengths:
  description: "select module __qualname__ string lengths — no prior spec checks these lengths"
  kind: python_call_eq
  category: classes
  id_prefix: qnamelen

  columns: [id, function, args, expected]
  rows:
    - [select, select.__qualname__.__len__, [], 6]
    - [kqueue, kqueue.__qualname__.__len__, [], 6]
    - [kevent, kevent.__qualname__.__len__, [], 6]
    - [error,  error.__qualname__.__len__,  [], 7]
