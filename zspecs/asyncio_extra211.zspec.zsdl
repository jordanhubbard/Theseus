table asyncio_extra211.streamwriter_dict_core_methods:
  description: "asyncio.StreamWriter.__dict__.__contains__ checks for write/drain/close/wait_closed/get_extra_info in asynciostream211 namespace — all five are defined on StreamWriter; new to asyncio_extra211"
  kind: python_call_eq
  category: dict_membership
  id_prefix: asynciostream211

  columns: [id, function, args, expected, description]
  rows:
    - [streamwriter_has_write,
       "StreamWriter.__dict__.__contains__",
       ["write"],
       true,
       "asyncio.StreamWriter.__dict__.__contains__('write') == True — StreamWriter.write(data) writes bytes to the transport; new to asyncio_extra211; verified Python 3.14.3"]
    - [streamwriter_has_drain,
       "StreamWriter.__dict__.__contains__",
       ["drain"],
       true,
       "asyncio.StreamWriter.__dict__.__contains__('drain') == True — StreamWriter.drain() coroutine waits until transport write buffer is below high-water mark; new to asyncio_extra211; verified Python 3.14.3"]
    - [streamwriter_has_close,
       "StreamWriter.__dict__.__contains__",
       ["close"],
       true,
       "asyncio.StreamWriter.__dict__.__contains__('close') == True — StreamWriter.close() closes the underlying transport; new to asyncio_extra211; verified Python 3.14.3"]
    - [streamwriter_has_wait_closed,
       "StreamWriter.__dict__.__contains__",
       ["wait_closed"],
       true,
       "asyncio.StreamWriter.__dict__.__contains__('wait_closed') == True — StreamWriter.wait_closed() coroutine waits until stream is closed; new to asyncio_extra211; verified Python 3.14.3"]
    - [streamwriter_has_get_extra_info,
       "StreamWriter.__dict__.__contains__",
       ["get_extra_info"],
       true,
       "asyncio.StreamWriter.__dict__.__contains__('get_extra_info') == True — StreamWriter.get_extra_info(name) returns optional transport information; new to asyncio_extra211; verified Python 3.14.3"]

