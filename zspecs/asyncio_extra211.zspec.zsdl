spec: asyncio_extra211
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-stream.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-stream.html — Python asyncio streams documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/streams.py"
    - "CPython source: Lib/asyncio/__init__.py"
  notes:
    - "This spec covers asyncio.StreamReader.__dict__ and asyncio.StreamWriter.__dict__ membership checks."
    - "asyncio.StreamReader.__dict__.__contains__('read') == True — StreamReader.read(n) reads up to n bytes from the stream. Verified with Python 3.14.3."
    - "asyncio.StreamReader.__dict__.__contains__('readline') == True — StreamReader.readline() reads until newline. Verified with Python 3.14.3."
    - "asyncio.StreamReader.__dict__.__contains__('readexactly') == True — StreamReader.readexactly(n) reads exactly n bytes, raises IncompleteReadError if EOF. Verified with Python 3.14.3."
    - "asyncio.StreamReader.__dict__.__contains__('readuntil') == True — StreamReader.readuntil(separator) reads until separator. Verified with Python 3.14.3."
    - "asyncio.StreamReader.__dict__.__contains__('feed_data') == True — StreamReader.feed_data(data) appends bytes to the internal buffer. Verified with Python 3.14.3."
    - "asyncio.StreamReader.__dict__.__contains__('at_eof') == True — StreamReader.at_eof() returns True if EOF was received and buffer is empty. Verified with Python 3.14.3."
    - "asyncio.StreamWriter.__dict__.__contains__('write') == True — StreamWriter.write(data) writes bytes to the transport. Verified with Python 3.14.3."
    - "asyncio.StreamWriter.__dict__.__contains__('drain') == True — StreamWriter.drain() is a coroutine that waits until it's appropriate to resume writing. Verified with Python 3.14.3."
    - "asyncio.StreamWriter.__dict__.__contains__('close') == True — StreamWriter.close() closes the underlying transport. Verified with Python 3.14.3."
    - "asyncio.StreamWriter.__dict__.__contains__('wait_closed') == True — StreamWriter.wait_closed() waits until the stream is closed. Verified with Python 3.14.3."
    - "asyncio.StreamWriter.__dict__.__contains__('get_extra_info') == True — StreamWriter.get_extra_info(name) returns optional transport information. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.StreamReader.__dict__ read-method membership
#
# asyncio.StreamReader.__dict__.__contains__('read')        == True
# asyncio.StreamReader.__dict__.__contains__('readline')    == True
# asyncio.StreamReader.__dict__.__contains__('readexactly') == True
# asyncio.StreamReader.__dict__.__contains__('readuntil')   == True
#
# StreamReader's four read methods are all defined directly on the class.
# New to asyncio_extra211.
# ---------------------------------------------------------------------------

table asyncio_extra211.streamreader_dict_read_methods:
  description: "asyncio.StreamReader.__dict__.__contains__ checks for read/readline/readexactly/readuntil in asynciostream211 namespace — all four read methods are defined on StreamReader itself; new to asyncio_extra211"
  kind: python_call_eq
  category: dict_membership
  id_prefix: asynciostream211

  columns: [id, function, args, expected, description]
  rows:
    - [streamreader_has_read,
       "StreamReader.__dict__.__contains__",
       ["read"],
       true,
       "asyncio.StreamReader.__dict__.__contains__('read') == True — StreamReader.read(n) is defined on StreamReader; new to asyncio_extra211; verified Python 3.14.3"]
    - [streamreader_has_readline,
       "StreamReader.__dict__.__contains__",
       ["readline"],
       true,
       "asyncio.StreamReader.__dict__.__contains__('readline') == True — StreamReader.readline() reads until newline; new to asyncio_extra211; verified Python 3.14.3"]
    - [streamreader_has_readexactly,
       "StreamReader.__dict__.__contains__",
       ["readexactly"],
       true,
       "asyncio.StreamReader.__dict__.__contains__('readexactly') == True — StreamReader.readexactly(n) reads exactly n bytes; new to asyncio_extra211; verified Python 3.14.3"]
    - [streamreader_has_readuntil,
       "StreamReader.__dict__.__contains__",
       ["readuntil"],
       true,
       "asyncio.StreamReader.__dict__.__contains__('readuntil') == True — StreamReader.readuntil(separator) reads until separator; new to asyncio_extra211; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.StreamReader.__dict__ data-feed and EOF membership
#
# asyncio.StreamReader.__dict__.__contains__('feed_data') == True
# asyncio.StreamReader.__dict__.__contains__('at_eof')    == True
# asyncio.StreamReader.__dict__.__contains__('feed_eof')  == True
# asyncio.StreamReader.__dict__.__contains__('feed_data') == True  (confirmed)
#
# feed_data, at_eof, and feed_eof are the protocol-side methods on StreamReader.
# New to asyncio_extra211.
# ---------------------------------------------------------------------------

table asyncio_extra211.streamreader_dict_feed_eof:
  description: "asyncio.StreamReader.__dict__.__contains__ checks for feed_data/at_eof/feed_eof in asynciostream211 namespace — protocol-facing methods; new to asyncio_extra211"
  kind: python_call_eq
  category: dict_membership
  id_prefix: asynciostream211

  columns: [id, function, args, expected, description]
  rows:
    - [streamreader_has_feed_data,
       "StreamReader.__dict__.__contains__",
       ["feed_data"],
       true,
       "asyncio.StreamReader.__dict__.__contains__('feed_data') == True — StreamReader.feed_data(data) appends bytes to internal buffer; new to asyncio_extra211; verified Python 3.14.3"]
    - [streamreader_has_at_eof,
       "StreamReader.__dict__.__contains__",
       ["at_eof"],
       true,
       "asyncio.StreamReader.__dict__.__contains__('at_eof') == True — StreamReader.at_eof() returns True when EOF received and buffer empty; new to asyncio_extra211; verified Python 3.14.3"]
    - [streamreader_has_feed_eof,
       "StreamReader.__dict__.__contains__",
       ["feed_eof"],
       true,
       "asyncio.StreamReader.__dict__.__contains__('feed_eof') == True — StreamReader.feed_eof() signals end-of-file to the reader; new to asyncio_extra211; verified Python 3.14.3"]
    - [streamreader_has_exception,
       "StreamReader.__dict__.__contains__",
       ["exception"],
       true,
       "asyncio.StreamReader.__dict__.__contains__('exception') == True — StreamReader.exception() returns the exception if set; new to asyncio_extra211; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
