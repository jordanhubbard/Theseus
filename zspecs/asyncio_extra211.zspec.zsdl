invariant asyncio_extra211.streamreader_has_read:
  description: "asyncio.StreamReader.__dict__.__contains__('read') == True — StreamReader.read(n=-1) is defined on StreamReader; reads up to n bytes (all if n==-1); new to asyncio_extra211; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: "StreamReader.__dict__.__contains__"
  args: ["read"]
  expected: true

invariant asyncio_extra211.streamreader_has_readline:
  description: "asyncio.StreamReader.__dict__.__contains__('readline') == True — StreamReader.readline() reads one line (up to newline); new to asyncio_extra211; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: "StreamReader.__dict__.__contains__"
  args: ["readline"]
  expected: true

