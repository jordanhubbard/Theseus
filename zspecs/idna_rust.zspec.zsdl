synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T19:52:07Z
  iterations: 2
  pass_count: 14
  fail_count: 0
  total_invariants: 14
  notes: Synthesis succeeded in 2 iteration(s). 14 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
