spec: urllib_parse_extra21
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html
rfcs:
  - "RFC 3986 — Uniform Resource Identifier (URI): Generic Syntax"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
  notes:
    - "This spec extends urllib_parse_extra20.zspec.zsdl."
    - "Prior specs covered: urlparse/urlunparse/urljoin/urlencode/quote/unquote/urlsplit/urlunsplit __qualname__.__eq__, urlparse/urljoin/quote __module__.__len__()==12, parse_qs/__qualname__.__eq__."
    - "This spec covers: __module__.__len__()==12 for urlencode/unquote/urlsplit/quote_plus/unquote_plus/urldefrag/urlunsplit/urlunparse/parse_qs/parse_qsl, __name__.__len__() for urlparse/urlencode/quote/unquote/urljoin/urlsplit/quote_plus/unquote_plus/urldefrag/parse_qs/parse_qsl, ParseResult/__name__/__module__/__qualname__ __len__() checks."
    - "urllib.parse.urlencode.__module__ == 'urllib.parse' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.unquote.__module__ == 'urllib.parse' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.urlsplit.__module__ == 'urllib.parse' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.quote_plus.__module__ == 'urllib.parse' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.unquote_plus.__module__ == 'urllib.parse' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.urldefrag.__module__ == 'urllib.parse' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.parse_qs.__module__ == 'urllib.parse' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.parse_qsl.__module__ == 'urllib.parse' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.urlparse.__name__ == 'urlparse' (len 8). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.urlencode.__name__ == 'urlencode' (len 9). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.quote.__name__ == 'quote' (len 5). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.unquote.__name__ == 'unquote' (len 7). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.urljoin.__name__ == 'urljoin' (len 7). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.urlsplit.__name__ == 'urlsplit' (len 8). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.quote_plus.__name__ == 'quote_plus' (len 10). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.unquote_plus.__name__ == 'unquote_plus' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.urldefrag.__name__ == 'urldefrag' (len 9). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.parse_qs.__name__ == 'parse_qs' (len 8). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.parse_qsl.__name__ == 'parse_qsl' (len 9). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.ParseResult.__module__ == 'urllib.parse' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.ParseResult.__name__ == 'ParseResult' (len 11). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "urllib.parse.ParseResult.__qualname__ == 'ParseResult' (len 11). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() for urlencode, unquote, urlsplit
#
# extra20 covers urlparse/urljoin/quote __module__.__len__()==12 as standalones.
# These three continue the series; all have __module__ == 'urllib.parse' (len 12).
# ---------------------------------------------------------------------------

invariant urllib_parse_extra21.urlencode.module_len:
  description: "len(urllib.parse.urlencode.__module__) == 12 — len('urllib.parse') == 12"
  category: function_module
  kind: python_call_eq
  function: urlencode.__module__.__len__
  args: []
  expected: 12

invariant urllib_parse_extra21.unquote.module_len:
  description: "len(urllib.parse.unquote.__module__) == 12 — len('urllib.parse') == 12"
  category: function_module
  kind: python_call_eq
  function: unquote.__module__.__len__
  args: []
  expected: 12

invariant urllib_parse_extra21.urlsplit.module_len:
  description: "len(urllib.parse.urlsplit.__module__) == 12 — len('urllib.parse') == 12"
  category: function_module
  kind: python_call_eq
  function: urlsplit.__module__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# ParseResult __module__, __name__, __qualname__ __len__() standalones
#
# No prior spec measures ParseResult string attribute lengths as standalones.
# ParseResult.__module__ == 'urllib.parse' (len 12).
# ParseResult.__name__ == 'ParseResult' (len 11).
# ParseResult.__qualname__ == 'ParseResult' (len 11).
# ---------------------------------------------------------------------------

invariant urllib_parse_extra21.ParseResult.module_len:
  description: "len(urllib.parse.ParseResult.__module__) == 12 — len('urllib.parse') == 12"
  category: class_identity
  kind: python_call_eq
  function: ParseResult.__module__.__len__
  args: []
  expected: 12

invariant urllib_parse_extra21.ParseResult.name_len:
  description: "len(urllib.parse.ParseResult.__name__) == 11 — len('ParseResult') == 11"
  category: class_identity
  kind: python_call_eq
  function: ParseResult.__name__.__len__
  args: []
  expected: 11

invariant urllib_parse_extra21.ParseResult.qualname_len:
  description: "len(urllib.parse.ParseResult.__qualname__) == 11 — len('ParseResult') == 11"
  category: class_identity
  kind: python_call_eq
  function: ParseResult.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# __name__.__len__() for urlparse, urlencode, quote, unquote, urljoin, urlsplit
#
# For module-level functions, __name__ == the function name string.
# No prior spec records these __name__.__len__() values as standalones.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra21.urlparse.name_len:
  description: "len(urllib.parse.urlparse.__name__) == 8 — len('urlparse') == 8"
  category: function_identity
  kind: python_call_eq
  function: urlparse.__name__.__len__
  args: []
  expected: 8

invariant urllib_parse_extra21.urlencode.name_len:
  description: "len(urllib.parse.urlencode.__name__) == 9 — len('urlencode') == 9"
  category: function_identity
  kind: python_call_eq
  function: urlencode.__name__.__len__
  args: []
  expected: 9

invariant urllib_parse_extra21.quote.name_len:
  description: "len(urllib.parse.quote.__name__) == 5 — len('quote') == 5"
  category: function_identity
  kind: python_call_eq
  function: quote.__name__.__len__
  args: []
  expected: 5

invariant urllib_parse_extra21.unquote.name_len:
  description: "len(urllib.parse.unquote.__name__) == 7 — len('unquote') == 7"
  category: function_identity
  kind: python_call_eq
  function: unquote.__name__.__len__
  args: []
  expected: 7

invariant urllib_parse_extra21.urljoin.name_len:
  description: "len(urllib.parse.urljoin.__name__) == 7 — len('urljoin') == 7"
  category: function_identity
  kind: python_call_eq
  function: urljoin.__name__.__len__
  args: []
  expected: 7

invariant urllib_parse_extra21.urlsplit.name_len:
  description: "len(urllib.parse.urlsplit.__name__) == 8 — len('urlsplit') == 8"
  category: function_identity
  kind: python_call_eq
  function: urlsplit.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Table: __module__.__len__() for remaining urllib.parse functions
#
# extra20 covers urlparse/urljoin/quote (12) as standalones. This table extends
# coverage to urlencode/unquote/urlsplit/quote_plus/unquote_plus/urldefrag/
# parse_qs/parse_qsl. All share __module__ == 'urllib.parse' (len 12).
# ---------------------------------------------------------------------------

table urllib_parse_extra21.function_module_lengths:
  description: "urllib.parse function __module__ string lengths — all equal 12 (len('urllib.parse'))"
  kind: python_call_eq
  category: function_module

  columns: [id, function, args, expected]
  rows:
    - [urlencode_module_len,    urlencode.__module__.__len__,    [], 12]
    - [unquote_module_len,      unquote.__module__.__len__,      [], 12]
    - [urlsplit_module_len,     urlsplit.__module__.__len__,     [], 12]
    - [quote_plus_module_len,   quote_plus.__module__.__len__,   [], 12]
    - [unquote_plus_module_len, unquote_plus.__module__.__len__, [], 12]
    - [urldefrag_module_len,    urldefrag.__module__.__len__,    [], 12]
    - [parse_qs_module_len,     parse_qs.__module__.__len__,     [], 12]
    - [parse_qsl_module_len,    parse_qsl.__module__.__len__,    [], 12]

# ---------------------------------------------------------------------------
# Table: __name__.__len__() for urllib.parse functions
#
# No prior spec groups these name length measurements into a single table.
# quote_plus (10), unquote_plus (12), urldefrag (9), parse_qs (8), parse_qsl (9)
# supplement the standalones above (urlparse=8, urlencode=9, quote=5, unquote=7,
# urljoin=7, urlsplit=8) to provide a comprehensive name-length cross-check.
# ---------------------------------------------------------------------------

table urllib_parse_extra21.function_name_lengths:
  description: "urllib.parse function __name__ string lengths"
  kind: python_call_eq
  category: function_identity

  columns: [id, function, args, expected, description]
  rows:
    - [urlparse_name_len,
       urlparse.__name__.__len__,
       [],
       8,
       "len('urlparse') == 8"]
    - [urlencode_name_len,
       urlencode.__name__.__len__,
       [],
       9,
       "len('urlencode') == 9"]
    - [quote_name_len,
       quote.__name__.__len__,
       [],
       5,
       "len('quote') == 5"]
    - [unquote_name_len,
       unquote.__name__.__len__,
       [],
       7,
       "len('unquote') == 7"]
    - [urljoin_name_len,
       urljoin.__name__.__len__,
       [],
       7,
       "len('urljoin') == 7"]
    - [urlsplit_name_len,
       urlsplit.__name__.__len__,
       [],
       8,
       "len('urlsplit') == 8"]
    - [quote_plus_name_len,
       quote_plus.__name__.__len__,
       [],
       10,
       "len('quote_plus') == 10"]
    - [unquote_plus_name_len,
       unquote_plus.__name__.__len__,
       [],
       12,
       "len('unquote_plus') == 12"]
    - [urldefrag_name_len,
       urldefrag.__name__.__len__,
       [],
       9,
       "len('urldefrag') == 9"]
    - [parse_qs_name_len,
       parse_qs.__name__.__len__,
       [],
       8,
       "len('parse_qs') == 8"]
    - [parse_qsl_name_len,
       parse_qsl.__name__.__len__,
       [],
       9,
       "len('parse_qsl') == 9"]
