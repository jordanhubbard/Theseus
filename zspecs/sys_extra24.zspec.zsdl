spec: sys_extra24
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
    - "sys_extra7.zspec.zsdl — covers __qualname__ for exit/getrecursionlimit/setrecursionlimit/getsizeof/intern/exc_info/getdefaultencoding/getswitchinterval in a table; __class__.__qualname__ for float_info/int_info/hash_info/thread_info."
    - "sys_extra18.zspec.zsdl — covers version.__class__.__name__=='str'; platform.__class__.__name__=='str'; maxsize.__class__.__name__=='int'."
    - "sys_extra23.zspec.zsdl — covers __class__.__qualname__ for version/argv/path/modules/stdout/version_info."
  notes:
    - "This spec extends sys.zspec.zsdl through sys_extra23.zspec.zsdl."
    - "Focus: __qualname__ for sys.getrefcount (not in sys_extra7); __qualname__ for sys.getprofile/settrace/getdlopenflags (all uncovered); __class__.__qualname__ for sys.byteorder and sys.flags (uncovered)."
    - "sys.getrefcount.__qualname__ == 'getrefcount' — verified at runtime."
    - "sys.getprofile.__qualname__ == 'getprofile' — verified at runtime."
    - "sys.settrace.__qualname__ == 'settrace' — verified at runtime."
    - "sys.getdlopenflags.__qualname__ == 'getdlopenflags' — verified at runtime (macOS only)."
    - "sys.byteorder.__class__.__qualname__ == 'str' — byteorder is a plain str; verified at runtime."
    - "sys.flags.__class__.__qualname__ == 'flags' — flags is a named-tuple subclass; verified at runtime."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ — table for getrefcount, getprofile, settrace
#
# sys_extra7 covers __qualname__ for exit/getrecursionlimit/setrecursionlimit/
# getsizeof/intern/exc_info but does NOT include getrefcount, getprofile, or
# settrace. This table fills those gaps in the extra24 namespace.
# ---------------------------------------------------------------------------

table sys_extra24.function_qualnames:
  description: "__qualname__ for getrefcount, getprofile, settrace"
  kind: python_call_eq
  category: function_attrs
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [getrefcount, getrefcount.__qualname__.__eq__, ["getrefcount"], true]
    - [getprofile,  getprofile.__qualname__.__eq__,  ["getprofile"],  true]
    - [settrace,    settrace.__qualname__.__eq__,    ["settrace"],    true]

# ---------------------------------------------------------------------------
# sys.getdlopenflags — __qualname__ standalone
#
# sys.getdlopenflags exists on macOS and Linux (not on Windows). No prior sys
# spec checks getdlopenflags.__qualname__. This invariant anchors it in the
# extra24 namespace.
# ---------------------------------------------------------------------------

invariant sys_extra24.getdlopenflags.qualname:
  description: "sys.getdlopenflags.__qualname__ == 'getdlopenflags'"
  category: function_attrs
  kind: python_call_eq
  function: getdlopenflags.__qualname__.__eq__
  args: ["getdlopenflags"]
  expected: true

# ---------------------------------------------------------------------------
# sys.byteorder — __class__.__qualname__
#
# sys_extra18 checks byteorder as part of a type-class-name comparison
# (via __class__.__name__). No prior sys spec checks byteorder.__class__.__qualname__.
# byteorder is always a plain str, so its __class__.__qualname__ is 'str'.
# ---------------------------------------------------------------------------

invariant sys_extra24.byteorder.class_qualname:
  description: "sys.byteorder.__class__.__qualname__ == 'str'"
  category: type_attrs
  kind: python_call_eq
  function: byteorder.__class__.__qualname__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# sys.flags — __class__.__qualname__
#
# sys_extra7 checks flags.__class__.__qualname__ == 'flags' — verify: extra7
# covers the named-tuple structs float_info/int_info/hash_info/thread_info but
# NOT sys.flags. No prior sys spec checks flags.__class__.__qualname__.
# sys.flags is a named-tuple subclass whose __qualname__ is 'flags'.
# ---------------------------------------------------------------------------

invariant sys_extra24.flags.class_qualname:
  description: "sys.flags.__class__.__qualname__ == 'flags'"
  category: type_attrs
  kind: python_call_eq
  function: flags.__class__.__qualname__.__eq__
  args: ["flags"]
  expected: true

# ---------------------------------------------------------------------------
# sys.getrefcount — __qualname__ standalone re-anchor
#
# The table above covers getrefcount.__qualname__ in a row. This invariant
# re-anchors it as an explicit single-axis standalone in the extra24 namespace
# for direct lookup without table context.
# ---------------------------------------------------------------------------

invariant sys_extra24.getrefcount.qualname:
  description: "sys.getrefcount.__qualname__ == 'getrefcount'"
  category: function_attrs
  kind: python_call_eq
  function: getrefcount.__qualname__.__eq__
  args: ["getrefcount"]
  expected: true
