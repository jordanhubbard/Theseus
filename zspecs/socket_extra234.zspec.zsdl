spec: socket_extra234
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "_socket_extra.zspec.zsdl — covers _socket C extension identity"
    - "socket_extra233.zspec.zsdl — covers getdefaulttimeout.__doc__.__contains__ and setdefaulttimeout.__doc__.__contains__ contracts"
    - "socket_extra232.zspec.zsdl — covers socket module identity contracts"
    - "socket.zspec.zsdl — covers getdefaulttimeout()==None"
    - "socket_extra7.zspec.zsdl — covers getdefaulttimeout().__class__.__name__=='NoneType'"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.AF_UNIX is available on macOS/Linux (POSIX platforms); value is 1 on macOS."
    - "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' — AF_UNIX is an IntEnum member of AddressFamily."
    - "socket.AF_UNIX.__eq__(1) == True — AF_UNIX has integer value 1 on macOS/Linux."
    - "socket.AddressFamily.__name__ == 'AddressFamily' — the enum class name."
    - "socket.AddressFamily.__module__ == 'socket' — AddressFamily is defined in socket module."
    - "socket.SocketKind.__name__ == 'SocketKind' — the socket kind enum class name."
    - "socket.SocketKind.__module__ == 'socket' — SocketKind is defined in socket module."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily' — AF_INET is also an AddressFamily member."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — SOCK_STREAM is a SocketKind member."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_UNIX availability and class name contracts
#
# socket.AF_UNIX.__class__.__name__ == 'AddressFamily'
# socket.AF_UNIX.__eq__(1)          == True  (value is 1 on macOS/Linux)
#
# socket.AF_UNIX is an IntEnum member of socket.AddressFamily. Its integer
# value is 1 on macOS and Linux (the POSIX standard value). The class name
# of AF_UNIX is 'AddressFamily' — the enum class containing all AF_* constants.
# No prior socket_extra spec covers AF_UNIX class name or value contracts.
# ---------------------------------------------------------------------------

table socket_extra234.af_unix_contracts:
  description: "AF_UNIX.__class__.__name__=='AddressFamily'; AF_UNIX.__eq__(1)==True; AF_UNIX availability and class name contracts; new to socket_extra234"
  kind: python_call_eq
  category: af_unix
  id_prefix: socket234

  columns: [id, function, args, expected, description]
  rows:
    - [af_unix_class_name,
       "AF_UNIX.__class__.__name__.__eq__",
       ["AddressFamily"],
       true,
       "socket.AF_UNIX.__class__.__name__.__eq__('AddressFamily') == True — AF_UNIX is an IntEnum member of socket.AddressFamily; its __class__.__name__ is 'AddressFamily' (13 characters); novel class name anchor for AF constants; new to socket_extra234; verified Python 3.14.3"]
    - [af_unix_eq_1,
       "AF_UNIX.__eq__",
       [1],
       true,
       "socket.AF_UNIX.__eq__(1) == True — AF_UNIX has integer value 1 on POSIX platforms (macOS/Linux); this is the standard UNIX domain socket address family; novel value anchor for AF_UNIX; new to socket_extra234; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.AddressFamily class identity contracts
#
# socket.AddressFamily.__name__   == 'AddressFamily'
# socket.AddressFamily.__module__ == 'socket'
#
# AddressFamily is an IntEnum defined in the Python socket module (Lib/socket.py).
# It groups all AF_* address family constants. Novel to socket_extra234.
# ---------------------------------------------------------------------------

table socket_extra234.address_family_class_identity:
  description: "AddressFamily.__name__=='AddressFamily'; AddressFamily.__module__=='socket'; AddressFamily enum class identity contracts; new to socket_extra234"
  kind: python_call_eq
  category: class_identity
  id_prefix: socket234a

  columns: [id, function, args, expected, description]
  rows:
    - [af_class_name_eq,
       "AddressFamily.__name__.__eq__",
       ["AddressFamily"],
       true,
       "socket.AddressFamily.__name__.__eq__('AddressFamily') == True — AddressFamily is an IntEnum grouping all AF_* address family constants; class name is 'AddressFamily' (13 characters); novel class identity anchor; new to socket_extra234; verified Python 3.14.3"]
    - [af_class_module_eq,
       "AddressFamily.__module__.__eq__",
       ["socket"],
       true,
       "socket.AddressFamily.__module__.__eq__('socket') == True — AddressFamily is defined in Lib/socket.py (the Python wrapper module); __module__ is 'socket' not '_socket'; novel class module anchor; new to socket_extra234; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.SocketKind class identity contracts
#
# socket.SocketKind.__name__   == 'SocketKind'
# socket.SocketKind.__module__ == 'socket'
#
# SocketKind is an IntEnum defined in the Python socket module (Lib/socket.py).
# It groups all SOCK_* socket type constants. Novel to socket_extra234.
# ---------------------------------------------------------------------------

table socket_extra234.socket_kind_class_identity:
  description: "SocketKind.__name__=='SocketKind'; SocketKind.__module__=='socket'; SocketKind enum class identity contracts; new to socket_extra234"
  kind: python_call_eq
  category: class_identity
  id_prefix: socket234b

  columns: [id, function, args, expected, description]
  rows:
    - [sk_class_name_eq,
       "SocketKind.__name__.__eq__",
       ["SocketKind"],
       true,
       "socket.SocketKind.__name__.__eq__('SocketKind') == True — SocketKind is an IntEnum grouping all SOCK_* socket type constants; class name is 'SocketKind' (10 characters); novel class identity anchor; new to socket_extra234; verified Python 3.14.3"]
    - [sk_class_module_eq,
       "SocketKind.__module__.__eq__",
       ["socket"],
       true,
       "socket.SocketKind.__module__.__eq__('socket') == True — SocketKind is defined in Lib/socket.py; __module__ is 'socket'; novel class module anchor; new to socket_extra234; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.AF_INET and socket.SOCK_STREAM class name contracts
#
# socket.AF_INET.__class__.__name__    == 'AddressFamily'
# socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'
#
# AF_INET is a member of AddressFamily; SOCK_STREAM is a member of SocketKind.
# These confirm that the two enum classes contain the expected constants.
# Novel to socket_extra234.
# ---------------------------------------------------------------------------

invariant socket_extra234.af_inet_class_name:
  description: "socket.AF_INET.__class__.__name__.__eq__('AddressFamily') == True — AF_INET (IPv4 address family, integer value 2) is a member of the AddressFamily IntEnum; its __class__.__name__ is 'AddressFamily'; confirms AF_INET is in the same enum as AF_UNIX; novel class name anchor for AF_INET; socket_extra234 is the first namespace to anchor this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: "AF_INET.__class__.__name__.__eq__"
  args: ["AddressFamily"]
  expected: true

invariant socket_extra234.sock_stream_class_name:
  description: "socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind') == True — SOCK_STREAM (stream socket type, integer value 1) is a member of the SocketKind IntEnum; its __class__.__name__ is 'SocketKind'; confirms SOCK_STREAM is categorized under the correct enum; novel class name anchor for SOCK_STREAM; socket_extra234 is the first namespace to anchor this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: "SOCK_STREAM.__class__.__name__.__eq__"
  args: ["SocketKind"]
  expected: true

invariant socket_extra234.address_family_name_eq:
  description: "socket.AddressFamily.__name__.__eq__('AddressFamily') == True — AddressFamily is the IntEnum class in Lib/socket.py that enumerates all AF_* address family constants (AF_UNIX, AF_INET, AF_INET6, etc.); its __name__ is 'AddressFamily' (13 characters: 'Address' (7) + 'Family' (6)); the class is defined in the pure-Python socket module that wraps the _socket C extension; no prior socket_extra spec anchors AddressFamily.__name__ as a standalone; socket_extra234 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: "AddressFamily.__name__.__eq__"
  args: ["AddressFamily"]
  expected: true

invariant socket_extra234.socket_kind_name_eq:
  description: "socket.SocketKind.__name__.__eq__('SocketKind') == True — SocketKind is the IntEnum class in Lib/socket.py that enumerates all SOCK_* socket type constants (SOCK_STREAM, SOCK_DGRAM, SOCK_RAW, etc.); its __name__ is 'SocketKind' (10 characters: 'Socket' (6) + 'Kind' (4)); the class is defined in the pure-Python socket module alongside AddressFamily; no prior socket_extra spec anchors SocketKind.__name__ as a standalone; socket_extra234 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: "SocketKind.__name__.__eq__"
  args: ["SocketKind"]
  expected: true
