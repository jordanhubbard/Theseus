spec: socket_extra736
version: ">=3.9"
backend: python_module(socket)
docs: "Behavioral spec covering socket.socket method qualnames."
error_model: python_exceptions

provenance:
  derived_from:
    - python_stdlib_socket
  not_derived_from: []
  notes: "Covers socket.socket instance method qualnames for connection, I/O, and control operations."
  created_at: "2026-04-12"

table socket_extra736.method_qualnames:
  description: "Verifies socket.socket method qualnames for all standard networking operations."
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: sk736xx
  columns: [id, function, args, expected]
  rows:
    - [sk736xx001, socket.socket.connect.__qualname__.__eq__, ["socket.connect"], true]
    - [sk736xx002, socket.socket.bind.__qualname__.__eq__, ["socket.bind"], true]
    - [sk736xx003, socket.socket.listen.__qualname__.__eq__, ["socket.listen"], true]
    - [sk736xx004, socket.socket.accept.__qualname__.__eq__, ["socket.accept"], true]
    - [sk736xx005, socket.socket.send.__qualname__.__eq__, ["socket.send"], true]
    - [sk736xx006, socket.socket.recv.__qualname__.__eq__, ["socket.recv"], true]
    - [sk736xx007, socket.socket.close.__qualname__.__eq__, ["socket.close"], true]
    - [sk736xx008, socket.socket.shutdown.__qualname__.__eq__, ["socket.shutdown"], true]
    - [sk736xx009, socket.socket.setsockopt.__qualname__.__eq__, ["socket.setsockopt"], true]
    - [sk736xx010, socket.socket.getsockopt.__qualname__.__eq__, ["socket.getsockopt"], true]
    - [sk736xx011, socket.socket.fileno.__qualname__.__eq__, ["socket.fileno"], true]
    - [sk736xx012, socket.socket.makefile.__qualname__.__eq__, ["socket.makefile"], true]
