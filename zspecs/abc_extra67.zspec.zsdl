# Standalone invariants — extra67
# ---------------------------------------------------------------------------

invariant abc_extra67.abstractmethod_co_name:
  description: "abc.abstractmethod.__code__.co_name.__eq__('abstractmethod') returns True — abc.abstractmethod is a pure Python function in abc.py; its code object's co_name is 'abstractmethod'; NEW in extra67: first standalone co_name invariant for abstractmethod in the abcmore67 namespace; wave 238 first code object name invariant for abstractmethod; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: abstractmethod.__code__.co_name.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra67.abstractmethod_co_argcount_1:
  description: "abc.abstractmethod.__code__.co_argcount.__eq__(1) returns True — abc.abstractmethod takes a single argument funcobj; co_argcount is 1; NEW in extra67: first standalone co_argcount invariant for abstractmethod in the abcmore67 namespace; wave 238 first code object argcount invariant for abstractmethod; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: abstractmethod.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant abc_extra67.abstractmethod_varnames_tuple:
  description: "abc.abstractmethod.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — co_varnames is always a tuple in CPython; abstractmethod.__code__.co_varnames.__class__.__name__ is 'tuple'; NEW in extra67: first standalone co_varnames type invariant for abstractmethod in the abcmore67 namespace; wave 238 first co_varnames type invariant for abstractmethod; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: abstractmethod.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant abc_extra67.get_cache_token_class_name:
  description: "abc.get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') returns True — abc.get_cache_token is implemented in the _abc C extension module; its __class__.__name__ is 'builtin_function_or_method'; NEW in extra67: first standalone __class__.__name__ invariant for get_cache_token in the abcmore67 namespace; wave 238 first type identity invariant for get_cache_token; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra67.abstractproperty_dict_mappingproxy:
  description: "abc.abstractproperty.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — Python class __dict__ is always a mappingproxy; abstractproperty.__dict__.__class__.__name__ is 'mappingproxy'; NEW in extra67: first standalone __dict__.__class__.__name__ invariant for abstractproperty in the abcmore67 namespace; wave 238 first dict type invariant for abstractproperty; verified with Python 3.14.3"
  category: dict
  kind: python_call_eq
  function: abstractproperty.__dict__.__class__.__name__.__eq__
