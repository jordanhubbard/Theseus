table abc_extra67.ABCMeta_register_varnames:
  description: "abc ABCMeta.register.__code__.co_varnames checks in abcmore67 namespace — wave 238 theme: ABCMeta method code object co_varnames; ABCMeta.register.__code__.co_varnames.__class__.__name__=='tuple' (co_varnames is always a tuple in CPython); ABCMeta.register.__code__.co_varnames.__len__()==2 (varnames are ('cls', 'subclass')); NEW in extra67: first co_varnames length check for ABCMeta.register in the abcmore67 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abcmore67a

  columns: [id, function, args, expected, description]
  rows:
    - [register_varnames_cls, ABCMeta.register.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true, "ABCMeta.register.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple in CPython; ABCMeta.register.__code__.co_varnames.__class__.__name__ is 'tuple'; NEW in extra67: first co_varnames type check for ABCMeta.register in the abcmore67 namespace; verified with Python 3.14.3"]
    - [register_varnames_len, ABCMeta.register.__code__.co_varnames.__len__,                  [],        2, "ABCMeta.register.__code__.co_varnames.__len__() == 2 — ABCMeta.register.__code__.co_varnames is ('cls', 'subclass'); its length is 2; NEW in extra67: first co_varnames.__len__() check for ABCMeta.register in the abcmore67 namespace; verified with Python 3.14.3"]

