spec: abc_extra67
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#abstract-base-classes — Python ABC documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra66.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, update_abstractmethods/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, all length tables, abstractproperty/abstractclassmethod/abstractstaticmethod qualnames/names/bases, ABCMeta.register/__instancecheck__/__subclasscheck__ qualname string equality and code attribute chains, class __mro__.__len__() tables, class __dict__ tables, class __class__ identity, __repr__/__weakref__/__eq__ class names, abc.__package__/__all__ membership, __loader__/__spec__/__file__ class names, __spec__ attributes, ABCMeta method __qualname__ string equality, ABCMeta.register code attribute type chains, abc.__spec__.__class__.__name__=='ModuleSpec', abc.__spec__.name=='abc', abc.__name__=='abc', abstractmethod/update_abstractmethods/get_cache_token doc content, ABC/__doc__.__contains__('inheritance'), ABCMeta/__doc__.__contains__('Base'), abc.__spec__.origin=='frozen', abc.__loader__.__class__.__name__=='type', ABCMeta.register/__code__ co_name/co_argcount/co_varnames, update_abstractmethods co_name/co_argcount, ABC.__dict__ mappingproxy and __abstractmethods__ membership."
    - "This spec covers (abcmore67 namespace): wave 238 theme — ABCMeta method code objects (continuing) + abstractmethod code attributes. NEW in extra67: abstractmethod.__code__.co_name=='abstractmethod'; abstractmethod.__code__.co_argcount==1 (funcobj); abstractmethod.__code__.co_varnames.__class__.__name__=='tuple'; ABCMeta.register.__code__.co_varnames.__class__.__name__=='tuple'; ABCMeta.register.__code__.co_varnames.__len__()==2 (cls, subclass); update_abstractmethods.__code__.co_varnames.__class__.__name__=='tuple'; get_cache_token.__class__.__name__=='builtin_function_or_method' (from _abc C extension); abstractproperty.__dict__.__class__.__name__=='mappingproxy'. ABCMeta.__new__ is a C extension wrapper_descriptor in Python 3.14 and has no __code__ attribute — excluded."
    - "abc.abstractmethod.__code__.co_name == 'abstractmethod'. abstractmethod is a pure Python function defined in abc.py; its code object's co_name is the function's simple name 'abstractmethod'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_argcount == 1. abstractmethod takes a single argument funcobj; co_argcount is 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_varnames.__class__.__name__ == 'tuple'. co_varnames is always a tuple in CPython; abstractmethod.__code__.co_varnames.__class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__code__.co_varnames.__class__.__name__ == 'tuple'. co_varnames is always a tuple in CPython; ABCMeta.register.__code__.co_varnames.__class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__code__.co_varnames.__len__() == 2. ABCMeta.register.__code__.co_varnames is ('cls', 'subclass'); its length is 2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_varnames.__class__.__name__ == 'tuple'. co_varnames is always a tuple in CPython; update_abstractmethods.__code__.co_varnames.__class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method'. get_cache_token is implemented in the _abc C extension module; its __class__.__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__dict__.__class__.__name__ == 'mappingproxy'. Python class __dict__ is always a mappingproxy; abstractproperty.__dict__.__class__.__name__ is 'mappingproxy'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__new__ is a C extension wrapper_descriptor in Python 3.14 and has no __code__ attribute — it is not included in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc abstractmethod code object attribute checks — extra67
#
# Wave 238 theme: abstractmethod code attributes.
#
# abstractmethod.__code__.co_name == 'abstractmethod'
# abstractmethod.__code__.co_argcount == 1
# abstractmethod.__code__.co_varnames.__class__.__name__ == 'tuple'
# ---------------------------------------------------------------------------

table abc_extra67.abstractmethod_code:
  description: "abc abstractmethod code object attribute checks in abcmore67 namespace — wave 238 theme: abstractmethod code attributes; abstractmethod.__code__.co_name=='abstractmethod' (pure Python function in abc.py; code object stores the function name); abstractmethod.__code__.co_argcount==1 (takes only funcobj); abstractmethod.__code__.co_varnames.__class__.__name__=='tuple' (co_varnames is always a tuple in CPython); NEW in extra67: first co_name, co_argcount, and co_varnames type checks for abstractmethod in the abcmore67 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abcmore67

  columns: [id, function, args, expected, description]
  rows:
    - [absmeth_co_name,         abstractmethod.__code__.co_name.__eq__,                          ["abstractmethod"], true, "abstractmethod.__code__.co_name == 'abstractmethod' — abc.abstractmethod is a pure Python function in abc.py; its code object's co_name is 'abstractmethod'; NEW in extra67: first co_name.__eq__('abstractmethod') check for abstractmethod in the abcmore67 namespace; verified with Python 3.14.3"]
    - [absmeth_co_argcount,     abstractmethod.__code__.co_argcount.__eq__,                      [1],               true, "abstractmethod.__code__.co_argcount == 1 — abc.abstractmethod takes a single argument funcobj; co_argcount is 1; NEW in extra67: first co_argcount.__eq__(1) check for abstractmethod in the abcmore67 namespace; verified with Python 3.14.3"]
    - [absmeth_varnames_cls,    abstractmethod.__code__.co_varnames.__class__.__name__.__eq__,   ["tuple"],         true, "abstractmethod.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple in CPython; abstractmethod.__code__.co_varnames.__class__.__name__ is 'tuple'; NEW in extra67: first co_varnames.__class__.__name__.__eq__('tuple') check for abstractmethod in the abcmore67 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
