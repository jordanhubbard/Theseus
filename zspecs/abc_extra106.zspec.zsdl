#
# abc.update_abstractmethods.__qualname__ == 'update_abstractmethods' (len=22, longest)
# abc.abstractproperty.__qualname__       == 'abstractproperty'       (len=16)
# abc.get_cache_token.__qualname__        == 'get_cache_token'        (len=15)
# abc.abstractmethod.__qualname__         == 'abstractmethod'         (len=14, shortest)
# ---------------------------------------------------------------------------

table abc_extra106.abc_callable_qualnames:
  description: "abc module public callable qualname checks in abcmeta106 namespace — wave 254 theme: abc.update_abstractmethods.__qualname__.__eq__('update_abstractmethods')==True (len=22: 'update_abstractmethods'=22; longest qualname in spec); abc.update_abstractmethods.__qualname__.__len__()==22; type(abc.update_abstractmethods).__name__.__eq__('function')==True (Python-defined); abc.update_abstractmethods.__code__.co_argcount==1 (takes cls — the class to update); abc.abstractproperty.__qualname__.__eq__('abstractproperty')==True (len=16: 'abstractproperty'=16; second longest); abc.abstractproperty.__qualname__.__len__()==16; type(abc.abstractproperty).__name__.__eq__('type')==True (abstractproperty is a class); abc.get_cache_token.__qualname__.__eq__('get_cache_token')==True (len=15: 'get_cache_token'=15); abc.get_cache_token.__qualname__.__len__()==15; type(abc.get_cache_token).__name__.__eq__('builtin_function_or_method')==True (C-implemented); abc.abstractmethod.__qualname__.__eq__('abstractmethod')==True (len=14: 'abstractmethod'=14; shortest qualname in spec); abc.abstractmethod.__qualname__.__len__()==14; type(abc.abstractmethod).__name__.__eq__('function')==True; compare qualname lengths: abstractmethod=14 (shortest) < get_cache_token=15 < abstractproperty=16 < update_abstractmethods=22 (longest); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta106b

  columns: [id, function, args, expected, description]
  rows:
    - [uam_qn_eq,         abc.update_abstractmethods.__qualname__.__eq__,                ["update_abstractmethods"], true, "update_abstractmethods.__qualname__ == 'update_abstractmethods' (len=22, longest qualname in spec); verified with Python 3.14.3"]
    - [uam_qn_len,        abc.update_abstractmethods.__qualname__.__len__,               [],                       22,   "update_abstractmethods.__qualname__.__len__() == 22 ('update_abstractmethods'=22, longest in spec); verified with Python 3.14.3"]
    - [uam_argc,          abc.update_abstractmethods.__code__.co_argcount.__eq__,        [1],                      true, "update_abstractmethods.__code__.co_argcount == 1 (takes cls); verified with Python 3.14.3"]
    - [ap_qn_eq,          abc.abstractproperty.__qualname__.__eq__,                      ["abstractproperty"],      true, "abstractproperty.__qualname__ == 'abstractproperty' (len=16, second longest); verified with Python 3.14.3"]
    - [ap_qn_len,         abc.abstractproperty.__qualname__.__len__,                     [],                       16,   "abstractproperty.__qualname__.__len__() == 16 ('abstractproperty'=16); verified with Python 3.14.3"]
    - [gct_qn_eq,         abc.get_cache_token.__qualname__.__eq__,                       ["get_cache_token"],       true, "get_cache_token.__qualname__ == 'get_cache_token' (len=15); verified with Python 3.14.3"]
    - [gct_qn_len,        abc.get_cache_token.__qualname__.__len__,                      [],                       15,   "get_cache_token.__qualname__.__len__() == 15 ('get_cache_token'=15); verified with Python 3.14.3"]
    - [am_qn_eq,          abc.abstractmethod.__qualname__.__eq__,                        ["abstractmethod"],        true, "abstractmethod.__qualname__ == 'abstractmethod' (len=14, shortest qualname in spec); verified with Python 3.14.3"]
    - [am_qn_len,         abc.abstractmethod.__qualname__.__len__,                       [],                       14,   "abstractmethod.__qualname__.__len__() == 14 ('abstractmethod'=14, shortest qualname in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra106
# ---------------------------------------------------------------------------

invariant abc_extra106.type_ABC_is_ABCMeta:
  description: "type(abc.ABC).__name__.__eq__('ABCMeta') returns True — ABC's metaclass is ABCMeta (type(abc.ABC).__name__=='ABCMeta'); this reflects the class ABC, metaclass=ABCMeta declaration; type(abc.ABCMeta).__name__=='type' (ABCMeta is created by the standard 'type' metaclass); compare: type(abc.abstractproperty).__name__=='type' (abstractproperty is a plain class created by type); type(abc.abstractmethod).__name__=='function' (abstractmethod is a function, not a class); type(abc.ABC).__name__.__len__()==7 ('ABCMeta'=7); type(abc.ABCMeta).__name__.__len__()==4 ('type'=4, shorter); ABC has ABCMeta as its metaclass — this means ABC intercepts abstract method tracking without users needing to write class Foo(metaclass=ABCMeta); they can just write class Foo(ABC); abc.ABC.__mro__.__len__()==2 ([ABC, object]); abc.ABCMeta.__mro__.__len__()==3 ([ABCMeta, type, object]); NEW in extra106: first standalone type(ABC) name invariant in abcmeta106 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: type(abc.ABC).__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra106.type_ABCMeta_is_type:
  description: "type(abc.ABCMeta).__name__.__eq__('type') returns True — ABCMeta is itself a metaclass, created by the built-in 'type' metaclass; type(abc.ABCMeta).__name__=='type' (len=4); compare: type(abc.ABC).__name__=='ABCMeta' (ABC is created by ABCMeta); type(abc.abstractproperty).__name__=='type' (abstractproperty is also a class created by type); type(abc.ABCMeta).__name__.__len__()==4 ('type'=4); type(abc.ABC).__name__.__len__()==7 ('ABCMeta'=7, longer than 'type'=4); ABCMeta.__bases__[0].__name__=='type' (ABCMeta inherits from type — the two ways to observe the type/ABCMeta relationship: ABCMeta.__bases__[0].__name__=='type' and type(ABCMeta).__name__=='type' both confirm the same fact from different angles); ABCMeta.__mro__[1].__name__=='type' (type appears at MRO position 1); NEW in extra106: first standalone type(ABCMeta) name invariant in abcmeta106 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: type(abc.ABCMeta).__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra106.update_abstractmethods_qualname_len_22:
  description: "abc.update_abstractmethods.__qualname__.__len__() == 22 — 'update_abstractmethods'=22 chars; this is the longest qualname in this spec; compare: abstractmethod=14 (shortest) < get_cache_token=15 < abstractproperty=16 < update_abstractmethods=22 (longest); update_abstractmethods is a Python function (type='function') that recalculates the set of abstract methods for a class after dynamically setting or unsetting abstract methods; abc.update_abstractmethods.__code__.co_argcount==1 (takes cls); qualname len=22 > abstractproperty len=16 (by 6 chars); update_abstractmethods was added in Python 3.10; abc.abstractmethod.__qualname__.__len__()==14 (shortest in spec — contrast: abstractmethod has the shortest qualname while update_abstractmethods has the longest); NEW in extra106: first standalone update_abstractmethods qualname length invariant in abcmeta106 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.update_abstractmethods.__qualname__.__len__
  args: []
  expected: 22

invariant abc_extra106.ABCMeta_mro1_name_is_type:
  description: "abc.ABCMeta.__mro__[1].__name__.__eq__('type') returns True — the second element of ABCMeta's MRO is 'type'; ABCMeta.__mro__ == [ABCMeta, type, object] (length=3); ABCMeta.__mro__[1].__name__.__len__()==4 ('type'=4, shortest name in ABCMeta's MRO: 'ABCMeta'=7 > 'object'=6 > 'type'=4); the presence of 'type' at MRO position 1 is what makes ABCMeta a metaclass — metaclasses inherit from type; contrast: ABC.__mro__[1].__name__=='object' (ABC does not have 'type' in its MRO — ABC is a regular class, not a metaclass); ABCMeta.__mro__[0].__name__=='ABCMeta' (self at position 0); ABCMeta.__mro__[2].__name__=='object' (root at position 2); MRO name lengths: mro[0]='ABCMeta'=7 (longest), mro[2]='object'=6, mro[1]='type'=4 (shortest); NEW in extra106: first standalone ABCMeta mro[1] name invariant in abcmeta106 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "abc.ABCMeta.__mro__[1].__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra106.get_cache_token_type_is_builtin:
  description: "type(abc.get_cache_token).__name__.__eq__('builtin_function_or_method') returns True — get_cache_token is implemented in C (in the _abc C extension module) and exposed via the abc Python module; type(abc.get_cache_token).__name__=='builtin_function_or_method' (the longest type name in this spec: len=26); compare type names of abc members: 'type'=4 (ABCMeta, abstractproperty) < 'function'=8 (abstractmethod, update_abstractmethods) < 'ABCMeta'=7 (ABC) < 'builtin_function_or_method'=26 (get_cache_token, longest); get_cache_token.__qualname__=='get_cache_token' (len=15); abc.get_cache_token returns an opaque token that changes each time the set of abstract base classes changes (used for cache invalidation); it is the only member in this spec implemented in C; all other abc callables are Python-defined functions or classes; NEW in extra106: first standalone get_cache_token type name invariant in abcmeta106 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: type(abc.get_cache_token).__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

