spec: abc_extra106
version: ">=3.11"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra105.zspec.zsdl."
    - "This spec covers: wave 254 theme — abc metaclass chain: type(abc.ABCMeta).__name__=='type'; type(abc.ABC).__name__=='ABCMeta'; type(abc.abstractmethod).__name__=='function'; type(abc.abstractproperty).__name__=='type'; type(abc.get_cache_token).__name__=='builtin_function_or_method'; type(abc.update_abstractmethods).__name__=='function'. Also: abc.ABCMeta.__mro__[0].__name__=='ABCMeta' (len=7), __mro__[1].__name__=='type' (len=4), __mro__[2].__name__=='object' (len=6); abc.ABC.__mro__[0].__name__=='ABC' (len=3), __mro__[1].__name__=='object' (len=6); abc.update_abstractmethods.__qualname__=='update_abstractmethods' (len=22, longest qualname in spec); abc.abstractproperty.__qualname__=='abstractproperty' (len=16); abc.get_cache_token.__qualname__=='get_cache_token' (len=15). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "type(abc.ABCMeta).__name__ == 'type' — ABCMeta is itself a class (metaclass), so its type is 'type' (the standard Python metaclass). type(abc.ABC).__name__ == 'ABCMeta' — ABC is an instance of ABCMeta (ABC's metaclass is ABCMeta). type(abc.abstractmethod).__name__ == 'function' — abstractmethod is a plain function decorator. type(abc.abstractproperty).__name__ == 'type' — abstractproperty is a class. type(abc.get_cache_token).__name__ == 'builtin_function_or_method' — get_cache_token is implemented in C. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__mro__[0].__name__ == 'ABCMeta' (len=7), __mro__[1].__name__ == 'type' (len=4), __mro__[2].__name__ == 'object' (len=6). abc.ABC.__mro__[0].__name__ == 'ABC' (len=3), __mro__[1].__name__ == 'object' (len=6). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc metaclass chain: type() of abc module members — extra106
#
# Wave 254 theme: type() introspection of abc module public members.
#
# type(abc.ABCMeta).__name__            == 'type'
# type(abc.ABC).__name__                == 'ABCMeta'
# type(abc.abstractmethod).__name__     == 'function'
# type(abc.abstractproperty).__name__   == 'type'
# type(abc.get_cache_token).__name__    == 'builtin_function_or_method'
# type(abc.update_abstractmethods).__name__ == 'function'
# ---------------------------------------------------------------------------

table abc_extra106.abc_metaclass_chain_types:
  description: "abc module member type() checks in abcmeta106 namespace — wave 254 theme: type(abc.ABCMeta).__name__.__eq__('type')==True (ABCMeta is a class so its type is 'type' — the standard Python metaclass; ABCMeta itself is a metaclass, created by type); type(abc.ABC).__name__.__eq__('ABCMeta')==True (ABC is a class whose metaclass is ABCMeta — ABC.__class__ is ABCMeta; this is the defining property of ABC: it is an instance of ABCMeta, not of type); type(abc.abstractmethod).__name__.__eq__('function')==True (abstractmethod is a regular Python function used as a decorator); type(abc.abstractproperty).__name__.__eq__('type')==True (abstractproperty is a class — a subclass of property — so its type is 'type'); type(abc.get_cache_token).__name__.__eq__('builtin_function_or_method')==True (get_cache_token is implemented in C, exposed from _abc C module); type(abc.update_abstractmethods).__name__.__eq__('function')==True (update_abstractmethods is a Python-defined function); compare: ABCMeta and abstractproperty have type 'type' (both are class objects); abstractmethod and update_abstractmethods have type 'function' (Python-defined callables); get_cache_token has type 'builtin_function_or_method' (C-implemented); ABC has type 'ABCMeta' (uniquely — its metaclass is ABCMeta, not type); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta106

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_type_eq,   type(abc.ABCMeta).__name__.__eq__,                            ["type"],                 true, "type(abc.ABCMeta).__name__ == 'type' (ABCMeta is a class, so type() yields 'type'); verified with Python 3.14.3"]
    - [abc_type_eq,       type(abc.ABC).__name__.__eq__,                                 ["ABCMeta"],              true, "type(abc.ABC).__name__ == 'ABCMeta' (ABC's metaclass is ABCMeta); verified with Python 3.14.3"]
    - [am_type_eq,        type(abc.abstractmethod).__name__.__eq__,                      ["function"],             true, "type(abc.abstractmethod).__name__ == 'function' (abstractmethod is a plain function decorator); verified with Python 3.14.3"]
    - [ap_type_eq,        type(abc.abstractproperty).__name__.__eq__,                    ["type"],                 true, "type(abc.abstractproperty).__name__ == 'type' (abstractproperty is a class); verified with Python 3.14.3"]
    - [gct_type_eq,       type(abc.get_cache_token).__name__.__eq__,                     ["builtin_function_or_method"], true, "type(abc.get_cache_token).__name__ == 'builtin_function_or_method' (C-implemented); verified with Python 3.14.3"]
    - [uam_type_eq,       type(abc.update_abstractmethods).__name__.__eq__,              ["function"],             true, "type(abc.update_abstractmethods).__name__ == 'function' (Python-defined function); verified with Python 3.14.3"]
    - [abcmeta_type_len,  type(abc.ABCMeta).__name__.__len__,                            [],                       4,    "type(abc.ABCMeta).__name__.__len__() == 4 ('type'=4); verified with Python 3.14.3"]
    - [abc_type_len,      type(abc.ABC).__name__.__len__,                                [],                       7,    "type(abc.ABC).__name__.__len__() == 7 ('ABCMeta'=7); verified with Python 3.14.3"]
    - [am_type_len,       type(abc.abstractmethod).__name__.__len__,                     [],                       8,    "type(abc.abstractmethod).__name__.__len__() == 8 ('function'=8); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta and abc.ABC MRO position names — extra106
#
# Wave 254 theme: MRO element names at each position.
#
# ABCMeta.__mro__[0].__name__ == 'ABCMeta' (len=7)
# ABCMeta.__mro__[1].__name__ == 'type'    (len=4)
# ABCMeta.__mro__[2].__name__ == 'object'  (len=6)
# ABC.__mro__[0].__name__     == 'ABC'     (len=3)
# ABC.__mro__[1].__name__     == 'object'  (len=6)
# ---------------------------------------------------------------------------

table abc_extra106.abc_mro_position_names:
  description: "abc.ABCMeta and abc.ABC MRO position name checks in abcmeta106 namespace — wave 254 theme: abc.ABCMeta.__mro__[0].__name__.__eq__('ABCMeta')==True (len=7: first position is ABCMeta itself, as expected for any class's own MRO); abc.ABCMeta.__mro__[0].__name__.__len__()==7; abc.ABCMeta.__mro__[1].__name__.__eq__('type')==True (len=4: second position is type — ABCMeta inherits from type, making it a metaclass); abc.ABCMeta.__mro__[1].__name__.__len__()==4; abc.ABCMeta.__mro__[2].__name__.__eq__('object')==True (len=6: third position is object — the root of all Python classes); abc.ABCMeta.__mro__[2].__name__.__len__()==6; abc.ABC.__mro__[0].__name__.__eq__('ABC')==True (len=3: ABC is at position 0 of its own MRO); abc.ABC.__mro__[0].__name__.__len__()==3; abc.ABC.__mro__[1].__name__.__eq__('object')==True (len=6: ABC inherits directly from object, so object is at position 1); compare ABCMeta MRO name lengths: mro[0]='ABCMeta'=7 (longest) > mro[2]='object'=6 > mro[1]='type'=4 (shortest); compare ABC MRO name lengths: mro[0]='ABC'=3 (shorter) < mro[1]='object'=6 (longer); 'object' appears at mro[2] for ABCMeta and mro[1] for ABC (different positions, same name); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: abcmeta106a

  columns: [id, function, args, expected, description]
  rows:
    - [meta_mro0_eq,      "abc.ABCMeta.__mro__[0].__name__.__eq__",                     ["ABCMeta"],              true, "ABCMeta.__mro__[0].__name__ == 'ABCMeta' (len=7, self at position 0); verified with Python 3.14.3"]
    - [meta_mro0_len,     "abc.ABCMeta.__mro__[0].__name__.__len__",                    [],                       7,    "ABCMeta.__mro__[0].__name__.__len__() == 7 ('ABCMeta'=7, longest in ABCMeta MRO name lengths); verified with Python 3.14.3"]
    - [meta_mro1_eq,      "abc.ABCMeta.__mro__[1].__name__.__eq__",                     ["type"],                 true, "ABCMeta.__mro__[1].__name__ == 'type' (len=4, ABCMeta inherits from type); verified with Python 3.14.3"]
    - [meta_mro1_len,     "abc.ABCMeta.__mro__[1].__name__.__len__",                    [],                       4,    "ABCMeta.__mro__[1].__name__.__len__() == 4 ('type'=4, shortest in ABCMeta MRO name lengths); verified with Python 3.14.3"]
    - [meta_mro2_eq,      "abc.ABCMeta.__mro__[2].__name__.__eq__",                     ["object"],               true, "ABCMeta.__mro__[2].__name__ == 'object' (len=6, root class at end of MRO); verified with Python 3.14.3"]
    - [meta_mro2_len,     "abc.ABCMeta.__mro__[2].__name__.__len__",                    [],                       6,    "ABCMeta.__mro__[2].__name__.__len__() == 6 ('object'=6); verified with Python 3.14.3"]
    - [abc_mro0_eq,       "abc.ABC.__mro__[0].__name__.__eq__",                         ["ABC"],                  true, "ABC.__mro__[0].__name__ == 'ABC' (len=3, self at position 0); verified with Python 3.14.3"]
    - [abc_mro0_len,      "abc.ABC.__mro__[0].__name__.__len__",                        [],                       3,    "ABC.__mro__[0].__name__.__len__() == 3 ('ABC'=3, shortest class name in spec); verified with Python 3.14.3"]
    - [abc_mro1_eq,       "abc.ABC.__mro__[1].__name__.__eq__",                         ["object"],               true, "ABC.__mro__[1].__name__ == 'object' (len=6, ABC inherits directly from object); verified with Python 3.14.3"]
    - [abc_mro1_len,      "abc.ABC.__mro__[1].__name__.__len__",                        [],                       6,    "ABC.__mro__[1].__name__.__len__() == 6 ('object'=6); verified with Python 3.14.3"]

