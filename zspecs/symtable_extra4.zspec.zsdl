spec: symtable_extra4
version: ">=3.9"
backend: python_module(symtable)

docs: https://docs.python.org/3/library/symtable.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/symtable.html — Python symtable documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/symtable.py"
  notes:
    - "This spec extends symtable.zspec.zsdl through symtable_extra3.zspec.zsdl."
    - "symtable covers: symtable/__name__, SymbolTable/__name__/__module__, Function/__name__, Class/__name__, Symbol/__name__, SymbolTable method __name__ (get_type/get_id/get_name/get_children/get_symbols), Symbol method __name__ (get_name/is_global/is_local), symtable() exec returns Module."
    - "symtable_extra covers: class_names table, class_modules table, Function/__bases__[0]=='SymbolTable', Class/__bases__[0]=='SymbolTable', symtable() returns SymbolTable, symtable().get_type()=='module'."
    - "symtable_extra2 covers: SymbolTableError (not available in Python 3.12+), symtable/__module__, SymbolTable/__bases__[0]=='object', class __qualname__ table, Symbol/__module__."
    - "symtable_extra3 covers: Symbol/__bases__[0].__name__=='object', SymbolTableError.__qualname__/'SymbolTableError' (unavailable), symtable/__qualname__, class name types table, Function/Class __module__ standalone."
    - "NEW in this spec: additional SymbolTable method names (is_optimized/is_nested/has_children/get_identifiers/lookup/get_lineno), additional Symbol method names (is_referenced/is_imported/is_parameter/is_assigned/is_free/is_nonlocal/is_declared_global/is_namespace), Function-specific method names (get_parameters/get_locals/get_globals/get_frees), SymbolTableType class (new in 3.12), behavioral checks on symtable() results (is_optimized/is_nested/has_children for module scope)."
    - "symtable.SymbolTable.is_optimized.__name__ == 'is_optimized' — checks if the scope uses optimized locals."
    - "symtable.SymbolTable.has_children.__name__ == 'has_children' — checks for nested scopes."
    - "symtable.Function.get_parameters.__name__ == 'get_parameters' — Function-only method."
    - "symtable.SymbolTableType.__name__ == 'SymbolTableType' — a StrEnum added in 3.12 with MODULE/FUNCTION/CLASS members."
    - "symtable('x = 1', '<string>', 'exec').is_optimized() == False — module scope is not optimized."
    - "symtable('x = 1', '<string>', 'exec').is_nested() == False — module scope is not nested."
    - "symtable('x = 1', '<string>', 'exec').has_children() == False — 'x = 1' introduces no child scopes."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Additional SymbolTable method names — not covered in any prior symtable spec.
# symtable covers: get_type, get_id, get_name, get_children, get_symbols.
# New here: is_optimized, is_nested, has_children, get_identifiers, lookup, get_lineno.
# ---------------------------------------------------------------------------

table symtable_extra4.SymbolTable.extra_method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: stmname

  columns: [id, function, args, expected]
  rows:
    - [is_optimized,    SymbolTable.is_optimized.__name__.__eq__,    ["is_optimized"],    true]
    - [is_nested,       SymbolTable.is_nested.__name__.__eq__,       ["is_nested"],       true]
    - [has_children,    SymbolTable.has_children.__name__.__eq__,    ["has_children"],    true]
    - [get_identifiers, SymbolTable.get_identifiers.__name__.__eq__, ["get_identifiers"], true]
    - [lookup,          SymbolTable.lookup.__name__.__eq__,          ["lookup"],          true]
    - [get_lineno,      SymbolTable.get_lineno.__name__.__eq__,      ["get_lineno"],      true]

# ---------------------------------------------------------------------------
# Symbol method names — not covered in any prior symtable spec.
# symtable covers: get_name, is_global, is_local.
# New here: is_referenced, is_imported, is_parameter, is_assigned, is_free,
# is_nonlocal, is_declared_global, is_namespace.
# ---------------------------------------------------------------------------

table symtable_extra4.Symbol.extra_method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: symname

  columns: [id, function, args, expected]
  rows:
    - [is_referenced,     Symbol.is_referenced.__name__.__eq__,     ["is_referenced"],     true]
    - [is_imported,       Symbol.is_imported.__name__.__eq__,       ["is_imported"],       true]
    - [is_parameter,      Symbol.is_parameter.__name__.__eq__,      ["is_parameter"],      true]
    - [is_assigned,       Symbol.is_assigned.__name__.__eq__,       ["is_assigned"],       true]
    - [is_free,           Symbol.is_free.__name__.__eq__,           ["is_free"],           true]
    - [is_nonlocal,       Symbol.is_nonlocal.__name__.__eq__,       ["is_nonlocal"],       true]
    - [is_declared_global, Symbol.is_declared_global.__name__.__eq__, ["is_declared_global"], true]
    - [is_namespace,      Symbol.is_namespace.__name__.__eq__,      ["is_namespace"],      true]

# ---------------------------------------------------------------------------
# Function-specific method names — not covered in any prior symtable spec.
# Function is a subclass of SymbolTable with additional methods.
# ---------------------------------------------------------------------------

table symtable_extra4.Function.method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: fnmname

  columns: [id, function, args, expected]
  rows:
    - [get_parameters, Function.get_parameters.__name__.__eq__, ["get_parameters"], true]
    - [get_locals,     Function.get_locals.__name__.__eq__,     ["get_locals"],     true]
    - [get_globals,    Function.get_globals.__name__.__eq__,    ["get_globals"],    true]
    - [get_frees,      Function.get_frees.__name__.__eq__,      ["get_frees"],      true]

# ---------------------------------------------------------------------------
# SymbolTableType — a StrEnum class added in Python 3.12.
# Not covered in any prior symtable spec.
# ---------------------------------------------------------------------------

invariant symtable_extra4.SymbolTableType.name:
  description: "symtable.SymbolTableType.__name__ == 'SymbolTableType' — a StrEnum for table type values"
  category: class_names
  kind: python_call_eq
  function: SymbolTableType.__name__.__eq__
  args: ["SymbolTableType"]
  expected: true

invariant symtable_extra4.SymbolTableType.module:
  description: "symtable.SymbolTableType.__module__ == 'symtable'"
  category: class_modules
  kind: python_call_eq
  function: SymbolTableType.__module__.__eq__
  args: ["symtable"]
  expected: true

invariant symtable_extra4.SymbolTableType.base_is_StrEnum:
  description: "symtable.SymbolTableType.__bases__[0].__name__ == 'StrEnum' — SymbolTableType is a StrEnum"
  category: class_hierarchy
  kind: python_call_eq
  function: SymbolTableType.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "StrEnum"
