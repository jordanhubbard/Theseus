spec: trough
version: ">=2.0.0"
backend: node(trough)

docs: https://github.com/wooorm/trough#readme

provenance:
  derived_from:
    - "trough README — https://github.com/wooorm/trough#readme"
    - "Test vectors verified with trough via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "trough source"
  notes:
    - "Async middleware-pipeline builder — used by unified.js plugin chains."
    - "Install: npm install trough"
    - "v2 ESM only; named export trough() returns a pipeline with .use(fn) and .run(input, callback)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factory; pipeline never throws synchronously."
  stderr: "null"
  stickiness: "Pipeline state mutates as steps are added via .use()."
  codes: {}

invariant trough.factory_returns_object:
  description: "trough() returns an object (the pipeline)"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: trough
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "Object"

invariant trough.pipeline_has_use:
  description: "Pipeline has .use (add step)"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: trough
  entry_args: []
  chain:
    - {get: "use.constructor.name"}
  expected: "Function"

invariant trough.pipeline_has_run:
  description: "Pipeline has .run (execute the pipeline)"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: trough
  entry_args: []
  chain:
    - {get: "run.constructor.name"}
  expected: "Function"

invariant trough.has_trough_export:
  description: "Module has named export 'trough'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "trough.constructor.name"}
  expected: "Function"

invariant trough.factory_arity:
  description: "trough takes no required args"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "trough.length"}
  expected: 0
