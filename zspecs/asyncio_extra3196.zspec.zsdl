spec: as3196
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 660 (as3196): __pow__, __lshift__, __rshift__ dict-presence for asyncio types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: asyncio.Task, asyncio.Future, asyncio.Event, asyncio.Lock, asyncio.Semaphore, asyncio.BoundedSemaphore, asyncio.Condition, asyncio.Queue, asyncio.PriorityQueue, asyncio.LifoQueue."
    - "Key finding (__pow__): all 10 asyncio classes return false for __pow__. Event loop and coroutine/task types are pure concurrency primitives — none define exponentiation in their own __dict__. asyncio.Semaphore tracks an integer counter but exposes only acquire()/release() — the ** operator is not part of its protocol. asyncio.Queue, PriorityQueue, and LifoQueue are FIFO/priority/LIFO data structures that grow via put() and shrink via get(); they have no numeric semantics whatsoever."
    - "Key finding (__lshift__): all 10 asyncio classes return false for __lshift__. Left-shift is a bitwise integer operator with no role in asyncio's concurrency model. asyncio.Queue does not define << for enqueue operations — items are enqueued via put()/put_nowait(). asyncio.Lock, Event, Condition, Semaphore, BoundedSemaphore are synchronization guards; none implement bitwise shift. asyncio.Task and asyncio.Future represent pending coroutine results; shifting tasks is semantically undefined."
    - "Key finding (__rshift__): all 10 asyncio classes return false for __rshift__. Right-shift is absent from all asyncio types. asyncio.Queue does not define >> for dequeue operations — items are dequeued via get()/get_nowait(). asyncio.Task/Future have no pipeline or bitshift semantics. asyncio.PriorityQueue and asyncio.LifoQueue are container variants of Queue; neither defines any arithmetic or bitwise operators."
    - "This continues the all-false pattern from wave 659 (__truediv__/__floordiv__/__mod__). The asyncio library is a pure concurrency API: its types interact exclusively through await, async with, and explicit method calls — never through Python's arithmetic or bitwise data model."
    - "Cross-wave summary for asyncio subjects:"
    - "  Wave 652 (as3076): __get__ — Task/Future/Queue/Handle true; others false."
    - "  Wave 653 (as3091): __hash__/__eq__/__bool__ — selected true."
    - "  Wave 654 (as3106): __lt__/__le__/__gt__ — TimerHandle true; others false."
    - "  Wave 655 (as3121): __ge__ — TimerHandle true; __repr__ — 12 classes true."
    - "  Wave 656 (as3136): __call__/__len__/__getitem__ — all false for all 14."
    - "  Wave 657 (as3151): __setitem__/__delitem__/__contains__ — all false for all 14."
    - "  Wave 658 (as3166): __add__/__sub__/__mul__ — all false for all 14."
    - "  Wave 659 (as3181): __truediv__/__floordiv__/__mod__ — all false for all 14."
    - "  Wave 660 (as3196): __pow__/__lshift__/__rshift__ — all false for all 10."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __pow__ dict-presence — operator.contains(Cls.__dict__, '__pow__')
#
# All 10 asyncio classes return false for __pow__.
# asyncio types are concurrency primitives, not numeric types.
# asyncio.Semaphore and asyncio.BoundedSemaphore track an integer counter
#   internally, but exponentiation (** operator) has no meaning for them;
#   the counter is modified only through acquire()/release().
# asyncio.Queue/PriorityQueue/LifoQueue are data structures with no
#   arithmetic interface — items flow through put() and get().
# asyncio.Task/Future are pending coroutine results; ** is undefined for tasks.
# asyncio.Event/Lock/Condition are state-based synchronization primitives
#   with no numeric data model of any kind.
# ---------------------------------------------------------------------------

table as3196.pow:
  description: "asyncio types __pow__ dict-presence checks; wave 660"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: as3196

  columns: [id, function, args, expected]
  rows:
    - ["as3196001", operator.contains, [asyncio.Task.__dict__,             "__pow__"], false]
    - ["as3196002", operator.contains, [asyncio.Future.__dict__,           "__pow__"], false]
    - ["as3196003", operator.contains, [asyncio.Event.__dict__,            "__pow__"], false]
    - ["as3196004", operator.contains, [asyncio.Lock.__dict__,             "__pow__"], false]
    - ["as3196005", operator.contains, [asyncio.Semaphore.__dict__,        "__pow__"], false]
    - ["as3196006", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__pow__"], false]
    - ["as3196007", operator.contains, [asyncio.Condition.__dict__,        "__pow__"], false]
    - ["as3196008", operator.contains, [asyncio.Queue.__dict__,            "__pow__"], false]
    - ["as3196009", operator.contains, [asyncio.PriorityQueue.__dict__,    "__pow__"], false]
    - ["as3196010", operator.contains, [asyncio.LifoQueue.__dict__,        "__pow__"], false]

# ---------------------------------------------------------------------------
# __lshift__ dict-presence — operator.contains(Cls.__dict__, '__lshift__')
#
# All 10 asyncio classes return false for __lshift__.
# Left-shift (<<) is a bitwise integer operator; none of the asyncio types
#   define it. asyncio.Queue does not overload << for enqueueing items —
#   the put()/put_nowait() coroutines are the canonical enqueue interface.
# asyncio.Lock/Event/Condition/Semaphore/BoundedSemaphore: synchronization
#   guards with no bitwise interface.
# asyncio.Task/Future: coroutine result holders; no bitwise shift defined.
# asyncio.PriorityQueue/LifoQueue: Queue variants with priority/LIFO ordering
#   but no operator overloading beyond what Queue itself provides.
# ---------------------------------------------------------------------------

