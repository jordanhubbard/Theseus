    - ["as3196019", operator.contains, [asyncio.PriorityQueue.__dict__,    "__lshift__"], false]
    - ["as3196020", operator.contains, [asyncio.LifoQueue.__dict__,        "__lshift__"], false]

# ---------------------------------------------------------------------------
# __rshift__ dict-presence — operator.contains(Cls.__dict__, '__rshift__')
#
# All 10 asyncio classes return false for __rshift__.
# Right-shift (>>) is a bitwise integer operator; no asyncio type defines it.
# asyncio.Queue does not overload >> for dequeuing — get()/get_nowait() are
#   the canonical dequeue interface; they are async-aware coroutines, not
#   bitwise shift operations.
# asyncio.PriorityQueue: a min-heap priority queue; no shift operator.
# asyncio.LifoQueue: a LIFO stack variant of Queue; no shift operator.
# asyncio.Task/Future: pending coroutine results; right-shift is undefined.
# asyncio.Event/Lock/Semaphore/BoundedSemaphore/Condition: synchronization
#   primitives with no bitwise data model.
# ---------------------------------------------------------------------------

