spec: decimal_extra2461
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "Python decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl"
    - "_decimal_extra.zspec.zsdl"
  notes:
    - "Wave 2461, theme: __len__ and __length_hint__ dict-presence — decimal module classes do not define length protocol."
    - "decimal.Decimal is a numeric type with rich arithmetic; it defines __add__, __mul__, __neg__ etc. but not __len__ or __length_hint__."
    - "decimal.Context holds arithmetic settings (precision, rounding) and defines abs, exp, ln etc. — no length protocol."
    - "decimal.DecimalTuple is a namedtuple with sign, digits, exponent fields — namedtuples inherit __len__ from tuple but do NOT define it in their own __dict__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# decimal.Decimal — length protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table decimal_extra2461.decimal_length_protocol:
  description: "decimal.Decimal.__dict__ does not define __len__ or __length_hint__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2461

  columns: [id, function, args, expected]
  rows:
    - ["dc2461001", "decimal.Decimal.__dict__.__contains__", ["__len__"],         false]
    - ["dc2461002", "decimal.Decimal.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# decimal.Context — length protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table decimal_extra2461.context_length_protocol:
  description: "decimal.Context.__dict__ does not define __len__ or __length_hint__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2461

  columns: [id, function, args, expected]
  rows:
    - ["dc2461003", "decimal.Context.__dict__.__contains__", ["__len__"],         false]
    - ["dc2461004", "decimal.Context.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# decimal.DecimalTuple — length protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table decimal_extra2461.decimaltuple_length_protocol:
  description: "decimal.DecimalTuple.__dict__ does not define __len__ or __length_hint__ (inherits __len__ from tuple)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2461

  columns: [id, function, args, expected]
  rows:
    - ["dc2461005", "decimal.DecimalTuple.__dict__.__contains__", ["__len__"],         false]
    - ["dc2461006", "decimal.DecimalTuple.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Complementary: methods that ARE in decimal class __dict__
# ---------------------------------------------------------------------------

table decimal_extra2461.class_own_methods:
  description: "Methods that ARE present in decimal class __dict__ (not length protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2461

  columns: [id, function, args, expected]
  rows:
    - ["dc2461007", "decimal.Decimal.__dict__.__contains__",     ["__add__"],  true]
    - ["dc2461008", "decimal.Decimal.__dict__.__contains__",     ["__mul__"],  true]
    - ["dc2461009", "decimal.Decimal.__dict__.__contains__",     ["__sub__"],  true]
    - ["dc2461010", "decimal.Decimal.__dict__.__contains__",     ["__neg__"],  true]
    - ["dc2461011", "decimal.Decimal.__dict__.__contains__",     ["__abs__"],  true]
    - ["dc2461012", "decimal.Context.__dict__.__contains__",     ["abs"],      true]
    - ["dc2461013", "decimal.Context.__dict__.__contains__",     ["exp"],      true]
    - ["dc2461014", "decimal.Context.__dict__.__contains__",     ["ln"],       true]
    - ["dc2461015", "decimal.Context.__dict__.__contains__",     ["log10"],    true]
    - ["dc2461016", "decimal.DecimalTuple.__dict__.__contains__", ["_fields"], true]
    - ["dc2461017", "decimal.DecimalTuple.__dict__.__contains__", ["_make"],   true]
    - ["dc2461018", "decimal.DecimalTuple.__dict__.__contains__", ["_asdict"], true]
