spec: hashlib_extra289
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module attributes and function class names"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py, Modules/_hashopenssl.c"
  notes:
    - "hashlib.__package__ is empty string '', not 'hashlib'"
    - "hashlib.__loader__.__class__.__name__ is 'SourceFileLoader' confirming pure-Python wrapper"
    - "pbkdf2_hmac and scrypt are builtin_function_or_method (C-level), new and file_digest are Python functions"
    - "algorithms_guaranteed and algorithms_available are both set instances"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table hashlib_extra289.module_identity:
  description: "hashlib module identity attributes: __name__, __package__, __spec__ class, __loader__ class"
  kind: python_call_eq
  category: identity
  id_prefix: hle289

  columns: [id, function, args, expected, description]
  rows:
    - [hle289_001, hashlib.__name__.__class__.__name__, [], str, "__name__ is a str"]
    - [hle289_002, hashlib.__name__, [], hashlib, "__name__ equals 'hashlib'"]
    - [hle289_003, hashlib.__package__, [], "", "__package__ is empty string"]
    - [hle289_004, hashlib.__spec__.__class__.__name__, [], ModuleSpec, "__spec__ is a ModuleSpec"]
    - [hle289_005, hashlib.__loader__.__class__.__name__, [], SourceFileLoader, "__loader__ is SourceFileLoader"]

table hashlib_extra289.function_class_names:
  description: "Class names of hashlib module-level callables and collections"
  kind: python_call_eq
  category: identity
  id_prefix: hle289f

  columns: [id, function, args, expected, description]
  rows:
    - [hle289f_001, hashlib.new.__class__.__name__, [], function, "hashlib.new is a Python function"]
    - [hle289f_002, hashlib.pbkdf2_hmac.__class__.__name__, [], builtin_function_or_method, "pbkdf2_hmac is a builtin"]
    - [hle289f_003, hashlib.scrypt.__class__.__name__, [], builtin_function_or_method, "scrypt is a builtin"]
    - [hle289f_004, hashlib.file_digest.__class__.__name__, [], function, "file_digest is a Python function"]
    - [hle289f_005, hashlib.algorithms_guaranteed.__class__.__name__, [], set, "algorithms_guaranteed is a set"]
    - [hle289f_006, hashlib.algorithms_available.__class__.__name__, [], set, "algorithms_available is a set"]

invariant hashlib_extra289.file_is_str:
  description: "hashlib.__file__ is a str path"
  category: identity
  kind: python_call_eq
  function: hashlib.__file__.__class__.__name__
  args: []
  expected: str

invariant hashlib_extra289.algorithms_available_is_set:
  description: "algorithms_available class name is set"
  category: identity
  kind: python_call_eq
  function: hashlib.algorithms_available.__class__.__name__
  args: []
  expected: set

invariant hashlib_extra289.new_is_function:
  description: "hashlib.new __class__.__name__ is function"
  category: identity
  kind: python_call_eq
  function: hashlib.new.__class__.__name__
  args: []
  expected: function

invariant hashlib_extra289.pbkdf2_is_builtin:
  description: "hashlib.pbkdf2_hmac __class__.__name__ is builtin_function_or_method"
  category: identity
  kind: python_call_eq
  function: hashlib.pbkdf2_hmac.__class__.__name__
  args: []
  expected: builtin_function_or_method
