spec: threading_extra96
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra95

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra95.zspec.zsdl."
    - "This spec covers: threading Semaphore and Event class identity — __module__, __bases__[0].__name__, __mro__.__len__(); Thread class identity (Wave 254)."
    - "threading.Semaphore.__name__ == 'Semaphore'. Verified with Python 3.14.3."
    - "threading.Semaphore.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Semaphore.__qualname__ == 'Semaphore'. Verified with Python 3.14.3."
    - "threading.Semaphore.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "threading.Semaphore.__mro__.__len__() == 2 — mro is [Semaphore, object]. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore'. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__qualname__ == 'BoundedSemaphore'. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore inherits from Semaphore. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__mro__.__len__() == 3 — mro is [BoundedSemaphore, Semaphore, object]. Verified with Python 3.14.3."
    - "threading.Event.__name__ == 'Event'. Verified with Python 3.14.3."
    - "threading.Event.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Event.__qualname__ == 'Event'. Verified with Python 3.14.3."
    - "threading.Event.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "threading.Event.__mro__.__len__() == 2 — mro is [Event, object]. Verified with Python 3.14.3."
    - "threading.Condition.__name__ == 'Condition'. Verified with Python 3.14.3."
    - "threading.Condition.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Condition.__qualname__ == 'Condition'. Verified with Python 3.14.3."
    - "threading.Condition.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "threading.Condition.__mro__.__len__() == 2 — mro is [Condition, object]. Verified with Python 3.14.3."
    - "threading.Thread.__name__ == 'Thread'. Verified with Python 3.14.3."
    - "threading.Thread.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Thread.__qualname__ == 'Thread'. Verified with Python 3.14.3."
    - "threading.Thread.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "threading.Thread.__mro__.__len__() == 2 — mro is [Thread, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: Semaphore and BoundedSemaphore class identity
#
# Wave 254 theme: threading synchronization primitive class identity.
#
# threading.Semaphore.__name__.__eq__('Semaphore') == True
# threading.Semaphore.__module__.__eq__('threading') == True
# threading.Semaphore.__qualname__.__eq__('Semaphore') == True
# threading.Semaphore.__bases__[0].__name__.__eq__('object') == True
# threading.Semaphore.__mro__.__len__().__eq__(2) == True
# threading.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') == True
# threading.BoundedSemaphore.__mro__.__len__().__eq__(3) == True
#
# Semaphore has no custom base; BoundedSemaphore inherits from Semaphore.
# New to extra96.
# ---------------------------------------------------------------------------

table threading_extra96.semaphore_class_identity:
  description: "threading.Semaphore and BoundedSemaphore class identity; __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(); wave 254; new to extra96"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingclsid96

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_name_eq_Semaphore,
       "Semaphore.__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__.__eq__('Semaphore') == True — Semaphore is a pure-Python class defined with 'class Semaphore:' in Lib/threading.py; __name__ is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra96"]
    - [semaphore_module_eq_threading,
       "Semaphore.__module__.__eq__",
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — Semaphore is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra96"]
    - [semaphore_qualname_eq_Semaphore,
       "Semaphore.__qualname__.__eq__",
       ["Semaphore"],
       true,
       "threading.Semaphore.__qualname__.__eq__('Semaphore') == True — Semaphore is defined at module scope; __qualname__ is 'Semaphore' with no enclosing scope prefix; str.__eq__('Semaphore') returns True; new to extra96"]
    - [semaphore_bases0_eq_object,
       "Semaphore.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Semaphore.__bases__[0].__name__.__eq__('object') == True — Semaphore has no explicit base class in Lib/threading.py; it inherits from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra96"]
    - [semaphore_mro_len_eq_2,
       "Semaphore.__mro__.__len__",
       [],
       2,
       "threading.Semaphore.__mro__.__len__() == 2 — Semaphore's mro is [Semaphore, object]; no intermediate base classes; tuple.__len__() returns 2; new to extra96"]
    - [boundedsemaphore_bases0_eq_Semaphore,
       "BoundedSemaphore.__bases__[0].__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') == True — BoundedSemaphore is defined as 'class BoundedSemaphore(Semaphore):' in Lib/threading.py; it inherits from Semaphore; __bases__[0].__name__ is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra96"]
    - [boundedsemaphore_mro_len_eq_3,
       "BoundedSemaphore.__mro__.__len__",
       [],
       3,
       "threading.BoundedSemaphore.__mro__.__len__() == 3 — BoundedSemaphore's mro is [BoundedSemaphore, Semaphore, object]; it adds one level over Semaphore; tuple.__len__() returns 3; new to extra96"]

# ---------------------------------------------------------------------------
# Table 2: Event and Condition class identity
#
# Wave 254 theme: threading.Event and Condition class identity attributes.
#
# threading.Event.__name__.__eq__('Event') == True
# threading.Event.__module__.__eq__('threading') == True
# threading.Event.__qualname__.__eq__('Event') == True
# threading.Event.__bases__[0].__name__.__eq__('object') == True
# threading.Event.__mro__.__len__().__eq__(2) == True
# threading.Condition.__bases__[0].__name__.__eq__('object') == True
# threading.Condition.__mro__.__len__().__eq__(2) == True
#
# Both Event and Condition have no custom base; mro length is 2. New to extra96.
# ---------------------------------------------------------------------------

table threading_extra96.event_condition_class_identity:
  description: "threading.Event and Condition class identity; __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(); wave 254; new to extra96"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingclsid96

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_eq_Event,
       "Event.__name__.__eq__",
       ["Event"],
       true,
       "threading.Event.__name__.__eq__('Event') == True — Event is a pure-Python class defined in Lib/threading.py; __name__ is 'Event'; str.__eq__('Event') returns True; new to extra96"]
    - [event_module_eq_threading,
       "Event.__module__.__eq__",
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — Event is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra96"]
    - [event_qualname_eq_Event,
       "Event.__qualname__.__eq__",
       ["Event"],
       true,
       "threading.Event.__qualname__.__eq__('Event') == True — Event is defined at module scope; __qualname__ is 'Event'; str.__eq__('Event') returns True; new to extra96"]
    - [event_bases0_eq_object,
       "Event.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Event.__bases__[0].__name__.__eq__('object') == True — Event has no explicit base class; inherits from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra96"]
    - [event_mro_len_eq_2,
       "Event.__mro__.__len__",
       [],
       2,
       "threading.Event.__mro__.__len__() == 2 — Event's mro is [Event, object]; tuple.__len__() returns 2; new to extra96"]
    - [condition_bases0_eq_object,
       "Condition.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Condition.__bases__[0].__name__.__eq__('object') == True — Condition has no explicit base class in Lib/threading.py; it inherits from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra96"]
    - [condition_mro_len_eq_2,
       "Condition.__mro__.__len__",
       [],
       2,
       "threading.Condition.__mro__.__len__() == 2 — Condition's mro is [Condition, object]; no intermediate base classes; tuple.__len__() returns 2; new to extra96"]

# ---------------------------------------------------------------------------
# Table 3: Thread class identity
#
# Wave 254 theme: threading.Thread class identity attributes.
#
# threading.Thread.__name__.__eq__('Thread') == True
# threading.Thread.__module__.__eq__('threading') == True
# threading.Thread.__qualname__.__eq__('Thread') == True
# threading.Thread.__bases__[0].__name__.__eq__('object') == True
# threading.Thread.__mro__.__len__().__eq__(2) == True
#
# Thread is the base thread class; inherits from object; mro length is 2.
# New to extra96.
# ---------------------------------------------------------------------------

table threading_extra96.thread_class_identity:
  description: "threading.Thread __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(); base thread class; wave 254; new to extra96"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingclsid96

  columns: [id, function, args, expected, description]
  rows:
    - [thread_name_eq_Thread,
       "Thread.__name__.__eq__",
       ["Thread"],
       true,
       "threading.Thread.__name__.__eq__('Thread') == True — Thread is the primary thread class defined with 'class Thread:' in Lib/threading.py; __name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra96"]
    - [thread_module_eq_threading,
       "Thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — Thread is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra96"]
    - [thread_qualname_eq_Thread,
       "Thread.__qualname__.__eq__",
       ["Thread"],
       true,
       "threading.Thread.__qualname__.__eq__('Thread') == True — Thread is defined at module scope; __qualname__ is the simple class name 'Thread'; str.__eq__('Thread') returns True; new to extra96"]
    - [thread_bases0_eq_object,
       "Thread.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Thread.__bases__[0].__name__.__eq__('object') == True — Thread has no explicit base class in Lib/threading.py; it inherits from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra96"]
    - [thread_mro_len_eq_2,
       "Thread.__mro__.__len__",
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 — Thread's mro is [Thread, object]; no intermediate base classes; tuple.__len__() returns 2; new to extra96"]

# ---------------------------------------------------------------------------
# Table 4: Cross-checks — all 5 classes __module__ == 'threading'
#
# Wave 254 theme: all covered threading classes share __module__ 'threading'.
#
# threading.Semaphore.__module__.__eq__('threading') == True  (already in T1)
# threading.BoundedSemaphore.__module__.__eq__('threading') == True
# threading.Event.__module__.__eq__('threading') == True       (already in T2)
# threading.Condition.__module__.__eq__('threading') == True
# threading.Thread.__module__.__eq__('threading') == True      (already in T3)
#
# This cross-check table consolidates the __module__ attribute for all 5 classes
# to confirm they all belong to the threading module. New to extra96.
# ---------------------------------------------------------------------------

table threading_extra96.all_classes_module_threading:
  description: "Semaphore/BoundedSemaphore/Event/Condition/Thread __module__ == 'threading'; cross-check; wave 254; new to extra96"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingclsid96

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_module_cross,
       "Semaphore.__module__.__eq__",
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — cross-check: Semaphore is defined in Lib/threading.py; __module__ is 'threading'; new to extra96"]
    - [boundedsemaphore_module_eq_threading,
       "BoundedSemaphore.__module__.__eq__",
       ["threading"],
       true,
       "threading.BoundedSemaphore.__module__.__eq__('threading') == True — BoundedSemaphore is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra96"]
    - [event_module_cross,
       "Event.__module__.__eq__",
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — cross-check: Event is defined in Lib/threading.py; __module__ is 'threading'; new to extra96"]
    - [condition_module_eq_threading,
       "Condition.__module__.__eq__",
       ["threading"],
       true,
       "threading.Condition.__module__.__eq__('threading') == True — Condition is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra96"]
    - [thread_module_cross,
       "Thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — cross-check: Thread is defined in Lib/threading.py; __module__ is 'threading'; new to extra96"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra96
# ---------------------------------------------------------------------------

invariant threading_extra96.semaphore_mro_len_eq_2:
  description: "threading.Semaphore.__mro__.__len__() == 2 — mro is [Semaphore, object]; wave 254; new to extra96"
  kind: python_call_eq
  function: Semaphore.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra96.boundedsemaphore_bases0_eq_Semaphore:
  description: "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore inherits from Semaphore; wave 254; new to extra96"
  kind: python_call_eq
  function: BoundedSemaphore.__bases__[0].__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra96.boundedsemaphore_mro_len_eq_3:
  description: "threading.BoundedSemaphore.__mro__.__len__() == 3 — mro is [BoundedSemaphore, Semaphore, object]; wave 254; new to extra96"
  kind: python_call_eq
  function: BoundedSemaphore.__mro__.__len__
  args: []
  expected: 3

invariant threading_extra96.event_mro_len_eq_2:
  description: "threading.Event.__mro__.__len__() == 2 — mro is [Event, object]; wave 254; new to extra96"
  kind: python_call_eq
  function: Event.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra96.thread_mro_len_eq_2:
  description: "threading.Thread.__mro__.__len__() == 2 — mro is [Thread, object]; base thread class; wave 254; new to extra96"
  kind: python_call_eq
  function: Thread.__mro__.__len__
  args: []
  expected: 2
