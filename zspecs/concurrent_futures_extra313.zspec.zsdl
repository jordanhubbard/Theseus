spec: concurrent_futures_extra313
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Extends concurrent_futures.zspec.zsdl, concurrent_futures_extra.zspec.zsdl, concurrent_futures_extra2.zspec.zsdl, concurrent_futures_extra3.zspec.zsdl."
    - "concurrent_futures_extra.zspec.zsdl covers Future/ThreadPoolExecutor/ProcessPoolExecutor/Executor/CancelledError/TimeoutError/BrokenExecutor/InvalidStateError __name__; wait and as_completed __name__; FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED type."
    - "concurrent_futures_extra3.zspec.zsdl covers BrokenExecutor/CancelledError/TimeoutError/InvalidStateError/Executor __name__ and __module__; Executor.submit/map/shutdown __name__; BrokenExecutor base RuntimeError; Executor base object; Executor __qualname__."
    - "This spec focuses on: module __name__ and __package__; ProcessPoolExecutor/__module__ and __qualname__; ThreadPoolExecutor/__module__ and __qualname__; BrokenExecutor/__module__ and __qualname__; Future/__qualname__; Executor/__qualname__ (standalone); bases checks for ProcessPoolExecutor and ThreadPoolExecutor."
    - "concurrent.futures.__name__ == 'concurrent.futures' — the package name attribute."
    - "concurrent.futures.__package__ == 'concurrent.futures' — the package attribute."
    - "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process'."
    - "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'."
    - "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'."
    - "concurrent.futures.Future.__qualname__ == 'Future' — top-level class."
    - "concurrent.futures.Executor.__qualname__ == 'Executor' — top-level class."
    - "concurrent.futures.Error does NOT exist as a public attribute on Python 3.14."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Package identity — __name__ and __package__
#
# The top-level concurrent.futures namespace has __name__ and __package__
# both equal to 'concurrent.futures'.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra313.package.name:
  description: "concurrent.futures.__name__ == 'concurrent.futures'"
  category: package_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra313.package.package_attr:
  description: "concurrent.futures.__package__ == 'concurrent.futures'"
  category: package_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["concurrent.futures"]
  expected: true

# ---------------------------------------------------------------------------
# ProcessPoolExecutor — __module__ and __qualname__
#
# ProcessPoolExecutor is defined in concurrent.futures.process.
# Its __qualname__ equals its __name__ (top-level class).
# Its first base class is Executor.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra313.ProcessPoolExecutor.module:
  description: "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process'"
  category: executor_modules
  kind: python_call_eq
  function: ProcessPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.process"]
  expected: true

invariant concurrent_futures_extra313.ProcessPoolExecutor.qualname:
  description: "concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor'"
  category: executor_qualnames
  kind: python_call_eq
  function: ProcessPoolExecutor.__qualname__.__eq__
  args: ["ProcessPoolExecutor"]
  expected: true

invariant concurrent_futures_extra313.ProcessPoolExecutor.base_is_Executor:
  description: "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'"
  category: executor_hierarchy
  kind: python_call_eq
  function: ProcessPoolExecutor.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Executor"

# ---------------------------------------------------------------------------
# ThreadPoolExecutor — __module__ and __qualname__
#
# ThreadPoolExecutor is defined in concurrent.futures.thread.
# Its __qualname__ equals its __name__ (top-level class).
# Its first base class is Executor.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra313.ThreadPoolExecutor.module:
  description: "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'"
  category: executor_modules
  kind: python_call_eq
  function: ThreadPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra313.ThreadPoolExecutor.qualname:
  description: "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor'"
  category: executor_qualnames
  kind: python_call_eq
  function: ThreadPoolExecutor.__qualname__.__eq__
  args: ["ThreadPoolExecutor"]
  expected: true

invariant concurrent_futures_extra313.ThreadPoolExecutor.base_is_Executor:
  description: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'"
  category: executor_hierarchy
  kind: python_call_eq
  function: ThreadPoolExecutor.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Executor"

# ---------------------------------------------------------------------------
# BrokenExecutor — __module__ and __qualname__
#
# BrokenExecutor is defined in concurrent.futures._base.
# Its __qualname__ equals its __name__ (top-level class).
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra313.BrokenExecutor.module:
  description: "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'"
  category: exception_modules
  kind: python_call_eq
  function: BrokenExecutor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra313.BrokenExecutor.qualname:
  description: "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor'"
  category: exception_qualnames
  kind: python_call_eq
  function: BrokenExecutor.__qualname__.__eq__
  args: ["BrokenExecutor"]
  expected: true

# ---------------------------------------------------------------------------
# Future — __qualname__
#
# concurrent.futures.Future.__qualname__ == 'Future' — top-level class.
# The __module__ check (concurrent.futures._base) is in concurrent_futures_extra.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra313.Future.qualname:
  description: "concurrent.futures.Future.__qualname__ == 'Future'"
  category: class_qualnames
  kind: python_call_eq
  function: Future.__qualname__.__eq__
  args: ["Future"]
  expected: true

# ---------------------------------------------------------------------------
# Executor — __qualname__ standalone
#
# concurrent_futures_extra3 covers Executor.__qualname__ in the context of
# the full Executor section. This spec adds it as a focused standalone check.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra313.Executor.qualname_standalone:
  description: "concurrent.futures.Executor.__qualname__ == 'Executor'"
  category: executor_qualnames
  kind: python_call_eq
  function: Executor.__qualname__.__eq__
  args: ["Executor"]
  expected: true
