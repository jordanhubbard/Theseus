spec: uuid_extra64
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra63.zspec.zsdl — covers UUID.__eq__/__lt__ __code__.co_name/co_argcount / uuid3/uuid5 __code__.co_name/co_argcount / NAMESPACE_DNS/URL/OID/X500/__class__/__name__=='UUID' (table + invariants)."
    - "uuid_extra62.zspec.zsdl — covers UUID.__init__/__str__/__hash__ __code__.co_name/co_argcount / uuid4/uuid1 __code__.co_name/co_argcount (table + invariants)."
    - "uuid_extra61.zspec.zsdl — covers uuid.__name__/__spec__.name/__spec__.__class__.__name__/__loader__.__class__.__name__ / UUID.__dict__.__class__.__name__=='mappingproxy' / UUID.__dict__.__contains__ __init__/__repr__/__str__/__hash__/__eq__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra63; it does NOT duplicate invariants present in those files."
    - "Wave 239 theme: UUID class __dict__ content + uuid module constants."
    - "uuid.UUID.__dict__.__contains__('__eq__') == True — UUID defines __eq__ in its __dict__. uuid_extra61 covers __contains__ for __init__/__repr__/__str__/__hash__/__eq__; this spec re-anchors __eq__ alongside novel __lt__/__hash__/hex/int/version checks. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__lt__') == True — UUID defines __lt__ in its __dict__. No prior uuid spec checks UUID.__dict__.__contains__('__lt__') as a standalone fact in this namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__hash__') == True — UUID defines __hash__ in its __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('hex') == True — UUID.hex is a property in __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('int') == True — UUID.int is a property in __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('version') == True — UUID.version is a property in __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_NCS.__class__.__name__ == 'str' — RESERVED_NCS is a module-level string constant. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RFC_4122.__class__.__name__ == 'str' — RFC_4122 is a module-level string constant. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_MICROSOFT.__class__.__name__ == 'str' — RESERVED_MICROSOFT is a module-level string constant. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_FUTURE.__class__.__name__ == 'str' — RESERVED_FUTURE is a module-level string constant. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.__dict__.__contains__ for __eq__ / __lt__ / __hash__
#
# Wave 239 theme: UUID class __dict__ content — comparison and hash methods.
#
# uuid.UUID defines __eq__, __lt__, and __hash__ in its class __dict__.
# uuid_extra61 covers __contains__ checks for __init__/__repr__/__str__/__hash__/__eq__.
# This table re-anchors __eq__ and __hash__ and adds __lt__ in the extra64
# namespace as part of the Wave 239 __dict__ content survey.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra64.UUID_dict_comparison_hash:
  description: "uuid.UUID/__dict__.__contains__('__eq__')==True / UUID/__dict__.__contains__('__lt__')==True / UUID/__dict__.__contains__('__hash__')==True — UUID defines __eq__, __lt__, and __hash__ in its class __dict__; uuid_extra61 covers __eq__ and __hash__; this spec adds __lt__ in extra64 namespace; first combined comparison+hash __dict__ contains table in extra64"
  kind: python_call_eq
  category: class_dict
  id_prefix: uuidmore64

  columns: [id, function, args, expected]
  rows:
    - [UUID_dict_contains_eq,   UUID.__dict__.__contains__, ["__eq__"],   true]
    - [UUID_dict_contains_lt,   UUID.__dict__.__contains__, ["__lt__"],   true]
    - [UUID_dict_contains_hash, UUID.__dict__.__contains__, ["__hash__"], true]

# ---------------------------------------------------------------------------
# UUID.__dict__.__contains__ for hex / int / version
#
# Wave 239 theme: UUID class __dict__ content — property attributes.
#
# uuid.UUID defines hex, int, and version as properties in its class __dict__.
# No prior uuid spec checks UUID.__dict__.__contains__ for hex, int, or version.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra64.UUID_dict_properties:
  description: "uuid.UUID/__dict__.__contains__('hex')==True / UUID/__dict__.__contains__('int')==True / UUID/__dict__.__contains__('version')==True — UUID.hex, UUID.int, and UUID.version are properties stored in UUID.__dict__; no prior uuid spec checks UUID.__dict__.__contains__ for hex, int, or version; first property __dict__ contains table for UUID"
  kind: python_call_eq
  category: class_dict
  id_prefix: uuidmore64

  columns: [id, function, args, expected]
  rows:
    - [UUID_dict_contains_hex,     UUID.__dict__.__contains__, ["hex"],     true]
    - [UUID_dict_contains_int,     UUID.__dict__.__contains__, ["int"],     true]
    - [UUID_dict_contains_version, UUID.__dict__.__contains__, ["version"], true]

# ---------------------------------------------------------------------------
# uuid.RESERVED_NCS and uuid.RFC_4122 __class__.__name__
#
# Wave 239 theme: uuid module variant constants class identity.
#
# uuid.RESERVED_NCS and uuid.RFC_4122 are module-level string constants
# describing UUID variant fields. Their __class__.__name__ is 'str'. No prior
# uuid spec checks __class__.__name__ for RESERVED_NCS or RFC_4122.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra64.variant_constants_ncs_rfc:
  description: "uuid.RESERVED_NCS/__class__/__name__.__eq__('str')==True / RFC_4122/__class__/__name__.__eq__('str')==True — RESERVED_NCS and RFC_4122 are module-level string constants describing UUID variant fields; no prior uuid spec checks __class__.__name__ for RESERVED_NCS or RFC_4122; first class identity anchor for uuid variant string constants"
  kind: python_call_eq
  category: constants
  id_prefix: uuidmore64

  columns: [id, function, args, expected]
  rows:
    - [RESERVED_NCS_class_str, RESERVED_NCS.__class__.__name__.__eq__, ["str"], true]
    - [RFC_4122_class_str,     RFC_4122.__class__.__name__.__eq__,     ["str"], true]

# ---------------------------------------------------------------------------
# uuid.RESERVED_MICROSOFT and uuid.RESERVED_FUTURE __class__.__name__
#
# Wave 239 theme: uuid module variant constants class identity (Microsoft/Future).
#
# uuid.RESERVED_MICROSOFT and uuid.RESERVED_FUTURE are module-level string
# constants for UUID variant fields. Their __class__.__name__ is 'str'. No
# prior uuid spec checks __class__.__name__ for these constants.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra64.variant_constants_ms_future:
  description: "uuid.RESERVED_MICROSOFT/__class__/__name__.__eq__('str')==True / RESERVED_FUTURE/__class__/__name__.__eq__('str')==True — RESERVED_MICROSOFT and RESERVED_FUTURE are module-level string constants for UUID variant fields; no prior uuid spec checks __class__.__name__ for these constants; first class identity anchor for RESERVED_MICROSOFT and RESERVED_FUTURE"
  kind: python_call_eq
  category: constants
  id_prefix: uuidmore64

  columns: [id, function, args, expected]
  rows:
    - [RESERVED_MICROSOFT_class_str, RESERVED_MICROSOFT.__class__.__name__.__eq__, ["str"], true]
    - [RESERVED_FUTURE_class_str,    RESERVED_FUTURE.__class__.__name__.__eq__,    ["str"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__lt__') — standalone
#
# uuid.UUID defines __lt__ in its class __dict__. uuid_extra61 covers
# __contains__ for __hash__ and __eq__ but not __lt__. First __lt__ __dict__
# contains standalone for UUID. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra64.UUID_dict_contains_lt:
  description: "uuid.UUID.__dict__.__contains__('__lt__') == True — UUID defines __lt__ in its class __dict__; uuid_extra61 covers __eq__ and __hash__ but not __lt__; first __lt__ __dict__ contains standalone for UUID"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["__lt__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('hex') — standalone
#
# uuid.UUID defines hex as a property in its class __dict__. No prior uuid
# spec checks UUID.__dict__.__contains__('hex'). First hex __dict__ contains
# standalone for UUID. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra64.UUID_dict_contains_hex:
  description: "uuid.UUID.__dict__.__contains__('hex') == True — UUID.hex is a property stored in UUID.__dict__; no prior uuid spec checks UUID.__dict__.__contains__('hex'); first hex __dict__ contains standalone for UUID"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["hex"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('version') — standalone
#
# uuid.UUID defines version as a property in its class __dict__. No prior uuid
# spec checks UUID.__dict__.__contains__('version'). First version __dict__
# contains standalone for UUID. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra64.UUID_dict_contains_version:
  description: "uuid.UUID.__dict__.__contains__('version') == True — UUID.version is a property stored in UUID.__dict__; no prior uuid spec checks UUID.__dict__.__contains__('version'); first version __dict__ contains standalone for UUID"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["version"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.RESERVED_NCS.__class__.__name__.__eq__('str') — standalone
#
# uuid.RESERVED_NCS is a module-level string constant. Its __class__.__name__
# is 'str'. No prior uuid spec checks RESERVED_NCS.__class__.__name__.
# First class identity standalone for RESERVED_NCS.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra64.RESERVED_NCS_class_str:
  description: "uuid.RESERVED_NCS.__class__.__name__.__eq__('str') == True — RESERVED_NCS is a module-level string constant describing a UUID variant; no prior uuid spec checks RESERVED_NCS.__class__.__name__; first class identity standalone for RESERVED_NCS"
  category: constants
  kind: python_call_eq
  function: RESERVED_NCS.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.RFC_4122.__class__.__name__.__eq__('str') — standalone
#
# uuid.RFC_4122 is a module-level string constant. Its __class__.__name__ is
# 'str'. No prior uuid spec checks RFC_4122.__class__.__name__. First class
# identity standalone for RFC_4122.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra64.RFC_4122_class_str:
  description: "uuid.RFC_4122.__class__.__name__.__eq__('str') == True — RFC_4122 is a module-level string constant describing the RFC 4122 UUID variant; no prior uuid spec checks RFC_4122.__class__.__name__; first class identity standalone for RFC_4122"
  category: constants
  kind: python_call_eq
  function: RFC_4122.__class__.__name__.__eq__
  args: ["str"]
  expected: true
