spec: socket_extra520
backend: python_module(socket)

table socket_extra520.socket_constants_class:
  description: socket module constant __class__.__name__ == int checks
  columns: [id, function, expected]
  rows:
    - [sol_socket_class,   socket.SOL_SOCKET.__class__.__name__.__eq__,   int]
    - [so_reuseaddr_class, socket.SO_REUSEADDR.__class__.__name__.__eq__, int]
    - [so_reuseport_class, socket.SO_REUSEPORT.__class__.__name__.__eq__, int]
    - [so_keepalive_class, socket.SO_KEEPALIVE.__class__.__name__.__eq__, int]
    - [so_sndbuf_class,    socket.SO_SNDBUF.__class__.__name__.__eq__,    int]
    - [so_rcvbuf_class,    socket.SO_RCVBUF.__class__.__name__.__eq__,    int]
    - [shut_rdwr_class,    socket.SHUT_RDWR.__class__.__name__.__eq__,    int]
    - [shut_rd_class,      socket.SHUT_RD.__class__.__name__.__eq__,      int]
    - [shut_wr_class,      socket.SHUT_WR.__class__.__name__.__eq__,      int]
    - [msg_peek_class,     socket.MSG_PEEK.__class__.__name__.__eq__,     int]
    - [msg_waitall_class,  socket.MSG_WAITALL.__class__.__name__.__eq__,  int]
