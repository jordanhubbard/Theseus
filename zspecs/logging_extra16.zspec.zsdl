spec: logging_extra16
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends logging.zspec.zsdl through logging_extra15.zspec.zsdl."
    - "logging_extra15 covers: getLevelName int->str for INFO/WARNING/ERROR/CRITICAL; getLevelName str->int for DEBUG/ERROR; getLogger/basicConfig/disable/captureWarnings __module__."
    - "logging_extra13 covers: CRITICAL/ERROR/WARNING/INFO/DEBUG/NOTSET constants; getLevelName(10)=='DEBUG'; getLogger/basicConfig/disable/captureWarnings __name__."
    - "logging_extra12 covers: MRO lengths for NullHandler/Filter/LogRecord/Filterer/FileHandler; NullHandler base class; getLevelName str->int for INFO/WARNING/ERROR/CRITICAL/NOTSET."
    - "This spec covers: Handler/Formatter/Filter/StreamHandler/FileHandler/NullHandler __name__ via table; Handler/Formatter/StreamHandler __module__ via table; base class checks for Handler/Formatter/StreamHandler/FileHandler/NullHandler via invariants."
    - "logging.Handler inherits from Filterer."
    - "logging.Formatter inherits from object directly."
    - "logging.StreamHandler inherits from Handler."
    - "logging.FileHandler inherits from StreamHandler."
    - "logging.NullHandler inherits from Handler (confirmed by logging_extra12 MRO data)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Handler, Formatter, Filter, StreamHandler, FileHandler, NullHandler __name__
#
# No prior logging spec records __name__ for Handler, Formatter, Filter,
# StreamHandler, FileHandler, or NullHandler as standalone table rows.
# ---------------------------------------------------------------------------

table logging_extra16.class_names:
  description: "__name__ attribute for logging handler and formatter classes"
  kind: python_call_eq
  category: class_names

  columns: [id, function, args, expected]
  rows:
    - [Handler,       Handler.__name__.__eq__,       ["Handler"],       true]
    - [Formatter,     Formatter.__name__.__eq__,     ["Formatter"],     true]
    - [Filter,        Filter.__name__.__eq__,        ["Filter"],        true]
    - [StreamHandler, StreamHandler.__name__.__eq__, ["StreamHandler"], true]
    - [FileHandler,   FileHandler.__name__.__eq__,   ["FileHandler"],   true]
    - [NullHandler,   NullHandler.__name__.__eq__,   ["NullHandler"],   true]

# ---------------------------------------------------------------------------
# Handler, Formatter, StreamHandler __module__
#
# No prior logging spec records __module__ for these handler/formatter classes.
# All are defined in logging/__init__.py, so __module__ == 'logging'.
# ---------------------------------------------------------------------------

table logging_extra16.class_modules:
  description: "__module__ attribute for logging handler and formatter classes"
  kind: python_call_eq
  category: class_modules

  columns: [id, function, args, expected]
  rows:
    - [Handler,       Handler.__module__.__eq__,       ["logging"], true]
    - [Formatter,     Formatter.__module__.__eq__,     ["logging"], true]
    - [StreamHandler, StreamHandler.__module__.__eq__, ["logging"], true]

# ---------------------------------------------------------------------------
# Base class checks via __bases__[0].__name__
#
# No prior logging spec records __bases__[0].__name__ for Handler, Formatter,
# StreamHandler, FileHandler, or NullHandler as standalone invariants.
# ---------------------------------------------------------------------------

invariant logging_extra16.Handler.base0_name:
  description: "logging.Handler.__bases__[0].__name__ == 'Filterer'"
  category: base_classes
  kind: python_call_eq
  function: Handler.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Filterer"]
  expected: true

invariant logging_extra16.Formatter.base0_name:
  description: "logging.Formatter.__bases__[0].__name__ == 'object'"
  category: base_classes
  kind: python_call_eq
  function: Formatter.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant logging_extra16.StreamHandler.base0_name:
  description: "logging.StreamHandler.__bases__[0].__name__ == 'Handler'"
  category: base_classes
  kind: python_call_eq
  function: StreamHandler.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Handler"]
  expected: true

invariant logging_extra16.FileHandler.base0_name:
  description: "logging.FileHandler.__bases__[0].__name__ == 'StreamHandler'"
  category: base_classes
  kind: python_call_eq
  function: FileHandler.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["StreamHandler"]
  expected: true

invariant logging_extra16.NullHandler.base0_name:
  description: "logging.NullHandler.__bases__[0].__name__ == 'Handler'"
  category: base_classes
  kind: python_call_eq
  function: NullHandler.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Handler"]
  expected: true
