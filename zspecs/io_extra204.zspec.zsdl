spec: io_extra204
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl — covers TextIOWrapper, BufferedRandom, UnsupportedOperation, DEFAULT_BUFFER_SIZE, SEEK_* constants"
    - "io_extra203.zspec.zsdl — covers IOBase identity: __name__, __module__, __class__.__name__, close/flush/readable/writable qualnames"
  notes:
    - "This spec covers io.BufferedRandom class identity not already in previous io_extra specs."
    - "io.BufferedRandom.__name__ == 'BufferedRandom' — the public class name (len=14)."
    - "io.BufferedRandom.__module__ == '_io' — defined in the C-level _io module, not re-exported with module fix."
    - "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' — the C-level base class (len=15)."
    - "io.BufferedRandom.__class__.__name__ == 'type' — BufferedRandom uses type as its metaclass (no ABCMeta)."
    - "io.BufferedRandom.__init__.__qualname__ == 'BufferedRandom.__init__' — len=23."
    - "io.BufferedRandom.read.__qualname__ == 'BufferedRandom.read' — len=19."
    - "io.BufferedRandom.write.__qualname__ == 'BufferedRandom.write' — len=20."
    - "io.BufferedRandom.seek.__qualname__ == 'BufferedRandom.seek' — len=19."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedRandom class identity — name, module, metaclass
# ---------------------------------------------------------------------------

table io_extra204.bufferedrandom_identity:
  description: "io.BufferedRandom class identity checks in iobufferedrandom204 namespace — __name__=='BufferedRandom'; __module__=='_io' (C-level); __class__.__name__=='type' (no ABCMeta); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_metadata
  id_prefix: iobufferedrandom204

  columns: [id, function, args, expected, description]
  rows:
    - [class_name,  BufferedRandom.__name__.__eq__,          ["BufferedRandom"], true, "io.BufferedRandom.__name__ == 'BufferedRandom' (len=14); verified with Python 3.14.3"]
    - [module,      BufferedRandom.__module__.__eq__,         ["_io"],            true, "io.BufferedRandom.__module__ == '_io' — C-level module name; verified with Python 3.14.3"]
    - [metaclass,   BufferedRandom.__class__.__name__.__eq__, ["type"],           true, "io.BufferedRandom.__class__.__name__ == 'type' — no ABCMeta; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# io.BufferedRandom.__bases__ — base class identity
# ---------------------------------------------------------------------------

table io_extra204.bufferedrandom_bases:
  description: "io.BufferedRandom base class identity in iobufferedrandom204b namespace — __bases__[0].__name__=='_BufferedIOBase' (C-level base, len=15); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: iobufferedrandom204b

  columns: [id, function, args, expected, description]
  rows:
    - [name_len,   BufferedRandom.__name__.__len__,           [],               14,   "io.BufferedRandom.__name__.__len__() == 14 ('BufferedRandom' has 14 chars); verified with Python 3.14.3"]
    - [module_len, BufferedRandom.__module__.__len__,          [],               3,    "io.BufferedRandom.__module__.__len__() == 3 ('_io' has 3 chars); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# io.BufferedRandom method qualnames — __init__, read, write, seek
# ---------------------------------------------------------------------------

table io_extra204.bufferedrandom_method_qualnames:
  description: "io.BufferedRandom method qualnames in iobufferedrandom204c namespace — __init__, read, write, seek qualnames all use 'BufferedRandom.' prefix; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: iobufferedrandom204c

  columns: [id, function, args, expected, description]
  rows:
    - [init_qn,  "BufferedRandom.__init__.__qualname__.__eq__", ["BufferedRandom.__init__"], true, "io.BufferedRandom.__init__.__qualname__ == 'BufferedRandom.__init__' (len=23); verified with Python 3.14.3"]
    - [read_qn,  BufferedRandom.read.__qualname__.__eq__,       ["BufferedRandom.read"],     true, "io.BufferedRandom.read.__qualname__ == 'BufferedRandom.read' (len=19); verified with Python 3.14.3"]
    - [write_qn, BufferedRandom.write.__qualname__.__eq__,      ["BufferedRandom.write"],    true, "io.BufferedRandom.write.__qualname__ == 'BufferedRandom.write' (len=20); verified with Python 3.14.3"]
    - [seek_qn,  BufferedRandom.seek.__qualname__.__eq__,       ["BufferedRandom.seek"],     true, "io.BufferedRandom.seek.__qualname__ == 'BufferedRandom.seek' (len=19); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — iobufferedrandom204
# ---------------------------------------------------------------------------

invariant io_extra204.BufferedRandom.name_eq:
  description: "io.BufferedRandom.__name__.__eq__('BufferedRandom') returns True — BufferedRandom is a buffered I/O class for random-access (both read and write) streams; __name__ len=14; compare: io.IOBase.__name__=='IOBase' (len=6); io.BufferedReader.__name__=='BufferedReader' (len=14, same length); NEW in io_extra204: first standalone BufferedRandom.__name__ identity invariant in iobufferedrandom204 namespace; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: BufferedRandom.__name__.__eq__
  args: ["BufferedRandom"]
  expected: true

invariant io_extra204.BufferedRandom.module_eq:
  description: "io.BufferedRandom.__module__.__eq__('_io') returns True — BufferedRandom is defined at the C-level in the _io module (Modules/_io/bufferedio.c); unlike io.IOBase which has __module__=='io', BufferedRandom is not re-exported with a module fix; compare: io.UnsupportedOperation.__module__=='io' (re-exported); verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: BufferedRandom.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra204.BufferedRandom.bases0_name:
  description: "io.BufferedRandom.__bases__.__getitem__(0).__name__ == '_BufferedIOBase' — BufferedRandom inherits from the C-level _BufferedIOBase class (len=15); _BufferedIOBase provides the buffered I/O protocol; compare: io.IOBase.__bases__[0].__name__=='_IOBase' (len=7); verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: BufferedRandom.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_BufferedIOBase"

invariant io_extra204.BufferedRandom.metaclass_name:
  description: "io.BufferedRandom.__class__.__name__.__eq__('type') returns True — BufferedRandom uses the plain 'type' metaclass (not ABCMeta); compare: io.IOBase.__class__.__name__=='ABCMeta' (IOBase uses ABCMeta for virtual subclass registration); io.BufferedReader.__class__.__name__=='type' (same as BufferedRandom); verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: BufferedRandom.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra204.BufferedRandom.init_qualname_len:
  description: "io.BufferedRandom.__init__.__qualname__.__len__() == 23 — 'BufferedRandom.__init__' has 23 chars ('BufferedRandom.'=15+'__init__'=8=23); __init__ accepts a raw stream and optional buffer_size; compare: read qualname='BufferedRandom.read' len=19; write qualname='BufferedRandom.write' len=20; seek qualname='BufferedRandom.seek' len=19; __init__ is longest qualname in spec; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: "BufferedRandom.__init__.__qualname__.__len__"
  args: []
  expected: 23

invariant io_extra204.BufferedRandom.read_qualname_len:
  description: "io.BufferedRandom.read.__qualname__.__len__() == 19 — 'BufferedRandom.read' has 19 chars ('BufferedRandom.'=15+'read'=4=19); read() reads and returns up to size bytes; if size is -1 (default), all bytes until EOF are returned; compare: seek qualname='BufferedRandom.seek' also len=19; write qualname='BufferedRandom.write' len=20; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: BufferedRandom.read.__qualname__.__len__
  args: []
  expected: 19

invariant io_extra204.BufferedRandom.write_qualname_eq:
  description: "io.BufferedRandom.write.__qualname__.__eq__('BufferedRandom.write') returns True — write() writes the given bytes-like object to the underlying raw stream; qualname 'BufferedRandom.write' has len=20 ('BufferedRandom.'=15+'write'=5=20); compare: read qualname='BufferedRandom.read' len=19; __init__ qualname='BufferedRandom.__init__' len=23 (longest); verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: BufferedRandom.write.__qualname__.__eq__
  args: ["BufferedRandom.write"]
  expected: true

invariant io_extra204.BufferedRandom.seek_qualname_eq:
  description: "io.BufferedRandom.seek.__qualname__.__eq__('BufferedRandom.seek') returns True — seek() moves the stream position to the given byte offset relative to position indicated by whence; qualname 'BufferedRandom.seek' has len=19 ('BufferedRandom.'=15+'seek'=4=19); compare qualname lengths in spec: read=19, seek=19, write=20, __init__=23; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: BufferedRandom.seek.__qualname__.__eq__
  args: ["BufferedRandom.seek"]
  expected: true
