spec: node_html_entities
version: ">=2.0.0"
backend: node(html-entities)

docs: https://github.com/mdevils/html-entities#readme

provenance:
  derived_from:
    - "html-entities README — https://github.com/mdevils/html-entities#readme"
    - "WHATWG HTML Standard — Named character references"
    - "Test vectors verified with html-entities via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "html-entities source"
  notes:
    - "html-entities (npm) is a fast HTML entity encoder/decoder; alternative to the `entities` package."
    - "Spec name prefixed 'node_' to disambiguate from Python's html.entities module spec at zspecs/html_entities.zspec.zsdl."
    - "Install: npm install html-entities"
    - "encode(str) escapes &, <, >, \", '; decode(str) unescapes named and numeric character references."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table node_html_entities.encode:
  kind: node_module_call_eq
  category: encode
  function: encode
  id_prefix: enc

  columns: [id, args, expected]
  rows:
    - [angle_brackets,  ["<script>"],     "&lt;script&gt;"]
    - [ampersand,       ["A & B"],        "A &amp; B"]
    - [double_quote,    ["\"hi\""],       "&quot;hi&quot;"]
    - [no_special,      ["plain text"],   "plain text"]
    - [empty,           [""],             ""]
    - [unicode_passthrough, ["Café"],     "Café"]

table node_html_entities.decode:
  kind: node_module_call_eq
  category: decode
  function: decode
  id_prefix: dec

  columns: [id, args, expected]
  rows:
    - [angle_brackets,  ["&lt;script&gt;"],   "<script>"]
    - [ampersand,       ["A &amp; B"],        "A & B"]
    - [named_copy,      ["&copy;"],           "©"]
    - [named_amp,       ["&amp;"],            "&"]
    - [numeric_decimal, ["&#65;"],            "A"]
    - [numeric_hex,     ["&#x41;"],           "A"]
    - [no_entities,     ["plain text"],       "plain text"]
    - [empty,           [""],                 ""]

# Round-trip: encode then decode is identity for inputs with the 5 escape-worthy chars.
invariant node_html_entities.roundtrip:
  description: "decode of pre-encoded HTML restores the original characters"
  category: roundtrip
  kind: node_module_call_eq
  function: decode
  args: ["&lt;a href=&quot;x&quot;&gt;a&amp;b&lt;/a&gt;"]
  expected: "<a href=\"x\">a&b</a>"
