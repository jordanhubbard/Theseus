spec: in3316
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 668 (in3316): __ipow__, __ilshift__, __irshift__ dict-presence checks for inspect types."
    - "Theme: __ipow__/__ilshift__/__irshift__ in-place power/shift dict-presence."
    - "In-place augmented assignment operators (**=, <<=, >>=) fall back to __pow__/__lshift__/__rshift__ if not defined."
    - "All values False — callable/iterator/inspection/synchronization types have no in-place power/shift operators."
    - "No inspect type defines __ipow__, __ilshift__, or __irshift__ in its own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "None of these types implement in-place power/shift protocols directly."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3316.ipow:
  description: "inspect types __ipow__ dict-presence checks; wave 668"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3316
  columns: [id, function, args, expected]
  rows:
    - ["in3316001", operator.contains, [inspect.Parameter.__dict__,           "__ipow__"], false]
    - ["in3316002", operator.contains, [inspect.Signature.__dict__,           "__ipow__"], false]
    - ["in3316003", operator.contains, [inspect.BoundArguments.__dict__,      "__ipow__"], false]
    - ["in3316004", operator.contains, [inspect.FrameInfo.__dict__,           "__ipow__"], false]
    - ["in3316005", operator.contains, [inspect.ArgInfo.__dict__,             "__ipow__"], false]
    - ["in3316006", operator.contains, [inspect.FullArgSpec.__dict__,         "__ipow__"], false]
    - ["in3316007", operator.contains, [inspect.Attribute.__dict__,           "__ipow__"], false]
    - ["in3316008", operator.contains, [inspect.ClassFoundException.__dict__, "__ipow__"], false]
    - ["in3316009", operator.contains, [inspect.EndOfBlock.__dict__,          "__ipow__"], false]

