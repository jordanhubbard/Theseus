spec: node_dir
version: ">=0.1.0"
backend: node(node-dir)

docs: https://github.com/fshost/node-dir#readme

provenance:
  derived_from:
    - "node-dir README — https://github.com/fshost/node-dir#readme"
    - "Test vectors verified with node-dir via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "node-dir source"
  notes:
    - "Asynchronous directory traversal — files / paths / subdirs / readFiles / readFilesStream / promiseFiles."
    - "Install: npm install node-dir"
    - "v0.1 CJS; named exports per traversal mode."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Callbacks receive (err, list); errors on missing/permission-denied directories."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant node_dir.has_files:
  description: "files() is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "files.constructor.name"}
  expected: "Function"

invariant node_dir.has_paths:
  description: "paths() is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "paths.constructor.name"}
  expected: "Function"

invariant node_dir.has_subdirs:
  description: "subdirs() is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "subdirs.constructor.name"}
  expected: "Function"

invariant node_dir.has_readFiles:
  description: "readFiles() is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "readFiles.constructor.name"}
  expected: "Function"

invariant node_dir.has_readFilesStream:
  description: "readFilesStream() is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "readFilesStream.constructor.name"}
  expected: "Function"

invariant node_dir.has_promiseFiles:
  description: "promiseFiles() (Promise variant) is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "promiseFiles.constructor.name"}
  expected: "Function"

