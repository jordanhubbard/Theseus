spec: io_extra271
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "io.StringIO().getvalue() == '' — default-constructed StringIO has empty buffer."
    - "io.StringIO('hello').getvalue() == 'hello' — pre-seeded StringIO returns full content via getvalue()."
    - "io.StringIO().write('abc') == 3 — write() returns the number of characters written."
    - "io.StringIO().getvalue() after write('abc') == 'abc' — getvalue() reflects written content."
    - "io.StringIO('hello').read() == 'hello' — read() from position 0 returns the full seeded content."
    - "io.StringIO('hello').tell() == 0 — stream position starts at 0 before any read."
    - "io.BytesIO().getvalue() == b'' — default-constructed BytesIO has empty buffer."
    - "io.BytesIO(b'hello').getvalue() == b'hello' — pre-seeded BytesIO returns full content via getvalue()."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# StringIO — getvalue() behavioral contracts
# ---------------------------------------------------------------------------

invariant io_extra271.StringIO.getvalue_empty:
  description: "io.StringIO().getvalue() == '' — default-constructed StringIO has empty buffer"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: []
  method: getvalue
  method_args: []
  expected: ""

invariant io_extra271.StringIO.getvalue_seeded:
  description: "io.StringIO('hello').getvalue() == 'hello' — pre-seeded buffer returned by getvalue()"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: getvalue
  method_args: []
  expected: "hello"

invariant io_extra271.StringIO.write_returns_count:
  description: "io.StringIO().write('abc') == 3 — write() returns character count written"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: []
  method: write
  method_args: ["abc"]
  expected: 3

invariant io_extra271.StringIO.read_seeded:
  description: "io.StringIO('hello').read() == 'hello' — read() from position 0 returns full seeded content"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: read
  method_args: []
  expected: "hello"

invariant io_extra271.StringIO.tell_initial:
  description: "io.StringIO('hello').tell() == 0 — stream position starts at 0 before any read"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: tell
  method_args: []
  expected: 0

invariant io_extra271.StringIO.readable:
  description: "io.StringIO().readable() == True — StringIO is always readable"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: []
  method: readable
  method_args: []
  expected: true

invariant io_extra271.StringIO.writable:
  description: "io.StringIO().writable() == True — StringIO is always writable"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: []
  method: writable
  method_args: []
  expected: true

invariant io_extra271.StringIO.seekable:
  description: "io.StringIO().seekable() == True — StringIO is always seekable"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: []
  method: seekable
  method_args: []
  expected: true

# ---------------------------------------------------------------------------
# BytesIO — getvalue() behavioral contracts
# ---------------------------------------------------------------------------

invariant io_extra271.BytesIO.getvalue_empty:
  description: "io.BytesIO().getvalue() == b'' — default-constructed BytesIO has empty buffer"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: []
  method: getvalue
  method_args: []
  expected: !b64 ""

invariant io_extra271.BytesIO.getvalue_seeded:
  description: "io.BytesIO(b'hello').getvalue() == b'hello' — pre-seeded buffer returned by getvalue()"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: [!b64 aGVsbG8=]
  method: getvalue
  method_args: []
  expected: !b64 aGVsbG8=

invariant io_extra271.BytesIO.write_returns_count:
  description: "io.BytesIO().write(b'abc') == 3 — write() returns byte count written"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: []
  method: write
  method_args: [!b64 YWJj]
  expected: 3

invariant io_extra271.BytesIO.tell_initial:
  description: "io.BytesIO(b'hello').tell() == 0 — stream position starts at 0 before any read"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: [!b64 aGVsbG8=]
  method: tell
  method_args: []
  expected: 0

invariant io_extra271.BytesIO.readable:
  description: "io.BytesIO().readable() == True — BytesIO is always readable"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: []
  method: readable
  method_args: []
  expected: true

invariant io_extra271.BytesIO.writable:
  description: "io.BytesIO().writable() == True — BytesIO is always writable"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: []
  method: writable
  method_args: []
  expected: true

invariant io_extra271.BytesIO.seekable:
  description: "io.BytesIO().seekable() == True — BytesIO is always seekable"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: []
  method: seekable
  method_args: []
  expected: true

# ---------------------------------------------------------------------------
# Table: StringIO and BytesIO class kind checks
# ---------------------------------------------------------------------------

table io_extra271.stream_class_kinds:
  description: "StringIO and BytesIO are class objects (type instances)"
  kind: python_call_eq
  category: classnames
  id_prefix: kind

  columns: [id, function, args, expected, description]
  rows:
    - [StringIO_is_type, StringIO.__class__.__name__.__eq__, ["type"], true, "io.StringIO.__class__.__name__ == 'type' — StringIO is a class object"]
    - [BytesIO_is_type,  BytesIO.__class__.__name__.__eq__,  ["type"], true, "io.BytesIO.__class__.__name__ == 'type' — BytesIO is a class object"]
