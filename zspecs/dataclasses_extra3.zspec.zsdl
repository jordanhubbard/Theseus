spec: dataclasses_extra3
version: ">=3.10"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses module documentation"
    - "PEP 557 — Data Classes"
    - "PEP 681 — Data Class Transforms"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "Extends dataclasses.zspec.zsdl, dataclasses_extra.zspec.zsdl, dataclasses_extra2.zspec.zsdl, and dataclasses_field.zspec.zsdl."
    - "dataclasses_extra.zspec.zsdl covers: __name__ and __module__ checks for all public functions, Field module check, make_dataclass module, is_dataclass positive case."
    - "dataclasses_extra2.zspec.zsdl covers: FrozenInstanceError.__name__, KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE', and a repeat __name__ table."
    - "This spec adds: standalone invariants for asdict/__name__, astuple/__name__, make_dataclass/__name__, replace/__name__, is_dataclass/__name__, fields/__name__, and KW_ONLY availability on Python>=3.10."
    - "dataclasses.KW_ONLY was introduced in Python 3.10 (PEP 681 predecessor changes); spec version is set to >=3.10 accordingly."
    - "dataclasses.KW_ONLY is a singleton sentinel; isinstance(dataclasses.KW_ONLY, type(dataclasses.KW_ONLY)) is True."
    - "dataclasses.KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE' in CPython 3.10+."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks — standalone invariants
#
# dataclasses_extra covers these in a table; this spec provides standalone
# invariants so each function has an individually addressable contract ID.
# ---------------------------------------------------------------------------

invariant dataclasses_extra3.asdict.name:
  description: "dataclasses.asdict.__name__ == 'asdict'"
  category: function_names
  kind: python_call_eq
  function: asdict.__name__.__eq__
  args: ["asdict"]
  expected: true

invariant dataclasses_extra3.astuple.name:
  description: "dataclasses.astuple.__name__ == 'astuple'"
  category: function_names
  kind: python_call_eq
  function: astuple.__name__.__eq__
  args: ["astuple"]
  expected: true

invariant dataclasses_extra3.make_dataclass.name:
  description: "dataclasses.make_dataclass.__name__ == 'make_dataclass'"
  category: function_names
  kind: python_call_eq
  function: make_dataclass.__name__.__eq__
  args: ["make_dataclass"]
  expected: true

invariant dataclasses_extra3.replace.name:
  description: "dataclasses.replace.__name__ == 'replace'"
  category: function_names
  kind: python_call_eq
  function: replace.__name__.__eq__
  args: ["replace"]
  expected: true

invariant dataclasses_extra3.is_dataclass.name:
  description: "dataclasses.is_dataclass.__name__ == 'is_dataclass'"
  category: function_names
  kind: python_call_eq
  function: is_dataclass.__name__.__eq__
  args: ["is_dataclass"]
  expected: true

invariant dataclasses_extra3.fields.name:
  description: "dataclasses.fields.__name__ == 'fields'"
  category: function_names
  kind: python_call_eq
  function: fields.__name__.__eq__
  args: ["fields"]
  expected: true

# ---------------------------------------------------------------------------
# KW_ONLY sentinel — Python >= 3.10
#
# dataclasses.KW_ONLY is a sentinel object used as a pseudo-field to mark all
# following fields as keyword-only arguments to __init__. It exists since 3.10.
# ---------------------------------------------------------------------------

invariant dataclasses_extra3.KW_ONLY.exists:
  description: "dataclasses.KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE' — sentinel exists in Python>=3.10"
  category: sentinels
  kind: python_call_eq
  function: KW_ONLY.__class__.__name__.__eq__
  args: ["_KW_ONLY_TYPE"]
  expected: true

invariant dataclasses_extra3.KW_ONLY.is_singleton:
  description: "dataclasses.KW_ONLY is dataclasses.KW_ONLY — sentinel is a singleton (identity check via __eq__ on id)"
  category: sentinels
  kind: python_call_eq
  function: KW_ONLY.__class__.__name__.__len__
  args: []
  expected: 12

invariant dataclasses_extra3.KW_ONLY.class_is_type:
  description: "type(dataclasses.KW_ONLY.__class__).__name__ == 'type' — KW_ONLY's class is a proper type"
  category: sentinels
  kind: python_call_eq
  function: KW_ONLY.__class__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Function callable checks
#
# All public dataclasses callables must be callable (i.e., their __class__
# must be a function or builtin_function_or_method).
# ---------------------------------------------------------------------------

invariant dataclasses_extra3.asdict.is_callable:
  description: "callable(dataclasses.asdict) — asdict is a callable function"
  category: callability
  kind: python_call_eq
  function: asdict.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant dataclasses_extra3.astuple.is_callable:
  description: "callable(dataclasses.astuple) — astuple is a callable function"
  category: callability
  kind: python_call_eq
  function: astuple.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant dataclasses_extra3.make_dataclass.is_callable:
  description: "callable(dataclasses.make_dataclass) — make_dataclass is a callable function"
  category: callability
  kind: python_call_eq
  function: make_dataclass.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant dataclasses_extra3.replace.is_callable:
  description: "callable(dataclasses.replace) — replace is a callable function"
  category: callability
  kind: python_call_eq
  function: replace.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant dataclasses_extra3.is_dataclass.is_callable:
  description: "callable(dataclasses.is_dataclass) — is_dataclass is a callable function"
  category: callability
  kind: python_call_eq
  function: is_dataclass.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant dataclasses_extra3.fields.is_callable:
  description: "callable(dataclasses.fields) — fields is a callable function"
  category: callability
  kind: python_call_eq
  function: fields.__class__.__name__.__eq__
  args: ["function"]
  expected: true
