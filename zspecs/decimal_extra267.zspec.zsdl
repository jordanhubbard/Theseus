  args: ["Inexact"]
  expected: true

invariant decimal_extra267.Underflow.base:
  description: "decimal.Underflow.__bases__[0].__name__ == 'Inexact'"
  category: identity
  kind: python_call_eq
  function: "Underflow.__bases__[0].__name__.__eq__"
  args: ["Inexact"]
  expected: true

invariant decimal_extra267.ConversionSyntax.base:
  description: "decimal.ConversionSyntax.__bases__[0].__name__ == 'InvalidOperation'"
  category: identity
  kind: python_call_eq
  function: "ConversionSyntax.__bases__[0].__name__.__eq__"
  args: ["InvalidOperation"]
  expected: true

invariant decimal_extra267.DivisionImpossible.base:
  description: "decimal.DivisionImpossible.__bases__[0].__name__ == 'InvalidOperation'"
  category: identity
  kind: python_call_eq
  function: "DivisionImpossible.__bases__[0].__name__.__eq__"
  args: ["InvalidOperation"]
  expected: true

invariant decimal_extra267.DivisionUndefined.base:
  description: "decimal.DivisionUndefined.__bases__[0].__name__ == 'InvalidOperation'"
  category: identity
