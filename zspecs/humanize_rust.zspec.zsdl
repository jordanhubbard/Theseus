spec: humanize_rust
version: ">=3.9"
backend: rust_module(humanize_rust)

docs: https://python-humanize.readthedocs.io/

provenance:
  derived_from:
    - "https://python-humanize.readthedocs.io/ — humanize library"
  notes:
    - "humanize formats numbers and dates for human consumption."
    - "humanize.intcomma(1000) == '1,000'."
    - "humanize.intword(1000000) == '1.0 million'."
    - "humanize.naturalsize(1024) contains 'Byte'."
    - "humanize.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant humanize_rust.intcomma_1000:
  description: "humanize.intcomma(1000) == '1,000'"
  category: intcomma
  kind: python_call_eq
  function: humanize_intcomma
  args: [1000]
  expected: "1,000"

invariant humanize_rust.intword_million:
  description: "humanize.intword(1000000) == '1.0 million'"
  category: intword
  kind: python_call_eq
  function: humanize_intword
  args: [1000000]
  expected: "1.0 million"

invariant humanize_rust.version_nonempty:
  description: "humanize.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: humanize_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T02:27:49Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
