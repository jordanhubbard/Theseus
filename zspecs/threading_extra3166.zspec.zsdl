spec: th3166
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 658 (th3166): __add__, __sub__, __mul__ dict-presence checks for threading types."
    - "None of the threading types define __add__, __sub__, or __mul__ in their own __dict__."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier, and threading.local are Python-level classes."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3166.add:
  description: "threading types __add__ dict-presence checks; wave 658"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th3166
  columns: [id, function, args, expected]
  rows:
    - ["th3166001", operator.contains, [threading.Thread.__dict__,           "__add__"], false]
    - ["th3166002", operator.contains, [type(threading.Lock()).__dict__,     "__add__"], false]
    - ["th3166003", operator.contains, [type(threading.RLock()).__dict__,    "__add__"], false]
    - ["th3166004", operator.contains, [threading.Event.__dict__,            "__add__"], false]
    - ["th3166005", operator.contains, [threading.Condition.__dict__,        "__add__"], false]
    - ["th3166006", operator.contains, [threading.Semaphore.__dict__,        "__add__"], false]
    - ["th3166007", operator.contains, [threading.BoundedSemaphore.__dict__, "__add__"], false]
    - ["th3166008", operator.contains, [threading.Timer.__dict__,            "__add__"], false]
    - ["th3166009", operator.contains, [threading.Barrier.__dict__,          "__add__"], false]
    - ["th3166010", operator.contains, [threading.local.__dict__,            "__add__"], false]

