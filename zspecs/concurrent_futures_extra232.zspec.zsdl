spec: concurrent_futures_extra232
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "concurrent.futures has no __version__ attribute in Python 3.14.3 — module is stdlib, not versioned separately."
    - "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED' — str constant, 15 chars, isupper; verified with Python 3.14.3."
    - "concurrent.futures.FIRST_EXCEPTION == 'FIRST_EXCEPTION' — str constant, 15 chars, isupper; verified with Python 3.14.3."
    - "concurrent.futures.ALL_COMPLETED == 'ALL_COMPLETED' — str constant, 13 chars, isupper; verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' — 19 chars; module is 'concurrent.futures.thread'; verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' — 20 chars; module is 'concurrent.futures.process'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures executor class name contracts — extra232 namespace
#
# ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' (19 chars).
# ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'.
# ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' (20 chars).
# ProcessPoolExecutor.__module__ == 'concurrent.futures.process'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra232.executor_class_names:
  description: "concurrent.futures ThreadPoolExecutor and ProcessPoolExecutor class name contracts in cf232ecn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cf232ecn

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_name_eq,       ThreadPoolExecutor.__name__.__eq__,    ["ThreadPoolExecutor"],        true, "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'; verified with Python 3.14.3"]
    - [tpe_name_len_19,   ThreadPoolExecutor.__name__.__len__,   [],                            19,   "concurrent.futures.ThreadPoolExecutor.__name__.__len__() == 19 — 'ThreadPoolExecutor' has 19 characters; verified with Python 3.14.3"]
    - [tpe_module_eq,     ThreadPoolExecutor.__module__.__eq__,  ["concurrent.futures.thread"], true, "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'; verified with Python 3.14.3"]
    - [ppe_name_eq,       ProcessPoolExecutor.__name__.__eq__,   ["ProcessPoolExecutor"],       true, "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor'; verified with Python 3.14.3"]
    - [ppe_name_len_20,   ProcessPoolExecutor.__name__.__len__,  [],                            20,   "concurrent.futures.ProcessPoolExecutor.__name__.__len__() == 20 — 'ProcessPoolExecutor' has 20 characters; verified with Python 3.14.3"]
    - [ppe_module_eq,     ProcessPoolExecutor.__module__.__eq__, ["concurrent.futures.process"], true, "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures wait-return constants (additional contracts) — extra232 namespace
#
# FIRST_COMPLETED.__class__.__name__ == 'str'.
# FIRST_EXCEPTION.__class__.__name__ == 'str'.
# ALL_COMPLETED.__class__.__name__ == 'str'.
# FIRST_COMPLETED starts with 'FIRST', ALL_COMPLETED starts with 'ALL'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra232.wait_constant_types:
  description: "concurrent.futures wait-return constant __class__.__name__ contracts in cf232wct namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cf232wct

  columns: [id, function, args, expected, description]
  rows:
    - [fc_class_name_eq,   FIRST_COMPLETED.__class__.__name__.__eq__, ["str"], true, "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [fe_class_name_eq,   FIRST_EXCEPTION.__class__.__name__.__eq__, ["str"], true, "concurrent.futures.FIRST_EXCEPTION.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [ac_class_name_eq,   ALL_COMPLETED.__class__.__name__.__eq__,   ["str"], true, "concurrent.futures.ALL_COMPLETED.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [fc_startswith_first, FIRST_COMPLETED.startswith,  ["FIRST"], true, "concurrent.futures.FIRST_COMPLETED.startswith('FIRST') == True; verified with Python 3.14.3"]
    - [fe_startswith_first, FIRST_EXCEPTION.startswith,  ["FIRST"], true, "concurrent.futures.FIRST_EXCEPTION.startswith('FIRST') == True; verified with Python 3.14.3"]
    - [ac_startswith_all,   ALL_COMPLETED.startswith,    ["ALL"],   true, "concurrent.futures.ALL_COMPLETED.startswith('ALL') == True; verified with Python 3.14.3"]
    - [ac_len_13,           ALL_COMPLETED.__len__,        [],        13,   "concurrent.futures.ALL_COMPLETED.__len__() == 13 — 'ALL_COMPLETED' has 13 characters; verified with Python 3.14.3"]
