docs: https://www.npmjs.com/package/is-blank

provenance:
  derived_from:
    - "is-blank README — https://www.npmjs.com/package/is-blank"
    - "Test vectors verified with is-blank via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "is-blank source"
  notes:
    - "is-blank is an npm package. Install: npm install is-blank"
    - "Returns true if the value is empty, null, undefined, or whitespace-only."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_blank.check:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: isblank

  columns: [id, args, expected]
  rows:
    - [empty,   [""],        true]
    - [spaces,  ["   "],     true]
    - [text,    ["hello"],   false]
    - [null_v,  [null],      true]

