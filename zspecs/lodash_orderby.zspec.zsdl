spec: lodash_orderby
version: ">=4.0.0"
backend: node(lodash.orderby)

docs: https://lodash.com/docs/#orderBy

provenance:
  derived_from:
    - "lodash.orderby README — https://www.npmjs.com/package/lodash.orderby"
    - "Test vectors verified with lodash.orderby@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.orderby exports the _.orderBy function directly as module.exports."
    - "orderBy(collection, iteratees, orders) sorts collection by iteratees."
    - "String iteratees access named properties. Orders are 'asc' or 'desc'."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns sorted array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_orderby.orderby:
  kind: node_module_call_eq
  function: ~
  category: orderby
  id_prefix: lob

  columns: [id, args, expected]
  rows:
    - [asc,   [[{"n": "b", "v": 2}, {"n": "a", "v": 1}], ["n"], ["asc"]],
       [{"n": "a", "v": 1}, {"n": "b", "v": 2}]]
    - [desc,  [[{"v": 1}, {"v": 3}, {"v": 2}], ["v"], ["desc"]],
       [{"v": 3}, {"v": 2}, {"v": 1}]]
    - [multi, [[{"n": "a", "v": 3}, {"n": "a", "v": 1}, {"n": "b", "v": 2}],
               ["n", "v"], ["asc", "asc"]],
       [{"n": "a", "v": 1}, {"n": "a", "v": 3}, {"n": "b", "v": 2}]]
