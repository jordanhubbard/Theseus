spec: abc_extra323
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers collections.abc coroutine and async abstract base classes: __name__, __module__, __bases__[0].__name__."
    - "collections.abc.Coroutine.__module__ == 'collections.abc' — the C-level _collections_abc is re-exported as collections.abc."
    - "collections.abc.Coroutine.__bases__[0].__name__ == 'Awaitable' — Coroutine subclasses Awaitable."
    - "collections.abc.AsyncIterable.__bases__[0].__name__ == 'object' — AsyncIterable is a root ABC."
    - "collections.abc.AsyncIterator.__bases__[0].__name__ == 'AsyncIterable' — AsyncIterator subclasses AsyncIterable."
    - "collections.abc.AsyncGenerator.__bases__[0].__name__ == 'AsyncIterator' — AsyncGenerator subclasses AsyncIterator."
    - "collections.abc.Generator.__bases__[0].__name__ == 'Iterator' — Generator subclasses Iterator."
    - "collections.abc.Buffer.__name__ == 'Buffer' — introduced in Python 3.12; present on 3.14."
    - "collections.abc.Buffer.__module__ == 'collections.abc'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Coroutine — name, module, and base class
#
# collections.abc.Coroutine is the ABC for coroutine objects. It subclasses
# Awaitable, which in turn subclasses object. Its __module__ is 'collections.abc'
# (the public name), not '_collections_abc' (the C extension name).
# ---------------------------------------------------------------------------

invariant abc_extra323.Coroutine.name:
  description: "collections.abc.Coroutine.__name__ == 'Coroutine'"
  category: async_abcs
  kind: python_call_eq
  function: Coroutine.__name__.__eq__
  args: ["Coroutine"]
  expected: true

invariant abc_extra323.Coroutine.module:
  description: "collections.abc.Coroutine.__module__ == 'collections.abc'"
  category: async_abcs
  kind: python_call_eq
  function: Coroutine.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra323.Coroutine.base:
  description: "collections.abc.Coroutine.__bases__[0].__name__ == 'Awaitable'"
  category: async_abcs
  kind: python_call_eq
  function: Coroutine.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Awaitable"

# ---------------------------------------------------------------------------
# AsyncIterable — name, module, and base class
#
# collections.abc.AsyncIterable is the root ABC for objects that support
# async iteration. It inherits directly from object (no intermediate ABC).
# ---------------------------------------------------------------------------

invariant abc_extra323.AsyncIterable.name:
  description: "collections.abc.AsyncIterable.__name__ == 'AsyncIterable'"
  category: async_abcs
  kind: python_call_eq
  function: AsyncIterable.__name__.__eq__
  args: ["AsyncIterable"]
  expected: true

invariant abc_extra323.AsyncIterable.module:
  description: "collections.abc.AsyncIterable.__module__ == 'collections.abc'"
  category: async_abcs
  kind: python_call_eq
  function: AsyncIterable.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra323.AsyncIterable.base:
  description: "collections.abc.AsyncIterable.__bases__[0].__name__ == 'object'"
  category: async_abcs
  kind: python_call_eq
  function: AsyncIterable.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# AsyncIterator — name, module, and base class
#
# collections.abc.AsyncIterator is an async iteration protocol ABC that
# requires __aiter__ and __anext__. It subclasses AsyncIterable.
# ---------------------------------------------------------------------------

invariant abc_extra323.AsyncIterator.name:
  description: "collections.abc.AsyncIterator.__name__ == 'AsyncIterator'"
  category: async_abcs
  kind: python_call_eq
  function: AsyncIterator.__name__.__eq__
  args: ["AsyncIterator"]
  expected: true

invariant abc_extra323.AsyncIterator.module:
  description: "collections.abc.AsyncIterator.__module__ == 'collections.abc'"
  category: async_abcs
  kind: python_call_eq
  function: AsyncIterator.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra323.AsyncIterator.base:
  description: "collections.abc.AsyncIterator.__bases__[0].__name__ == 'AsyncIterable'"
  category: async_abcs
  kind: python_call_eq
  function: AsyncIterator.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "AsyncIterable"

# ---------------------------------------------------------------------------
# AsyncGenerator — name, module, and base class
#
# collections.abc.AsyncGenerator is the ABC for async generator objects,
# adding asend/athrow/aclose to the AsyncIterator protocol.
# ---------------------------------------------------------------------------

invariant abc_extra323.AsyncGenerator.name:
  description: "collections.abc.AsyncGenerator.__name__ == 'AsyncGenerator'"
  category: async_abcs
  kind: python_call_eq
  function: AsyncGenerator.__name__.__eq__
  args: ["AsyncGenerator"]
  expected: true

invariant abc_extra323.AsyncGenerator.module:
  description: "collections.abc.AsyncGenerator.__module__ == 'collections.abc'"
  category: async_abcs
  kind: python_call_eq
  function: AsyncGenerator.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra323.AsyncGenerator.base:
  description: "collections.abc.AsyncGenerator.__bases__[0].__name__ == 'AsyncIterator'"
  category: async_abcs
  kind: python_call_eq
  function: AsyncGenerator.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "AsyncIterator"

# ---------------------------------------------------------------------------
# Generator — name, module, and base class
#
# collections.abc.Generator is the ABC for synchronous generator objects.
# It subclasses Iterator, adding send/throw/close to the Iterator protocol.
# ---------------------------------------------------------------------------

invariant abc_extra323.Generator.name:
  description: "collections.abc.Generator.__name__ == 'Generator'"
  category: sync_generator_abcs
  kind: python_call_eq
  function: Generator.__name__.__eq__
  args: ["Generator"]
  expected: true

invariant abc_extra323.Generator.module:
  description: "collections.abc.Generator.__module__ == 'collections.abc'"
  category: sync_generator_abcs
  kind: python_call_eq
  function: Generator.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra323.Generator.base:
  description: "collections.abc.Generator.__bases__[0].__name__ == 'Iterator'"
  category: sync_generator_abcs
  kind: python_call_eq
  function: Generator.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Iterator"

# ---------------------------------------------------------------------------
# Buffer — name and module (Python 3.12+)
#
# collections.abc.Buffer was added in Python 3.12 as the ABC for objects that
# support the buffer protocol (PEP 688). It inherits from object and is
# exposed in the public collections.abc namespace.
# ---------------------------------------------------------------------------

invariant abc_extra323.Buffer.name:
  description: "collections.abc.Buffer.__name__ == 'Buffer' (Python 3.12+)"
  category: buffer_abc
  version: ">=3.12"
  kind: python_call_eq
  function: Buffer.__name__.__eq__
  args: ["Buffer"]
  expected: true

invariant abc_extra323.Buffer.module:
  description: "collections.abc.Buffer.__module__ == 'collections.abc' (Python 3.12+)"
  category: buffer_abc
  version: ">=3.12"
  kind: python_call_eq
  function: Buffer.__module__.__eq__
  args: ["collections.abc"]
  expected: true
