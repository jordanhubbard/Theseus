spec: pathlib_extra49
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra48.zspec.zsdl — covers Path filesystem mutation/traversal method __qualname__.__len__() unified table."
    - "pathlib_extra47.zspec.zsdl — covers Path.cwd/home/stat/exists/is_file/is_dir/open/read_text/write_text __qualname__.__len__()."
    - "pathlib_extra37.zspec.zsdl — covers Path.iterdir/glob/rglob/resolve __qualname__.__len__()."
    - "pathlib_extra19.zspec.zsdl — covers Path.mkdir __qualname__.__eq__() (string equality)."
    - "pathlib_extra28.zspec.zsdl — covers Path.resolve/iterdir __qualname__.__eq__() (string equality)."
  notes:
    - "This spec extends pathlib_extra48.zspec.zsdl."
    - "Prior specs collectively covered: Path/PurePath/PosixPath/PureWindowsPath/PurePosixPath/WindowsPath __name__ and __bases__ (various); all Path method __qualname__.__len__() values; select Path method __qualname__.__eq__() string equality; no prior pathlib spec covers any of the six main pathlib classes' own __qualname__ attributes, nor Path.cwd/__qualname__ or Path.home/__qualname__ as equality checks."
    - "This spec covers: pathlib.Path.__qualname__=='Path' (NOVEL — no prior pathlib spec checks Path.__qualname__; novel equality anchor in pathlib_extra49 namespace); pathlib.PurePath.__qualname__=='PurePath' (NOVEL); pathlib.PurePosixPath.__qualname__=='PurePosixPath' (NOVEL); pathlib.PureWindowsPath.__qualname__=='PureWindowsPath' (NOVEL); pathlib.PosixPath.__qualname__=='PosixPath' (NOVEL); pathlib.WindowsPath.__qualname__=='WindowsPath' (NOVEL); pathlib.Path.cwd.__qualname__=='Path.cwd' (NOVEL — pathlib_extra47 covers Path.cwd.__qualname__.__len__() but not the string equality; novel equality anchor in pathlib_extra49 namespace); pathlib.Path.home.__qualname__=='Path.home' (NOVEL — pathlib_extra47 covers Path.home.__qualname__.__len__() but not string equality; novel)."
    - "pathlib.Path.__qualname__ == 'Path'. The concrete filesystem path class. __qualname__ equals bare class name for top-level classes. No prior pathlib spec checks Path.__qualname__. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__qualname__ == 'PurePath'. The abstract pure path base class. __qualname__ == 'PurePath'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePosixPath.__qualname__ == 'PurePosixPath'. Pure POSIX path class. __qualname__ == 'PurePosixPath'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PureWindowsPath.__qualname__ == 'PureWindowsPath'. Pure Windows path class. __qualname__ == 'PureWindowsPath'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PosixPath.__qualname__ == 'PosixPath'. Concrete POSIX filesystem path class. __qualname__ == 'PosixPath'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.WindowsPath.__qualname__ == 'WindowsPath'. Concrete Windows filesystem path class. __qualname__ == 'WindowsPath'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.cwd.__qualname__ == 'Path.cwd'. Class method qualname includes the class name prefix. pathlib_extra47 covers Path.cwd.__qualname__.__len__()==8; no prior spec checks the string equality. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.home.__qualname__ == 'Path.home'. Class method qualname includes the class name prefix. pathlib_extra47 covers Path.home.__qualname__.__len__()==9; no prior spec checks the string equality. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib class __qualname__ attributes
#
# The six public pathlib classes all have __qualname__ equal to their bare
# class name. These are all top-level classes defined at module scope.
#
#   Path.__qualname__           == 'Path'
#   PurePath.__qualname__       == 'PurePath'
#   PurePosixPath.__qualname__  == 'PurePosixPath'
#   PureWindowsPath.__qualname__== 'PureWindowsPath'
#   PosixPath.__qualname__      == 'PosixPath'
#   WindowsPath.__qualname__    == 'WindowsPath'
#
# No prior pathlib spec covers any of these class __qualname__ attributes.
# All six are novel equality anchors in the pathlib_extra49 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra49.class_qualnames:
  description: "pathlib class __qualname__ attributes: Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath — __qualname__ equals bare class name for all top-level pathlib classes; no prior pathlib spec checks any of these class __qualname__ attributes; all six novel equality anchors in pathlib_extra49 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pcq49

  columns: [id, function, args, expected]
  rows:
    - [Path_qualname,           Path.__qualname__.__eq__,           ["Path"],            true]
    - [PurePath_qualname,       PurePath.__qualname__.__eq__,       ["PurePath"],        true]
    - [PurePosixPath_qualname,  PurePosixPath.__qualname__.__eq__,  ["PurePosixPath"],   true]
    - [PureWindowsPath_qualname,PureWindowsPath.__qualname__.__eq__,["PureWindowsPath"], true]
    - [PosixPath_qualname,      PosixPath.__qualname__.__eq__,      ["PosixPath"],       true]
    - [WindowsPath_qualname,    WindowsPath.__qualname__.__eq__,    ["WindowsPath"],     true]

# ---------------------------------------------------------------------------
# pathlib.Path class method __qualname__ attributes
#
# Class methods (like cwd and home) have a __qualname__ that includes the
# class name as a prefix, following the pattern '<ClassName>.<method_name>'.
#
#   Path.cwd.__qualname__  == 'Path.cwd'   (len 8)
#   Path.home.__qualname__ == 'Path.home'  (len 9)
#
# pathlib_extra47 covers both of these via __qualname__.__len__() checks.
# No prior pathlib spec covers the string equality of these qualnames.
# Both are novel equality anchors in the pathlib_extra49 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra49.Path_classmethod_qualnames:
  description: "pathlib.Path class method __qualname__ attributes: cwd=='Path.cwd' and home=='Path.home' — qualname includes class prefix for bound methods; pathlib_extra47 covers __qualname__.__len__() for both (8 and 9); no prior pathlib spec checks the string equality; both novel equality anchors in pathlib_extra49 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: method_identity
  id_prefix: pcmq49

  columns: [id, function, args, expected]
  rows:
    - [cwd_qualname,  Path.cwd.__qualname__.__eq__,  ["Path.cwd"],  true]
    - [home_qualname, Path.home.__qualname__.__eq__, ["Path.home"], true]
