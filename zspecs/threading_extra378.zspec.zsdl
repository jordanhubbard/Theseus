spec: threading_extra378
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.current_thread.__name__ == 'current_thread' — pure-Python wrapper in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.current_thread.__module__ == 'threading' — defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.main_thread.__name__ == 'main_thread' — pure-Python function in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.main_thread.__module__ == 'threading' — defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.active_count.__name__ == 'active_count' — pure-Python function in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.active_count.__module__ == 'threading' — defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.enumerate.__name__ == 'enumerate' — pure-Python function in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.enumerate.__module__ == 'threading' — defined in Lib/threading.py; shadows built-in enumerate within the module. Verified with Python 3.14.3."
    - "threading.settrace.__name__ == 'settrace' — pure-Python function in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.settrace.__module__ == 'threading' — defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.setprofile.__name__ == 'setprofile' — pure-Python function in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.setprofile.__module__ == 'threading' — defined in Lib/threading.py. Verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading thread-introspection function identity
#          (current_thread, main_thread, active_count, enumerate)
#
# threading.current_thread.__name__ == 'current_thread' / __module__ == 'threading'
# threading.main_thread.__name__ == 'main_thread'       / __module__ == 'threading'
# threading.active_count.__name__ == 'active_count'     / __module__ == 'threading'
# threading.enumerate.__name__ == 'enumerate'            / __module__ == 'threading'
#
# All four are pure-Python functions in Lib/threading.py that inspect the
# current state of running threads. threading.enumerate shadows the built-in
# enumerate within the module namespace but its own __name__ is 'enumerate'
# and __module__ is 'threading'.
# ---------------------------------------------------------------------------

table threading_extra378.thread_introspection_identity:
  description: "threading.current_thread, main_thread, active_count, enumerate function identity: __name__ and __module__; all pure-Python in Lib/threading.py; new to extra378"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingti378

  columns: [id, function, args, expected, description]
  rows:
    - [current_thread_name_eq,
       "current_thread.__name__.__eq__",
       ["current_thread"],
       true,
       "threading.current_thread.__name__.__eq__('current_thread') == True — current_thread is a pure-Python function in Lib/threading.py that returns the Thread object corresponding to the caller's thread of control; its __name__ is 'current_thread'; str.__eq__('current_thread') returns True; new to extra378"]
    - [current_thread_module_eq,
       "current_thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.current_thread.__module__.__eq__('threading') == True — current_thread is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra378"]
    - [main_thread_name_eq,
       "main_thread.__name__.__eq__",
       ["main_thread"],
       true,
       "threading.main_thread.__name__.__eq__('main_thread') == True — main_thread is a pure-Python function in Lib/threading.py that returns the main Thread object (the thread from which the Python interpreter was started); its __name__ is 'main_thread'; str.__eq__('main_thread') returns True; new to extra378"]
    - [main_thread_module_eq,
       "main_thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.main_thread.__module__.__eq__('threading') == True — main_thread is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra378"]
    - [active_count_name_eq,
       "active_count.__name__.__eq__",
       ["active_count"],
       true,
       "threading.active_count.__name__.__eq__('active_count') == True — active_count is a pure-Python function in Lib/threading.py that returns the number of Thread objects currently alive; its __name__ is 'active_count'; str.__eq__('active_count') returns True; new to extra378"]
    - [active_count_module_eq,
       "active_count.__module__.__eq__",
       ["threading"],
       true,
       "threading.active_count.__module__.__eq__('threading') == True — active_count is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra378"]
    - [enumerate_name_eq,
       "enumerate.__name__.__eq__",
       ["enumerate"],
       true,
       "threading.enumerate.__name__.__eq__('enumerate') == True — threading.enumerate is a pure-Python function in Lib/threading.py that returns a list of all Thread objects currently alive; it shadows the built-in enumerate within the module; its __name__ is 'enumerate'; str.__eq__('enumerate') returns True; new to extra378"]
    - [enumerate_module_eq,
       "enumerate.__module__.__eq__",
       ["threading"],
       true,
       "threading.enumerate.__module__.__eq__('threading') == True — threading.enumerate is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra378"]

# ---------------------------------------------------------------------------
# Table 2: threading trace/profile hook function identity (settrace, setprofile)
#
# threading.settrace.__name__ == 'settrace'     / __module__ == 'threading'
# threading.setprofile.__name__ == 'setprofile' / __module__ == 'threading'
#
# settrace installs a trace function for all threads started from the threading
# module. setprofile installs a profile function similarly. Both are pure-Python
# functions in Lib/threading.py.
# ---------------------------------------------------------------------------

table threading_extra378.trace_profile_hook_identity:
  description: "threading.settrace and threading.setprofile hook-installer function identity: __name__ and __module__; both pure-Python in Lib/threading.py; new to extra378"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtp378

  columns: [id, function, args, expected, description]
  rows:
    - [settrace_name_eq,
       "settrace.__name__.__eq__",
       ["settrace"],
       true,
       "threading.settrace.__name__.__eq__('settrace') == True — settrace is a pure-Python function in Lib/threading.py that installs a trace function for all threads started from the threading module; its __name__ is 'settrace'; str.__eq__('settrace') returns True; new to extra378"]
    - [settrace_module_eq,
       "settrace.__module__.__eq__",
       ["threading"],
       true,
       "threading.settrace.__module__.__eq__('threading') == True — settrace is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra378"]
    - [setprofile_name_eq,
       "setprofile.__name__.__eq__",
       ["setprofile"],
       true,
       "threading.setprofile.__name__.__eq__('setprofile') == True — setprofile is a pure-Python function in Lib/threading.py that installs a profile function for all threads started from the threading module; its __name__ is 'setprofile'; str.__eq__('setprofile') returns True; new to extra378"]
    - [setprofile_module_eq,
       "setprofile.__module__.__eq__",
       ["threading"],
       true,
       "threading.setprofile.__module__.__eq__('threading') == True — setprofile is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra378"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra378
# ---------------------------------------------------------------------------

invariant threading_extra378.current_thread_name:
  description: "threading.current_thread.__name__ == 'current_thread' — pure-Python function returning the caller's Thread object; new to extra378"
  kind: python_call_eq
  function: current_thread.__name__.__eq__
  args: ["current_thread"]
  expected: true

invariant threading_extra378.current_thread_module:
  description: "threading.current_thread.__module__ == 'threading' — defined in Lib/threading.py; new to extra378"
  kind: python_call_eq
  function: current_thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra378.main_thread_name:
  description: "threading.main_thread.__name__ == 'main_thread' — pure-Python function returning the main Thread object; new to extra378"
  kind: python_call_eq
  function: main_thread.__name__.__eq__
  args: ["main_thread"]
  expected: true

invariant threading_extra378.main_thread_module:
  description: "threading.main_thread.__module__ == 'threading' — defined in Lib/threading.py; new to extra378"
  kind: python_call_eq
  function: main_thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra378.active_count_name:
  description: "threading.active_count.__name__ == 'active_count' — pure-Python function returning count of alive Thread objects; new to extra378"
  kind: python_call_eq
  function: active_count.__name__.__eq__
  args: ["active_count"]
  expected: true

invariant threading_extra378.active_count_module:
  description: "threading.active_count.__module__ == 'threading' — defined in Lib/threading.py; new to extra378"
  kind: python_call_eq
  function: active_count.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra378.enumerate_name:
  description: "threading.enumerate.__name__ == 'enumerate' — pure-Python function listing all alive Thread objects; shadows built-in enumerate in module namespace; new to extra378"
  kind: python_call_eq
  function: enumerate.__name__.__eq__
  args: ["enumerate"]
  expected: true

invariant threading_extra378.enumerate_module:
  description: "threading.enumerate.__module__ == 'threading' — defined in Lib/threading.py; new to extra378"
  kind: python_call_eq
  function: enumerate.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra378.settrace_name:
  description: "threading.settrace.__name__ == 'settrace' — pure-Python function installing per-thread trace hooks; new to extra378"
  kind: python_call_eq
  function: settrace.__name__.__eq__
  args: ["settrace"]
  expected: true

invariant threading_extra378.settrace_module:
  description: "threading.settrace.__module__ == 'threading' — defined in Lib/threading.py; new to extra378"
  kind: python_call_eq
  function: settrace.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra378.setprofile_name:
  description: "threading.setprofile.__name__ == 'setprofile' — pure-Python function installing per-thread profile hooks; new to extra378"
  kind: python_call_eq
  function: setprofile.__name__.__eq__
  args: ["setprofile"]
  expected: true

invariant threading_extra378.setprofile_module:
  description: "threading.setprofile.__module__ == 'threading' — defined in Lib/threading.py; new to extra378"
  kind: python_call_eq
  function: setprofile.__module__.__eq__
  args: ["threading"]
  expected: true
