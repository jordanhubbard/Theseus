spec: statistics_extra12
version: ">=3.8"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics.zspec.zsdl and prior extras through statistics_extra11.zspec.zsdl."
    - "statistics_extra10 covers: mean([10,20,30])==20, mean([-1,-2,-3])==-2."
    - "No prior spec covers mean([1,2,3,4,5])==3 (five-element symmetrical list)."
    - "statistics_extra10 covers: variance([1,2,3,4])==1.666..., variance([0,0])==0."
    - "No prior spec covers variance([1,2,3])==1.0 (minimal three-element case, exact integer result)."
    - "statistics_extra.zspec covers stdev([2,4])==1.414...; statistics_extra10 covers stdev([1,2,3,4])."
    - "No prior spec covers stdev([1,2,3])==1.0 (exact unit standard deviation)."
    - "statistics_extra3 covers geometric_mean([4,9])==6.0; statistics_extra5 covers geometric_mean([1,2,4,8])."
    - "No prior spec covers geometric_mean([2,8])==4.0 (sqrt(16)) — new two-element vector."
    - "statistics_extra.zspec covers harmonic_mean([1,2,4])==1.714...; no prior spec covers harmonic_mean([2,3,6])==3.0."
    - "statistics_extra7 covers fmean([5])==5.0 and fmean([2.0,4.0])==3.0."
    - "No prior spec covers fmean([3,6,9])==6.0 (integer inputs, three elements)."
    - "statistics_extra7 covers pvariance([1,2,3])==0.666...; no prior spec covers pvariance([1,3,5])==2.666..."
    - "statistics_extra7 covers pstdev([1,2,3])==0.816...; no prior spec covers pstdev([1,3,5])==1.632..."
    - "No prior spec covers median_low([1,2,3,4])==2 or median_high([1,2,3,4])==3 with this vector."
    - "statistics.mean([1,2,3,4,5]) == 3 — symmetrical five-element list, mean at center element."
    - "statistics.variance([1,2,3]) == 1 — minimal case with exact integer result."
    - "statistics.stdev([1,2,3]) == 1.0 — unit standard deviation, exact float."
    - "statistics.geometric_mean([2,8]) == 4.0 — sqrt(2*8) == sqrt(16) == 4.0."
    - "statistics.harmonic_mean([2,3,6]) == 3.0 — 3 / (1/2 + 1/3 + 1/6) == 3 / 1 == 3.0."
    - "statistics.fmean([3,6,9]) == 6.0 — fast float mean of arithmetic progression."
    - "statistics.pvariance([1,3,5]) == 2.666... — population variance of arithmetic sequence."
    - "statistics.pstdev([1,3,5]) == 1.632... — population stdev of arithmetic sequence."
    - "statistics.median_low([1,2,3,4]) == 2 — low median of even-length list."
    - "statistics.median_high([1,2,3,4]) == 3 — high median of even-length list."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# mean — five-element symmetrical list
#
# statistics_extra10 covers mean([10,20,30])==20 and mean([-1,-2,-3])==-2.
# No prior spec covers mean([1,2,3,4,5])==3 — the center element of an
# arithmetic progression starting at 1 is the mean by symmetry.
# ---------------------------------------------------------------------------

invariant statistics_extra12.mean.one_through_five:
  description: "statistics.mean([1,2,3,4,5]) == 3 — mean of a symmetric arithmetic progression"
  category: mean
  kind: python_call_eq
  function: mean
  args: [[1, 2, 3, 4, 5]]
  expected: 3

# ---------------------------------------------------------------------------
# variance — three-element case with exact integer result
#
# statistics_extra10 covers variance([1,2,3,4])==1.666... and variance([0,0])==0.
# No prior spec covers variance([1,2,3])==1.0 (sample variance, exact result).
# Sample variance: mean==2, deviations are -1,0,1, squared sum==2, divided by 2 == 1.
# ---------------------------------------------------------------------------

invariant statistics_extra12.variance.one_two_three:
  description: "statistics.variance([1,2,3]) == 1 — sample variance of [1,2,3] is exactly 1"
  category: variance
  kind: python_call_eq
  function: variance
  args: [[1, 2, 3]]
  expected: 1

# ---------------------------------------------------------------------------
# stdev — unit standard deviation
#
# statistics_extra.zspec covers stdev([2,4])==1.414...; extra10 covers stdev([1,2,3,4]).
# No prior spec covers stdev([1,2,3])==1.0 (the exact integer unit stdev case).
# Since variance([1,2,3])==1, stdev == sqrt(1) == 1.0 exactly.
# ---------------------------------------------------------------------------

invariant statistics_extra12.stdev.unit:
  description: "statistics.stdev([1,2,3]) == 1.0 — unit standard deviation, exact float result"
  category: stdev
  kind: python_call_eq
  function: stdev
  args: [[1, 2, 3]]
  expected: 1.0

# ---------------------------------------------------------------------------
# geometric_mean — two-element perfect square vector
#
# statistics_extra3 covers geometric_mean([4,9])==6.0 (two elements, sqrt(36)).
# statistics_extra5 covers geometric_mean([1,2,4,8]) (four elements, type check).
# No prior spec covers geometric_mean([2,8])==4.0 — sqrt(2*8)==sqrt(16)==4.0.
# This is a different two-element vector: factors of 16 instead of 36.
# ---------------------------------------------------------------------------

invariant statistics_extra12.geometric_mean.two_eight:
  description: "statistics.geometric_mean([2,8]) == 4.0 — sqrt(2*8) == sqrt(16) == 4.0"
  category: geometric_mean
  kind: python_call_eq
  function: geometric_mean
  args: [[2, 8]]
  expected: 4.0

# ---------------------------------------------------------------------------
# harmonic_mean — three-element case with exact integer result
#
# statistics_extra.zspec covers harmonic_mean([1,2,4])==1.714...
# No prior spec covers harmonic_mean([2,3,6])==3.0.
# HM = 3 / (1/2 + 1/3 + 1/6) = 3 / (3/6 + 2/6 + 1/6) = 3 / (6/6) = 3.0 (exact).
# ---------------------------------------------------------------------------

invariant statistics_extra12.harmonic_mean.two_three_six:
  description: "statistics.harmonic_mean([2,3,6]) == 3.0 — HM = 3 / (1/2 + 1/3 + 1/6) == 3.0"
  category: harmonic_mean
  kind: python_call_eq
  function: harmonic_mean
  args: [[2, 3, 6]]
  expected: 3.0

# ---------------------------------------------------------------------------
# fmean — integer inputs, three elements
#
# statistics_extra7 covers fmean([5])==5.0 and fmean([2.0,4.0])==3.0.
# No prior spec covers fmean([3,6,9])==6.0 (integer input, three elements).
# fmean always returns a float; (3+6+9)/3 == 18/3 == 6.0.
# ---------------------------------------------------------------------------

invariant statistics_extra12.fmean.three_six_nine:
  description: "statistics.fmean([3,6,9]) == 6.0 — fast float mean of arithmetic progression"
  category: fmean
  kind: python_call_eq
  function: fmean
  args: [[3, 6, 9]]
  expected: 6.0

# ---------------------------------------------------------------------------
# pvariance — new vector [1, 3, 5]
#
# statistics_extra7 covers pvariance([1,2,3])==0.666...
# No prior spec covers pvariance([1,3,5])==2.666... (arithmetic progression step 2).
# Population variance: mean==3, deviations: -2,0,2, squared sum==8, divided by 3 == 8/3.
# Verified: 2.6666666666666665.
# ---------------------------------------------------------------------------

invariant statistics_extra12.pvariance.one_three_five:
  description: "statistics.pvariance([1,3,5]) == 2.666... — population variance of arithmetic sequence with step 2"
  category: pvariance
  kind: python_call_eq
  function: pvariance
  args: [[1, 3, 5]]
  expected: 2.6666666666666665

# ---------------------------------------------------------------------------
# pstdev — new vector [1, 3, 5]
#
# statistics_extra7 covers pstdev([1,2,3])==0.816...
# No prior spec covers pstdev([1,3,5])==1.632...
# pstdev == sqrt(pvariance) == sqrt(8/3) == 1.632993161855452.
# ---------------------------------------------------------------------------

invariant statistics_extra12.pstdev.one_three_five:
  description: "statistics.pstdev([1,3,5]) == 1.632... — population stdev of arithmetic sequence with step 2"
  category: pstdev
  kind: python_call_eq
  function: pstdev
  args: [[1, 3, 5]]
  expected: 1.632993161855452

# ---------------------------------------------------------------------------
# median_low / median_high — even-length list
#
# No prior spec checks median_low or median_high with [1,2,3,4].
# For an even-length sorted list [1,2,3,4]:
#   median_low returns the lower of the two middle values: 2.
#   median_high returns the higher of the two middle values: 3.
# These cover a different axis from median() which returns 2.5 (the average).
# ---------------------------------------------------------------------------

invariant statistics_extra12.median_low.four_elements:
  description: "statistics.median_low([1,2,3,4]) == 2 — lower middle value of even-length list"
  category: median
  kind: python_call_eq
  function: median_low
  args: [[1, 2, 3, 4]]
  expected: 2

invariant statistics_extra12.median_high.four_elements:
  description: "statistics.median_high([1,2,3,4]) == 3 — upper middle value of even-length list"
  category: median
  kind: python_call_eq
  function: median_high
  args: [[1, 2, 3, 4]]
  expected: 3
