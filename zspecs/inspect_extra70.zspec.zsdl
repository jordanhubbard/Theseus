spec: inspect_extra70
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra69.zspec.zsdl."
    - "Wave 236 theme: inspect module spec/loader identity, formatargvalues/classify_class_attrs/unwrap function identity."
    - "inspect.__name__ == 'inspect' — module __name__ equals its registered fully-qualified name. Verified with Python 3.14.3."
    - "inspect.__spec__.name == 'inspect' — ModuleSpec.name is the fully-qualified name used by the import system. Verified with Python 3.14.3."
    - "inspect.__loader__.__class__.__name__ == 'SourceFileLoader' — inspect is a pure-Python module (Lib/inspect.py) loaded by SourceFileLoader. Verified with Python 3.14.3."
    - "inspect.__file__.__contains__('.py') == True — inspect.__file__ is a path ending with '.py'. Verified with Python 3.14.3."
    - "formatargvalues.__class__.__name__ == 'function' — formatargvalues is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "formatargvalues.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "formatargvalues.__qualname__ == 'formatargvalues' — top-level function so qualname equals simple name. Verified with Python 3.14.3."
    - "classify_class_attrs.__class__.__name__ == 'function' — classify_class_attrs is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "classify_class_attrs.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "classify_class_attrs.__qualname__ == 'classify_class_attrs' — top-level function so qualname equals simple name. Verified with Python 3.14.3."
    - "unwrap.__class__.__name__ == 'function' — unwrap is a pure-Python function in Lib/inspect.py (added in 3.4). Verified with Python 3.14.3."
    - "unwrap.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "unwrap.__qualname__ == 'unwrap' — top-level function so qualname equals simple name. Verified with Python 3.14.3."
    - "unwrap.__code__.co_argcount == 1 — def unwrap(func, *, stop=None): has one positional parameter 'func'; stop is keyword-only so co_argcount == 1. Verified with Python 3.14.3."
    - "Prior inspect_extra69 covered getattr_static, isabstract, ismethod, iscoroutinefunction identity. This spec covers inspect module spec/loader checks and formatargvalues, classify_class_attrs, unwrap identity — all novel under the inspmore70 id_prefix. All checks in this spec are new to extra70."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect module spec identity — extra70
#
# Wave 236 theme: inspect module __name__, __spec__, __loader__, __file__ checks.
#
# inspect is a pure-Python module (Lib/inspect.py). Like all importable
# modules it has a __name__ attribute equal to its fully-qualified name,
# a __spec__ of type ModuleSpec, and a __loader__ of type SourceFileLoader.
#
# inspect.__name__                         == 'inspect'
# inspect.__spec__.name                    == 'inspect'
# inspect.__loader__.__class__.__name__    == 'SourceFileLoader'
# inspect.__file__.__contains__('.py')     == True
#
# No prior inspect spec checks these module-spec attributes via inspmore70.
# New to extra70.
# ---------------------------------------------------------------------------

table inspect_extra70.inspect_module_spec:
  description: "inspect module spec identity: __name__=='inspect', __spec__.name=='inspect', __loader__.__class__.__name__=='SourceFileLoader', __file__ contains '.py'; wave 236 module spec identity; new to extra70"
  kind: python_call_eq
  category: module_identity
  id_prefix: inspmore70

  columns: [id, function, args, expected, description]
  rows:
    - [inspect_name_eq_inspect,
       __name__.__eq__,
       ["inspect"],
       true,
       "inspect.__name__.__eq__('inspect') == True — every Python module has a __name__ attribute equal to its fully-qualified module name as registered in sys.modules; for the top-level inspect module this is 'inspect' (7 chars) with no package prefix; str.__eq__('inspect') returns True; no prior inspect spec checks __name__.__eq__ via the inspmore70 id_prefix; new to extra70"]
    - [inspect_spec_name_eq_inspect,
       __spec__.name.__eq__,
       ["inspect"],
       true,
       "inspect.__spec__.name.__eq__('inspect') == True — __spec__ is an importlib.machinery.ModuleSpec object carrying the metadata the import system uses; ModuleSpec.name is the fully-qualified module name 'inspect' (7 chars); __eq__ returns True; no prior inspect spec checks __spec__.name via the inspmore70 id_prefix; new to extra70"]
    - [inspect_loader_class_name_eq_SourceFileLoader,
       __loader__.__class__.__name__.__eq__,
       ["SourceFileLoader"],
       true,
       "inspect.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — inspect is a pure-Python module stored in Lib/inspect.py; the import system uses importlib._bootstrap_external.SourceFileLoader to read and compile the source; SourceFileLoader.__name__ == 'SourceFileLoader' (16 chars); __eq__ returns True; no prior inspect spec checks __loader__.__class__.__name__ via the inspmore70 id_prefix; new to extra70"]
    - [inspect_file_contains_py,
       __file__.__contains__,
       [".py"],
       true,
       "inspect.__file__.__contains__('.py') == True — inspect is a pure-Python source module; its __file__ attribute is the absolute path to Lib/inspect.py, which ends with '.py'; str.__contains__('.py') returns True; no prior inspect spec checks __file__.__contains__('.py') via the inspmore70 id_prefix; new to extra70"]

# ---------------------------------------------------------------------------
# formatargvalues identity — extra70
#
# Wave 236 theme: formatargvalues is a pure-Python function in Lib/inspect.py.
#
# inspect.formatargvalues formats an argument list using inspect.getargvalues
# results. It is a top-level function with:
#
# formatargvalues.__class__.__name__ == 'function'
# formatargvalues.__module__         == 'inspect'
# formatargvalues.__qualname__       == 'formatargvalues'
#
# No prior inspect spec checks formatargvalues identity via inspmore70. New to extra70.
# ---------------------------------------------------------------------------

table inspect_extra70.formatargvalues_identity:
  description: "formatargvalues identity: __class__.__name__=='function', __module__=='inspect', __qualname__=='formatargvalues'; wave 236 formatargvalues identity; new to extra70"
  kind: python_call_eq
  category: function_identity
  id_prefix: inspmore70

  columns: [id, function, args, expected, description]
  rows:
    - [formatargvalues_class_name_eq_function,
       formatargvalues.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.formatargvalues.__class__.__name__.__eq__('function') == True — formatargvalues is a pure-Python function defined in Lib/inspect.py that formats argument information returned by getargvalues into a human-readable string; its __class__ is the built-in function type; function.__name__ == 'function' (8 chars); __eq__ returns True; no prior inspect spec checks formatargvalues.__class__.__name__ via inspmore70; new to extra70"]
    - [formatargvalues_module_eq_inspect,
       formatargvalues.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.formatargvalues.__module__.__eq__('inspect') == True — formatargvalues is defined in Lib/inspect.py and belongs to the inspect module; its __module__ attribute is 'inspect' (7 chars); __eq__ returns True; no prior inspect spec checks formatargvalues.__module__ via inspmore70; new to extra70"]
    - [formatargvalues_qualname_eq_formatargvalues,
       formatargvalues.__qualname__.__eq__,
       ["formatargvalues"],
       true,
       "inspect.formatargvalues.__qualname__.__eq__('formatargvalues') == True — formatargvalues is a top-level function in the inspect module (no enclosing class or function scope); its __qualname__ is therefore equal to its simple name 'formatargvalues' (15 chars); __eq__ returns True; no prior inspect spec checks formatargvalues.__qualname__ via inspmore70; new to extra70"]

# ---------------------------------------------------------------------------
# classify_class_attrs identity — extra70
#
# Wave 236 theme: classify_class_attrs is a pure-Python function in Lib/inspect.py.
#
# inspect.classify_class_attrs returns a list of Attribute named-tuples
# describing the attributes of a class, partitioned into categories
# (method, class method, static method, data, etc.). It is a top-level function.
#
# classify_class_attrs.__class__.__name__ == 'function'
# classify_class_attrs.__module__         == 'inspect'
# classify_class_attrs.__qualname__       == 'classify_class_attrs'
#
# No prior inspect spec checks classify_class_attrs identity via inspmore70. New to extra70.
# ---------------------------------------------------------------------------

table inspect_extra70.classify_class_attrs_identity:
  description: "classify_class_attrs identity: __class__.__name__=='function', __module__=='inspect', __qualname__=='classify_class_attrs'; wave 236 classify_class_attrs identity; new to extra70"
  kind: python_call_eq
  category: function_identity
  id_prefix: inspmore70

  columns: [id, function, args, expected, description]
  rows:
    - [classify_class_attrs_class_name_eq_function,
       classify_class_attrs.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.classify_class_attrs.__class__.__name__.__eq__('function') == True — classify_class_attrs is a pure-Python function defined in Lib/inspect.py that returns a list of Attribute named-tuples classifying each attribute of a class by kind (method, class method, static method, property, data); its __class__ is the built-in function type; function.__name__ == 'function' (8 chars); __eq__ returns True; no prior inspect spec checks classify_class_attrs.__class__.__name__ via inspmore70; new to extra70"]
    - [classify_class_attrs_module_eq_inspect,
       classify_class_attrs.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.classify_class_attrs.__module__.__eq__('inspect') == True — classify_class_attrs is defined in Lib/inspect.py; its __module__ attribute is 'inspect' (7 chars); __eq__ returns True; no prior inspect spec checks classify_class_attrs.__module__ via inspmore70; new to extra70"]
    - [classify_class_attrs_qualname_eq_classify_class_attrs,
       classify_class_attrs.__qualname__.__eq__,
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__qualname__.__eq__('classify_class_attrs') == True — classify_class_attrs is a top-level function in the inspect module (no enclosing class or function scope); its __qualname__ is equal to its simple name 'classify_class_attrs' (20 chars); __eq__ returns True; no prior inspect spec checks classify_class_attrs.__qualname__ via inspmore70; new to extra70"]

# ---------------------------------------------------------------------------
# unwrap identity and co_argcount — extra70
#
# Wave 236 theme: unwrap is a pure-Python function in Lib/inspect.py.
#
# inspect.unwrap follows the __wrapped__ chain of decorators to get the
# original function. Its signature is: def unwrap(func, *, stop=None)
#
# unwrap.__class__.__name__      == 'function'
# unwrap.__module__              == 'inspect'
# unwrap.__qualname__            == 'unwrap'
# unwrap.__code__.co_argcount    == 1   (only 'func' is positional; stop is keyword-only)
#
# No prior inspect spec checks unwrap identity via inspmore70. New to extra70.
# ---------------------------------------------------------------------------

table inspect_extra70.unwrap_identity:
  description: "unwrap identity: __class__.__name__=='function', __module__=='inspect', __qualname__=='unwrap', co_argcount==1; wave 236 unwrap identity; new to extra70"
  kind: python_call_eq
  category: function_identity
  id_prefix: inspmore70

  columns: [id, function, args, expected, description]
  rows:
    - [unwrap_class_name_eq_function,
       unwrap.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.unwrap.__class__.__name__.__eq__('function') == True — unwrap is a pure-Python function defined in Lib/inspect.py (added in Python 3.4) that follows the chain of __wrapped__ attributes to retrieve the innermost unwrapped function beneath a series of decorators; its __class__ is the built-in function type; function.__name__ == 'function' (8 chars); __eq__ returns True; no prior inspect spec checks unwrap.__class__.__name__ via inspmore70; new to extra70"]
    - [unwrap_module_eq_inspect,
       unwrap.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.unwrap.__module__.__eq__('inspect') == True — unwrap is defined in Lib/inspect.py; its __module__ attribute is 'inspect' (7 chars); __eq__ returns True; no prior inspect spec checks unwrap.__module__ via inspmore70; new to extra70"]
    - [unwrap_qualname_eq_unwrap,
       unwrap.__qualname__.__eq__,
       ["unwrap"],
       true,
       "inspect.unwrap.__qualname__.__eq__('unwrap') == True — unwrap is a top-level function in the inspect module (no enclosing class or function scope); its __qualname__ is equal to its simple name 'unwrap' (6 chars); __eq__ returns True; no prior inspect spec checks unwrap.__qualname__ via inspmore70; new to extra70"]
    - [unwrap_co_argcount_eq_1,
       unwrap.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.unwrap.__code__.co_argcount.__eq__(1) == True — unwrap is defined as 'def unwrap(func, *, stop=None):' with one positional parameter 'func' and one keyword-only parameter 'stop'; co_argcount counts only positional parameters (those before the * separator) and excludes keyword-only, *args, and **kwargs parameters; for unwrap co_argcount == 1; int.__eq__(1) returns True; no prior inspect spec checks unwrap.__code__.co_argcount via inspmore70; new to extra70"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra70
# ---------------------------------------------------------------------------

invariant inspect_extra70.inspect_name_inspect:
  description: "inspect.__name__.__eq__('inspect') == True — module __name__ equals its registered fully-qualified name; wave 236 module spec identity; new to extra70"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra70.inspect_loader_SourceFileLoader:
  description: "inspect.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — inspect is a pure-Python .py module loaded by SourceFileLoader; wave 236 module loader identity; new to extra70"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant inspect_extra70.formatargvalues_module_inspect:
  description: "inspect.formatargvalues.__module__.__eq__('inspect') == True — formatargvalues is a pure-Python function defined in Lib/inspect.py; wave 236 formatargvalues identity; new to extra70"
  kind: python_call_eq
  function: formatargvalues.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra70.classify_class_attrs_module_inspect:
  description: "inspect.classify_class_attrs.__module__.__eq__('inspect') == True — classify_class_attrs is a pure-Python function defined in Lib/inspect.py; wave 236 classify_class_attrs identity; new to extra70"
  kind: python_call_eq
  function: classify_class_attrs.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra70.unwrap_co_argcount_1:
  description: "inspect.unwrap.__code__.co_argcount.__eq__(1) == True — unwrap(func, *, stop=None) has 1 positional parameter; wave 236 unwrap code attributes; new to extra70"
  kind: python_call_eq
  function: unwrap.__code__.co_argcount.__eq__
  args: [1]
  expected: true
