spec: decimal_extra2161
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "Theme: descriptor protocol dict-presence — checks for __get__, __set__, __delete__, __set_name__, fget, fset, fdel, __objclass__, __func__ in class __dict__."
    - "decimal.Decimal does not define __get__, __set__, __delete__, fget, fset, fdel, __set_name__, __objclass__, or __func__ in its own __dict__."
    - "decimal.Decimal exposes two getset_descriptor instances: real and imag (supporting the numeric tower). These descriptor instances have __objclass__ == decimal.Decimal, but the keys __get__, fget, __objclass__, etc. are NOT present in decimal.Decimal.__dict__ itself."
    - "decimal.Context does not define any descriptor protocol keys in its own __dict__. It exposes getset_descriptor instances for prec, Emax, Emin, rounding, capitals, and clamp — again, the descriptor protocol methods live on the getset_descriptor type, not on Context itself."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal — descriptor protocol dict-presence
#
# decimal.Decimal provides real and imag as getset_descriptor instances
# (numeric tower compatibility), but does NOT define __get__, fget,
# __objclass__, or any other descriptor protocol key in its own __dict__.
# ---------------------------------------------------------------------------

table decimal_extra2161.Decimal_descriptor_presence:
  kind: python_call_eq
  category: descriptor_presence
  columns: [id, function, args, expected]
  rows:
    - ["dc2161001", "decimal.Decimal.__dict__.__contains__", ["__get__"], false]
    - ["dc2161002", "decimal.Decimal.__dict__.__contains__", ["__set__"], false]
    - ["dc2161003", "decimal.Decimal.__dict__.__contains__", ["__delete__"], false]
    - ["dc2161004", "decimal.Decimal.__dict__.__contains__", ["__set_name__"], false]
    - ["dc2161005", "decimal.Decimal.__dict__.__contains__", ["fget"], false]
    - ["dc2161006", "decimal.Decimal.__dict__.__contains__", ["fset"], false]
    - ["dc2161007", "decimal.Decimal.__dict__.__contains__", ["fdel"], false]
    - ["dc2161008", "decimal.Decimal.__dict__.__contains__", ["__objclass__"], false]
    - ["dc2161009", "decimal.Decimal.__dict__.__contains__", ["__func__"], false]
    - ["dc2161010", "decimal.Decimal.__dict__.__contains__", ["real"], true]
    - ["dc2161011", "decimal.Decimal.__dict__.__contains__", ["imag"], true]
    - ["dc2161012", "decimal.Decimal.__dict__.__contains__", ["exp"], true]
    - ["dc2161013", "decimal.Decimal.__dict__.__contains__", ["sqrt"], true]
    - ["dc2161014", "decimal.Decimal.__dict__.__contains__", ["ln"], true]
    - ["dc2161015", "decimal.Decimal.__dict__.__contains__", ["log10"], true]
    - ["dc2161016", "decimal.Decimal.__dict__.__contains__", ["quantize"], true]
    - ["dc2161017", "decimal.Decimal.__dict__.__contains__", ["is_finite"], true]
    - ["dc2161018", "decimal.Decimal.__dict__.__contains__", ["is_nan"], true]
    - ["dc2161019", "decimal.Decimal.__dict__.__contains__", ["is_zero"], true]
    - ["dc2161020", "decimal.Decimal.__dict__.__contains__", ["as_tuple"], true]

# ---------------------------------------------------------------------------
# decimal.Context — descriptor protocol dict-presence
#
# decimal.Context provides getset_descriptor instances for prec, Emax,
# Emin, rounding, capitals, and clamp (mutable numeric context settings).
# The class does NOT define __get__, fget, __objclass__, etc. in its own
# __dict__ — those methods live on the getset_descriptor type.
# ---------------------------------------------------------------------------

table decimal_extra2161.Context_descriptor_presence:
  kind: python_call_eq
  category: descriptor_presence
  columns: [id, function, args, expected]
  rows:
