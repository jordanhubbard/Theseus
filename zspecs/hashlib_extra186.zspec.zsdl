spec: hashlib_extra186
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
  notes:
    - "hashlib.new.__name__ == '__hash_new' — the public 'new' attribute is an internal wrapper named '__hash_new'; len=10."
    - "hashlib.new.__module__ == 'hashlib' — the wrapper function is defined in the hashlib module."
    - "hashlib.new.__qualname__ == '__hash_new' — qualname matches the internal function name."
    - "hashlib.md5.__name__ == 'openssl_md5' — on macOS, md5 is backed by OpenSSL; len=11."
    - "hashlib.sha256.__name__ == 'openssl_sha256' — OpenSSL-backed SHA-256 constructor; len=14."
    - "hashlib.sha512.__name__ == 'openssl_sha512' — OpenSSL-backed SHA-512 constructor; len=14."
    - "hashlib.new.__class__.__name__ == 'function' — new is a plain Python function object."
    - "hashlib.new.__code__.co_argcount == 1 — one positional argument ('name'); remaining are keyword-only."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: hashlib.new function identity
#
# hashlib.new.__name__     == '__hash_new'   (internal wrapper; len=10)
# hashlib.new.__module__   == 'hashlib'
# hashlib.new.__qualname__ == '__hash_new'
# hashlib.new.__class__.__name__ == 'function'
#
# The public hashlib.new name is an alias for __hash_new, a private wrapper.
# ---------------------------------------------------------------------------

table hashlib_extra186.new_function_identity:
  description: "hashlib.new function identity: __name__, __module__, __qualname__, and class; new to extra186"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibhashobj186

  columns: [id, function, args, expected, description]
  rows:
    - [new_name_eq,
       new.__name__.__eq__,
       ["__hash_new"],
       true,
       "hashlib.new.__name__.__eq__('__hash_new') == True — public new is the __hash_new wrapper; len=10; new to extra186"]
    - [new_name_len,
       new.__name__.__len__,
       [],
       10,
       "hashlib.new.__name__.__len__() == 10 — '__hash_new' has 10 characters; new to extra186"]
    - [new_module_eq,
       new.__module__.__eq__,
       ["hashlib"],
       true,
       "hashlib.new.__module__.__eq__('hashlib') == True — wrapper function is defined in hashlib; new to extra186"]
    - [new_qualname_eq,
       new.__qualname__.__eq__,
       ["__hash_new"],
       true,
       "hashlib.new.__qualname__.__eq__('__hash_new') == True — qualname matches internal function name; new to extra186"]
    - [new_class_name_eq,
       new.__class__.__name__.__eq__,
       ["function"],
       true,
       "hashlib.new.__class__.__name__.__eq__('function') == True — new is a plain Python function; new to extra186"]

# ---------------------------------------------------------------------------
# Table 2: hashlib.new code object attributes
#
# hashlib.new.__code__.co_argcount == 1
#   — one positional argument ('name'); remaining hash parameters are keyword-only.
# ---------------------------------------------------------------------------

table hashlib_extra186.new_code_attributes:
  description: "hashlib.new.__code__ positional argument count; new to extra186"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibhashobj186

  columns: [id, function, args, expected, description]
  rows:
    - [new_co_argcount,
       new.__code__.co_argcount.__eq__,
       [1],
       true,
       "hashlib.new.__code__.co_argcount.__eq__(1) == True — one positional arg ('name'); new to extra186"]
    - [new_co_argcount_val,
       new.__code__.co_argcount.__class__.__name__.__eq__,
       ["int"],
       true,
       "hashlib.new.__code__.co_argcount type is int; new to extra186"]

# ---------------------------------------------------------------------------
# Table 3: OpenSSL-backed constructor __name__ values
#
# hashlib.md5.__name__    == 'openssl_md5'    (len=11)
# hashlib.sha256.__name__ == 'openssl_sha256' (len=14)
# hashlib.sha512.__name__ == 'openssl_sha512' (len=14)
#
# On macOS with OpenSSL, the MD5/SHA constructors are backed by OpenSSL.
# ---------------------------------------------------------------------------

table hashlib_extra186.openssl_constructor_names:
  description: "hashlib OpenSSL-backed constructor __name__ values on macOS; new to extra186"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibhashobj186

  columns: [id, function, args, expected, description]
  rows:
    - [md5_name_eq,
       md5.__name__.__eq__,
       ["openssl_md5"],
       true,
       "hashlib.md5.__name__.__eq__('openssl_md5') == True — MD5 constructor is OpenSSL-backed on macOS; new to extra186"]
    - [md5_name_len,
       md5.__name__.__len__,
       [],
       11,
       "hashlib.md5.__name__.__len__() == 11 — 'openssl_md5' has 11 characters; new to extra186"]
    - [sha256_name_eq,
       sha256.__name__.__eq__,
       ["openssl_sha256"],
       true,
       "hashlib.sha256.__name__.__eq__('openssl_sha256') == True — SHA-256 constructor is OpenSSL-backed on macOS; new to extra186"]
    - [sha256_name_len,
       sha256.__name__.__len__,
       [],
       14,
       "hashlib.sha256.__name__.__len__() == 14 — 'openssl_sha256' has 14 characters; new to extra186"]
    - [sha512_name_eq,
       sha512.__name__.__eq__,
       ["openssl_sha512"],
       true,
       "hashlib.sha512.__name__.__eq__('openssl_sha512') == True — SHA-512 constructor is OpenSSL-backed on macOS; new to extra186"]
    - [sha512_name_len,
       sha512.__name__.__len__,
       [],
       14,
       "hashlib.sha512.__name__.__len__() == 14 — 'openssl_sha512' has 14 characters; new to extra186"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra186
# ---------------------------------------------------------------------------

invariant hashlib_extra186.new_name_is_hash_new:
  description: "hashlib.new.__name__ == '__hash_new' — the public new attribute is an internal wrapper; len=10; new to extra186"
  category: identity
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["__hash_new"]
  expected: true

invariant hashlib_extra186.new_module_is_hashlib:
  description: "hashlib.new.__module__ == 'hashlib' — __hash_new wrapper is defined in the hashlib module; new to extra186"
  category: identity
  kind: python_call_eq
  function: new.__module__.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlib_extra186.new_qualname_is_hash_new:
  description: "hashlib.new.__qualname__ == '__hash_new' — qualname matches the private function name; new to extra186"
  category: identity
  kind: python_call_eq
  function: new.__qualname__.__eq__
  args: ["__hash_new"]
  expected: true

invariant hashlib_extra186.new_class_is_function:
  description: "hashlib.new.__class__.__name__ == 'function' — hashlib.new is a plain Python function object; new to extra186"
  category: identity
  kind: python_call_eq
  function: new.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant hashlib_extra186.md5_name_is_openssl_md5:
  description: "hashlib.md5.__name__ == 'openssl_md5' — MD5 constructor is OpenSSL-backed on macOS; len=11; new to extra186"
  category: identity
  kind: python_call_eq
  function: md5.__name__.__eq__
  args: ["openssl_md5"]
  expected: true

invariant hashlib_extra186.sha256_name_is_openssl_sha256:
  description: "hashlib.sha256.__name__ == 'openssl_sha256' — SHA-256 constructor is OpenSSL-backed on macOS; len=14; new to extra186"
  category: identity
  kind: python_call_eq
  function: sha256.__name__.__eq__
  args: ["openssl_sha256"]
  expected: true

invariant hashlib_extra186.sha512_name_is_openssl_sha512:
  description: "hashlib.sha512.__name__ == 'openssl_sha512' — SHA-512 constructor is OpenSSL-backed on macOS; len=14; new to extra186"
  category: identity
  kind: python_call_eq
  function: sha512.__name__.__eq__
  args: ["openssl_sha512"]
  expected: true

invariant hashlib_extra186.new_co_argcount_is_1:
  description: "hashlib.new.__code__.co_argcount == 1 — one positional argument 'name'; rest are keyword-only; new to extra186"
  category: identity
  kind: python_call_eq
  function: new.__code__.co_argcount.__eq__
  args: [1]
  expected: true
