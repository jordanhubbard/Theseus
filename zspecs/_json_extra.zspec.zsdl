spec: _json_extra
version: ">=3.9"
backend: python_module(_json)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json.zspec.zsdl, json_extra.zspec.zsdl, json_extra2.zspec.zsdl, and json_extra3.zspec.zsdl."
    - "The _json module is the C accelerator for the json stdlib module."
    - "_json.encode_basestring wraps a string in double quotes and escapes special chars."
    - "_json.encode_basestring_ascii also escapes non-ASCII chars as \\uXXXX sequences."
    - "_json.scanstring parses a JSON string token starting after the opening quote."
    - "_json.make_encoder is the C constructor for the Encoder type."
    - "_json.make_scanner is the C constructor for the Scanner type."
    - "_json functions report __module__ == '_json' on CPython (verified on 3.12)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ — encode_basestring and encode_basestring_ascii
# ---------------------------------------------------------------------------

invariant _json_extra.encode_basestring.__name__:
  description: "_json.encode_basestring.__name__ == 'encode_basestring'"
  category: identity
  kind: python_call_eq
  function: encode_basestring.__name__.__eq__
  args: ["encode_basestring"]
  expected: true

invariant _json_extra.encode_basestring_ascii.__name__:
  description: "_json.encode_basestring_ascii.__name__ == 'encode_basestring_ascii'"
  category: identity
  kind: python_call_eq
  function: encode_basestring_ascii.__name__.__eq__
  args: ["encode_basestring_ascii"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ — scanstring, make_encoder, make_scanner
# ---------------------------------------------------------------------------

invariant _json_extra.scanstring.__name__:
  description: "_json.scanstring.__name__ == 'scanstring'"
  category: identity
  kind: python_call_eq
  function: scanstring.__name__.__eq__
  args: ["scanstring"]
  expected: true

invariant _json_extra.make_encoder.__name__:
  description: "_json.make_encoder.__name__ == 'make_encoder'"
  category: identity
  kind: python_call_eq
  function: make_encoder.__name__.__eq__
  args: ["make_encoder"]
  expected: true

invariant _json_extra.make_scanner.__name__:
  description: "_json.make_scanner.__name__ == 'make_scanner'"
  category: identity
  kind: python_call_eq
  function: make_scanner.__name__.__eq__
  args: ["make_scanner"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — all functions report __module__ == '_json'
# ---------------------------------------------------------------------------

table _json_extra.function_modules:
  kind: python_call_eq
  category: identity
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [encode_basestring,       encode_basestring.__module__.__eq__,       ["_json"], true]
    - [encode_basestring_ascii, encode_basestring_ascii.__module__.__eq__, ["_json"], true]
    - [scanstring,              scanstring.__module__.__eq__,              ["_json"], true]
    - [make_encoder,            make_encoder.__module__.__eq__,            ["_json"], true]
    - [make_scanner,            make_scanner.__module__.__eq__,            ["_json"], true]

# ---------------------------------------------------------------------------
# encode_basestring — behavioral invariants
# ---------------------------------------------------------------------------

invariant _json_extra.encode_basestring.plain_ascii:
  description: "_json.encode_basestring('hello') == '\"hello\"' — plain ASCII wrapped in double quotes"
  category: behavioral
  kind: python_call_eq
  function: encode_basestring
  args: ["hello"]
  expected: "\"hello\""

invariant _json_extra.encode_basestring.empty_string:
  description: "_json.encode_basestring('') == '\"\"' — empty string becomes empty JSON string"
  category: behavioral
  kind: python_call_eq
  function: encode_basestring
  args: [""]
  expected: "\"\""

invariant _json_extra.encode_basestring.backslash:
  description: "_json.encode_basestring('a\\\\b') == '\"a\\\\\\\\b\"' — backslash is doubled"
  category: behavioral
  kind: python_call_eq
  function: encode_basestring
  args: ["a\\b"]
  expected: "\"a\\\\b\""

# ---------------------------------------------------------------------------
# encode_basestring_ascii — behavioral invariants
# ---------------------------------------------------------------------------

invariant _json_extra.encode_basestring_ascii.plain_ascii:
  description: "_json.encode_basestring_ascii('hi') == '\"hi\"' — pure ASCII, no escaping"
  category: behavioral
  kind: python_call_eq
  function: encode_basestring_ascii
  args: ["hi"]
  expected: "\"hi\""

invariant _json_extra.encode_basestring_ascii.tab_escape:
  description: "_json.encode_basestring_ascii('a\\tb') == '\"a\\\\tb\"' — tab escaped as \\t"
  category: behavioral
  kind: python_call_eq
  function: encode_basestring_ascii
  args: ["a\tb"]
  expected: "\"a\\tb\""

invariant _json_extra.encode_basestring_ascii.empty_string:
  description: "_json.encode_basestring_ascii('') == '\"\"' — empty string becomes empty JSON string"
  category: behavioral
  kind: python_call_eq
  function: encode_basestring_ascii
  args: [""]
  expected: "\"\""

# ---------------------------------------------------------------------------
# scanstring — behavioral invariants
# (scanstring(s, idx) scans a JSON string starting after the opening quote at idx)
# ---------------------------------------------------------------------------

invariant _json_extra.scanstring.simple_string:
  description: "_json.scanstring('\"hello\"', 1) == ('hello', 7) — parse hello from position 1"
  category: behavioral
  kind: python_call_eq
  function: scanstring
  args: ["\"hello\"", 1]
  expected: ["hello", 7]

invariant _json_extra.scanstring.empty_string:
  description: "_json.scanstring('\"\"', 1) == ('', 2) — parse empty string from position 1"
  category: behavioral
  kind: python_call_eq
  function: scanstring
  args: ["\"\"", 1]
  expected: ["", 2]
