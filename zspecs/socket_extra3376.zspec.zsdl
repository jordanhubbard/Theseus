docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 672 (sk3376): __trunc__, __round__, __index__ dict-presence checks for socket types."
    - "Theme: __trunc__/__round__/__index__ dict-presence (math.trunc(x), round(x), operator.index(x))."
    - "All values False — UUID, Struct, and socket types have no truncation, rounding, or integer-conversion protocol."
    - "socket.socket is a Python class; it does not define __trunc__, __round__, or __index__ in its __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses (EnumType metaclass)."
    - "AddressFamily and SocketKind are IntEnum but do NOT define __trunc__, __round__, or __index__ in their own __dict__; these methods are not overridden at the subclass level."
    - "operator.contains(socket.AddressFamily.__dict__, '__index__') is False — not present in AddressFamily's own __dict__."
    - "operator.contains(socket.SocketKind.__dict__, '__index__') is False — same reasoning as AddressFamily."
    - "All values are False for all 3 socket types across all 3 operators."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

