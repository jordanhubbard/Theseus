spec: decimal_extra231
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal string format contracts — __str__ output and __format__ with various format specs."
    - "str(decimal.Decimal('1.0')) == '1.0' — preserves trailing zero after decimal point; verified Python 3.14.3 macOS."
    - "str(decimal.Decimal('1.00')) == '1.00' — preserves two trailing zeros; verified Python 3.14.3 macOS."
    - "str(decimal.Decimal('0')) == '0' — zero renders as '0'; verified Python 3.14.3 macOS."
    - "str(decimal.Decimal('1E+2')) == '1E+2' — exponential notation preserved; verified Python 3.14.3 macOS."
    - "str(decimal.Decimal('0.001')) == '0.001' — small decimal with leading zeros preserved; verified Python 3.14.3 macOS."
    - "decimal.Decimal('1.5').__format__('f') == '1.5' — fixed-point format; verified Python 3.14.3 macOS."
    - "decimal.Decimal('1.5').__format__('.2f') == '1.50' — fixed-point with 2 decimal places pads with zero; verified Python 3.14.3 macOS."
    - "decimal.Decimal('1000').__format__(',') == '1,000' — thousands separator format; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.__str__() format contracts
# Decimal preserves the string representation used at construction time,
# including trailing zeros and exponential notation.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra231.Decimal.str_1_0:
  description: "str(decimal.Decimal('1.0')) == '1.0' — trailing zero after decimal preserved; verified Python 3.14.3 macOS"
  category: str_format
  kind: python_call_eq
  function: Decimal
  args: ["1.0"]
  method: __str__
  expected: "1.0"

invariant decimal_extra231.Decimal.str_1_00:
  description: "str(decimal.Decimal('1.00')) == '1.00' — two trailing zeros preserved; verified Python 3.14.3 macOS"
  category: str_format
  kind: python_call_eq
  function: Decimal
  args: ["1.00"]
  method: __str__
  expected: "1.00"

invariant decimal_extra231.Decimal.str_zero:
  description: "str(decimal.Decimal('0')) == '0' — zero renders as '0'; verified Python 3.14.3 macOS"
  category: str_format
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: __str__
  expected: "0"

invariant decimal_extra231.Decimal.str_exp:
  description: "str(decimal.Decimal('1E+2')) == '1E+2' — exponential notation preserved as-is; verified Python 3.14.3 macOS"
  category: str_format
  kind: python_call_eq
  function: Decimal
  args: ["1E+2"]
  method: __str__
  expected: "1E+2"

invariant decimal_extra231.Decimal.str_small:
  description: "str(decimal.Decimal('0.001')) == '0.001' — small decimal with leading zero preserved; verified Python 3.14.3 macOS"
  category: str_format
  kind: python_call_eq
  function: Decimal
  args: ["0.001"]
  method: __str__
  expected: "0.001"

# ---------------------------------------------------------------------------
# decimal.Decimal.__str__() length spot-checks
# Verify string lengths for key representations.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra231.str_lengths:
  description: "decimal.Decimal.__str__() string lengths for key representations; verified Python 3.14.3"
  kind: python_call_eq
  category: str_format
  id_prefix: decstrlen231

  columns: [id, function, args, method, method_chain, expected]
  rows:
    - [len_1_0,   Decimal, ["1.0"],   __str__, __len__, 3]
    - [len_1_00,  Decimal, ["1.00"],  __str__, __len__, 4]
    - [len_0,     Decimal, ["0"],     __str__, __len__, 1]
    - [len_1E2,   Decimal, ["1E+2"],  __str__, __len__, 4]
    - [len_small, Decimal, ["0.001"], __str__, __len__, 5]

# ---------------------------------------------------------------------------
# decimal.Decimal.__format__() contracts
# __format__ applies Python format mini-language to Decimal values.
# 'f' format: fixed-point notation.
# '.2f' format: fixed-point with 2 decimal places.
# ',' format: thousands separator.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra231.Decimal.format_f:
  description: "decimal.Decimal('1.5').__format__('f') == '1.5' — fixed-point format spec; verified Python 3.14.3 macOS"
  category: format_spec
  kind: python_call_eq
  function: Decimal
  args: ["1.5"]
  method: __format__
  method_args: ["f"]
  expected: "1.5"

invariant decimal_extra231.Decimal.format_2f:
  description: "decimal.Decimal('1.5').__format__('.2f') == '1.50' — .2f pads to two decimal places; verified Python 3.14.3 macOS"
  category: format_spec
  kind: python_call_eq
  function: Decimal
  args: ["1.5"]
  method: __format__
  method_args: [".2f"]
  expected: "1.50"

invariant decimal_extra231.Decimal.format_comma:
  description: "decimal.Decimal('1000').__format__(',') == '1,000' — comma format adds thousands separator; verified Python 3.14.3 macOS"
  category: format_spec
  kind: python_call_eq
  function: Decimal
  args: ["1000"]
  method: __format__
  method_args: [","]
  expected: "1,000"

invariant decimal_extra231.Decimal.format_empty:
  description: "decimal.Decimal('1.5').__format__('') == '1.5' — empty format spec yields same as str(); verified Python 3.14.3 macOS"
  category: format_spec
  kind: python_call_eq
  function: Decimal
  args: ["1.5"]
  method: __format__
  method_args: [""]
  expected: "1.5"
