spec: inspect_extra245
version: ">=3.0"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra244.zspec.zsdl — covers getmembers_static, get_annotations, and descriptor predicate identity"
    - "inspect_extra243.zspec.zsdl — covers classify_class_attrs and getmembers identity"
    - "inspect_extra242.zspec.zsdl — covers isclass, isfunction, ismethod identity"
    - "inspect_extra.zspec.zsdl — covers ismodule, isbuiltin, isroutine names and modules"
    - "inspect.zspec.zsdl — covers inspect function names and callable checks"
  notes:
    - "This spec covers inspect.ismodule, inspect.isclass, inspect.ismethod behavioral contracts."
    - "inspect.ismodule.__name__ == 'ismodule' (len=8) — ismodule is a Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ismodule.__module__ == 'inspect' (len=7) — ismodule is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ismodule.__class__.__name__ == 'function' — ismodule is a plain Python function. Verified with Python 3.14.3."
    - "inspect.isclass.__name__ == 'isclass' (len=7) — isclass is a Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isclass.__module__ == 'inspect' (len=7) — isclass is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isclass.__class__.__name__ == 'function' — isclass is a plain Python function. Verified with Python 3.14.3."
    - "inspect.ismethod.__name__ == 'ismethod' (len=8) — ismethod is a Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ismethod.__module__ == 'inspect' (len=7) — ismethod is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ismethod.__class__.__name__ == 'function' — ismethod is a plain Python function. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.ismodule function identity contracts
#
# inspect.ismodule.__name__ == 'ismodule' (len=8)
# inspect.ismodule.__module__ == 'inspect' (len=7)
# inspect.ismodule.__qualname__ == 'ismodule' (len=8)
# inspect.ismodule.__class__.__name__ == 'function'
# inspect.ismodule.__name__.__len__() == 8
#
# ismodule is a Python function in Lib/inspect.py. New to extra245.
# ---------------------------------------------------------------------------

table inspect_extra245.inspismod245_ismodule_identity:
  description: "inspect.ismodule function identity: name, module, qualname, class; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: inspismod245

  columns: [id, function, args, expected, description]
  rows:
    - [ism_name_eq,
       ismodule.__name__.__eq__,
       ["ismodule"],
       true,
       "inspect.ismodule.__name__.__eq__('ismodule') == True — ismodule is a Python function in Lib/inspect.py; __name__ is 'ismodule' (len=8); new to extra245"]
    - [ism_name_len_8,
       ismodule.__name__.__len__,
       [],
       8,
       "inspect.ismodule.__name__.__len__() == 8 — 'ismodule' has exactly 8 characters; str.__len__() returns 8; new to extra245"]
    - [ism_module_eq,
       ismodule.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ismodule.__module__.__eq__('inspect') == True — ismodule is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra245"]
    - [ism_module_len_7,
       ismodule.__module__.__len__,
       [],
       7,
       "inspect.ismodule.__module__.__len__() == 7 — 'inspect' has exactly 7 characters; str.__len__() returns 7; new to extra245"]
    - [ism_qualname_eq,
       ismodule.__qualname__.__eq__,
       ["ismodule"],
       true,
       "inspect.ismodule.__qualname__.__eq__('ismodule') == True — __qualname__ is 'ismodule' (len=8); same as __name__ for top-level function; new to extra245"]

# ---------------------------------------------------------------------------
# Table 2: inspect.ismodule class type and content checks
#
# inspect.ismodule.__class__.__name__ == 'function'
# inspect.ismodule.__name__.__contains__('module') == True
# inspect.ismodule.__name__.__startswith__('is') == True
# inspect.ismodule.__module__.__contains__('inspect') == True
# inspect.ismodule.__class__.__module__ == 'builtins'
#
# New to extra245.
# ---------------------------------------------------------------------------

table inspect_extra245.inspismod245_ismodule_class:
  description: "inspect.ismodule class type, name/module content checks; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: inspismod245b

  columns: [id, function, args, expected, description]
  rows:
    - [ism_class_is_function,
       ismodule.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.ismodule.__class__.__name__.__eq__('function') == True — ismodule is a plain Python function; __class__.__name__ is 'function'; new to extra245"]
    - [ism_name_contains_module,
       ismodule.__name__.__contains__,
       ["module"],
       true,
       "inspect.ismodule.__name__.__contains__('module') == True — 'ismodule' contains 'module'; new to extra245"]
    - [ism_name_contains_is,
       ismodule.__name__.__contains__,
       ["is"],
       true,
       "inspect.ismodule.__name__.__contains__('is') == True — 'ismodule' contains 'is' (the inspect predicate prefix); new to extra245"]
    - [ism_module_contains_inspect,
       ismodule.__module__.__contains__,
       ["inspect"],
       true,
       "inspect.ismodule.__module__.__contains__('inspect') == True — 'inspect' contains the substring 'inspect'; new to extra245"]
    - [ism_class_module_builtins,
       ismodule.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "inspect.ismodule.__class__.__module__.__eq__('builtins') == True — function type is defined in the builtins module; new to extra245"]

# ---------------------------------------------------------------------------
# Table 3: inspect.isclass and inspect.ismethod function identity contracts
#
# inspect.isclass.__name__ == 'isclass' (len=7)
# inspect.isclass.__module__ == 'inspect' (len=7)
# inspect.isclass.__qualname__ == 'isclass' (len=7)
# inspect.ismethod.__name__ == 'ismethod' (len=8)
# inspect.ismethod.__module__ == 'inspect' (len=7)
#
# isclass and ismethod are Python functions in Lib/inspect.py. New to extra245.
# ---------------------------------------------------------------------------

table inspect_extra245.inspisfns245_isclass_ismethod:
  description: "inspect.isclass and ismethod function identity: name, module, qualname; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: inspisfns245

  columns: [id, function, args, expected, description]
  rows:
    - [isc_name_eq,
       isclass.__name__.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__name__.__eq__('isclass') == True — isclass is a Python function in Lib/inspect.py; __name__ is 'isclass' (len=7); new to extra245"]
    - [isc_name_len_7,
       isclass.__name__.__len__,
       [],
       7,
       "inspect.isclass.__name__.__len__() == 7 — 'isclass' has exactly 7 characters; str.__len__() returns 7; new to extra245"]
    - [isc_module_eq,
       isclass.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isclass.__module__.__eq__('inspect') == True — isclass is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra245"]
    - [ism_method_name_eq,
       ismethod.__name__.__eq__,
       ["ismethod"],
       true,
       "inspect.ismethod.__name__.__eq__('ismethod') == True — ismethod is a Python function in Lib/inspect.py; __name__ is 'ismethod' (len=8); new to extra245"]
    - [ism_method_module_eq,
       ismethod.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ismethod.__module__.__eq__('inspect') == True — ismethod is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra245"]

# ---------------------------------------------------------------------------
# Table 4: inspect.isclass and inspect.ismethod class type and content checks
#
# inspect.isclass.__class__.__name__ == 'function'
# inspect.isclass.__name__.__contains__('class') == True
# inspect.isclass.__name__.__startswith__('is') == True
# inspect.ismethod.__class__.__name__ == 'function'
# inspect.ismethod.__qualname__ == 'ismethod' (len=8)
#
# New to extra245.
# ---------------------------------------------------------------------------

table inspect_extra245.inspisfns245_class_content:
  description: "inspect.isclass and ismethod class type, qualname, content checks; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: inspisfns245b

  columns: [id, function, args, expected, description]
  rows:
    - [isc_class_is_function,
       isclass.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.isclass.__class__.__name__.__eq__('function') == True — isclass is a plain Python function; __class__.__name__ is 'function'; new to extra245"]
    - [isc_name_contains_class,
       isclass.__name__.__contains__,
       ["class"],
       true,
       "inspect.isclass.__name__.__contains__('class') == True — 'isclass' contains 'class'; new to extra245"]
    - [isc_name_contains_is,
       isclass.__name__.__contains__,
       ["is"],
       true,
       "inspect.isclass.__name__.__contains__('is') == True — 'isclass' contains 'is' (the inspect predicate prefix); new to extra245"]
    - [ism_method_class_is_function,
       ismethod.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.ismethod.__class__.__name__.__eq__('function') == True — ismethod is a plain Python function; __class__.__name__ is 'function'; new to extra245"]
    - [ism_method_qualname_eq,
       ismethod.__qualname__.__eq__,
       ["ismethod"],
       true,
       "inspect.ismethod.__qualname__.__eq__('ismethod') == True — __qualname__ is 'ismethod' (len=8); same as __name__ for top-level function; new to extra245"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra245
# ---------------------------------------------------------------------------

invariant inspect_extra245.ism_name_eq:
  description: "inspect.ismodule.__name__ == 'ismodule' (len=8); new to extra245"
  kind: python_call_eq
  function: ismodule.__name__.__eq__
  args: ["ismodule"]
  expected: true

invariant inspect_extra245.ism_module_eq:
  description: "inspect.ismodule.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra245"
  kind: python_call_eq
  function: ismodule.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra245.ism_class_is_function:
  description: "inspect.ismodule.__class__.__name__ == 'function' — plain Python function; new to extra245"
  kind: python_call_eq
  function: ismodule.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra245.ism_name_len_8:
  description: "inspect.ismodule.__name__.__len__() == 8; new to extra245"
  kind: python_call_eq
  function: ismodule.__name__.__len__
  args: []
  expected: 8

invariant inspect_extra245.isc_name_eq:
  description: "inspect.isclass.__name__ == 'isclass' (len=7); new to extra245"
  kind: python_call_eq
  function: isclass.__name__.__eq__
  args: ["isclass"]
  expected: true

invariant inspect_extra245.isc_module_eq:
  description: "inspect.isclass.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra245"
  kind: python_call_eq
  function: isclass.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra245.isc_class_is_function:
  description: "inspect.isclass.__class__.__name__ == 'function' — plain Python function; new to extra245"
  kind: python_call_eq
  function: isclass.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra245.isc_name_len_7:
  description: "inspect.isclass.__name__.__len__() == 7; new to extra245"
  kind: python_call_eq
  function: isclass.__name__.__len__
  args: []
  expected: 7

invariant inspect_extra245.ism_method_name_eq:
  description: "inspect.ismethod.__name__ == 'ismethod' (len=8); new to extra245"
  kind: python_call_eq
  function: ismethod.__name__.__eq__
  args: ["ismethod"]
  expected: true

invariant inspect_extra245.ism_method_module_eq:
  description: "inspect.ismethod.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra245"
  kind: python_call_eq
  function: ismethod.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra245.ism_method_class_is_function:
  description: "inspect.ismethod.__class__.__name__ == 'function' — plain Python function; new to extra245"
  kind: python_call_eq
  function: ismethod.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra245.ism_method_qualname_eq:
  description: "inspect.ismethod.__qualname__ == 'ismethod'; new to extra245"
  kind: python_call_eq
  function: ismethod.__qualname__.__eq__
  args: ["ismethod"]
  expected: true
