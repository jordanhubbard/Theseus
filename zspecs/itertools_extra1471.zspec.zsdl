spec: itertools_extra1471
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave 545 theme: __len__ and __getitem__ method presence and type checks for itertools classes."
    - "itertools.chain: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "itertools.count: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "itertools.cycle: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "itertools.repeat: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__ (has __length_hint__ instead). Verified with Python 3.12."
    - "itertools.accumulate: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "itertools.combinations: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "itertools.product: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "itertools.islice: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "All itertools C types are pure iterators implementing __iter__/__next__; none implement sequence or mapping protocols."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools chain/count/cycle — __len__ and __getitem__ absence
#
# Wave 545 theme: itertools.chain, count, cycle — infinite or chaining iterators.
#
# itertools.chain.__dict__.__contains__("__len__") == False
# itertools.chain.__dict__.__contains__("__getitem__") == False
# itertools.count.__dict__.__contains__("__len__") == False
# itertools.count.__dict__.__contains__("__getitem__") == False
# itertools.cycle.__dict__.__contains__("__len__") == False
# itertools.cycle.__dict__.__contains__("__getitem__") == False
#
# chain, count, and cycle are C extension iterator types that produce values
# lazily; they have no defined length and do not support index access.
# New to extra1471.
# ---------------------------------------------------------------------------

table itertools_extra1471.chain_count_cycle_absence:
  description: "itertools chain/count/cycle have no __len__ or __getitem__ in __dict__; pure lazy iterators; wave 545; new to extra1471"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1471cc

  columns: [id, function, args, expected, description]
  rows:
    - [it1471cc001,
       "chain.__dict__.__contains__",
       ["__len__"],
       false,
       "itertools.chain.__dict__.__contains__('__len__') == False — chain is a lazy iterator that chains multiple iterables; it has no defined length; __len__ is not in chain.__dict__; verified with Python 3.12; new to extra1471"]
    - [it1471cc002,
       "chain.__dict__.__contains__",
       ["__getitem__"],
       false,
       "itertools.chain.__dict__.__contains__('__getitem__') == False — chain does not support index access; elements are consumed lazily via __next__; __getitem__ is not in chain.__dict__; verified with Python 3.12; new to extra1471"]
    - [it1471cc003,
       "count.__dict__.__contains__",
       ["__len__"],
       false,
       "itertools.count.__dict__.__contains__('__len__') == False — count is an infinite counter iterator; it has no defined length; __len__ is not in count.__dict__; verified with Python 3.12; new to extra1471"]
    - [it1471cc004,
       "count.__dict__.__contains__",
       ["__getitem__"],
       false,
       "itertools.count.__dict__.__contains__('__getitem__') == False — count does not support index access; it is an unbounded counting iterator; __getitem__ is not in count.__dict__; verified with Python 3.12; new to extra1471"]
    - [it1471cc005,
       "cycle.__dict__.__contains__",
       ["__len__"],
       false,
       "itertools.cycle.__dict__.__contains__('__len__') == False — cycle is an infinite cycling iterator; it has no defined length; __len__ is not in cycle.__dict__; verified with Python 3.12; new to extra1471"]
    - [it1471cc006,
       "cycle.__dict__.__contains__",
       ["__getitem__"],
       false,
       "itertools.cycle.__dict__.__contains__('__getitem__') == False — cycle does not support index access; elements repeat endlessly via __next__; __getitem__ is not in cycle.__dict__; verified with Python 3.12; new to extra1471"]

# ---------------------------------------------------------------------------
# Table 2: itertools repeat/accumulate/islice — __len__ and __getitem__ absence
#
# Wave 545 theme: itertools.repeat, accumulate, islice — finite or accumulating
# iterators.
#
# itertools.repeat.__dict__.__contains__("__len__") == False
# itertools.repeat.__dict__.__contains__("__getitem__") == False
# itertools.accumulate.__dict__.__contains__("__len__") == False
# itertools.accumulate.__dict__.__contains__("__getitem__") == False
# itertools.islice.__dict__.__contains__("__len__") == False
# itertools.islice.__dict__.__contains__("__getitem__") == False
#
# repeat has __length_hint__ for optional bounded-repeat support, but NOT __len__.
# accumulate and islice are purely stateful iterators with no size information.
# New to extra1471.
# ---------------------------------------------------------------------------

table itertools_extra1471.repeat_accumulate_islice_absence:
  description: "itertools repeat/accumulate/islice have no __len__ or __getitem__ in __dict__; wave 545; new to extra1471"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1471ra

  columns: [id, function, args, expected, description]
  rows:
    - [it1471ra001,
       "repeat.__dict__.__contains__",
       ["__len__"],
       false,
       "itertools.repeat.__dict__.__contains__('__len__') == False — repeat has __length_hint__ for bounded repeats but NOT __len__; the distinction is that __length_hint__ is advisory while __len__ promises an exact count; __len__ is not in repeat.__dict__; verified with Python 3.12; new to extra1471"]
    - [it1471ra002,
       "repeat.__dict__.__contains__",
       ["__getitem__"],
       false,
       "itertools.repeat.__dict__.__contains__('__getitem__') == False — repeat does not support index access; it yields the same value repeatedly via __next__; __getitem__ is not in repeat.__dict__; verified with Python 3.12; new to extra1471"]
    - [it1471ra003,
       "accumulate.__dict__.__contains__",
       ["__len__"],
       false,
       "itertools.accumulate.__dict__.__contains__('__len__') == False — accumulate is a stateful iterator producing running totals or other accumulated values; it has no defined length; __len__ is not in accumulate.__dict__; verified with Python 3.12; new to extra1471"]
    - [it1471ra004,
       "accumulate.__dict__.__contains__",
       ["__getitem__"],
       false,
       "itertools.accumulate.__dict__.__contains__('__getitem__') == False — accumulate does not support index access; accumulated values are produced lazily one at a time; __getitem__ is not in accumulate.__dict__; verified with Python 3.12; new to extra1471"]
    - [it1471ra005,
       "islice.__dict__.__contains__",
       ["__len__"],
       false,
       "itertools.islice.__dict__.__contains__('__len__') == False — islice slices another iterator lazily; it does not know its own length in advance; __len__ is not in islice.__dict__; verified with Python 3.12; new to extra1471"]
    - [it1471ra006,
       "islice.__dict__.__contains__",
       ["__getitem__"],
       false,
       "itertools.islice.__dict__.__contains__('__getitem__') == False — islice does not support index access; it is a slice view over another iterator consumed via __next__; __getitem__ is not in islice.__dict__; verified with Python 3.12; new to extra1471"]

# ---------------------------------------------------------------------------
# Table 3: itertools combinations/product — __len__ and __getitem__ absence
#
# Wave 545 theme: itertools.combinations, product — combinatoric iterators.
#
# itertools.combinations.__dict__.__contains__("__len__") == False
# itertools.combinations.__dict__.__contains__("__getitem__") == False
# itertools.product.__dict__.__contains__("__len__") == False
# itertools.product.__dict__.__contains__("__getitem__") == False
# itertools.combinations.__dict__.__contains__("__setitem__") == False
# itertools.product.__dict__.__contains__("__setitem__") == False
#
# combinations and product are combinatoric C extension iterator types.
# Despite having a mathematically definable count of outputs, they do not
# expose __len__ and are not indexable. New to extra1471.
# ---------------------------------------------------------------------------

table itertools_extra1471.combinations_product_absence:
  description: "itertools combinations/product have no __len__, __getitem__, or __setitem__ in __dict__; combinatoric iterators only; wave 545; new to extra1471"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1471cb

  columns: [id, function, args, expected, description]
  rows:
    - [it1471cb001,
       "combinations.__dict__.__contains__",
       ["__len__"],
       false,
       "itertools.combinations.__dict__.__contains__('__len__') == False — combinations yields r-length tuples from an input iterable in sorted order; despite having a binomial-coefficient count it does not expose __len__; verified with Python 3.12; new to extra1471"]
    - [it1471cb002,
       "combinations.__dict__.__contains__",
       ["__getitem__"],
       false,
       "itertools.combinations.__dict__.__contains__('__getitem__') == False — combinations does not support index access; tuples are produced sequentially via __next__; __getitem__ is not in combinations.__dict__; verified with Python 3.12; new to extra1471"]
    - [it1471cb003,
       "combinations.__dict__.__contains__",
       ["__setitem__"],
       false,
       "itertools.combinations.__dict__.__contains__('__setitem__') == False — combinations is immutable; item assignment is not supported; __setitem__ is not in combinations.__dict__; verified with Python 3.12; new to extra1471"]
    - [it1471cb004,
       "product.__dict__.__contains__",
       ["__len__"],
       false,
       "itertools.product.__dict__.__contains__('__len__') == False — product yields Cartesian product tuples; despite having a product-of-lengths count it does not expose __len__; __len__ is not in product.__dict__; verified with Python 3.12; new to extra1471"]
    - [it1471cb005,
       "product.__dict__.__contains__",
       ["__getitem__"],
       false,
       "itertools.product.__dict__.__contains__('__getitem__') == False — product does not support index access; Cartesian product tuples are yielded via __next__; __getitem__ is not in product.__dict__; verified with Python 3.12; new to extra1471"]
    - [it1471cb006,
       "product.__dict__.__contains__",
       ["__setitem__"],
       false,
       "itertools.product.__dict__.__contains__('__setitem__') == False — product is immutable; item assignment is not supported; __setitem__ is not in product.__dict__; verified with Python 3.12; new to extra1471"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1471
# ---------------------------------------------------------------------------

invariant itertools_extra1471.chain_no_len:
  description: "itertools.chain.__dict__ does not contain '__len__' — chain is a lazy iterator with no defined length; wave 545; new to extra1471"
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant itertools_extra1471.chain_no_getitem:
  description: "itertools.chain.__dict__ does not contain '__getitem__' — chain does not support index access; wave 545; new to extra1471"
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__getitem__"]
  expected: false

invariant itertools_extra1471.repeat_no_len:
  description: "itertools.repeat.__dict__ does not contain '__len__' — repeat has __length_hint__ but NOT __len__; wave 545; new to extra1471"
  kind: python_call_eq
  function: repeat.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant itertools_extra1471.repeat_no_getitem:
  description: "itertools.repeat.__dict__ does not contain '__getitem__' — repeat does not support index access; wave 545; new to extra1471"
  kind: python_call_eq
  function: repeat.__dict__.__contains__
  args: ["__getitem__"]
  expected: false

invariant itertools_extra1471.combinations_no_len:
  description: "itertools.combinations.__dict__ does not contain '__len__' — combinatoric iterator with no __len__; wave 545; new to extra1471"
  kind: python_call_eq
  function: combinations.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant itertools_extra1471.product_no_len:
  description: "itertools.product.__dict__ does not contain '__len__' — Cartesian product iterator with no __len__; wave 545; new to extra1471"
  kind: python_call_eq
  function: product.__dict__.__contains__
  args: ["__len__"]
  expected: false
