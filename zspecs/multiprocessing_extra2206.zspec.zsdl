spec: multiprocessing_extra2206
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.html#synchronization-primitives"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
    - "multiprocessing.zspec.zsdl"
    - "multiprocessing_extra.zspec.zsdl"
    - "multiprocessing_extra2.zspec.zsdl"
  notes:
    - "Wave _extra2206: rich comparison operator protocol dict-presence checks for multiprocessing classes."
    - "Covers __lt__, __le__, __gt__, __ge__, __eq__, __ne__ presence in Process, synchronize.Lock, synchronize.RLock, synchronize.Semaphore, synchronize.Event, queues.Queue class dicts."
    - "multiprocessing.Process does not define any comparison operators in its own __dict__."
    - "multiprocessing.synchronize.Lock, RLock, Semaphore, Event, BoundedSemaphore are SemLock-backed sync primitives; none define comparison operators."
    - "multiprocessing.queues.Queue is a multiprocessing-safe queue; it does not define comparison operators."
    - "Fully-qualified class paths are used: multiprocessing.synchronize.Lock, multiprocessing.queues.Queue, etc."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table multiprocessing_extra2206.Process_comparison_protocol:
  description: "multiprocessing.Process __lt__/__le__/__gt__/__ge__/__eq__/__ne__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2206

  columns: [id, function, args, expected]
  rows:
    - ["mp2206001", "multiprocessing.Process.__dict__.__contains__", ["__lt__"], false]
    - ["mp2206002", "multiprocessing.Process.__dict__.__contains__", ["__le__"], false]
    - ["mp2206003", "multiprocessing.Process.__dict__.__contains__", ["__gt__"], false]
    - ["mp2206004", "multiprocessing.Process.__dict__.__contains__", ["__ge__"], false]
    - ["mp2206005", "multiprocessing.Process.__dict__.__contains__", ["__eq__"], false]
    - ["mp2206006", "multiprocessing.Process.__dict__.__contains__", ["__ne__"], false]

