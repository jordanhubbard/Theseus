spec: multiprocessing_extra1786
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/queues.py"
  notes:
    - "Wave 566, suffix _extra1786. Theme: __class_getitem__ and __init_subclass__ class creation hooks — which stdlib types define these in their own __dict__."
    - "multiprocessing.Process does NOT define __class_getitem__ in its own __dict__ — Process is not a generic type."
    - "multiprocessing.Pool does NOT define __class_getitem__ in its own __dict__ — Pool is not a generic type."
    - "multiprocessing.Queue is a factory function; its returned proxy class does not expose __class_getitem__."
    - "multiprocessing.Lock is a factory function; the underlying lock type does not define __class_getitem__."
    - "None of the multiprocessing types define __init_subclass__ in their own __dict__; all rely on the default from object."
    - "multiprocessing.Pool defines __enter__ and __exit__ in its own __dict__ (sync context manager)."
    - "multiprocessing.Process defines run, start, join, terminate, kill, is_alive in its own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __class_getitem__ and __init_subclass__ absent from multiprocessing types
#
# multiprocessing is a process-management library; none of its public types
# define __class_getitem__ or __init_subclass__ in their own __dict__.
# Process and Pool are genuine class objects; Queue and Lock are factory
# functions whose return types also lack these hooks.
# ---------------------------------------------------------------------------

table multiprocessing_extra1786.class_getitem_absent:
  kind: python_call_eq
  category: class_getitem
  id_prefix: mp1786

  columns: [id, function, args, expected]
  rows:
    - ["mp1786001", multiprocessing.Process.__dict__.__contains__,  ["__class_getitem__"], false]
    - ["mp1786002", multiprocessing.Pool.__dict__.__contains__,     ["__class_getitem__"], false]
    - ["mp1786003", multiprocessing.Process.__dict__.__contains__,  ["__init_subclass__"], false]
    - ["mp1786004", multiprocessing.Pool.__dict__.__contains__,     ["__init_subclass__"], false]
    - ["mp1786005", multiprocessing.Process.__dict__.__contains__,  ["run"],               true]
    - ["mp1786006", multiprocessing.Process.__dict__.__contains__,  ["start"],             true]
    - ["mp1786007", multiprocessing.Process.__dict__.__contains__,  ["join"],              true]
    - ["mp1786008", multiprocessing.Process.__dict__.__contains__,  ["terminate"],         true]
    - ["mp1786009", multiprocessing.Process.__dict__.__contains__,  ["is_alive"],          true]
    - ["mp1786010", multiprocessing.Pool.__dict__.__contains__,     ["__enter__"],         true]
    - ["mp1786011", multiprocessing.Pool.__dict__.__contains__,     ["__exit__"],          true]
    - ["mp1786012", multiprocessing.Pool.__dict__.__contains__,     ["map"],               true]
    - ["mp1786013", multiprocessing.Pool.__dict__.__contains__,     ["apply"],             true]

# ---------------------------------------------------------------------------
# Table 2: complementary identity and dict-membership checks
#
# Positive identity anchors for Process and Pool class names and modules,
# plus additional dict membership checks to confirm key method presence.
# ---------------------------------------------------------------------------

table multiprocessing_extra1786.identity_and_complementary:
  kind: python_call_eq
  category: identity
  id_prefix: mp1786

  columns: [id, function, args, expected]
  rows:
    - ["mp1786014", multiprocessing.Process.__name__.__eq__,               ["Process"],                   true]
    - ["mp1786015", multiprocessing.Pool.__name__.__eq__,                  ["Pool"],                      true]
    - ["mp1786016", multiprocessing.Process.__module__.__eq__,             ["multiprocessing.process"],   true]
    - ["mp1786017", multiprocessing.Pool.__module__.__eq__,                ["multiprocessing.pool"],      true]
    - ["mp1786018", multiprocessing.Process.__class__.__name__.__eq__,     ["type"],                      true]
    - ["mp1786019", multiprocessing.Pool.__class__.__name__.__eq__,        ["type"],                      true]
    - ["mp1786020", multiprocessing.Pool.__dict__.__contains__,            ["starmap"],                   true]
    - ["mp1786021", multiprocessing.Pool.__dict__.__contains__,            ["close"],                     true]
    - ["mp1786022", multiprocessing.Pool.__dict__.__contains__,            ["terminate"],                 true]
    - ["mp1786023", multiprocessing.Process.__dict__.__contains__,         ["kill"],                      true]
    - ["mp1786024", multiprocessing.Process.__dict__.__contains__,         ["__init__"],                  true]
    - ["mp1786025", multiprocessing.Pool.__dict__.__contains__,            ["imap"],                      true]
