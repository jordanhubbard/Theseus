spec: theseus_tokenize_cr
version: ">=3.8"
backend: python_cleanroom(theseus_tokenize_cr)
blocks: tokenize

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/tokenize.html"
    - "Python token types: NUMBER, STRING, NAME, OP, NEWLINE, INDENT, DEDENT, etc."
  not_derived_from:
    - "CPython source: Lib/tokenize.py (internal implementation)"
  notes:
    - "Clean-room tokenize module. Do NOT import tokenize."
    - "tokenize(readline): yield TokenInfo named-tuples for each token."
    - "generate_tokens(readline): like tokenize but for string input."
    - "TokenInfo fields: type, string, start, end, line."
    - "Token constants: NUMBER, STRING, NAME, OP, NEWLINE, ENDMARKER, etc."

error_model: python_exceptions

invariant theseus_tokenize_cr.tokenize2_name:
  description: "tokenize 'x = 1' yields a NAME token for 'x'"
  category: tokenize
  kind: python_call_eq
  function: tokenize2_name
  args: []
  expected: true

invariant theseus_tokenize_cr.tokenize2_number:
  description: "tokenize '42' yields a NUMBER token"
  category: tokenize
  kind: python_call_eq
  function: tokenize2_number
  args: []
  expected: "42"

invariant theseus_tokenize_cr.tokenize2_count:
  description: "tokenize 'a + b' yields at least 3 non-ENDMARKER tokens"
  category: tokenize
  kind: python_call_eq
  function: tokenize2_count
  args: []
  expected: true
