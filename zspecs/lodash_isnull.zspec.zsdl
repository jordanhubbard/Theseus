spec: lodash_isnull
version: ">=4.0.0"
backend: node(lodash.isnull)

docs: https://lodash.com/docs/#isNull

provenance:
  derived_from:
    - "lodash.isnull README — https://www.npmjs.com/package/lodash.isnull"
    - "Test vectors verified with lodash.isnull@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.isnull exports the _.isNull function directly as module.exports."
    - "isNull checks if value is null (strict check — undefined returns false)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_isnull.isnull:
  kind: node_module_call_eq
  function: ~
  category: isnull
  id_prefix: lisnl

  columns: [id, args, expected]
  rows:
    - [yes_null,  [null],         true]
    - [zero,      [0],            false]
    - [empty_str, [""],           false]
    - [false_val, [false],        false]
    - [object,    [{"a": 1}],    false]
