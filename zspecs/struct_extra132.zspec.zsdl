spec: struct_extra132
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra131.zspec.zsdl — covers Struct.__repr__ wrapper_descriptor identity / Struct.__str__ and __hash__ inherited-from-object identity (qualname 'object.__str__'/'object.__hash__', __objclass__.__name__=='object') (table + invariants)."
    - "struct_extra130.zspec.zsdl — covers struct.error MRO / Struct.__mro__[1].__name__ / Struct.iter_unpack method identity / Struct.__new__ identity (table + invariants)."
    - "struct_extra129.zspec.zsdl — covers struct module-level function __name__/__qualname__/__module__/__class__.__name__ for pack/unpack/calcsize/pack_into/unpack_from/iter_unpack (table + invariants)."
    - "struct_extra128.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from __qualname__ equality / Struct method __class__.__name__=='method_descriptor' / Struct method __name__ equality (table + invariants)."
    - "struct_extra127.zspec.zsdl — covers Struct.size and format __objclass__.__name__ and __module__ equality (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / qualname/name lengths and __objclass__.__name__ (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior struct spec files."
    - "Wave 359 theme: struct.Struct.size and format getset_descriptor __name__ equality / Struct method __objclass__.__module__=='_struct' / Struct.iter_unpack __name__/__qualname__/__objclass__ / Struct.__sizeof__ method_descriptor identity (__name__/__qualname__/__objclass__)."
    - "struct.Struct.size.__name__ == 'size'. The short attribute name for the getset_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__name__ == 'format'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__objclass__.__module__ == '_struct'. All Struct method_descriptors have __objclass__.__module__=='_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__objclass__.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__objclass__.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__objclass__.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__name__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__objclass__.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__qualname__ == 'Struct.__sizeof__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__name__ == '__sizeof__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__objclass__.__name__ == 'Struct'. __sizeof__ is defined by Struct (not inherited from object). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__objclass__.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct_extra127 anchors size/format __objclass__.__name__=='Struct' and __module__=='_struct'. struct_extra98 anchors size/__format__ getset_descriptor class names and qualnames. struct_extra128 anchors pack/unpack/pack_into/unpack_from __qualname__ and __name__. This spec is the first to anchor size/format __name__ equality, method __objclass__.__module__, iter_unpack full identity, and __sizeof__ identity under structdesc132."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.size.__name__.__eq__('size')
# struct.Struct.format.__name__.__eq__('format')
# struct.Struct.size.__class__.__name__.__eq__('getset_descriptor')
# struct.Struct.format.__class__.__name__.__eq__('getset_descriptor')
# struct.Struct.pack.__objclass__.__module__.__eq__('_struct')
#
# Wave 359 theme: size/format descriptor __name__ and method __objclass__.__module__.
#
# struct.Struct.size and format are getset_descriptor objects (PyGetSetDef-based
# descriptors in CPython). Their __name__ is the short attribute name without
# the class prefix: 'size' and 'format'. struct_extra98 anchors their class names
# and qualnames (e.g., qualname 'Struct.size'). This spec anchors the __name__
# attribute (short form) via __eq__ for the first time under structdesc132.
# struct.Struct.pack.__objclass__.__module__ is '_struct' — the C extension that
# defines the Struct type. struct_extra127 anchors __objclass__.__name__=='Struct'
# and __module__=='_struct' for size/format; this spec anchors the same pattern
# for method_descriptors (pack/unpack). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra132.size_format_names_and_method_module:
  description: "struct.Struct/size/__name__.__eq__('size')==True / format/__name__.__eq__('format')==True / size/__class__/__name__.__eq__('getset_descriptor')==True / format/__class__/__name__.__eq__('getset_descriptor')==True / pack/__objclass__/__module__.__eq__('_struct')==True — size/format are getset_descriptor; their __name__ is the short form; pack/__objclass__/__module__ is '_struct' (C extension); extra127 anchors __objclass__.__name__; first structdesc132 anchor for size/format __name__ and method __objclass__.__module__"
  kind: python_call_eq
  category: type_identity
  id_prefix: structdesc132

  columns: [id, function, args, expected, description]
  rows:
    - [size_name,      Struct.size.__name__.__eq__,                 ["size"],              true, "Struct.size.__name__ is 'size' (short attribute name; qualname is 'Struct.size')"]
    - [fmt_name,       Struct.format.__name__.__eq__,               ["format"],            true, "Struct.format.__name__ is 'format' (short attribute name; qualname is 'Struct.format')"]
    - [size_cls,       Struct.size.__class__.__name__.__eq__,       ["getset_descriptor"], true, "Struct.size.__class__.__name__ is 'getset_descriptor' (PyGetSetDef-based C descriptor)"]
    - [fmt_cls,        Struct.format.__class__.__name__.__eq__,     ["getset_descriptor"], true, "Struct.format.__class__.__name__ is 'getset_descriptor' (PyGetSetDef-based C descriptor)"]
    - [pack_obj_mod,   Struct.pack.__objclass__.__module__.__eq__,  ["_struct"],           true, "Struct.pack.__objclass__.__module__ is '_struct' (C extension module defining Struct)"]

# ---------------------------------------------------------------------------
# struct.Struct.unpack.__objclass__.__module__.__eq__('_struct')
# struct.Struct.pack_into.__objclass__.__module__.__eq__('_struct')
# struct.Struct.unpack_from.__objclass__.__module__.__eq__('_struct')
# struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack')
# struct.Struct.iter_unpack.__name__.__eq__('iter_unpack')
#
# Wave 359 theme: Struct method __objclass__.__module__ and iter_unpack qualname.
#
# All Struct method_descriptor objects (pack, unpack, pack_into, unpack_from,
# iter_unpack) have __objclass__.__module__ == '_struct', confirming they are all
# from the same C extension. struct_extra128 anchors pack/unpack/pack_into/unpack_from
# __qualname__ and __name__; struct_extra130 anchors iter_unpack method identity.
# This spec anchors unpack/pack_into/unpack_from __objclass__.__module__ and adds
# iter_unpack __qualname__ and __name__ as cross-checks. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table struct_extra132.method_objclass_module_and_iter_unpack:
  description: "struct.Struct/unpack/__objclass__/__module__.__eq__('_struct')==True / pack_into/__objclass__/__module__.__eq__('_struct')==True / unpack_from/__objclass__/__module__.__eq__('_struct')==True / iter_unpack/__qualname__.__eq__('Struct.iter_unpack')==True / iter_unpack/__name__.__eq__('iter_unpack')==True — all Struct method_descriptors have __objclass__.__module__=='_struct'; iter_unpack cross-check of qualname and __name__; first structdesc132 anchor for unpack/pack_into/unpack_from __objclass__.__module__"
  kind: python_call_eq
  category: type_identity
  id_prefix: structdesc132

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_obj_mod,      Struct.unpack.__objclass__.__module__.__eq__,      ["_struct"],            true, "Struct.unpack.__objclass__.__module__ is '_struct' (same C extension as pack)"]
    - [pack_into_obj_mod,   Struct.pack_into.__objclass__.__module__.__eq__,   ["_struct"],            true, "Struct.pack_into.__objclass__.__module__ is '_struct' (writes packed bytes into a buffer)"]
    - [unpack_from_obj_mod, Struct.unpack_from.__objclass__.__module__.__eq__, ["_struct"],            true, "Struct.unpack_from.__objclass__.__module__ is '_struct' (reads from buffer at an offset)"]
    - [iter_qual,           Struct.iter_unpack.__qualname__.__eq__,            ["Struct.iter_unpack"], true, "Struct.iter_unpack.__qualname__ is 'Struct.iter_unpack' (returns iterator over packed buffer)"]
    - [iter_name,           Struct.iter_unpack.__name__.__eq__,                ["iter_unpack"],        true, "Struct.iter_unpack.__name__ is 'iter_unpack' (short form; yields tuples from repeated struct layout)"]

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__objclass__.__name__.__eq__('Struct')
# struct.Struct.iter_unpack.__objclass__.__module__.__eq__('_struct')
# struct.Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__')
# struct.Struct.__sizeof__.__name__.__eq__('__sizeof__')
# struct.Struct.__sizeof__.__objclass__.__name__.__eq__('Struct')
#
# Wave 359 theme: iter_unpack __objclass__ and __sizeof__ method_descriptor identity.
#
# struct.Struct.__sizeof__ is a method_descriptor defined by Struct (not inherited
# from object), with qualname 'Struct.__sizeof__' and __objclass__.__name__=='Struct'.
# This contrasts with __str__ and __hash__ (inherited from object, __objclass__=='object').
# __sizeof__ returns the memory footprint of the Struct instance in bytes; on
# Python 3.14.3/macOS it typically returns 56 for an empty Struct. No prior struct
# spec anchors __sizeof__ identity (__name__/__qualname__/__objclass__) under
# structdesc132. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra132.iter_unpack_objclass_and_sizeof_identity:
  description: "struct.Struct/iter_unpack/__objclass__/__name__.__eq__('Struct')==True / iter_unpack/__objclass__/__module__.__eq__('_struct')==True / __sizeof__/__qualname__.__eq__('Struct.__sizeof__')==True / __sizeof__/__name__.__eq__('__sizeof__')==True / __sizeof__/__objclass__/__name__.__eq__('Struct')==True — iter_unpack __objclass__ is Struct from _struct; __sizeof__ is Struct-defined (not inherited; contrast with __hash__/__str__ which are from object); first structdesc132 anchor for iter_unpack __objclass__ and __sizeof__ identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: structdesc132

  columns: [id, function, args, expected, description]
  rows:
    - [iter_obj_name,    Struct.iter_unpack.__objclass__.__name__.__eq__,    ["Struct"],           true, "Struct.iter_unpack.__objclass__.__name__ is 'Struct' (iter_unpack is defined by Struct, not inherited)"]
    - [iter_obj_mod,     Struct.iter_unpack.__objclass__.__module__.__eq__,  ["_struct"],          true, "Struct.iter_unpack.__objclass__.__module__ is '_struct' (C extension owning Struct)"]
    - [sizeof_qual,      Struct.__sizeof__.__qualname__.__eq__,               ["Struct.__sizeof__"], true, "Struct.__sizeof__.__qualname__ is 'Struct.__sizeof__' (Struct-defined, not 'object.__sizeof__')"]
    - [sizeof_name,      Struct.__sizeof__.__name__.__eq__,                   ["__sizeof__"],       true, "Struct.__sizeof__.__name__ is '__sizeof__' (short form; returns instance memory size in bytes)"]
    - [sizeof_obj_name,  Struct.__sizeof__.__objclass__.__name__.__eq__,      ["Struct"],           true, "Struct.__sizeof__.__objclass__.__name__ is 'Struct' (defined by Struct; contrasts with __str__/__hash__ which are from 'object')"]

# ---------------------------------------------------------------------------
# struct.Struct.size.__name__.__eq__('size') — standalone
#
# struct.Struct.size.__name__ is 'size'. The size attribute of a Struct instance
# (or its class-level descriptor) is the total number of bytes required to pack
# or unpack the structure. For example, struct.Struct('HHI').size == 8 on most
# platforms. struct.Struct.size is a getset_descriptor (PyGetSetDef-based C
# descriptor) whose __name__ is the short attribute name 'size'. struct_extra98
# anchors the qualname 'Struct.size' (with class prefix); this standalone anchors
# the __name__ 'size' (without class prefix) for the first time under structdesc132.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra132.Struct_size_name:
  description: "struct.Struct.size.__name__.__eq__('size') == True — size is a getset_descriptor for the total byte size of the packed structure; __name__ is short form 'size'; extra98 anchors qualname 'Struct.size' (with prefix); first standalone for size.__name__.__eq__ under structdesc132"
  category: type_identity
  kind: python_call_eq
  function: Struct.size.__name__.__eq__
  args: ["size"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.format.__name__.__eq__('format') — standalone
#
# struct.Struct.format.__name__ is 'format'. The format attribute stores the
# format string used to create the Struct instance (e.g., 'HHI', '>I', '<4s').
# struct.Struct.format is a getset_descriptor (like size) — a PyGetSetDef-based
# C descriptor that provides read access to the format string stored in the C
# struct (PyStructObject). Its __name__ is the short attribute name 'format'.
# struct_extra98 anchors the qualname 'Struct.format'; struct_extra127 anchors
# __objclass__.__name__=='Struct' and __module__=='_struct'. This is the first
# standalone for format.__name__.__eq__('format') under structdesc132.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra132.Struct_format_name:
  description: "struct.Struct.format.__name__.__eq__('format') == True — format is a getset_descriptor providing read access to the format string (e.g., '>I', '4s'); __name__ is short form 'format'; extra98 anchors qualname 'Struct.format'; extra127 anchors __objclass__; first standalone for format.__name__.__eq__ under structdesc132"
  category: type_identity
  kind: python_call_eq
  function: Struct.format.__name__.__eq__
  args: ["format"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__') — standalone
#
# struct.Struct.__sizeof__.__qualname__ is 'Struct.__sizeof__'. The __sizeof__
# method returns the size of the Struct object in memory (in bytes), used by
# sys.getsizeof(). It is a method_descriptor defined by Struct itself (not
# inherited from object), as confirmed by its qualname beginning with 'Struct.'
# rather than 'object.'. This contrasts with __str__ and __hash__ (qualnames
# 'object.__str__' and 'object.__hash__' — anchored in extra131). The
# __sizeof__.__objclass__.__name__ == 'Struct' (Struct-defined, not from object).
# No prior struct spec anchors __sizeof__.__qualname__ via __eq__ as a standalone
# under structdesc132. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra132.Struct_sizeof_qualname:
  description: "struct.Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__') == True — __sizeof__ is Struct-defined (returns memory size for sys.getsizeof); qualname 'Struct.__sizeof__' (not 'object.__sizeof__'); contrasts with __str__/__hash__ inherited from object; first standalone for __sizeof__.__qualname__.__eq__ under structdesc132"
  category: type_identity
  kind: python_call_eq
  function: Struct.__sizeof__.__qualname__.__eq__
  args: ["Struct.__sizeof__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__sizeof__.__objclass__.__name__.__eq__('Struct') — standalone
#
# struct.Struct.__sizeof__.__objclass__.__name__ is 'Struct'. The __objclass__
# attribute confirms that __sizeof__ is defined by the Struct C type (not by
# object or another base). This is the key distinction from __str__ and __hash__
# (whose __objclass__.__name__ is 'object'). The __sizeof__ method is part of
# the Struct C implementation in _struct.c and returns the Python-level memory
# size of the Struct instance object, which sys.getsizeof() uses to compute
# the total allocated size. No prior struct spec anchors __sizeof__.__objclass__
# __name__ via __eq__ as a standalone under structdesc132.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra132.Struct_sizeof_objclass_name:
  description: "struct.Struct.__sizeof__.__objclass__.__name__.__eq__('Struct') == True — __sizeof__.__objclass__ is Struct (defined by Struct, not inherited from object); contrasts with __str__/__hash__.__objclass__.__name__=='object' (anchored in extra131); first standalone for __sizeof__.__objclass__.__name__.__eq__ under structdesc132"
  category: type_identity
  kind: python_call_eq
  function: Struct.__sizeof__.__objclass__.__name__.__eq__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__objclass__.__name__.__eq__('Struct') — standalone
#
# struct.Struct.iter_unpack.__objclass__.__name__ is 'Struct'. iter_unpack is
# a method_descriptor defined by Struct (in _struct.c) that returns an iterator
# yielding tuples by repeatedly applying the struct layout to a buffer. It is
# primarily used for parsing binary streams of fixed-size records. Like pack,
# unpack, pack_into, and unpack_from, iter_unpack has __objclass__.__name__==
# 'Struct' (not 'object'). This spec is the first to anchor iter_unpack's
# __objclass__.__name__ via __eq__ as a standalone under structdesc132.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra132.Struct_iter_unpack_objclass_name:
  description: "struct.Struct.iter_unpack.__objclass__.__name__.__eq__('Struct') == True — iter_unpack is Struct-defined (returns iterator over repeated struct unpacking from a buffer); __objclass__.__name__=='Struct'; extra130 anchors iter_unpack method identity; first standalone for iter_unpack.__objclass__.__name__.__eq__ under structdesc132"
  category: type_identity
  kind: python_call_eq
  function: Struct.iter_unpack.__objclass__.__name__.__eq__
  args: ["Struct"]
  expected: true
