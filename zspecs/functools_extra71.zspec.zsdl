spec: functools_extra71
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra70.zspec.zsdl."
    - "Wave 232 theme: co_consts class name checks for wraps/update_wrapper/lru_cache, and partial C extension class identity attributes."
    - "wraps.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is always a tuple of constants in CPython code objects. Verified with Python 3.14.3."
    - "update_wrapper.__code__.co_consts.__class__.__name__ == 'tuple' — same invariant for update_wrapper. Verified with Python 3.14.3."
    - "lru_cache.__code__.co_consts.__class__.__name__ == 'tuple' — same invariant for lru_cache. Verified with Python 3.14.3."
    - "partial.__class__.__name__ == 'type' — partial is a C extension class (Modules/_functoolsmodule.c); its metaclass is 'type'. Verified with Python 3.14.3."
    - "partial.__module__ == 'functools' — partial is registered in the functools module namespace. Verified with Python 3.14.3."
    - "partial.__qualname__ == 'partial' — partial is a top-level (non-nested) class so its __qualname__ equals its simple name. Verified with Python 3.14.3."
    - "partial.__bases__[0].__name__ == 'object' — partial subclasses object directly (no intermediate base). Verified with Python 3.14.3."
    - "partial.__doc__.__class__.__name__ == 'str' — partial has a docstring stored as a str. Verified with Python 3.14.3."
    - "partial.__doc__.__contains__('partial') == True — the word 'partial' appears in the partial class docstring. Verified with Python 3.14.3."
    - "reduce.__doc__.__class__.__name__ == 'str' — reduce is a C builtin (_functools.reduce) with a str docstring. Verified with Python 3.14.3."
    - "reduce.__doc__.__contains__('function') == True — reduce applies a function of two arguments; the word 'function' appears in the docstring. Verified with Python 3.14.3."
    - "reduce.__module__ == '_functools' — reduce is implemented in the _functools C extension. Verified with Python 3.14.3."
    - "No prior functools spec checks co_consts.__class__.__name__, partial.__class__.__name__, partial.__module__, partial.__qualname__, partial.__bases__[0].__name__, partial.__doc__ content, or reduce.__doc__ content. All checks in this spec are new to extra71."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools __code__.co_consts.__class__.__name__ — extra71
#
# Wave 232 theme: co_consts is always a tuple.
#
# co_consts (PyCodeObject.co_consts) is a tuple of constants used by the
# bytecode (literals, None, docstrings, nested code objects, etc.). In CPython
# this attribute is always stored as a Python tuple.
#
# wraps.__code__.co_consts.__class__.__name__ == 'tuple'
# update_wrapper.__code__.co_consts.__class__.__name__ == 'tuple'
# lru_cache.__code__.co_consts.__class__.__name__ == 'tuple'
#
# No prior functools spec checks co_consts.__class__.__name__. New to extra71.
# ---------------------------------------------------------------------------

table functools_extra71.co_consts_class_name:
  description: "functools function __code__.co_consts.__class__.__name__.__eq__('tuple')==true — co_consts is always a tuple in CPython; wave 232 co_consts chains; new to extra71"
  kind: python_call_eq
  category: co_consts
  id_prefix: functoolsconst71

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_code_co_consts_class_name_eq_tuple,
       wraps.__code__.co_consts.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.wraps.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — wraps is a pure-Python function (Lib/functools.py); its __code__ is a PyCodeObject; PyCodeObject.co_consts is a tuple of constants used by the bytecode (literals, None, nested code objects, the docstring as co_consts[0] if present); the tuple built-in type has __name__ == 'tuple' (5 chars); __eq__ returns True; no prior functools spec checks co_consts.__class__.__name__ for wraps; new to extra71"]
    - [update_wrapper_code_co_consts_class_name_eq_tuple,
       update_wrapper.__code__.co_consts.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.update_wrapper.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — update_wrapper is a pure-Python function (Lib/functools.py); its co_consts is a tuple of bytecode constants; tuple.__name__ == 'tuple'; __eq__ returns True; no prior functools spec checks co_consts.__class__.__name__ for update_wrapper; new to extra71"]
    - [lru_cache_code_co_consts_class_name_eq_tuple,
       lru_cache.__code__.co_consts.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.lru_cache.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — lru_cache is a pure-Python function (Lib/functools.py); its co_consts is a tuple of bytecode constants; tuple.__name__ == 'tuple'; __eq__ returns True; no prior functools spec checks co_consts.__class__.__name__ for lru_cache; new to extra71"]

# ---------------------------------------------------------------------------
# functools.partial class identity attributes — extra71
#
# Wave 232 theme: partial is a C extension class; inspect its metaclass,
# module, qualname, and base class.
#
# partial.__class__.__name__ == 'type'   (its metaclass is type)
# partial.__module__         == 'functools'
# partial.__qualname__       == 'partial'
# partial.__bases__[0].__name__ == 'object'  (direct base is object)
#
# Function values containing '[' MUST be double-quoted in table rows.
# No prior functools spec checks these partial identity attributes. New to extra71.
# ---------------------------------------------------------------------------

table functools_extra71.partial_identity:
  description: "partial class identity attributes: __module__=='functools', __qualname__=='partial', __bases__[0].__name__=='object'; wave 232 partial identity; new to extra71"
  kind: python_call_eq
  category: partial_identity
  id_prefix: functoolsconst71

  columns: [id, function, args, expected, description]
  rows:
    - [partial_module_eq_functools,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial is a C extension type defined in Modules/_functoolsmodule.c and exposed via the functools module; its __module__ attribute is set to 'functools' (8 chars) when the module registers it; __eq__ on the str 'functools' returns True; no prior functools spec checks partial.__module__; new to extra71"]
    - [partial_qualname_eq_partial,
       partial.__qualname__.__eq__,
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — partial is a top-level (non-nested) class in the functools namespace; its __qualname__ is therefore equal to its simple name 'partial' (7 chars); no intermediate class or function scope appears in the qualified name; __eq__ returns True; no prior functools spec checks partial.__qualname__; new to extra71"]
    - [partial_bases_0_name_eq_object,
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial is a C extension type that subclasses object directly (no intermediate Python base class); partial.__bases__ is a tuple with a single element, the built-in object type; object.__name__ == 'object' (6 chars); __eq__ returns True; function value contains '[' so it is double-quoted; no prior functools spec checks partial.__bases__[0].__name__; new to extra71"]

# ---------------------------------------------------------------------------
# functools.partial.__doc__ content — extra71
#
# Wave 232 theme: partial has a str docstring containing 'partial'.
#
# partial.__doc__.__class__.__name__ == 'str'
# partial.__doc__.__contains__('partial') == True
#
# No prior functools spec checks partial.__doc__. New to extra71.
# ---------------------------------------------------------------------------

table functools_extra71.partial_doc_contains:
  description: "partial.__doc__ is a str and contains 'partial'; wave 232 partial doc content; new to extra71"
  kind: python_call_eq
  category: partial_doc
  id_prefix: functoolsconst71

  columns: [id, function, args, expected, description]
  rows:
    - [partial_doc_class_name_eq_str,
       partial.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — partial is a C extension type (Modules/_functoolsmodule.c) that has a docstring set in its PyTypeObject.tp_doc field; the docstring is exposed as a Python str object; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior functools spec checks partial.__doc__.__class__.__name__; new to extra71"]
    - [partial_doc_contains_partial,
       partial.__doc__.__contains__,
       ["partial"],
       true,
       "functools.partial.__doc__.__contains__('partial') == True — partial is a C extension type whose docstring describes what a partial object is; the type name 'partial' appears in the docstring (e.g., 'partial(func, *args, **keywords)' in the signature line); str.__contains__ returns True at the first occurrence; no prior functools spec checks partial.__doc__.__contains__('partial'); new to extra71"]

# ---------------------------------------------------------------------------
# functools.reduce.__doc__ content — extra71
#
# Wave 232 theme: reduce (C builtin) has a str docstring containing 'function'.
#
# reduce.__doc__.__class__.__name__ == 'str'
# reduce.__doc__.__contains__('function') == True
#
# No prior functools spec checks reduce.__doc__. New to extra71.
# ---------------------------------------------------------------------------

table functools_extra71.reduce_doc_contains:
  description: "reduce.__doc__ is a str and contains 'function'; wave 232 reduce doc content; new to extra71"
  kind: python_call_eq
  category: reduce_doc
  id_prefix: functoolsconst71

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_doc_class_name_eq_str,
       reduce.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — reduce is a C builtin function (_functools.reduce) implemented in Modules/_functoolsmodule.c; its docstring is set via the method definition's ml_doc field and exposed as a Python str object; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior functools spec checks reduce.__doc__.__class__.__name__; new to extra71"]
    - [reduce_doc_contains_function,
       reduce.__doc__.__contains__,
       ["function"],
       true,
       "functools.reduce.__doc__.__contains__('function') == True — reduce applies a function of two arguments cumulatively to the items of an iterable; the word 'function' appears in the docstring description (e.g., 'Apply a function of two arguments cumulatively...'); str.__contains__ returns True at the first occurrence; no prior functools spec checks reduce.__doc__.__contains__('function'); new to extra71"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra71
# ---------------------------------------------------------------------------

invariant functools_extra71.wraps_co_consts_tuple:
  description: "functools.wraps.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — co_consts is always a tuple in CPython; wave 232 co_consts chains; new to extra71"
  kind: python_call_eq
  function: wraps.__code__.co_consts.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra71.partial_module_functools:
  description: "functools.partial.__module__.__eq__('functools') == True — partial C extension type registers its module as 'functools'; wave 232 partial identity; new to extra71"
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra71.partial_bases_object:
  description: "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial subclasses object directly; wave 232 partial identity; new to extra71"
  kind: python_call_eq
  function: "partial.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra71.partial_doc_partial:
  description: "functools.partial.__doc__.__contains__('partial') == True — type name appears in partial docstring; wave 232 partial doc content; new to extra71"
  kind: python_call_eq
  function: partial.__doc__.__contains__
  args: ["partial"]
  expected: true

invariant functools_extra71.reduce_doc_function:
  description: "functools.reduce.__doc__.__contains__('function') == True — 'function' appears in reduce docstring; wave 232 reduce doc content; new to extra71"
  kind: python_call_eq
  function: reduce.__doc__.__contains__
  args: ["function"]
  expected: true
