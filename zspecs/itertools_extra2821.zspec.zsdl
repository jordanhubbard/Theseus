spec: itertools_extra2821
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "any proprietary source"
  notes:
    - "Wave 635 (_extra2821): __radd__, __rsub__, and __rmul__ dict-presence checks (reflected/right-hand addition, subtraction, multiplication)."
    - "All itertools types are lazy iterator wrappers — none define reflected arithmetic operators."
    - "itertools.chain, count, repeat, cycle, islice, compress, dropwhile, takewhile: C-level types; no __radd__/__rsub__/__rmul__."
    - "itertools.starmap, groupby, filterfalse, accumulate, zip_longest: C-level types; no __radd__/__rsub__/__rmul__."
    - "itertools.pairwise, product, permutations, combinations, combinations_with_replacement: C-level types; no __radd__/__rsub__/__rmul__."
    - "Reflected operators (__radd__, __rsub__, __rmul__) are invoked when the left operand does not support the operation; iterator types produce sequences, not numeric values."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __radd__ dict-presence (reflected addition)
#
# Core itertools types: chain, count, repeat, cycle, islice, compress,
# dropwhile, takewhile, starmap, groupby — none define __radd__.
# ---------------------------------------------------------------------------

table itertools_extra2821.radd_protocol_core:
  description: "itertools core types __radd__ dict-presence checks — all False (no reflected addition protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2821
  columns: [id, function, args, expected]
  rows:
    - ["it2821001", "itertools.chain.__dict__.__contains__",     ["__radd__"], false]
    - ["it2821002", "itertools.count.__dict__.__contains__",     ["__radd__"], false]
    - ["it2821003", "itertools.repeat.__dict__.__contains__",    ["__radd__"], false]
    - ["it2821004", "itertools.cycle.__dict__.__contains__",     ["__radd__"], false]
    - ["it2821005", "itertools.islice.__dict__.__contains__",    ["__radd__"], false]
    - ["it2821006", "itertools.compress.__dict__.__contains__",  ["__radd__"], false]
    - ["it2821007", "itertools.dropwhile.__dict__.__contains__", ["__radd__"], false]
    - ["it2821008", "itertools.takewhile.__dict__.__contains__", ["__radd__"], false]
    - ["it2821009", "itertools.starmap.__dict__.__contains__",   ["__radd__"], false]
    - ["it2821010", "itertools.groupby.__dict__.__contains__",   ["__radd__"], false]

