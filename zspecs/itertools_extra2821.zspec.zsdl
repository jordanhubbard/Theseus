# ---------------------------------------------------------------------------
# Table 3: __rmul__ dict-presence (reflected multiplication)
#
# Combinatoric and filtering types: product, permutations, combinations,
# combinations_with_replacement, chain, compress, dropwhile, takewhile.
# None define __rmul__ — sequence repetition has no iterator semantics.
# ---------------------------------------------------------------------------

table itertools_extra2821.rmul_protocol:
