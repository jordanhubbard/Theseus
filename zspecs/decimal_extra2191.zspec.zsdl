spec: decimal_extra2191
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2191: context manager protocol dict-presence checks — __enter__, __exit__, __aenter__, __aexit__, acquire, release, __wrapped__, __closure__."
    - "decimal.Decimal is a C-extension type; its __dict__ does NOT define any context manager or lock protocol method."
    - "decimal.Context is a C-extension type; its __dict__ does NOT define __enter__ or __exit__. The context manager returned by decimal.localcontext() is a separate ContextManager helper class (decimal.ContextManager in Python 3.14+)."
    - "decimal.DecimalException and its subclasses (InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded, Subnormal, FloatOperation, Clamped) are exception classes; none define context manager or lock protocol methods in their own __dict__."
    - "No decimal module class defines __aenter__, __aexit__, acquire, release, __wrapped__, or __closure__ in its own __dict__."
    - "decimal.localcontext() returns a decimal.ContextManager instance whose class defines both __enter__ and __exit__, but decimal.ContextManager is not directly accessible as a module-level name."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table decimal_extra2191.decimal_context_protocol:
  description: "decimal.Decimal dict-presence checks for context manager and lock protocol keys"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2191

  columns: [id, function, args, expected]
  rows:
    - ["dc2191001", "decimal.Decimal.__dict__.__contains__", ["__enter__"], false]
    - ["dc2191002", "decimal.Decimal.__dict__.__contains__", ["__exit__"], false]
    - ["dc2191003", "decimal.Decimal.__dict__.__contains__", ["__aenter__"], false]
    - ["dc2191004", "decimal.Decimal.__dict__.__contains__", ["__aexit__"], false]
    - ["dc2191005", "decimal.Decimal.__dict__.__contains__", ["acquire"], false]
    - ["dc2191006", "decimal.Decimal.__dict__.__contains__", ["release"], false]
    - ["dc2191007", "decimal.Decimal.__dict__.__contains__", ["__wrapped__"], false]
    - ["dc2191008", "decimal.Decimal.__dict__.__contains__", ["__closure__"], false]

