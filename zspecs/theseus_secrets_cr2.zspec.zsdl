spec: theseus_secrets_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_secrets_cr2)
blocks: secrets

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html"
    - "PEP 506 — Adding a secrets module to the standard library"
  notes:
    - "Clean-room extended secrets utilities. Do NOT import secrets."
    - "token_urlsafe(nbytes=32): return URL-safe base64 token from nbytes of random bytes."
    - "compare_digest(a, b): constant-time comparison of strings or bytes."
    - "randbits(k): return k random bits as integer using os.urandom."
    - "secrets2_token_urlsafe(): len(token_urlsafe(16)) > 0 — returns True."
    - "secrets2_compare_digest_self(): x = token_hex(8); compare_digest(x, x) == True."
    - "secrets2_randbits(): 0 <= randbits(8) <= 255 — returns True."
    - "Zero-arg invariant signatures — def secrets2_token_urlsafe(): return bool"
    - "token_urlsafe: os.urandom(nbytes) then URL-safe base64 encode (no +/= issues)."
    - "compare_digest: iterate both strings in parallel; XOR chars; return True iff XOR sum is 0."
    - "randbits(k): read ceil(k/8) bytes from os.urandom; extract k bits."
    - "Export: token_urlsafe(nbytes), token_hex(nbytes), compare_digest(a,b), randbits(k), token_bytes(nbytes)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_secrets_cr2.token_urlsafe:
  description: "token_urlsafe(16) returns non-empty string"
  category: token_urlsafe
  kind: python_call_eq
  function: secrets2_token_urlsafe
  args: []
  expected: true

invariant theseus_secrets_cr2.compare_digest_self:
  description: "compare_digest(x, x) == True for any x"
  category: compare_digest
  kind: python_call_eq
  function: secrets2_compare_digest_self
  args: []
  expected: true

invariant theseus_secrets_cr2.randbits:
  description: "randbits(8) is in [0, 255]"
  category: randbits
  kind: python_call_eq
  function: secrets2_randbits
  args: []
  expected: true
