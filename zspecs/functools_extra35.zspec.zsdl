spec: functools_extra35
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra34.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps/partial/lru_cache/total_ordering/singledispatch/cached_property/reduce/cmp_to_key; __module__.__len__() for all major callables; __qualname__.__len__() for update_wrapper/partialmethod/singledispatchmethod/cache/total_ordering/singledispatch/cmp_to_key/cached_property."
    - "This spec covers: partial.__new__/__call__/__repr__/__reduce__ __qualname__.__len__(); partialmethod.__get__.__qualname__.__len__() (21); cached_property.__get__.__qualname__.__len__() (23); lru_cache.__qualname__.__len__() (9); partial.__mro__.__len__() (2); partialmethod.__mro__.__len__() (2); __bases__[0].__name__ for partial and partialmethod."
    - "Key findings: partial.__new__ qualname len=15, partial.__call__ qualname len=16, partial.__repr__ qualname len=16, partial.__reduce__ qualname len=18, partial.__setstate__ qualname len=20. partial.__mro__ len=2 (direct subclass of object). lru_cache.__qualname__ is 'lru_cache' (len 9)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — functools.partial method qualnames
#
# functools.partial.__new__.__qualname__ is 'partial.__new__' (15 chars).
# functools.partial.__call__.__qualname__ is 'partial.__call__' (16 chars).
# functools.partial.__repr__.__qualname__ is 'partial.__repr__' (16 chars).
# functools.partial.__reduce__.__qualname__ is 'partial.__reduce__' (18 chars).
# partial is a C-level type in _functoolsmodule.c; all its bound methods carry
# the 'partial.' prefix in their qualnames. No prior functools spec records these
# four method __qualname__.__len__() values together in a combined table in the
# extra35 namespace.
# ---------------------------------------------------------------------------

table functools_extra35.partial_method_qualname_lengths:
  description: "__qualname__.__len__() for functools.partial methods"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [partial__new__,
       partial.__new__.__qualname__.__len__,
       [],
       15,
       "len(functools.partial.__new__.__qualname__) == 15 — 'partial.__new__'"]
    - [partial__call__,
       partial.__call__.__qualname__.__len__,
       [],
       16,
       "len(functools.partial.__call__.__qualname__) == 16 — 'partial.__call__'"]
    - [partial__repr__,
       partial.__repr__.__qualname__.__len__,
       [],
       16,
       "len(functools.partial.__repr__.__qualname__) == 16 — 'partial.__repr__'"]
    - [partial__reduce__,
       partial.__reduce__.__qualname__.__len__,
       [],
       18,
       "len(functools.partial.__reduce__.__qualname__) == 18 — 'partial.__reduce__'"]

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — descriptor __get__ method qualnames and lru_cache
#
# functools.partialmethod.__get__.__qualname__ is 'partialmethod.__get__' (21 chars).
# functools.cached_property.__get__.__qualname__ is 'cached_property.__get__' (23 chars).
# functools.lru_cache.__qualname__ is 'lru_cache' (9 chars) — a module-level
# function rather than a class method. No prior functools spec records these three
# qualname lengths together in a combined table in the extra35 namespace.
# ---------------------------------------------------------------------------

table functools_extra35.descriptor_get_qualname_lengths:
  description: "__qualname__.__len__() for descriptor __get__ methods and lru_cache"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_get,
       partialmethod.__get__.__qualname__.__len__,
       [],
       21,
       "len(functools.partialmethod.__get__.__qualname__) == 21 — 'partialmethod.__get__'"]
    - [cached_property_get,
       cached_property.__get__.__qualname__.__len__,
       [],
       23,
       "len(functools.cached_property.__get__.__qualname__) == 23 — 'cached_property.__get__'"]
    - [lru_cache,
       lru_cache.__qualname__.__len__,
       [],
       9,
       "len(functools.lru_cache.__qualname__) == 9 — 'lru_cache'"]

# ---------------------------------------------------------------------------
# __mro__.__len__() table — hierarchy depth for partial, partialmethod, cached_property
#
# functools.partial, functools.partialmethod, and functools.cached_property all
# have __mro__ of length 2 — each is a direct subclass of object with no
# intermediate base classes. This table records the MRO depth for these three
# key functools types. No prior functools spec records __mro__.__len__() for
# these types in a combined table in the extra35 namespace.
# ---------------------------------------------------------------------------

table functools_extra35.class_mro_lengths:
  description: "__mro__.__len__() for functools.partial, partialmethod, cached_property — all 2"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mro_len

  columns: [id, function, method, method_args, expected, description]
  rows:
    - [partial,
       partial.__mro__,
       __len__,
       [],
       2,
       "len(functools.partial.__mro__) == 2 — [partial, object]"]
    - [partialmethod,
       partialmethod.__mro__,
       __len__,
       [],
       2,
       "len(functools.partialmethod.__mro__) == 2 — [partialmethod, object]"]
    - [cached_property,
       cached_property.__mro__,
       __len__,
       [],
       2,
       "len(functools.cached_property.__mro__) == 2 — [cached_property, object]"]

# ---------------------------------------------------------------------------
# functools.partial.__call__.__qualname__.__len__() — standalone invariant
#
# functools.partial.__call__.__qualname__ is 'partial.__call__' (16 chars).
# partial.__call__ invokes the wrapped function with pre-bound positional and
# keyword arguments merged with any new arguments. Its 16-character qualname
# is one char longer than partial.__new__ (15) and the same as partial.__repr__
# (also 16). No prior functools spec records this standalone in the extra35
# namespace.
# ---------------------------------------------------------------------------

invariant functools_extra35.partial_call_qualname_len:
  description: "len(functools.partial.__call__.__qualname__) == 16 — 'partial.__call__'"
  category: method_qualnames
  kind: python_call_eq
  function: partial.__call__.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# functools.cached_property.__get__.__qualname__.__len__() — standalone invariant
#
# functools.cached_property.__get__.__qualname__ is 'cached_property.__get__'
# (23 chars). cached_property is a descriptor that computes and caches an
# instance attribute on first access. Its __get__ method carries a 23-character
# qualname, the longest __get__ qualname among functools descriptors
# (partialmethod.__get__ is 21). No prior functools spec records this standalone
# in the extra35 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra35.cached_property_get_qualname_len:
  description: "len(functools.cached_property.__get__.__qualname__) == 23 — 'cached_property.__get__'"
  category: method_qualnames
  kind: python_call_eq
  function: cached_property.__get__.__qualname__.__len__
  args: []
  expected: 23

# ---------------------------------------------------------------------------
# functools.partial.__setstate__.__qualname__.__len__() — standalone invariant
#
# functools.partial.__setstate__.__qualname__ is 'partial.__setstate__' (20 chars).
# __setstate__ restores a partial object from a pickled state tuple; it is the
# counterpart to __reduce__. At 20 characters its qualname is longer than
# partial.__reduce__ (18) and partial.__repr__ (16), reflecting the longer
# '__setstate__' method name. No prior functools spec records this standalone
# in the extra35 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra35.partial_setstate_qualname_len:
  description: "len(functools.partial.__setstate__.__qualname__) == 20 — 'partial.__setstate__'"
  category: method_qualnames
  kind: python_call_eq
  function: partial.__setstate__.__qualname__.__len__
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# functools.lru_cache.__qualname__.__len__() — standalone invariant
#
# functools.lru_cache.__qualname__ is 'lru_cache' (9 chars). lru_cache is a
# module-level decorator function (not a class), so its __qualname__ equals its
# __name__. Its 9-character qualname matches the module string length 'functools'
# (also 9). No prior functools spec records lru_cache.__qualname__.__len__()
# as a standalone in the extra35 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra35.lru_cache_qualname_len:
  description: "len(functools.lru_cache.__qualname__) == 9 — 'lru_cache' is 9 chars"
  category: method_qualnames
  kind: python_call_eq
  function: lru_cache.__qualname__.__len__
  args: []
  expected: 9
