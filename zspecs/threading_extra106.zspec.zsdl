spec: threading_extra106
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra105

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra105.zspec.zsdl."
    - "This spec covers: threading.Lock (C type) and threading._RLock (Python class) method __class__.__name__ values; Lock methods are 'method_descriptor' (C slots); _RLock methods are 'function' (pure Python); wave 258."
    - "threading.Lock.acquire.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "threading.Lock.release.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "threading.Lock.__enter__.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "threading.Lock.__exit__.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "threading.Lock.locked.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "threading._RLock.acquire.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading._RLock.release.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading._RLock.__enter__.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading._RLock.__exit__.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading._RLock._is_owned.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "The contrast between method_descriptor (C slot) and function (Python def) reliably identifies C vs Python implementations. Lock is from Modules/_threadmodule.c; _RLock is from Lib/threading.py."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Lock method __class__.__name__ values
#
# Wave 258 theme: threading.Lock is a C extension type (lock_type from
# Modules/_threadmodule.c); its unbound methods are 'method_descriptor' objects.
#
# threading.Lock.acquire.__class__.__name__ == 'method_descriptor'
# threading.Lock.release.__class__.__name__ == 'method_descriptor'
# threading.Lock.__enter__.__class__.__name__ == 'method_descriptor'
# threading.Lock.__exit__.__class__.__name__ == 'method_descriptor'
# threading.Lock.locked.__class__.__name__ == 'method_descriptor'
#
# New to extra106.
# ---------------------------------------------------------------------------

table threading_extra106.lock_method_class_names:
  description: "threading.Lock method __class__.__name__ == 'method_descriptor' for acquire/release/__enter__/__exit__/locked; C extension type methods are method_descriptor; wave 258; new to extra106"
  kind: python_call_eq
  category: class_names
  id_prefix: threadinglock106

  columns: [id, function, args, expected, description]
  rows:
    - [lock_acquire_class_method_descriptor,
       "Lock.acquire.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.acquire.__class__.__name__.__eq__('method_descriptor') == True — threading.Lock is a C extension type (lock_type) from Modules/_threadmodule.c; acquire is defined in the type's PyMethodDef table; unbound C methods are method_descriptor objects; __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra106"]
    - [lock_release_class_method_descriptor,
       "Lock.release.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.release.__class__.__name__.__eq__('method_descriptor') == True — Lock.release is a C method slot on the lock_type; unbound it is a method_descriptor; __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra106"]
    - ["lock_enter_class_method_descriptor",
       "Lock.__enter__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.__enter__.__class__.__name__.__eq__('method_descriptor') == True — Lock.__enter__ implements the context manager protocol as a C method slot; unbound it is a method_descriptor; __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra106"]
    - ["lock_exit_class_method_descriptor",
       "Lock.__exit__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.__exit__.__class__.__name__.__eq__('method_descriptor') == True — Lock.__exit__ is a C method slot for context manager protocol exit; unbound it is a method_descriptor; __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra106"]
    - [lock_locked_class_method_descriptor,
       "Lock.locked.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.locked.__class__.__name__.__eq__('method_descriptor') == True — Lock.locked is a C method slot that returns True if the lock is held; unbound it is a method_descriptor; __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra106"]

# ---------------------------------------------------------------------------
# Table 2: threading._RLock method __class__.__name__ values
#
# Wave 258 theme: threading._RLock is a pure-Python class defined in
# Lib/threading.py; its methods are plain Python 'function' objects.
#
# threading._RLock.acquire.__class__.__name__ == 'function'
# threading._RLock.release.__class__.__name__ == 'function'
# threading._RLock.__enter__.__class__.__name__ == 'function'
# threading._RLock.__exit__.__class__.__name__ == 'function'
# threading._RLock._is_owned.__class__.__name__ == 'function'
#
# New to extra106.
# ---------------------------------------------------------------------------

table threading_extra106.rlock_method_class_names:
  description: "threading._RLock method __class__.__name__ == 'function' for acquire/release/__enter__/__exit__/_is_owned; pure-Python class methods are 'function'; wave 258; new to extra106"
  kind: python_call_eq
  category: class_names
  id_prefix: threadingrlock106

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_acquire_class_function,
       "_RLock.acquire.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock.acquire.__class__.__name__.__eq__('function') == True — threading._RLock is a pure-Python class defined in Lib/threading.py; its acquire method is defined with 'def acquire(...)' and accessed unbound from the class is a plain Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra106"]
    - [rlock_release_class_function,
       "_RLock.release.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock.release.__class__.__name__.__eq__('function') == True — _RLock.release is a Python def method; accessed unbound from the class it is a function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra106"]
    - ["rlock_enter_class_function",
       "_RLock.__enter__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock.__enter__.__class__.__name__.__eq__('function') == True — _RLock.__enter__ is a Python def method implementing the context manager protocol; accessed unbound from the class it is a function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra106"]
    - ["rlock_exit_class_function",
       "_RLock.__exit__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock.__exit__.__class__.__name__.__eq__('function') == True — _RLock.__exit__ is a Python def method for context manager protocol exit; accessed unbound from the class it is a function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra106"]
    - [rlock_is_owned_class_function,
       "_RLock._is_owned.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock._is_owned.__class__.__name__.__eq__('function') == True — _RLock._is_owned is a private helper method defined with 'def _is_owned(self)' in Lib/threading.py; accessed unbound from the class it is a function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra106"]

# ---------------------------------------------------------------------------
# Table 3: Lock vs _RLock method class names — contrast table
#
# Wave 258 theme: direct comparison of Lock (C type → method_descriptor) vs
# _RLock (Python class → function) for the same method name.
# This highlights the C-vs-Python implementation boundary.
#
# Lock.acquire.__class__.__name__ == 'method_descriptor'  (C)
# _RLock.acquire.__class__.__name__ == 'function'          (Python)
# Lock.release.__class__.__name__ == 'method_descriptor'  (C)
# _RLock.release.__class__.__name__ == 'function'          (Python)
# Lock.__enter__.__class__.__name__ == 'method_descriptor' (C)
# _RLock.__enter__.__class__.__name__ == 'function'        (Python)
# Lock.locked.__class__.__name__ == 'method_descriptor'   (C, no Python equivalent)
# _RLock._is_owned.__class__.__name__ == 'function'        (Python, no C equivalent)
#
# New to extra106.
# ---------------------------------------------------------------------------

table threading_extra106.lock_vs_rlock_contrast:
  description: "Lock (C) method_descriptor vs _RLock (Python) function — acquire/release/__enter__ contrast; identifies C vs Python implementation boundary; wave 258; new to extra106"
  kind: python_call_eq
  category: class_names
  id_prefix: threadingcontrast106

  columns: [id, function, args, expected, description]
  rows:
    - [lock_acquire_is_method_descriptor,
       "Lock.acquire.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.acquire.__class__.__name__.__eq__('method_descriptor') == True — Lock is a C extension type; acquire is a C method slot; class name is 'method_descriptor'; contrast with _RLock.acquire which is 'function'; new to extra106"]
    - [rlock_acquire_is_function,
       "_RLock.acquire.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock.acquire.__class__.__name__.__eq__('function') == True — _RLock is a Python class; acquire is a Python def; class name is 'function'; contrast with Lock.acquire which is 'method_descriptor'; new to extra106"]
    - [lock_release_is_method_descriptor,
       "Lock.release.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.release.__class__.__name__.__eq__('method_descriptor') == True — Lock.release is a C slot; class name is 'method_descriptor'; new to extra106"]
    - [rlock_release_is_function,
       "_RLock.release.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock.release.__class__.__name__.__eq__('function') == True — _RLock.release is a Python def; class name is 'function'; new to extra106"]
    - ["lock_enter_is_method_descriptor",
       "Lock.__enter__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.__enter__.__class__.__name__.__eq__('method_descriptor') == True — Lock.__enter__ is a C slot; class name is 'method_descriptor'; new to extra106"]
    - ["rlock_enter_is_function",
       "_RLock.__enter__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock.__enter__.__class__.__name__.__eq__('function') == True — _RLock.__enter__ is a Python def; class name is 'function'; new to extra106"]
    - [lock_locked_is_method_descriptor,
       "Lock.locked.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.locked.__class__.__name__.__eq__('method_descriptor') == True — Lock.locked is a C slot with no _RLock equivalent; class name is 'method_descriptor'; new to extra106"]
    - [rlock_is_owned_is_function,
       "_RLock._is_owned.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock._is_owned.__class__.__name__.__eq__('function') == True — _RLock._is_owned is a private Python def with no Lock equivalent; class name is 'function'; new to extra106"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra106
# ---------------------------------------------------------------------------

invariant threading_extra106.lock_acquire_method_descriptor:
  description: "threading.Lock.acquire.__class__.__name__ == 'method_descriptor' — Lock is a C extension type; its methods are method_descriptor objects; wave 258; new to extra106"
  kind: python_call_eq
  function: Lock.acquire.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant threading_extra106.rlock_acquire_function:
  description: "threading._RLock.acquire.__class__.__name__ == 'function' — _RLock is a pure-Python class; its methods are function objects; wave 258; new to extra106"
  kind: python_call_eq
  function: _RLock.acquire.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra106.rlock_is_owned_function:
  description: "threading._RLock._is_owned.__class__.__name__ == 'function' — private helper method is a plain Python function; wave 258; new to extra106"
  kind: python_call_eq
  function: _RLock._is_owned.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra106.lock_locked_method_descriptor:
  description: "threading.Lock.locked.__class__.__name__ == 'method_descriptor' — C method slot with no _RLock equivalent; wave 258; new to extra106"
  kind: python_call_eq
  function: Lock.locked.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant threading_extra106.lock_exit_method_descriptor:
  description: "threading.Lock.__exit__.__class__.__name__ == 'method_descriptor' — C slot for context manager exit; wave 258; new to extra106"
  kind: python_call_eq
  function: "Lock.__exit__.__class__.__name__.__eq__"
  args: ["method_descriptor"]
  expected: true

