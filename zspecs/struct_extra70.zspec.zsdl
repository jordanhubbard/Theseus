spec: struct_extra70
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra69.zspec.zsdl — covers Struct.pack/__qualname__.__len__()==11 / Struct.unpack/__qualname__.__len__()==13 / Struct.pack_into/__qualname__.__len__()==16 / Struct.unpack_from/__qualname__.__len__()==18 / Struct.iter_unpack/__qualname__.__len__()==18 / error/__qualname__=='error' / error/__doc__/__class__/__name__=='NoneType' / Struct/__dict__/__contains__('__sizeof__') / Struct.size/__qualname__=='Struct.size' (table + invariants)."
    - "struct_extra68.zspec.zsdl — covers Struct.size/format/__class__/__name__=='getset_descriptor' / Struct.__doc__/__class__/__name__=='str' / Struct.__name__/__module__/__qualname__ / pack/unpack/calcsize/__qualname__ (table + invariants)."
    - "struct_extra67.zspec.zsdl — covers pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/__class__/__name__=='builtin_function_or_method' / error/__name__/__module__/__bases__[0]/__mro__.__len__() (table + invariants)."
    - "struct_extra66.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __class__/__name__=='method_descriptor' / __qualname__ eq and len (table + invariants)."
    - "struct_extra65.zspec.zsdl — covers Struct.__dict__.__class__.__name__=='mappingproxy' / Struct.__dict__.__contains__ pack/unpack/pack_into/unpack_from/iter_unpack/size/format (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra69; it does NOT duplicate invariants present in those files."
    - "Wave 241 theme: struct.Struct __dict__ content deeper."
    - "struct.Struct.__dict__.__contains__('__init__') == True — Struct defines __init__ in its class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('__new__') == True — Struct defines __new__ in its class __dict__ (C types often do). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__doc__.__contains__('format') == True — the pack docstring mentions 'format'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__doc__.__contains__('format') == True — the unpack docstring mentions 'format'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__doc__.__contains__('format') == True — the calcsize docstring mentions 'format'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__contains__('fmt') == True — the Struct docstring mentions 'fmt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('__repr__') == True — Struct defines __repr__ in its class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('__module__') == True — Struct defines __module__ in its class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__ for __init__ and __new__
#
# Wave 241 theme: struct.Struct __dict__ content deeper.
#
# struct.Struct defines both __init__ and __new__ in its class __dict__.
# struct_extra65 covers Struct.__dict__.__contains__ for pack/unpack/pack_into/
# unpack_from/iter_unpack/size/format. struct_extra69 covers __sizeof__.
# No prior struct spec checks Struct.__dict__.__contains__ for __init__ or __new__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra70.Struct_dict_contains_init_new:
  description: "struct.Struct/__dict__.__contains__('__init__')==True / Struct/__dict__.__contains__('__new__')==True — Struct defines both __init__ and __new__ in its class __dict__; struct_extra65 covers pack/unpack/size/format; struct_extra69 covers __sizeof__; no prior struct spec checks __init__ or __new__ in Struct.__dict__; first __init__ and __new__ dict contains anchor for Struct"
  kind: python_call_eq
  category: class_dict
  id_prefix: structmore70

  columns: [id, function, args, expected]
  rows:
    - [Struct_dict_contains_init, Struct.__dict__.__contains__, ["__init__"], true]
    - [Struct_dict_contains_new,  Struct.__dict__.__contains__, ["__new__"],  true]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__ for __repr__ and __module__
#
# Wave 241 theme: struct.Struct __dict__ content — repr and module.
#
# struct.Struct defines __repr__ and __module__ in its class __dict__.
# No prior struct spec checks Struct.__dict__.__contains__ for __repr__
# or __module__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra70.Struct_dict_contains_repr_module:
  description: "struct.Struct/__dict__.__contains__('__repr__')==True / Struct/__dict__.__contains__('__module__')==True — Struct defines __repr__ and __module__ in its class __dict__; no prior struct spec checks __repr__ or __module__ in Struct.__dict__; first __repr__ and __module__ dict contains anchor for Struct"
  kind: python_call_eq
  category: class_dict
  id_prefix: structmore70

  columns: [id, function, args, expected]
  rows:
    - [Struct_dict_contains_repr,   Struct.__dict__.__contains__, ["__repr__"],   true]
    - [Struct_dict_contains_module, Struct.__dict__.__contains__, ["__module__"], true]

# ---------------------------------------------------------------------------
# struct.pack / unpack / calcsize __doc__.__contains__('format')
#
# Wave 241 theme: struct module function docstrings mention 'format'.
#
# struct.pack, struct.unpack, and struct.calcsize all have docstrings that
# mention 'format'. No prior struct spec checks __doc__.__contains__ for
# any of these functions. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra70.pack_unpack_calcsize_doc_contains_format:
  description: "struct.pack/__doc__.__contains__('format')==True / struct.unpack/__doc__.__contains__('format')==True / struct.calcsize/__doc__.__contains__('format')==True — pack, unpack, and calcsize docstrings all mention 'format'; no prior struct spec checks __doc__.__contains__ for these functions; first doc content anchor for pack/unpack/calcsize"
  kind: python_call_eq
  category: docstrings
  id_prefix: structmore70

  columns: [id, function, args, expected]
  rows:
    - [pack_doc_contains_format,     pack.__doc__.__contains__,     ["format"], true]
    - [unpack_doc_contains_format,   unpack.__doc__.__contains__,   ["format"], true]
    - [calcsize_doc_contains_format, calcsize.__doc__.__contains__, ["format"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__contains__('fmt') and struct.Struct.__doc__.__contains__('Struct')
#
# Wave 241 theme: Struct class docstring content.
#
# struct.Struct.__doc__ contains 'fmt' (the Struct docstring is
# 'Struct(fmt) --> compiled struct object'). It also contains 'Struct'.
# No prior struct spec checks Struct.__doc__.__contains__ for any string.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra70.Struct_doc_contains_fmt_Struct:
  description: "struct.Struct/__doc__.__contains__('fmt')==True / Struct/__doc__.__contains__('Struct')==True — Struct docstring is 'Struct(fmt) --> compiled struct object'; it contains 'fmt' and 'Struct'; no prior struct spec checks Struct.__doc__.__contains__; first Struct docstring content anchor"
  kind: python_call_eq
  category: docstrings
  id_prefix: structmore70

  columns: [id, function, args, expected]
  rows:
    - [Struct_doc_contains_fmt,    Struct.__doc__.__contains__, ["fmt"],    true]
    - [Struct_doc_contains_Struct, Struct.__doc__.__contains__, ["Struct"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__init__') — standalone
#
# struct.Struct defines __init__ in its class __dict__. No prior struct spec
# checks Struct.__dict__.__contains__('__init__'). First __init__ dict contains
# standalone for Struct. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra70.Struct_dict_contains_init:
  description: "struct.Struct.__dict__.__contains__('__init__') == True — Struct defines __init__ in its class __dict__; no prior struct spec checks __init__ in Struct.__dict__; first __init__ dict contains standalone for Struct"
  category: class_dict
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__new__') — standalone
#
# struct.Struct defines __new__ in its class __dict__. No prior struct spec
# checks Struct.__dict__.__contains__('__new__'). First __new__ dict contains
# standalone for Struct. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra70.Struct_dict_contains_new:
  description: "struct.Struct.__dict__.__contains__('__new__') == True — Struct defines __new__ in its class __dict__; no prior struct spec checks __new__ in Struct.__dict__; first __new__ dict contains standalone for Struct"
  category: class_dict
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["__new__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack.__doc__.__contains__('format') — standalone
#
# struct.pack has a docstring that mentions 'format'. No prior struct spec
# checks pack.__doc__.__contains__('format'). First doc content standalone
# for struct.pack. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra70.pack_doc_contains_format:
  description: "struct.pack.__doc__.__contains__('format') == True — pack docstring mentions 'format'; no prior struct spec checks pack.__doc__.__contains__; first doc content standalone for struct.pack"
  category: docstrings
  kind: python_call_eq
  function: pack.__doc__.__contains__
  args: ["format"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__contains__('fmt') — standalone
#
# struct.Struct.__doc__ contains 'fmt'. No prior struct spec checks
# Struct.__doc__.__contains__('fmt'). First Struct doc content standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra70.Struct_doc_contains_fmt:
  description: "struct.Struct.__doc__.__contains__('fmt') == True — Struct docstring is 'Struct(fmt) --> compiled struct object' and contains 'fmt'; no prior struct spec checks Struct.__doc__.__contains__; first Struct docstring content standalone"
  category: docstrings
  kind: python_call_eq
  function: Struct.__doc__.__contains__
  args: ["fmt"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__repr__') — standalone
#
# struct.Struct defines __repr__ in its class __dict__. No prior struct spec
# checks Struct.__dict__.__contains__('__repr__'). First __repr__ dict contains
# standalone for Struct. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra70.Struct_dict_contains_repr:
  description: "struct.Struct.__dict__.__contains__('__repr__') == True — Struct defines __repr__ in its class __dict__; no prior struct spec checks __repr__ in Struct.__dict__; first __repr__ dict contains standalone for Struct"
  category: class_dict
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["__repr__"]
  expected: true
