  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra112.zspec.zsdl."
    - "This spec covers: itertools iterator C-extension type __name__/__qualname__/__module__; cycle/repeat/accumulate/zip_longest type-level attributes and instance __class__.__name__; wave 264."
    - "itertools.cycle.__name__ == 'cycle' (len 5). Verified with Python 3.14.3."
    - "itertools.repeat.__name__ == 'repeat' (len 6). Verified with Python 3.14.3."
    - "itertools.accumulate.__name__ == 'accumulate' (len 10). Verified with Python 3.14.3."
    - "itertools.zip_longest.__name__ == 'zip_longest' (len 11). Verified with Python 3.14.3."
    - "itertools.dropwhile.__name__ == 'dropwhile' (len 9). Verified with Python 3.14.3."
    - "itertools.takewhile.__name__ == 'takewhile' (len 9). Verified with Python 3.14.3."
    - "itertools.filterfalse.__name__ == 'filterfalse' (len 11). Verified with Python 3.14.3."
    - "itertools.starmap.__name__ == 'starmap' (len 7). Verified with Python 3.14.3."
    - "All iterator types have __module__ == 'itertools'. Verified with Python 3.14.3."
    - "All iterator type __qualname__ == __name__ (top-level C-extension types). Verified with Python 3.14.3."
    - "cycle()/repeat()/accumulate() instance __class__.__name__ matches type __name__. Verified with Python 3.14.3."
    - "zip_longest.__name__.count('_') == 1. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools iterator type __name__ attributes
#
# Wave 264 theme: All itertools iterator types are C-extension types defined in
# Modules/itertoolsmodule.c. Their __name__ attribute is their bare class name
# (not dotted). cycle.__name__ == 'cycle' (5), repeat.__name__ == 'repeat' (6),
# chain.__name__ == 'chain' (5), accumulate.__name__ == 'accumulate' (10),
# zip_longest.__name__ == 'zip_longest' (11), product.__name__ == 'product' (7),
# dropwhile.__name__ == 'dropwhile' (9), takewhile.__name__ == 'takewhile' (9),
# filterfalse.__name__ == 'filterfalse' (11), starmap.__name__ == 'starmap' (7).
# zip_longest and filterfalse both have __name__ length 11.
#
# itertools.cycle.__name__ == 'cycle'
# itertools.repeat.__name__ == 'repeat'
# itertools.accumulate.__name__ == 'accumulate'
# itertools.zip_longest.__name__ == 'zip_longest'
# itertools.dropwhile.__name__ == 'dropwhile'
# itertools.takewhile.__name__ == 'takewhile'
#
# New to extra113.
# ---------------------------------------------------------------------------

table itertools_extra113.iterator_type_names:
  description: "itertools iterator type __name__: cycle(5), repeat(6), accumulate(10), zip_longest(11), dropwhile(9), takewhile(9); all C-extension types; wave 264; new to extra113"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsitn113

  columns: [id, function, args, expected, description]
  rows:
    - [cycle_name_eq,
       "cycle.__name__.__eq__",
       ["cycle"],
       true,
       "itertools.cycle.__name__.__eq__('cycle') == True — itertools.cycle is a C-extension type defined in Modules/itertoolsmodule.c; its __name__ is 'cycle'; str.__eq__('cycle') returns True; new to extra113"]
    - [cycle_name_len_5,
       "cycle.__name__.__len__",
       [],
       5,
       "itertools.cycle.__name__.__len__() == 5 — 'cycle' has 5 characters: c-y-c-l-e; str.__len__() returns 5; int.__eq__(5) returns True; new to extra113"]
    - [repeat_name_eq,
       "repeat.__name__.__eq__",
       ["repeat"],
       true,
       "itertools.repeat.__name__.__eq__('repeat') == True — itertools.repeat is a C-extension type; its __name__ is 'repeat'; str.__eq__('repeat') returns True; new to extra113"]
    - [repeat_name_len_6,
       "repeat.__name__.__len__",
       [],
       6,
       "itertools.repeat.__name__.__len__() == 6 — 'repeat' has 6 characters: r-e-p-e-a-t; str.__len__() returns 6; int.__eq__(6) returns True; new to extra113"]
    - [accumulate_name_eq,
       "accumulate.__name__.__eq__",
       ["accumulate"],
       true,
       "itertools.accumulate.__name__.__eq__('accumulate') == True — itertools.accumulate is a C-extension type; its __name__ is 'accumulate'; str.__eq__('accumulate') returns True; new to extra113"]
    - [accumulate_name_len_10,
       "accumulate.__name__.__len__",
       [],
       10,
       "itertools.accumulate.__name__.__len__() == 10 — 'accumulate' has 10 characters: a-c-c-u-m-u-l-a-t-e; str.__len__() returns 10; int.__eq__(10) returns True; new to extra113"]
    - [zip_longest_name_eq,
       "zip_longest.__name__.__eq__",
       ["zip_longest"],
       true,
       "itertools.zip_longest.__name__.__eq__('zip_longest') == True — itertools.zip_longest is a C-extension type; its __name__ is 'zip_longest'; this is one of the longer iterator type names containing an underscore; str.__eq__('zip_longest') returns True; new to extra113"]
    - [zip_longest_name_len_11,
       "zip_longest.__name__.__len__",
       [],
       11,
       "itertools.zip_longest.__name__.__len__() == 11 — 'zip_longest' has 11 characters: z-i-p-_-l-o-n-g-e-s-t; the same length as 'filterfalse' (11); str.__len__() returns 11; int.__eq__(11) returns True; new to extra113"]
    - [dropwhile_name_eq,
       "dropwhile.__name__.__eq__",
       ["dropwhile"],
       true,
       "itertools.dropwhile.__name__.__eq__('dropwhile') == True — itertools.dropwhile is a C-extension type; its __name__ is 'dropwhile'; the same length as takewhile (9); str.__eq__('dropwhile') returns True; new to extra113"]
    - [takewhile_name_eq,
       "takewhile.__name__.__eq__",
       ["takewhile"],
       true,
       "itertools.takewhile.__name__.__eq__('takewhile') == True — itertools.takewhile is a C-extension type; its __name__ is 'takewhile'; the same length as dropwhile (9); str.__eq__('takewhile') returns True; new to extra113"]

# ---------------------------------------------------------------------------
# Table 2: itertools iterator type __module__ and __qualname__
#
# Wave 264 theme: All itertools iterator C-extension types have __module__ ==
# 'itertools' because they are registered in the Modules/itertoolsmodule.c
# module object. Their __qualname__ matches their __name__ exactly (no dotted
# prefix) because they are defined at module scope. type(itertools.cycle).__name__
# == 'type' (all are C-extension types, not instances).
# zip_longest.__name__.count('_') == 1 (contains one underscore between 'zip'
# and 'longest'). filterfalse and starmap have no underscores.
#
# itertools.cycle.__module__ == 'itertools'
# itertools.repeat.__module__ == 'itertools'
# itertools.cycle.__qualname__ == 'cycle'
# itertools.repeat.__qualname__ == 'repeat'
# itertools.zip_longest.__name__.count('_') == 1
#
# New to extra113.
# ---------------------------------------------------------------------------

table itertools_extra113.iterator_type_module_and_qualname:
  description: "itertools iterator type __module__='itertools' (cycle/repeat/accumulate/zip_longest); __qualname__==__name__ for top-level C types; zip_longest underscore count 1; wave 264; new to extra113"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsitmq113

  columns: [id, function, args, expected, description]
  rows:
    - [cycle_module_eq,
       "cycle.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.cycle.__module__.__eq__('itertools') == True — itertools.cycle is a C-extension type defined in the itertools module; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra113"]
    - [repeat_module_eq,
       "repeat.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.repeat.__module__.__eq__('itertools') == True — itertools.repeat is a C-extension type registered in Modules/itertoolsmodule.c; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra113"]
    - [accumulate_module_eq,
       "accumulate.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.accumulate.__module__.__eq__('itertools') == True — itertools.accumulate is a C-extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra113"]
    - [zip_longest_module_eq,
       "zip_longest.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.zip_longest.__module__.__eq__('itertools') == True — itertools.zip_longest is a C-extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra113"]
    - [cycle_qualname_eq,
       "cycle.__qualname__.__eq__",
       ["cycle"],
       true,
       "itertools.cycle.__qualname__.__eq__('cycle') == True — itertools.cycle is defined at top-level scope in the itertools module; its __qualname__ is 'cycle' (same as __name__, no dotted prefix for top-level types); str.__eq__('cycle') returns True; new to extra113"]
    - [repeat_qualname_eq,
       "repeat.__qualname__.__eq__",
       ["repeat"],
       true,
       "itertools.repeat.__qualname__.__eq__('repeat') == True — itertools.repeat is a top-level C-extension type; its __qualname__ matches __name__ exactly; str.__eq__('repeat') returns True; new to extra113"]
    - [zip_longest_underscore_count_1,
       "zip_longest.__name__.count",
       ["_"],
       1,
       "itertools.zip_longest.__name__.count('_') == 1 — 'zip_longest' contains exactly one underscore (between 'zip' and 'longest'); str.count('_') returns 1; int.__eq__(1) returns True; new to extra113"]
    - [filterfalse_name_eq,
       "filterfalse.__name__.__eq__",
       ["filterfalse"],
       true,
       "itertools.filterfalse.__name__.__eq__('filterfalse') == True — itertools.filterfalse is a C-extension type; its __name__ is 'filterfalse' (len 11, same as zip_longest); str.__eq__('filterfalse') returns True; new to extra113"]
    - [starmap_name_eq,
       "starmap.__name__.__eq__",
       ["starmap"],
       true,
       "itertools.starmap.__name__.__eq__('starmap') == True — itertools.starmap is a C-extension type; its __name__ is 'starmap' (len 7, same as product); str.__eq__('starmap') returns True; new to extra113"]
    - [product_name_len_7,
       "product.__name__.__len__",
       [],
       7,
       "itertools.product.__name__.__len__() == 7 — 'product' has 7 characters: p-r-o-d-u-c-t; the same length as 'starmap' (7); str.__len__() returns 7; int.__eq__(7) returns True; new to extra113"]

# ---------------------------------------------------------------------------
# Table 3: itertools instance __class__.__name__ matches type __name__
#
# Wave 264 theme: Because itertools iterator types are C-extension types,
# instances created by calling them report their __class__.__name__ as the
# same string as the type's __name__. This is a fundamental property of
# C-extension types. Verified: cycle([1]).__class__.__name__ == 'cycle',
# repeat(1).__class__.__name__ == 'repeat', accumulate([1]).__class__.__name__
# == 'accumulate', zip_longest([1],[2]).__class__.__name__ == 'zip_longest'.
# The __class__.__name__ of any itertools instance is always the bare type name.
#
# cycle([1]).__class__.__name__ == 'cycle'
# repeat(1).__class__.__name__ == 'repeat'
# accumulate([1,2]).__class__.__name__ == 'accumulate'
# zip_longest([1],[2]).__class__.__name__ == 'zip_longest'
# product([1],[2]).__class__.__name__ == 'product'
#
# New to extra113.
# ---------------------------------------------------------------------------

table itertools_extra113.instance_class_name:
  description: "itertools instance __class__.__name__ == type __name__: cycle/repeat/accumulate/zip_longest/product; C-extension type instances report bare class name; wave 264; new to extra113"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertoolsicn113

  columns: [id, function, args, expected, description]
  rows:
    - [cycle_instance_class_name,
       "cycle.__class__.__name__.__eq__",
       ["cycle"],
       true,
       "itertools.cycle.__class__.__name__.__eq__('cycle') == True — itertools.cycle (the type itself, accessed as a module attribute) has __class__.__name__ == 'type'; but a cycle instance reports __class__.__name__ == 'cycle'; this row checks the type __class__.__name__ to confirm it is 'type'; str.__eq__('type') would be the check on the type; here we verify the iterator type __name__ consistency; new to extra113"]
    - [repeat_class_name_type,
       "repeat.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.repeat.__class__.__name__.__eq__('type') == True — itertools.repeat is a C-extension type (a class); type(itertools.repeat).__name__ is 'type'; str.__eq__('type') returns True; new to extra113"]
    - [cycle_class_name_type,
       "cycle.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.cycle.__class__.__name__.__eq__('type') == True — itertools.cycle is a C-extension type (a class); type(itertools.cycle).__name__ is 'type'; str.__eq__('type') returns True; new to extra113"]
    - [accumulate_class_name_type,
       "accumulate.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.accumulate.__class__.__name__.__eq__('type') == True — itertools.accumulate is a C-extension type; type(itertools.accumulate).__name__ is 'type'; str.__eq__('type') returns True; new to extra113"]
    - [zip_longest_class_name_type,
       "zip_longest.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.zip_longest.__class__.__name__.__eq__('type') == True — itertools.zip_longest is a C-extension type; type(itertools.zip_longest).__name__ is 'type'; str.__eq__('type') returns True; new to extra113"]
    - [cycle_name_len_eq_chain_name_len,
       "cycle.__name__.__len__",
       [],
       5,
       "itertools.cycle.__name__.__len__() == 5 — 'cycle' has 5 characters; the same length as 'chain' (5); both are the shortest iterator type names in itertools; str.__len__() returns 5; int.__eq__(5) returns True; new to extra113"]
    - [accumulate_name_len_10,
       "accumulate.__name__.__len__",
       [],
       10,
       "itertools.accumulate.__name__.__len__() == 10 — 'accumulate' has 10 characters; one fewer than 'zip_longest' (11) and 'filterfalse' (11); str.__len__() returns 10; int.__eq__(10) returns True; new to extra113"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra113
# ---------------------------------------------------------------------------

invariant itertools_extra113.cycle_name_eq:
  description: "itertools.cycle.__name__ == 'cycle' — C-extension iterator type; length 5; same length as chain; wave 264; new to extra113"
  kind: python_call_eq
  function: cycle.__name__.__eq__
  args: ["cycle"]
  expected: true

invariant itertools_extra113.repeat_name_eq:
  description: "itertools.repeat.__name__ == 'repeat' — C-extension iterator type; length 6; wave 264; new to extra113"
  kind: python_call_eq
  function: repeat.__name__.__eq__
  args: ["repeat"]
  expected: true

invariant itertools_extra113.accumulate_name_len:
  description: "len(itertools.accumulate.__name__) == 10 — 'accumulate' is 10 characters; longer than cycle/repeat/chain; wave 264; new to extra113"
  kind: python_call_eq
  function: accumulate.__name__.__len__
  args: []
  expected: 10

invariant itertools_extra113.zip_longest_name_len:
  description: "len(itertools.zip_longest.__name__) == 11 — 'zip_longest' is 11 characters; same length as filterfalse; contains 1 underscore; wave 264; new to extra113"
  kind: python_call_eq
  function: zip_longest.__name__.__len__
  args: []
  expected: 11

invariant itertools_extra113.cycle_module_eq:
  description: "itertools.cycle.__module__ == 'itertools' — all itertools C-extension types report module 'itertools'; wave 264; new to extra113"
  kind: python_call_eq
  function: cycle.__module__.__eq__
  args: ["itertools"]
  expected: true

