spec: struct_extra946
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.Struct class, struct.error exception, module functions, and module identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra946.module_identity:
  description: "struct module-level identity attributes"
  kind: python_call_eq
  category: module_identity
  id_prefix: st946mi
  columns: [id, function, args, expected]
  rows:
    - [st946mi001, struct.__name__.__eq__,       ["struct"], true]
    - [st946mi002, struct.__spec__.name.__eq__,  ["struct"], true]
    - [st946mi003, struct.__name__.__class__.__name__.__eq__, ["str"], true]
    - [st946mi004, struct.__spec__.name.__class__.__name__.__eq__, ["str"], true]
    - [st946mi005, struct.__package__.__class__.__name__.__eq__, ["str"], true]

table struct_extra946.class_and_exception:
  description: "struct.Struct class name and struct.error exception identity"
  kind: python_call_eq
  category: class_and_exception
  id_prefix: st946ce
  columns: [id, function, args, expected]
  rows:
    - [st946ce001, struct.Struct.__name__.__eq__,                       ["Struct"],  true]
    - [st946ce002, struct.error.__name__.__eq__,                        ["error"],   true]
    - [st946ce003, struct.Struct.__name__.__class__.__name__.__eq__,    ["str"],     true]
    - [st946ce004, struct.error.__name__.__class__.__name__.__eq__,     ["str"],     true]
    - [st946ce005, struct.error.__bases__.__class__.__name__.__eq__,    ["tuple"],   true]
    - [st946ce006, struct.Struct.__qualname__.__eq__,                   ["Struct"],  true]
    - [st946ce007, struct.error.__qualname__.__eq__,                    ["error"],   true]

table struct_extra946.function_names:
  description: "struct module function __name__ attributes"
  kind: python_call_eq
  category: function_names
  id_prefix: st946fn
  columns: [id, function, args, expected]
  rows:
    - [st946fn001, struct.pack.__name__.__eq__,                      ["pack"],     true]
    - [st946fn002, struct.unpack.__name__.__eq__,                    ["unpack"],   true]
    - [st946fn003, struct.calcsize.__name__.__eq__,                  ["calcsize"], true]
    - [st946fn004, struct.pack.__name__.__class__.__name__.__eq__,   ["str"],      true]
    - [st946fn005, struct.unpack.__name__.__class__.__name__.__eq__, ["str"],      true]
