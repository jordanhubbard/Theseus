spec: theseus_pyexpat_cr
version: ">=3.0"
backend: python_cleanroom(theseus_pyexpat_cr)
blocks: pyexpat

docs: https://docs.python.org/3/library/pyexpat.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pyexpat.html"
  not_derived_from:
    - "CPython source: Modules/pyexpat.c"
  notes:
    - "Clean-room pyexpat module. Do NOT import pyexpat."

error_model: python_exceptions

invariant theseus_pyexpat_cr.pyexp2_parser:
  description: "ParserCreate() creates an XML parser"
  category: behavior
  kind: python_call_eq
  function: pyexp2_parser
  args: []
  expected: true

invariant theseus_pyexpat_cr.pyexp2_version:
  description: "EXPAT_VERSION string is accessible"
  category: behavior
  kind: python_call_eq
  function: pyexp2_version
  args: []
  expected: true

invariant theseus_pyexpat_cr.pyexp2_error:
  description: "ExpatError exception class exists"
  category: behavior
  kind: python_call_eq
  function: pyexp2_error
  args: []
  expected: true
