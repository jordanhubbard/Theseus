spec: hashlib_extra324
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "This spec covers the .name attribute of hash objects returned by hashlib constructors."
    - "hashlib.md5, sha1, sha256, sha512, sha3_256, blake2b, blake2s are module-level constructor aliases."
    - "hashlib.new('md5', data) returns the same type as hashlib.md5(data); its .name is also 'md5'."
    - "These .name values are canonical algorithm names as reported by Python 3.14.3 on macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Hash object .name attribute for each constructor
# ---------------------------------------------------------------------------

invariant hashlib_extra324.md5.name:
  description: "hashlib.md5(b'test').name == 'md5' — canonical algorithm name"
  category: properties
  kind: python_call_eq
  function: md5
  args: [!ascii "test"]
  method: name.__eq__
  method_args: ["md5"]
  expected: true

invariant hashlib_extra324.sha256.name:
  description: "hashlib.sha256(b'test').name == 'sha256' — canonical algorithm name"
  category: properties
  kind: python_call_eq
  function: sha256
  args: [!ascii "test"]
  method: name.__eq__
  method_args: ["sha256"]
  expected: true

invariant hashlib_extra324.sha512.name:
  description: "hashlib.sha512(b'test').name == 'sha512' — canonical algorithm name"
  category: properties
  kind: python_call_eq
  function: sha512
  args: [!ascii "test"]
  method: name.__eq__
  method_args: ["sha512"]
  expected: true

invariant hashlib_extra324.sha3_256.name:
  description: "hashlib.sha3_256(b'test').name == 'sha3_256' — canonical algorithm name"
  category: properties
  kind: python_call_eq
  function: sha3_256
  args: [!ascii "test"]
  method: name.__eq__
  method_args: ["sha3_256"]
  expected: true

invariant hashlib_extra324.sha1.name:
  description: "hashlib.sha1(b'test').name == 'sha1' — canonical algorithm name"
  category: properties
  kind: python_call_eq
  function: sha1
  args: [!ascii "test"]
  method: name.__eq__
  method_args: ["sha1"]
  expected: true

invariant hashlib_extra324.blake2b.name:
  description: "hashlib.blake2b(b'test').name == 'blake2b' — canonical algorithm name"
  category: properties
  kind: python_call_eq
  function: blake2b
  args: [!ascii "test"]
  method: name.__eq__
  method_args: ["blake2b"]
  expected: true

invariant hashlib_extra324.blake2s.name:
  description: "hashlib.blake2s(b'test').name == 'blake2s' — canonical algorithm name"
  category: properties
  kind: python_call_eq
  function: blake2s
  args: [!ascii "test"]
  method: name.__eq__
  method_args: ["blake2s"]
  expected: true

invariant hashlib_extra324.new_md5.name:
  description: "hashlib.new('md5', b'test').name == 'md5' — new() preserves canonical algorithm name"
  category: properties
  kind: python_call_eq
  function: new
  args: ["md5", !ascii "test"]
  method: name.__eq__
  method_args: ["md5"]
  expected: true
