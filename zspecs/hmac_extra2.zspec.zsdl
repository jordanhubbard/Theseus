spec: hmac_extra2
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"
  - "FIPS 198-1 — The Keyed-Hash Message Authentication Code (HMAC)"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "FIPS 198-1 — The Keyed-Hash Message Authentication Code (HMAC), July 2008"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "OpenSSL HMAC implementation: crypto/hmac/hmac.c"
  notes:
    - "This spec extends hmac.zspec.zsdl and hmac_extra.zspec.zsdl with aspects not covered there."
    - "hmac.zspec.zsdl covers: compare_digest string table; new SHA-256/SHA-1 hexdigest; new SHA-256 digest_size/block_size/name; HMAC.__name__/__module__; new/compare_digest/digest class names; compare_digest type mismatch TypeError."
    - "hmac_extra.zspec.zsdl covers: new/digest/compare_digest __name__ table; new returns HMAC; new md5 digest_size; compare_digest bytes table; hexdigest returns str; hexdigest sha256/md5 len; HMAC.__name__/__module__."
    - "This spec adds: __module__ for new/compare_digest/digest; HMAC.__bases__[0].__name__; new(b'key', b'msg', 'sha256').digest_size/block_size; .name type check; compare_digest(b'a', b'a') and compare_digest(b'a', b'b') standalone invariants."
    - "hmac.new.__module__ == 'hmac' — new() is a Python-level function defined in Lib/hmac.py."
    - "hmac.compare_digest.__module__ == 'hmac' — compare_digest is defined/re-exported in hmac."
    - "hmac.digest.__module__ == 'hmac' — digest() is a Python 3.7+ function in Lib/hmac.py."
    - "hmac.HMAC.__bases__[0].__name__ == 'object' — HMAC inherits directly from object."
    - "hmac.new(b'key', b'msg', 'sha256').name.__class__.__name__ == 'str' — .name is always a str."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ checks — new, compare_digest, digest
#
# hmac.zspec.zsdl and hmac_extra.zspec.zsdl both cover __name__ for these
# functions; here we add the __module__ dimension — new coverage.
# ---------------------------------------------------------------------------

invariant hmac_extra2.new.module:
  description: "hmac.new.__module__ == 'hmac'"
  category: identity
  kind: python_call_eq
  function: new.__module__.__eq__
  args: ["hmac"]
  expected: true

invariant hmac_extra2.compare_digest.module:
  description: "hmac.compare_digest.__module__ == 'hmac'"
  category: identity
  kind: python_call_eq
  function: compare_digest.__module__.__eq__
  args: ["hmac"]
  expected: true

invariant hmac_extra2.digest.module:
  description: "hmac.digest.__module__ == 'hmac'"
  category: identity
  kind: python_call_eq
  function: digest.__module__.__eq__
  args: ["hmac"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ standalone invariants
#
# hmac_extra.zspec.zsdl covers these in a table; here we add standalone
# invariants for hmac_extra2 namespace completeness.
# ---------------------------------------------------------------------------

invariant hmac_extra2.new.name:
  description: "hmac.new.__name__ == 'new'"
  category: identity
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["new"]
  expected: true

invariant hmac_extra2.compare_digest.name:
  description: "hmac.compare_digest.__name__ == 'compare_digest'"
  category: identity
  kind: python_call_eq
  function: compare_digest.__name__.__eq__
  args: ["compare_digest"]
  expected: true

invariant hmac_extra2.digest.name:
  description: "hmac.digest.__name__ == 'digest'"
  category: identity
  kind: python_call_eq
  function: digest.__name__.__eq__
  args: ["digest"]
  expected: true

# ---------------------------------------------------------------------------
# HMAC class identity — __module__, __name__, and base class
#
# hmac.zspec.zsdl and hmac_extra.zspec.zsdl both cover HMAC.__name__/__module__;
# here we add HMAC.__bases__[0].__name__ — new coverage in this spec family.
# ---------------------------------------------------------------------------

invariant hmac_extra2.HMAC.module:
  description: "hmac.HMAC.__module__ == 'hmac'"
  category: class_metadata
  kind: python_call_eq
  function: HMAC.__module__.__eq__
  args: ["hmac"]
  expected: true

invariant hmac_extra2.HMAC.name:
  description: "hmac.HMAC.__name__ == 'HMAC'"
  category: class_metadata
  kind: python_call_eq
  function: HMAC.__name__.__eq__
  args: ["HMAC"]
  expected: true

invariant hmac_extra2.HMAC.base_is_object:
  description: "hmac.HMAC.__bases__[0].__name__ == 'object' — HMAC inherits directly from object"
  category: class_metadata
  kind: python_call_eq
  function: HMAC.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# hmac.new() return type — __class__.__name__ == 'HMAC'
# ---------------------------------------------------------------------------

invariant hmac_extra2.new.returns_HMAC_class:
  description: "hmac.new(b'key', b'msg', 'sha256').__class__.__name__ == 'HMAC'"
  category: return_types
  kind: python_call_eq
  function: new
  args:
    - {type: bytes_ascii, value: "key"}
    - {type: bytes_ascii, value: "msg"}
    - "sha256"
  method: __class__.__name__.__eq__
  method_args: ["HMAC"]
  expected: true

# ---------------------------------------------------------------------------
# hmac.new() properties — digest_size, block_size (SHA-256)
#
# hmac.zspec.zsdl covers these via the `method:` field (attribute access).
# Here we verify using method_args comparison for orthogonal coverage.
# ---------------------------------------------------------------------------

invariant hmac_extra2.new.sha256.digest_size:
  description: "hmac.new(b'key', b'msg', 'sha256').digest_size == 32"
  category: properties
  kind: python_call_eq
  function: new
  args:
    - {type: bytes_ascii, value: "key"}
    - {type: bytes_ascii, value: "msg"}
    - "sha256"
  method: digest_size.__eq__
  method_args: [32]
  expected: true

invariant hmac_extra2.new.sha256.block_size:
  description: "hmac.new(b'key', b'msg', 'sha256').block_size == 64"
  category: properties
  kind: python_call_eq
  function: new
  args:
    - {type: bytes_ascii, value: "key"}
    - {type: bytes_ascii, value: "msg"}
    - "sha256"
  method: block_size.__eq__
  method_args: [64]
  expected: true

# ---------------------------------------------------------------------------
# hmac.new() .name attribute — type check
#
# hmac.zspec.zsdl covers .name == 'hmac-sha256' (the value).
# Here we check that .name is a str instance — new coverage.
# ---------------------------------------------------------------------------

invariant hmac_extra2.new.name_is_str:
  description: "hmac.new(b'key', b'msg', 'sha256').name.__class__.__name__ == 'str'"
  category: return_types
  kind: python_call_eq
  function: new
  args:
    - {type: bytes_ascii, value: "key"}
    - {type: bytes_ascii, value: "msg"}
    - "sha256"
  method: name.__class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# compare_digest — bytes single-byte values
#
# hmac_extra.zspec.zsdl covers bytes equal/unequal/empty in a table.
# Here we add standalone invariants for single-byte b'a'/b'b' — new coverage.
# ---------------------------------------------------------------------------

invariant hmac_extra2.compare_digest.bytes_a_equal:
  description: "hmac.compare_digest(b'a', b'a') == True"
  category: compare_digest
  kind: python_call_eq
  function: compare_digest
  args:
    - {type: bytes_ascii, value: "a"}
    - {type: bytes_ascii, value: "a"}
  expected: true

invariant hmac_extra2.compare_digest.bytes_a_b_unequal:
  description: "hmac.compare_digest(b'a', b'b') == False"
  category: compare_digest
  kind: python_call_eq
  function: compare_digest
  args:
    - {type: bytes_ascii, value: "a"}
    - {type: bytes_ascii, value: "b"}
  expected: false
