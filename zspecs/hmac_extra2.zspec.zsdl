spec: hmac_extra2
version: ">=3.7"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "OpenSSL HMAC implementation: crypto/hmac/hmac.c"
  notes:
    - "This spec extends hmac.zspec.zsdl and hmac_extra.zspec.zsdl with additional coverage."
    - "hmac.HMAC.__name__ == 'HMAC' — class name attribute."
    - "hmac.HMAC.__module__ == 'hmac' — class lives in the hmac module."
    - "hmac.digest.__name__ == 'digest' — one-shot function name (Python 3.7+)."
    - "hmac.compare_digest.__name__ == 'compare_digest' — constant-time comparison function name."
    - "hmac.new.__name__ == 'new' — factory function name."
    - "hmac.new(b'key', b'msg', 'sha256').__class__.__name__ == 'HMAC' — factory returns HMAC instance."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HMAC class metadata
# ---------------------------------------------------------------------------

table hmac_extra2.class_metadata:
  kind: python_call_eq
  category: class_metadata
  id_prefix: meta

  columns: [id, description, function, args, expected]
  rows:
    - [HMAC_name,   "HMAC.__name__ == 'HMAC'",   HMAC.__name__.__eq__,   ["HMAC"],  true]
    - [HMAC_module, "HMAC.__module__ == 'hmac'",  HMAC.__module__.__eq__, ["hmac"],  true]

# ---------------------------------------------------------------------------
# Function __name__ attributes
# ---------------------------------------------------------------------------

table hmac_extra2.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, description, function, args, expected]
  rows:
    - [digest,          "digest.__name__ == 'digest'",                   digest.__name__.__eq__,          ["digest"],          true]
    - [compare_digest,  "compare_digest.__name__ == 'compare_digest'",   compare_digest.__name__.__eq__,  ["compare_digest"],  true]
    - [new,             "new.__name__ == 'new'",                         new.__name__.__eq__,             ["new"],             true]

# ---------------------------------------------------------------------------
# hmac.new() — return type is an HMAC instance
# ---------------------------------------------------------------------------

invariant hmac_extra2.new_returns_HMAC:
  description: "new(b'key', b'msg', 'sha256').__class__.__name__ == 'HMAC'"
  category: return_types
  kind: python_call_eq
  function: new
  args:
    - {type: bytes_ascii, value: "key"}
    - {type: bytes_ascii, value: "msg"}
    - "sha256"
  method: __class__.__name__.__eq__
  method_args: ["HMAC"]
  expected: true
