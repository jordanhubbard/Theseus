spec: multiprocessing_extra11
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "This spec extends multiprocessing.zspec.zsdl and prior extras through multiprocessing_extra10.zspec.zsdl."
    - "multiprocessing_extra10 covers: Process lifecycle method __qualname__ (start/run/join/terminate/kill/is_alive/close via BaseProcess)."
    - "multiprocessing_extra9 covers: BufferTooShort/__qualname__/__module__/__bases__[0]; RLock/__qualname__; Process.__mro__[1].__name__ == 'BaseProcess'; Process.__mro__[2].__name__ == 'object'."
    - "multiprocessing_extra8 covers: __bases__[0].__name__ for Process/ProcessError/AuthenticationError/TimeoutError; MRO[1] for ProcessError/AuthenticationError/TimeoutError."
    - "multiprocessing_extra7 covers: __module__ for Pool/Process/Lock/Event/Semaphore/Queue."
    - "multiprocessing_extra5 covers: __qualname__ for Process/Pool/Manager/Pipe/Lock/Value/Array/AuthenticationError/ProcessError/TimeoutError."
    - "multiprocessing_extra covers: Pool.__name__/__class__.__name__=='type'; Manager is a function; factory __name__ table."
    - "NOT yet covered in any prior spec: Pool method __qualname__ for apply/map/close/terminate/join."
    - "NOT yet covered: Pool.__mro__[1].__name__ == 'object' — MRO access path for Pool."
    - "NOT yet covered: Pool.__bases__[0].__name__ == 'object' — Pool inherits directly from object."
    - "NOT yet covered: BaseManager.__name__ == 'BaseManager' — class name check."
    - "NOT yet covered: BaseManager.__qualname__ == 'BaseManager'."
    - "NOT yet covered: BaseManager.__module__ == 'multiprocessing.managers'."
    - "NOT yet covered: BaseManager.__bases__[0].__name__ == 'object'."
    - "NOT yet covered: SyncManager.__name__ == 'SyncManager' — class name check."
    - "NOT yet covered: SyncManager.__bases__[0].__name__ == 'BaseManager' — SyncManager inherits from BaseManager."
    - "NOT yet covered: SyncManager.__module__ == 'multiprocessing.managers'."
    - "multiprocessing.pool.Pool is accessed as multiprocessing.Pool in the backend namespace."
    - "multiprocessing.Pool.__mro__[1].__name__ == 'object' — Pool inherits directly from object; MRO is [Pool, object]."
    - "multiprocessing.Pool.apply.__qualname__ == 'Pool.apply' — method defined on Pool."
    - "multiprocessing.Pool.map.__qualname__ == 'Pool.map'."
    - "multiprocessing.Pool.close.__qualname__ == 'Pool.close'."
    - "multiprocessing.Pool.terminate.__qualname__ == 'Pool.terminate'."
    - "multiprocessing.Pool.join.__qualname__ == 'Pool.join'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pool MRO — index-based access
#
# multiprocessing_extra covers Pool.__class__.__name__ == 'type'. No prior
# spec uses the __mro__ access path for Pool. Pool inherits directly from
# object (MRO is [Pool, object]), so __mro__[1] is object.
# multiprocessing_extra covers Pool.__bases__ indirectly. This spec adds
# the orthogonal __mro__[1] access path and __bases__[0] as a standalone.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra11.Pool.mro_index1:
  description: "multiprocessing.Pool.__mro__[1].__name__ == 'object' — Pool inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Pool.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

invariant multiprocessing_extra11.Pool.base:
  description: "multiprocessing.Pool.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: Pool.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Pool method __qualname__ checks
#
# No prior multiprocessing spec checks __qualname__ for any Pool method.
# Pool methods are defined in Lib/multiprocessing/pool.py on the Pool class
# itself, so their __qualname__ is 'Pool.<method>'.
# ---------------------------------------------------------------------------

table multiprocessing_extra11.Pool_method_qualnames:
  description: "multiprocessing.Pool methods have __qualname__ == 'Pool.<method>'"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: poolmqname

  columns: [id, function, args, expected]
  rows:
    - [apply,     Pool.apply.__qualname__.__eq__,     ["Pool.apply"],     true]
    - [map,       Pool.map.__qualname__.__eq__,       ["Pool.map"],       true]
    - [close,     Pool.close.__qualname__.__eq__,     ["Pool.close"],     true]
    - [terminate, Pool.terminate.__qualname__.__eq__, ["Pool.terminate"], true]
    - [join,      Pool.join.__qualname__.__eq__,      ["Pool.join"],      true]

# ---------------------------------------------------------------------------
# BaseManager class identity checks
#
# multiprocessing.managers.BaseManager is the base class for all manager
# types. No prior multiprocessing spec checks __name__, __qualname__,
# __module__, or __bases__ for BaseManager. It lives in the backend namespace
# via multiprocessing.managers.BaseManager.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra11.BaseManager.name:
  description: "multiprocessing.managers.BaseManager.__name__ == 'BaseManager'"
  category: class_names
  kind: python_call_eq
  function: managers.BaseManager.__name__.__eq__
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra11.BaseManager.qualname:
  description: "multiprocessing.managers.BaseManager.__qualname__ == 'BaseManager'"
  category: class_names
  kind: python_call_eq
  function: managers.BaseManager.__qualname__.__eq__
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra11.BaseManager.module:
  description: "multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers'"
  category: class_modules
  kind: python_call_eq
  function: managers.BaseManager.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true

invariant multiprocessing_extra11.BaseManager.base:
  description: "multiprocessing.managers.BaseManager.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: managers.BaseManager.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# SyncManager class identity checks
#
# multiprocessing_extra5 covers multiprocessing.Manager.__qualname__ == 'Manager'
# (the top-level binding). No prior spec checks the underlying SyncManager
# class attributes directly via managers.SyncManager. SyncManager inherits
# from BaseManager, so its __bases__[0] is BaseManager.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra11.SyncManager.name:
  description: "multiprocessing.managers.SyncManager.__name__ == 'SyncManager'"
  category: class_names
  kind: python_call_eq
  function: managers.SyncManager.__name__.__eq__
  args: ["SyncManager"]
  expected: true

invariant multiprocessing_extra11.SyncManager.module:
  description: "multiprocessing.managers.SyncManager.__module__ == 'multiprocessing.managers'"
  category: class_modules
  kind: python_call_eq
  function: managers.SyncManager.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true

invariant multiprocessing_extra11.SyncManager.base:
  description: "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager'"
  category: class_hierarchy
  kind: python_call_eq
  function: managers.SyncManager.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseManager"
