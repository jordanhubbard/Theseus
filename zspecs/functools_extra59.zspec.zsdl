spec: functools_extra59
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra58.zspec.zsdl."
    - "Prior specs covered __dict__.__class__.__name__.__len__()==12 for partial/partialmethod/singledispatchmethod/cached_property (extra36) and TopologicalSorter.__dict__.__class__.__name__.__eq__('mappingproxy') (extra19). No prior spec records __dict__.__class__.__name__.__eq__('mappingproxy') for partial/partialmethod/singledispatchmethod/cached_property as explicit rows."
    - "Prior specs covered reduce.__module__.__eq__('_functools') (extra12/extra13/extra19); reduce.__module__.__len__()==10 (extra13/extra20/extra34/extra36); reduce.__module__.__class__.__name__=='str' (extra58 covers cmp_to_key; extra59 covers reduce). No prior spec records reduce.__module__.__class__.__name__.__eq__('str') or reduce.__module__.__class__.__qualname__.__eq__('str') for reduce."
    - "Prior specs covered partialmethod.__doc__.__class__.__name__.__len__()==3 (extra36 notes); no prior spec records partialmethod.__doc__.__class__.__name__.__eq__('str') as an explicit row. singledispatch.__doc__.__class__.__name__.__eq__('str') was covered in extra55. No prior spec records partialmethod.__doc__.__class__.__name__.__eq__('str') as an explicit invariant row."
    - "This spec covers: functools.partial.__dict__.__class__.__name__.__eq__('mappingproxy')==true; functools.partialmethod.__dict__.__class__.__name__.__eq__('mappingproxy')==true; functools.singledispatchmethod.__dict__.__class__.__name__.__eq__('mappingproxy')==true; functools.cached_property.__dict__.__class__.__name__.__eq__('mappingproxy')==true; functools.reduce.__module__.__class__.__name__.__eq__('str')==true; functools.reduce.__module__.__class__.__qualname__.__eq__('str')==true; functools.partialmethod.__doc__.__class__.__name__.__eq__('str')==true."
    - "Key findings: Python class __dict__ is always a mappingproxy object (the type's namespace exposed as a read-only mapping). Its type is builtins.mappingproxy, whose __name__ is 'mappingproxy' (12 chars) and __qualname__ is also 'mappingproxy'. Prior specs only recorded the length (12) for partial/partialmethod/singledispatchmethod/cached_property, not the string equality invariant. functools.reduce is a C-extension function in Modules/_functoolsmodule.c; its __module__ is '_functools' (a Python str object, 10 chars), so reduce.__module__.__class__.__name__ == 'str'. extra58 established this pattern for cmp_to_key but not reduce. functools.partialmethod is a pure-Python class in Lib/functools.py; its __doc__ is a Python string literal, so __doc__.__class__.__name__ == 'str'. All seven invariants are new to extra59."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools class __dict__.__class__.__name__ == 'mappingproxy' — extra59
#
# Every Python class object exposes its namespace via __dict__, which is a
# mappingproxy (a read-only view of the underlying dict). The type of this
# mappingproxy is builtins.mappingproxy, whose __name__ == 'mappingproxy'
# (12 chars). Prior specs recorded __dict__.__class__.__name__.__len__()==12
# for partial/partialmethod/singledispatchmethod/cached_property in extra36
# (and TopologicalSorter.__dict__.__class__.__name__.__eq__('mappingproxy') in
# extra19), but no prior spec records the string equality form for
# partial/partialmethod/singledispatchmethod/cached_property as explicit rows.
# All four checks below are new to extra59.
# ---------------------------------------------------------------------------

table functools_extra59.class_dict_class_name_eq:
  description: "functools class __dict__.__class__.__name__ == 'mappingproxy' — every Python class __dict__ is a mappingproxy; __class__.__name__ == 'mappingproxy' (12 chars); extra36 covered __len__()==12 for these four classes but not the string equality form; new to extra59"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsmod59

  columns: [id, function, args, expected, description]
  rows:
    - [partial_dict_class_name,
       partial.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "functools.partial.__dict__.__class__.__name__ == 'mappingproxy' — partial is a C-extension class in Modules/_functoolsmodule.c; its __dict__ is a mappingproxy (Python's read-only class namespace wrapper); mappingproxy.__name__ == 'mappingproxy' (12 chars); prior extra36 confirmed partial.__dict__.__class__.__name__.__len__()==12 but did not record the string equality; this is the first explicit __dict__.__class__.__name__.__eq__('mappingproxy') row for partial; new to extra59"]
    - [partialmethod_dict_class_name,
       partialmethod.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "functools.partialmethod.__dict__.__class__.__name__ == 'mappingproxy' — partialmethod is a pure-Python class in Lib/functools.py (added in Python 3.4) that creates a partial-like descriptor for use as a method; its __dict__ is a mappingproxy; mappingproxy.__name__ == 'mappingproxy' (12 chars); prior extra36 confirmed partialmethod.__dict__.__class__.__name__.__len__()==12 but did not record the string equality; this is the first explicit __dict__.__class__.__name__.__eq__('mappingproxy') row for partialmethod; new to extra59"]
    - [singledispatchmethod_dict_class_name,
       singledispatchmethod.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "functools.singledispatchmethod.__dict__.__class__.__name__ == 'mappingproxy' — singledispatchmethod is a pure-Python class in Lib/functools.py (added in Python 3.8) that enables single-dispatch generic methods; its __dict__ is a mappingproxy; mappingproxy.__name__ == 'mappingproxy' (12 chars); prior extra36 confirmed singledispatchmethod.__dict__.__class__.__name__.__len__()==12 but did not record the string equality; this is the first explicit __dict__.__class__.__name__.__eq__('mappingproxy') row for singledispatchmethod; new to extra59"]
    - [cached_property_dict_class_name,
       cached_property.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "functools.cached_property.__dict__.__class__.__name__ == 'mappingproxy' — cached_property is a pure-Python class in Lib/functools.py (added in Python 3.8) that transforms a method into a lazily-evaluated property cached on the instance; its __dict__ is a mappingproxy; mappingproxy.__name__ == 'mappingproxy' (12 chars); prior extra36 confirmed cached_property.__dict__.__class__.__name__.__len__()==12 but did not record the string equality; this is the first explicit __dict__.__class__.__name__.__eq__('mappingproxy') row for cached_property; new to extra59"]

# ---------------------------------------------------------------------------
# functools.reduce __module__.__class__.__name__ and __qualname__ — extra59
#
# functools.reduce is a C-extension builtin_function_or_method implemented in
# Modules/_functoolsmodule.c. Its __module__ attribute is the Python string
# '_functools' (10 chars). Since this is a Python str object, its __class__ is
# the str built-in type. str.__name__ == 'str' (3 chars) and str.__qualname__
# == 'str' (3 chars; str is a top-level type with no enclosing class scope).
# Prior extra58 established __module__.__class__.__name__.__eq__('str') for
# cmp_to_key (also a _functools C-extension function) but not for reduce. This
# is the first __module__.__class__.__name__/__qualname__ check for reduce.
# ---------------------------------------------------------------------------

table functools_extra59.reduce_module_class_attrs:
  description: "functools.reduce __module__.__class__.__name__/__qualname__ == 'str' — reduce is a C-extension function; __module__ is '_functools' (Python str, 10 chars); str.__name__==str.__qualname__=='str'; extra58 covered cmp_to_key but not reduce; new to extra59"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsmod59

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_module_class_name,
       reduce.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.reduce.__module__.__class__.__name__ == 'str' — reduce is a C-extension function in Modules/_functoolsmodule.c that applies a function cumulatively to items of a sequence; __module__ is the Python string '_functools' (10 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra12/extra13/extra19 confirmed reduce.__module__.__eq__('_functools'); extra58 established __module__.__class__.__name__.__eq__('str') for cmp_to_key but not reduce; this is the first __module__.__class__.__name__ check for reduce; new to extra59"]
    - [reduce_module_class_qualname,
       reduce.__module__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "functools.reduce.__module__.__class__.__qualname__ == 'str' — reduce.__module__ is a Python str object ('_functools', 10 chars); the str built-in type is a top-level type with __qualname__ == __name__ == 'str' (3 chars; no enclosing class scope); consistent with extra59's reduce.__module__.__class__.__name__.__eq__('str'); no prior functools spec records __module__.__class__.__qualname__ for reduce; new to extra59"]

# ---------------------------------------------------------------------------
# functools.partialmethod __doc__.__class__.__name__ == 'str' — extra59
#
# functools.partialmethod is a pure-Python class in Lib/functools.py. Its
# __doc__ is a Python string literal (the class docstring). Since __doc__ is a
# Python str object, __doc__.__class__.__name__ == 'str' (3 chars). Prior specs
# recorded partial.__doc__.__class__.__name__.__len__()==3 (extra36 notes) and
# singledispatch.__doc__.__class__.__name__.__eq__('str') in extra55, but no
# prior spec records partialmethod.__doc__.__class__.__name__.__eq__('str') as
# an explicit invariant row. This is new to extra59.
# ---------------------------------------------------------------------------

table functools_extra59.partialmethod_doc_class_name:
  description: "functools.partialmethod.__doc__.__class__.__name__ == 'str' — partialmethod is a pure-Python class; its docstring is a Python str object; str.__name__ == 'str' (3 chars); no prior spec records this as an explicit invariant row; new to extra59"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsmod59

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_doc_class_name,
       partialmethod.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partialmethod.__doc__.__class__.__name__ == 'str' — partialmethod is a pure-Python class in Lib/functools.py (descriptor for partial-function methods; added Python 3.4); its __doc__ is defined as a string literal in the class body, making it a Python str object; Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra36 noted partial.__doc__.__class__.__name__.__len__()==3 and extra55 covered singledispatch.__doc__.__class__.__name__.__eq__('str'), but no prior spec records partialmethod.__doc__.__class__.__name__.__eq__('str') as an explicit row; new to extra59"]
