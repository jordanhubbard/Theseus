spec: threading_extra225
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading Thread.__init__, Semaphore.__init__, Event.__init__, Barrier.__init__, and Timer.__init__ code attribute contracts."
    - "threading.Thread.__init__.__code__.co_argcount == 6 (self, group, target, name, args, kwargs). Verified with Python 3.14.3."
    - "threading.Thread.__init__.__code__.co_kwonlyargcount == 2 (daemon, context are keyword-only). Verified with Python 3.14.3."
    - "threading.Thread.__init__.__code__.co_name == '__init__'. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__qualname__ == 'Thread.__init__'. Verified with Python 3.14.3."
    - "threading.Semaphore.__init__.__code__.co_argcount == 2 (self, value). Verified with Python 3.14.3."
    - "threading.Semaphore.__init__.__code__.co_name == '__init__'. Verified with Python 3.14.3."
    - "threading.Event.__init__.__code__.co_argcount == 1 (self only). Verified with Python 3.14.3."
    - "threading.Barrier.__init__.__code__.co_argcount == 4 (self, parties, action, timeout). Verified with Python 3.14.3."
    - "threading.Barrier.__init__.__code__.co_name == '__init__'. Verified with Python 3.14.3."
    - "threading.Timer.__init__.__code__.co_argcount == 5 (self, interval, function, args, kwargs). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading Thread.__init__ code attribute checks
#
# Verified with Python 3.14.3:
#   threading.Thread.__init__.__code__.co_argcount == 6
#       (self, group, target, name, args, kwargs)
#   threading.Thread.__init__.__code__.co_kwonlyargcount == 2
#       (daemon and context are keyword-only)
#   threading.Thread.__init__.__code__.co_name == '__init__'
#   threading.Thread.__init__.__qualname__ == 'Thread.__init__'
# ---------------------------------------------------------------------------

table threading_extra225.thread_init_code_attrs:
  description: "threading.Thread.__init__ code attribute checks; new to extra225"
  kind: python_call_eq
  category: code_inspection
  id_prefix: threadingextra225threadinit

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_co_argcount_eq,
       "Thread.__init__.__code__.co_argcount.__eq__",
       [6],
       true,
       "threading.Thread.__init__.__code__.co_argcount.__eq__(6) == True — Thread.__init__(self, group, target, name, args, kwargs) has 6 positional params; co_argcount is 6; int.__eq__(6) returns True; new to extra225"]
    - [thread_init_co_kwonlyargcount_eq,
       "Thread.__init__.__code__.co_kwonlyargcount.__eq__",
       [2],
       true,
       "threading.Thread.__init__.__code__.co_kwonlyargcount.__eq__(2) == True — daemon and context are keyword-only params in Thread.__init__; co_kwonlyargcount is 2; int.__eq__(2) returns True; new to extra225"]
    - [thread_init_co_name_eq,
       "Thread.__init__.__code__.co_name.__eq__",
       ["__init__"],
       true,
       "threading.Thread.__init__.__code__.co_name.__eq__('__init__') == True — co_name is the code object's function name; str.__eq__('__init__') returns True; new to extra225"]
    - [thread_init_qualname_eq,
       "Thread.__init__.__qualname__.__eq__",
       ["Thread.__init__"],
       true,
       "threading.Thread.__init__.__qualname__.__eq__('Thread.__init__') == True — qualname includes the owning class Thread; str.__eq__('Thread.__init__') returns True; new to extra225"]
    - [thread_init_co_argcount_class_name_eq,
       "Thread.__init__.__code__.co_argcount.__class__.__name__.__eq__",
       ["int"],
       true,
       "threading.Thread.__init__.__code__.co_argcount.__class__.__name__.__eq__('int') == True — co_argcount is an int; str.__eq__('int') returns True; new to extra225"]

# ---------------------------------------------------------------------------
# Table 2: threading Semaphore, Event, Barrier, Timer __init__ code checks
#
# Verified with Python 3.14.3:
#   threading.Semaphore.__init__.__code__.co_argcount == 2  (self, value)
#   threading.Event.__init__.__code__.co_argcount == 1      (self)
#   threading.Barrier.__init__.__code__.co_argcount == 4    (self, parties, action, timeout)
#   threading.Timer.__init__.__code__.co_argcount == 5      (self, interval, function, args, kwargs)
# ---------------------------------------------------------------------------

table threading_extra225.sync_init_co_argcount:
  description: "threading Semaphore, Event, Barrier, Timer __init__ co_argcount checks; new to extra225"
  kind: python_call_eq
  category: code_inspection
  id_prefix: threadingextra225syncinit

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_init_co_argcount_eq,
       "Semaphore.__init__.__code__.co_argcount.__eq__",
       [2],
       true,
       "threading.Semaphore.__init__.__code__.co_argcount.__eq__(2) == True — Semaphore.__init__(self, value=1) has 2 positional params; co_argcount is 2; int.__eq__(2) returns True; new to extra225"]
    - [semaphore_init_co_name_eq,
       "Semaphore.__init__.__code__.co_name.__eq__",
       ["__init__"],
       true,
       "threading.Semaphore.__init__.__code__.co_name.__eq__('__init__') == True — co_name is the code object's function name; str.__eq__('__init__') returns True; new to extra225"]
    - [event_init_co_argcount_eq,
       "Event.__init__.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Event.__init__.__code__.co_argcount.__eq__(1) == True — Event.__init__(self) takes only self; co_argcount is 1; int.__eq__(1) returns True; new to extra225"]
    - [barrier_init_co_argcount_eq,
       "Barrier.__init__.__code__.co_argcount.__eq__",
       [4],
       true,
       "threading.Barrier.__init__.__code__.co_argcount.__eq__(4) == True — Barrier.__init__(self, parties, action, timeout) has 4 positional params; co_argcount is 4; int.__eq__(4) returns True; new to extra225"]
    - [barrier_init_co_name_eq,
       "Barrier.__init__.__code__.co_name.__eq__",
       ["__init__"],
       true,
       "threading.Barrier.__init__.__code__.co_name.__eq__('__init__') == True — co_name is the code object's function name; str.__eq__('__init__') returns True; new to extra225"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra225
# ---------------------------------------------------------------------------

invariant threading_extra225.Thread_init_co_argcount:
  description: "threading.Thread.__init__.__code__.co_argcount == 6 — Thread.__init__ takes self, group, target, name, args, kwargs; new to extra225"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_argcount.__eq__
  args: [6]
  expected: true

invariant threading_extra225.Thread_init_co_kwonlyargcount:
  description: "threading.Thread.__init__.__code__.co_kwonlyargcount == 2 — daemon and context are keyword-only; new to extra225"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_kwonlyargcount.__eq__
  args: [2]
  expected: true

invariant threading_extra225.Thread_init_co_name:
  description: "threading.Thread.__init__.__code__.co_name == '__init__' — co_name is __init__; new to extra225"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

invariant threading_extra225.Thread_init_qualname:
  description: "threading.Thread.__init__.__qualname__ == 'Thread.__init__' — qualname includes the class; new to extra225"
  kind: python_call_eq
  function: Thread.__init__.__qualname__.__eq__
  args: ["Thread.__init__"]
  expected: true

invariant threading_extra225.Semaphore_init_co_argcount:
  description: "threading.Semaphore.__init__.__code__.co_argcount == 2 — Semaphore.__init__ takes self and value; new to extra225"
  kind: python_call_eq
  function: Semaphore.__init__.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant threading_extra225.Semaphore_init_co_name:
  description: "threading.Semaphore.__init__.__code__.co_name == '__init__' — co_name is __init__; new to extra225"
  kind: python_call_eq
  function: Semaphore.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

invariant threading_extra225.Event_init_co_argcount:
  description: "threading.Event.__init__.__code__.co_argcount == 1 — Event.__init__ takes only self; new to extra225"
  kind: python_call_eq
  function: Event.__init__.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant threading_extra225.Barrier_init_co_argcount:
  description: "threading.Barrier.__init__.__code__.co_argcount == 4 — Barrier.__init__ takes self, parties, action, timeout; new to extra225"
  kind: python_call_eq
  function: Barrier.__init__.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant threading_extra225.Barrier_init_co_name:
  description: "threading.Barrier.__init__.__code__.co_name == '__init__' — co_name is __init__; new to extra225"
  kind: python_call_eq
  function: Barrier.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

invariant threading_extra225.Timer_init_co_argcount:
  description: "threading.Timer.__init__.__code__.co_argcount == 5 — Timer.__init__ takes self, interval, function, args, kwargs; new to extra225"
  kind: python_call_eq
  function: Timer.__init__.__code__.co_argcount.__eq__
  args: [5]
  expected: true
