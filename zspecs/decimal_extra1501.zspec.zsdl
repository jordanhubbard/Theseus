spec: decimal_extra1501
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module Decimal, Context, DecimalException, InvalidOperation documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "IBM General Decimal Arithmetic specification"
  notes:
    - "Wave 547 (_extra1501): async protocol method __dict__ presence checks for decimal module classes."
    - "All decimal classes are synchronous only. None define __await__, __aiter__, __anext__, __aenter__, or __aexit__ in their own __dict__."
    - "decimal.Decimal is an arbitrary-precision decimal number type; its __dict__ defines arithmetic operators (__add__, __mul__, __sub__, __neg__, __str__, __repr__) and numeric conversion methods but no async protocol dunders."
    - "decimal.Context stores arithmetic settings (precision, rounding mode, exponent limits); its __dict__ defines prec, rounding, Emax, Emin, clamp, and arithmetic methods but no async protocol dunders."
    - "decimal.DecimalException is the base exception class for all decimal exceptions; its minimal __dict__ (module, weakref, doc) contains no async protocol dunders."
    - "decimal.InvalidOperation is the exception raised for invalid operations; its minimal __dict__ (module, doc) contains no async protocol dunders."
    - "Decimal arithmetic is CPU-bound and synchronous; there is no async decimal arithmetic protocol in the standard library."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1501.decimal_class_async_protocol:
  description: "decimal.Decimal async protocol absence — __await__, __aiter__, __anext__, __aenter__, __aexit__ are all absent from decimal.Decimal.__dict__; positive anchors show arithmetic operators that ARE defined; wave 547; new to extra1501"
  kind: python_call_eq
  category: async_protocol
  id_prefix: dc1501dc
  columns: [id, function, args, expected, description]
  rows:
    - [dc1501dc001,
       decimal.Decimal.__dict__.__contains__,
       ["__await__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__await__') == False — decimal.Decimal is an arbitrary-precision decimal number type; it does not implement the awaitable protocol; Decimal arithmetic is synchronous and CPU-bound; __await__ is absent from Decimal.__dict__; verified with Python 3.12"]
    - [dc1501dc002,
       decimal.Decimal.__dict__.__contains__,
       ["__aiter__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__aiter__') == False — decimal.Decimal does not implement the async iterator protocol; __aiter__ is absent; Decimal is a scalar numeric type, not an iterable; verified with Python 3.12"]
    - [dc1501dc003,
       decimal.Decimal.__dict__.__contains__,
       ["__anext__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__anext__') == False — decimal.Decimal does not implement __anext__; async iteration is not part of the Decimal numeric type design; verified with Python 3.12"]
    - [dc1501dc004,
       decimal.Decimal.__dict__.__contains__,
       ["__aenter__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__aenter__') == False — decimal.Decimal does not implement the async context manager protocol; __aenter__ is absent; Decimal instances are immutable values and not resource managers; verified with Python 3.12"]
    - [dc1501dc005,
       decimal.Decimal.__dict__.__contains__,
       ["__aexit__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__aexit__') == False — decimal.Decimal does not implement __aexit__; all five async protocol dunders are absent from Decimal.__dict__; verified with Python 3.12"]
    - [dc1501dc006,
       decimal.Decimal.__dict__.__contains__,
       ["__add__"],
       true,
       "decimal.Decimal.__dict__.__contains__('__add__') == True — positive anchor: decimal.Decimal defines '__add__' in its own __dict__; arithmetic operators are defined while all five async protocol dunders are absent; verified with Python 3.12"]
    - [dc1501dc007,
       decimal.Decimal.__dict__.__contains__,
       ["__mul__"],
       true,
       "decimal.Decimal.__dict__.__contains__('__mul__') == True — positive anchor: decimal.Decimal defines '__mul__' in its own __dict__; multiplication is a core numeric operation implemented synchronously; there is no async arithmetic protocol on Decimal; verified with Python 3.12"]
    - [dc1501dc008,
       decimal.Decimal.__dict__.__contains__,
       ["__neg__"],
       true,
       "decimal.Decimal.__dict__.__contains__('__neg__') == True — positive anchor: decimal.Decimal defines '__neg__' (unary negation) in its own __dict__; unary arithmetic is defined while all five async protocol dunders (__await__, __aiter__, __anext__, __aenter__, __aexit__) are absent; verified with Python 3.12"]

table decimal_extra1501.context_class_async_protocol:
  description: "decimal.Context async protocol absence — __await__, __aiter__, __anext__, __aenter__, __aexit__ are all absent from decimal.Context.__dict__; Context stores arithmetic settings but implements no async protocol; positive anchors show settings attributes that ARE defined; wave 547; new to extra1501"
  kind: python_call_eq
  category: async_protocol
  id_prefix: dc1501cx
  columns: [id, function, args, expected, description]
  rows:
    - [dc1501cx001,
       decimal.Context.__dict__.__contains__,
       ["__await__"],
       false,
       "decimal.Context.__dict__.__contains__('__await__') == False — decimal.Context stores arithmetic settings (precision, rounding mode, traps); it does not implement the awaitable protocol; __await__ is absent from Context.__dict__; verified with Python 3.12"]
    - [dc1501cx002,
       decimal.Context.__dict__.__contains__,
       ["__aiter__"],
       false,
       "decimal.Context.__dict__.__contains__('__aiter__') == False — decimal.Context does not implement __aiter__; Context is a settings object, not an async sequence; verified with Python 3.12"]
    - [dc1501cx003,
       decimal.Context.__dict__.__contains__,
       ["__aenter__"],
       false,
       "decimal.Context.__dict__.__contains__('__aenter__') == False — decimal.Context does not implement the async context manager protocol; __aenter__ is absent; even though Context is closely associated with context management via decimal.localcontext(), the Context class itself implements neither the sync nor async context manager protocol; verified with Python 3.12"]
    - [dc1501cx004,
       decimal.Context.__dict__.__contains__,
       ["__aexit__"],
       false,
       "decimal.Context.__dict__.__contains__('__aexit__') == False — decimal.Context does not implement __aexit__; all five async protocol dunders are absent from Context.__dict__; the ContextManager class (returned by localcontext()) handles the sync context protocol, and no async variant exists; verified with Python 3.12"]
    - [dc1501cx005,
       decimal.Context.__dict__.__contains__,
       ["prec"],
       true,
       "decimal.Context.__dict__.__contains__('prec') == True — positive anchor: decimal.Context defines 'prec' (precision) in its own __dict__; arithmetic configuration attributes are present while all five async protocol dunders are absent; verified with Python 3.12"]
    - [dc1501cx006,
       decimal.Context.__dict__.__contains__,
       ["rounding"],
       true,
       "decimal.Context.__dict__.__contains__('rounding') == True — positive anchor: decimal.Context defines 'rounding' (rounding mode) in its own __dict__; rounding configuration is a core Context attribute while __await__, __aiter__, __anext__, __aenter__, __aexit__ are all absent; verified with Python 3.12"]
    - [dc1501cx007,
       decimal.Context.__dict__.__contains__,
       ["Emax"],
       true,
       "decimal.Context.__dict__.__contains__('Emax') == True — positive anchor: decimal.Context defines 'Emax' (maximum exponent) in its own __dict__; exponent limit attributes are synchronous settings with no async equivalent; verified with Python 3.12"]

