spec: theseus_compileall_cr
version: ">=3.8"
backend: python_cleanroom(theseus_compileall_cr)
blocks: compileall

docs: https://docs.python.org/3/library/compileall.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/compileall.html"
  not_derived_from:
    - "CPython source: Lib/compileall.py"
  notes:
    - "Clean-room compileall module. Do NOT import compileall."

error_model: python_exceptions

invariant theseus_compileall_cr.compileall2_compile_file:
  description: "compile_file() compiles a .py file to .pyc"
  category: behavior
  kind: python_call_eq
  function: compileall2_compile_file
  args: []
  expected: true

invariant theseus_compileall_cr.compileall2_compile_dir:
  description: "compile_dir() returns True for a valid directory"
  category: behavior
  kind: python_call_eq
  function: compileall2_compile_dir
  args: []
  expected: true

invariant theseus_compileall_cr.compileall2_compile_path:
  description: "compile_path() succeeds on an empty sys.path-like list"
  category: behavior
  kind: python_call_eq
  function: compileall2_compile_path
  args: []
  expected: true
