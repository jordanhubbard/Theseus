spec: io3301
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 667 (io3301): __itruediv__, __ifloordiv__, __imod__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "Theme: __itruediv__, __ifloordiv__, __imod__ dict-presence (in-place /=, //=, %=)."
    - "No io class defines __itruediv__ in its own __dict__: stream I/O classes are sequential I/O abstractions, not numeric types, and do not implement in-place true division."
    - "No io class defines __ifloordiv__ in its own __dict__: stream I/O classes do not implement in-place floor division; arithmetic is not part of the stream I/O protocol."
    - "No io class defines __imod__ in its own __dict__: stream I/O classes do not implement in-place modulo; augmented assignment operators have no meaning for I/O streams."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __itruediv__ dict-presence — operator.contains(Cls.__dict__, '__itruediv__')
#
# No io class defines __itruediv__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions, not numeric types,
# and do not implement the in-place true division operator (/=).
# ---------------------------------------------------------------------------

table io3301.itruediv:
  description: "io types __itruediv__ dict-presence checks; wave 667"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: io3301

  columns: [id, function, args, expected]
  rows:
    - ["io3301001", operator.contains, [io.RawIOBase.__dict__,       "__itruediv__"], false]
    - ["io3301002", operator.contains, [io.BufferedIOBase.__dict__,  "__itruediv__"], false]
    - ["io3301003", operator.contains, [io.TextIOBase.__dict__,      "__itruediv__"], false]
    - ["io3301004", operator.contains, [io.FileIO.__dict__,          "__itruediv__"], false]
    - ["io3301005", operator.contains, [io.BytesIO.__dict__,         "__itruediv__"], false]
