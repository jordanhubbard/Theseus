spec: multiprocessing_extra145
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py, Lib/multiprocessing/queues.py, Lib/multiprocessing/process.py, Lib/multiprocessing/synchronize.py, Lib/multiprocessing/managers.py"
  notes:
    - "This spec covers multiprocessing submodule __name__ attributes. multiprocessing.pool.__name__=='multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20). multiprocessing.queues.__name__=='multiprocessing.queues' (len=22: 'multiprocessing'=15+'.'=1+'queues'=6=22). multiprocessing.process.__name__=='multiprocessing.process' (len=23: 'multiprocessing'=15+'.'=1+'process'=7=23). multiprocessing.synchronize.__name__=='multiprocessing.synchronize' (len=27: 'multiprocessing'=15+'.'=1+'synchronize'=11=27; the longest submodule name in this spec). multiprocessing.managers.__name__=='multiprocessing.managers' (len=24: 'multiprocessing'=15+'.'=1+'managers'=8=24). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.synchronize is the longest submodule name (len=27). multiprocessing.pool is the shortest (len=20). multiprocessing.queues and multiprocessing.process were already covered as module-hosted classes in extra143 and extra144 — this spec focuses on the module-level __name__ attributes rather than class contents. All __spec__.name values equal the corresponding __name__ values. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing submodule __name__ attributes — extra145
#
# multiprocessing.pool.__name__         == 'multiprocessing.pool'         (len=20)
# multiprocessing.queues.__name__       == 'multiprocessing.queues'       (len=22)
# multiprocessing.process.__name__      == 'multiprocessing.process'      (len=23)
# multiprocessing.synchronize.__name__  == 'multiprocessing.synchronize'  (len=27)
# multiprocessing.managers.__name__     == 'multiprocessing.managers'     (len=24)
# ---------------------------------------------------------------------------

table multiprocessing_extra145.submodule_names_pool_queues_process:
  description: "multiprocessing.pool, queues, and process __name__ attribute checks — pool.__name__.__eq__('multiprocessing.pool')==True (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20; the shortest submodule name in this spec); pool.__name__.__len__()==20; queues.__name__.__eq__('multiprocessing.queues')==True (len=22: 'multiprocessing'=15+'.'=1+'queues'=6=22; 2 more than pool); queues.__name__.__len__()==22; process.__name__.__eq__('multiprocessing.process')==True (len=23: 'multiprocessing'=15+'.'=1+'process'=7=23; 1 more than queues); process.__name__.__len__()==23; all share the 'multiprocessing' prefix (len=15); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsub_pqp145

  columns: [id, function, args, expected, description]
  rows:
    - [pool_nm_eq,    multiprocessing.pool.__name__.__eq__,      ["multiprocessing.pool"],     true,  "multiprocessing.pool.__name__ == 'multiprocessing.pool' (len=20); verified with Python 3.14.3"]
    - [pool_nm_len,   multiprocessing.pool.__name__.__len__,      [],                           20,    "multiprocessing.pool.__name__.__len__() == 20 (shortest in this spec); verified with Python 3.14.3"]
    - [pool_spec_eq,  multiprocessing.pool.__spec__.name.__eq__, ["multiprocessing.pool"],     true,  "multiprocessing.pool.__spec__.name == 'multiprocessing.pool' (len=20); verified with Python 3.14.3"]
    - [que_nm_eq,     multiprocessing.queues.__name__.__eq__,    ["multiprocessing.queues"],   true,  "multiprocessing.queues.__name__ == 'multiprocessing.queues' (len=22); verified with Python 3.14.3"]
    - [que_nm_len,    multiprocessing.queues.__name__.__len__,    [],                           22,    "multiprocessing.queues.__name__.__len__() == 22; verified with Python 3.14.3"]
    - [que_spec_eq,   multiprocessing.queues.__spec__.name.__eq__, ["multiprocessing.queues"], true,  "multiprocessing.queues.__spec__.name == 'multiprocessing.queues' (len=22); verified with Python 3.14.3"]
    - [proc_nm_eq,    multiprocessing.process.__name__.__eq__,   ["multiprocessing.process"],  true,  "multiprocessing.process.__name__ == 'multiprocessing.process' (len=23); verified with Python 3.14.3"]
    - [proc_nm_len,   multiprocessing.process.__name__.__len__,   [],                           23,    "multiprocessing.process.__name__.__len__() == 23; verified with Python 3.14.3"]
    - [proc_spec_eq,  multiprocessing.process.__spec__.name.__eq__, ["multiprocessing.process"], true, "multiprocessing.process.__spec__.name == 'multiprocessing.process' (len=23); verified with Python 3.14.3"]

table multiprocessing_extra145.submodule_names_synchronize_managers:
  description: "multiprocessing.synchronize and managers __name__ attribute checks — synchronize.__name__.__eq__('multiprocessing.synchronize')==True (len=27: 'multiprocessing'=15+'.'=1+'synchronize'=11=27; the longest submodule name in this spec; 'synchronize' is the longest suffix at 11 chars); synchronize.__name__.__len__()==27; managers.__name__.__eq__('multiprocessing.managers')==True (len=24: 'multiprocessing'=15+'.'=1+'managers'=8=24; between process at 23 and synchronize at 27); managers.__name__.__len__()==24; both share the 'multiprocessing' prefix (len=15); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsub_sm145

  columns: [id, function, args, expected, description]
  rows:
    - [sync_nm_eq,    multiprocessing.synchronize.__name__.__eq__,   ["multiprocessing.synchronize"],  true,  "multiprocessing.synchronize.__name__ == 'multiprocessing.synchronize' (len=27); verified with Python 3.14.3"]
    - [sync_nm_len,   multiprocessing.synchronize.__name__.__len__,   [],                               27,    "multiprocessing.synchronize.__name__.__len__() == 27 (longest in this spec); verified with Python 3.14.3"]
    - [sync_spec_eq,  multiprocessing.synchronize.__spec__.name.__eq__, ["multiprocessing.synchronize"], true, "multiprocessing.synchronize.__spec__.name == 'multiprocessing.synchronize' (len=27); verified with Python 3.14.3"]
    - [mgr_nm_eq,     multiprocessing.managers.__name__.__eq__,      ["multiprocessing.managers"],     true,  "multiprocessing.managers.__name__ == 'multiprocessing.managers' (len=24); verified with Python 3.14.3"]
    - [mgr_nm_len,    multiprocessing.managers.__name__.__len__,      [],                               24,    "multiprocessing.managers.__name__.__len__() == 24; verified with Python 3.14.3"]
    - [mgr_spec_eq,   multiprocessing.managers.__spec__.name.__eq__, ["multiprocessing.managers"],     true,  "multiprocessing.managers.__spec__.name == 'multiprocessing.managers' (len=24); verified with Python 3.14.3"]

table multiprocessing_extra145.submodule_spec_names_match:
  description: "multiprocessing submodule __spec__.name lengths match __name__ lengths — pool.__spec__.name.__len__()==20 (matches pool.__name__.__len__()==20); queues.__spec__.name.__len__()==22; process.__spec__.name.__len__()==23; synchronize.__spec__.name.__len__()==27; managers.__spec__.name.__len__()==24; the __spec__.name attribute holds the fully-qualified module name used by the import system and always equals __name__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsub_spec145

  columns: [id, function, args, expected, description]
  rows:
    - [pool_spec_len,  multiprocessing.pool.__spec__.name.__len__,         [],  20,  "multiprocessing.pool.__spec__.name.__len__() == 20; verified with Python 3.14.3"]
    - [que_spec_len,   multiprocessing.queues.__spec__.name.__len__,       [],  22,  "multiprocessing.queues.__spec__.name.__len__() == 22; verified with Python 3.14.3"]
    - [proc_spec_len,  multiprocessing.process.__spec__.name.__len__,      [],  23,  "multiprocessing.process.__spec__.name.__len__() == 23; verified with Python 3.14.3"]
    - [sync_spec_len,  multiprocessing.synchronize.__spec__.name.__len__,  [],  27,  "multiprocessing.synchronize.__spec__.name.__len__() == 27 (longest); verified with Python 3.14.3"]
    - [mgr_spec_len,   multiprocessing.managers.__spec__.name.__len__,     [],  24,  "multiprocessing.managers.__spec__.name.__len__() == 24; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra145
# ---------------------------------------------------------------------------

invariant multiprocessing_extra145.pool_name_len_20:
  description: "multiprocessing.pool.__name__.__len__() == 20 — multiprocessing.pool.__name__ is 'multiprocessing.pool' (20 chars: 'multiprocessing'=15+'.'=1+'pool'=4=20); this is the shortest submodule name in this spec (compare: queues=22, process=23, managers=24, synchronize=27); pool.__spec__.name=='multiprocessing.pool' (len=20; matches __name__); the multiprocessing.pool module hosts the Pool class covered in extra144; NEW in extra145: first standalone multiprocessing.pool __name__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.__name__.__len__
  args: []
  expected: 20

invariant multiprocessing_extra145.queues_name_len_22:
  description: "multiprocessing.queues.__name__.__len__() == 22 — multiprocessing.queues.__name__ is 'multiprocessing.queues' (22 chars: 'multiprocessing'=15+'.'=1+'queues'=6=22); this is 2 more than pool (20) and 1 less than process (23); the multiprocessing.queues module hosts the Queue class covered in extra143; queues.__spec__.name=='multiprocessing.queues' (len=22; matches __name__); NEW in extra145: first standalone multiprocessing.queues __name__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.queues.__name__.__len__
  args: []
  expected: 22

invariant multiprocessing_extra145.process_name_len_23:
  description: "multiprocessing.process.__name__.__len__() == 23 — multiprocessing.process.__name__ is 'multiprocessing.process' (23 chars: 'multiprocessing'=15+'.'=1+'process'=7=23); this is 1 more than queues (22) and 1 less than managers (24); the multiprocessing.process module contains the BaseProcess and Process class implementations; process.__spec__.name=='multiprocessing.process' (len=23; matches __name__); NEW in extra145: first standalone multiprocessing.process __name__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.__name__.__len__
  args: []
  expected: 23

invariant multiprocessing_extra145.synchronize_name_len_27:
  description: "multiprocessing.synchronize.__name__.__len__() == 27 — multiprocessing.synchronize.__name__ is 'multiprocessing.synchronize' (27 chars: 'multiprocessing'=15+'.'=1+'synchronize'=11=27); this is the longest submodule name in this spec (compare: managers=24, process=23, queues=22, pool=20); 'synchronize' is the longest single-word suffix across all five submodules at 11 chars; synchronize.__spec__.name=='multiprocessing.synchronize' (len=27; matches __name__); NEW in extra145: first standalone multiprocessing.synchronize __name__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.synchronize.__name__.__len__
  args: []
  expected: 27

invariant multiprocessing_extra145.managers_name_len_24:
  description: "multiprocessing.managers.__name__.__len__() == 24 — multiprocessing.managers.__name__ is 'multiprocessing.managers' (24 chars: 'multiprocessing'=15+'.'=1+'managers'=8=24); this is 1 more than process (23) and 3 less than synchronize (27); managers.__spec__.name=='multiprocessing.managers' (len=24; matches __name__); the multiprocessing.managers module provides the Manager class for creating server processes that manage shared objects; NEW in extra145: first standalone multiprocessing.managers __name__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.__name__.__len__
  args: []
  expected: 24

invariant multiprocessing_extra145.synchronize_spec_name_eq:
  description: "multiprocessing.synchronize.__spec__.name.__eq__('multiprocessing.synchronize') == True — multiprocessing.synchronize.__spec__.name is 'multiprocessing.synchronize' (27 chars); the ModuleSpec name attribute holds the fully-qualified module name and always equals __name__; synchronize.__name__=='multiprocessing.synchronize' (len=27: the longest submodule name in this spec); the synchronize module implements Lock, RLock, Semaphore, BoundedSemaphore, Event, and Condition for inter-process synchronization; NEW in extra145: first standalone multiprocessing.synchronize __spec__.name equality invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.synchronize.__spec__.name.__eq__
  args: ["multiprocessing.synchronize"]
  expected: true

invariant multiprocessing_extra145.pool_spec_name_eq:
  description: "multiprocessing.pool.__spec__.name.__eq__('multiprocessing.pool') == True — multiprocessing.pool.__spec__.name is 'multiprocessing.pool' (20 chars: the shortest submodule name in this spec); pool.__name__=='multiprocessing.pool' (len=20; __spec__.name matches __name__); the pool module hosts the Pool class (covered in extra144 which shows Pool.__module__=='multiprocessing.pool' and Pool.__doc__.__len__()==73); NEW in extra145: first standalone multiprocessing.pool __spec__.name equality invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.__spec__.name.__eq__
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra145.managers_spec_name_eq:
  description: "multiprocessing.managers.__spec__.name.__eq__('multiprocessing.managers') == True — multiprocessing.managers.__spec__.name is 'multiprocessing.managers' (24 chars: 'multiprocessing'=15+'.'=1+'managers'=8=24); managers.__name__=='multiprocessing.managers' (len=24; __spec__.name matches __name__); between process (len=23) and synchronize (len=27) in length; NEW in extra145: first standalone multiprocessing.managers __spec__.name equality invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.__spec__.name.__eq__
  args: ["multiprocessing.managers"]
  expected: true
