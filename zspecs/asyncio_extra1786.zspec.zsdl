spec: asyncio_extra1786
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/asyncio-task.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-sync.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-queue.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "Wave 566, suffix _extra1786. Theme: __class_getitem__ and __init_subclass__ class creation hooks — which stdlib types define these in their own __dict__."
    - "asyncio.Future defines __class_getitem__ in its own __dict__ (PEP 585 generic syntax support added in Python 3.9)."
    - "asyncio.Task defines __class_getitem__ in its own __dict__ (PEP 585 generic syntax support added in Python 3.9)."
    - "asyncio.Queue defines __class_getitem__ in its own __dict__ (asyncio.Queue[T] is supported in Python 3.9+)."
    - "asyncio.Lock does NOT define __class_getitem__ in its own __dict__ — Lock is not a generic type."
    - "asyncio.Semaphore does NOT define __class_getitem__ in its own __dict__ — Semaphore is not a generic type."
    - "asyncio.Event does NOT define __class_getitem__ in its own __dict__ — Event is not a generic type."
    - "asyncio.Condition does NOT define __class_getitem__ in its own __dict__ — Condition is not a generic type."
    - "None of the tested asyncio types define __init_subclass__ in their own __dict__; all inherit the default from object."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __class_getitem__ presence in asyncio type __dict__
#
# asyncio.Future, asyncio.Task, and asyncio.Queue each define
# __class_getitem__ directly in their own __dict__ for PEP 585 generic
# syntax (e.g., asyncio.Future[int]).  Lock, Semaphore, Event, and
# Condition do NOT define __class_getitem__ — they are not generic types.
# ---------------------------------------------------------------------------

table asyncio_extra1786.class_getitem_in_dict:
  kind: python_call_eq
  category: class_getitem
  id_prefix: as1786

  columns: [id, function, args, expected]
  rows:
    - ["as1786001", asyncio.Future.__dict__.__contains__,    ["__class_getitem__"], true]
    - ["as1786002", asyncio.Task.__dict__.__contains__,      ["__class_getitem__"], true]
    - ["as1786003", asyncio.Queue.__dict__.__contains__,     ["__class_getitem__"], true]
    - ["as1786004", asyncio.Lock.__dict__.__contains__,      ["__class_getitem__"], false]
    - ["as1786005", asyncio.Semaphore.__dict__.__contains__,  ["__class_getitem__"], false]
    - ["as1786006", asyncio.Event.__dict__.__contains__,      ["__class_getitem__"], false]
    - ["as1786007", asyncio.Condition.__dict__.__contains__,  ["__class_getitem__"], false]
    - ["as1786008", asyncio.Future.__dict__.__contains__,    ["__init_subclass__"], false]
    - ["as1786009", asyncio.Task.__dict__.__contains__,      ["__init_subclass__"], false]
    - ["as1786010", asyncio.Queue.__dict__.__contains__,     ["__init_subclass__"], false]
    - ["as1786011", asyncio.Lock.__dict__.__contains__,      ["__init_subclass__"], false]
    - ["as1786012", asyncio.Semaphore.__dict__.__contains__,  ["__init_subclass__"], false]
    - ["as1786013", asyncio.Event.__dict__.__contains__,      ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Table 2: complementary identity and dict-membership checks
#
# asyncio.Future and asyncio.Task also define __await__ and __class_getitem__
# respectively in their own dicts.  We verify __name__, __module__, and a
# selection of other dict members to provide positive anchors alongside the
# negative __init_subclass__ checks.
# ---------------------------------------------------------------------------

table asyncio_extra1786.identity_and_complementary:
  kind: python_call_eq
  category: identity
  id_prefix: as1786

  columns: [id, function, args, expected]
  rows:
    - ["as1786014", asyncio.Condition.__dict__.__contains__,  ["__init_subclass__"], false]
    - ["as1786015", asyncio.Future.__dict__.__contains__,     ["__await__"],          true]
    - ["as1786016", asyncio.Future.__name__.__eq__,           ["Future"],             true]
    - ["as1786017", asyncio.Task.__name__.__eq__,             ["Task"],               true]
    - ["as1786018", asyncio.Queue.__name__.__eq__,            ["Queue"],              true]
    - ["as1786019", asyncio.Lock.__name__.__eq__,             ["Lock"],               true]
    - ["as1786020", asyncio.Future.__module__.__eq__,         ["asyncio.futures"],    true]
    - ["as1786021", asyncio.Task.__module__.__eq__,           ["asyncio.tasks"],      true]
    - ["as1786022", asyncio.Queue.__module__.__eq__,          ["asyncio.queues"],     true]
    - ["as1786023", asyncio.Lock.__module__.__eq__,           ["asyncio.locks"],      true]
    - ["as1786024", asyncio.Future.__dict__.__contains__,     ["cancel"],             true]
    - ["as1786025", asyncio.Queue.__dict__.__contains__,      ["get"],                true]
