  description: "multiprocessing types __rrshift__ dict-presence checks; wave 664"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3256

  columns: [id, function, args, expected]
  rows:
