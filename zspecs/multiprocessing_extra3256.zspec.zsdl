    - ["mp3256018",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__rrshift__"], false]
    - ["mp3256019",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__rrshift__"], false]
    - ["mp3256020",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__rrshift__"], false]
    - ["mp3256021",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__rrshift__"], false]
    - ["mp3256022",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__rrshift__"], false]
    - ["mp3256023",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__rrshift__"], false]
    - ["mp3256024",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__rrshift__"], false]

# ---------------------------------------------------------------------------
# combined — __rpow__, __rlshift__, __rrshift__ across all 8 mp subjects
#
# Covers the full matrix: 8 classes x 3 methods = 24 rows.
# __rpow__: false for all 8 — not in any type's own __dict__.
# __rlshift__: false for all 8 — not in any type's own __dict__.
# __rrshift__: false for all 8 — not in any type's own __dict__.
# All 24 values are false.
# The BaseListProxy asymmetry across waves deserves emphasis:
#   Wave 658: BaseListProxy.__add__ = true (list + list via __add__).
#   Wave 658: BaseListProxy.__mul__ = true (list * n via __mul__).
#   Wave 662: BaseListProxy.__radd__ = false (list has no __radd__).
#   Wave 662: BaseListProxy.__rmul__ = false (list has no __rmul__).
#   Wave 663: BaseListProxy.__rtruediv__ = false (list has no __rtruediv__).
#   Wave 663: BaseListProxy.__rfloordiv__ = false (list has no __rfloordiv__).
#   Wave 663: BaseListProxy.__rmod__ = false (list has no __rmod__).
#   Wave 664: BaseListProxy.__rpow__ = false (list has no __rpow__).
#   Wave 664: BaseListProxy.__rlshift__ = false (list has no __rlshift__).
#   Wave 664: BaseListProxy.__rrshift__ = false (list has no __rrshift__).
#   Python's list type defines __add__ and __mul__ but NOT their reflected
#   counterparts and defines no power or shift operators at all.
# _BaseSetProxy note: set defines __sub__ (set difference s - t) and bitwise
#   set operators (__and__/__or__/__xor__/__ior__/__iand__/__ixor__), but set
#   does NOT define __rpow__, __rlshift__, or __rrshift__. All reflected
#   power and shift operators are absent from both set and _BaseSetProxy.
# multiprocessing is a process-based concurrency library; its types interact
#   exclusively through explicit method calls, subprocess lifecycle management,
#   and IPC — never through Python's reflected power or shift operators.
# ---------------------------------------------------------------------------

