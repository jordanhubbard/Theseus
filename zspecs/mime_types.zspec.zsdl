spec: mime_types
version: ">=2.0.0"
backend: node(mime-types)

docs: https://github.com/jshttp/mime-types#readme

provenance:
  derived_from:
    - "mime-types README — https://github.com/jshttp/mime-types#readme"
    - "Test vectors verified with mime-types@2.1.35 via Node.js 25.6.0 on macOS/Darwin 25.4.0, 2026-04-09"
    - "mime-types source: index.js (MIT; source inspection permitted)"
  not_derived_from:
    - "mime-types source: internal mime-db lookup tables"
  notes:
    - "mime-types exports an object with lookup, extension, contentType, charset, and types properties."
    - "lookup(ext) returns the MIME type for the given file extension, or false if unknown."
    - "extension(type) returns the primary file extension for the given MIME type, or false if unknown."
    - "contentType(ext_or_type) returns the full Content-Type header string, or false."
    - "charset(type) returns the charset for the MIME type ('UTF-8'), or false for binary types."
    - "Extensions can be passed with or without a leading dot."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Functions return false for unknown types/extensions. node exits 0 for all invariants."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# lookup(ext) — extension → MIME type
# ---------------------------------------------------------------------------

table mime_types.lookup:
  kind: node_module_call_eq
  function: lookup
  category: lookup
  id_prefix: lookup

  columns: [id, args, expected]
  rows:
    - [html,        ["html"],        "text/html"]
    - [json,        ["json"],        "application/json"]
    - [png,         ["png"],         "image/png"]
    - [jpg,         ["jpg"],         "image/jpeg"]
    - [txt,         ["txt"],         "text/plain"]
    - [pdf,         ["pdf"],         "application/pdf"]
    - [js,          ["js"],          "application/javascript"]
    - [css,         ["css"],         "text/css"]
    - [svg,         ["svg"],         "image/svg+xml"]
    - [xml,         ["xml"],         "application/xml"]
    - [mp4,         ["mp4"],         "video/mp4"]
    - [mp3,         ["mp3"],         "audio/mpeg"]
    - [unknown,     ["unknown_xyz"], false]

# ---------------------------------------------------------------------------
# extension(type) — MIME type → primary extension
# ---------------------------------------------------------------------------

table mime_types.extension:
  kind: node_module_call_eq
  function: extension
  category: extension
  id_prefix: extension

  columns: [id, args, expected]
  rows:
    - [text_html,        ["text/html"],        "html"]
    - [application_json, ["application/json"], "json"]
    - [image_png,        ["image/png"],        "png"]
    - [image_jpeg,       ["image/jpeg"],       "jpeg"]
    - [text_plain,       ["text/plain"],       "txt"]
    - [application_pdf,  ["application/pdf"],  "pdf"]
    - [unknown_type,     ["unknown/type"],     false]

# ---------------------------------------------------------------------------
# contentType(ext_or_type) — return full Content-Type header string
# ---------------------------------------------------------------------------

table mime_types.contentType:
  kind: node_module_call_eq
  function: contentType
  category: contentType
  id_prefix: contentType

  columns: [id, args, expected]
  rows:
    - [ext_html,       ["html"],      "text/html; charset=utf-8"]
    - [ext_json,       ["json"],      "application/json; charset=utf-8"]
    - [ext_png,        ["png"],       "image/png"]
    - [type_text_html, ["text/html"], "text/html; charset=utf-8"]

# ---------------------------------------------------------------------------
# charset(type) — return charset for MIME type
# ---------------------------------------------------------------------------

table mime_types.charset:
  kind: node_module_call_eq
  function: charset
  category: charset
  id_prefix: charset

  columns: [id, args, expected]
  rows:
    - [text_html,        ["text/html"],        "UTF-8"]
    - [application_json, ["application/json"], "UTF-8"]
    - [image_png,        ["image/png"],        false]
