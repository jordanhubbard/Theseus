spec: mime_types
version: ">=2.0.0"
backend: node(mime-types)

docs: https://www.npmjs.com/package/mime-types

provenance:
  derived_from:
    - "mime-types README — https://www.npmjs.com/package/mime-types"
    - "Test vectors verified with mime-types via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "mime-types source"
  notes:
    - "mime-types is an npm package. Install: npm install mime-types"
    - "mime.lookup(path) returns MIME type for a file extension."
    - "mime.extension(type) returns the default extension for a MIME type."
    - "mime.contentType(type) returns the full content-type header value with charset."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns MIME type string or extension string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table mime_types.lookup:
  kind: node_module_call_eq
  function: lookup
  category: lookup
  id_prefix: mmlookup

  columns: [id, args, expected]
  rows:
    - [png,  ["file.png"],   "image/png"]
    - [html, ["index.html"], "text/html"]
    - [pdf,  ["doc.pdf"],    "application/pdf"]

table mime_types.extension:
  kind: node_module_call_eq
  function: extension
  category: lookup
  id_prefix: mmext

  columns: [id, args, expected]
  rows:
    - [jpeg, ["image/jpeg"], "jpeg"]

table mime_types.contentType:
  kind: node_module_call_eq
  function: contentType
  category: lookup
  id_prefix: mmct

  columns: [id, args, expected]
  rows:
    - [html, ["html"], "text/html; charset=utf-8"]
