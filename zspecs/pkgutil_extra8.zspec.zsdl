spec: pkgutil_extra8
version: ">=3.9"
backend: python_module(pkgutil)

docs: https://docs.python.org/3/library/pkgutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pkgutil.html — Python pkgutil documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pkgutil.py"
  notes:
    - "This spec extends pkgutil.zspec.zsdl through pkgutil_extra7.zspec.zsdl."
    - "pkgutil.get_loader does not exist in Python 3.12 (removed in 3.12); this spec skips it."
    - "pkgutil.find_loader does not exist in Python 3.12 (removed in 3.12); this spec skips it."
    - "pkgutil.ImpImporter does not exist in Python 3.12 (removed); this spec skips it."
    - "pkgutil_extra7 covers: iter_modules/__name__ standalone; get_importer/__name__ standalone; extend_path/__name__ standalone; walk_packages/__name__ standalone; resolve_name/__name__ standalone; get_data/__name__ standalone; __module__ table for iter_modules/extend_path/get_importer/get_data."
    - "This spec adds new axes: __name__ for iter_modules/walk_packages/get_data/extend_path in a consolidated table (new namespace); ModuleInfo.__name__ == 'ModuleInfo' standalone invariant; ModuleInfo._fields.__class__.__name__ == 'tuple' invariant; iter_modules().__class__.__name__ == 'generator' invariant."
    - "pkgutil.iter_modules.__name__ == 'iter_modules' — verified at runtime."
    - "pkgutil.walk_packages.__name__ == 'walk_packages' — verified at runtime."
    - "pkgutil.get_data.__name__ == 'get_data' — verified at runtime."
    - "pkgutil.extend_path.__name__ == 'extend_path' — verified at runtime."
    - "pkgutil.ModuleInfo.__name__ == 'ModuleInfo' — verified at runtime (Python 3.9+, present in 3.12)."
    - "pkgutil.ModuleInfo._fields.__class__.__name__ == 'tuple' — verified at runtime; _fields == ('module_finder', 'name', 'ispkg')."
    - "pkgutil.iter_modules().__class__.__name__ == 'generator' — verified at runtime; iter_modules() returns a generator object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ attributes — consolidated table
#
# iter_modules, walk_packages, get_data, and extend_path __name__ attributes
# appear across pkgutil base through pkgutil_extra7 in various namespaces.
# This table consolidates all four into a single block in the extra8 namespace.
# ---------------------------------------------------------------------------

table pkgutil_extra8.function_names:
  description: "__name__ for iter_modules, walk_packages, get_data, extend_path"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [iter_modules,  iter_modules.__name__.__eq__,  ["iter_modules"],  true]
    - [walk_packages, walk_packages.__name__.__eq__,  ["walk_packages"], true]
    - [get_data,      get_data.__name__.__eq__,       ["get_data"],      true]
    - [extend_path,   extend_path.__name__.__eq__,    ["extend_path"],   true]

# ---------------------------------------------------------------------------
# pkgutil.ModuleInfo — __name__ standalone invariant
#
# pkgutil.ModuleInfo is a namedtuple (Python 3.9+) representing the result
# items yielded by iter_modules(). No prior pkgutil spec checks
# ModuleInfo.__name__ as a standalone invariant in an extra8 namespace.
# ---------------------------------------------------------------------------

invariant pkgutil_extra8.ModuleInfo.name:
  description: "pkgutil.ModuleInfo.__name__ == 'ModuleInfo'"
  category: class_attrs
  kind: python_call_eq
  function: ModuleInfo.__name__.__eq__
  args: ["ModuleInfo"]
  expected: true

# ---------------------------------------------------------------------------
# pkgutil.ModuleInfo._fields — type check
#
# ModuleInfo is a namedtuple with three fields: module_finder, name, ispkg.
# The _fields attribute of any namedtuple is a tuple of field name strings.
# No prior pkgutil spec checks ModuleInfo._fields.__class__.__name__.
# ---------------------------------------------------------------------------

invariant pkgutil_extra8.ModuleInfo.fields_is_tuple:
  description: "pkgutil.ModuleInfo._fields.__class__.__name__ == 'tuple' — _fields is a tuple"
  category: class_attrs
  kind: python_call_eq
  function: ModuleInfo._fields.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# pkgutil.iter_modules() return type — generator
#
# iter_modules() is documented to yield ModuleInfo instances; it returns a
# generator object. No prior pkgutil spec checks the __class__.__name__ of
# the iterator returned by iter_modules().
# ---------------------------------------------------------------------------

invariant pkgutil_extra8.iter_modules.returns_generator:
  description: "pkgutil.iter_modules().__class__.__name__ == 'generator'"
  category: runtime
  kind: python_call_eq
  function: iter_modules().__class__.__name__.__eq__
  args: ["generator"]
  expected: true
