spec: object_assign_deep
version: ">=0.4.0"
backend: node(object-assign-deep)

docs: https://www.npmjs.com/package/object-assign-deep

provenance:
  derived_from:
    - "object-assign-deep README — https://www.npmjs.com/package/object-assign-deep"
    - "Test vectors verified with object-assign-deep via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "object-assign-deep source"
  notes:
    - "object-assign-deep is an npm package. Install: npm install object-assign-deep"
    - "Deep version of Object.assign — recursively merges nested objects."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the target object with sources deeply merged."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table object_assign_deep.deepAssign:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: objassigndeep

  columns: [id, args, expected]
  rows:
    - [merge_nested, [{}, {"a": {"x": 1}}, {"a": {"y": 2}}],
       {"a": {"x": 1, "y": 2}}]
    - [flat_merge,   [{}, {"a": 1}, {"b": 2}],
       {"a": 1, "b": 2}]
