spec: warnings_extra9
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Python/_warnings.c"
  notes:
    - "This spec extends warnings.zspec.zsdl through warnings_extra8.zspec.zsdl."
    - "warnings_extra8 covers: WarningMessage/catch_warnings __module__; SyntaxWarning/ResourceWarning/UnicodeWarning/BytesWarning __name__/__qualname__; category __module__ == 'builtins'."
    - "warnings_extra6 covers: filterwarnings/simplefilter/resetwarnings/showwarning/formatwarning __module__; showwarning/formatwarning __qualname__; built-in warning category __qualname__."
    - "NOT yet covered: warnings.filters.__class__.__name__ == 'list' — type of the module-level filter list."
    - "NOT yet covered: DeprecationWarning.__mro__[1].__name__ == 'Warning' — direct parent class."
    - "NOT yet covered: DeprecationWarning.__mro__[2].__name__ == 'Exception' — MRO chain."
    - "NOT yet covered: DeprecationWarning.__mro__[3].__name__ == 'BaseException' — MRO chain."
    - "NOT yet covered: DeprecationWarning.__mro__[4].__name__ == 'object' — root of MRO."
    - "NOT yet covered: UserWarning.__bases__[0].__name__ == 'Warning' — direct parent."
    - "NOT yet covered: DeprecationWarning.__bases__[0].__name__ == 'Warning' — direct parent."
    - "NOT yet covered: FutureWarning.__mro__[1].__name__ == 'Warning' — MRO chain."
    - "NOT yet covered: PendingDeprecationWarning.__mro__[1].__name__ == 'Warning' — MRO chain."
    - "All standard warning categories (DeprecationWarning, UserWarning, RuntimeWarning, SyntaxWarning, FutureWarning, PendingDeprecationWarning) inherit directly from Warning."
    - "warnings.filters is a list; its class name is 'list'."
    - "DeprecationWarning MRO is [DeprecationWarning, Warning, Exception, BaseException, object] — 5 entries."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# warnings.filters — type identity check
#
# warnings.filters is the module-level list of active warning filters.
# No prior warnings spec records its runtime type. Its __class__.__name__
# is 'list', confirming it is a plain Python list object.
# ---------------------------------------------------------------------------

invariant warnings_extra9.filters.class_name:
  description: "warnings.filters.__class__.__name__ == 'list' — the filter list is a Python list"
  category: module_attributes
  kind: python_call_eq
  function: filters.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# DeprecationWarning MRO entries
#
# No prior warnings spec records MRO entries for any warning category class.
# DeprecationWarning MRO: [DeprecationWarning, Warning, Exception, BaseException, object].
# These 5 entries trace the full exception hierarchy.
# ---------------------------------------------------------------------------

invariant warnings_extra9.DeprecationWarning.mro_1:
  description: "DeprecationWarning.__mro__[1].__name__ == 'Warning' — direct parent class"
  category: category_mro
  kind: python_call_eq
  function: DeprecationWarning.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Warning"

invariant warnings_extra9.DeprecationWarning.mro_2:
  description: "DeprecationWarning.__mro__[2].__name__ == 'Exception'"
  category: category_mro
  kind: python_call_eq
  function: DeprecationWarning.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Exception"

invariant warnings_extra9.DeprecationWarning.mro_3:
  description: "DeprecationWarning.__mro__[3].__name__ == 'BaseException'"
  category: category_mro
  kind: python_call_eq
  function: DeprecationWarning.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "BaseException"

invariant warnings_extra9.DeprecationWarning.mro_4:
  description: "DeprecationWarning.__mro__[4].__name__ == 'object' — root of MRO"
  category: category_mro
  kind: python_call_eq
  function: DeprecationWarning.__mro__.__getitem__
  args: [4]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Direct parent class (__bases__[0].__name__) — DeprecationWarning, UserWarning
#
# All standard warning categories inherit directly from Warning. No prior spec
# records __bases__[0].__name__ for any warning category class as a standalone
# invariant. DeprecationWarning and UserWarning are verified here.
# ---------------------------------------------------------------------------

invariant warnings_extra9.DeprecationWarning.base_is_Warning:
  description: "DeprecationWarning.__bases__[0].__name__ == 'Warning' — direct parent is Warning"
  category: category_bases
  kind: python_call_eq
  function: DeprecationWarning.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Warning"

invariant warnings_extra9.UserWarning.base_is_Warning:
  description: "UserWarning.__bases__[0].__name__ == 'Warning' — direct parent is Warning"
  category: category_bases
  kind: python_call_eq
  function: UserWarning.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Warning"

# ---------------------------------------------------------------------------
# Additional warning category MRO[1] checks
#
# FutureWarning and PendingDeprecationWarning both inherit directly from Warning.
# Confirming MRO[1].__name__ == 'Warning' for each provides independent checks
# of the standard warning category hierarchy.
# ---------------------------------------------------------------------------

invariant warnings_extra9.FutureWarning.mro_1:
  description: "FutureWarning.__mro__[1].__name__ == 'Warning' — direct parent class"
  category: category_mro
  kind: python_call_eq
  function: FutureWarning.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Warning"

invariant warnings_extra9.PendingDeprecationWarning.mro_1:
  description: "PendingDeprecationWarning.__mro__[1].__name__ == 'Warning' — direct parent class"
  category: category_mro
  kind: python_call_eq
  function: PendingDeprecationWarning.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Warning"

invariant warnings_extra9.RuntimeWarning.mro_1:
  description: "RuntimeWarning.__mro__[1].__name__ == 'Warning' — direct parent class"
  category: category_mro
  kind: python_call_eq
  function: RuntimeWarning.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Warning"

invariant warnings_extra9.SyntaxWarning.mro_1:
  description: "SyntaxWarning.__mro__[1].__name__ == 'Warning' — direct parent class"
  category: category_mro
  kind: python_call_eq
  function: SyntaxWarning.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Warning"
