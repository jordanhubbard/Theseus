spec: io_extra175
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, and io.IOBase class identity (__name__, __module__, __bases__[0].__name__)."
    - "io.RawIOBase.__name__ == 'RawIOBase' (len=9: 'Raw'(3)+'IO'(2)+'Base'(4)=9)."
    - "io.RawIOBase.__module__ == 'io' (len=2) — the public Python-level ABC, unlike the concrete classes which report '_io' (3 chars)."
    - "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' (len=10) — the internal C-level base with underscore prefix."
    - "io.BufferedIOBase.__name__ == 'BufferedIOBase' (len=14: 'Buffered'(8)+'IO'(2)+'Base'(4)=14)."
    - "io.BufferedIOBase.__module__ == 'io' (len=2) — public ABC with module 'io', unlike concrete subclasses with module '_io'."
    - "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' (len=15) — C-level base class with underscore prefix."
    - "io.TextIOBase.__name__ == 'TextIOBase' (len=10: 'Text'(4)+'IO'(2)+'Base'(4)=10)."
    - "io.TextIOBase.__module__ == 'io' (len=2)."
    - "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' (len=11)."
    - "io.IOBase.__name__ == 'IOBase' (len=6: 'IO'(2)+'Base'(4)=6)."
    - "io.IOBase.__module__ == 'io' (len=2)."
    - "io.IOBase.__bases__[0].__name__ == '_IOBase' (len=7) — the C-level root base with underscore prefix."
    - "All four abstract base classes report __module__ == 'io' (2 chars), unlike concrete classes (BytesIO, StringIO, BufferedReader, etc.) which report __module__ == '_io' (3 chars)."
    - "Name length ordering: IOBase(6) < RawIOBase(9) < TextIOBase(10) < BufferedIOBase(14)."
    - "Each ABC's C-level base name is 1 char longer (underscore prefix): _IOBase(7), _RawIOBase(10), _TextIOBase(11), _BufferedIOBase(15)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.RawIOBase class identity
# __name__ == 'RawIOBase' (len=9), __module__ == 'io' (len=2)
# __bases__[0].__name__ == '_RawIOBase' (len=10)
# The public ABC reports module 'io' (2), concrete subclasses report '_io' (3)
# ---------------------------------------------------------------------------

table io_extra175.RawIOBase_class_identity:
  description: "io.RawIOBase class identity: __name__=='RawIOBase' (len=9), __module__=='io' (len=2), __bases__[0].__name__=='_RawIOBase' (len=10); 'RawIOBase'='Raw'(3)+'IO'(2)+'Base'(4)=9; ABC module is 'io' (2) not '_io' (3)"
  kind: python_call_eq
  category: identity
  id_prefix: iorab175

  columns: [id, function, args, expected, description]
  rows:
    - [rab_name,     RawIOBase.__name__.__eq__,                ["RawIOBase"],   true, "io.RawIOBase.__name__ == 'RawIOBase' — RawIOBase is the abstract base class for raw binary I/O, providing unbuffered access to the underlying OS; 'RawIOBase' has 9 characters: 'Raw'(3)+'IO'(2)+'Base'(4)=9; RawIOBase (9) > IOBase (6) by 3 == len('Raw'): the 'Raw' prefix distinguishes RawIOBase from the root IOBase; RawIOBase (9) < TextIOBase (10) by 1 and < BufferedIOBase (14) by 5; the concrete subclass io.FileIO (6 chars) inherits from RawIOBase; RawIOBase's raw reads and writes call the OS directly without buffering, unlike BufferedReader/BufferedWriter which wrap RawIOBase with buffering; confirmed Python 3.14.3 macOS"]
    - [rab_module,   RawIOBase.__module__.__eq__,              ["io"],           true, "io.RawIOBase.__module__ == 'io' — RawIOBase is the public ABC defined in the 'io' module (2 chars); this contrasts with the concrete subclasses: io.FileIO.__module__ == '_io' (3 chars), io.BufferedReader.__module__ == '_io' (3 chars) — the abstract base classes report 'io' (2 chars) while concrete classes report '_io' (3 chars); RawIOBase.__module__ (2: 'io') < BytesIO.__module__ (3: '_io'): the ABC module name is 1 character shorter than the concrete class module name; all four abstract base classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase) share __module__ == 'io' (2 chars); confirmed Python 3.14.3 macOS"]
    - [rab_base0,    "RawIOBase.__bases__[0].__name__.__eq__",  ["_RawIOBase"],  true, "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' — the first C-level base of io.RawIOBase is '_RawIOBase' (10 chars); '_RawIOBase' has 10 characters: '_'(1)+'Raw'(3)+'IO'(2)+'Base'(4)=10; '_RawIOBase' (10 chars) == RawIOBase (9 chars) + 1: the C-level base name is exactly 1 character longer than the public ABC name due to the underscore prefix; io.RawIOBase also has io.IOBase as its second base (index 1): io.RawIOBase.__bases__[1].__name__ == 'IOBase'; the underscore prefix marks '_RawIOBase' as the internal C-extension implementation base; confirmed Python 3.14.3 macOS"]
    - [rab_name_len, RawIOBase.__name__.__len__,               [],               9,   "io.RawIOBase.__name__.__len__() == 9 — 'RawIOBase' has 9 characters: 'Raw'(3)+'IO'(2)+'Base'(4)=9; RawIOBase (9) is in the ascending ABC name length sequence: IOBase(6) < RawIOBase(9) < TextIOBase(10) < BufferedIOBase(14); RawIOBase (9) == len('PosixPath') (9) and len('fullmatch') (9) and len('Underflow') (9) — cross-module 9-character ties across pathlib, re, and decimal; the gap from IOBase (6) to RawIOBase (9) is 3 == len('Raw'): the 'Raw' prefix adds exactly 3 characters; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.BufferedIOBase class identity
# __name__ == 'BufferedIOBase' (len=14), __module__ == 'io' (len=2)
# __bases__[0].__name__ == '_BufferedIOBase' (len=15)
# BufferedIOBase (14) ties with len(BufferedReader/Writer/Random) == 14
# ---------------------------------------------------------------------------

table io_extra175.BufferedIOBase_class_identity:
  description: "io.BufferedIOBase class identity: __name__=='BufferedIOBase' (len=14), __module__=='io' (len=2), __bases__[0].__name__=='_BufferedIOBase' (len=15); 'BufferedIOBase'='Buffered'(8)+'IO'(2)+'Base'(4)=14; BufferedIOBase(14) ties with BufferedReader/Writer/Random(14)"
  kind: python_call_eq
  category: identity
  id_prefix: iobiob175

  columns: [id, function, args, expected, description]
  rows:
    - [biob_name,     BufferedIOBase.__name__.__eq__,                ["BufferedIOBase"],   true, "io.BufferedIOBase.__name__ == 'BufferedIOBase' — BufferedIOBase is the abstract base class for buffered binary I/O streams; 'BufferedIOBase' has 14 characters: 'Buffered'(8)+'IO'(2)+'Base'(4)=14; BufferedIOBase (14) ties in name length with BufferedReader (14), BufferedWriter (14), and BufferedRandom (14) from io_extra173 — all four share the 14-character 'Buffered*' family; BufferedIOBase (14) is the public Python-level ABC while its concrete subclasses (BufferedReader, BufferedWriter, BufferedRandom, BytesIO) implement the actual buffered I/O functionality; BufferedIOBase (14) > TextIOBase (10) by 4 == len('Text') - net length difference comes from 'Buffered'(8) vs 'Text'(4); confirmed Python 3.14.3 macOS"]
    - [biob_module,   BufferedIOBase.__module__.__eq__,              ["io"],               true, "io.BufferedIOBase.__module__ == 'io' — BufferedIOBase is a public ABC defined in the 'io' module (2 chars); BufferedIOBase.__module__ (2: 'io') != BufferedReader.__module__ (3: '_io'): the ABC and its concrete subclasses differ in their module attribution — ABCs report 'io' (2 chars) while concrete classes report '_io' (3 chars); BufferedIOBase.__module__ (2: 'io') == IOBase.__module__ (2: 'io') == RawIOBase.__module__ (2: 'io') == TextIOBase.__module__ (2: 'io'): all four io ABCs share the same 2-character module name 'io'; confirmed Python 3.14.3 macOS"]
    - [biob_base0,    "BufferedIOBase.__bases__[0].__name__.__eq__",  ["_BufferedIOBase"], true, "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' — BufferedIOBase's first C-level base is '_BufferedIOBase' (15 chars); '_BufferedIOBase' has 15 characters: '_'(1)+'Buffered'(8)+'IO'(2)+'Base'(4)=15; '_BufferedIOBase' (15 chars) == BufferedIOBase (14 chars) + 1: the C-level base name is exactly 1 character longer due to the underscore prefix; this same '_BufferedIOBase' (15 chars) is also the direct C-level base of the concrete classes BytesIO, BufferedReader, BufferedWriter, BufferedRandom; BufferedIOBase has io.IOBase as its second base (index 1): the public ABC MRO includes IOBase; confirmed Python 3.14.3 macOS"]
    - [biob_name_len, BufferedIOBase.__name__.__len__,               [],                  14,   "io.BufferedIOBase.__name__.__len__() == 14 — 'BufferedIOBase' has 14 characters: 'Buffered'(8)+'IO'(2)+'Base'(4)=14; BufferedIOBase (14) ties with BufferedReader (14), BufferedWriter (14), BufferedRandom (14): the abstract base class name has the same length as all three concrete buffered classes; the 14-character tie: ABC + 3 concrete classes all at 14; BufferedIOBase (14) is the maximum in the ABC name length sequence: IOBase(6) < RawIOBase(9) < TextIOBase(10) < BufferedIOBase(14); 'BufferedIOBase' (14 chars) == 'DivisionByZero' (14 chars) from decimal_extra164 — a cross-module 14-character tie; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.TextIOBase class identity
# __name__ == 'TextIOBase' (len=10), __module__ == 'io' (len=2)
# __bases__[0].__name__ == '_TextIOBase' (len=11)
# TextIOBase (10) > RawIOBase (9) by 1
# ---------------------------------------------------------------------------

table io_extra175.TextIOBase_class_identity:
  description: "io.TextIOBase class identity: __name__=='TextIOBase' (len=10), __module__=='io' (len=2), __bases__[0].__name__=='_TextIOBase' (len=11); 'TextIOBase'='Text'(4)+'IO'(2)+'Base'(4)=10; TextIOBase(10) > RawIOBase(9) by 1"
  kind: python_call_eq
  category: identity
  id_prefix: iotib175

  columns: [id, function, args, expected, description]
  rows:
    - [tib_name,     TextIOBase.__name__.__eq__,                ["TextIOBase"],   true, "io.TextIOBase.__name__ == 'TextIOBase' — TextIOBase is the abstract base class for text I/O streams (str-based); 'TextIOBase' has 10 characters: 'Text'(4)+'IO'(2)+'Base'(4)=10; TextIOBase (10) > RawIOBase (9) by 1: consecutive in the ABC name length sequence; TextIOBase (10) < BufferedIOBase (14) by 4 == len('Text') - (len('Buffered') - len('Text')) = 8 - 4 = 4: the 'Buffered' prefix (8 chars) is 4 chars longer than the 'Text' prefix (4 chars); the concrete text stream classes TextIOWrapper and StringIO both inherit from TextIOBase; TextIOBase (10 chars) == len('symlink_to') (10 chars) from the pathlib spec — a cross-module tie; confirmed Python 3.14.3 macOS"]
    - [tib_module,   TextIOBase.__module__.__eq__,              ["io"],            true, "io.TextIOBase.__module__ == 'io' — TextIOBase is a public ABC in the 'io' module (2 chars); TextIOBase.__module__ (2: 'io') == RawIOBase.__module__ (2: 'io') == BufferedIOBase.__module__ (2: 'io') == IOBase.__module__ (2: 'io'): all four io ABCs share the 2-character module name 'io'; TextIOBase.__module__ (2: 'io') != StringIO.__module__ (3: '_io'): the ABC reports 'io' (2 chars) while the concrete text stream StringIO reports '_io' (3 chars); 'io' (2 chars) is the minimum module name length in the io module family; confirmed Python 3.14.3 macOS"]
    - [tib_base0,    "TextIOBase.__bases__[0].__name__.__eq__",  ["_TextIOBase"],  true, "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' — TextIOBase's first C-level base is '_TextIOBase' (11 chars); '_TextIOBase' has 11 characters: '_'(1)+'Text'(4)+'IO'(2)+'Base'(4)=11; '_TextIOBase' (11 chars) == TextIOBase (10 chars) + 1: the C-level base name is 1 character longer due to the underscore prefix — the same +1 pattern holds for all four io ABC/C-base pairs: IOBase(6)/_IOBase(7), RawIOBase(9)/_RawIOBase(10), TextIOBase(10)/_TextIOBase(11), BufferedIOBase(14)/_BufferedIOBase(15); '_TextIOBase' (11 chars) == len('WindowsPath') (11) from pathlib_extra173 — a cross-module tie; confirmed Python 3.14.3 macOS"]
    - [tib_name_len, TextIOBase.__name__.__len__,               [],                10,   "io.TextIOBase.__name__.__len__() == 10 — 'TextIOBase' has 10 characters: 'Text'(4)+'IO'(2)+'Base'(4)=10; TextIOBase (10) is the third in the ascending ABC name length sequence: IOBase(6) < RawIOBase(9) < TextIOBase(10) < BufferedIOBase(14); the gap TextIOBase(10) - RawIOBase(9) == 1 is the smallest gap in the sequence — they are consecutive by 1; the gap BufferedIOBase(14) - TextIOBase(10) == 4 is the largest gap in the sequence; TextIOBase (10) == len('symlink_to') (10) — cross-module pathlib tie; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.IOBase class identity
# __name__ == 'IOBase' (len=6), __module__ == 'io' (len=2)
# __bases__[0].__name__ == '_IOBase' (len=7)
# IOBase is the root of the io ABC hierarchy
# ---------------------------------------------------------------------------

table io_extra175.IOBase_class_identity:
  description: "io.IOBase class identity: __name__=='IOBase' (len=6), __module__=='io' (len=2), __bases__[0].__name__=='_IOBase' (len=7); IOBase is the root of the io ABC hierarchy; 'IOBase'='IO'(2)+'Base'(4)=6; IOBase(6) is the shortest ABC name"
  kind: python_call_eq
  category: identity
  id_prefix: ioiob175

  columns: [id, function, args, expected, description]
  rows:
    - [iob_name,     IOBase.__name__.__eq__,                ["IOBase"],   true, "io.IOBase.__name__ == 'IOBase' — IOBase is the abstract root base class for all I/O streams in Python; 'IOBase' has 6 characters: 'IO'(2)+'Base'(4)=6; IOBase (6) is the minimum ABC name length in the ascending sequence: IOBase(6) < RawIOBase(9) < TextIOBase(10) < BufferedIOBase(14); IOBase defines the fundamental I/O interface: close(), closed, fileno(), flush(), isatty(), readable(), readline(), readlines(), seek(), seekable(), tell(), truncate(), writable(), writelines(); IOBase (6 chars) == len('Decimal') - 1 (7-1=6) and == len('object') (6) — a coincidental tie with the base Python type name; confirmed Python 3.14.3 macOS"]
    - [iob_module,   IOBase.__module__.__eq__,              ["io"],        true, "io.IOBase.__module__ == 'io' — IOBase is a public ABC in the 'io' module (2 chars); IOBase.__module__ (2: 'io') is the minimum module name length in the io module family; 'io' (2 chars) == len('io') == 2: the shortest standard library module name tied only with 're' (2 chars); IOBase.__module__ (2: 'io') is the same for all four io ABCs (IOBase, RawIOBase, BufferedIOBase, TextIOBase) — uniform 'io' module attribution for all abstract base classes; concrete classes (BytesIO, StringIO, FileIO, BufferedReader, etc.) report '__module__ == '_io'' (3 chars) instead; confirmed Python 3.14.3 macOS"]
    - [iob_base0,    "IOBase.__bases__[0].__name__.__eq__",  ["_IOBase"],  true, "io.IOBase.__bases__[0].__name__ == '_IOBase' — IOBase's C-level base is '_IOBase' (7 chars); '_IOBase' has 7 characters: '_'(1)+'IO'(2)+'Base'(4)=7; '_IOBase' (7 chars) == IOBase (6 chars) + 1: the C-level base is exactly 1 character longer due to the underscore prefix — the +1 underscore pattern is consistent across all four io ABC pairs; '_IOBase' (7 chars) is the deepest C-level root for all io streams: every I/O class in the io module ultimately descends from '_IOBase'; '_IOBase' (7 chars) == len('Decimal') == len('Context') == len('decimal') == 7 — a cross-module 7-character tie; confirmed Python 3.14.3 macOS"]
    - [iob_name_len, IOBase.__name__.__len__,               [],            6,    "io.IOBase.__name__.__len__() == 6 — 'IOBase' has 6 characters: 'IO'(2)+'Base'(4)=6; IOBase (6) is the minimum in the ascending ABC name length sequence: IOBase(6) < RawIOBase(9) < TextIOBase(10) < BufferedIOBase(14); IOBase (6) == len('object') (6): the root io ABC has the same name length as the Python root object class — a coincidental structural tie between the io hierarchy root and the Python type hierarchy root; the gap from IOBase (6) to RawIOBase (9) is 3 — the largest relative gap in the ascending sequence; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# ABC module distinction: io ABCs vs concrete classes
# All four ABCs have __module__ == 'io' (2 chars)
# All concrete classes have __module__ == '_io' (3 chars)
# The underscore prefix in '_io' marks the C extension implementation
# ---------------------------------------------------------------------------

table io_extra175.ABC_module_uniformity:
  description: "All four io ABCs (IOBase, RawIOBase, BufferedIOBase, TextIOBase) have __module__=='io' (2 chars); concrete classes (BytesIO, StringIO, BufferedReader) have __module__=='_io' (3 chars); ABC vs concrete module distinction: 'io'(2) vs '_io'(3) differ by 1"
  kind: python_call_eq
  category: identity
  id_prefix: iomod175

  columns: [id, function, args, expected, description]
  rows:
    - [iob_mod_io,    IOBase.__module__.__eq__,         ["io"],   true,  "io.IOBase.__module__ == 'io' — IOBase is a public ABC whose __module__ is 'io' (2 chars); the 2-character 'io' module is the public Python module for I/O classes; IOBase (root ABC) == RawIOBase.__module__ == TextIOBase.__module__ == BufferedIOBase.__module__ == 'io': all four ABCs share this 2-char module name; confirmed Python 3.14.3 macOS"]
    - [rab_mod_io,    RawIOBase.__module__.__eq__,      ["io"],   true,  "io.RawIOBase.__module__ == 'io' — RawIOBase is a public ABC with __module__ == 'io' (2 chars); RawIOBase.__module__ (2: 'io') confirms it is a Python-level abstract base defined in the public 'io' module, not in the C extension '_io' (3 chars); the public 'io' module (2 chars) hosts the four ABCs while '_io' (3 chars) hosts the concrete implementations; 'io' (2 chars) < '_io' (3 chars) by 1: the C extension module name is 1 character longer; confirmed Python 3.14.3 macOS"]
    - [tib_mod_io,    TextIOBase.__module__.__eq__,     ["io"],   true,  "io.TextIOBase.__module__ == 'io' — TextIOBase is a public ABC with __module__ == 'io' (2 chars); TextIOBase.__module__ (2: 'io') contrasts with the concrete text stream io.StringIO.__module__ (3: '_io'): the ABC is in 'io' while the concrete class is in '_io'; 'io' (2 chars) == 're' (2 chars) in module name length: the io and re modules tie for the shortest standard library module name at 2 characters; confirmed Python 3.14.3 macOS"]
    - [biob_mod_io,   BufferedIOBase.__module__.__eq__, ["io"],   true,  "io.BufferedIOBase.__module__ == 'io' — BufferedIOBase is a public ABC with __module__ == 'io' (2 chars); BufferedIOBase.__module__ (2: 'io') != BufferedReader.__module__ (3: '_io'): the ABC module differs from its concrete subclass module by the leading underscore; the ABC/concrete module split at 'io'/'_io' is a CPython architectural pattern: abstract class logic lives in pure Python ('io' module) while concrete high-performance implementations live in C ('_io' C extension); confirmed Python 3.14.3 macOS"]
    - [biob_ne_raw,   BufferedIOBase.__name__.__eq__,   ["RawIOBase"], false, "io.BufferedIOBase.__name__.__eq__('RawIOBase') == False — 'BufferedIOBase' (14 chars) != 'RawIOBase' (9 chars); BufferedIOBase (14) and RawIOBase (9) are sibling ABCs — both inherit from IOBase, but they represent different I/O categories: BufferedIOBase for buffered binary streams, RawIOBase for raw binary streams; BufferedIOBase (14) > RawIOBase (9) by 5: the 'Buffered' prefix (8 chars) is 5 characters longer than the 'Raw' prefix (3 chars); the False assertion encodes the binary I/O split between buffered and raw stream hierarchies; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra175.RawIOBase_name_is_RawIOBase:
  description: "io.RawIOBase.__name__ == 'RawIOBase' — RawIOBase is the abstract base class for raw binary I/O; 'RawIOBase' has 9 characters: 'Raw'(3)+'IO'(2)+'Base'(4)=9; RawIOBase (9) > IOBase (6) by 3 == len('Raw'): the 'Raw' prefix contributes exactly the 3-character difference; RawIOBase.__module__ == 'io' (2 chars) — ABC module, not '_io' (3 chars); RawIOBase.__bases__[0].__name__ == '_RawIOBase' (10 chars) — C-level base is 1 char longer; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: RawIOBase.__name__.__eq__
  args: ["RawIOBase"]
  expected: true

invariant io_extra175.RawIOBase_module_is_io:
  description: "io.RawIOBase.__module__ == 'io' — RawIOBase is an ABC in the public 'io' module; 'io' has 2 characters; RawIOBase.__module__ (2: 'io') differs from concrete subclass io.FileIO.__module__ (3: '_io'): the ABC is in 'io' while the concrete class is in '_io'; the 4 io ABCs (IOBase, RawIOBase, BufferedIOBase, TextIOBase) all share __module__ == 'io' (2 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: RawIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra175.RawIOBase_base_is__RawIOBase:
  description: "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' — the first C-level base of RawIOBase is '_RawIOBase' (10 chars); '_RawIOBase' = '_'(1)+'Raw'(3)+'IO'(2)+'Base'(4)=10; the +1 underscore pattern: RawIOBase(9) + 1 == '_RawIOBase'(10) — every io ABC name plus 1 equals the corresponding C-level base name; io.RawIOBase also has io.IOBase as its second base (bases[1]); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "RawIOBase.__bases__[0].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

invariant io_extra175.BufferedIOBase_name_is_BufferedIOBase:
  description: "io.BufferedIOBase.__name__ == 'BufferedIOBase' — BufferedIOBase is the abstract base for buffered binary streams; 'BufferedIOBase' has 14 characters: 'Buffered'(8)+'IO'(2)+'Base'(4)=14; BufferedIOBase (14) ties with BufferedReader (14), BufferedWriter (14), BufferedRandom (14) — a four-way 14-character tie including the ABC and all three concrete subclasses; BufferedIOBase (14) > TextIOBase (10) by 4; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BufferedIOBase.__name__.__eq__
  args: ["BufferedIOBase"]
  expected: true

invariant io_extra175.BufferedIOBase_base_is__BufferedIOBase:
  description: "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' — the first C-level base of BufferedIOBase is '_BufferedIOBase' (15 chars); '_BufferedIOBase' = '_'(1)+'Buffered'(8)+'IO'(2)+'Base'(4)=15; BufferedIOBase(14) + 1 == '_BufferedIOBase'(15) — the +1 underscore pattern; this same '_BufferedIOBase' is also the direct C-level base for BytesIO, BufferedReader, BufferedWriter, and BufferedRandom; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "BufferedIOBase.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra175.TextIOBase_name_is_TextIOBase:
  description: "io.TextIOBase.__name__ == 'TextIOBase' — TextIOBase is the abstract base for text I/O streams; 'TextIOBase' has 10 characters: 'Text'(4)+'IO'(2)+'Base'(4)=10; TextIOBase (10) > RawIOBase (9) by 1 — consecutive in the ABC name length sequence with the smallest gap; TextIOBase.__module__ == 'io' (2 chars) — ABC module; TextIOBase.__bases__[0].__name__ == '_TextIOBase' (11 chars) — C-level base is 1 char longer; TextIOWrapper and StringIO both inherit from TextIOBase; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: TextIOBase.__name__.__eq__
  args: ["TextIOBase"]
  expected: true

invariant io_extra175.TextIOBase_base_is__TextIOBase:
  description: "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' — the first C-level base of TextIOBase is '_TextIOBase' (11 chars); '_TextIOBase' = '_'(1)+'Text'(4)+'IO'(2)+'Base'(4)=11; TextIOBase(10) + 1 == '_TextIOBase'(11) — the +1 underscore pattern holds; '_TextIOBase' (11 chars) == len('WindowsPath') (11) from pathlib — a cross-module tie; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "TextIOBase.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra175.IOBase_name_is_IOBase:
  description: "io.IOBase.__name__ == 'IOBase' — IOBase is the root ABC for all io streams; 'IOBase' has 6 characters: 'IO'(2)+'Base'(4)=6; IOBase (6) is the minimum ABC name length in the sequence IOBase(6) < RawIOBase(9) < TextIOBase(10) < BufferedIOBase(14); IOBase (6) == len('object') (6): the root io ABC and the Python root class share the same 6-character name length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true
