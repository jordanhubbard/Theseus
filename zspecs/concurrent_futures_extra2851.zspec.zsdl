spec: cf2851
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [concurrent.futures source, Python docs, https://docs.python.org/3/library/concurrent.futures.html]
  not_derived_from: [any external dataset, concurrent_futures_extra284.zspec.zsdl, concurrent_futures_extra285.zspec.zsdl]
  notes: [Wave 637 theme — __rlshift__/__rrshift__/__rpow__ dict-presence checks for concurrent.futures types. Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor/CancelledError/TimeoutError/BrokenExecutor/InvalidStateError are concurrency primitives not numeric types — none define reflected shift or power operator dunders. All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

