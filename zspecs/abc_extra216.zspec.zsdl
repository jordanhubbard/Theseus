spec: abc_extra216
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.ABCMeta.__name__.__len__() == 7 ('ABCMeta' = 7 chars)."
    - "abc.ABC.__name__.__len__() == 3 ('ABC' = 3 chars)."
    - "abc.abstractmethod.__name__.__len__() == 14 ('abstractmethod' = 14 chars)."
    - "abc.get_cache_token.__name__.__len__() == 15 ('get_cache_token' = 15 chars)."
    - "abc.ABCMeta.__name__.__contains__('Meta') == True."
    - "abc.ABCMeta.__name__.__contains__('ABC') == True."
    - "abc.abstractmethod.__name__.__startswith__('abstract') == True."
    - "abc.abstractclassmethod.__name__.__startswith__('abstract') == True; __name__.__len__() == 19."
    - "abc.abstractstaticmethod.__name__.__startswith__('abstract') == True; __name__.__len__() == 20."
    - "abc.abstractproperty.__name__.__startswith__('abstract') == True; __name__.__len__() == 16."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc class name lengths — extra216 namespace
#
# ABCMeta (7), ABC (3), abstractmethod (14), get_cache_token (15).
# ---------------------------------------------------------------------------

table abc_extra216.abc_name_lengths:
  description: "abc module class and function __name__.__len__() checks in extra216 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc216namelen

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_name_len,        ABCMeta.__name__.__len__,         [], 7,  "abc.ABCMeta.__name__.__len__() == 7 ('ABCMeta'=7); verified with Python 3.14.3"]
    - [abc_name_len,            ABC.__name__.__len__,             [], 3,  "abc.ABC.__name__.__len__() == 3 ('ABC'=3); verified with Python 3.14.3"]
    - [abstractmethod_name_len, abstractmethod.__name__.__len__,  [], 14, "abc.abstractmethod.__name__.__len__() == 14 ('abstractmethod'=14); verified with Python 3.14.3"]
    - [getcachetoken_name_len,  get_cache_token.__name__.__len__, [], 15, "abc.get_cache_token.__name__.__len__() == 15 ('get_cache_token'=15); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__name__ contains 'Meta' and 'ABC' — extra216 namespace
# ---------------------------------------------------------------------------

table abc_extra216.abcmeta_name_contains:
  description: "abc.ABCMeta.__name__.__contains__() checks for 'Meta' and 'ABC' substrings in extra216 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc216metacontains

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_contains_meta, ABCMeta.__name__.__contains__, ["Meta"], true, "abc.ABCMeta.__name__.__contains__('Meta') == True — 'ABCMeta' contains 'Meta'; verified with Python 3.14.3"]
    - [abcmeta_contains_abc,  ABCMeta.__name__.__contains__, ["ABC"],  true, "abc.ABCMeta.__name__.__contains__('ABC') == True — 'ABCMeta' contains 'ABC'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abstract* names all start with 'abstract' — extra216 namespace
# ---------------------------------------------------------------------------

table abc_extra216.abstract_names_startswith:
  description: "abc abstract* __name__.__startswith__('abstract') checks in extra216 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc216abstrstarts

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_starts,       abstractmethod.__name__.__startswith__,       ["abstract"], true, "abc.abstractmethod.__name__.__startswith__('abstract') == True; verified with Python 3.14.3"]
    - [abstractclassmethod_starts,  abstractclassmethod.__name__.__startswith__,  ["abstract"], true, "abc.abstractclassmethod.__name__.__startswith__('abstract') == True; verified with Python 3.14.3"]
    - [abstractstaticmethod_starts, abstractstaticmethod.__name__.__startswith__, ["abstract"], true, "abc.abstractstaticmethod.__name__.__startswith__('abstract') == True; verified with Python 3.14.3"]
    - [abstractproperty_starts,     abstractproperty.__name__.__startswith__,     ["abstract"], true, "abc.abstractproperty.__name__.__startswith__('abstract') == True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# deprecated abstract* class name lengths — extra216 namespace
# ---------------------------------------------------------------------------

invariant abc_extra216.abstractclassmethod_name_len:
  description: "abc.abstractclassmethod.__name__.__len__() == 19 ('abstractclassmethod' = 19 chars); deprecated since Python 3.3 but present in 3.14.3; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractclassmethod.__name__.__len__
  args: []
  expected: 19

invariant abc_extra216.abstractstaticmethod_name_len:
  description: "abc.abstractstaticmethod.__name__.__len__() == 20 ('abstractstaticmethod' = 20 chars); deprecated since Python 3.3 but present in 3.14.3; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractstaticmethod.__name__.__len__
  args: []
  expected: 20

invariant abc_extra216.abstractproperty_name_len:
  description: "abc.abstractproperty.__name__.__len__() == 16 ('abstractproperty' = 16 chars); deprecated since Python 3.3 but present in 3.14.3; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractproperty.__name__.__len__
  args: []
  expected: 16
