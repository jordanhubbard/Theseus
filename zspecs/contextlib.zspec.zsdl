spec: contextlib
version: ">=3.10"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "Python contextlib documentation — https://docs.python.org/3/library/contextlib.html"
    - "Test vectors verified by running Python 3.14.3 contextlib module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "contextlib.nullcontext(enter_result) returns a context manager whose __enter__ returns enter_result."
    - "contextlib.nullcontext() with no argument returns None from __enter__."
    - "contextlib.nullcontext.__exit__ always returns None (falsy), never suppressing exceptions."
    - "contextlib.suppress(*exceptions) is a context manager that silently swallows the listed exception types."
    - "contextlib.closing(thing) is a context manager that calls thing.close() on exit."
    - "contextlib.ExitStack.__enter__ returns self (the ExitStack instance)."
    - "contextlib.redirect_stdout and redirect_stderr redirect sys.stdout/stderr to a given file-like object."
    - "contextlib.AbstractContextManager is the ABC for synchronous context managers."
    - "contextlib.asynccontextmanager and contextlib.AsyncExitStack are async variants."
    - "All expected values verified by running Python 3.14.3 on macOS Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class / function name metadata
# ---------------------------------------------------------------------------

invariant contextlib.contextmanager.name:
  description: "contextlib.contextmanager.__name__ == 'contextmanager'"
  category: class_names
  kind: python_call_eq
  function: contextmanager.__name__.__eq__
  args: ["contextmanager"]
  expected: true

invariant contextlib.suppress.name:
  description: "contextlib.suppress.__name__ == 'suppress'"
  category: class_names
  kind: python_call_eq
  function: suppress.__name__.__eq__
  args: ["suppress"]
  expected: true

invariant contextlib.exitstack.name:
  description: "contextlib.ExitStack.__name__ == 'ExitStack'"
  category: class_names
  kind: python_call_eq
  function: ExitStack.__name__.__eq__
  args: ["ExitStack"]
  expected: true

invariant contextlib.closing.name:
  description: "contextlib.closing.__name__ == 'closing'"
  category: class_names
  kind: python_call_eq
  function: closing.__name__.__eq__
  args: ["closing"]
  expected: true

invariant contextlib.redirect_stdout.name:
  description: "contextlib.redirect_stdout.__name__ == 'redirect_stdout'"
  category: class_names
  kind: python_call_eq
  function: redirect_stdout.__name__.__eq__
  args: ["redirect_stdout"]
  expected: true

invariant contextlib.redirect_stderr.name:
  description: "contextlib.redirect_stderr.__name__ == 'redirect_stderr'"
  category: class_names
  kind: python_call_eq
  function: redirect_stderr.__name__.__eq__
  args: ["redirect_stderr"]
  expected: true

invariant contextlib.nullcontext.name:
  description: "contextlib.nullcontext.__name__ == 'nullcontext'"
  category: class_names
  kind: python_call_eq
  function: nullcontext.__name__.__eq__
  args: ["nullcontext"]
  expected: true

invariant contextlib.asyncexitstack.name:
  description: "contextlib.AsyncExitStack.__name__ == 'AsyncExitStack'"
  category: class_names
  kind: python_call_eq
  function: AsyncExitStack.__name__.__eq__
  args: ["AsyncExitStack"]
  expected: true

invariant contextlib.abstractcontextmanager.name:
  description: "contextlib.AbstractContextManager.__name__ == 'AbstractContextManager'"
  category: class_names
  kind: python_call_eq
  function: AbstractContextManager.__name__.__eq__
  args: ["AbstractContextManager"]
  expected: true

invariant contextlib.asynccontextmanager.name:
  description: "contextlib.asynccontextmanager.__name__ == 'asynccontextmanager'"
  category: class_names
  kind: python_call_eq
  function: asynccontextmanager.__name__.__eq__
  args: ["asynccontextmanager"]
  expected: true

# ---------------------------------------------------------------------------
# nullcontext — __enter__ returns the given enter_result
#
# nullcontext(value).__enter__() == value for any JSON-representable value.
# nullcontext() with no argument returns None from __enter__.
# ---------------------------------------------------------------------------

invariant contextlib.nullcontext.enter_int:
  description: "contextlib.nullcontext(42).__enter__() == 42"
  category: nullcontext
  kind: python_call_eq
  function: nullcontext
  args: [42]
  method: __enter__
  expected: 42

invariant contextlib.nullcontext.enter_string:
  description: "contextlib.nullcontext('hello').__enter__() == 'hello'"
  category: nullcontext
  kind: python_call_eq
  function: nullcontext
  args: ["hello"]
  method: __enter__
  expected: "hello"

invariant contextlib.nullcontext.enter_none_explicit:
  description: "contextlib.nullcontext(None).__enter__() == None"
  category: nullcontext
  kind: python_call_eq
  function: nullcontext
  args: [null]
  method: __enter__
  expected: null

invariant contextlib.nullcontext.enter_no_arg:
  description: "contextlib.nullcontext().__enter__() == None (default enter_result is None)"
  category: nullcontext
  kind: python_call_eq
  function: nullcontext
  args: []
  method: __enter__
  expected: null

invariant contextlib.nullcontext.enter_float:
  description: "contextlib.nullcontext(3.14).__enter__() == 3.14"
  category: nullcontext
  kind: python_call_eq
  function: nullcontext
  args: [3.14]
  method: __enter__
  expected: 3.14

invariant contextlib.nullcontext.enter_true:
  description: "contextlib.nullcontext(True).__enter__() == True"
  category: nullcontext
  kind: python_call_eq
  function: nullcontext
  args: [true]
  method: __enter__
  expected: true

invariant contextlib.nullcontext.enter_list:
  description: "contextlib.nullcontext([1,2,3]).__enter__() == [1,2,3]"
  category: nullcontext
  kind: python_call_eq
  function: nullcontext
  args: [[1, 2, 3]]
  method: __enter__
  expected: [1, 2, 3]

# ---------------------------------------------------------------------------
# nullcontext — __exit__ always returns None (falsy, does not suppress exceptions)
# ---------------------------------------------------------------------------

invariant contextlib.nullcontext.exit_returns_none:
  description: "contextlib.nullcontext(99).__exit__(None,None,None) is None"
  category: nullcontext
  kind: python_call_eq
  function: nullcontext
  args: [99]
  method: __exit__
  method_args: [null, null, null]
  expected: null
