spec: is_present
version: ">=1.0.0"
backend: node(is-present)

docs: https://www.npmjs.com/package/is-present

provenance:
  derived_from:
    - "is-present README — https://www.npmjs.com/package/is-present"
    - "Test vectors verified with is-present via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "is-present source"
  notes:
    - "is-present is an npm package. Install: npm install is-present"
    - "Returns true if the value has non-whitespace content (opposite of is-blank)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_present.check:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: ispres

  columns: [id, args, expected]
  rows:
    - [text,    ["hello"],   true]
    - [empty,   [""],        false]
    - [spaces,  ["   "],     false]
    - [null_v,  [null],      false]
