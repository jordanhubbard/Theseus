spec: hashlib_extra2821
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra2806.zspec.zsdl — covers __ilshift__, __irshift__, and __ipow__ absence for HASH, blake2b, blake2s."
    - "hashlib_extra2791.zspec.zsdl — covers __iand__, __ior__, and __ixor__ absence for HASH, blake2b, blake2s."
    - "hashlib_extra2776.zspec.zsdl — covers __isub__, __imul__, and __itruediv__ absence for HASH, blake2b, blake2s."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "hashlib.HASH.__dict__.__contains__('__radd__') == False — HASH (the OpenSSL-backed C type) does not define the reflected addition operator; cryptographic hash objects are not numeric operands; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.HASH.__dict__.__contains__('__rsub__') == False — HASH does not define the reflected subtraction operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.HASH.__dict__.__contains__('__rmul__') == False — HASH does not define the reflected multiplication operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__radd__') == False — blake2b does not define the reflected addition operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__rsub__') == False — blake2b does not define the reflected subtraction operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__rmul__') == False — blake2b does not define the reflected multiplication operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__radd__') == False — blake2s does not define the reflected addition operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__rsub__') == False — blake2s does not define the reflected subtraction operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__rmul__') == False — blake2s does not define the reflected multiplication operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: hashlib.HASH.__dict__ — __radd__, __rsub__, __rmul__ absence
# HASH is the C type for OpenSSL-backed hash objects (sha256, md5, sha1, etc.).
# Reflected arithmetic operators (__radd__, __rsub__, __rmul__) are invoked when
# the left operand does not support the operation; hash digest objects are
# cryptographic primitives, not numeric operands, so none of these are defined.
# ---------------------------------------------------------------------------

table hashlib_extra2821.hash_dict_radd_rsub_rmul:
  description: "hashlib.HASH.__dict__ does not contain __radd__, __rsub__, or __rmul__ — HASH is a cryptographic digest type, not a numeric operand; reflected arithmetic operators are absent; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2821

  columns: [id, function, args, expected]
  rows:
    - ["hl2821-hash-radd", hashlib.HASH.__dict__.__contains__, ["__radd__"], false]
    - ["hl2821-hash-rsub", hashlib.HASH.__dict__.__contains__, ["__rsub__"], false]
    - ["hl2821-hash-rmul", hashlib.HASH.__dict__.__contains__, ["__rmul__"], false]

# ---------------------------------------------------------------------------
# Table 2: hashlib.blake2b.__dict__ — __radd__, __rsub__, __rmul__ absence
# blake2b is the C type for BLAKE2b hash objects.
# Like HASH, it defines no reflected arithmetic operators.
# ---------------------------------------------------------------------------

table hashlib_extra2821.blake2b_dict_radd_rsub_rmul:
  description: "hashlib.blake2b.__dict__ does not contain __radd__, __rsub__, or __rmul__ — the BLAKE2b hash type defines no reflected arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2821

  columns: [id, function, args, expected]
  rows:
    - ["hl2821-b2b-radd", hashlib.blake2b.__dict__.__contains__, ["__radd__"], false]
    - ["hl2821-b2b-rsub", hashlib.blake2b.__dict__.__contains__, ["__rsub__"], false]
    - ["hl2821-b2b-rmul", hashlib.blake2b.__dict__.__contains__, ["__rmul__"], false]

# ---------------------------------------------------------------------------
# Table 3: hashlib.blake2s.__dict__ — __radd__, __rsub__, __rmul__ absence
# blake2s is the C type for BLAKE2s hash objects.
# Like HASH and blake2b, it defines no reflected arithmetic operators.
# ---------------------------------------------------------------------------

table hashlib_extra2821.blake2s_dict_radd_rsub_rmul:
  description: "hashlib.blake2s.__dict__ does not contain __radd__, __rsub__, or __rmul__ — the BLAKE2s hash type defines no reflected arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2821

  columns: [id, function, args, expected]
  rows:
    - ["hl2821-b2s-radd", hashlib.blake2s.__dict__.__contains__, ["__radd__"], false]
    - ["hl2821-b2s-rsub", hashlib.blake2s.__dict__.__contains__, ["__rsub__"], false]
    - ["hl2821-b2s-rmul", hashlib.blake2s.__dict__.__contains__, ["__rmul__"], false]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — all three hash types absent for all three dunders
# Consolidates one row per (type, dunder) pair for easy cross-type comparison.
# ---------------------------------------------------------------------------

table hashlib_extra2821.all_types_all_dunders_absent:
  description: "HASH, blake2b, and blake2s all lack __radd__, __rsub__, and __rmul__ in __dict__ — no hashlib hash type defines reflected addition, subtraction, or multiplication operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2821

  columns: [id, function, args, expected]
  rows:
    - ["hl2821-x-hash-radd", hashlib.HASH.__dict__.__contains__,    ["__radd__"], false]
    - ["hl2821-x-hash-rsub", hashlib.HASH.__dict__.__contains__,    ["__rsub__"], false]
    - ["hl2821-x-hash-rmul", hashlib.HASH.__dict__.__contains__,    ["__rmul__"], false]
    - ["hl2821-x-b2b-radd",  hashlib.blake2b.__dict__.__contains__, ["__radd__"], false]
    - ["hl2821-x-b2b-rsub",  hashlib.blake2b.__dict__.__contains__, ["__rsub__"], false]
    - ["hl2821-x-b2b-rmul",  hashlib.blake2b.__dict__.__contains__, ["__rmul__"], false]
    - ["hl2821-x-b2s-radd",  hashlib.blake2s.__dict__.__contains__, ["__radd__"], false]
    - ["hl2821-x-b2s-rsub",  hashlib.blake2s.__dict__.__contains__, ["__rsub__"], false]
    - ["hl2821-x-b2s-rmul",  hashlib.blake2s.__dict__.__contains__, ["__rmul__"], false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra2821.hash_no_radd:
  description: "hashlib.HASH.__dict__.__contains__('__radd__') == False — HASH (OpenSSL-backed C type) does not define the reflected addition operator; hash objects are cryptographic primitives, not numeric operands; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: hashlib.HASH.__dict__.__contains__
  args: ["__radd__"]
  expected: false

