spec: dataclasses_rust
version: ">=3.9"
backend: rust_module(dataclasses_rust)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses documentation"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "Python dataclasses module with pre-wired Point(x, y) and Color(r, g, b) dataclasses."
    - "Expose make_point_dict(x, y) -> dict: returns asdict(Point(x, y)) == {'x': x, 'y': y}."
    - "Expose make_point_tuple(x, y) -> list: returns list(astuple(Point(x, y))) == [x, y]."
    - "Expose point_field_count() -> int: returns len(fields(Point)) == 2."
    - "Expose make_color_dict(r, g, b) -> dict: returns asdict(Color(r, g, b)) == {'r': r, 'g': g, 'b': b}."
    - "Expose color_field_names() -> list[str]: returns [f.name for f in fields(Color)] == ['r', 'g', 'b']."
    - "All test vectors verified against Python 3.14.3 dataclasses module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# make_point_dict — asdict for Point(x, y)
table dataclasses_rust.point.asdict:
  kind: python_call_eq
  category: asdict
  id_prefix: dc_pd
  function: make_point_dict

  columns: [id, args, expected]
  rows:
    - [origin,    [0, 0],   {x: 0, y: 0}]
    - [unit,      [1, 2],   {x: 1, y: 2}]
    - [negative,  [-3, 4],  {x: -3, y: 4}]
    - [large,     [100, 200], {x: 100, y: 200}]

# make_point_tuple — astuple for Point(x, y) as list
table dataclasses_rust.point.astuple:
  kind: python_call_eq
  category: astuple
  id_prefix: dc_pt
  function: make_point_tuple

  columns: [id, args, expected]
  rows:
    - [origin,   [0, 0],  [0, 0]]
    - [unit,     [1, 2],  [1, 2]]
    - [mixed,    [3, -5], [3, -5]]

# point_field_count — len(fields(Point))
invariant dataclasses_rust.point.field_count:
  description: "Point dataclass has exactly 2 fields: x and y"
  category: fields
  kind: python_call_eq
  function: point_field_count
  args: []
  expected: 2

# make_color_dict — asdict for Color(r, g, b)
table dataclasses_rust.color.asdict:
  kind: python_call_eq
  category: asdict
  id_prefix: dc_cd
  function: make_color_dict

  columns: [id, args, expected]
  rows:
    - [black,    [0, 0, 0],       {r: 0, g: 0, b: 0}]
    - [white,    [255, 255, 255], {r: 255, g: 255, b: 255}]
    - [red,      [255, 0, 0],    {r: 255, g: 0, b: 0}]

# color_field_names — [f.name for f in fields(Color)]
invariant dataclasses_rust.color.field_names:
  description: "Color fields are ['r', 'g', 'b']"
  category: fields
  kind: python_call_eq
  function: color_field_names
  args: []
  expected: ["r", "g", "b"]

