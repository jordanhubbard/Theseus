spec: io_extra236
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/fileio.c"
  notes:
    - "This spec covers: io.DEFAULT_BUFFER_SIZE constant value and class, io.SEEK_SET/SEEK_CUR/SEEK_END seek mode integer constants, and io.UnsupportedOperation identity contracts."
    - "io.DEFAULT_BUFFER_SIZE == 131072 — platform default I/O buffer size in bytes (128 KiB); verified Python 3.14.3 macOS."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — the constant is an int; verified Python 3.14.3 macOS."
    - "io.DEFAULT_BUFFER_SIZE.__gt__(0) == True — buffer size is always positive; verified Python 3.14.3 macOS."
    - "io.SEEK_SET == 0 — seek from start of stream; verified Python 3.14.3 macOS."
    - "io.SEEK_CUR == 1 — seek from current stream position; verified Python 3.14.3 macOS."
    - "io.SEEK_END == 2 — seek from end of stream; verified Python 3.14.3 macOS."
    - "io.SEEK_SET.__class__.__name__ == 'int' — seek constants are plain int; verified Python 3.14.3 macOS."
    - "io.UnsupportedOperation.__name__ == 'UnsupportedOperation' — class name string; verified Python 3.14.3 macOS."
    - "io.UnsupportedOperation.__module__ == 'io' — module reported as public 'io'; verified Python 3.14.3 macOS."
    - "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — first base class is OSError; verified Python 3.14.3 macOS."
    - "io.UnsupportedOperation.__bases__[1].__name__ == 'ValueError' — second base class is ValueError; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE constant contracts
# Value is 131072 (128 KiB), type int, positive.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra236.DEFAULT_BUFFER_SIZE.value:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 — default I/O buffer size is 131072 bytes (128 KiB) on this platform; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true

invariant io_extra236.DEFAULT_BUFFER_SIZE.class_name:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — DEFAULT_BUFFER_SIZE is a plain int constant; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra236.DEFAULT_BUFFER_SIZE.positive:
  description: "io.DEFAULT_BUFFER_SIZE.__gt__(0) == True — DEFAULT_BUFFER_SIZE is always a positive integer; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__gt__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# io seek mode constants
# SEEK_SET=0, SEEK_CUR=1, SEEK_END=2, all plain int.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra236.seek_constants:
  description: "io seek mode integer constant contracts — SEEK_SET=0, SEEK_CUR=1, SEEK_END=2; verified with Python 3.14.3"
  kind: python_call_eq
  category: constant
  id_prefix: ioseekconst236

  columns: [id, function, args, expected]
  rows:
    - [seek_set_val,  SEEK_SET.__eq__,  [0], true]
    - [seek_cur_val,  SEEK_CUR.__eq__,  [1], true]
    - [seek_end_val,  SEEK_END.__eq__,  [2], true]

invariant io_extra236.SEEK_SET.class_name:
  description: "io.SEEK_SET.__class__.__name__ == 'int' — seek mode constants are plain int values; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: SEEK_SET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# io.UnsupportedOperation identity contracts
# Name, module, and base classes (OSError, ValueError).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra236.UnsupportedOperation.name:
  description: "io.UnsupportedOperation.__name__ == 'UnsupportedOperation' — class name string identity; verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: UnsupportedOperation.__name__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

invariant io_extra236.UnsupportedOperation.module:
  description: "io.UnsupportedOperation.__module__ == 'io' — UnsupportedOperation reports its module as the public 'io' wrapper; verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: UnsupportedOperation.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra236.UnsupportedOperation.base0_oserror:
  description: "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — first base class is OSError; verified Python 3.14.3 macOS"
  category: hierarchy
  kind: python_call_eq
  function: "UnsupportedOperation.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

invariant io_extra236.UnsupportedOperation.base1_valueerror:
  description: "io.UnsupportedOperation.__bases__[1].__name__ == 'ValueError' — second base class is ValueError (multiple inheritance); verified Python 3.14.3 macOS"
  category: hierarchy
  kind: python_call_eq
  function: "UnsupportedOperation.__bases__[1].__name__.__eq__"
  args: ["ValueError"]
  expected: true
