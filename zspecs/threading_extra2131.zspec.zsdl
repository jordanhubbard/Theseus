spec: threading_extra2131
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 2131 (_extra2131): exception protocol dict-presence checks — __cause__, __context__, __traceback__, __suppress_context__, __notes__, args, with_traceback in class __dict__ for threading types."
    - "Theme: exception protocol dict-presence — checking whether exception-related attributes are defined at the class level in __dict__ for threading synchronization and exception types."
    - "threading has two exception types: threading.BrokenBarrierError (subclass of RuntimeError) and threading.ThreadError (subclass of Exception)."
    - "For exception types (BrokenBarrierError, ThreadError): __cause__, __context__, __traceback__, __suppress_context__, __notes__, args, and with_traceback are all absent from the class __dict__. These are instance-level attributes set by the interpreter when exceptions are raised, not class-level entries."
    - "threading.Thread, Lock, Condition, Semaphore, BoundedSemaphore, Event, Barrier are synchronization/lifecycle types — not exception types. None define any exception-protocol attributes in __dict__."
    - "threading.Timer is a Thread subclass for delayed invocation — not an exception type."
    - "threading.local provides thread-local storage — not an exception type."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: exception protocol dict-presence for threading exception types
#
# threading.BrokenBarrierError subclasses RuntimeError.
# threading.ThreadError subclasses Exception.
# Even though these ARE exception types, the exception protocol attributes
# (__cause__, __context__, __traceback__, etc.) are NOT class-level __dict__
# entries — they are set on instances at raise time by the interpreter.
# args and with_traceback are inherited from BaseException instances, not
# overridden at the class level in these subclasses.
# ---------------------------------------------------------------------------

table threading_extra2131.exception_protocol:
  description: "threading exception types (BrokenBarrierError, ThreadError) exception-protocol dict-presence checks — all False (instance-level, not class-level)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2131

  columns: [id, function, args, expected]
  rows:
    - ["th2131001", "threading.BrokenBarrierError.__dict__.__contains__", ["__cause__"],            false]
    - ["th2131002", "threading.BrokenBarrierError.__dict__.__contains__", ["__context__"],          false]
    - ["th2131003", "threading.BrokenBarrierError.__dict__.__contains__", ["__traceback__"],        false]
    - ["th2131004", "threading.BrokenBarrierError.__dict__.__contains__", ["__suppress_context__"], false]
    - ["th2131005", "threading.BrokenBarrierError.__dict__.__contains__", ["__notes__"],            false]
    - ["th2131006", "threading.BrokenBarrierError.__dict__.__contains__", ["args"],                 false]
    - ["th2131007", "threading.BrokenBarrierError.__dict__.__contains__", ["with_traceback"],       false]
    - ["th2131008", "threading.ThreadError.__dict__.__contains__",        ["__cause__"],            false]
    - ["th2131009", "threading.ThreadError.__dict__.__contains__",        ["__context__"],          false]
    - ["th2131010", "threading.ThreadError.__dict__.__contains__",        ["__traceback__"],        false]
    - ["th2131011", "threading.ThreadError.__dict__.__contains__",        ["__suppress_context__"], false]
    - ["th2131012", "threading.ThreadError.__dict__.__contains__",        ["__notes__"],            false]
    - ["th2131013", "threading.ThreadError.__dict__.__contains__",        ["args"],                 false]
    - ["th2131014", "threading.ThreadError.__dict__.__contains__",        ["with_traceback"],       false]

# ---------------------------------------------------------------------------
# Table 2: exception protocol dict-presence for threading synchronization types
#
# Thread, Condition, Semaphore, BoundedSemaphore, Event, Barrier, Lock —
# none are exception types and none carry exception-protocol attributes in
# their class __dict__.
# ---------------------------------------------------------------------------

table threading_extra2131.non_exception_types:
  description: "threading synchronization types (Thread, Condition, Semaphore, BoundedSemaphore, Event, Barrier) exception-protocol dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2131

  columns: [id, function, args, expected]
  rows:
    - ["th2131015", "threading.Thread.__dict__.__contains__",           ["__cause__"],            false]
    - ["th2131016", "threading.Thread.__dict__.__contains__",           ["__context__"],          false]
    - ["th2131017", "threading.Thread.__dict__.__contains__",           ["__traceback__"],        false]
    - ["th2131018", "threading.Thread.__dict__.__contains__",           ["__suppress_context__"], false]
    - ["th2131019", "threading.Thread.__dict__.__contains__",           ["__notes__"],            false]
    - ["th2131020", "threading.Thread.__dict__.__contains__",           ["args"],                 false]
    - ["th2131021", "threading.Thread.__dict__.__contains__",           ["with_traceback"],       false]
    - ["th2131022", "threading.Condition.__dict__.__contains__",        ["__cause__"],            false]
    - ["th2131023", "threading.Condition.__dict__.__contains__",        ["__context__"],          false]
    - ["th2131024", "threading.Condition.__dict__.__contains__",        ["__traceback__"],        false]
    - ["th2131025", "threading.Condition.__dict__.__contains__",        ["__suppress_context__"], false]
    - ["th2131026", "threading.Condition.__dict__.__contains__",        ["args"],                 false]
    - ["th2131027", "threading.Condition.__dict__.__contains__",        ["with_traceback"],       false]
    - ["th2131028", "threading.Semaphore.__dict__.__contains__",        ["__cause__"],            false]
    - ["th2131029", "threading.Semaphore.__dict__.__contains__",        ["__context__"],          false]
    - ["th2131030", "threading.Semaphore.__dict__.__contains__",        ["args"],                 false]
    - ["th2131031", "threading.Semaphore.__dict__.__contains__",        ["with_traceback"],       false]

# ---------------------------------------------------------------------------
# Table 3: exception protocol dict-presence for remaining threading types
#
# BoundedSemaphore, Event, Barrier, Lock, Timer, local — completing the
# survey of threading non-exception types.
# ---------------------------------------------------------------------------

table threading_extra2131.remaining_non_exception_types:
  description: "threading remaining non-exception types (BoundedSemaphore, Event, Barrier, Lock, Timer, local) exception-protocol dict-presence checks — all False"
