spec: typing_extra26
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing_extra25.zspec.zsdl."
    - "Focus: __qualname__ values for TypeVar instance methods and module-level functions (get_type_hints, get_args, get_origin, cast, overload) not yet collected in a combined table in the extra26 namespace."
    - "typing_extra23 covers combined __qualname__.__eq__ table for overload/final/no_type_check/cast in the extra23 namespace."
    - "typing_extra21 covers __name__ and __module__ for cast/overload/get_type_hints."
    - "typing_extra22 covers combined __qualname__ table for Generic/TypeVar/ParamSpec/TypeVarTuple."
    - "No prior spec records TypeVar.__repr__.__qualname__ or a combined table of function __qualname__.__len__ for get_type_hints/get_args/get_origin/cast/overload in the extra26 namespace."
    - "TypeVar.__init__.__qualname__ is 'object.__init__' (inherited from object, not overridden in TypeVar)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TypeVar.__repr__.__qualname__ — standalone invariant
#
# TypeVar defines its own __repr__; its __qualname__ is 'TypeVar.__repr__'.
# typing_extra22 covers TypeVar.__qualname__ (the class) in a combined table,
# but no prior spec records TypeVar.__repr__.__qualname__ directly.
# ---------------------------------------------------------------------------

invariant typing_extra26.TypeVar.repr_qualname:
  description: "typing.TypeVar.__repr__.__qualname__ == 'TypeVar.__repr__' — TypeVar defines its own __repr__"
  category: method_qualnames
  kind: python_call_eq
  function: "TypeVar.__repr__.__qualname__.__eq__"
  args: ["TypeVar.__repr__"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function __qualname__ values — combined table
#
# get_type_hints, get_args, get_origin, cast, overload are all defined at
# module level in typing; each has __qualname__ equal to its own name.
# typing_extra23 covers cast and overload __qualname__.__eq__ in a combined
# table in the extra23 namespace. No prior spec combines all five in a single
# table in the extra26 namespace.
# ---------------------------------------------------------------------------

table typing_extra26.function_qualnames:
  description: "__qualname__.__eq__ for typing module-level functions"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [get_type_hints, "get_type_hints.__qualname__.__eq__", ["get_type_hints"], true]
    - [get_args,       "get_args.__qualname__.__eq__",       ["get_args"],       true]
    - [get_origin,     "get_origin.__qualname__.__eq__",     ["get_origin"],     true]
    - [cast,           "cast.__qualname__.__eq__",           ["cast"],           true]
    - [overload,       "overload.__qualname__.__eq__",       ["overload"],       true]

# ---------------------------------------------------------------------------
# Module-level function __qualname__.__len__() values — combined table
#
# Verifies the string length of each __qualname__:
#   get_type_hints -> 14, get_args -> 8, get_origin -> 10, cast -> 4, overload -> 8
# No prior typing spec collects these five qualname lengths in a single table
# in the extra26 namespace.
# ---------------------------------------------------------------------------

table typing_extra26.function_qualname_lens:
  description: "__qualname__.__len__() for typing module-level functions"
  kind: python_call_eq
  category: function_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [get_type_hints, "get_type_hints.__qualname__.__len__", [], 14]
    - [get_args,       "get_args.__qualname__.__len__",       [],  8]
    - [get_origin,     "get_origin.__qualname__.__len__",     [], 10]
    - [cast,           "cast.__qualname__.__len__",           [],  4]
    - [overload,       "overload.__qualname__.__len__",       [],  8]

# ---------------------------------------------------------------------------
# TypeVar.__repr__.__qualname__.__len__() == 16 — standalone invariant
#
# len('TypeVar.__repr__') == 16.
# No prior typing spec records this length in the extra26 namespace.
# ---------------------------------------------------------------------------

invariant typing_extra26.TypeVar.repr_qualname_len:
  description: "len(typing.TypeVar.__repr__.__qualname__) == 16 — len('TypeVar.__repr__') == 16"
  category: method_qualname_lengths
  kind: python_call_eq
  function: "TypeVar.__repr__.__qualname__.__len__"
  args: []
  expected: 16
