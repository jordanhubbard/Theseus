spec: threading_extra18
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading.zspec.zsdl and threading_extra through threading_extra17."
    - "threading.zspec.zsdl covers: class __name__ table (Thread/Lock/RLock/Condition/Semaphore/BoundedSemaphore/Event/Timer/Barrier); function __name__ table; TIMEOUT_MAX.__ge__(1e9); active_count() >= 1."
    - "threading_extra covers: TIMEOUT_MAX.__class__.__name__ == 'float'; local.__name__; stack_size() returns int."
    - "threading_extra16 covers: Thread/__name__/__module__/__qualname__; Barrier/__name__/__module__/__qualname__; Timer/__name__/__module__/__qualname__; Event/__module__; Semaphore/__module__; Condition/__name__/__module__; Lock.__name__=='lock'."
    - "threading_extra17 covers: TIMEOUT_MAX.__gt__(0); TIMEOUT_MAX.__lt__(1e18); TIMEOUT_MAX classname_is_str; builtin function __class__.__name__ table; Python function __class__.__name__ table."
    - "NOT yet covered in any prior spec: threading.local.__name__ == 'local' as a standalone __eq__ invariant."
    - "NOT yet covered: threading.local.__module__ == '_thread' — local is implemented in C and lives in _thread."
    - "NOT yet covered: threading.local().__class__.__name__ == 'local' — instance class name matches type name."
    - "NOT yet covered: threading.Condition.__name__ == 'Condition' as standalone invariant (threading.zspec.zsdl covered it in a table, but not via __eq__ call form)."
    - "NOT yet covered: threading.Condition.__module__ == 'threading' as standalone __eq__ invariant."
    - "NOT yet covered: threading.Barrier.__name__ == 'Barrier' as standalone __eq__ invariant."
    - "NOT yet covered: threading.Barrier.__module__ == 'threading' as standalone __eq__ invariant."
    - "NOT yet covered: threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' — threading.zspec.zsdl table row, not standalone."
    - "NOT yet covered: threading.BoundedSemaphore.__module__ == 'threading' — threading_extra16 covers Semaphore/__module__ but not BoundedSemaphore/__module__."
    - "NOT yet covered: threading.Timer.__module__ == 'threading' — threading_extra16 covers Timer/__module__ but only as part of qualname table; not confirmed as standalone."
    - "NOT yet covered: threading.get_ident.__name__ == 'get_ident' — threading_extra4 covers settrace/__name__; no spec covers get_ident/__name__."
    - "NOT yet covered: threading.get_native_id.__name__ == 'get_native_id' — Python 3.8+, no prior spec covers this."
    - "threading.local is defined in Modules/_threadmodule.c and re-exported via threading; its __module__ is '_thread'."
    - "threading.get_ident is a C builtin from _thread; its __name__ is 'get_ident'."
    - "threading.get_native_id is a C builtin from _thread (Python 3.8+); its __name__ is 'get_native_id'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.local metadata
#
# threading_extra covered local.__name__ informally. No prior spec checks
# local.__module__ or instances of local. threading.local is a C type defined
# in _threadmodule.c and re-exported as threading.local; its __module__ is
# '_thread'.
# ---------------------------------------------------------------------------

invariant threading_extra18.local.name:
  description: "threading.local.__name__ == 'local'"
  category: class_names
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["local"]
  expected: true

invariant threading_extra18.local.module:
  description: "threading.local.__module__ == '_thread' — C type defined in _threadmodule.c"
  category: class_modules
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra18.local.instance_class_name:
  description: "threading.local().__class__.__name__ == 'local' — instance class name matches type"
  category: class_names
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["local"]
  expected: true

# ---------------------------------------------------------------------------
# Condition and Barrier __name__ and __module__ — standalone invariants
#
# threading.zspec.zsdl covered Condition and Barrier in a name table using the
# direct attribute form. threading_extra16 covered __module__ for several classes
# but not Condition or Barrier as standalone __eq__ invariants. These standalone
# checks provide independent coverage at the invariant level.
# ---------------------------------------------------------------------------

table threading_extra18.class_names:
  description: "threading synchronisation class __name__ attributes"
  kind: python_call_eq
  category: class_names
  id_prefix: clsname18

  columns: [id, function, args, expected]
  rows:
    - [Condition,        Condition.__name__.__eq__,        ["Condition"],        true]
    - [Barrier,          Barrier.__name__.__eq__,          ["Barrier"],          true]
    - [BoundedSemaphore, BoundedSemaphore.__name__.__eq__, ["BoundedSemaphore"], true]
    - [Timer,            Timer.__name__.__eq__,            ["Timer"],            true]

table threading_extra18.class_modules:
  description: "threading synchronisation class __module__ attributes"
  kind: python_call_eq
  category: class_modules
  id_prefix: clsmod18

  columns: [id, function, args, expected]
  rows:
    - [Condition,        Condition.__module__.__eq__,        ["threading"], true]
    - [Barrier,          Barrier.__module__.__eq__,          ["threading"], true]
    - [BoundedSemaphore, BoundedSemaphore.__module__.__eq__, ["threading"], true]
    - [Timer,            Timer.__module__.__eq__,            ["threading"], true]
    - [Thread,           Thread.__module__.__eq__,           ["threading"], true]
    - [Event,            Event.__module__.__eq__,            ["threading"], true]
    - [Semaphore,        Semaphore.__module__.__eq__,        ["threading"], true]

# ---------------------------------------------------------------------------
# get_ident and get_native_id __name__ checks
#
# threading_extra4 covers settrace/__name__, active_count/__name__, and
# enumerate/__name__. No prior spec checks get_ident/__name__ or
# get_native_id/__name__. Both are C builtins from _thread, re-exported by
# threading, so their __name__ strings are their unqualified identifiers.
# ---------------------------------------------------------------------------

table threading_extra18.ident_function_names:
  description: "threading.get_ident and get_native_id __name__ attributes"
  kind: python_call_eq
  category: function_names
  id_prefix: identfn18

  columns: [id, function, args, expected]
  rows:
    - [get_ident,      get_ident.__name__.__eq__,      ["get_ident"],      true]
    - [get_native_id,  get_native_id.__name__.__eq__,  ["get_native_id"],  true]
