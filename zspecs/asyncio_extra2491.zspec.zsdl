spec: asyncio_extra2491
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — Task and Future"
    - "https://docs.python.org/3/library/asyncio-sync.html — Lock, Event, Semaphore"
    - "https://docs.python.org/3/library/asyncio-queue.html — Queue"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Theme: __setitem__, __delitem__, and __missing__ dict-presence — checking whether asyncio classes define mutable item access and missing-key protocol in their class __dict__."
    - "asyncio.Queue.__dict__.__contains__('__setitem__') == False — Queue does not define __setitem__; verified Python 3.14.4."
    - "asyncio.Queue.__dict__.__contains__('__delitem__') == False — Queue does not define __delitem__; verified Python 3.14.4."
    - "asyncio.Queue.__dict__.__contains__('__missing__') == False — Queue does not define __missing__; verified Python 3.14.4."
    - "asyncio.Task.__dict__.__contains__('__setitem__') == False — Task does not define __setitem__; verified Python 3.14.4."
    - "asyncio.Task.__dict__.__contains__('__delitem__') == False — Task does not define __delitem__; verified Python 3.14.4."
    - "asyncio.Task.__dict__.__contains__('__missing__') == False — Task does not define __missing__; verified Python 3.14.4."
    - "asyncio.Future.__dict__.__contains__('__setitem__') == False — Future does not define __setitem__; verified Python 3.14.4."
    - "asyncio.Lock.__dict__.__contains__('__setitem__') == False — Lock does not define __setitem__; verified Python 3.14.4."
    - "asyncio.Event.__dict__.__contains__('__setitem__') == False — Event does not define __setitem__; verified Python 3.14.4."
    - "Accessing a missing key via __dict__.__getitem__ raises KeyError for all asyncio classes; verified Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio class __dict__ __contains__ checks — __setitem__, __delitem__,
# __missing__ dict-presence theme
#
# None of the core asyncio synchronization/task classes define __setitem__,
# __delitem__, or __missing__ in their own class __dict__. These classes are
# not dict-like containers and do not support mutable item access or the
# missing-key protocol.
# ---------------------------------------------------------------------------

table asyncio_extra2491.queue_dict_mutable_item:
  description: "asyncio.Queue.__dict__.__contains__ checks for __setitem__, __delitem__, __missing__ — Queue defines __init__, __repr__, _get, _put but NOT mutable item access methods; verified Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: as2491

  columns: [id, function, args, expected]
  rows:
    - ["as2491001", asyncio.Queue.__dict__.__contains__, ["__init__"],      true]
    - ["as2491002", asyncio.Queue.__dict__.__contains__, ["__repr__"],      true]
    - ["as2491003", asyncio.Queue.__dict__.__contains__, ["__doc__"],       true]
    - ["as2491004", asyncio.Queue.__dict__.__contains__, ["__setitem__"],   false]
    - ["as2491005", asyncio.Queue.__dict__.__contains__, ["__delitem__"],   false]
    - ["as2491006", asyncio.Queue.__dict__.__contains__, ["__missing__"],   false]

