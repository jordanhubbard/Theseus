spec: p_map
version: ">=7.0.0"
backend: node(p-map)

docs: https://github.com/sindresorhus/p-map#readme

provenance:
  derived_from:
    - "p-map README — https://github.com/sindresorhus/p-map#readme"
    - "Test vectors verified with p-map via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "p-map source"
  notes:
    - "Map over a list with promises and concurrency control."
    - "Install: npm install p-map"
    - "v7 ESM only; default export pMap is async function."
    - "Spec covers shape only — actual mapping needs a JS function which can't be threaded through JSON."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws on invalid concurrency or non-iterable input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant p_map.default_export_is_async:
  description: "Default export pMap is an AsyncFunction"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "AsyncFunction"

invariant p_map.default_export_arity:
  description: "pMap takes (input, mapper, options) — function.length 2"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 2

invariant p_map.default_export_name:
  description: "pMap function.name is 'pMap'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.name"}
  expected: "pMap"
