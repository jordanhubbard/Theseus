spec: concurrent_futures_extra226
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/__init__.py"
  notes:
    - "concurrent.futures.wait.__name__ == 'wait' — function name; module is concurrent.futures._base; verified with Python 3.14.3."
    - "concurrent.futures.as_completed.__name__ == 'as_completed' — function name; module is concurrent.futures._base; verified with Python 3.14.3."
    - "concurrent.futures.wait.__qualname__ == 'wait' — simple top-level function; verified with Python 3.14.3."
    - "concurrent.futures.as_completed.__qualname__ == 'as_completed' — simple top-level function; verified with Python 3.14.3."
    - "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str' — FIRST_COMPLETED is a plain string constant; verified with Python 3.14.3."
    - "concurrent.futures.FIRST_EXCEPTION.__class__.__name__ == 'str' — FIRST_EXCEPTION is a plain string constant; verified with Python 3.14.3."
    - "concurrent.futures.ALL_COMPLETED.__class__.__name__ == 'str' — ALL_COMPLETED is a plain string constant; verified with Python 3.14.3."
    - "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED' — the string value equals its own name; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.wait and as_completed name contracts — extra226 namespace
#
# wait.__name__ == 'wait'; as_completed.__name__ == 'as_completed'.
# Both live in concurrent.futures._base.
# ---------------------------------------------------------------------------

table concurrent_futures_extra226.function_name_contracts:
  description: "concurrent.futures wait/as_completed __name__ and __module__ contracts in cf226fn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cf226fn

  columns: [id, function, args, expected, description]
  rows:
    - [wait_name_eq,           wait.__name__.__eq__,           ["wait"],          true, "concurrent.futures.wait.__name__ == 'wait'; verified with Python 3.14.3"]
    - [wait_qualname_eq,       wait.__qualname__.__eq__,       ["wait"],          true, "concurrent.futures.wait.__qualname__ == 'wait'; verified with Python 3.14.3"]
    - [wait_module_eq,         wait.__module__.__eq__,         ["concurrent.futures._base"], true, "concurrent.futures.wait.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [as_completed_name_eq,   as_completed.__name__.__eq__,   ["as_completed"],  true, "concurrent.futures.as_completed.__name__ == 'as_completed'; verified with Python 3.14.3"]
    - [as_completed_qualname_eq, as_completed.__qualname__.__eq__, ["as_completed"], true, "concurrent.futures.as_completed.__qualname__ == 'as_completed'; verified with Python 3.14.3"]
    - [as_completed_module_eq, as_completed.__module__.__eq__,  ["concurrent.futures._base"], true, "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures wait-return constants class name contracts — extra226 namespace
#
# FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED are plain str constants.
# ---------------------------------------------------------------------------

table concurrent_futures_extra226.wait_constants:
  description: "concurrent.futures FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED class name contracts in cf226wc namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cf226wc

  columns: [id, function, args, expected, description]
  rows:
    - [first_completed_class_name_eq, FIRST_COMPLETED.__class__.__name__.__eq__, ["str"], true, "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [first_exception_class_name_eq, FIRST_EXCEPTION.__class__.__name__.__eq__, ["str"], true, "concurrent.futures.FIRST_EXCEPTION.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [all_completed_class_name_eq,   ALL_COMPLETED.__class__.__name__.__eq__,   ["str"], true, "concurrent.futures.ALL_COMPLETED.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [first_completed_value_eq,      FIRST_COMPLETED.__eq__,                    ["FIRST_COMPLETED"], true, "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED'; verified with Python 3.14.3"]
