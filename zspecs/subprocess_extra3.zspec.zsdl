spec: subprocess_extra3
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
  notes:
    - "This spec extends subprocess.zspec.zsdl, subprocess_extra.zspec.zsdl, subprocess_extra2.zspec.zsdl, and subprocess_popen.zspec.zsdl."
    - "subprocess.zspec.zsdl covers: class __name__ (CompletedProcess/CalledProcessError/TimeoutExpired/Popen/SubprocessError), function __name__ (run/call/check_call/check_output/getstatusoutput/getoutput), PIPE/STDOUT/DEVNULL values, run() and check_output() live execution, CalledProcessError constructor (returncode/cmd), exception MRO via __mro__[1]."
    - "subprocess_extra.zspec.zsdl covers: CompletedProcess/SubprocessError/CalledProcessError/TimeoutExpired __module__; SubprocessError/CalledProcessError/TimeoutExpired __bases__[0] via __getitem__; PIPE/STDOUT/DEVNULL class name 'int'; run/call/check_call/check_output/getoutput/getstatusoutput class name 'function'."
    - "subprocess_extra2.zspec.zsdl covers: Popen.__module__; run.__module__; CalledProcessError.output/stderr defaults to None; TimeoutExpired with float timeout; run(check=True) returns CompletedProcess."
    - "subprocess_popen.zspec.zsdl covers: CompletedProcess constructor attrs (args/returncode/stdout/stderr); TimeoutExpired constructor attrs (cmd/timeout/output); Popen pid/returncode/wait."
    - "This spec adds standalone invariants for: CompletedProcess __name__/__module__; TimeoutExpired __name__ and __bases__[0].__name__; CalledProcessError __name__ and __bases__[0].__name__; SubprocessError __name__."
    - "subprocess.CompletedProcess.__name__ == 'CompletedProcess' — confirmed on CPython 3.12."
    - "subprocess.CompletedProcess.__module__ == 'subprocess' — pure-Python class in subprocess.py."
    - "subprocess.TimeoutExpired.__name__ == 'TimeoutExpired' — confirmed on CPython 3.12."
    - "subprocess.TimeoutExpired.__bases__[0].__name__ == 'SubprocessError' — direct subclass relationship."
    - "subprocess.CalledProcessError.__name__ == 'CalledProcessError' — confirmed on CPython 3.12."
    - "subprocess.CalledProcessError.__bases__[0].__name__ == 'SubprocessError' — direct subclass relationship."
    - "subprocess.SubprocessError.__name__ == 'SubprocessError' — confirmed on CPython 3.12."
    - "subprocess.SubprocessError.__bases__[0].__name__ == 'Exception' — SubprocessError is a direct Exception subclass."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# CompletedProcess — __name__ and __module__ as standalone invariants
#
# subprocess.zspec.zsdl covers __name__ in a table; subprocess_extra covers
# __module__. This spec adds them as named standalone invariants.
# ---------------------------------------------------------------------------

invariant subprocess_extra3.CompletedProcess.name:
  description: "subprocess.CompletedProcess.__name__ == 'CompletedProcess'"
  category: class_names
  kind: python_call_eq
  function: CompletedProcess.__name__.__eq__
  args: ["CompletedProcess"]
  expected: true

invariant subprocess_extra3.CompletedProcess.module:
  description: "subprocess.CompletedProcess.__module__ == 'subprocess'"
  category: class_modules
  kind: python_call_eq
  function: CompletedProcess.__module__.__eq__
  args: ["subprocess"]
  expected: true

# ---------------------------------------------------------------------------
# TimeoutExpired — __name__ and base class hierarchy
#
# subprocess_extra covers __bases__[0] via __getitem__; subprocess.zspec.zsdl
# covers __name__ in a table. This spec adds standalone invariants for both
# and additionally verifies the class hierarchy via __mro__[1] as a complement.
# ---------------------------------------------------------------------------

invariant subprocess_extra3.TimeoutExpired.name:
  description: "subprocess.TimeoutExpired.__name__ == 'TimeoutExpired'"
  category: class_names
  kind: python_call_eq
  function: TimeoutExpired.__name__.__eq__
  args: ["TimeoutExpired"]
  expected: true

invariant subprocess_extra3.TimeoutExpired.base:
  description: "subprocess.TimeoutExpired.__bases__[0].__name__ == 'SubprocessError'"
  category: class_hierarchy
  kind: python_call_eq
  function: TimeoutExpired.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "SubprocessError"

invariant subprocess_extra3.TimeoutExpired.module:
  description: "subprocess.TimeoutExpired.__module__ == 'subprocess'"
  category: class_modules
  kind: python_call_eq
  function: TimeoutExpired.__module__.__eq__
  args: ["subprocess"]
  expected: true

# ---------------------------------------------------------------------------
# CalledProcessError — __name__ and base class hierarchy
#
# subprocess_extra covers __bases__[0] via __getitem__; subprocess.zspec.zsdl
# covers __name__ in a table. This spec adds standalone invariants for both.
# ---------------------------------------------------------------------------

invariant subprocess_extra3.CalledProcessError.name:
  description: "subprocess.CalledProcessError.__name__ == 'CalledProcessError'"
  category: class_names
  kind: python_call_eq
  function: CalledProcessError.__name__.__eq__
  args: ["CalledProcessError"]
  expected: true

invariant subprocess_extra3.CalledProcessError.base:
  description: "subprocess.CalledProcessError.__bases__[0].__name__ == 'SubprocessError'"
  category: class_hierarchy
  kind: python_call_eq
  function: CalledProcessError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "SubprocessError"

invariant subprocess_extra3.CalledProcessError.module:
  description: "subprocess.CalledProcessError.__module__ == 'subprocess'"
  category: class_modules
  kind: python_call_eq
  function: CalledProcessError.__module__.__eq__
  args: ["subprocess"]
  expected: true

# ---------------------------------------------------------------------------
# SubprocessError — __name__ and base class hierarchy
#
# SubprocessError is the root of the subprocess exception hierarchy.
# It is a direct subclass of the built-in Exception.
# ---------------------------------------------------------------------------

invariant subprocess_extra3.SubprocessError.name:
  description: "subprocess.SubprocessError.__name__ == 'SubprocessError'"
  category: class_names
  kind: python_call_eq
  function: SubprocessError.__name__.__eq__
  args: ["SubprocessError"]
  expected: true

invariant subprocess_extra3.SubprocessError.base:
  description: "subprocess.SubprocessError.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: SubprocessError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant subprocess_extra3.SubprocessError.module:
  description: "subprocess.SubprocessError.__module__ == 'subprocess'"
  category: class_modules
  kind: python_call_eq
  function: SubprocessError.__module__.__eq__
  args: ["subprocess"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — CalledProcessError and TimeoutExpired share the same
# second MRO entry (SubprocessError), and SubprocessError's second MRO entry
# is Exception. Verify these as orthogonal checks to __bases__.
# ---------------------------------------------------------------------------

invariant subprocess_extra3.CalledProcessError.mro_index1:
  description: "subprocess.CalledProcessError.__mro__[1].__name__ == 'SubprocessError'"
  category: class_hierarchy
  kind: python_call_eq
  function: CalledProcessError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "SubprocessError"

invariant subprocess_extra3.SubprocessError.mro_index1:
  description: "subprocess.SubprocessError.__mro__[1].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: SubprocessError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Exception"
