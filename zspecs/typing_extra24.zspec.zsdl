spec: typing_extra24
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "PEP 484 — Type Hints"
    - "PEP 646 — Variadic Generics"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
    - "typing_extra23.zspec.zsdl — covers combined __class__.__name__ table for Literal/ClassVar/Final; combined __qualname__.__eq__ table for overload/final/no_type_check/cast; TypeVar/__bases__[0].__name__ standalone; ParamSpec/__bases__[0].__name__ standalone; TypeVarTuple.__mro__.__len__()==2"
    - "typing_extra22.zspec.zsdl — covers __qualname__ table for Generic/TypeVar/ParamSpec/TypeVarTuple; Protocol MRO entries; Generic/__qualname__.__eq__"
    - "typing_extra21.zspec.zsdl — covers __class__.__name__ for Any/Union/Optional/ClassVar; __name__ and __module__ tables for cast/overload/get_type_hints"
    - "typing_extra20.zspec.zsdl — covers __qualname__.__len__ for overload/final/runtime_checkable; __name__.__len__ for get_origin/get_args"
  notes:
    - "This spec extends typing.zspec.zsdl through typing_extra23.zspec.zsdl."
    - "Focus: __module__ table for get_args/get_origin/is_typeddict/no_type_check; __name__ table for get_args/get_origin/is_typeddict; TypeVarTuple class hierarchy."
    - "typing_extra21 covers __module__ for cast/overload/get_type_hints. This spec covers __module__ for get_args/get_origin/is_typeddict/no_type_check — not yet combined in any prior table."
    - "typing_extra21 covers __name__ for cast/overload/get_type_hints. This spec covers __name__ for get_args/get_origin/is_typeddict — not yet combined in any prior table."
    - "typing.get_args.__module__ == 'typing' — module-level utility function."
    - "typing.get_origin.__module__ == 'typing' — module-level utility function."
    - "typing.is_typeddict.__module__ == 'typing' — module-level utility function."
    - "typing.no_type_check.__module__ == 'typing' — module-level decorator."
    - "typing.TypeVarTuple.__bases__[0].__name__ == 'object' — TypeVarTuple directly subclasses object."
    - "typing.TypeVar.__mro__.__len__() == 2 — MRO is [TypeVar, object]."
    - "typing.ParamSpec.__mro__.__len__() == 2 — MRO is [ParamSpec, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for typing utility functions — table
#
# typing_extra21 covers __module__ for cast/overload/get_type_hints.
# No prior typing spec collects __module__ for get_args, get_origin, is_typeddict,
# and no_type_check together in a combined table.
# All four are module-level functions whose __module__ is 'typing'.
# ---------------------------------------------------------------------------

table typing_extra24.function_modules:
  description: "__module__ for typing utility functions not yet covered in a combined table"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [get_args,      get_args.__module__.__eq__,      ["typing"], true]
    - [get_origin,    get_origin.__module__.__eq__,    ["typing"], true]
    - [is_typeddict,  is_typeddict.__module__.__eq__,  ["typing"], true]
    - [no_type_check, no_type_check.__module__.__eq__, ["typing"], true]

# ---------------------------------------------------------------------------
# __name__ for typing utility functions — table
#
# typing_extra21 covers __name__ for cast/overload/get_type_hints.
# No prior typing spec collects __name__ for get_args, get_origin, and is_typeddict
# together in a combined table under the extra24 namespace.
# ---------------------------------------------------------------------------

table typing_extra24.function_names:
  description: "__name__ for typing utility functions (extra24 namespace)"
  kind: python_call_eq
  category: function_names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [get_args,     get_args.__name__.__eq__,     ["get_args"],     true]
    - [get_origin,   get_origin.__name__.__eq__,   ["get_origin"],   true]
    - [is_typeddict, is_typeddict.__name__.__eq__,  ["is_typeddict"], true]

# ---------------------------------------------------------------------------
# TypeVarTuple.__bases__[0].__name__ standalone
#
# typing_extra23 covers TypeVar/__bases__[0].__name__ and ParamSpec/__bases__[0].__name__.
# No prior spec covers TypeVarTuple/__bases__[0].__name__ as a standalone invariant.
# TypeVarTuple directly subclasses object on Python 3.11+.
# ---------------------------------------------------------------------------

invariant typing_extra24.TypeVarTuple.bases0.name_eq:
  description: "typing.TypeVarTuple.__bases__[0].__name__ == 'object' — TypeVarTuple directly subclasses object"
  category: class_hierarchy
  kind: python_call_eq
  function: "TypeVarTuple.__bases__.__getitem__(0).__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# TypeVar and ParamSpec MRO length — standalone invariants
#
# typing_extra23 covers TypeVarTuple.__mro__.__len__()==2 but not TypeVar or
# ParamSpec MRO length. Both TypeVar and ParamSpec have MRO [Class, object]
# (length 2) on Python 3.12+.
# ---------------------------------------------------------------------------

invariant typing_extra24.TypeVar.mro_len:
  description: "typing.TypeVar.__mro__.__len__() == 2 — MRO is [TypeVar, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: TypeVar.__mro__.__len__
  args: []
  expected: 2

invariant typing_extra24.ParamSpec.mro_len:
  description: "typing.ParamSpec.__mro__.__len__() == 2 — MRO is [ParamSpec, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: ParamSpec.__mro__.__len__
  args: []
  expected: 2
