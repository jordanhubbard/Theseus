spec: asyncio_extra40
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra39.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, QueueFull/__name__.__len__()==9, QueueEmpty/QueueFull __qualname__.__len__(), Runner method __name__/__qualname__.__len__() tables, various function and class lengths, MRO depths for all queue/lock/sync classes, AbstractEventLoop/__name__/__len__() tables, BaseEventLoop/Handle/TimerHandle/Protocol/StreamReader lengths, Event method __qualname__ string values and lengths (extra39), Semaphore.acquire/release __qualname__ string values and lengths (extra39), Semaphore/__name__=='Semaphore' (extra39), Event/__name__=='Event' (extra39)."
    - "This spec covers: Semaphore.acquire.__qualname__=='Semaphore.acquire'; Semaphore.release.__qualname__=='Semaphore.release'; BoundedSemaphore.__name__=='BoundedSemaphore'; BoundedSemaphore.__module__=='asyncio.locks' (13 chars); BoundedSemaphore.acquire.__qualname__.__len__()==17 (inherits from Semaphore, so qualname is 'Semaphore.acquire'); Condition.__name__=='Condition'; Condition.__module__=='asyncio.locks' (13 chars); Condition.wait.__qualname__.__len__()==14 ('Condition.wait')."
    - "asyncio.BoundedSemaphore.acquire.__qualname__ == 'Semaphore.acquire' (17 chars, NOT 'BoundedSemaphore.acquire'). BoundedSemaphore inherits acquire from Semaphore without overriding it, so the __qualname__ reflects the defining class (Semaphore). This means BoundedSemaphore.acquire.__qualname__.__len__() == 17, not 24. The extra40 invariant captures this inheritance-revealing behavior."
    - "asyncio.Condition does not have an 'acquire' method — it uses __aenter__/__aexit__ for context management. The available Condition methods are: notify, notify_all, wait, wait_for, _get_loop, _notify. Condition.wait.__qualname__ == 'Condition.wait' (14 chars: 'Condition'(9) + '.'(1) + 'wait'(4) = 14)."
    - "asyncio.BoundedSemaphore.__module__ == 'asyncio.locks' (13 chars). asyncio.Condition.__module__ == 'asyncio.locks' (13 chars). Both BoundedSemaphore and Condition are implemented in the asyncio.locks submodule. The module name 'asyncio.locks' is 13 chars ('asyncio'(7) + '.'(1) + 'locks'(5) = 13)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Semaphore method __qualname__ string equality — extra40 namespace
#
# The two primary Semaphore methods:
#   Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (17 chars)
#   Semaphore.release.__qualname__ == 'Semaphore.release' (17 chars)
# Both are 17 chars: 'Semaphore'(9) + '.'(1) + 'acquire'/'release'(7) = 17.
# Prior spec extra39 captured the __len__() integer values; this spec (extra40)
# captures the full string equality checks as boolean invariants.
# ---------------------------------------------------------------------------

table asyncio_extra40.semaphore_method_qualname_equality:
  description: "asyncio.Semaphore method __qualname__ string equality in extra40 namespace — acquire and release"
  kind: python_call_eq
  category: method_names
  id_prefix: semaphoremethqualeq40

  columns: [id, function, args, expected, description]
  rows:
    - [acquire, Semaphore.acquire.__qualname__.__eq__, ["Semaphore.acquire"], true, "Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (17 chars)"]
    - [release, Semaphore.release.__qualname__.__eq__, ["Semaphore.release"], true, "Semaphore.release.__qualname__ == 'Semaphore.release' (17 chars)"]

# ---------------------------------------------------------------------------
# asyncio.BoundedSemaphore identity — extra40 namespace
#
# BoundedSemaphore extends Semaphore with an upper bound on releases:
#   BoundedSemaphore.__name__   == 'BoundedSemaphore'  (16 chars)
#   BoundedSemaphore.__module__ == 'asyncio.locks'     (13 chars)
# BoundedSemaphore.acquire is inherited from Semaphore without override,
# so BoundedSemaphore.acquire.__qualname__ == 'Semaphore.acquire' (17 chars),
# NOT 'BoundedSemaphore.acquire' (24 chars). The __len__() == 17 reveals this.
# ---------------------------------------------------------------------------

table asyncio_extra40.bounded_semaphore_identity:
  description: "asyncio.BoundedSemaphore identity in extra40 namespace — __name__, __module__, and inherited acquire qualname length"
  kind: python_call_eq
  category: class_names
  id_prefix: bsemid40

  columns: [id, function, args, expected, description]
  rows:
    - [name,           BoundedSemaphore.__name__.__eq__,              ["BoundedSemaphore"], true, "BoundedSemaphore.__name__ == 'BoundedSemaphore' (16 chars)"]
    - [module,         BoundedSemaphore.__module__.__eq__,            ["asyncio.locks"],    true, "BoundedSemaphore.__module__ == 'asyncio.locks' (13 chars)"]
    - [acquire_qulen,  BoundedSemaphore.acquire.__qualname__.__len__, [],                   17,   "BoundedSemaphore.acquire.__qualname__.__len__() == 17 — inherits from Semaphore, qualname is 'Semaphore.acquire'"]

# ---------------------------------------------------------------------------
# asyncio.Condition identity — extra40 namespace
#
# Condition is the asyncio condition variable for await-based synchronization:
#   Condition.__name__          == 'Condition'     (9 chars)
#   Condition.__module__        == 'asyncio.locks' (13 chars)
#   Condition.wait.__qualname__ == 'Condition.wait' (14 chars)
# Note: Condition does NOT have an 'acquire' method; it uses __aenter__/__aexit__
# for context management. The wait method's qualname is 'Condition.wait':
# 'Condition'(9) + '.'(1) + 'wait'(4) = 14 chars.
# Both Condition and BoundedSemaphore share __module__ == 'asyncio.locks' (13 chars).
# ---------------------------------------------------------------------------

table asyncio_extra40.condition_identity:
  description: "asyncio.Condition identity in extra40 namespace — __name__, __module__, and wait method qualname length"
  kind: python_call_eq
  category: class_names
  id_prefix: conditionid40

  columns: [id, function, args, expected, description]
  rows:
    - [name,          Condition.__name__.__eq__,              ["Condition"],     true, "Condition.__name__ == 'Condition' (9 chars)"]
    - [module,        Condition.__module__.__eq__,            ["asyncio.locks"], true, "Condition.__module__ == 'asyncio.locks' (13 chars)"]
    - [wait_qulen,    Condition.wait.__qualname__.__len__,    [],               14,   "'Condition.wait' is 14 characters — 'Condition'(9) + '.'(1) + 'wait'(4)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra40
# ---------------------------------------------------------------------------

invariant asyncio_extra40.BoundedSemaphore_name_eq:
  description: "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore' — the class name for the bounded asyncio semaphore (16 chars)"
  category: class_names
  kind: python_call_eq
  function: BoundedSemaphore.__name__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

invariant asyncio_extra40.BoundedSemaphore_module_eq:
  description: "asyncio.BoundedSemaphore.__module__ == 'asyncio.locks' — implemented in the asyncio.locks submodule (13 chars)"
  category: module_names
  kind: python_call_eq
  function: BoundedSemaphore.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra40.BoundedSemaphore_acquire_qualname_len:
  description: "asyncio.BoundedSemaphore.acquire.__qualname__.__len__() == 17 — acquire is inherited from Semaphore, so qualname is 'Semaphore.acquire' (17 chars), not 'BoundedSemaphore.acquire' (24 chars)"
  category: method_names
  kind: python_call_eq
  function: BoundedSemaphore.acquire.__qualname__.__len__
  args: []
  expected: 17

invariant asyncio_extra40.Condition_name_eq:
  description: "asyncio.Condition.__name__ == 'Condition' — the class name for the asyncio condition variable (9 chars)"
  category: class_names
  kind: python_call_eq
  function: Condition.__name__.__eq__
  args: ["Condition"]
  expected: true

invariant asyncio_extra40.Condition_module_eq:
  description: "asyncio.Condition.__module__ == 'asyncio.locks' — implemented in the asyncio.locks submodule; same module as BoundedSemaphore (13 chars)"
  category: module_names
  kind: python_call_eq
  function: Condition.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra40.Condition_wait_qualname_len:
  description: "asyncio.Condition.wait.__qualname__.__len__() == 14 — 'Condition.wait' has 14 characters: 'Condition'(9) + '.'(1) + 'wait'(4)"
  category: method_names
  kind: python_call_eq
  function: Condition.wait.__qualname__.__len__
  args: []
  expected: 14
