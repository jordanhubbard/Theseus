spec: trio_rust
version: ">=3.9"
backend: rust_module(trio_rust)

docs: https://trio.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://trio.readthedocs.io/en/stable/ — Trio documentation"
  not_derived_from:
    - "trio source: trio/__init__.py"
  notes:
    - "Trio is a friendly Python library for async concurrency."
    - "trio.run is available."
    - "trio.open_nursery is available."
    - "trio.__version__ is a non-empty string."
    - "trio.Cancelled is an exception class."
    - "Expose trio_has_run() -> bool: hasattr(trio, 'run')."
    - "Expose trio_has_nursery() -> bool: hasattr(trio, 'open_nursery')."
    - "Expose trio_version_nonempty() -> bool: len(trio.__version__) > 0."
    - "All test vectors verified against trio 0.29.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# trio_has_run — run present
invariant trio_rust.module.has_run:
  description: "trio.run is available"
  category: module
  kind: python_call_eq
  function: trio_has_run
  args: []
  expected: true

# trio_has_nursery — open_nursery present
invariant trio_rust.module.has_nursery:
  description: "trio.open_nursery is available"
  category: module
  kind: python_call_eq
  function: trio_has_nursery
  args: []
  expected: true

# trio_version_nonempty — version non-empty
invariant trio_rust.version.nonempty:
  description: "trio.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: trio_version_nonempty
  args: []
  expected: true

