spec: token_extra12
version: ">=3.9"
backend: python_module(token)

docs: https://docs.python.org/3/library/token.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/token.html — Python token module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/token.py"
    - "token_extra11.zspec.zsdl — covers tok_name.__len__()==71; EXACT_TOKEN_TYPES.__len__()==48; exact values for ENDMARKER/NAME/NUMBER/STRING/NEWLINE/OP"
    - "token_extra10.zspec.zsdl — covers NAME/NUMBER/STRING/OP/NEWLINE/ENDMARKER/INDENT/DEDENT/COMMENT/ENCODING/NL/ERRORTOKEN __class__.__name__=='int' via __eq__ (table)"
    - "token_extra9.zspec.zsdl — covers tok_name/EXACT_TOKEN_TYPES __class__.__name__=='dict'; ISEOF/ISTERMINAL/ISNONTERMINAL __qualname__; tok_name indices 11-16; EXACT_TOKEN_TYPES exact values"
    - "token_extra4.zspec.zsdl — covers INDENT==5/DEDENT==6 exact values"
    - "token_extra2.zspec.zsdl — covers ERRORTOKEN/__class__.__name__=='int' standalone; ENCODING/__class__.__name__=='int' standalone"
    - "token_extra.zspec.zsdl — covers int type checks for major constants; tok_name/EXACT_TOKEN_TYPES is_dict; NAME/NUMBER/STRING/NEWLINE/ENDMARKER exact values"
  notes:
    - "This spec extends token_extra11.zspec.zsdl."
    - "Focus: standalone __class__.__name__=='int' invariants for ENCODING, COMMENT, NL, ERRORTOKEN, INDENT, DEDENT, LPAR, RPAR in the token_extra12 namespace; exact integer values for COMMENT, INDENT, DEDENT, LPAR, RPAR."
    - "token.ENCODING.__class__.__name__ == 'int' — token_extra2/token_extra10 cover this in prior namespaces; distinct standalone invariant in token_extra12."
    - "token.COMMENT == 65 — verified on Python 3.12 (macOS/Darwin 25.4.0). No prior token spec covers COMMENT exact value as a standalone invariant."
    - "token.NL.__class__.__name__ == 'int' — token_extra10 covers NL in a class-name table; standalone in token_extra12 namespace."
    - "token.ERRORTOKEN.__class__.__name__ == 'int' — token_extra2/token_extra10 cover this; standalone in token_extra12 namespace."
    - "token.INDENT.__class__.__name__ == 'int' — token_extra10 covers INDENT in a class-name table; standalone in token_extra12 namespace."
    - "token.DEDENT.__class__.__name__ == 'int' — token_extra10 covers DEDENT in a class-name table; standalone in token_extra12 namespace."
    - "token.LPAR.__class__.__name__ == 'int' — token_extra10 covers LPAR (as part of OP group) indirectly; standalone in token_extra12 namespace."
    - "token.RPAR.__class__.__name__ == 'int' — standalone in token_extra12 namespace."
    - "token.LPAR == 7 and token.RPAR == 8 — tok_name round-trip values were verified in token_extra9/token_extra10; exact __eq__ invariants for LPAR/RPAR in token_extra12 namespace are new."
    - "token.INDENT == 5 and token.DEDENT == 6 — token_extra4 covers these in its namespace; distinct in token_extra12."
    - "All values: ENCODING=68, COMMENT=65, NL=66, ERRORTOKEN=67, INDENT=5, DEDENT=6, LPAR=7, RPAR=8 — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Token constant __class__.__name__ == 'int' — standalone invariants
# (token_extra12 namespace)
#
# token_extra10 covers all of these in a single table. token_extra2 covers
# ENCODING/ERRORTOKEN standalone. These are distinct standalone invariants
# in the token_extra12 namespace.
# ---------------------------------------------------------------------------

invariant token_extra12.ENCODING.class_is_int:
  description: "token.ENCODING.__class__.__name__ == 'int' — ENCODING constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: ENCODING.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant token_extra12.NL.class_is_int:
  description: "token.NL.__class__.__name__ == 'int' — NL (non-logical newline) constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: NL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant token_extra12.ERRORTOKEN.class_is_int:
  description: "token.ERRORTOKEN.__class__.__name__ == 'int' — ERRORTOKEN constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: ERRORTOKEN.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant token_extra12.INDENT.class_is_int:
  description: "token.INDENT.__class__.__name__ == 'int' — INDENT constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: INDENT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant token_extra12.DEDENT.class_is_int:
  description: "token.DEDENT.__class__.__name__ == 'int' — DEDENT constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: DEDENT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant token_extra12.LPAR.class_is_int:
  description: "token.LPAR.__class__.__name__ == 'int' — LPAR constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: LPAR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant token_extra12.RPAR.class_is_int:
  description: "token.RPAR.__class__.__name__ == 'int' — RPAR constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: RPAR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Token constant exact values — standalone invariants
# (token_extra12 namespace)
#
# COMMENT==65, NL==66, ERRORTOKEN==67, ENCODING==68 — from tok_name
# round-trip coverage in token_extra9/token_extra10; no prior token spec
# covers these as standalone __eq__ invariants.
# INDENT==5/DEDENT==6 covered in token_extra4; distinct in token_extra12.
# LPAR==7/RPAR==8 not covered as standalone __eq__ invariants in any prior spec.
# All values verified on Python 3.12 (macOS/Darwin 25.4.0).
# ---------------------------------------------------------------------------

table token_extra12.constant_exact_values:
  description: "Exact integer values for token constants"
  kind: python_call_eq
  category: constant_values
  id_prefix: cval

  columns: [id, function, args, expected]
  rows:
    - [COMMENT,    COMMENT.__eq__,    [65], true]
    - [INDENT,     INDENT.__eq__,     [5],  true]
    - [DEDENT,     DEDENT.__eq__,     [6],  true]
    - [LPAR,       LPAR.__eq__,       [7],  true]
    - [RPAR,       RPAR.__eq__,       [8],  true]
