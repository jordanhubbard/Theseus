spec: pathlib_extra230
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path method __class__.__name__ type and __code__.co_argcount contracts."
    - "pathlib.Path.is_absolute.__class__.__name__ == 'function'; verified with Python 3.14.3."
    - "pathlib.Path.is_file.__class__.__name__ == 'function'; verified with Python 3.14.3."
    - "pathlib.Path.is_dir.__class__.__name__ == 'function'; verified with Python 3.14.3."
    - "pathlib.Path.exists.__class__.__name__ == 'function'; verified with Python 3.14.3."
    - "pathlib.Path.stat.__class__.__name__ == 'function'; verified with Python 3.14.3."
    - "pathlib.Path.open.__class__.__name__ == 'function'; verified with Python 3.14.3."
    - "pathlib.Path.resolve.__class__.__name__ == 'function'; verified with Python 3.14.3."
    - "pathlib.Path.iterdir.__class__.__name__ == 'function'; verified with Python 3.14.3."
    - "pathlib.Path.mkdir.__class__.__name__ == 'function'; verified with Python 3.14.3."
    - "pathlib.Path.unlink.__class__.__name__ == 'function'; verified with Python 3.14.3."
    - "pathlib.Path.is_absolute.__code__.co_argcount == 1: only self; verified with Python 3.14.3."
    - "pathlib.Path.exists.__code__.co_argcount == 1: only self (follow_symlinks is keyword-only); verified with Python 3.14.3."
    - "pathlib.Path.resolve.__code__.co_argcount == 2: self and strict; verified with Python 3.14.3."
    - "pathlib.Path.open.__code__.co_argcount == 6: self, mode, buffering, encoding, errors, newline; verified with Python 3.14.3."
    - "pathlib.Path.mkdir.__code__.co_argcount == 4: self, mode, parents, exist_ok; verified with Python 3.14.3."
    - "pathlib.Path.unlink.__code__.co_argcount == 2: self and missing_ok; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path method __class__.__name__ values
# All Path methods are pure Python functions (__class__.__name__ == 'function').
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table pathlib_extra230.path_method_class_names:
  description: "pathlib.Path method __class__.__name__ contracts for 10 methods; all are plain Python functions; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_metadata
  id_prefix: plmthdclsname230

  columns: [id, function, args, expected]
  rows:
    - [is_absolute_classname, Path.is_absolute.__class__.__name__.__eq__, ["function"], true]
    - [is_file_classname,     Path.is_file.__class__.__name__.__eq__,     ["function"], true]
    - [is_dir_classname,      Path.is_dir.__class__.__name__.__eq__,      ["function"], true]
    - [exists_classname,      Path.exists.__class__.__name__.__eq__,      ["function"], true]
    - [stat_classname,        Path.stat.__class__.__name__.__eq__,        ["function"], true]
    - [open_classname,        Path.open.__class__.__name__.__eq__,        ["function"], true]
    - [resolve_classname,     Path.resolve.__class__.__name__.__eq__,     ["function"], true]
    - [iterdir_classname,     Path.iterdir.__class__.__name__.__eq__,     ["function"], true]
    - [mkdir_classname,       Path.mkdir.__class__.__name__.__eq__,       ["function"], true]
    - [unlink_classname,      Path.unlink.__class__.__name__.__eq__,      ["function"], true]

# ---------------------------------------------------------------------------
# pathlib.Path method __code__.co_argcount values
# co_argcount counts positional and defaulted args only (not keyword-only).
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table pathlib_extra230.path_method_co_argcount:
  description: "pathlib.Path method __code__.co_argcount contracts; co_argcount counts positional args only, not keyword-only; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_metadata
  id_prefix: plmthdargcnt230

  columns: [id, function, args, expected]
  rows:
    - [is_absolute_argcount, Path.is_absolute.__code__.co_argcount.__eq__, [1], true]
    - [is_file_argcount,     Path.is_file.__code__.co_argcount.__eq__,     [1], true]
    - [is_dir_argcount,      Path.is_dir.__code__.co_argcount.__eq__,      [1], true]
    - [exists_argcount,      Path.exists.__code__.co_argcount.__eq__,      [1], true]
    - [iterdir_argcount,     Path.iterdir.__code__.co_argcount.__eq__,     [1], true]
    - [resolve_argcount,     Path.resolve.__code__.co_argcount.__eq__,     [2], true]
    - [unlink_argcount,      Path.unlink.__code__.co_argcount.__eq__,      [2], true]
    - [mkdir_argcount,       Path.mkdir.__code__.co_argcount.__eq__,       [4], true]
    - [open_argcount,        Path.open.__code__.co_argcount.__eq__,        [6], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

invariant pathlib_extra230.Path.is_absolute_class_name:
  description: "pathlib.Path.is_absolute.__class__.__name__ == 'function' — is_absolute is a plain Python function; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: Path.is_absolute.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra230.Path.exists_class_name:
  description: "pathlib.Path.exists.__class__.__name__ == 'function' — exists is a plain Python function; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: Path.exists.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra230.Path.is_absolute_co_argcount:
  description: "pathlib.Path.is_absolute.__code__.co_argcount == 1 — only self; verified with Python 3.14.3"
  category: code_metadata
  kind: python_call_eq
  function: Path.is_absolute.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant pathlib_extra230.Path.exists_co_argcount:
  description: "pathlib.Path.exists.__code__.co_argcount == 1 — only self; follow_symlinks is keyword-only and not counted by co_argcount; verified with Python 3.14.3"
  category: code_metadata
  kind: python_call_eq
  function: Path.exists.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant pathlib_extra230.Path.open_co_argcount:
  description: "pathlib.Path.open.__code__.co_argcount == 6 — self, mode, buffering, encoding, errors, newline; verified with Python 3.14.3"
  category: code_metadata
  kind: python_call_eq
  function: Path.open.__code__.co_argcount.__eq__
  args: [6]
  expected: true

invariant pathlib_extra230.Path.resolve_co_argcount:
  description: "pathlib.Path.resolve.__code__.co_argcount == 2 — self and strict; verified with Python 3.14.3"
  category: code_metadata
  kind: python_call_eq
  function: Path.resolve.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant pathlib_extra230.Path.mkdir_co_argcount:
  description: "pathlib.Path.mkdir.__code__.co_argcount == 4 — self, mode, parents, exist_ok; verified with Python 3.14.3"
  category: code_metadata
  kind: python_call_eq
  function: Path.mkdir.__code__.co_argcount.__eq__
  args: [4]
  expected: true
