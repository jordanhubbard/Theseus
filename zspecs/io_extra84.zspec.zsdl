spec: io_extra84
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra83."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths; FileIO/BytesIO/StringIO __dict__ membership; BufferedReader/BufferedWriter/TextIOWrapper identity and MRO lengths; BufferedReader/BufferedWriter/TextIOWrapper __dict__.__class__.__name__ and key method membership; BytesIO/StringIO/FileIO __dict__.__class__.__name__ and membership; UnsupportedOperation identity, bases, MRO; DEFAULT_BUFFER_SIZE and SEEK_* constants class and value."
    - "This spec covers: BufferedRandom/__name__/__module__; BufferedRandom/__bases__.__len__() and __bases__[0].__name__; BufferedRandom/__mro__.__len__(); BufferedRWPair/__name__/__module__; BufferedRWPair/__bases__.__len__() and __bases__[0].__name__; BufferedRWPair/__mro__.__len__(); IncrementalNewlineDecoder/__name__/__module__; IncrementalNewlineDecoder/__bases__.__len__() and __bases__[0].__name__."
    - "io.BufferedRandom.__name__ == 'BufferedRandom' — the C type name matches Python-visible name."
    - "io.BufferedRandom.__module__ == '_io' — implemented in the _io C extension module."
    - "io.BufferedRandom.__bases__.__len__() == 1 — BufferedRandom has a single base class."
    - "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' — inherits from _BufferedIOBase."
    - "io.BufferedRandom.__mro__.__len__() == 4 — MRO is [BufferedRandom, _BufferedIOBase, _IOBase, object]."
    - "io.BufferedRWPair.__name__ == 'BufferedRWPair' — the C type name matches Python-visible name."
    - "io.BufferedRWPair.__module__ == '_io' — implemented in the _io C extension module."
    - "io.BufferedRWPair.__bases__.__len__() == 1 — BufferedRWPair has a single base class."
    - "io.BufferedRWPair.__bases__[0].__name__ == '_BufferedIOBase' — inherits from _BufferedIOBase."
    - "io.BufferedRWPair.__mro__.__len__() == 4 — MRO is [BufferedRWPair, _BufferedIOBase, _IOBase, object]."
    - "io.IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder' — the C type name matches Python-visible name."
    - "io.IncrementalNewlineDecoder.__module__ == '_io' — implemented in the _io C extension module."
    - "io.IncrementalNewlineDecoder.__bases__.__len__() == 1 — IncrementalNewlineDecoder has a single base class."
    - "io.IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' — inherits directly from object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BufferedRandom class identity: __name__ and __module__
# BufferedRandom is a C type defined in the _io extension.
# __module__ == '_io' (not 'io') because it is implemented in the C layer.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra84.BufferedRandom_identity:
  description: "BufferedRandom __name__ and __module__"
  kind: python_call_eq
  category: class_identity
  id_prefix: iomore84

  columns: [id, function, args, expected]
  rows:
    - [bufran_name,   BufferedRandom.__name__.__eq__,   ["BufferedRandom"], true]
    - [bufran_module, BufferedRandom.__module__.__eq__, ["_io"],            true]

# ---------------------------------------------------------------------------
# BufferedRandom __bases__ and __mro__
# BufferedRandom has a single base class _BufferedIOBase.
# MRO: [BufferedRandom, _BufferedIOBase, _IOBase, object] — length 4.
# Function values with [ must be double-quoted.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra84.BufferedRandom_hierarchy:
  description: "BufferedRandom __bases__ length and __bases__[0].__name__; __mro__.__len__()"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: iomore84

  columns: [id, function, args, expected]
  rows:
    - [bufran_bases_len,  BufferedRandom.__bases__.__len__,               [],                 1]
    - [bufran_base0_name, "BufferedRandom.__bases__[0].__name__.__eq__",  ["_BufferedIOBase"], true]
    - [bufran_mro_len,    BufferedRandom.__mro__.__len__,                 [],                 4]

# ---------------------------------------------------------------------------
# BufferedRWPair class identity, bases, and MRO
# BufferedRWPair is also a C type in _io with a single base _BufferedIOBase.
# MRO: [BufferedRWPair, _BufferedIOBase, _IOBase, object] — length 4.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra84.BufferedRWPair_identity_hierarchy:
  description: "BufferedRWPair __name__, __module__, __bases__ len, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: iomore84

  columns: [id, function, args, expected]
  rows:
    - [bufrwp_name,      BufferedRWPair.__name__.__eq__,                  ["BufferedRWPair"],  true]
    - [bufrwp_module,    BufferedRWPair.__module__.__eq__,                ["_io"],             true]
    - [bufrwp_bases_len, BufferedRWPair.__bases__.__len__,                [],                  1]
    - [bufrwp_base0,     "BufferedRWPair.__bases__[0].__name__.__eq__",   ["_BufferedIOBase"], true]
    - [bufrwp_mro_len,   BufferedRWPair.__mro__.__len__,                  [],                  4]

# ---------------------------------------------------------------------------
# IncrementalNewlineDecoder class identity, bases, and module
# IncrementalNewlineDecoder is a C type in _io that inherits directly from object.
# __bases__.__len__() == 1; __bases__[0].__name__ == 'object'.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra84.IncrementalNewlineDecoder_identity:
  description: "IncrementalNewlineDecoder __name__, __module__, __bases__ len, __bases__[0].__name__"
  kind: python_call_eq
  category: class_identity
  id_prefix: iomore84

  columns: [id, function, args, expected]
  rows:
    - [indec_name,      IncrementalNewlineDecoder.__name__.__eq__,                  ["IncrementalNewlineDecoder"], true]
    - [indec_module,    IncrementalNewlineDecoder.__module__.__eq__,                ["_io"],                       true]
    - [indec_bases_len, IncrementalNewlineDecoder.__bases__.__len__,                [],                            1]
    - [indec_base0,     "IncrementalNewlineDecoder.__bases__[0].__name__.__eq__",   ["object"],                    true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra84.BufferedRandom.name:
  description: "io.BufferedRandom.__name__ == 'BufferedRandom'"
  category: class_identity
  kind: python_call_eq
  function: BufferedRandom.__name__.__eq__
  args: ["BufferedRandom"]
  expected: true

invariant io_extra84.BufferedRandom.module:
  description: "io.BufferedRandom.__module__ == '_io'"
  category: class_identity
  kind: python_call_eq
  function: BufferedRandom.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra84.BufferedRandom.bases_len:
  description: "io.BufferedRandom.__bases__.__len__() == 1 (single base: _BufferedIOBase)"
  category: class_hierarchy
  kind: python_call_eq
  function: BufferedRandom.__bases__.__len__
  args: []
  expected: 1

invariant io_extra84.BufferedRandom.mro_len:
  description: "io.BufferedRandom.__mro__.__len__() == 4 ([BufferedRandom, _BufferedIOBase, _IOBase, object])"
  category: class_hierarchy
  kind: python_call_eq
  function: BufferedRandom.__mro__.__len__
  args: []
  expected: 4

invariant io_extra84.BufferedRWPair.module:
  description: "io.BufferedRWPair.__module__ == '_io'"
  category: class_identity
  kind: python_call_eq
  function: BufferedRWPair.__module__.__eq__
  args: ["_io"]
  expected: true
