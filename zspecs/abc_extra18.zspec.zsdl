spec: abc_extra18
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "abc_extra17.zspec.zsdl — covers combined __qualname__ table and __qualname__.__len__ table for ABCMeta/ABC/abstractmethod/get_cache_token; ABCMeta/__name__.__len__; get_cache_token/__name__.__len__; ABCMeta/__mro__.__len__==3; ABC/__mro__.__len__==2; ABC/__name__.__len__."
    - "abc_extra15.zspec.zsdl — covers __mro__.__len__//__bases__.__len__//__bases__[0].__name__ tables for abstractclassmethod/abstractstaticmethod/abstractproperty."
    - "abc_extra12.zspec.zsdl — covers abstractclassmethod/__qualname__ and abstractstaticmethod/__qualname__ as standalone invariants."
  notes:
    - "This spec extends abc.zspec.zsdl through abc_extra17.zspec.zsdl."
    - "Focus: (1) combined __qualname__.__len__ table for abstractclassmethod and abstractstaticmethod — not covered in any prior spec; (2) combined __qualname__ table for all six abc members in the extra18 namespace (new namespace); (3) abstractclassmethod.__mro__[1].__name__ == 'classmethod' standalone; (4) abstractstaticmethod.__mro__[1].__name__ == 'staticmethod' standalone."
    - "abc_extra12 covers abstractclassmethod/__qualname__ and abstractstaticmethod/__qualname__ as standalone invariants but no prior spec combines them together with ABCMeta/ABC/abstractmethod/get_cache_token into a single six-row qualname table."
    - "No prior spec records __qualname__.__len__() for abstractclassmethod (19) or abstractstaticmethod (20) in any combined table."
    - "abc.abstractclassmethod.__mro__[1].__name__ == 'classmethod' — abstractclassmethod inherits from classmethod."
    - "abc.abstractstaticmethod.__mro__[1].__name__ == 'staticmethod' — abstractstaticmethod inherits from staticmethod."
    - "abstractclassmethod and abstractstaticmethod are deprecated since Python 3.3 and present on Python <3.13."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for six abc members — combined table in extra18 namespace
#
# abc_extra17 combines ABCMeta/ABC/abstractmethod/get_cache_token into one table.
# abc_extra12 covers abstractclassmethod and abstractstaticmethod as standalone
# invariants. No prior spec combines all six into a single table in the extra18
# namespace. All six have a simple qualname equal to their class or function name.
# ---------------------------------------------------------------------------

table abc_extra18.all_qualnames:
  description: "__qualname__ for six abc members in the extra18 namespace"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [ABCMeta,               ABCMeta.__qualname__.__eq__,               ["ABCMeta"],               true]
    - [ABC,                   ABC.__qualname__.__eq__,                   ["ABC"],                   true]
    - [abstractmethod,        abstractmethod.__qualname__.__eq__,        ["abstractmethod"],        true]
    - [get_cache_token,       get_cache_token.__qualname__.__eq__,       ["get_cache_token"],       true]
    - [abstractclassmethod,   abstractclassmethod.__qualname__.__eq__,   ["abstractclassmethod"],   true]
    - [abstractstaticmethod,  abstractstaticmethod.__qualname__.__eq__,  ["abstractstaticmethod"],  true]

# ---------------------------------------------------------------------------
# __qualname__.__len__ for abstractclassmethod and abstractstaticmethod
#
# abc_extra17 covers __qualname__.__len__ for ABCMeta/ABC/abstractmethod/
# get_cache_token. No prior spec records __qualname__.__len__() for
# abstractclassmethod (len 19) or abstractstaticmethod (len 20) — these
# deprecated members were skipped from the length table.
# ---------------------------------------------------------------------------

table abc_extra18.deprecated_qualname_lens:
  description: "__qualname__.__len__ for abstractclassmethod and abstractstaticmethod"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [abstractclassmethod,  abstractclassmethod.__qualname__.__len__,  [], 19]
    - [abstractstaticmethod, abstractstaticmethod.__qualname__.__len__, [], 20]

# ---------------------------------------------------------------------------
# abstractclassmethod.__mro__[1].__name__ == 'classmethod'
#
# abstractclassmethod's MRO is [abstractclassmethod, classmethod, object].
# abc_extra15 records __mro__.__len__() == 3 and __bases__[0].__name__ for
# the deprecated abstract classes. No prior spec accesses __mro__[1].__name__
# via __getitem__ as a standalone invariant for abstractclassmethod.
# ---------------------------------------------------------------------------

invariant abc_extra18.abstractclassmethod.mro_index1_name:
  description: "abc.abstractclassmethod.__mro__[1].__name__ == 'classmethod' — immediate base class is classmethod"
  category: class_hierarchy
  kind: python_call_eq
  function: "abstractclassmethod.__mro__.__getitem__(1).__name__.__eq__"
  args: ["classmethod"]
  expected: true

# ---------------------------------------------------------------------------
# abstractstaticmethod.__mro__[1].__name__ == 'staticmethod'
#
# abstractstaticmethod's MRO is [abstractstaticmethod, staticmethod, object].
# abc_extra15 records __mro__.__len__() == 3 and __bases__[0].__name__ for
# the deprecated abstract classes. No prior spec accesses __mro__[1].__name__
# via __getitem__ as a standalone invariant for abstractstaticmethod.
# ---------------------------------------------------------------------------

invariant abc_extra18.abstractstaticmethod.mro_index1_name:
  description: "abc.abstractstaticmethod.__mro__[1].__name__ == 'staticmethod' — immediate base class is staticmethod"
  category: class_hierarchy
  kind: python_call_eq
  function: "abstractstaticmethod.__mro__.__getitem__(1).__name__.__eq__"
  args: ["staticmethod"]
  expected: true
