spec: multiprocessing_extra102
version: ">=3.9"
backend: python_module(multiprocessing)
extends: multiprocessing_extra99

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing_extra99.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing exception class identity. NEW in extra102: multiprocessing.ProcessError.__class__.__name__=='type'; multiprocessing.ProcessError.__module__=='multiprocessing.context'; multiprocessing.ProcessError.__bases__[0].__name__=='Exception'; multiprocessing.ProcessError.__mro__.__len__()==4 ([ProcessError, Exception, BaseException, object]); multiprocessing.AuthenticationError.__bases__[0].__name__=='ProcessError'; multiprocessing.AuthenticationError.__mro__.__len__()==5; multiprocessing.BufferTooShort.__bases__[0].__name__=='ProcessError'; multiprocessing.TimeoutError.__bases__[0].__name__=='ProcessError'; multiprocessing.AuthenticationError.__qualname__=='AuthenticationError' (len=19, longest); multiprocessing.BufferTooShort.__qualname__=='BufferTooShort' (len=14); multiprocessing.TimeoutError.__qualname__=='TimeoutError' (len=12); multiprocessing.ProcessError.__qualname__=='ProcessError' (len=12, tied with TimeoutError). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__module__ == 'multiprocessing.context'. All multiprocessing exception classes (ProcessError, AuthenticationError, BufferTooShort, TimeoutError) are defined in Lib/multiprocessing/context.py, so __module__ is 'multiprocessing.context'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__mro__.__len__() == 4. MRO is [ProcessError, Exception, BaseException, object] — 4 elements. Each subclass of ProcessError adds one element, giving them MRO len=5. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__qualname__.__len__() == 19. 'AuthenticationError' is 19 chars: 'Authentication'=14 + 'Error'=5. This is the longest multiprocessing exception qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.ProcessError class identity — extra102
#
# Wave 254 theme: multiprocessing exception class identity.
# All multiprocessing exception classes are defined in context.py.
#
# multiprocessing.ProcessError.__class__.__name__      == 'type'
# multiprocessing.ProcessError.__module__              == 'multiprocessing.context'
# multiprocessing.ProcessError.__bases__[0].__name__   == 'Exception'
# multiprocessing.ProcessError.__mro__.__len__()       == 4
# multiprocessing.ProcessError.__qualname__            == 'ProcessError'  (len=12)
# ---------------------------------------------------------------------------

table multiprocessing_extra102.mp_process_error_identity:
  description: "multiprocessing.ProcessError class identity checks in mpexcident102 namespace — wave 254 theme: multiprocessing exception classes are defined in Lib/multiprocessing/context.py; multiprocessing.ProcessError.__class__.__name__.__eq__('type')==True (ProcessError is a class, metaclass is type); multiprocessing.ProcessError.__module__.__eq__('multiprocessing.context')==True (defined in context.py, not __init__.py); multiprocessing.ProcessError.__bases__[0].__name__.__eq__('Exception')==True (ProcessError inherits directly from Exception); multiprocessing.ProcessError.__mro__.__len__()==4 (MRO is [ProcessError, Exception, BaseException, object]); multiprocessing.ProcessError.__qualname__.__eq__('ProcessError')==True (len=12: 'Process'=7 + 'Error'=5); multiprocessing.ProcessError.__qualname__.__len__()==12; multiprocessing.ProcessError.__qualname__.__class__.__name__.__eq__('str')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpexcident102

  columns: [id, function, args, expected, description]
  rows:
    - [pe_cls_nm,   multiprocessing.ProcessError.__class__.__name__.__eq__,        ["type"],                    true, "multiprocessing.ProcessError.__class__.__name__ == 'type' (ProcessError is a class); verified with Python 3.14.3"]
    - [pe_module,   multiprocessing.ProcessError.__module__.__eq__,                 ["multiprocessing.context"], true, "multiprocessing.ProcessError.__module__ == 'multiprocessing.context' (defined in context.py); verified with Python 3.14.3"]
    - [pe_base0,    "multiprocessing.ProcessError.__bases__[0].__name__.__eq__",    ["Exception"],               true, "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception' — ProcessError inherits from Exception; verified with Python 3.14.3"]
    - [pe_mro_len,  multiprocessing.ProcessError.__mro__.__len__,                   [],                          4,    "multiprocessing.ProcessError.__mro__.__len__() == 4 — [ProcessError, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [pe_qn_eq,    multiprocessing.ProcessError.__qualname__.__eq__,               ["ProcessError"],            true, "multiprocessing.ProcessError.__qualname__ == 'ProcessError' (len=12); verified with Python 3.14.3"]
    - [pe_qn_len,   multiprocessing.ProcessError.__qualname__.__len__,              [],                          12,   "multiprocessing.ProcessError.__qualname__.__len__() == 12 ('Process'=7 + 'Error'=5); verified with Python 3.14.3"]
    - [pe_qn_cls,   multiprocessing.ProcessError.__qualname__.__class__.__name__.__eq__, ["str"],                true, "multiprocessing.ProcessError.__qualname__.__class__.__name__ == 'str'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing exception subclass identity — extra102
#
# multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError'
# multiprocessing.AuthenticationError.__mro__.__len__()     == 5
# multiprocessing.AuthenticationError.__qualname__          == 'AuthenticationError' (len=19, longest)
# multiprocessing.BufferTooShort.__bases__[0].__name__      == 'ProcessError'
# multiprocessing.BufferTooShort.__qualname__               == 'BufferTooShort' (len=14)
# multiprocessing.TimeoutError.__bases__[0].__name__        == 'ProcessError'
# multiprocessing.TimeoutError.__qualname__                 == 'TimeoutError' (len=12)
# multiprocessing.TimeoutError.__module__                   == 'multiprocessing.context'
# ---------------------------------------------------------------------------

table multiprocessing_extra102.mp_exception_subclass_identity:
  description: "multiprocessing exception subclass identity checks in mpexcident102 namespace — wave 254 theme: ProcessError subclasses all inherit from ProcessError as their direct base; multiprocessing.AuthenticationError.__bases__[0].__name__.__eq__('ProcessError')==True; multiprocessing.AuthenticationError.__mro__.__len__()==5 (MRO is [AuthenticationError, ProcessError, Exception, BaseException, object] — one more than ProcessError's 4-element MRO); multiprocessing.AuthenticationError.__qualname__.__eq__('AuthenticationError')==True (len=19: 'Authentication'=14 + 'Error'=5, longest in spec); multiprocessing.AuthenticationError.__qualname__.__len__()==19; multiprocessing.BufferTooShort.__bases__[0].__name__.__eq__('ProcessError')==True; multiprocessing.BufferTooShort.__qualname__.__eq__('BufferTooShort')==True (len=14: 'Buffer'=6+'Too'=3+'Short'=5); multiprocessing.BufferTooShort.__qualname__.__len__()==14; multiprocessing.TimeoutError.__bases__[0].__name__.__eq__('ProcessError')==True; multiprocessing.TimeoutError.__qualname__.__eq__('TimeoutError')==True (len=12: tied with ProcessError); multiprocessing.TimeoutError.__module__.__eq__('multiprocessing.context')==True; all verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpexcident102a

  columns: [id, function, args, expected, description]
  rows:
    - [auth_base0,    "multiprocessing.AuthenticationError.__bases__[0].__name__.__eq__", ["ProcessError"], true, "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError'; verified with Python 3.14.3"]
    - [auth_mro_len,  multiprocessing.AuthenticationError.__mro__.__len__,                [],               5,    "multiprocessing.AuthenticationError.__mro__.__len__() == 5 — [AuthenticationError, ProcessError, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [auth_qn_eq,    multiprocessing.AuthenticationError.__qualname__.__eq__,            ["AuthenticationError"], true, "multiprocessing.AuthenticationError.__qualname__ == 'AuthenticationError' (len=19, longest in spec); verified with Python 3.14.3"]
    - [auth_qn_len,   multiprocessing.AuthenticationError.__qualname__.__len__,           [],               19,   "multiprocessing.AuthenticationError.__qualname__.__len__() == 19 ('Authentication'=14+'Error'=5, longest); verified with Python 3.14.3"]
    - [buf_base0,     "multiprocessing.BufferTooShort.__bases__[0].__name__.__eq__",      ["ProcessError"], true, "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'; verified with Python 3.14.3"]
    - [buf_qn_eq,     multiprocessing.BufferTooShort.__qualname__.__eq__,                 ["BufferTooShort"], true, "multiprocessing.BufferTooShort.__qualname__ == 'BufferTooShort' (len=14); verified with Python 3.14.3"]
    - [buf_qn_len,    multiprocessing.BufferTooShort.__qualname__.__len__,                [],               14,   "multiprocessing.BufferTooShort.__qualname__.__len__() == 14 ('Buffer'=6+'Too'=3+'Short'=5); verified with Python 3.14.3"]
    - [timeout_base0, "multiprocessing.TimeoutError.__bases__[0].__name__.__eq__",        ["ProcessError"], true, "multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError'; verified with Python 3.14.3"]
    - [timeout_qn_eq, multiprocessing.TimeoutError.__qualname__.__eq__,                   ["TimeoutError"], true, "multiprocessing.TimeoutError.__qualname__ == 'TimeoutError' (len=12, tied with ProcessError); verified with Python 3.14.3"]
    - [timeout_qn_ln, multiprocessing.TimeoutError.__qualname__.__len__,                  [],               12,   "multiprocessing.TimeoutError.__qualname__.__len__() == 12 (tied with ProcessError); verified with Python 3.14.3"]
    - [timeout_module, multiprocessing.TimeoutError.__module__.__eq__,                    ["multiprocessing.context"], true, "multiprocessing.TimeoutError.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra102
# ---------------------------------------------------------------------------

invariant multiprocessing_extra102.ProcessError_base_is_Exception:
  description: "multiprocessing.ProcessError.__bases__[0].__name__.__eq__('Exception') returns True — ProcessError inherits directly from Exception (not from a custom intermediate class); this means ProcessError's MRO is [ProcessError, Exception, BaseException, object] (4 elements); all ProcessError subclasses (AuthenticationError, BufferTooShort, TimeoutError) add one level each (MRO len=5: [subclass, ProcessError, Exception, BaseException, object]); contrast with concurrent.futures exceptions: CancelledError base is 'Error' (a private intermediate class), BrokenExecutor base is 'RuntimeError'; multiprocessing.ProcessError.__module__ is 'multiprocessing.context'; ProcessError.__class__.__name__ is 'type'; NEW in extra102: first standalone ProcessError base class invariant in mpexcident102 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.ProcessError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant multiprocessing_extra102.AuthenticationError_qualname_longest:
  description: "multiprocessing.AuthenticationError.__qualname__.__len__() == 19 — AuthenticationError.__qualname__ is 'AuthenticationError' (19 chars: 'Authentication'=14 + 'Error'=5); this is the longest multiprocessing exception class qualname; compare exception qualname lengths: ProcessError=12, TimeoutError=12, BufferTooShort=14, AuthenticationError=19; AuthenticationError.__bases__[0].__name__ is 'ProcessError' (inherits from ProcessError); AuthenticationError.__mro__.__len__() is 5 ([AuthenticationError, ProcessError, Exception, BaseException, object]); AuthenticationError.__module__ is 'multiprocessing.context'; NEW in extra102: first standalone AuthenticationError qualname length invariant in mpexcident102 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.AuthenticationError.__qualname__.__len__
  args: []
  expected: 19

invariant multiprocessing_extra102.ProcessError_mro_len_4:
  description: "multiprocessing.ProcessError.__mro__.__len__() == 4 — ProcessError's MRO is [ProcessError, Exception, BaseException, object] (4 elements); each ProcessError subclass (AuthenticationError, BufferTooShort, TimeoutError) has MRO length 5 ([subclass, ProcessError, Exception, BaseException, object]) — exactly one more than ProcessError itself; contrast with multiprocessing.Process.__mro__.__len__()==3 ([Process, BaseProcess, object]); ProcessError.__module__ is 'multiprocessing.context'; ProcessError.__class__.__name__ is 'type'; ProcessError.__qualname__ is 'ProcessError' (len=12); NEW in extra102: first standalone ProcessError MRO length invariant in mpexcident102 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.ProcessError.__mro__.__len__
  args: []
  expected: 4

invariant multiprocessing_extra102.BufferTooShort_base_is_ProcessError:
  description: "multiprocessing.BufferTooShort.__bases__[0].__name__.__eq__('ProcessError') returns True — BufferTooShort inherits from ProcessError as its sole direct base class; BufferTooShort is raised when a connection receives a message too large for the buffer to hold; BufferTooShort.__qualname__ is 'BufferTooShort' (len=14: 'Buffer'=6 + 'Too'=3 + 'Short'=5); BufferTooShort.__module__ is 'multiprocessing.context'; BufferTooShort.__mro__.__len__() is 5 ([BufferTooShort, ProcessError, Exception, BaseException, object]); NEW in extra102: first standalone BufferTooShort base class invariant in mpexcident102 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.BufferTooShort.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra102.TimeoutError_base_is_ProcessError:
  description: "multiprocessing.TimeoutError.__bases__[0].__name__.__eq__('ProcessError') returns True — multiprocessing.TimeoutError inherits from ProcessError (not from the built-in TimeoutError or OSError); this is an important distinction: multiprocessing.TimeoutError.__module__ is 'multiprocessing.context' (defined in context.py), while concurrent.futures.TimeoutError.__module__ is 'builtins' (the built-in TimeoutError re-exported); multiprocessing.TimeoutError.__bases__[0].__name__ is 'ProcessError' while concurrent.futures.TimeoutError.__bases__[0].__name__ is 'OSError'; multiprocessing.TimeoutError.__qualname__ is 'TimeoutError' (len=12, tied with ProcessError); NEW in extra102: first standalone multiprocessing.TimeoutError base class invariant in mpexcident102 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.TimeoutError.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

