spec: pathlib_extra65
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra64.zspec.zsdl — covers pathlib.__all__.__contains__ membership; pathlib.__package__.__eq__('pathlib'); Path/PurePath __doc__.__class__.__name__.__len__()==3."
    - "pathlib_extra63.zspec.zsdl — covers pathlib.__all__.__class__.__name__.__eq__('list') and __all__.__len__()==7; Path/PurePath/PurePosixPath/PureWindowsPath __eq__.__class__.__name__.__eq__('function')."
    - "pathlib_extra62.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __repr__/__hash__/__class__.__name__ chains."
    - "pathlib_extra44.zspec.zsdl — covers pathlib.__name__.__len__()==7; pathlib.__package__.__len__()==7; pathlib.__file__.__class__.__name__.__len__()==3."
  notes:
    - "This spec extends pathlib_extra64.zspec.zsdl."
    - "Wave 225 theme: __loader__ identity + __spec__ attribute chains + __file__/__cached__ class name checks."
    - "pathlib is a pure Python package (Lib/pathlib/__init__.py). Its loader is a SourceFileLoader instance (not a class object). Therefore __loader__.__class__.__name__ == 'SourceFileLoader'. This contrasts with io whose __loader__ is the FrozenImporter class itself (so io.__loader__.__class__.__name__ == 'type')."
    - "pathlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — pathlib is a pure Python package loaded by importlib's SourceFileLoader. The loader is an instance of SourceFileLoader, so __loader__.__class__.__name__ is 'SourceFileLoader'. No prior pathlib spec checks __loader__.__class__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — the module's __spec__ is an importlib.machinery.ModuleSpec instance. pathlib_extra64 covers __spec__.__class__.__name__ for the table row via the note about decimal_extra54 covering it for decimal, but no prior pathlib spec uses __spec__.__class__.__name__.__eq__('ModuleSpec') as a table anchor for pathlib specifically. Novel for pathlib. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.__file__.__class__.__name__.__eq__('str') == True — pathlib_extra44 covers __file__.__class__.__name__.__len__()==3 (length). This equality anchor is distinct and novel in the pathlibload65 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.__cached__.__class__.__name__.__eq__('str') == True — pathlib has a __cached__ attribute pointing to the compiled .pyc bytecode file. Its type is str. No prior pathlib spec checks __cached__.__class__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.__loader__.__class__.__name__.__eq__('SourceFileLoader')
#
# pathlib is a pure Python package loaded by importlib's SourceFileLoader.
# The loader is a SourceFileLoader instance, so its __class__.__name__ is
# 'SourceFileLoader'.
#
# This contrasts with:
#   - io: __loader__ is the FrozenImporter class itself => __class__.__name__ == 'type'
#   - C extensions: __loader__ is an ExtensionFileLoader instance
#
# No prior pathlib spec checks __loader__.__class__.__name__.
# Novel anchor in pathlibload65 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra65.loader_class_name:
  description: "pathlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') — pathlib is a pure Python package loaded by SourceFileLoader; the loader is an instance so __loader__.__class__.__name__=='SourceFileLoader'; contrasts with io (FrozenImporter class object => 'type') and C extensions (ExtensionFileLoader); no prior pathlib spec checks __loader__.__class__.__name__; novel anchor in pathlibload65 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibload65ldr

  columns: [id, function, args, expected]
  rows:
    - [loader_class_name_SourceFileLoader, __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true]

# ---------------------------------------------------------------------------
# pathlib.__spec__.__class__.__name__.__eq__('ModuleSpec')
#
# The pathlib module's __spec__ attribute is an importlib.machinery.ModuleSpec
# instance. The class name of ModuleSpec is 'ModuleSpec'.
#
#   pathlib.__spec__.__class__.__name__.__eq__('ModuleSpec') == True
#
# No prior pathlib spec checks __spec__.__class__.__name__.__eq__('ModuleSpec')
# as a table anchor for pathlib. Novel in pathlibload65 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra65.spec_class_name:
  description: "pathlib.__spec__.__class__.__name__.__eq__('ModuleSpec') — pathlib.__spec__ is an importlib.machinery.ModuleSpec instance; __spec__.__class__.__name__=='ModuleSpec'; no prior pathlib spec checks __spec__.__class__.__name__.__eq__('ModuleSpec') as a table anchor for pathlib; novel in pathlibload65 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibload65spec

  columns: [id, function, args, expected]
  rows:
    - [spec_class_name_ModuleSpec, "__spec__.__class__.__name__.__eq__", ["ModuleSpec"], true]

# ---------------------------------------------------------------------------
# pathlib.__file__.__class__.__name__.__eq__('str')
# pathlib.__cached__.__class__.__name__.__eq__('str')
#
# pathlib is a pure Python module with both a __file__ (path to __init__.py)
# and a __cached__ (path to the compiled .pyc bytecode). Both are str.
#
#   pathlib.__file__.__class__.__name__.__eq__('str')    == True
#   pathlib.__cached__.__class__.__name__.__eq__('str')  == True
#
# pathlib_extra44 covers __file__.__class__.__name__.__len__()==3 (length).
# The equality anchor __file__.__class__.__name__.__eq__('str') is distinct.
# No prior pathlib spec checks __cached__.__class__.__name__. Both novel.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra65.file_cached_class_names:
  description: "pathlib.__file__/__cached__.__class__.__name__.__eq__('str') — pathlib is pure Python with both __file__ (path to __init__.py) and __cached__ (path to .pyc bytecode); both are str; pathlib_extra44 covers __file__.__class__.__name__.__len__()==3 (length) but not __eq__('str') equality; no prior pathlib spec checks __cached__.__class__.__name__; both novel anchors in pathlibload65 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibload65files

  columns: [id, function, args, expected]
  rows:
    - [file_class_name_eq_str,   __file__.__class__.__name__.__eq__,   ["str"], true]
    - [cached_class_name_eq_str, __cached__.__class__.__name__.__eq__, ["str"], true]

invariant pathlib_extra65.loader_class_name_SourceFileLoader:
  description: "pathlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — pathlib is a pure Python package loaded by SourceFileLoader; no prior pathlib spec checks __loader__.__class__.__name__; novel anchor in pathlibload65 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant pathlib_extra65.spec_class_name_ModuleSpec:
  description: "pathlib.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — pathlib.__spec__ is an importlib.machinery.ModuleSpec instance; no prior pathlib spec checks __spec__.__class__.__name__ equality for pathlib; novel anchor in pathlibload65 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant pathlib_extra65.file_class_name_eq_str:
  description: "pathlib.__file__.__class__.__name__.__eq__('str') == True — pathlib.__file__ is a str path to pathlib/__init__.py; pathlib_extra44 covers the length (3) but not the equality; this equality anchor is novel in pathlibload65 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pathlib_extra65.cached_class_name_eq_str:
  description: "pathlib.__cached__.__class__.__name__.__eq__('str') == True — pathlib.__cached__ is a str path to the compiled .pyc bytecode; no prior pathlib spec checks __cached__.__class__.__name__; novel anchor in pathlibload65 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __cached__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
