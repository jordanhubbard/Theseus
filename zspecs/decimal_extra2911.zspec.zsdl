spec: dc2911
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/decimal_extra2896.zspec.zsdl — wave 640 predecessor (covered __itruediv__, __ifloordiv__, __imod__)"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "Wave 641 theme: __ilshift__, __irshift__, __ipow__ dict-presence checks (in-place left-shift, right-shift, power operators)."
    - "decimal.Decimal IS a numeric type and defines __pow__ and __rpow__ (confirmed True in wave 637) — but does NOT define __ipow__."
    - "Decimal does not define __lshift__ or __rshift__ (not an integer type), so __ilshift__ and __irshift__ are also absent."
    - "The absence of __ipow__ is notable: Decimal supports ** via __pow__/__rpow__, but **= falls back to rebinding (immutable value type)."
    - "decimal.Context is a mutable configuration object that defines no shift or power operators on itself."
    - "decimal exception hierarchy classes (DecimalException and all subclasses) do NOT define any shift or power operators."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __ilshift__ dict-presence
# Decimal has no integer bitwise operations — __ilshift__ absent from all types
# ---------------------------------------------------------------------------

table dc2911.ilshift:
  description: "__ilshift__ is absent from all decimal types — Decimal is not an integer type and has no bitwise left-shift semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2911

  columns: [id, function, args, expected]
  rows:
    - ["dc2911001", "decimal.Decimal.__dict__.__contains__",          ["__ilshift__"], false]
    - ["dc2911002", "decimal.Context.__dict__.__contains__",          ["__ilshift__"], false]
    - ["dc2911003", "decimal.DecimalException.__dict__.__contains__", ["__ilshift__"], false]
    - ["dc2911004", "decimal.InvalidOperation.__dict__.__contains__", ["__ilshift__"], false]
    - ["dc2911005", "decimal.DivisionByZero.__dict__.__contains__",   ["__ilshift__"], false]
    - ["dc2911006", "decimal.Overflow.__dict__.__contains__",         ["__ilshift__"], false]
    - ["dc2911007", "decimal.Decimal.__dict__.__contains__",          ["__lshift__"],  false]
    - ["dc2911008", "decimal.Context.__dict__.__contains__",          ["__lshift__"],  false]

# ---------------------------------------------------------------------------
# Table: __irshift__ dict-presence
# Decimal has no integer bitwise operations — __irshift__ absent from all types
# ---------------------------------------------------------------------------

table dc2911.irshift:
  description: "__irshift__ is absent from all decimal types — Decimal is not an integer type and has no bitwise right-shift semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2911

  columns: [id, function, args, expected]
  rows:
    - ["dc2911009",  "decimal.Decimal.__dict__.__contains__",          ["__irshift__"], false]
    - ["dc2911010", "decimal.Context.__dict__.__contains__",          ["__irshift__"], false]
    - ["dc2911011", "decimal.DecimalException.__dict__.__contains__", ["__irshift__"], false]
    - ["dc2911012", "decimal.InvalidOperation.__dict__.__contains__", ["__irshift__"], false]
    - ["dc2911013", "decimal.DivisionByZero.__dict__.__contains__",   ["__irshift__"], false]
    - ["dc2911014", "decimal.Overflow.__dict__.__contains__",         ["__irshift__"], false]
    - ["dc2911015", "decimal.Decimal.__dict__.__contains__",          ["__rshift__"],  false]
    - ["dc2911016", "decimal.Context.__dict__.__contains__",          ["__rshift__"],  false]

# ---------------------------------------------------------------------------
# Table: __ipow__ dict-presence
# Decimal defines __pow__ and __rpow__ but NOT __ipow__ — immutable, **= rebinds
# ---------------------------------------------------------------------------

table dc2911.ipow:
  description: "__ipow__ is absent from all decimal types — Decimal defines __pow__/__rpow__ but is immutable and omits the in-place power variant"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2911

  columns: [id, function, args, expected]
  rows:
    - ["dc2911017", "decimal.Decimal.__dict__.__contains__",          ["__ipow__"], false]
    - ["dc2911018", "decimal.Context.__dict__.__contains__",          ["__ipow__"], false]
    - ["dc2911019", "decimal.DecimalException.__dict__.__contains__", ["__ipow__"], false]
    - ["dc2911020", "decimal.InvalidOperation.__dict__.__contains__", ["__ipow__"], false]
    - ["dc2911021", "decimal.DivisionByZero.__dict__.__contains__",   ["__ipow__"], false]
    - ["dc2911022", "decimal.Overflow.__dict__.__contains__",         ["__ipow__"], false]
    - ["dc2911023", "decimal.Decimal.__dict__.__contains__",          ["__pow__"],  true]
    - ["dc2911024", "decimal.Decimal.__dict__.__contains__",          ["__rpow__"], true]

# ---------------------------------------------------------------------------
# Table: Decimal shift/power profile — __pow__/__rpow__ present, all in-place variants absent
# Key insight: Decimal supports ** but not **=; has no << or >> support at all
# ---------------------------------------------------------------------------

table dc2911.combined:
  description: "decimal.Decimal defines __pow__ and __rpow__ but NOT __ipow__ — and lacks __lshift__/__rshift__ entirely, so __ilshift__/__irshift__ are also absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2911

  columns: [id, function, args, expected]
  rows:
    - ["dc2911025", "decimal.Decimal.__dict__.__contains__", ["__pow__"],    true]
    - ["dc2911026", "decimal.Decimal.__dict__.__contains__", ["__rpow__"],   true]
    - ["dc2911027", "decimal.Decimal.__dict__.__contains__", ["__ipow__"],   false]
    - ["dc2911028", "decimal.Decimal.__dict__.__contains__", ["__lshift__"], false]
    - ["dc2911029", "decimal.Decimal.__dict__.__contains__", ["__rshift__"], false]
    - ["dc2911030", "decimal.Decimal.__dict__.__contains__", ["__ilshift__"], false]
    - ["dc2911031", "decimal.Decimal.__dict__.__contains__", ["__irshift__"], false]
    - ["dc2911032", "decimal.Clamped.__dict__.__contains__",        ["__ipow__"],    false]
    - ["dc2911033", "decimal.Inexact.__dict__.__contains__",        ["__ilshift__"], false]
    - ["dc2911034", "decimal.Rounded.__dict__.__contains__",        ["__irshift__"], false]
    - ["dc2911035", "decimal.Subnormal.__dict__.__contains__",      ["__ipow__"],    false]
    - ["dc2911036", "decimal.FloatOperation.__dict__.__contains__", ["__ilshift__"], false]
