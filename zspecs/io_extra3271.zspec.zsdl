spec: io3271
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 665 (io3271): __rand__, __ror__, __rxor__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "Theme: __rand__, __ror__, __rxor__ dict-presence (reflected bitwise logical)."
    - "No io class defines __rand__ in its own __dict__: stream I/O classes are sequential I/O abstractions, not integer types, and do not implement reflected bitwise AND."
    - "No io class defines __ror__ in its own __dict__: stream I/O classes do not implement reflected bitwise OR; the | operator on streams is not defined."
    - "No io class defines __rxor__ in its own __dict__: stream I/O classes do not implement reflected bitwise XOR."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __rand__ dict-presence — operator.contains(Cls.__dict__, '__rand__')
#
# No io class defines __rand__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions, not integer types,
# and do not implement the reflected bitwise AND operator.
# ---------------------------------------------------------------------------

table io3271.rand:
  description: "io types __rand__ dict-presence checks; wave 665"
