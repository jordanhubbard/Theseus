spec: threading_extra196
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.current_thread.__name__ == 'current_thread' (len=14); current_thread returns the current Thread object; it is a plain Python function defined in threading.py; verified with Python 3.14.3."
    - "threading.current_thread.__module__ == 'threading' (len=9); defined at top level in threading.py; verified with Python 3.14.3."
    - "threading.current_thread.__qualname__ == 'current_thread' (len=14); top-level function so qualname equals name; verified with Python 3.14.3."
    - "threading.main_thread.__name__ == 'main_thread' (len=11); main_thread returns the main Thread object; it is a plain Python function in threading.py; verified with Python 3.14.3."
    - "threading.main_thread.__module__ == 'threading' (len=9); defined at top level in threading.py; verified with Python 3.14.3."
    - "threading.active_count.__name__ == 'active_count' (len=12); active_count returns the number of Thread objects currently alive; it is a plain Python function in threading.py; verified with Python 3.14.3."
    - "threading.active_count.__module__ == 'threading' (len=9); defined at top level in threading.py; verified with Python 3.14.3."
    - "threading.enumerate.__name__ == 'enumerate' (len=9); threading.enumerate returns a list of all Thread objects currently alive; it is a plain Python function in threading.py distinct from the built-in enumerate; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.current_thread name, module, and qualname identity
#
# threading.current_thread.__name__    == 'current_thread' (len=14)
# threading.current_thread.__module__  == 'threading' (len=9)
# threading.current_thread.__qualname__ == 'current_thread' (len=14)
#
# current_thread is a plain Python function defined at top level in threading.py.
# New to extra196.
# ---------------------------------------------------------------------------

table threading_extra196.current_thread_name_module_qualname:
  description: "threading.current_thread identity: __name__=='current_thread'(len=14); __module__=='threading'(len=9); __qualname__=='current_thread'(len=14); new to extra196"
  kind: python_call_eq
  category: identity
  id_prefix: threadingfuncs196

  columns: [id, function, args, expected, description]
  rows:
    - [ct_name_eq,
       current_thread.__name__.__eq__,
       ["current_thread"],
       true,
       "threading.current_thread.__name__.__eq__('current_thread') == True — current_thread returns the current Thread object corresponding to the caller's thread of control; __name__ is 'current_thread' (len=14); str.__eq__('current_thread') returns True; verified with Python 3.14.3; new to extra196"]
    - [ct_name_len,
       current_thread.__name__.__len__,
       [],
       14,
       "threading.current_thread.__name__.__len__() == 14 — 'current_thread' has 14 characters; str.__len__() returns 14; verified with Python 3.14.3; new to extra196"]
    - [ct_module_eq,
       current_thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.current_thread.__module__.__eq__('threading') == True — current_thread is defined at top level in threading.py; __module__ is 'threading' (len=9); str.__eq__('threading') returns True; verified with Python 3.14.3; new to extra196"]
    - [ct_module_len,
       current_thread.__module__.__len__,
       [],
       9,
       "threading.current_thread.__module__.__len__() == 9 — 'threading' has 9 characters: t-h-r-e-a-d-i-n-g; str.__len__() returns 9; verified with Python 3.14.3; new to extra196"]
    - [ct_qualname_eq,
       current_thread.__qualname__.__eq__,
       ["current_thread"],
       true,
       "threading.current_thread.__qualname__.__eq__('current_thread') == True — current_thread is a top-level function so qualname equals name; __qualname__ is 'current_thread' (len=14); str.__eq__('current_thread') returns True; verified with Python 3.14.3; new to extra196"]

# ---------------------------------------------------------------------------
# Table 2: threading.main_thread name and module identity
#
# threading.main_thread.__name__   == 'main_thread' (len=11)
# threading.main_thread.__module__ == 'threading' (len=9)
# threading.active_count.__name__  == 'active_count' (len=12)
#
# main_thread and active_count are plain Python functions in threading.py.
# New to extra196.
# ---------------------------------------------------------------------------

table threading_extra196.main_thread_active_count_identity:
  description: "threading.main_thread and active_count: main_thread.__name__=='main_thread'(len=11); main_thread.__module__=='threading'(len=9); active_count.__name__=='active_count'(len=12); new to extra196"
  kind: python_call_eq
  category: identity
  id_prefix: threadingfuncs196

  columns: [id, function, args, expected, description]
  rows:
    - [mt_name_eq,
       main_thread.__name__.__eq__,
       ["main_thread"],
       true,
       "threading.main_thread.__name__.__eq__('main_thread') == True — main_thread returns the main Thread object; __name__ is 'main_thread' (len=11); str.__eq__('main_thread') returns True; verified with Python 3.14.3; new to extra196"]
    - [mt_name_len,
       main_thread.__name__.__len__,
       [],
       11,
       "threading.main_thread.__name__.__len__() == 11 — 'main_thread' has 11 characters: m-a-i-n-_-t-h-r-e-a-d; str.__len__() returns 11; verified with Python 3.14.3; new to extra196"]
    - [mt_module_eq,
       main_thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.main_thread.__module__.__eq__('threading') == True — main_thread is defined at top level in threading.py; __module__ is 'threading' (len=9); str.__eq__('threading') returns True; verified with Python 3.14.3; new to extra196"]
    - [ac_name_eq,
       active_count.__name__.__eq__,
       ["active_count"],
       true,
       "threading.active_count.__name__.__eq__('active_count') == True — active_count returns the number of Thread objects currently alive; __name__ is 'active_count' (len=12); str.__eq__('active_count') returns True; verified with Python 3.14.3; new to extra196"]
    - [ac_name_len,
       active_count.__name__.__len__,
       [],
       12,
       "threading.active_count.__name__.__len__() == 12 — 'active_count' has 12 characters: a-c-t-i-v-e-_-c-o-u-n-t; str.__len__() returns 12; verified with Python 3.14.3; new to extra196"]

# ---------------------------------------------------------------------------
# Table 3: threading.active_count module and threading.enumerate identity
#
# threading.active_count.__module__  == 'threading' (len=9)
# threading.enumerate.__name__       == 'enumerate' (len=9)
# threading.enumerate.__module__     == 'threading' (len=9)
#
# threading.enumerate is distinct from the built-in enumerate function.
# New to extra196.
# ---------------------------------------------------------------------------

table threading_extra196.active_count_module_enumerate_identity:
  description: "threading.active_count.__module__=='threading'(len=9); threading.enumerate.__name__=='enumerate'(len=9); threading.enumerate.__module__=='threading'(len=9); new to extra196"
  kind: python_call_eq
  category: identity
  id_prefix: threadingfuncs196

  columns: [id, function, args, expected, description]
  rows:
    - [ac_module_eq,
       active_count.__module__.__eq__,
       ["threading"],
       true,
       "threading.active_count.__module__.__eq__('threading') == True — active_count is defined at top level in threading.py; __module__ is 'threading' (len=9); str.__eq__('threading') returns True; verified with Python 3.14.3; new to extra196"]
    - [ac_module_len,
       active_count.__module__.__len__,
       [],
       9,
       "threading.active_count.__module__.__len__() == 9 — 'threading' has 9 characters: t-h-r-e-a-d-i-n-g; str.__len__() returns 9; verified with Python 3.14.3; new to extra196"]
    - [enum_name_eq,
       enumerate.__name__.__eq__,
       ["enumerate"],
       true,
       "threading.enumerate.__name__.__eq__('enumerate') == True — threading.enumerate returns a list of all Thread objects currently alive; it is distinct from the built-in enumerate; __name__ is 'enumerate' (len=9); str.__eq__('enumerate') returns True; verified with Python 3.14.3; new to extra196"]
    - [enum_name_len,
       enumerate.__name__.__len__,
       [],
       9,
       "threading.enumerate.__name__.__len__() == 9 — 'enumerate' has 9 characters: e-n-u-m-e-r-a-t-e; str.__len__() returns 9; verified with Python 3.14.3; new to extra196"]
    - [enum_module_eq,
       enumerate.__module__.__eq__,
       ["threading"],
       true,
       "threading.enumerate.__module__.__eq__('threading') == True — threading.enumerate is defined at top level in threading.py; __module__ is 'threading' (len=9); str.__eq__('threading') returns True; verified with Python 3.14.3; new to extra196"]

