spec: is_wsl
version: ">=3.0.0"
backend: node(is-wsl)

docs: https://github.com/sindresorhus/is-wsl#readme

provenance:
  derived_from:
    - "is-wsl README — https://github.com/sindresorhus/is-wsl#readme"
    - "Test vectors verified with is-wsl via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "is-wsl source"
  notes:
    - "Detect Windows Subsystem for Linux — boolean module export."
    - "Install: npm install is-wsl"
    - "v3 ESM only; default export is the boolean (computed at module load)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure boolean; never throws."
  stderr: "null"
  stickiness: "Value is fixed for the process lifetime."
  codes: {}

invariant is_wsl.default_is_boolean:
  description: "Default export is a Boolean"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "Boolean"

invariant is_wsl.macos_value_is_false:
  description: "On macOS (the test runner), isWsl is false"
  category: usage
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
  expected: false
