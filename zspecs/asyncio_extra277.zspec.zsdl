spec: asyncio_extra277
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-protocol.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-protocol.html — Python asyncio protocol documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/protocols.py"
  notes:
    - "This spec covers: asyncio.Protocol, asyncio.BaseProtocol, and asyncio.DatagramProtocol class identity. NEW in extra277: asyncio.Protocol.__name__=='Protocol'; asyncio.Protocol.__module__=='asyncio.protocols'; asyncio.Protocol.__bases__[0].__name__=='BaseProtocol'; asyncio.Protocol.__mro__.__len__()==3 ([Protocol, BaseProtocol, object]); asyncio.BaseProtocol.__name__=='BaseProtocol'; asyncio.BaseProtocol.__module__=='asyncio.protocols'; asyncio.BaseProtocol.__bases__[0].__name__=='object'; asyncio.BaseProtocol.__mro__.__len__()==2; asyncio.DatagramProtocol.__name__=='DatagramProtocol'; asyncio.DatagramProtocol.__module__=='asyncio.protocols'; asyncio.DatagramProtocol.__bases__[0].__name__=='BaseProtocol'; asyncio.DatagramProtocol.__mro__.__len__()==3; Protocol.data_received.__qualname__=='Protocol.data_received' (len=22, own method); Protocol.connection_made.__qualname__=='BaseProtocol.connection_made' (len=28, inherited); DatagramProtocol.datagram_received.__qualname__=='DatagramProtocol.datagram_received' (len=34, longest). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.Protocol.__module__ == 'asyncio.protocols'. All three protocol classes are defined in Lib/asyncio/protocols.py; the module name is 'asyncio.protocols' (len=17), not 'asyncio' (len=7). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.Protocol.__bases__[0].__name__ == 'BaseProtocol'. Protocol inherits from BaseProtocol; DatagramProtocol also inherits from BaseProtocol; BaseProtocol inherits directly from object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.Protocol.connection_made.__qualname__ == 'BaseProtocol.connection_made'. connection_made is defined on BaseProtocol and inherited by both Protocol and DatagramProtocol; its qualname reflects the defining class. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.DatagramProtocol.datagram_received.__qualname__ == 'DatagramProtocol.datagram_received' (len=34). This is the longest protocol method qualname in this spec: 'DatagramProtocol.'=17 + 'datagram_received'=17 = 34. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Protocol class identity — extra277
#
# asyncio.Protocol.__name__               == 'Protocol'
# asyncio.Protocol.__module__             == 'asyncio.protocols'
# asyncio.Protocol.__bases__[0].__name__  == 'BaseProtocol'
# asyncio.Protocol.__mro__.__len__()      == 3   ([Protocol, BaseProtocol, object])
# asyncio.Protocol.__qualname__           == 'Protocol'
# ---------------------------------------------------------------------------

table asyncio_extra277.asyncio_protocol_class_identity:
  description: "asyncio.Protocol class identity checks in asyncioprotident277 namespace — asyncio.Protocol is a pure-Python class defined in Lib/asyncio/protocols.py (module='asyncio.protocols', not 'asyncio'); Protocol.__name__.__eq__('Protocol')==True (len=8); Protocol.__module__.__eq__('asyncio.protocols')==True (len=17: 'asyncio.'=8 + 'protocols'=9); Protocol.__bases__[0].__name__.__eq__('BaseProtocol')==True (Protocol inherits from BaseProtocol as its sole direct base); Protocol.__mro__.__len__()==3 (MRO is [Protocol, BaseProtocol, object]); Protocol.__qualname__.__eq__('Protocol')==True (module-level class, qualname equals name); Protocol.data_received.__qualname__.__eq__('Protocol.data_received')==True (len=22: 'Protocol.'=9 + 'data_received'=13; data_received is defined on Protocol itself); Protocol.connection_made.__qualname__.__eq__('BaseProtocol.connection_made')==True (len=28: connection_made is inherited from BaseProtocol, qualname reflects defining class); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioprotident277

  columns: [id, function, args, expected, description]
  rows:
    - [prot_name_eq,    asyncio.Protocol.__name__.__eq__,                     ["Protocol"],                 true, "asyncio.Protocol.__name__ == 'Protocol'; verified with Python 3.14.3"]
    - [prot_module_eq,  asyncio.Protocol.__module__.__eq__,                   ["asyncio.protocols"],        true, "asyncio.Protocol.__module__ == 'asyncio.protocols' (len=17); verified with Python 3.14.3"]
    - [prot_base0_eq,   "asyncio.Protocol.__bases__[0].__name__.__eq__",      ["BaseProtocol"],             true, "asyncio.Protocol.__bases__[0].__name__ == 'BaseProtocol'; verified with Python 3.14.3"]
    - [prot_mro_len,    asyncio.Protocol.__mro__.__len__,                     [],                           3,    "asyncio.Protocol.__mro__.__len__() == 3 — [Protocol, BaseProtocol, object]; verified with Python 3.14.3"]
    - [prot_qn_eq,      asyncio.Protocol.__qualname__.__eq__,                 ["Protocol"],                 true, "asyncio.Protocol.__qualname__ == 'Protocol' (module-level class); verified with Python 3.14.3"]
    - [prot_dr_qn_eq,   asyncio.Protocol.data_received.__qualname__.__eq__,   ["Protocol.data_received"],   true, "Protocol.data_received.__qualname__ == 'Protocol.data_received' (len=22, own method); verified with Python 3.14.3"]
    - [prot_dr_qn_len,  asyncio.Protocol.data_received.__qualname__.__len__,  [],                           22,   "Protocol.data_received.__qualname__.__len__() == 22 ('Protocol.'=9 + 'data_received'=13); verified with Python 3.14.3"]
    - [prot_cm_qn_eq,   asyncio.Protocol.connection_made.__qualname__.__eq__, ["BaseProtocol.connection_made"], true, "Protocol.connection_made.__qualname__ == 'BaseProtocol.connection_made' (len=28, inherited from BaseProtocol); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.BaseProtocol and asyncio.DatagramProtocol class identity — extra277
#
# asyncio.BaseProtocol.__name__                         == 'BaseProtocol'
# asyncio.BaseProtocol.__module__                       == 'asyncio.protocols'
# asyncio.BaseProtocol.__bases__[0].__name__            == 'object'
# asyncio.BaseProtocol.__mro__.__len__()                == 2
# asyncio.DatagramProtocol.__name__                     == 'DatagramProtocol'
# asyncio.DatagramProtocol.__module__                   == 'asyncio.protocols'
# asyncio.DatagramProtocol.__bases__[0].__name__        == 'BaseProtocol'
# asyncio.DatagramProtocol.__mro__.__len__()            == 3
# DatagramProtocol.datagram_received.__qualname__       == 'DatagramProtocol.datagram_received' (len=34)
# DatagramProtocol.error_received.__qualname__          == 'DatagramProtocol.error_received'    (len=31)
# ---------------------------------------------------------------------------

table asyncio_extra277.asyncio_base_datagram_protocol_identity:
  description: "asyncio.BaseProtocol and asyncio.DatagramProtocol class identity checks in asyncioprotident277 namespace — asyncio.BaseProtocol is the root of the protocol hierarchy; BaseProtocol.__name__.__eq__('BaseProtocol')==True; BaseProtocol.__module__.__eq__('asyncio.protocols')==True (same module as Protocol and DatagramProtocol); BaseProtocol.__bases__[0].__name__.__eq__('object')==True (direct subclass of object, no intermediate base); BaseProtocol.__mro__.__len__()==2 ([BaseProtocol, object]); asyncio.DatagramProtocol inherits from BaseProtocol like Protocol does; DatagramProtocol.__name__.__eq__('DatagramProtocol')==True; DatagramProtocol.__module__.__eq__('asyncio.protocols')==True; DatagramProtocol.__bases__[0].__name__.__eq__('BaseProtocol')==True; DatagramProtocol.__mro__.__len__()==3 ([DatagramProtocol, BaseProtocol, object]); DatagramProtocol.datagram_received.__qualname__.__eq__('DatagramProtocol.datagram_received')==True (len=34: 'DatagramProtocol.'=17 + 'datagram_received'=17, longest qualname in spec); DatagramProtocol.error_received.__qualname__.__eq__('DatagramProtocol.error_received')==True (len=31: 'DatagramProtocol.'=17 + 'error_received'=14); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioprotident277a

  columns: [id, function, args, expected, description]
  rows:
    - [bp_name_eq,     asyncio.BaseProtocol.__name__.__eq__,                              ["BaseProtocol"],                      true, "asyncio.BaseProtocol.__name__ == 'BaseProtocol'; verified with Python 3.14.3"]
    - [bp_module_eq,   asyncio.BaseProtocol.__module__.__eq__,                            ["asyncio.protocols"],                 true, "asyncio.BaseProtocol.__module__ == 'asyncio.protocols'; verified with Python 3.14.3"]
    - [bp_base0_eq,    "asyncio.BaseProtocol.__bases__[0].__name__.__eq__",               ["object"],                           true, "asyncio.BaseProtocol.__bases__[0].__name__ == 'object' — direct subclass of object; verified with Python 3.14.3"]
    - [bp_mro_len,     asyncio.BaseProtocol.__mro__.__len__,                              [],                                   2,    "asyncio.BaseProtocol.__mro__.__len__() == 2 — [BaseProtocol, object]; verified with Python 3.14.3"]
    - [dgp_name_eq,    asyncio.DatagramProtocol.__name__.__eq__,                          ["DatagramProtocol"],                  true, "asyncio.DatagramProtocol.__name__ == 'DatagramProtocol'; verified with Python 3.14.3"]
    - [dgp_module_eq,  asyncio.DatagramProtocol.__module__.__eq__,                        ["asyncio.protocols"],                 true, "asyncio.DatagramProtocol.__module__ == 'asyncio.protocols'; verified with Python 3.14.3"]
    - [dgp_base0_eq,   "asyncio.DatagramProtocol.__bases__[0].__name__.__eq__",           ["BaseProtocol"],                     true, "asyncio.DatagramProtocol.__bases__[0].__name__ == 'BaseProtocol'; verified with Python 3.14.3"]
    - [dgp_mro_len,    asyncio.DatagramProtocol.__mro__.__len__,                          [],                                   3,    "asyncio.DatagramProtocol.__mro__.__len__() == 3 — [DatagramProtocol, BaseProtocol, object]; verified with Python 3.14.3"]
    - [dgp_dr_qn_eq,   asyncio.DatagramProtocol.datagram_received.__qualname__.__eq__,    ["DatagramProtocol.datagram_received"], true, "DatagramProtocol.datagram_received.__qualname__ == 'DatagramProtocol.datagram_received' (len=34, longest in spec); verified with Python 3.14.3"]
    - [dgp_dr_qn_len,  asyncio.DatagramProtocol.datagram_received.__qualname__.__len__,   [],                                   34,   "DatagramProtocol.datagram_received.__qualname__.__len__() == 34 ('DatagramProtocol.'=17 + 'datagram_received'=17); verified with Python 3.14.3"]
    - [dgp_er_qn_eq,   asyncio.DatagramProtocol.error_received.__qualname__.__eq__,       ["DatagramProtocol.error_received"],   true, "DatagramProtocol.error_received.__qualname__ == 'DatagramProtocol.error_received' (len=31); verified with Python 3.14.3"]
    - [dgp_er_qn_len,  asyncio.DatagramProtocol.error_received.__qualname__.__len__,      [],                                   31,   "DatagramProtocol.error_received.__qualname__.__len__() == 31 ('DatagramProtocol.'=17 + 'error_received'=14); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra277
# ---------------------------------------------------------------------------

invariant asyncio_extra277.Protocol_module_is_asyncio_protocols:
  description: "asyncio.Protocol.__module__.__eq__('asyncio.protocols') returns True — asyncio.Protocol is defined in Lib/asyncio/protocols.py, so its __module__ is 'asyncio.protocols' (len=17: 'asyncio.'=8 + 'protocols'=9); this differs from C-extension classes like asyncio.Task and asyncio.Future whose __module__ is '_asyncio' (the C extension); all three protocol classes (BaseProtocol, Protocol, DatagramProtocol) share the same __module__ 'asyncio.protocols'; the module is part of the asyncio package but is a distinct sub-module; NEW in extra277: first standalone Protocol.__module__ invariant in asyncioprotident277 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Protocol.__module__.__eq__
  args: ["asyncio.protocols"]
  expected: true

invariant asyncio_extra277.Protocol_base_is_BaseProtocol:
  description: "asyncio.Protocol.__bases__[0].__name__.__eq__('BaseProtocol') returns True — asyncio.Protocol inherits from asyncio.BaseProtocol as its sole direct base class; Protocol's MRO is [Protocol, BaseProtocol, object] (length=3); BaseProtocol in turn inherits directly from object (MRO=[BaseProtocol, object], length=2); DatagramProtocol also inherits from BaseProtocol (same pattern); the Protocol→BaseProtocol→object chain means Protocol inherits connection_made, connection_lost, pause_writing, and resume_writing from BaseProtocol, whose qualnames reflect the defining class; NEW in extra277: first standalone Protocol base class invariant in asyncioprotident277 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "asyncio.Protocol.__bases__[0].__name__.__eq__"
  args: ["BaseProtocol"]
  expected: true

invariant asyncio_extra277.DatagramProtocol_datagram_received_qualname_len_34:
  description: "asyncio.DatagramProtocol.datagram_received.__qualname__.__len__() == 34 — DatagramProtocol.datagram_received.__qualname__ is 'DatagramProtocol.datagram_received' (34 chars: 'DatagramProtocol.'=17 + 'datagram_received'=17); this is the longest protocol method qualname in this spec; compare qualname lengths: BaseProtocol.connection_lost=28, BaseProtocol.connection_made=28, BaseProtocol.resume_writing=27, BaseProtocol.pause_writing=26, Protocol.data_received=22, DatagramProtocol.error_received=31, DatagramProtocol.datagram_received=34 (longest); the prefix 'DatagramProtocol.' (17 chars) equals the suffix 'datagram_received' (17 chars), making this the only protocol method qualname where prefix and suffix have equal length; NEW in extra277: first standalone DatagramProtocol.datagram_received qualname length invariant in asyncioprotident277 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.DatagramProtocol.datagram_received.__qualname__.__len__
  args: []
  expected: 34

invariant asyncio_extra277.BaseProtocol_mro_len_is_2:
  description: "asyncio.BaseProtocol.__mro__.__len__() == 2 — asyncio.BaseProtocol's MRO is [BaseProtocol, object]; this minimal 2-element chain reflects BaseProtocol's direct inheritance from object with no intermediate classes; BaseProtocol is the root of the asyncio protocol hierarchy; both Protocol and DatagramProtocol have MRO length 3 ([X, BaseProtocol, object]) because BaseProtocol inserts itself between them and object; BaseProtocol defines connection_made, connection_lost, pause_writing, and resume_writing with default no-op implementations; BaseProtocol.__module__ is 'asyncio.protocols'; NEW in extra277: first standalone BaseProtocol MRO length invariant in asyncioprotident277 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.BaseProtocol.__mro__.__len__
  args: []
  expected: 2

invariant asyncio_extra277.Protocol_data_received_qualname_len_22:
  description: "asyncio.Protocol.data_received.__qualname__.__len__() == 22 — Protocol.data_received.__qualname__ is 'Protocol.data_received' (22 chars: 'Protocol.'=9 + 'data_received'=13); data_received is defined directly on Protocol (not inherited from BaseProtocol), so its qualname uses 'Protocol.' prefix; contrast with connection_made, connection_lost, pause_writing, and resume_writing which are inherited from BaseProtocol and have qualnames with 'BaseProtocol.' prefix (28 chars each); data_received is Protocol's most distinctive method — it is called when data is received from a transport; NEW in extra277: first standalone Protocol.data_received qualname length invariant in asyncioprotident277 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Protocol.data_received.__qualname__.__len__
  args: []
  expected: 22

invariant asyncio_extra277.DatagramProtocol_base_is_BaseProtocol:
  description: "asyncio.DatagramProtocol.__bases__[0].__name__.__eq__('BaseProtocol') returns True — asyncio.DatagramProtocol inherits from asyncio.BaseProtocol as its sole direct base, parallel to asyncio.Protocol; DatagramProtocol's MRO is [DatagramProtocol, BaseProtocol, object] (length=3); DatagramProtocol.__module__ is 'asyncio.protocols'; DatagramProtocol adds datagram_received and error_received methods (own methods with 'DatagramProtocol.' prefix in qualname), while connection_made and connection_lost are inherited from BaseProtocol (qualname 'BaseProtocol.connection_made' and 'BaseProtocol.connection_lost'); DatagramProtocol is used for UDP transports, unlike Protocol which is used for stream (TCP) transports; NEW in extra277: first standalone DatagramProtocol base class invariant in asyncioprotident277 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "asyncio.DatagramProtocol.__bases__[0].__name__.__eq__"
  args: ["BaseProtocol"]
  expected: true
