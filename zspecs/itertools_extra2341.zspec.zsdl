spec: itertools_extra2341
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 603 (_extra2341): __slots__ content and absence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All itertools types are C extension types implemented in Modules/itertoolsmodule.c."
    - "C extension types do not expose a Python-level __slots__ entry in their __dict__."
    - "Verified for: chain, cycle, count, combinations, permutations, product, islice, repeat, groupby, compress, takewhile, dropwhile, starmap, accumulate, filterfalse, zip_longest, pairwise."
    - "All __dict__.__contains__('__slots__') calls return False on Python 3.14."
  created_at: "2026-04-12"

table itertools_extra2341.c_types_no_slots_a:
  description: "itertools C types: chain, cycle, count, combinations, permutations, product, islice — no __slots__ in __dict__"
  kind: python_call_eq
  category: slots_absence
  id_prefix: it2341
  columns: [id, function, args, expected]
  rows:
    - ["it2341001", "itertools.chain.__dict__.__contains__", ["__slots__"], false]
    - ["it2341002", "itertools.cycle.__dict__.__contains__", ["__slots__"], false]
    - ["it2341003", "itertools.count.__dict__.__contains__", ["__slots__"], false]
    - ["it2341004", "itertools.combinations.__dict__.__contains__", ["__slots__"], false]
    - ["it2341005", "itertools.permutations.__dict__.__contains__", ["__slots__"], false]
    - ["it2341006", "itertools.product.__dict__.__contains__", ["__slots__"], false]
    - ["it2341007", "itertools.islice.__dict__.__contains__", ["__slots__"], false]

