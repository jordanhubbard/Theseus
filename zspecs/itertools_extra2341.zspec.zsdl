table itertools_extra2341.c_types_no_slots_cross_check:
  description: "Cross-check: C extension types also do not expose arbitrary slot names like 'iterable' or 'stop'"
  kind: python_call_eq
  category: slots_absence
  id_prefix: it2341
  columns: [id, function, args, expected]
  rows:
    - ["it2341018", "itertools.chain.__dict__.__contains__", ["iterable"], false]
    - ["it2341019", "itertools.cycle.__dict__.__contains__", ["iterable"], false]
    - ["it2341020", "itertools.count.__dict__.__contains__", ["stop"], false]
    - ["it2341021", "itertools.repeat.__dict__.__contains__", ["object"], false]
    - ["it2341022", "itertools.islice.__dict__.__contains__", ["stop"], false]
