spec: functools_extra213
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "Python functools documentation — https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools_extra212.zspec.zsdl — covers co_flags, co_stacksize, and co_filename checks for lru_cache, wraps, update_wrapper, cache, singledispatch"
    - "functools_extra211.zspec.zsdl — covers __defaults__ class names and lengths for lru_cache, wraps, update_wrapper"
    - "functools_extra.zspec.zsdl — covers __name__ and __module__ checks for public functools symbols"
  notes:
    - "functools.lru_cache.__code__.co_varnames is a tuple of 5 elements: ('maxsize', 'typed', 'user_function', 'wrapper', 'decorating_function'). Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_varnames is a tuple of 3 elements: ('wrapped', 'assigned', 'updated'). Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_varnames.__contains__('wrapped') == True — 'wrapped' is the first positional argument to wraps. Verified with Python 3.14.3."
    - "functools.update_wrapper.__code__.co_varnames is a tuple of 6 elements: ('wrapper', 'wrapped', 'assigned', 'updated', 'attr', 'value'). Verified with Python 3.14.3."
    - "functools.update_wrapper.__code__.co_varnames.__contains__('wrapper') == True — 'wrapper' is the first positional argument to update_wrapper. Verified with Python 3.14.3."
    - "functools.reduce is a C-level built-in function and does not have a __code__ attribute; co_varnames checks apply only to Python-level functions."
    - "co_varnames.__class__.__name__ == 'tuple' for all Python-level functools functions — co_varnames is always a tuple of local variable names. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: co_varnames.__class__.__name__ == 'tuple' for Python-level functools functions
#
# lru_cache, wraps, and update_wrapper are Python-level functions.
# Their __code__.co_varnames is always a tuple of local variable name strings.
# co_varnames.__class__.__name__ == 'tuple' for all of them.
# Verified values: lru_cache len=5, wraps len=3, update_wrapper len=6.
# ---------------------------------------------------------------------------

table functools_extra213.co_varnames_class_name:
  description: "__code__.co_varnames.__class__.__name__ == 'tuple' for Python-level functools functions; co_varnames is a tuple of local variable names; lru_cache has 5 varnames, wraps has 3, update_wrapper has 6; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_object
  id_prefix: functcovarnames213

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_varnames_class,
       "lru_cache.__code__.co_varnames.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.lru_cache.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of 5 local variable names: maxsize, typed, user_function, wrapper, decorating_function; str.__eq__('tuple') returns True; new to extra213"]
    - [wraps_varnames_class,
       "wraps.__code__.co_varnames.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.wraps.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of 3 local variable names: wrapped, assigned, updated; str.__eq__('tuple') returns True; new to extra213"]
    - [update_wrapper_varnames_class,
       "update_wrapper.__code__.co_varnames.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.update_wrapper.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of 6 local variable names: wrapper, wrapped, assigned, updated, attr, value; str.__eq__('tuple') returns True; new to extra213"]
    - [singledispatch_varnames_class,
       "singledispatch.__code__.co_varnames.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.singledispatch.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of local variable names for the singledispatch decorator factory; str.__eq__('tuple') returns True; new to extra213"]

# ---------------------------------------------------------------------------
# Table 2: co_varnames.__len__() exact counts
#
# lru_cache has 5 local variable names.
# wraps has 3 local variable names.
# update_wrapper has 6 local variable names.
# ---------------------------------------------------------------------------

table functools_extra213.co_varnames_len:
  description: "__code__.co_varnames.__len__() exact counts for Python-level functools functions; lru_cache=5, wraps=3, update_wrapper=6; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_object
  id_prefix: functcovarnames213

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_varnames_len,
       "lru_cache.__code__.co_varnames.__len__",
       [],
       5,
       "functools.lru_cache.__code__.co_varnames.__len__() == 5 — lru_cache has 5 local variable names: maxsize, typed, user_function, wrapper, decorating_function; tuple.__len__() returns 5; new to extra213"]
    - [wraps_varnames_len,
       "wraps.__code__.co_varnames.__len__",
       [],
       3,
       "functools.wraps.__code__.co_varnames.__len__() == 3 — wraps has 3 local variable names: wrapped, assigned, updated; tuple.__len__() returns 3; new to extra213"]
    - [update_wrapper_varnames_len,
       "update_wrapper.__code__.co_varnames.__len__",
       [],
       6,
       "functools.update_wrapper.__code__.co_varnames.__len__() == 6 — update_wrapper has 6 local variable names: wrapper, wrapped, assigned, updated, attr, value; tuple.__len__() returns 6; new to extra213"]
    - [wraps_varnames_contains_wrapped,
       "wraps.__code__.co_varnames.__contains__",
       ["wrapped"],
       true,
       "functools.wraps.__code__.co_varnames.__contains__('wrapped') == True — 'wrapped' is the first positional argument to wraps (the function being decorated); tuple.__contains__('wrapped') returns True; new to extra213"]

# ---------------------------------------------------------------------------
# Table 3: co_varnames.__contains__ membership checks
#
# wraps: contains 'wrapped' (True)
# update_wrapper: contains 'wrapper' (True) and 'wrapped' (True)
# lru_cache: contains 'maxsize' (True) and 'typed' (True)
# ---------------------------------------------------------------------------

table functools_extra213.co_varnames_contains:
  description: "__code__.co_varnames.__contains__ membership checks for Python-level functools functions; key argument names are present in co_varnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_object
  id_prefix: functcovarnames213

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_contains_wrapper,
       "update_wrapper.__code__.co_varnames.__contains__",
       ["wrapper"],
       true,
       "functools.update_wrapper.__code__.co_varnames.__contains__('wrapper') == True — 'wrapper' is the first positional argument to update_wrapper (the function being decorated); tuple.__contains__('wrapper') returns True; new to extra213"]
    - [update_wrapper_contains_wrapped,
       "update_wrapper.__code__.co_varnames.__contains__",
       ["wrapped"],
       true,
       "functools.update_wrapper.__code__.co_varnames.__contains__('wrapped') == True — 'wrapped' is the second positional argument to update_wrapper (the original function whose attributes are copied); tuple.__contains__('wrapped') returns True; new to extra213"]
    - [lru_cache_contains_maxsize,
       "lru_cache.__code__.co_varnames.__contains__",
       ["maxsize"],
       true,
       "functools.lru_cache.__code__.co_varnames.__contains__('maxsize') == True — 'maxsize' is the first parameter of lru_cache controlling the cache size; tuple.__contains__('maxsize') returns True; new to extra213"]
    - [lru_cache_contains_typed,
       "lru_cache.__code__.co_varnames.__contains__",
       ["typed"],
       true,
       "functools.lru_cache.__code__.co_varnames.__contains__('typed') == True — 'typed' is the second parameter of lru_cache controlling type-based cache key separation; tuple.__contains__('typed') returns True; new to extra213"]
    - [wraps_contains_assigned,
       "wraps.__code__.co_varnames.__contains__",
       ["assigned"],
       true,
       "functools.wraps.__code__.co_varnames.__contains__('assigned') == True — 'assigned' is the second parameter of wraps listing attributes to copy directly; tuple.__contains__('assigned') returns True; new to extra213"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra213
# ---------------------------------------------------------------------------

invariant functools_extra213.lru_cache_varnames_class_tuple:
  description: "functools.lru_cache.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of 5 local variable names; lru_cache is a Python-level function; new to extra213; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: lru_cache.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra213.lru_cache_varnames_len_5:
  description: "functools.lru_cache.__code__.co_varnames.__len__() == 5 — lru_cache has 5 local variable names: maxsize, typed, user_function, wrapper, decorating_function; new to extra213; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: lru_cache.__code__.co_varnames.__len__
  args: []
  expected: 5

invariant functools_extra213.wraps_varnames_contains_wrapped:
  description: "functools.wraps.__code__.co_varnames.__contains__('wrapped') == True — 'wrapped' is the first positional argument to wraps; the decorated function being wrapped; new to extra213; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: wraps.__code__.co_varnames.__contains__
  args: ["wrapped"]
  expected: true

invariant functools_extra213.update_wrapper_varnames_contains_wrapper:
  description: "functools.update_wrapper.__code__.co_varnames.__contains__('wrapper') == True — 'wrapper' is the first positional argument to update_wrapper; the function being decorated; new to extra213; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: update_wrapper.__code__.co_varnames.__contains__
  args: ["wrapper"]
  expected: true

invariant functools_extra213.wraps_varnames_len_3:
  description: "functools.wraps.__code__.co_varnames.__len__() == 3 — wraps has 3 local variable names: wrapped, assigned, updated; new to extra213; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: wraps.__code__.co_varnames.__len__
  args: []
  expected: 3

invariant functools_extra213.update_wrapper_varnames_len_6:
  description: "functools.update_wrapper.__code__.co_varnames.__len__() == 6 — update_wrapper has 6 local variable names: wrapper, wrapped, assigned, updated, attr, value; new to extra213; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: update_wrapper.__code__.co_varnames.__len__
  args: []
  expected: 6

invariant functools_extra213.update_wrapper_varnames_class_tuple:
  description: "functools.update_wrapper.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of 6 local variable names; update_wrapper is a Python-level function; new to extra213; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: update_wrapper.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra213.lru_cache_varnames_contains_maxsize:
  description: "functools.lru_cache.__code__.co_varnames.__contains__('maxsize') == True — 'maxsize' is the first parameter of lru_cache controlling the LRU cache size limit; new to extra213; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: lru_cache.__code__.co_varnames.__contains__
  args: ["maxsize"]
  expected: true
