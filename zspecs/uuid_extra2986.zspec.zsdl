spec: uu2986
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid: UUID objects according to RFC 4122"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 646 (uu2986): __len__, __length_hint__, __contains__ dict-presence checks for uuid types."
    - "uuid.UUID is an immutable identifier class; uuid.SafeUUID is an Enum — neither is a container or sequence type."
    - "None of the uuid types define __len__, __length_hint__, or __contains__ in their own __dict__."
    - "Verified types: uuid.UUID, uuid.SafeUUID."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table uu2986.len:
