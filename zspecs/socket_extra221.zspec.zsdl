# socket function and class __qualname__ equality checks
#
# socket.socket.__qualname__.__eq__('socket')          == True
# socket.socket.bind.__qualname__.__eq__('socket.bind') == True
# socket.socket.connect.__qualname__.__eq__('socket.connect') == True
# socket.socket.send.__qualname__.__eq__('socket.send') == True
# socket.gethostname.__qualname__.__eq__('gethostname') == True
# ---------------------------------------------------------------------------

invariant socket_extra221.socket_class_qualname_eq:
  description: "socket.socket.__qualname__.__eq__('socket') == True — socket.socket is the main socket class; its qualname is 'socket' (matching the class name); note the module and class share the name 'socket'; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "socket.socket.__qualname__.__eq__"
  args: ["socket"]
  expected: true

invariant socket_extra221.socket_bind_qualname_eq:
  description: "socket.socket.bind.__qualname__.__eq__('socket.bind') == True — socket.bind is a method of the socket class; qualified name 'socket.bind' correctly names the class and method; binds socket to address; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "socket.socket.bind.__qualname__.__eq__"
  args: ["socket.bind"]
  expected: true

invariant socket_extra221.socket_connect_qualname_eq:
  description: "socket.socket.connect.__qualname__.__eq__('socket.connect') == True — socket.connect is a method of the socket class; qualified name 'socket.connect' correctly names the class and method; connects socket to remote address; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "socket.socket.connect.__qualname__.__eq__"
  args: ["socket.connect"]
  expected: true

invariant socket_extra221.socket_send_qualname_eq:
  description: "socket.socket.send.__qualname__.__eq__('socket.send') == True — socket.send is a method of the socket class; qualified name 'socket.send' correctly names the class and method; sends data to remote end; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "socket.socket.send.__qualname__.__eq__"
  args: ["socket.send"]
  expected: true

invariant socket_extra221.gethostname_qualname_eq:
  description: "socket.gethostname.__qualname__.__eq__('gethostname') == True — socket.gethostname is a module-level function; its qualname is 'gethostname' (11 chars); returns the machine's hostname; implemented in _socket C extension but qualname is the simple name; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "socket.gethostname.__qualname__.__eq__"
  args: ["gethostname"]
  expected: true
