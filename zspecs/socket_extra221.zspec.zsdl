table socket_extra221.socket_method_qualname_lengths_b:
  description: "socket.socket method and exception __qualname__.__len__() checks in socket221a namespace — wave 221 theme: socket.accept is 13 chars; socket.send is 11 chars; socket.recv is 11 chars (same as send); gaierror is 8 chars; herror is 6 chars; send and recv are symmetric at 11 chars each; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
