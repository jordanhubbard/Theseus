spec: socket_extra221
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 793 — Transmission Control Protocol (TCP)"
  - "RFC 791 — Internet Protocol (IP)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.socket.__qualname__ == 'socket' (6 chars)."
    - "socket.socket.close.__qualname__ == 'socket.close' (12 chars)."
    - "socket.socket.bind.__qualname__ == 'socket.bind' (11 chars)."
    - "socket.socket.connect.__qualname__ == 'socket.connect' (14 chars)."
    - "socket.socket.listen.__qualname__ == 'socket.listen' (13 chars)."
    - "socket.socket.accept.__qualname__ == 'socket.accept' (13 chars)."
    - "socket.socket.send.__qualname__ == 'socket.send' (11 chars)."
    - "socket.socket.recv.__qualname__ == 'socket.recv' (11 chars)."
    - "socket.gaierror.__qualname__ == 'gaierror' (8 chars)."
    - "socket.herror.__qualname__ == 'herror' (6 chars)."
    - "socket.gethostname.__qualname__ == 'gethostname' (11 chars)."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket class and method __qualname__.__len__() checks (group A)
#
# socket.socket.__qualname__.__len__()         == 6   ('socket')
# socket.socket.close.__qualname__.__len__()   == 12  ('socket.close')
# socket.socket.bind.__qualname__.__len__()    == 11  ('socket.bind')
# socket.socket.connect.__qualname__.__len__() == 14  ('socket.connect')
# socket.socket.listen.__qualname__.__len__()  == 13  ('socket.listen')
# ---------------------------------------------------------------------------

table socket_extra221.socket_method_qualname_lengths_a:
  description: "socket.socket class and method __qualname__.__len__() checks in socket221 namespace — wave 221 theme: socket class qualname is 6 chars; socket.close is 12 chars; socket.bind is 11 chars; socket.connect is 14 chars; socket.listen is 13 chars; all socket methods carry the 'socket.' prefix (7 chars); verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: socket221

  columns: [id, function, args, expected, description]
  rows:
    - [socket_class_qualname_len,   socket.socket.__qualname__.__len__,         [], 6,  "socket.socket.__qualname__.__len__() == 6 — class qualname 'socket' is 6 characters"]
    - [socket_close_qualname_len,   socket.socket.close.__qualname__.__len__,   [], 12, "socket.socket.close.__qualname__.__len__() == 12 — 'socket.close' is 12 characters"]
    - [socket_bind_qualname_len,    socket.socket.bind.__qualname__.__len__,    [], 11, "socket.socket.bind.__qualname__.__len__() == 11 — 'socket.bind' is 11 characters"]
    - [socket_connect_qualname_len, socket.socket.connect.__qualname__.__len__, [], 14, "socket.socket.connect.__qualname__.__len__() == 14 — 'socket.connect' is 14 characters"]
    - [socket_listen_qualname_len,  socket.socket.listen.__qualname__.__len__,  [], 13, "socket.socket.listen.__qualname__.__len__() == 13 — 'socket.listen' is 13 characters"]

