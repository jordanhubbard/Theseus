table asyncio_extra185.name_len_and_mro:
  description: "asyncio event loop name lengths and MRO depths: AEL name=17 > BEL name=13; AEL mro=2, BEL mro=3; new to asyncio_extra185"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioeventloop185

  columns: [id, function, args, expected, description]
  rows:
    - [ael_name_len_17b,
       AbstractEventLoop.__name__.__len__,
       [],
       17,
       "asyncio.AbstractEventLoop.__name__.__len__() == 17 — longer name; AEL(17) > BEL(13); str.__len__() returns 17; new to asyncio_extra185"]
    - [bel_name_len_13b,
       BaseEventLoop.__name__.__len__,
       [],
       13,
       "asyncio.BaseEventLoop.__name__.__len__() == 13 — shorter name; BEL(13) < AEL(17); str.__len__() returns 13; new to asyncio_extra185"]
    - [ael_mro_len_2,
       AbstractEventLoop.__mro__.__len__,
       [],
       2,
       "asyncio.AbstractEventLoop.__mro__.__len__() == 2 — MRO is (AbstractEventLoop, object); tuple.__len__() returns 2; new to asyncio_extra185"]
    - [bel_mro_len_3,
       BaseEventLoop.__mro__.__len__,
       [],
       3,
       "asyncio.BaseEventLoop.__mro__.__len__() == 3 — MRO is (BaseEventLoop, AbstractEventLoop, object); tuple.__len__() returns 3; new to asyncio_extra185"]
    - [ael_module_len_14,
       AbstractEventLoop.__module__.__len__,
       [],
       14,
       "asyncio.AbstractEventLoop.__module__.__len__() == 14 — 'asyncio.events' has 14 characters; str.__len__() returns 14; new to asyncio_extra185"]

