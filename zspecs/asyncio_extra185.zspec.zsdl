spec: asyncio_extra185
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "asyncio.AbstractEventLoop.__module__ is 'asyncio.events' (not 'asyncio.base_events'); verified with Python 3.14.3."
    - "asyncio.BaseEventLoop.__module__ is 'asyncio.base_events'; verified with Python 3.14.3."
    - "AbstractEventLoop.__name__ has len=17: A-b-s-t-r-a-c-t-E-v-e-n-t-L-o-o-p. BaseEventLoop.__name__ has len=13: B-a-s-e-E-v-e-n-t-L-o-o-p."
    - "AbstractEventLoop.__mro__ has len=2 (AbstractEventLoop, object). BaseEventLoop.__mro__ has len=3 (BaseEventLoop, AbstractEventLoop, object)."
    - "AbstractEventLoop.__bases__[0].__name__ == 'object'; BaseEventLoop.__bases__[0].__name__ == 'AbstractEventLoop'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.AbstractEventLoop identity
