# ---------------------------------------------------------------------------

table asyncio_extra185.abstract_event_loop_identity:
  description: "asyncio.AbstractEventLoop class identity: name len=17, module='asyncio.events', qualname, bases[0]='object'; new to asyncio_extra185"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioeventloop185

  columns: [id, function, args, expected, description]
  rows:
    - [ael_name_eq,
       AbstractEventLoop.__name__.__eq__,
       ["AbstractEventLoop"],
       true,
       "asyncio.AbstractEventLoop.__name__.__eq__('AbstractEventLoop') == True — class name is 'AbstractEventLoop'; str.__eq__ returns True; new to asyncio_extra185"]
    - [ael_name_len_17,
       AbstractEventLoop.__name__.__len__,
       [],
       17,
       "asyncio.AbstractEventLoop.__name__.__len__() == 17 — 'AbstractEventLoop' has 17 characters: A-b-s-t-r-a-c-t-E-v-e-n-t-L-o-o-p; str.__len__() returns 17; new to asyncio_extra185"]
    - [ael_module_eq,
       AbstractEventLoop.__module__.__eq__,
       ["asyncio.events"],
       true,
       "asyncio.AbstractEventLoop.__module__.__eq__('asyncio.events') == True — class is defined in asyncio.events; str.__eq__ returns True; new to asyncio_extra185"]
    - [ael_qualname_eq,
       AbstractEventLoop.__qualname__.__eq__,
       ["AbstractEventLoop"],
       true,
       "asyncio.AbstractEventLoop.__qualname__.__eq__('AbstractEventLoop') == True — qualname equals name for top-level class; str.__eq__ returns True; new to asyncio_extra185"]
    - [ael_bases0_name_eq,
       "AbstractEventLoop.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "asyncio.AbstractEventLoop.__bases__[0].__name__.__eq__('object') == True — AbstractEventLoop directly inherits from object; str.__eq__ returns True; new to asyncio_extra185"]

