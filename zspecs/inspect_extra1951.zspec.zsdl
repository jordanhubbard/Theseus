spec: inspect_extra1951
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 577 (_extra1951): __contains__, __iter__, __next__, __aiter__, __anext__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "inspect.Parameter, inspect.Signature, and inspect.BoundArguments do NOT define __contains__ in their own __dict__."
    - "None of the inspect classes define __iter__ or __next__ in their own __dict__ — they are not iterators."
    - "None of the inspect classes define __aiter__ or __anext__ — inspect has no async iterator types."
    - "inspect.Signature.__dict__.__contains__ returns False for __iter__, __next__, and __contains__."
  created_at: "2026-04-12"
error_model: python_exceptions

table inspect_extra1951.contains_protocol_parameter:
  description: "inspect.Parameter __contains__ dict-presence checks — not defined"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1951
  columns: [id, function, args, expected]
  rows:
    - ["in1951001", "inspect.Parameter.__dict__.__contains__",      ["__contains__"], false]
    - ["in1951002", "inspect.Signature.__dict__.__contains__",      ["__contains__"], false]
    - ["in1951003", "inspect.BoundArguments.__dict__.__contains__", ["__contains__"], false]

table inspect_extra1951.iter_protocol:
  description: "inspect classes __iter__ dict-presence checks — none define __iter__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1951
  columns: [id, function, args, expected]
  rows:
    - ["in1951004", "inspect.Parameter.__dict__.__contains__",      ["__iter__"], false]
    - ["in1951005", "inspect.Signature.__dict__.__contains__",      ["__iter__"], false]
    - ["in1951006", "inspect.BoundArguments.__dict__.__contains__", ["__iter__"], false]

table inspect_extra1951.next_protocol:
  description: "inspect classes __next__ dict-presence checks — none define __next__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1951
  columns: [id, function, args, expected]
  rows:
    - ["in1951007", "inspect.Parameter.__dict__.__contains__",      ["__next__"], false]
    - ["in1951008", "inspect.Signature.__dict__.__contains__",      ["__next__"], false]
    - ["in1951009", "inspect.BoundArguments.__dict__.__contains__", ["__next__"], false]

table inspect_extra1951.async_iter_protocol_parameter:
  description: "inspect.Parameter __aiter__/__anext__ dict-presence checks — not defined"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1951
  columns: [id, function, args, expected]
  rows:
    - ["in1951010", "inspect.Parameter.__dict__.__contains__",      ["__aiter__"], false]
    - ["in1951011", "inspect.Parameter.__dict__.__contains__",      ["__anext__"], false]
    - ["in1951012", "inspect.Signature.__dict__.__contains__",      ["__aiter__"], false]
    - ["in1951013", "inspect.Signature.__dict__.__contains__",      ["__anext__"], false]
    - ["in1951014", "inspect.BoundArguments.__dict__.__contains__", ["__aiter__"], false]
    - ["in1951015", "inspect.BoundArguments.__dict__.__contains__", ["__anext__"], false]

table inspect_extra1951.signature_dict_contains_three:
  description: "inspect.Signature.__dict__.__contains__ called with __iter__, __next__, __contains__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1951
  columns: [id, function, args, expected]
  rows:
    - ["in1951016", "inspect.Signature.__dict__.__contains__", ["__iter__"],     false]
    - ["in1951017", "inspect.Signature.__dict__.__contains__", ["__next__"],     false]
    - ["in1951018", "inspect.Signature.__dict__.__contains__", ["__contains__"], false]

table inspect_extra1951.parameter_positive_dict_presence:
  description: "inspect.Parameter and Signature own-dict presence of real members"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1951
  columns: [id, function, args, expected]
  rows:
    - ["in1951019", "inspect.Parameter.__dict__.__contains__",      ["kind"],             true]
    - ["in1951020", "inspect.Parameter.__dict__.__contains__",      ["default"],          true]
    - ["in1951021", "inspect.Parameter.__dict__.__contains__",      ["annotation"],       true]
    - ["in1951022", "inspect.Parameter.__dict__.__contains__",      ["name"],             true]
    - ["in1951023", "inspect.Signature.__dict__.__contains__",      ["parameters"],       true]
    - ["in1951024", "inspect.Signature.__dict__.__contains__",      ["return_annotation"], true]
    - ["in1951025", "inspect.Signature.__dict__.__contains__",      ["bind"],             true]
    - ["in1951026", "inspect.BoundArguments.__dict__.__contains__", ["arguments"],        true]
    - ["in1951027", "inspect.BoundArguments.__dict__.__contains__", ["args"],             true]
    - ["in1951028", "inspect.BoundArguments.__dict__.__contains__", ["kwargs"],           true]

table inspect_extra1951.iter_contains_cross_check:
  description: "Cross-check: __iter__ and __contains__ absent while real members present across all three classes"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1951
  columns: [id, function, args, expected]
  rows:
    - ["in1951029", "inspect.Parameter.__dict__.__contains__",      ["__iter__"],     false]
    - ["in1951030", "inspect.Parameter.__dict__.__contains__",      ["__contains__"], false]
    - ["in1951031", "inspect.BoundArguments.__dict__.__contains__", ["__iter__"],     false]
    - ["in1951032", "inspect.BoundArguments.__dict__.__contains__", ["__contains__"], false]
