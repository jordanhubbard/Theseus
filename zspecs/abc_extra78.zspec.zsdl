spec: abc_extra78
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra77.zspec.zsdl."
    - "This spec covers: wave 245 theme — abc ABC/ABCMeta __module__ and __dict__ class names. NEW in extra78: ABC.__module__=='abc'; ABCMeta.__module__=='abc'; abstractmethod.__module__=='abc'; abstractproperty.__module__=='abc'; ABC.__dict__.__class__.__name__=='mappingproxy'; ABCMeta.__dict__.__class__.__name__=='mappingproxy'; ABC.__bases__[0].__name__=='object'; ABCMeta.__bases__[0].__name__=='type'; ABC.__qualname__=='ABC'; ABCMeta.__qualname__=='ABCMeta'; ABC.__name__=='ABC'; ABCMeta.__name__=='ABCMeta'; abstractmethod.__name__=='abstractmethod'; abstractproperty.__name__=='abstractproperty'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__module__ == 'abc'. ABC is defined in the abc module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__module__ == 'abc'. ABCMeta is defined in the abc module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__module__ == 'abc'. abstractmethod is defined in the abc module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__module__ == 'abc'. abstractproperty is defined in the abc module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy'. Like all class __dict__ attributes, it is a mappingproxy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'. Like all class __dict__ attributes, it is a mappingproxy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__bases__[0].__name__ == 'object'. ABC directly subclasses object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type'. ABCMeta directly subclasses type, making it a metaclass. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__qualname__ == 'ABC'. Simple unqualified class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__qualname__ == 'ABCMeta'. Simple unqualified class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__name__ == 'ABC'. Simple class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__name__ == 'ABCMeta'. Simple class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__name__ == 'abstractmethod'. Simple class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__name__ == 'abstractproperty'. Simple class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc ABC and ABCMeta __module__ checks — extra78
#
# Wave 245 theme: abc ABC/ABCMeta __module__ and __dict__ class names.
#
# ABC.__module__ == 'abc'
# ABCMeta.__module__ == 'abc'
# abstractmethod.__module__ == 'abc'
# abstractproperty.__module__ == 'abc'
# ---------------------------------------------------------------------------

table abc_extra78.ABC_and_ABCMeta_modules:
  description: "abc ABC/ABCMeta/abstractmethod/abstractproperty __module__ checks in abcextra78 namespace — wave 245 theme: abc ABC/ABCMeta __module__ and __dict__ class names; ABC.__module__=='abc'; ABCMeta.__module__=='abc'; abstractmethod.__module__=='abc'; abstractproperty.__module__=='abc'; all abc classes are defined directly in the abc module; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra78

  columns: [id, function, args, expected, description]
  rows:
    - [abc_module,      ABC.__module__.__eq__,              ["abc"], true, "ABC.__module__ == 'abc' — ABC is defined in the abc module; verified with Python 3.14.3"]
    - [abcmeta_module,  ABCMeta.__module__.__eq__,          ["abc"], true, "ABCMeta.__module__ == 'abc' — ABCMeta is defined in the abc module; verified with Python 3.14.3"]
    - [am_module,       abstractmethod.__module__.__eq__,   ["abc"], true, "abstractmethod.__module__ == 'abc' — abstractmethod is defined in the abc module; verified with Python 3.14.3"]
    - [ap_module,       abstractproperty.__module__.__eq__, ["abc"], true, "abstractproperty.__module__ == 'abc' — abstractproperty is defined in the abc module; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABC and ABCMeta __dict__ class names — extra78
#
# ABC.__dict__.__class__.__name__ == 'mappingproxy'
# ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'
# ABC.__bases__[0].__name__ == 'object'
# ABCMeta.__bases__[0].__name__ == 'type'
# ---------------------------------------------------------------------------

table abc_extra78.ABC_and_ABCMeta_dict_class_and_bases:
  description: "abc ABC and ABCMeta __dict__ class name and __bases__ checks in abcextra78 namespace — wave 245 theme: abc ABC/ABCMeta __dict__ class names and base classes; ABC.__dict__.__class__.__name__=='mappingproxy'; ABCMeta.__dict__.__class__.__name__=='mappingproxy'; ABC.__bases__[0].__name__=='object' (ABC directly subclasses object); ABCMeta.__bases__[0].__name__=='type' (ABCMeta subclasses type, making it a metaclass); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra78a

  columns: [id, function, args, expected, description]
  rows:
    - [abc_dict_class,    ABC.__dict__.__class__.__name__.__eq__,    ["mappingproxy"], true, "ABC.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy; verified with Python 3.14.3"]
    - [abcmeta_dict_class, ABCMeta.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "ABCMeta.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy; verified with Python 3.14.3"]
    - [abc_base_name,     "ABC.__bases__[0].__name__.__eq__",        ["object"],       true, "ABC.__bases__[0].__name__ == 'object' — ABC directly subclasses object; verified with Python 3.14.3"]
    - [abcmeta_base_name, "ABCMeta.__bases__[0].__name__.__eq__",    ["type"],         true, "ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta subclasses type, making it a metaclass; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABC and ABCMeta __qualname__ and __name__ checks — extra78
#
# ABC.__qualname__ == 'ABC'
# ABCMeta.__qualname__ == 'ABCMeta'
# ABC.__name__ == 'ABC'
# ABCMeta.__name__ == 'ABCMeta'
# ---------------------------------------------------------------------------

table abc_extra78.ABC_and_ABCMeta_qualnames_and_names:
  description: "abc ABC and ABCMeta __qualname__ and __name__ checks in abcextra78 namespace — wave 245 theme: abc ABC/ABCMeta identity attributes; ABC.__qualname__=='ABC'; ABCMeta.__qualname__=='ABCMeta'; ABC.__name__=='ABC'; ABCMeta.__name__=='ABCMeta'; all are simple top-level class names with no enclosing scope; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra78b

  columns: [id, function, args, expected, description]
  rows:
    - [abc_qualname,     ABC.__qualname__.__eq__,    ["ABC"],     true, "ABC.__qualname__ == 'ABC' — simple top-level class qualname; verified with Python 3.14.3"]
    - [abcmeta_qualname, ABCMeta.__qualname__.__eq__, ["ABCMeta"], true, "ABCMeta.__qualname__ == 'ABCMeta' — simple top-level class qualname; verified with Python 3.14.3"]
    - [abc_name,         ABC.__name__.__eq__,        ["ABC"],     true, "ABC.__name__ == 'ABC' — simple class name; verified with Python 3.14.3"]
    - [abcmeta_name,     ABCMeta.__name__.__eq__,    ["ABCMeta"], true, "ABCMeta.__name__ == 'ABCMeta' — simple class name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc abstractmethod and abstractproperty __name__ checks + cross-checks — extra78
# ---------------------------------------------------------------------------

table abc_extra78.abstract_decorator_names_and_cross_checks:
  description: "abc abstractmethod and abstractproperty __name__ checks and cross-check table in abcextra78 namespace — wave 245 theme: abc abstract decorator identity; abstractmethod.__name__=='abstractmethod'; abstractproperty.__name__=='abstractproperty'; ABC.__module__=='abc' (cross-check); ABCMeta.__module__=='abc' (cross-check); ABC.__bases__[0].__name__=='object' (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra78c

  columns: [id, function, args, expected, description]
  rows:
    - [am_name,           abstractmethod.__name__.__eq__,   ["abstractmethod"],   true, "abstractmethod.__name__ == 'abstractmethod' — simple class name; verified with Python 3.14.3"]
    - [ap_name,           abstractproperty.__name__.__eq__, ["abstractproperty"], true, "abstractproperty.__name__ == 'abstractproperty' — simple class name; verified with Python 3.14.3"]
    - [abc_module_cross,  ABC.__module__.__eq__,            ["abc"],              true, "ABC.__module__ == 'abc' — cross-check; verified with Python 3.14.3"]
    - [abcmeta_mod_cross, ABCMeta.__module__.__eq__,        ["abc"],              true, "ABCMeta.__module__ == 'abc' — cross-check; verified with Python 3.14.3"]
    - [abc_base_cross,    "ABC.__bases__[0].__name__.__eq__", ["object"],         true, "ABC.__bases__[0].__name__ == 'object' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra78
# ---------------------------------------------------------------------------

invariant abc_extra78.ABC_module:
  description: "abc.ABC.__module__.__eq__('abc') returns True — ABC is defined directly in the abc module; NEW in extra78: first standalone __module__ invariant for ABC in abcextra78 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABC.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra78.ABCMeta_module:
  description: "abc.ABCMeta.__module__.__eq__('abc') returns True — ABCMeta is defined directly in the abc module; NEW in extra78: first standalone __module__ invariant for ABCMeta in abcextra78 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra78.ABC_dict_class_name:
  description: "abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — the __dict__ attribute of any Python class is a mappingproxy, a read-only view of the class namespace; NEW in extra78: first standalone __dict__.__class__.__name__ invariant for ABC in abcextra78 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABC.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra78.ABCMeta_base_name:
  description: "abc.ABCMeta.__bases__[0].__name__.__eq__('type') returns True — ABCMeta subclasses type, making it a metaclass that controls class creation for abstract base classes; NEW in extra78: first standalone __bases__[0].__name__ invariant for ABCMeta in abcextra78 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__bases__[0].__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra78.abstractmethod_name:
  description: "abc.abstractmethod.__name__.__eq__('abstractmethod') returns True — abstractmethod is a top-level decorator class in the abc module; NEW in extra78: first standalone __name__ invariant for abstractmethod in abcextra78 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__name__.__eq__
  args: ["abstractmethod"]
  expected: true
