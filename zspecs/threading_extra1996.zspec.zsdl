spec: threading_extra1996
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 580 (_extra1996): __index__, __complex__, __float__, __round__, __abs__ dict-presence checks."
    - "threading.Thread, threading.Event, threading.Lock, threading.Condition, threading.Semaphore, threading.Barrier are synchronization primitives — none are numeric types."
    - "None of the threading classes define __index__ — they are not integer-like types."
    - "None of the threading classes define __complex__ or __float__ — no numeric conversion protocols."
    - "None of the threading classes define __round__ or __abs__ — no rounding or absolute value protocols."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table threading_extra1996.index_protocol:
  description: "threading types __index__ dict-presence checks — none define integer conversion protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1996
  columns: [id, function, args, expected]
  rows:
    - ["th1996001", "threading.Thread.__dict__.__contains__",    ["__index__"], false]
    - ["th1996002", "threading.Event.__dict__.__contains__",     ["__index__"], false]
    - ["th1996003", "threading.Lock.__dict__.__contains__",      ["__index__"], false]
    - ["th1996004", "threading.Condition.__dict__.__contains__", ["__index__"], false]
    - ["th1996005", "threading.Semaphore.__dict__.__contains__", ["__index__"], false]
    - ["th1996006", "threading.Barrier.__dict__.__contains__",   ["__index__"], false]

