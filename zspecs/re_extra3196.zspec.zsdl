# ---------------------------------------------------------------------------
# __rshift__ dict-presence — operator.contains(Cls.__dict__, '__rshift__')
#
# No re class defines __rshift__ in its own __dict__; all false.
# re.RegexFlag is an IntFlag subclass; any right-shift behavior is inherited
