  columns: [id, function, args, expected]
  rows:
    - ["re3196007", operator.contains, [re.Pattern.__dict__,   "__rshift__"], false]
    - ["re3196008", operator.contains, [re.Match.__dict__,     "__rshift__"], false]
    - ["re3196009", operator.contains, [re.RegexFlag.__dict__, "__rshift__"], false]

# ---------------------------------------------------------------------------
# combined — __pow__, __lshift__, __rshift__ across all 3 re subjects
#
# 3 classes x 3 methods = 9 rows.
# All nine values are false; re.RegexFlag inherits any int arithmetic from base
# classes without storing those methods in its own __dict__.
# ---------------------------------------------------------------------------

table re3196.combined:
