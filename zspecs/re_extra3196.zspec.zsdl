spec: re3196
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 660 (re3196): __pow__, __lshift__, __rshift__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "No re class defines __pow__ in its own __dict__: the ** operator has no meaning for compiled patterns, match objects, or flag enumerations."
    - "No re class defines __lshift__ in its own __dict__: re types do not support bitwise left-shift."
    - "No re class defines __rshift__ in its own __dict__: re.RegexFlag is an IntFlag subclass; any bitwise behavior it supports is inherited from int/IntFlag base classes, not stored in re.RegexFlag.__dict__."
    - "re.Pattern and re.Match are accessed directly via re.Pattern.__dict__ and re.Match.__dict__ (not type(re.compile(...)).__dict__)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __pow__ dict-presence — operator.contains(Cls.__dict__, '__pow__')
#
# No re class defines __pow__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum whose exponentiation semantics, if any, come from base-class
# inheritance and are not stored in re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

table re3196.pow:
  description: "re types __pow__ dict-presence checks; wave 660"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3196

  columns: [id, function, args, expected]
  rows:
    - ["re3196001", operator.contains, [re.Pattern.__dict__,   "__pow__"], false]
    - ["re3196002", operator.contains, [re.Match.__dict__,     "__pow__"], false]
    - ["re3196003", operator.contains, [re.RegexFlag.__dict__, "__pow__"], false]

# ---------------------------------------------------------------------------
# __lshift__ dict-presence — operator.contains(Cls.__dict__, '__lshift__')
