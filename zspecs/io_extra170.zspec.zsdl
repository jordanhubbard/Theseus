spec: io_extra170
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.IOBase class identity and its C-level base _IOBase __dict__ membership; io.BufferedIOBase class identity."
    - "io.IOBase is a Python ABC wrapper defined in Lib/io.py. Its __dict__ has only 6 entries: __module__, __firstlineno__, __doc__, __static_attributes__, __abstractmethods__, _abc_impl."
    - "The real implementation lives in the C-extension class _io._IOBase, accessible as io.IOBase.__bases__[0]."
    - "io.IOBase.__bases__[0].__dict__ is the __dict__ of _io._IOBase (len=26), which contains the concrete implementations of close, flush, readline, readlines, and writelines."
    - "io.IOBase.__name__ == 'IOBase' (len=6: 'IO' (2) + 'Base' (4) = 6)."
    - "io.IOBase.__module__ == 'io' (len=2: the public io module, not the private '_io' C extension)."
    - "io.IOBase.__bases__[0].__name__ == '_IOBase' (len=7: '_' (1) + 'IOBase' (6) = 7; the leading underscore marks it as a private implementation class)."
    - "io.IOBase.__bases__[0].__dict__.__contains__('close') == True (len('close')=5)."
    - "io.IOBase.__bases__[0].__dict__.__contains__('flush') == True (len('flush')=5)."
    - "io.IOBase.__bases__[0].__dict__.__contains__('readline') == True (len('readline')=8)."
    - "io.IOBase.__bases__[0].__dict__.__contains__('readlines') == True (len('readlines')=9)."
    - "io.IOBase.__bases__[0].__dict__.__contains__('writelines') == True (len('writelines')=10)."
    - "Key name length ranking: close=flush=5, readline=8, readlines=9, writelines=10."
    - "Two-way tie at 5: close and flush — both 5-character method names."
    - "io.BufferedIOBase.__name__ == 'BufferedIOBase' (len=14: 'Buffered' (8) + 'IO' (2) + 'Base' (4) = 14)."
    - "io.BufferedIOBase.__module__ == 'io' (len=2: the public io Python module)."
    - "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' (len=15: '_' (1) + 'BufferedIOBase' (14) = 15; the private C-extension class)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.IOBase.__bases__[0].__dict__ membership
# The C-level _IOBase class is the real home of close, flush, readline,
# readlines, writelines. Accessed via io.IOBase.__bases__[0].
# close=flush=5, readline=8, readlines=9, writelines=10.
# ---------------------------------------------------------------------------

table io_extra170.IOBase_bases0_dict_membership:
  description: "io.IOBase.__bases__[0].__dict__ membership: close=flush (len=5, tie), readline (len=8), readlines (len=9), writelines (len=10); all True; two-way tie at 5 for close and flush"
  kind: python_call_eq
  category: identity
  id_prefix: iobase170

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_close_in,      "IOBase.__bases__[0].__dict__.__contains__",  ["close"],      true, "io.IOBase.__bases__[0].__dict__.__contains__('close') == True (close is defined on _IOBase, the C-level base; io.IOBase is a Python ABC wrapper — its own __dict__ has only 6 entries like __abstractmethods__; the real method implementations reside in the C class _io._IOBase, accessible as io.IOBase.__bases__[0]; IOBase.close() flushes and closes the stream; after close(), any operation on the stream raises ValueError; 'close' has 5 characters — tied with 'flush' (also 5) in key name length; close (5) < readline (8) < readlines (9) < writelines (10) in the ascending key name length sequence)"]
    - [iobase_flush_in,      "IOBase.__bases__[0].__dict__.__contains__",  ["flush"],      true, "io.IOBase.__bases__[0].__dict__.__contains__('flush') == True (flush is defined on _IOBase, the C-level base accessible as io.IOBase.__bases__[0]; IOBase.flush() flushes the write buffers of the stream; for read-only and non-blocking streams this is a no-op; 'flush' has 5 characters — tied with 'close' (also 5) in key name length; close and flush form a two-way tie at 5 because both are 5-character method names; the two-way tie at 5 is the minimum key name length in this table; flush is a no-op at the IOBase level — concrete buffered subclasses override it to drain the write buffer)"]
    - [iobase_readline_in,   "IOBase.__bases__[0].__dict__.__contains__",  ["readline"],   true, "io.IOBase.__bases__[0].__dict__.__contains__('readline') == True (readline is defined on _IOBase, the C-level base; IOBase.readline() reads and returns one line from the stream using successive calls to read(); 'readline' has 8 characters: 'read' (4) + 'line' (4) = 8; readline (8) is the third-shortest key in this table; the four distinct lengths in this table: 5 (close, flush), 8 (readline), 9 (readlines), 10 (writelines); readline (8) sits between the tie at 5 and readlines (9); readline contains the substring 'read' (4 chars) shared with 'readlines'; readline uses read(1) internally unless overridden)"]
    - [iobase_readlines_in,  "IOBase.__bases__[0].__dict__.__contains__",  ["readlines"],  true, "io.IOBase.__bases__[0].__dict__.__contains__('readlines') == True (readlines is defined on _IOBase, the C-level base; IOBase.readlines() reads and returns a list of all lines from the stream using repeated readline(); an optional hint argument limits the total bytes read; 'readlines' has 9 characters: 'read' (4) + 'lines' (5) = 9; readlines (9) is 1 character longer than readline (8) — the plural 's' adds 1 character; readlines (9) is 1 shorter than writelines (10); key name length ranking: close=flush=5, readline=8, readlines=9, writelines=10; readlines and writelines mirror each other as the plural read/write line methods)"]
    - [iobase_writelines_in, "IOBase.__bases__[0].__dict__.__contains__",  ["writelines"], true, "io.IOBase.__bases__[0].__dict__.__contains__('writelines') == True (writelines is defined on _IOBase, the C-level base; IOBase.writelines() writes a list of lines to the stream; line separators are not added by writelines() — the lines must include their own line endings; 'writelines' has 10 characters: 'write' (5) + 'lines' (5) = 10; writelines (10) is the longest key name in this table and the maximum; writelines (10) is 1 longer than readlines (9) because 'write' (5) > 'read' (4) by 1 character; the ascending sequence: close=flush=5, readline=8, readlines=9, writelines=10; writelines stands alone at the maximum length 10)"]

# ---------------------------------------------------------------------------
# io.IOBase class identity and io.BufferedIOBase class identity
# IOBase.__name__='IOBase' (len=6), __module__='io' (len=2)
# IOBase.__bases__[0].__name__='_IOBase' (len=7)
# BufferedIOBase.__name__='BufferedIOBase' (len=14), __module__='io' (len=2)
# BufferedIOBase.__bases__[0].__name__='_BufferedIOBase' (len=15)
# ---------------------------------------------------------------------------

table io_extra170.IOBase_and_BufferedIOBase_identity:
  description: "io.IOBase identity: __name__='IOBase' (len=6), __module__='io' (len=2), __bases__[0].__name__='_IOBase' (len=7); io.BufferedIOBase: __name__='BufferedIOBase' (len=14), __module__='io' (len=2), __bases__[0].__name__='_BufferedIOBase' (len=15)"
  kind: python_call_eq
  category: identity
  id_prefix: iobase170

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_name,     IOBase.__name__.__eq__,                       ["IOBase"],          true, "io.IOBase.__name__ == 'IOBase' (io.IOBase is the abstract base class for all I/O classes in the io module hierarchy; 'IOBase' has 6 characters: 'IO' (2) + 'Base' (4) = 6; io.IOBase is the Python-level ABC wrapper defined in Lib/io.py; its __module__ is 'io' (2 chars), the public module, unlike the C-implemented io classes (BufferedWriter, BytesIO, FileIO) whose __module__ is '_io' (3 chars); 'IOBase' (6 chars) is shorter than 'BufferedIOBase' (14 chars) by 8 characters — the 'Buffered' prefix (8 chars) is the difference; IOBase.__name__ (6) == IOBase.__name__.__len__() == len('IOBase') == 6)"]
    - [iobase_module,   IOBase.__module__.__eq__,                     ["io"],              true, "io.IOBase.__module__ == 'io' (io.IOBase is defined in the public 'io' module — Lib/io.py — unlike the C-extension io classes such as BytesIO, BufferedWriter, and FileIO whose __module__ is '_io' (3 chars); 'io' has 2 characters — the shortest module name in the io class hierarchy; IOBase.__module__ == 'io' (2) vs FileIO.__module__ == '_io' (3): the Python wrapper has a shorter module name than the private C implementation; the public 'io' module acts as a namespace re-exporting C classes from '_io' alongside defining ABC wrappers like IOBase and BufferedIOBase)"]
    - [iobase_base0,    "IOBase.__bases__[0].__name__.__eq__",        ["_IOBase"],         true, "io.IOBase.__bases__[0].__name__ == '_IOBase' (io.IOBase inherits from the C-extension class _io._IOBase, accessible as io.IOBase.__bases__[0]; '_IOBase' has 7 characters: '_' (1) + 'IOBase' (6) = 7; the leading underscore '_' marks _IOBase as a private implementation class; _IOBase (7 chars) is 1 character longer than IOBase (6 chars) due to the underscore prefix; _IOBase contains the actual implementations of close, flush, readline, readlines, writelines, seekable, readable, writable and other methods; io.IOBase wraps _IOBase to provide the public ABC interface with __abstractmethods__)"]
    - [bufiobase_name,  BufferedIOBase.__name__.__eq__,               ["BufferedIOBase"],  true, "io.BufferedIOBase.__name__ == 'BufferedIOBase' (io.BufferedIOBase is the abstract base class for all buffered I/O classes; 'BufferedIOBase' has 14 characters: 'Buffered' (8) + 'IO' (2) + 'Base' (4) = 14; BufferedIOBase (14 chars) is the longest class name among the IOBase family checked in this spec: IOBase (6), RawIOBase (9), BufferedIOBase (14); the 'Buffered' prefix (8 chars) is the distinguishing part; io.BufferedIOBase.__module__ == 'io' (2 chars) — it is also a Python-level ABC wrapper like io.IOBase; concrete buffered classes like BufferedWriter and BufferedReader are C-level implementations)"]
    - [bufiobase_module, BufferedIOBase.__module__.__eq__,             ["io"],              true, "io.BufferedIOBase.__module__ == 'io' (like io.IOBase, io.BufferedIOBase is a Python ABC wrapper defined in Lib/io.py; its __module__ is 'io' (2 chars) — the public module; 'io' (2 chars) is the shortest module name in the entire io class hierarchy; the parallel structure: io.IOBase.__module__ == 'io' and io.BufferedIOBase.__module__ == 'io'; both ABC wrapper classes live in the public 'io' module; contrast with the concrete BufferedWriter and BufferedReader whose __module__ is '_io' (3 chars) — they are C implementations that the public 'io' module re-exports)"]
    - [bufiobase_base0, "BufferedIOBase.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true, "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' (io.BufferedIOBase inherits from _io._BufferedIOBase, the C-level buffered IO base; '_BufferedIOBase' has 15 characters: '_' (1) + 'Buffered' (8) + 'IO' (2) + 'Base' (4) = 15; _BufferedIOBase (15 chars) is 1 longer than BufferedIOBase (14 chars) due to the leading underscore; analogously, _IOBase (7) is 1 longer than IOBase (6) — the same underscore pattern applies to both base pairs; _BufferedIOBase (15 chars) is the longest class name seen in this spec)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra170.IOBase_close_flush_tie_at_5:
  description: "io.IOBase.__bases__[0].__dict__.__contains__('close') == True — 'close' and 'flush' both have 5 characters, forming a two-way tie at 5 in key name length among the _IOBase methods checked in this spec; both close and flush are fundamental stream management operations: close() terminates the stream permanently, flush() drains buffered data to the underlying resource; the two-way tie at 5 is the minimum key name length in this spec; the ascending key name length sequence is: close=flush=5, readline=8, readlines=9, writelines=10; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "IOBase.__bases__[0].__dict__.__contains__"
  args: ["close"]
  expected: true

invariant io_extra170.IOBase_writelines_is_longest_at_10:
  description: "io.IOBase.__bases__[0].__dict__.__contains__('writelines') == True — 'writelines' has 10 characters: 'write' (5) + 'lines' (5) = 10; writelines (10) is the longest key name among the five _IOBase methods checked in this spec; it stands alone at the maximum length 10; the ascending sequence: close=flush=5, readline=8, readlines=9, writelines=10; writelines is 1 longer than readlines (9) because 'write' (5) is 1 longer than 'read' (4); writelines is 5 characters longer than close or flush (both 5) — doubling the minimum; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "IOBase.__bases__[0].__dict__.__contains__"
  args: ["writelines"]
  expected: true

invariant io_extra170.IOBase_name_is_IOBase:
  description: "io.IOBase.__name__ == 'IOBase' — 'IOBase' has 6 characters: 'IO' (2) + 'Base' (4) = 6; io.IOBase is the Python ABC wrapper (defined in Lib/io.py) for the C-level _IOBase class; its __module__ == 'io' (2 chars) — the public module rather than '_io' (3 chars); 'IOBase' (6 chars) is 8 characters shorter than 'BufferedIOBase' (14 chars) because the 'Buffered' prefix (8 chars) is absent from the base class name; io.IOBase.__name__ (6) == io.IOBase.__bases__[0].__name__.__len__() - 1 == 7 - 1 == 6 because the base '_IOBase' has the same name with a leading underscore added; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true

invariant io_extra170.BufferedIOBase_name_len_14:
  description: "io.BufferedIOBase.__name__.__len__() == 14 — 'BufferedIOBase' has 14 characters: 'Buffered' (8) + 'IO' (2) + 'Base' (4) = 14; BufferedIOBase (14) is the longest class name in the io ABC wrapper family checked in this spec; the 'Buffered' prefix (8 chars) contributes more than half of the total 14-character name; io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' (15 chars) is 1 longer than BufferedIOBase (14) due to the leading underscore; the parallel relationship: IOBase (6) and _IOBase (7) differ by 1; BufferedIOBase (14) and _BufferedIOBase (15) also differ by 1 — the leading underscore pattern is consistent; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BufferedIOBase.__name__.__len__
  args: []
  expected: 14

