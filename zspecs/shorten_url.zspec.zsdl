spec: shorten_url
version: ">=1.1.0"
backend: node(shorten-url)

docs: https://www.npmjs.com/package/shorten-url

provenance:
  derived_from:
    - "shorten-url README — https://www.npmjs.com/package/shorten-url"
    - "Test vectors verified with shorten-url via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "shorten-url source"
  notes:
    - "shorten-url is an npm package. Install: npm install shorten-url"
    - "Truncates a URL to maxLength characters, appending ellipsis if truncated."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table shorten_url.shorten:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: shortu

  columns: [id, args, expected]
  rows:
    - [truncated, ["https://www.example.com", 20], "https://www.example…"]
    - [fits,      ["https://example.com", 30],     "https://example.com"]
    - [short,     ["short", 20],                   "short"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:50:34Z
  iterations: 2
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 2 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
