spec: multiprocessing_extra14
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/synchronize.py"
  notes:
    - "This spec extends multiprocessing.zspec.zsdl and prior extras through multiprocessing_extra13.zspec.zsdl."
    - "multiprocessing covers: Process/__name__, Queue/__name__, Pipe/__name__, Pool/Lock/Event/Semaphore/Value/Array/Manager __name__ table; cpu_count/current_process/active_children/__name__ table; ProcessError/AuthenticationError/BufferTooShort/TimeoutError __name__."
    - "multiprocessing_extra covers: Process/__name__/__module__/__bases__[0]; Pool/__class__.__name__=='type'; Pool/__name__; AuthenticationError/__name__/__bases__[0]."
    - "multiprocessing_extra3 covers: cpu_count/__name__, ProcessError/__name__, BufferTooShort/__name__ standalone; Lock/__module__, Event/__module__, Value/__module__, Array/__module__ standalone."
    - "multiprocessing_extra7 covers: AuthenticationError/__module__, ProcessError/__module__."
    - "NOT yet covered in any prior spec: cpu_count.__class__.__name__ — type of the cpu_count callable."
    - "NOT yet covered: current_process.__class__.__name__ — type of current_process callable."
    - "NOT yet covered: active_children.__class__.__name__ — type of active_children callable."
    - "NOT yet covered: AuthenticationError.__class__.__name__ == 'type' — metaclass check."
    - "NOT yet covered: ProcessError.__class__.__name__ == 'type' — metaclass check."
    - "NOT yet covered: TimeoutError.__class__.__name__ == 'type' — metaclass check."
    - "NOT yet covered: BufferTooShort.__class__.__name__ == 'type' — metaclass check."
    - "NOT yet covered: ProcessError.__mro__[2].__name__ == 'BaseException' — MRO extra8 covers only index 1."
    - "NOT yet covered: ProcessError.__mro__[3].__name__ == 'object' — MRO terminus check."
    - "NOT yet covered: AuthenticationError.__mro__[3].__name__ == 'BaseException' — MRO depth index 3."
    - "multiprocessing.cpu_count is a bound method of the context object; its __class__.__name__ is 'method'."
    - "multiprocessing.current_process.__class__.__name__ == 'function' — a plain Python function in process.py."
    - "multiprocessing.active_children.__class__.__name__ == 'function' — a plain Python function in process.py."
    - "multiprocessing.AuthenticationError.__class__.__name__ == 'type' — plain Python exception class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __class__.__name__ checks
#
# No prior multiprocessing spec checks __class__.__name__ for any of the
# module-level functions (cpu_count, current_process, active_children).
# cpu_count is a bound method of the multiprocessing context object, so its
# __class__.__name__ is 'method'. current_process and active_children are
# plain Python functions defined in multiprocessing/process.py, so their
# __class__.__name__ is 'function'.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra14.cpu_count.class_name:
  description: "multiprocessing.cpu_count.__class__.__name__ == 'method' — bound context method"
  category: function_types
  kind: python_call_eq
  function: cpu_count.__class__.__name__.__eq__
  args: ["method"]
  expected: true

table multiprocessing_extra14.process_function_class_names:
  description: "multiprocessing process functions have __class__.__name__ == 'function'"
  kind: python_call_eq
  category: function_types
  id_prefix: pfcname14

  columns: [id, function, args, expected]
  rows:
    - [current_process,  current_process.__class__.__name__.__eq__,  ["function"], true]
    - [active_children,  active_children.__class__.__name__.__eq__,  ["function"], true]

# ---------------------------------------------------------------------------
# Exception class metaclass checks — __class__.__name__ == 'type'
#
# multiprocessing_extra covers Pool/__class__.__name__=='type' and
# Process/__class__.__name__=='type'. multiprocessing_extra12 covers
# process.BaseProcess/__class__.__name__=='type'. No prior spec checks
# __class__.__name__ for any multiprocessing exception class.
# AuthenticationError, ProcessError, TimeoutError, and BufferTooShort are
# all plain Python exception classes, so their metaclass is 'type'.
# ---------------------------------------------------------------------------

table multiprocessing_extra14.exception_class_metaclass:
  description: "multiprocessing exception classes have __class__.__name__ == 'type'"
  kind: python_call_eq
  category: class_types
  id_prefix: excmeta14

  columns: [id, function, args, expected]
  rows:
    - [ProcessError,          ProcessError.__class__.__name__.__eq__,          ["type"], true]
    - [AuthenticationError,   AuthenticationError.__class__.__name__.__eq__,   ["type"], true]
    - [TimeoutError,          TimeoutError.__class__.__name__.__eq__,          ["type"], true]
    - [BufferTooShort,        BufferTooShort.__class__.__name__.__eq__,        ["type"], true]

# ---------------------------------------------------------------------------
# ProcessError MRO checks
#
# multiprocessing_extra8 covers ProcessError/__mro__[1].__name__=='Exception'
# (MRO index 1 only). No prior spec checks ProcessError at index 2 or 3.
# The full MRO for ProcessError is [ProcessError, Exception, BaseException,
# object], so index 2 is 'BaseException' and index 3 is 'object'.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra14.ProcessError.mro_index2:
  description: "multiprocessing.ProcessError.__mro__[2].__name__ == 'BaseException'"
  category: class_hierarchy
  kind: python_call_eq
  function: ProcessError.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "BaseException"

invariant multiprocessing_extra14.ProcessError.mro_index3:
  description: "multiprocessing.ProcessError.__mro__[3].__name__ == 'object' — MRO terminates at object"
  category: class_hierarchy
  kind: python_call_eq
  function: ProcessError.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# AuthenticationError MRO index check
#
# multiprocessing_extra8 covers AuthenticationError/__mro__[1].'ProcessError'
# and /__mro__[2].'Exception'. No prior spec checks index 3.
# AuthenticationError MRO: [AuthenticationError, ProcessError, Exception,
# BaseException, object], so index 3 is 'BaseException'.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra14.AuthenticationError.mro_index3:
  description: "multiprocessing.AuthenticationError.__mro__[3].__name__ == 'BaseException'"
  category: class_hierarchy
  kind: python_call_eq
  function: AuthenticationError.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "BaseException"
