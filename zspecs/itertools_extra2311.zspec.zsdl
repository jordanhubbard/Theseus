spec: itertools_extra2311
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 601 (_extra2311): __abstractmethods__ content and absence checks."
    - "itertools classes are C extension types implemented in cpython/Modules/itertoolsmodule.c."
    - "C extension types never carry __abstractmethods__ in their class dict; the ABC machinery operates at the Python level."
    - "itertools.chain, cycle, count, combinations, islice, product, permutations, repeat, zip_longest: all absent."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __abstractmethods__ absence from __dict__ — core itertools classes
#
# C extension iterator types have no __abstractmethods__ entry in their
# class dict. All checks expected False.
# ---------------------------------------------------------------------------

table itertools_extra2311.abstract_absence_core:
  description: "core itertools C types have no __abstractmethods__ in class dict — all False — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2311

  columns: [id, function, args, expected]
  rows:
    - ["it2311001", "itertools.chain.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["it2311002", "itertools.cycle.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["it2311003", "itertools.count.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["it2311004", "itertools.combinations.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["it2311005", "itertools.islice.__dict__.__contains__", ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 2: __abstractmethods__ absence from __dict__ — combinatoric/extra types
#
# itertools.product, permutations, repeat, zip_longest are also C extension
# types and also carry no __abstractmethods__ in their class dict.
# ---------------------------------------------------------------------------

table itertools_extra2311.abstract_absence_extra:
  description: "extra itertools C types have no __abstractmethods__ in class dict — all False — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2311

  columns: [id, function, args, expected]
  rows:
    - ["it2311006", "itertools.product.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["it2311007", "itertools.permutations.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["it2311008", "itertools.repeat.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["it2311009", "itertools.zip_longest.__dict__.__contains__", ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 3: __abstractmethods__ direct access raises AttributeError
#
# Accessing cls.__abstractmethods__ on any itertools type raises AttributeError
# because neither the class nor any base class in its MRO defines the attribute.
# ---------------------------------------------------------------------------

table itertools_extra2311.abstract_attr_error:
  description: "itertools types raise AttributeError on __abstractmethods__ access — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: it2311

  columns: [id, function, args, expected]
  rows:
    - ["it2311010", "itertools.chain.__abstractmethods__.__len__", [], "AttributeError"]
    - ["it2311011", "itertools.cycle.__abstractmethods__.__len__", [], "AttributeError"]
    - ["it2311012", "itertools.count.__abstractmethods__.__len__", [], "AttributeError"]
    - ["it2311013", "itertools.combinations.__abstractmethods__.__len__", [], "AttributeError"]
    - ["it2311014", "itertools.islice.__abstractmethods__.__len__", [], "AttributeError"]

# ---------------------------------------------------------------------------
# Table 4: __abstractmethods__.__contains__ chained access raises AttributeError
#
# Because __abstractmethods__ is absent, chained access to
# __abstractmethods__.__contains__ propagates AttributeError for all types.
# ---------------------------------------------------------------------------

table itertools_extra2311.abstract_contains_error:
  description: "itertools __abstractmethods__.__contains__ raises AttributeError — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: it2311

  columns: [id, function, args, expected]
  rows:
    - ["it2311015", "itertools.chain.__abstractmethods__.__contains__", ["__next__"], "AttributeError"]
    - ["it2311016", "itertools.cycle.__abstractmethods__.__contains__", ["__next__"], "AttributeError"]
    - ["it2311017", "itertools.count.__abstractmethods__.__contains__", ["__next__"], "AttributeError"]
    - ["it2311018", "itertools.combinations.__abstractmethods__.__contains__", ["__next__"], "AttributeError"]
    - ["it2311019", "itertools.islice.__abstractmethods__.__contains__", ["__next__"], "AttributeError"]
    - ["it2311020", "itertools.product.__abstractmethods__.__contains__", ["__next__"], "AttributeError"]
    - ["it2311021", "itertools.permutations.__abstractmethods__.__contains__", ["__next__"], "AttributeError"]
    - ["it2311022", "itertools.repeat.__abstractmethods__.__contains__", ["__next__"], "AttributeError"]
    - ["it2311023", "itertools.zip_longest.__abstractmethods__.__contains__", ["__next__"], "AttributeError"]
