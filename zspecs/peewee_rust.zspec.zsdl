spec: peewee_rust
version: ">=3.9"
backend: rust_module(peewee_rust)

docs: https://docs.peewee-orm.com/en/latest/

provenance:
  derived_from:
    - "https://docs.peewee-orm.com/en/latest/ — Peewee documentation"
  not_derived_from:
    - "peewee source: peewee.py"
  notes:
    - "Peewee is a small, expressive ORM."
    - "from peewee import SqliteDatabase, Model, CharField."
    - "db = SqliteDatabase(':memory:'); db.database == ':memory:'."
    - "SqliteDatabase.__name__ == 'SqliteDatabase'."
    - "peewee.Model is available."
    - "Expose peewee_db_name() -> str: SqliteDatabase(':memory:').database."
    - "Expose peewee_sqlite_class_name() -> str: SqliteDatabase.__name__."
    - "Expose peewee_has_model() -> bool: hasattr(peewee, 'Model')."
    - "All test vectors verified against peewee 3.17.9."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# peewee_db_name — in-memory database name
invariant peewee_rust.db.memory_name:
  description: "SqliteDatabase(':memory:').database == ':memory:'"
  category: db
  kind: python_call_eq
  function: peewee_db_name
  args: []
  expected: ":memory:"

# peewee_sqlite_class_name — class name
invariant peewee_rust.db.class_name:
  description: "SqliteDatabase.__name__ == 'SqliteDatabase'"
  category: db_class
  kind: python_call_eq
  function: peewee_sqlite_class_name
  args: []
  expected: "SqliteDatabase"

# peewee_has_model — Model class present
invariant peewee_rust.module.has_model:
  description: "peewee.Model is available"
  category: module
  kind: python_call_eq
  function: peewee_has_model
  args: []
  expected: true

