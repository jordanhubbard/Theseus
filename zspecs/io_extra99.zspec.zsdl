spec: io_extra99
version: ">=3.9"
backend: python_module(io)
extends: io_extra98

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
  notes:
    - "This spec extends io_extra98.zspec.zsdl."
    - "This spec covers: io concrete class identity — __module__, __bases__[0].__name__, __mro__.__len__(), __qualname__ for BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper."
    - "All these classes are C extension types from _io, so their __module__ is '_io' (not 'io')."
    - "io.BytesIO.__module__ = '_io' — BytesIO is a C type from the _io extension module."
    - "io.BytesIO.__bases__[0].__name__ = '_BufferedIOBase' — BytesIO directly extends _BufferedIOBase."
    - "io.BytesIO.__mro__.__len__() = 4 — MRO is [BytesIO, _BufferedIOBase, _IOBase, object]."
    - "io.StringIO.__module__ = '_io' — StringIO is a C type from the _io extension module."
    - "io.StringIO.__bases__[0].__name__ = '_TextIOBase' — StringIO directly extends _TextIOBase."
    - "io.StringIO.__mro__.__len__() = 4 — MRO is [StringIO, _TextIOBase, _IOBase, object]."
    - "io.FileIO.__module__ = '_io' — FileIO is a C type from the _io extension module."
    - "io.FileIO.__bases__[0].__name__ = '_RawIOBase' — FileIO directly extends _RawIOBase."
    - "io.FileIO.__mro__.__len__() = 4 — MRO is [FileIO, _RawIOBase, _IOBase, object]."
    - "io.BufferedReader.__bases__[0].__name__ = '_BufferedIOBase' — BufferedReader extends _BufferedIOBase."
    - "io.BufferedWriter.__bases__[0].__name__ = '_BufferedIOBase' — BufferedWriter extends _BufferedIOBase."
    - "io.BufferedRandom.__bases__[0].__name__ = '_BufferedIOBase' — BufferedRandom extends _BufferedIOBase."
    - "io.TextIOWrapper.__module__ = '_io' — TextIOWrapper is a C type from the _io extension module."
    - "io.TextIOWrapper.__bases__[0].__name__ = '_TextIOBase' — TextIOWrapper directly extends _TextIOBase."
    - "io.TextIOWrapper.__mro__.__len__() = 4 — MRO is [TextIOWrapper, _TextIOBase, _IOBase, object]."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO and io.StringIO class identity
# Both are C extension types from _io. __module__ == '_io' for both.
# BytesIO extends _BufferedIOBase; StringIO extends _TextIOBase.
# MRO length is 4 for both.
# ---------------------------------------------------------------------------

table io_extra99.BytesIO_StringIO_identity:
  description: "io.BytesIO and io.StringIO class identity: __module__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioconcretecls99

  columns: [id, function, args, expected]
  rows:
    - [bytesio_module_io,     BytesIO.__module__.__eq__,             ["_io"],            true]
    - [bytesio_module_not_io, BytesIO.__module__.__eq__,             ["io"],             false]
    - [bytesio_base_name,     "BytesIO.__bases__[0].__name__.__eq__",  ["_BufferedIOBase"], true]
    - [bytesio_mro_len,       BytesIO.__mro__.__len__,               [],                 4]
    - [stringio_module_io,    StringIO.__module__.__eq__,            ["_io"],            true]
    - [stringio_base_name,    "StringIO.__bases__[0].__name__.__eq__", ["_TextIOBase"],    true]
    - [stringio_mro_len,      StringIO.__mro__.__len__,              [],                 4]

# ---------------------------------------------------------------------------
# io.FileIO class identity
# FileIO is a C type from _io. __module__ == '_io'.
# FileIO extends _RawIOBase. MRO length == 4.
# ---------------------------------------------------------------------------

table io_extra99.FileIO_identity:
  description: "io.FileIO class identity: __module__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioconcretecls99

  columns: [id, function, args, expected]
  rows:
    - [fileio_module_eq,    FileIO.__module__.__eq__,             ["_io"],       true]
    - [fileio_module_not,   FileIO.__module__.__eq__,             ["io"],        false]
    - [fileio_base_raw,     "FileIO.__bases__[0].__name__.__eq__",  ["_RawIOBase"], true]
    - [fileio_base_not_buf, "FileIO.__bases__[0].__name__.__eq__",  ["_BufferedIOBase"], false]
    - [fileio_mro_len,      FileIO.__mro__.__len__,               [],            4]

# ---------------------------------------------------------------------------
# io.BufferedReader, io.BufferedWriter, io.BufferedRandom class identity
# All three are C types from _io extending _BufferedIOBase.
# MRO length == 4 for all three.
# ---------------------------------------------------------------------------

table io_extra99.Buffered_classes_identity:
  description: "io.BufferedReader, BufferedWriter, BufferedRandom class identity: __module__ and __bases__[0].__name__"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioconcretecls99

  columns: [id, function, args, expected]
  rows:
    - [br_module_eq,   BufferedReader.__module__.__eq__,             ["_io"],             true]
    - [br_base_eq,     "BufferedReader.__bases__[0].__name__.__eq__",  ["_BufferedIOBase"],  true]
    - [br_mro_len,     BufferedReader.__mro__.__len__,               [],                  4]
    - [bw_module_eq,   BufferedWriter.__module__.__eq__,             ["_io"],             true]
    - [bw_base_eq,     "BufferedWriter.__bases__[0].__name__.__eq__",  ["_BufferedIOBase"],  true]
    - [bw_mro_len,     BufferedWriter.__mro__.__len__,               [],                  4]
    - [brnd_module_eq, BufferedRandom.__module__.__eq__,             ["_io"],             true]
    - [brnd_base_eq,   "BufferedRandom.__bases__[0].__name__.__eq__",  ["_BufferedIOBase"],  true]
    - [brnd_mro_len,   BufferedRandom.__mro__.__len__,               [],                  4]

# ---------------------------------------------------------------------------
# io.TextIOWrapper class identity
# TextIOWrapper is a C type from _io extending _TextIOBase. MRO length == 4.
# __qualname__ == 'TextIOWrapper'.
# ---------------------------------------------------------------------------

table io_extra99.TextIOWrapper_identity:
  description: "io.TextIOWrapper class identity: __module__, __bases__[0].__name__, __mro__.__len__(), __qualname__"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioconcretecls99

  columns: [id, function, args, expected]
  rows:
    - [tiow_module_eq,    TextIOWrapper.__module__.__eq__,             ["_io"],        true]
    - [tiow_module_not,   TextIOWrapper.__module__.__eq__,             ["io"],         false]
    - [tiow_base_eq,      "TextIOWrapper.__bases__[0].__name__.__eq__",  ["_TextIOBase"], true]
    - [tiow_mro_len,      TextIOWrapper.__mro__.__len__,               [],             4]
    - [tiow_qualname_eq,  TextIOWrapper.__qualname__.__eq__,           ["TextIOWrapper"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra99.BytesIO.module_is_underscore_io:
  description: "io.BytesIO.__module__ == '_io' (BytesIO is a C extension type from _io, not the pure Python io wrapper)"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra99.StringIO.base_is_TextIOBase:
  description: "io.StringIO.__bases__[0].__name__ == '_TextIOBase' (StringIO directly extends the private C base _TextIOBase)"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__bases__[0].__name__.__eq__
  args: ["_TextIOBase"]
  expected: true

invariant io_extra99.FileIO.mro_len_4:
  description: "io.FileIO.__mro__.__len__() == 4 (MRO is [FileIO, _RawIOBase, _IOBase, object])"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__mro__.__len__
  args: []
  expected: 4

invariant io_extra99.BufferedReader.base_is_BufferedIOBase:
  description: "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' (BufferedReader extends the private C base _BufferedIOBase)"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__bases__[0].__name__.__eq__
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra99.TextIOWrapper.mro_len_4:
  description: "io.TextIOWrapper.__mro__.__len__() == 4 (MRO is [TextIOWrapper, _TextIOBase, _IOBase, object])"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__mro__.__len__
  args: []
  expected: 4
