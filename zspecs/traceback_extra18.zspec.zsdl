spec: traceback_extra18
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends prior traceback specs through traceback_extra17.zspec.zsdl."
    - "Focus: __qualname__ values for module-level traceback functions and top-level classes."
    - "Module-level functions have __qualname__ equal to their simple name (no class prefix)."
    - "Top-level classes have __qualname__ equal to their class name."
    - "traceback.format_exc.__qualname__ == 'format_exc' — module-level function."
    - "traceback.TracebackException.__qualname__ == 'TracebackException' — top-level class."
    - "traceback.StackSummary.__qualname__ == 'StackSummary' — top-level class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# traceback module-level function __qualname__ values
#
# For module-level functions, __qualname__ equals the simple function name.
# No prior traceback spec records __qualname__ for these six functions.
# ---------------------------------------------------------------------------

invariant traceback_extra18.format_exc.qualname:
  description: "traceback.format_exc.__qualname__ == 'format_exc'"
  category: function_qualname
  kind: python_call_eq
  function: format_exc.__qualname__.__eq__
  args: ["format_exc"]
  expected: true

invariant traceback_extra18.format_tb.qualname:
  description: "traceback.format_tb.__qualname__ == 'format_tb'"
  category: function_qualname
  kind: python_call_eq
  function: format_tb.__qualname__.__eq__
  args: ["format_tb"]
  expected: true

invariant traceback_extra18.format_stack.qualname:
  description: "traceback.format_stack.__qualname__ == 'format_stack'"
  category: function_qualname
  kind: python_call_eq
  function: format_stack.__qualname__.__eq__
  args: ["format_stack"]
  expected: true

invariant traceback_extra18.print_exc.qualname:
  description: "traceback.print_exc.__qualname__ == 'print_exc'"
  category: function_qualname
  kind: python_call_eq
  function: print_exc.__qualname__.__eq__
  args: ["print_exc"]
  expected: true

invariant traceback_extra18.print_tb.qualname:
  description: "traceback.print_tb.__qualname__ == 'print_tb'"
  category: function_qualname
  kind: python_call_eq
  function: print_tb.__qualname__.__eq__
  args: ["print_tb"]
  expected: true

invariant traceback_extra18.extract_tb.qualname:
  description: "traceback.extract_tb.__qualname__ == 'extract_tb'"
  category: function_qualname
  kind: python_call_eq
  function: extract_tb.__qualname__.__eq__
  args: ["extract_tb"]
  expected: true

invariant traceback_extra18.extract_stack.qualname:
  description: "traceback.extract_stack.__qualname__ == 'extract_stack'"
  category: function_qualname
  kind: python_call_eq
  function: extract_stack.__qualname__.__eq__
  args: ["extract_stack"]
  expected: true

# ---------------------------------------------------------------------------
# traceback top-level class __qualname__ values
#
# Top-level classes have __qualname__ equal to their class name.
# No prior traceback spec records __qualname__ for TracebackException or
# StackSummary as classes (distinct from instances or methods).
# ---------------------------------------------------------------------------

invariant traceback_extra18.TracebackException.qualname:
  description: "traceback.TracebackException.__qualname__ == 'TracebackException'"
  category: class_qualname
  kind: python_call_eq
  function: TracebackException.__qualname__.__eq__
  args: ["TracebackException"]
  expected: true

invariant traceback_extra18.StackSummary.qualname:
  description: "traceback.StackSummary.__qualname__ == 'StackSummary'"
  category: class_qualname
  kind: python_call_eq
  function: StackSummary.__qualname__.__eq__
  args: ["StackSummary"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all nine __qualname__ checks
#
# Covers format_exc/format_tb/format_stack/print_exc/print_tb/extract_tb/
# extract_stack (functions) and TracebackException/StackSummary (classes).
# ---------------------------------------------------------------------------

table traceback_extra18.qualnames:
  description: "__qualname__ values for traceback module-level functions and classes"
  kind: python_call_eq
  category: function_qualname

  columns: [id, function, args, expected]
  rows:
    - [format_exc,          format_exc.__qualname__.__eq__,          ["format_exc"],          true]
    - [format_tb,           format_tb.__qualname__.__eq__,           ["format_tb"],           true]
    - [format_stack,        format_stack.__qualname__.__eq__,        ["format_stack"],        true]
    - [print_exc,           print_exc.__qualname__.__eq__,           ["print_exc"],           true]
    - [print_tb,            print_tb.__qualname__.__eq__,            ["print_tb"],            true]
    - [extract_tb,          extract_tb.__qualname__.__eq__,          ["extract_tb"],          true]
    - [extract_stack,       extract_stack.__qualname__.__eq__,       ["extract_stack"],       true]
    - [TracebackException,  TracebackException.__qualname__.__eq__,  ["TracebackException"],  true]
    - [StackSummary,        StackSummary.__qualname__.__eq__,        ["StackSummary"],        true]
