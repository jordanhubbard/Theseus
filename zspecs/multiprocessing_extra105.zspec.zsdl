spec: multiprocessing_extra105
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec extends multiprocessing_extra104.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing.Pool method class names and code attributes. NEW in extra105: type(Pool.map).__name__=='function' (Pool.map is a Python function, not a method_descriptor); type(Pool.starmap).__name__=='function'; type(Pool.apply).__name__=='function'; type(Pool.apply_async).__name__=='function'; type(Pool.close).__name__=='function'; type(Pool.terminate).__name__=='function'; type(Pool.join).__name__=='function'; Pool.map.__qualname__=='Pool.map' (len=8); Pool.starmap.__qualname__=='Pool.starmap' (len=12); Pool.apply.__qualname__=='Pool.apply' (len=10); Pool.apply_async.__qualname__=='Pool.apply_async' (len=16, longest); Pool.close.__qualname__=='Pool.close' (len=10); Pool.terminate.__qualname__=='Pool.terminate' (len=14); Pool.join.__qualname__=='Pool.join' (len=9); Pool.map.__code__.co_argcount==4; Pool.apply.__code__.co_argcount==4; Pool.apply_async.__code__.co_argcount==6 (most args); Pool.close.__code__.co_argcount==1; Pool.__module__=='multiprocessing.pool', Pool.__bases__[0].__name__=='object', Pool.__mro__.__len__()==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All Pool methods are Python 'function' type (not method_descriptor). This is because Pool is a pure-Python class defined in Lib/multiprocessing/pool.py — none of its methods are C-implemented. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.apply_async.__code__.co_argcount == 6. The six parameters are self, func, args, kwds, callback, and error_callback. This is the most arguments of any Pool method in this spec. Pool.map.__code__.co_argcount==4 (self, func, iterable, chunksize). Pool.close/terminate/join each have co_argcount==1 (self only). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.__bases__[0].__name__ == 'object'. Pool inherits directly from object with MRO [Pool, object] (length=2). Pool.__module__=='multiprocessing.pool'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Pool method type checks — extra105
#
# Wave 254 theme: Pool method class names (all 'function').
#
# type(Pool.map).__name__       == 'function'  (not method_descriptor)
# type(Pool.apply).__name__     == 'function'
# type(Pool.apply_async).__name__ == 'function'
# type(Pool.close).__name__     == 'function'
# type(Pool.terminate).__name__ == 'function'
# type(Pool.join).__name__      == 'function'
# ---------------------------------------------------------------------------

table multiprocessing_extra105.mp_pool_method_types:
  description: "multiprocessing.Pool method type checks in mppool105 namespace — wave 254 theme: all Pool methods are Python 'function' type (not method_descriptor or builtin_function_or_method) because Pool is a pure-Python class in Lib/multiprocessing/pool.py; type(Pool.map).__name__.__eq__('function')==True; type(Pool.starmap).__name__.__eq__('function')==True; type(Pool.apply).__name__.__eq__('function')==True; type(Pool.apply_async).__name__.__eq__('function')==True; type(Pool.close).__name__.__eq__('function')==True; type(Pool.terminate).__name__.__eq__('function')==True; type(Pool.join).__name__.__eq__('function')==True; all seven methods share the same type ('function'); contrast with C-extension classes where methods would be 'method_descriptor' or 'builtin_function_or_method'; Pool.__module__=='multiprocessing.pool'; Pool.__bases__[0].__name__=='object'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppool105

  columns: [id, function, args, expected, description]
  rows:
    - [map_type_eq,         multiprocessing.pool.Pool.map.__class__.__name__.__eq__,        ["function"], true, "type(Pool.map).__name__ == 'function' (pure-Python, not C-level method_descriptor); verified with Python 3.14.3"]
    - [starmap_type_eq,     multiprocessing.pool.Pool.starmap.__class__.__name__.__eq__,    ["function"], true, "type(Pool.starmap).__name__ == 'function'; verified with Python 3.14.3"]
    - [apply_type_eq,       multiprocessing.pool.Pool.apply.__class__.__name__.__eq__,      ["function"], true, "type(Pool.apply).__name__ == 'function'; verified with Python 3.14.3"]
    - [apply_async_type_eq, multiprocessing.pool.Pool.apply_async.__class__.__name__.__eq__, ["function"], true, "type(Pool.apply_async).__name__ == 'function'; verified with Python 3.14.3"]
    - [close_type_eq,       multiprocessing.pool.Pool.close.__class__.__name__.__eq__,      ["function"], true, "type(Pool.close).__name__ == 'function'; verified with Python 3.14.3"]
    - [terminate_type_eq,   multiprocessing.pool.Pool.terminate.__class__.__name__.__eq__,  ["function"], true, "type(Pool.terminate).__name__ == 'function'; verified with Python 3.14.3"]
    - [join_type_eq,        multiprocessing.pool.Pool.join.__class__.__name__.__eq__,       ["function"], true, "type(Pool.join).__name__ == 'function'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Pool method __qualname__ lengths — extra105
#
# Wave 254 theme: Pool method qualname lengths.
#
# Pool.map.__qualname__        == 'Pool.map'         (len=8, shortest)
# Pool.apply_async.__qualname__ == 'Pool.apply_async' (len=16, longest)
# Pool.terminate.__qualname__  == 'Pool.terminate'   (len=14)
# ---------------------------------------------------------------------------

table multiprocessing_extra105.mp_pool_method_qualnames:
  description: "multiprocessing.Pool method __qualname__ length checks in mppool105 namespace — wave 254 theme: Pool.map.__qualname__.__eq__('Pool.map')==True (len=8, shortest method qualname in spec — 'Pool.'=5+'map'=3=8); Pool.join.__qualname__.__eq__('Pool.join')==True (len=9); Pool.apply.__qualname__.__eq__('Pool.apply')==True (len=10); Pool.close.__qualname__.__eq__('Pool.close')==True (len=10, tied with apply); Pool.starmap.__qualname__.__eq__('Pool.starmap')==True (len=12); Pool.terminate.__qualname__.__eq__('Pool.terminate')==True (len=14); Pool.apply_async.__qualname__.__eq__('Pool.apply_async')==True (len=16, longest); qualname length ordering: map=8 < join=9 < apply=close=10 < starmap=12 < terminate=14 < apply_async=16; all share prefix 'Pool.' (len=5); apply_async qualname len=16 > terminate=14 > starmap=12; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppool105a

  columns: [id, function, args, expected, description]
  rows:
    - [map_qn_eq,          multiprocessing.pool.Pool.map.__qualname__.__eq__,         ["Pool.map"],         true, "Pool.map.__qualname__ == 'Pool.map' (len=8, shortest method qualname in spec); verified with Python 3.14.3"]
    - [map_qn_len,         multiprocessing.pool.Pool.map.__qualname__.__len__,        [],                   8,    "Pool.map.__qualname__.__len__() == 8 ('Pool.map'=8); verified with Python 3.14.3"]
    - [starmap_qn_eq,      multiprocessing.pool.Pool.starmap.__qualname__.__eq__,     ["Pool.starmap"],     true, "Pool.starmap.__qualname__ == 'Pool.starmap' (len=12); verified with Python 3.14.3"]
    - [starmap_qn_len,     multiprocessing.pool.Pool.starmap.__qualname__.__len__,    [],                   12,   "Pool.starmap.__qualname__.__len__() == 12 ('Pool.starmap'=12); verified with Python 3.14.3"]
    - [apply_qn_eq,        multiprocessing.pool.Pool.apply.__qualname__.__eq__,       ["Pool.apply"],       true, "Pool.apply.__qualname__ == 'Pool.apply' (len=10); verified with Python 3.14.3"]
    - [apply_async_qn_eq,  multiprocessing.pool.Pool.apply_async.__qualname__.__eq__, ["Pool.apply_async"], true, "Pool.apply_async.__qualname__ == 'Pool.apply_async' (len=16, longest method qualname in spec); verified with Python 3.14.3"]
    - [apply_async_qn_len, multiprocessing.pool.Pool.apply_async.__qualname__.__len__, [],                  16,   "Pool.apply_async.__qualname__.__len__() == 16 ('Pool.apply_async'=16, longest); verified with Python 3.14.3"]
    - [terminate_qn_eq,    multiprocessing.pool.Pool.terminate.__qualname__.__eq__,   ["Pool.terminate"],   true, "Pool.terminate.__qualname__ == 'Pool.terminate' (len=14); verified with Python 3.14.3"]
    - [join_qn_len,        multiprocessing.pool.Pool.join.__qualname__.__len__,       [],                   9,    "Pool.join.__qualname__.__len__() == 9 ('Pool.join'=9); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Pool method co_argcount and Pool class identity — extra105
#
# Wave 254 theme: Pool method argument counts and class hierarchy.
#
# Pool.map.__code__.co_argcount        == 4 (self, func, iterable, chunksize)
# Pool.apply_async.__code__.co_argcount == 6 (most args)
# Pool.close.__code__.co_argcount      == 1 (self only)
# Pool.__bases__[0].__name__           == 'object' (mro len=2)
# ---------------------------------------------------------------------------

table multiprocessing_extra105.mp_pool_method_argcounts:
  description: "multiprocessing.Pool method co_argcount and Pool class identity checks in mppool105 namespace — wave 254 theme: Pool.map.__code__.co_argcount.__eq__(4)==True (params: self, func, iterable, chunksize); Pool.starmap.__code__.co_argcount.__eq__(4)==True (params: self, func, iterable, chunksize — same count as map); Pool.apply.__code__.co_argcount.__eq__(4)==True (params: self, func, args, kwds — same count as map/starmap); Pool.apply_async.__code__.co_argcount.__eq__(6)==True (params: self, func, args, kwds, callback, error_callback — most args in spec); Pool.close.__code__.co_argcount.__eq__(1)==True (self only); Pool.terminate.__code__.co_argcount.__eq__(1)==True (self only); Pool.join.__code__.co_argcount.__eq__(1)==True (self only); Pool.__bases__[0].__name__.__eq__('object')==True (Pool inherits directly from object, MRO=[Pool, object], length=2); Pool.__module__.__eq__('multiprocessing.pool')==True; argcount ordering: close=terminate=join=1 < map=starmap=apply=4 < apply_async=6; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: mppool105b

  columns: [id, function, args, expected, description]
  rows:
    - [map_co_argc,         multiprocessing.pool.Pool.map.__code__.co_argcount.__eq__,         [4], true, "Pool.map.__code__.co_argcount == 4 (self, func, iterable, chunksize); verified with Python 3.14.3"]
    - [starmap_co_argc,     multiprocessing.pool.Pool.starmap.__code__.co_argcount.__eq__,     [4], true, "Pool.starmap.__code__.co_argcount == 4 (self, func, iterable, chunksize — same as map); verified with Python 3.14.3"]
    - [apply_co_argc,       multiprocessing.pool.Pool.apply.__code__.co_argcount.__eq__,       [4], true, "Pool.apply.__code__.co_argcount == 4 (self, func, args, kwds); verified with Python 3.14.3"]
    - [apply_async_co_argc, multiprocessing.pool.Pool.apply_async.__code__.co_argcount.__eq__, [6], true, "Pool.apply_async.__code__.co_argcount == 6 (self, func, args, kwds, callback, error_callback — most args in spec); verified with Python 3.14.3"]
    - [close_co_argc,       multiprocessing.pool.Pool.close.__code__.co_argcount.__eq__,       [1], true, "Pool.close.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]
    - [terminate_co_argc,   multiprocessing.pool.Pool.terminate.__code__.co_argcount.__eq__,   [1], true, "Pool.terminate.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]
    - [join_co_argc,        multiprocessing.pool.Pool.join.__code__.co_argcount.__eq__,        [1], true, "Pool.join.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]
    - [pool_base_eq,        "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__",           ["object"], true, "Pool.__bases__[0].__name__ == 'object' (Pool inherits directly from object); verified with Python 3.14.3"]
    - [pool_mro_len,        multiprocessing.pool.Pool.__mro__.__len__,                         [], 2,    "Pool.__mro__.__len__() == 2 ([Pool, object]); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra105
# ---------------------------------------------------------------------------

invariant multiprocessing_extra105.Pool_map_is_function:
  description: "multiprocessing.pool.Pool.map.__class__.__name__.__eq__('function') returns True — Pool.map is a pure-Python function (not a C-level method_descriptor or builtin_function_or_method) because Pool is implemented entirely in Python (Lib/multiprocessing/pool.py); all seven Pool methods in this spec (map, starmap, apply, apply_async, close, terminate, join) share type 'function'; Pool.map.__qualname__=='Pool.map' (len=8, shortest method qualname in spec); Pool.map.__code__.co_argcount==4 (self, func, iterable, chunksize); compare: Pool.apply_async.__code__.co_argcount==6 (most args); Pool.__module__=='multiprocessing.pool'; NEW in extra105: first standalone Pool.map type invariant in mppool105 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.map.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant multiprocessing_extra105.Pool_apply_async_co_argcount_6:
  description: "multiprocessing.pool.Pool.apply_async.__code__.co_argcount == 6 — apply_async has the most parameters of any Pool method in this spec: self, func, args, kwds, callback, and error_callback; Pool.apply_async.__qualname__=='Pool.apply_async' (len=16, longest method qualname in spec); compare co_argcount values: close=terminate=join=1 (fewest), map=starmap=apply=4, apply_async=6 (most); the callback and error_callback parameters distinguish apply_async from synchronous Pool.apply (which has co_argcount==4); Pool.apply_async is the asynchronous variant that returns an AsyncResult and optionally calls callbacks on completion; NEW in extra105: first standalone Pool.apply_async argcount invariant in mppool105 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: multiprocessing.pool.Pool.apply_async.__code__.co_argcount.__eq__
  args: [6]
  expected: true

invariant multiprocessing_extra105.Pool_apply_async_qualname_len_16:
  description: "multiprocessing.pool.Pool.apply_async.__qualname__.__len__() == 16 — 'Pool.apply_async' = 'Pool.'=5 + 'apply_async'=11 = 16; this is the longest method qualname in this spec; compare qualname lengths: map=8 (shortest), join=9, apply=close=10, starmap=12, terminate=14, apply_async=16 (longest); Pool.apply_async.__code__.co_argcount==6 (also the most args); note that 'apply_async' (len=11) is longer than 'terminate' (len=9) or 'starmap' (len=7); Pool.apply_async is Pool's primary asynchronous dispatch method, returning an AsyncResult object; NEW in extra105: first standalone Pool.apply_async qualname length invariant in mppool105 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.apply_async.__qualname__.__len__
  args: []
  expected: 16

invariant multiprocessing_extra105.Pool_base_is_object:
  description: "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__('object') returns True — Pool inherits directly from object with MRO [Pool, object] (length=2); Pool.__module__=='multiprocessing.pool'; Pool.__qualname__=='Pool' (len=4, the shortest qualname in this spec — all method qualnames start with 'Pool.' which is already 5 chars); Pool.__mro__.__len__()==2; compare: all of Pool's methods are type 'function' because Pool itself is a pure-Python class; Pool is the primary multiprocessing worker pool class, managing a set of worker processes; NEW in extra105: first standalone Pool class base invariant in mppool105 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra105.Pool_close_co_argcount_1:
  description: "multiprocessing.pool.Pool.close.__code__.co_argcount == 1 — Pool.close takes only self (no additional arguments); Pool.terminate.__code__.co_argcount==1 and Pool.join.__code__.co_argcount==1 also take only self; all three lifecycle methods (close, terminate, join) have co_argcount==1, the minimum in this spec; compare: Pool.apply_async.__code__.co_argcount==6 (maximum); Pool.close.__qualname__=='Pool.close' (len=10); Pool.close prevents new tasks from being submitted to the pool (unlike terminate which immediately stops workers); the three methods with co_argcount==1 are the pool lifecycle methods; NEW in extra105: first standalone Pool.close argcount invariant in mppool105 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: multiprocessing.pool.Pool.close.__code__.co_argcount.__eq__
  args: [1]
  expected: true
