spec: http_status_extra3
version: ">=3.9"
backend: python_module(http)

docs: https://docs.python.org/3/library/http.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.html — Python http module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/__init__.py"
    - "http_status.zspec.zsdl — covers HTTPStatus class identity, core status values and phrases (OK, CREATED, NO_CONTENT, NOT_MODIFIED, BAD_REQUEST, UNAUTHORIZED, FORBIDDEN, NOT_FOUND, INTERNAL_SERVER_ERROR)"
    - "http_status_extra.zspec.zsdl — covers OK/NOT_FOUND/INTERNAL_SERVER_ERROR .value standalone; OK/NOT_FOUND .name standalone; OK/CREATED/NO_CONTENT/BAD_REQUEST/UNAUTHORIZED/FORBIDDEN/NOT_FOUND value table"
    - "http_status_extra2.zspec.zsdl — covers ACCEPTED.value (202), MOVED_PERMANENTLY.value (301); CREATED/NO_CONTENT/BAD_REQUEST/INTERNAL_SERVER_ERROR .phrase standalone; phrase table (OK/CREATED/ACCEPTED/MOVED_PERMANENTLY/BAD_REQUEST/INTERNAL_SERVER_ERROR)"
  notes:
    - "This spec extends http_status.zspec.zsdl through http_status_extra2.zspec.zsdl."
    - "Focus: METHOD_NOT_ALLOWED (405) .value/.name/.phrase — no prior http spec covers any attribute of METHOD_NOT_ALLOWED; NOT_ACCEPTABLE (406) .value/.name — new code not in any prior spec; CONFLICT (409) .value — new code; GONE (410) .value — new code; .name for INTERNAL_SERVER_ERROR/CREATED/BAD_REQUEST — http_status_extra covers OK.name and NOT_FOUND.name only."
    - "http.HTTPStatus.METHOD_NOT_ALLOWED.value == 405 — no prior http spec covers METHOD_NOT_ALLOWED. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.HTTPStatus.METHOD_NOT_ALLOWED.name == 'METHOD_NOT_ALLOWED' — no prior spec. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.HTTPStatus.METHOD_NOT_ALLOWED.phrase == 'Method Not Allowed' — no prior spec. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.HTTPStatus.NOT_ACCEPTABLE.value == 406 — no prior http spec covers NOT_ACCEPTABLE. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.HTTPStatus.NOT_ACCEPTABLE.name == 'NOT_ACCEPTABLE' — no prior spec. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.HTTPStatus.CONFLICT.value == 409 — no prior http spec covers CONFLICT. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.HTTPStatus.GONE.value == 410 — no prior http spec covers GONE. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.HTTPStatus.INTERNAL_SERVER_ERROR.name == 'INTERNAL_SERVER_ERROR' — http_status_extra covers OK.name and NOT_FOUND.name; INTERNAL_SERVER_ERROR.name is new. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.HTTPStatus.CREATED.name == 'CREATED' — no prior spec checks CREATED.name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.HTTPStatus.BAD_REQUEST.name == 'BAD_REQUEST' — no prior spec checks BAD_REQUEST.name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HTTPStatus.METHOD_NOT_ALLOWED — value, name, phrase
#
# No prior http spec covers any attribute of METHOD_NOT_ALLOWED (405).
# http_status_extra and http_status_extra2 cover codes up through NOT_FOUND (404)
# and MOVED_PERMANENTLY (301). METHOD_NOT_ALLOWED is a distinct 4xx code.
# ---------------------------------------------------------------------------

invariant http_status_extra3.METHOD_NOT_ALLOWED.value:
  description: "http.HTTPStatus.METHOD_NOT_ALLOWED.value == 405"
  category: status_values
  kind: python_call_eq
  function: HTTPStatus.METHOD_NOT_ALLOWED.value.__eq__
  args: [405]
  expected: true

invariant http_status_extra3.METHOD_NOT_ALLOWED.name:
  description: "http.HTTPStatus.METHOD_NOT_ALLOWED.name == 'METHOD_NOT_ALLOWED'"
  category: member_names
  kind: python_call_eq
  function: HTTPStatus.METHOD_NOT_ALLOWED.name.__eq__
  args: ["METHOD_NOT_ALLOWED"]
  expected: true

invariant http_status_extra3.METHOD_NOT_ALLOWED.phrase:
  description: "http.HTTPStatus.METHOD_NOT_ALLOWED.phrase == 'Method Not Allowed'"
  category: phrase
  kind: python_call_eq
  function: HTTPStatus.METHOD_NOT_ALLOWED.phrase.__eq__
  args: ["Method Not Allowed"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus.NOT_ACCEPTABLE (406) — value and name
#
# No prior http spec covers NOT_ACCEPTABLE. It is a standard 4xx client error
# used when the server cannot produce a response matching Accept headers.
# ---------------------------------------------------------------------------

invariant http_status_extra3.NOT_ACCEPTABLE.value:
  description: "http.HTTPStatus.NOT_ACCEPTABLE.value == 406"
  category: status_values
  kind: python_call_eq
  function: HTTPStatus.NOT_ACCEPTABLE.value.__eq__
  args: [406]
  expected: true

invariant http_status_extra3.NOT_ACCEPTABLE.name:
  description: "http.HTTPStatus.NOT_ACCEPTABLE.name == 'NOT_ACCEPTABLE'"
  category: member_names
  kind: python_call_eq
  function: HTTPStatus.NOT_ACCEPTABLE.name.__eq__
  args: ["NOT_ACCEPTABLE"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus.CONFLICT (409) and HTTPStatus.GONE (410) — value
#
# Neither CONFLICT nor GONE appears in any prior http spec. Both are standard
# 4xx client error codes. Covered here as new behavioral axes.
# ---------------------------------------------------------------------------

invariant http_status_extra3.CONFLICT.value:
  description: "http.HTTPStatus.CONFLICT.value == 409"
  category: status_values
  kind: python_call_eq
  function: HTTPStatus.CONFLICT.value.__eq__
  args: [409]
  expected: true

invariant http_status_extra3.GONE.value:
  description: "http.HTTPStatus.GONE.value == 410"
  category: status_values
  kind: python_call_eq
  function: HTTPStatus.GONE.value.__eq__
  args: [410]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus .name for INTERNAL_SERVER_ERROR, CREATED, BAD_REQUEST
#
# http_status_extra covers OK.name and NOT_FOUND.name only.
# No prior http spec checks .name for INTERNAL_SERVER_ERROR, CREATED, or
# BAD_REQUEST. The .name attribute is the enum member identifier string, which
# is distinct from .phrase (human-readable description).
# ---------------------------------------------------------------------------

table http_status_extra3.additional_names:
  description: ".name for additional HTTPStatus members not covered by prior specs"
  kind: python_call_eq
  category: member_names
  id_prefix: hse3n

  columns: [id, function, args, expected]
  rows:
    - [internal_server_error, HTTPStatus.INTERNAL_SERVER_ERROR.name.__eq__, ["INTERNAL_SERVER_ERROR"], true]
    - [created,               HTTPStatus.CREATED.name.__eq__,               ["CREATED"],               true]
    - [bad_request,           HTTPStatus.BAD_REQUEST.name.__eq__,           ["BAD_REQUEST"],           true]
