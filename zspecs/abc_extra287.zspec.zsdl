spec: abc_extra287
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module class and function identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "abc.ABC.__bases__[0].__name__ == 'object' — ABC is a simple helper class with object as its only base"
    - "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta is a metaclass, inheriting from type"
    - "abc.abstractmethod.__module__ == 'abc' — abstractmethod is a pure-Python class defined in abc"
    - "abc.get_cache_token.__module__ == '_abc' — get_cache_token is implemented in the C extension _abc"
    - "abc.abstractclassmethod is present on Python 3.14.4 (deprecated but not yet removed)"
    - "abc.abstractclassmethod.__bases__[0].__name__ == 'classmethod'"
    - "abc.ABC.__subclasshook__ is a builtin_function_or_method bound to ABCMeta"
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra287.abc_class_identity:
  description: "abc.ABC, abc.ABCMeta class name, module, and base class identity"
  kind: python_call_eq
  category: identity
  id_prefix: abc287a

  columns: [id, function, args, expected, description]
  rows:
    - [abc287a001, abc.ABC.__name__.__eq__, ["ABC"], true, "ABC.__name__ is 'ABC'"]
    - [abc287a002, abc.ABC.__module__.__eq__, ["abc"], true, "ABC.__module__ is 'abc'"]
    - [abc287a003, "abc.ABC.__bases__[0].__name__.__eq__", ["object"], true, "ABC base class is object"]
    - [abc287a004, abc.ABCMeta.__name__.__eq__, ["ABCMeta"], true, "ABCMeta.__name__ is 'ABCMeta'"]
    - [abc287a005, abc.ABCMeta.__module__.__eq__, ["abc"], true, "ABCMeta.__module__ is 'abc'"]
    - [abc287a006, "abc.ABCMeta.__bases__[0].__name__.__eq__", ["type"], true, "ABCMeta base class is type"]

table abc_extra287.abc_function_identity:
  description: "abc.abstractmethod, abc.abstractclassmethod, abc.get_cache_token name and module identity"
  kind: python_call_eq
  category: identity
  id_prefix: abc287b

  columns: [id, function, args, expected, description]
  rows:
    - [abc287b001, abc.abstractmethod.__name__.__eq__, ["abstractmethod"], true, "abstractmethod.__name__ is 'abstractmethod'"]
    - [abc287b002, abc.abstractmethod.__module__.__eq__, ["abc"], true, "abstractmethod.__module__ is 'abc'"]
    - [abc287b003, abc.abstractclassmethod.__name__.__eq__, ["abstractclassmethod"], true, "abstractclassmethod.__name__ is 'abstractclassmethod'"]
    - [abc287b004, abc.abstractclassmethod.__module__.__eq__, ["abc"], true, "abstractclassmethod.__module__ is 'abc'"]
    - [abc287b005, "abc.abstractclassmethod.__bases__[0].__name__.__eq__", ["classmethod"], true, "abstractclassmethod base class is classmethod"]
    - [abc287b006, abc.get_cache_token.__name__.__eq__, ["get_cache_token"], true, "get_cache_token.__name__ is 'get_cache_token'"]
    - [abc287b007, abc.get_cache_token.__module__.__eq__, ["_abc"], true, "get_cache_token.__module__ is '_abc' (C extension)"]

table abc_extra287.abc_subclasshook_identity:
  description: "abc.ABC.__subclasshook__ name identity"
  kind: python_call_eq
  category: identity
  id_prefix: abc287c

  columns: [id, function, args, expected, description]
  rows:
    - [abc287c001, abc.ABC.__subclasshook__.__name__.__eq__, ["__subclasshook__"], true, "ABC.__subclasshook__.__name__ is '__subclasshook__'"]

invariant abc_extra287.abc_base_is_object:
  description: "abc.ABC.__bases__[0].__name__ is 'object' — ABC is a plain class with no special base"
  category: identity
  kind: python_call_eq
  function: "abc.ABC.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant abc_extra287.abcmeta_base_is_type:
  description: "abc.ABCMeta.__bases__[0].__name__ is 'type' — ABCMeta is a metaclass inheriting from type"
  category: identity
  kind: python_call_eq
  function: "abc.ABCMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra287.get_cache_token_in_c_extension:
  description: "abc.get_cache_token.__module__ is '_abc', indicating it is implemented in the C extension"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra287.abstractclassmethod_base_is_classmethod:
  description: "abc.abstractclassmethod inherits from classmethod (deprecated decorator still present in 3.14)"
  category: identity
  kind: python_call_eq
  function: "abc.abstractclassmethod.__bases__[0].__name__.__eq__"
  args: ["classmethod"]
  expected: true
