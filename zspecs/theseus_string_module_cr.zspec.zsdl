spec: theseus_string_module_cr
version: ">=3.8"
backend: python_cleanroom(theseus_string_module_cr)
blocks: string

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/string.html"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "Clean-room string module. Do NOT import string."

error_model: python_exceptions

invariant theseus_string_module_cr.string2_digits:
  description: "digits constant contains 0-9"
  category: constants
  kind: python_call_eq
  function: string2_digits
  args: []
  expected: true

invariant theseus_string_module_cr.string2_template:
  description: "Template substitutes variables correctly"
  category: behavior
  kind: python_call_eq
  function: string2_template
  args: []
  expected: true

invariant theseus_string_module_cr.string2_capwords:
  description: "capwords capitalizes words in a string"
  category: behavior
  kind: python_call_eq
  function: string2_capwords
  args: []
  expected: true
