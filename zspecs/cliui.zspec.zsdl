spec: cliui
version: ">=9.0.0"
backend: node(cliui)
esm: true

docs: https://github.com/yargs/cliui#readme

provenance:
  derived_from:
    - "cliui README — https://github.com/yargs/cliui#readme"
    - "Test vectors verified with cliui via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "cliui source"
  notes:
    - "Easy-to-build help text for command-line tools — used by yargs."
    - "Install: npm install cliui"
    - "v9 ESM only; default export IS the factory: cliui({width, wrap}) → ui with .div() / .span() / .toString()."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure builder; never throws."
  stderr: "null"
  stickiness: "Each ui instance accumulates rows."
  codes: {}

invariant cliui.default_export_is_function:
  description: "Default export is a function (factory)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "Function"

invariant cliui.factory_returns_object_with_div:
  description: "cliui() returns an object exposing .div"
  category: factory
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: [{"width": 40}]}
    - {get: "div.constructor.name"}
  expected: "Function"

invariant cliui.factory_returns_object_with_span:
  description: "cliui() returns an object exposing .span"
  category: factory
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: [{"width": 40}]}
    - {get: "span.constructor.name"}
  expected: "Function"

invariant cliui.factory_returns_object_with_toString:
  description: "cliui() returns an object exposing .toString"
  category: factory
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: [{"width": 40}]}
    - {get: "toString.constructor.name"}
  expected: "Function"

invariant cliui.has_resetOutput:
  description: "ui has .resetOutput method"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: [{"width": 40}]}
    - {get: "resetOutput.constructor.name"}
  expected: "Function"

invariant cliui.fresh_ui_renders_empty_string:
  description: "Empty cliui().toString() is ''"
  category: render
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: [{"width": 40}]}
    - {method: toString, args: []}
  expected: ""

invariant cliui.width_is_recorded:
  description: "Returned ui has .width matching the option passed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: [{"width": 60}]}
    - {get: width}
  expected: 60
