spec: normalize_email
version: ">=1.1.1"
backend: node(normalize-email)

docs: https://www.npmjs.com/package/normalize-email

provenance:
  derived_from:
    - "normalize-email README — https://www.npmjs.com/package/normalize-email"
    - "Test vectors verified with normalize-email via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "normalize-email source"
  notes:
    - "normalize-email is an npm package. Install: npm install normalize-email"
    - "Normalizes a Gmail address by removing dots and plus-labels, and lowercases."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a normalized email string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table normalize_email.normalize:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: noreml

  columns: [id, args, expected]
  rows:
    - [dots_plus, ["foo.bar+baz@gmail.com"],  "foobar@gmail.com"]
    - [uppercase, ["TEST@EXAMPLE.COM"],        "test@example.com"]
    - [clean,     ["user@example.com"],        "user@example.com"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:03:28Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
