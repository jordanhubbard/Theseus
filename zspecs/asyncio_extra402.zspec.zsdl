spec: asyncio_extra402
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio-eventloop.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio event loop documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "asyncio.BaseEventLoop.run_forever.__name__ == 'run_forever'"
    - "asyncio.BaseEventLoop.run_until_complete.__name__ == 'run_until_complete'"
    - "asyncio.BaseEventLoop.stop.__name__ == 'stop'"
    - "asyncio.BaseEventLoop.close.__name__ == 'close'"
    - "asyncio.BaseEventLoop.is_running.__name__ == 'is_running'"
    - "asyncio.BaseEventLoop.is_closed.__name__ == 'is_closed'"
    - "asyncio.BaseEventLoop.create_task.__name__ == 'create_task'"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra402.base_event_loop_method_names:
  description: "Verify __name__ attribute of asyncio.BaseEventLoop methods"
  kind: python_call_eq
  category: identity
  id_prefix: aio402m

  columns: [id, function, args, expected]
  rows:
    - [aio402m001, asyncio.BaseEventLoop.run_forever.__name__.__eq__, ["run_forever"], true]
    - [aio402m002, asyncio.BaseEventLoop.run_until_complete.__name__.__eq__, ["run_until_complete"], true]
    - [aio402m003, asyncio.BaseEventLoop.stop.__name__.__eq__, ["stop"], true]
    - [aio402m004, asyncio.BaseEventLoop.close.__name__.__eq__, ["close"], true]
    - [aio402m005, asyncio.BaseEventLoop.is_running.__name__.__eq__, ["is_running"], true]
    - [aio402m006, asyncio.BaseEventLoop.is_closed.__name__.__eq__, ["is_closed"], true]
    - [aio402m007, asyncio.BaseEventLoop.create_task.__name__.__eq__, ["create_task"], true]
