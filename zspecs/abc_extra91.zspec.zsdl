spec: abc_extra91
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra90

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra90.zspec.zsdl."
    - "This spec covers: wave 254 theme — abc abstractclassmethod, abstractstaticmethod, and abstractproperty deprecated class method class names and identity. NOTE: abc.__all__ was removed in Python 3.14.3 and is absent; this spec focuses on deprecated class method identity instead. NEW in extra91: abstractclassmethod.__name__=='abstractclassmethod'; abstractclassmethod.__bases__[0].__name__=='classmethod'; abstractclassmethod.__init__.__class__.__name__=='function'; abstractclassmethod.__get__.__class__.__name__=='wrapper_descriptor'; abstractclassmethod.__init__.__qualname__=='abstractclassmethod.__init__' (len=28); abstractstaticmethod.__name__=='abstractstaticmethod'; abstractstaticmethod.__bases__[0].__name__=='staticmethod'; abstractstaticmethod.__init__.__class__.__name__=='function'; abstractstaticmethod.__init__.__qualname__=='abstractstaticmethod.__init__' (len=29); abstractproperty.__bases__[0].__name__=='property'; abstractproperty.__init__.__class__.__name__=='wrapper_descriptor'; abstractproperty.getter.__class__.__name__=='method_descriptor'; abstractproperty.getter.__qualname__=='property.getter' (len=15); abstractproperty.setter.__qualname__=='property.setter' (len=15); abstractproperty.deleter.__qualname__=='property.deleter' (len=16). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__all__ was removed in Python 3.14.3. This spec does not test __all__ membership. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abstractclassmethod.__init__.__qualname__ == 'abstractclassmethod.__init__' (len=28). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abstractstaticmethod.__init__.__qualname__ == 'abstractstaticmethod.__init__' (len=29). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abstractproperty.getter.__qualname__ == 'property.getter' (len=15). getter is inherited from property, so qualname uses 'property.getter' not 'abstractproperty.getter'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abstractproperty.deleter.__qualname__ == 'property.deleter' (len=16). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abstractclassmethod class identity and method class names — extra91
#
# Wave 254 theme: abc deprecated class method identity and method class names.
# abc.__all__ was removed in Python 3.14.3.
#
# abstractclassmethod.__name__ == 'abstractclassmethod'
# abstractclassmethod.__module__ == 'abc'
# abstractclassmethod.__bases__[0].__name__ == 'classmethod'
# abstractclassmethod.__init__.__class__.__name__ == 'function'
# abstractclassmethod.__get__.__class__.__name__ == 'wrapper_descriptor'
# abstractclassmethod.__init__.__qualname__ == 'abstractclassmethod.__init__' (len=28)
# ---------------------------------------------------------------------------

table abc_extra91.abstractclassmethod_identity:
  description: "abstractclassmethod class identity and method class name checks in abcdepclsmethods91 namespace — wave 254 theme: abc deprecated class method identity; abstractclassmethod is a deprecated subclass of classmethod that adds abstract method marking; abstractclassmethod.__name__.__eq__('abstractclassmethod')==True; abstractclassmethod.__module__.__eq__('abc')==True; abstractclassmethod.__bases__[0].__name__.__eq__('classmethod')==True (inherits from classmethod); abstractclassmethod.__init__.__class__.__name__.__eq__('function')==True (__init__ is a Python function); abstractclassmethod.__get__.__class__.__name__.__eq__('wrapper_descriptor')==True (__get__ is inherited from classmethod as C-level descriptor); abstractclassmethod.__init__.__qualname__.__len__()==28 ('abstractclassmethod.__init__'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdepclsmethods91

  columns: [id, function, args, expected, description]
  rows:
    - [abscls_name,       "abstractclassmethod.__name__.__eq__",                    ["abstractclassmethod"], true, "abstractclassmethod.__name__ == 'abstractclassmethod'; verified with Python 3.14.3"]
    - [abscls_module,     "abstractclassmethod.__module__.__eq__",                  ["abc"],                 true, "abstractclassmethod.__module__ == 'abc'; verified with Python 3.14.3"]
    - [abscls_base0,      "abstractclassmethod.__bases__[0].__name__.__eq__",       ["classmethod"],         true, "abstractclassmethod.__bases__[0].__name__ == 'classmethod' — inherits from classmethod; verified with Python 3.14.3"]
    - [abscls_init_class, "abstractclassmethod.__init__.__class__.__name__.__eq__", ["function"],            true, "abstractclassmethod.__init__.__class__.__name__ == 'function' — __init__ is a Python function; verified with Python 3.14.3"]
    - [abscls_get_class,  "abstractclassmethod.__get__.__class__.__name__.__eq__",  ["wrapper_descriptor"],  true, "abstractclassmethod.__get__.__class__.__name__ == 'wrapper_descriptor' — inherited from classmethod; verified with Python 3.14.3"]
    - [abscls_init_qlen,  "abstractclassmethod.__init__.__qualname__.__len__",      [],                      28,   "abstractclassmethod.__init__.__qualname__.__len__() == 28 — qualname is 'abstractclassmethod.__init__'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abstractstaticmethod class identity and method class names — extra91
#
# abstractstaticmethod.__name__ == 'abstractstaticmethod'
# abstractstaticmethod.__module__ == 'abc'
# abstractstaticmethod.__bases__[0].__name__ == 'staticmethod'
# abstractstaticmethod.__init__.__class__.__name__ == 'function'
# abstractstaticmethod.__get__.__class__.__name__ == 'wrapper_descriptor'
# abstractstaticmethod.__init__.__qualname__ == 'abstractstaticmethod.__init__' (len=29)
# ---------------------------------------------------------------------------

table abc_extra91.abstractstaticmethod_identity:
  description: "abstractstaticmethod class identity and method class name checks in abcdepclsmethods91 namespace — wave 254 theme: abc deprecated class method identity; abstractstaticmethod is a deprecated subclass of staticmethod that adds abstract method marking; abstractstaticmethod.__name__.__eq__('abstractstaticmethod')==True; abstractstaticmethod.__module__.__eq__('abc')==True; abstractstaticmethod.__bases__[0].__name__.__eq__('staticmethod')==True; abstractstaticmethod.__init__.__class__.__name__.__eq__('function')==True (__init__ is a Python function, same as abstractclassmethod); abstractstaticmethod.__get__.__class__.__name__.__eq__('wrapper_descriptor')==True; abstractstaticmethod.__init__.__qualname__.__len__()==29 (one char longer than abstractclassmethod.__init__.__qualname__ len=28 because 'abstractstaticmethod' is 20 chars vs 'abstractclassmethod' 19 chars); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdepclsmethods91a

  columns: [id, function, args, expected, description]
  rows:
    - [absstatic_name,       "abstractstaticmethod.__name__.__eq__",                    ["abstractstaticmethod"], true, "abstractstaticmethod.__name__ == 'abstractstaticmethod'; verified with Python 3.14.3"]
    - [absstatic_module,     "abstractstaticmethod.__module__.__eq__",                  ["abc"],                  true, "abstractstaticmethod.__module__ == 'abc'; verified with Python 3.14.3"]
    - [absstatic_base0,      "abstractstaticmethod.__bases__[0].__name__.__eq__",       ["staticmethod"],         true, "abstractstaticmethod.__bases__[0].__name__ == 'staticmethod' — inherits from staticmethod; verified with Python 3.14.3"]
    - [absstatic_init_class, "abstractstaticmethod.__init__.__class__.__name__.__eq__", ["function"],             true, "abstractstaticmethod.__init__.__class__.__name__ == 'function' — __init__ is a Python function; verified with Python 3.14.3"]
    - [absstatic_get_class,  "abstractstaticmethod.__get__.__class__.__name__.__eq__",  ["wrapper_descriptor"],   true, "abstractstaticmethod.__get__.__class__.__name__ == 'wrapper_descriptor' — inherited from staticmethod; verified with Python 3.14.3"]
    - [absstatic_init_qlen,  "abstractstaticmethod.__init__.__qualname__.__len__",      [],                       29,   "abstractstaticmethod.__init__.__qualname__.__len__() == 29 — qualname is 'abstractstaticmethod.__init__'; one longer than abstractclassmethod (28); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abstractproperty class identity and method class names — extra91
#
# abstractproperty.__bases__[0].__name__ == 'property'
# abstractproperty.__init__.__class__.__name__ == 'wrapper_descriptor'
# abstractproperty.getter/__qualname__ == 'property.getter' (len=15)
# abstractproperty.setter.__qualname__ == 'property.setter' (len=15)
# abstractproperty.deleter.__qualname__ == 'property.deleter' (len=16)
# ---------------------------------------------------------------------------

table abc_extra91.abstractproperty_identity:
  description: "abstractproperty class identity and method class name checks in abcdepclsmethods91 namespace — wave 254 theme: abc deprecated abstractproperty method identity; abstractproperty is a deprecated subclass of property; abstractproperty.__bases__[0].__name__.__eq__('property')==True; abstractproperty.__init__.__class__.__name__.__eq__('wrapper_descriptor')==True (__init__ is inherited from property as a C-level wrapper_descriptor, unlike abstractclassmethod/__init__ which is a Python function); abstractproperty.getter.__class__.__name__.__eq__('method_descriptor')==True; abstractproperty.getter.__qualname__.__eq__('property.getter')==True (qualname uses 'property' not 'abstractproperty' because getter is inherited from property); abstractproperty.setter.__qualname__.__len__()==15; abstractproperty.deleter.__qualname__.__len__()==16; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdepclsmethods91b

  columns: [id, function, args, expected, description]
  rows:
    - [absprop_base0,        "abstractproperty.__bases__[0].__name__.__eq__",      ["property"],          true, "abstractproperty.__bases__[0].__name__ == 'property' — inherits from property; verified with Python 3.14.3"]
    - [absprop_init_class,   "abstractproperty.__init__.__class__.__name__.__eq__", ["wrapper_descriptor"], true, "abstractproperty.__init__.__class__.__name__ == 'wrapper_descriptor' — C-level, unlike abstractclassmethod.__init__ (function); verified with Python 3.14.3"]
    - [absprop_getter_class, "abstractproperty.getter.__class__.__name__.__eq__",  ["method_descriptor"], true, "abstractproperty.getter.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3"]
    - [absprop_getter_qeq,   "abstractproperty.getter.__qualname__.__eq__",        ["property.getter"],   true, "abstractproperty.getter.__qualname__ == 'property.getter' — inherited from property; verified with Python 3.14.3"]
    - [absprop_setter_qlen,  "abstractproperty.setter.__qualname__.__len__",       [],                    15,   "abstractproperty.setter.__qualname__.__len__() == 15 — qualname is 'property.setter'; verified with Python 3.14.3"]
    - [absprop_deleter_qlen, "abstractproperty.deleter.__qualname__.__len__",      [],                    16,   "abstractproperty.deleter.__qualname__.__len__() == 16 — qualname is 'property.deleter'; one longer than getter/setter; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abstractclassmethod/abstractstaticmethod __init__ __qualname__ lengths — extra91
#
# abstractclassmethod.__init__.__qualname__.__len__() == 28
# abstractstaticmethod.__init__.__qualname__.__len__() == 29
# abstractclassmethod.__qualname__.__len__() == 19
# abstractstaticmethod.__qualname__.__len__() == 20
# abstractproperty.__qualname__.__len__() == 16
# ---------------------------------------------------------------------------

table abc_extra91.deprecated_class_qualname_lengths:
  description: "Deprecated abc class __qualname__ and __init__.__qualname__ length checks in abcdepclsmethods91 namespace — wave 254 theme: abc deprecated class qualname lengths; abstractclassmethod.__qualname__.__len__()==19 ('abstractclassmethod'); abstractstaticmethod.__qualname__.__len__()==20 ('abstractstaticmethod', one char longer); abstractproperty.__qualname__.__len__()==16 ('abstractproperty', shortest of the three); abstractclassmethod.__init__.__qualname__.__len__()==28 ('abstractclassmethod.__init__' = 19 + 1 + 8); abstractstaticmethod.__init__.__qualname__.__len__()==29 ('abstractstaticmethod.__init__' = 20 + 1 + 8); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdepclsmethods91c

  columns: [id, function, args, expected, description]
  rows:
    - [abscls_qlen,      "abstractclassmethod.__qualname__.__len__",        [], 19, "abstractclassmethod.__qualname__.__len__() == 19 — qualname is 'abstractclassmethod'; verified with Python 3.14.3"]
    - [absstatic_qlen,   "abstractstaticmethod.__qualname__.__len__",       [], 20, "abstractstaticmethod.__qualname__.__len__() == 20 — qualname is 'abstractstaticmethod'; one char longer than abstractclassmethod; verified with Python 3.14.3"]
    - [absprop_qlen,     "abstractproperty.__qualname__.__len__",           [], 16, "abstractproperty.__qualname__.__len__() == 16 — qualname is 'abstractproperty'; shortest of the deprecated classes; verified with Python 3.14.3"]
    - [abscls_init_qlen, "abstractclassmethod.__init__.__qualname__.__len__",  [], 28, "abstractclassmethod.__init__.__qualname__.__len__() == 28 — 'abstractclassmethod.__init__'; verified with Python 3.14.3"]
    - [absstatic_initql, "abstractstaticmethod.__init__.__qualname__.__len__", [], 29, "abstractstaticmethod.__init__.__qualname__.__len__() == 29 — 'abstractstaticmethod.__init__'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra91
# ---------------------------------------------------------------------------

invariant abc_extra91.abstractclassmethod_init_qualname_eq:
  description: "abc.abstractclassmethod.__init__.__qualname__.__eq__('abstractclassmethod.__init__') returns True — abstractclassmethod.__init__ is a Python function (class is 'function') defined in Lib/abc.py; its __qualname__ is 'abstractclassmethod.__init__' (len=28); this is 9 chars longer than abstractclassmethod.__qualname__ itself (19 chars) due to the '.__init__' suffix (9 chars); abstractclassmethod is deprecated since Python 3.3 and raises DeprecationWarning; NEW in extra91: first standalone __init__.__qualname__.__eq__ invariant for abstractclassmethod in abcdepclsmethods91 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abstractclassmethod.__init__.__qualname__.__eq__"
  args: ["abstractclassmethod.__init__"]
  expected: true

invariant abc_extra91.abstractstaticmethod_init_qualname_eq:
  description: "abc.abstractstaticmethod.__init__.__qualname__.__eq__('abstractstaticmethod.__init__') returns True — abstractstaticmethod.__init__ is a Python function (class is 'function') defined in Lib/abc.py; its __qualname__ is 'abstractstaticmethod.__init__' (len=29); this is exactly 1 char longer than abstractclassmethod.__init__.__qualname__ (len=28) because 'abstractstaticmethod' (20) is 1 char longer than 'abstractclassmethod' (19); NEW in extra91: first standalone __init__.__qualname__.__eq__ invariant for abstractstaticmethod in abcdepclsmethods91 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abstractstaticmethod.__init__.__qualname__.__eq__"
  args: ["abstractstaticmethod.__init__"]
  expected: true

invariant abc_extra91.abstractproperty_getter_qualname_eq:
  description: "abc.abstractproperty.getter.__qualname__.__eq__('property.getter') returns True — abstractproperty.getter uses the qualname 'property.getter' (not 'abstractproperty.getter') because getter is inherited from the property base class and not overridden in abstractproperty; this shows that Python qualnames reflect where the method was originally defined, not the class through which it is accessed; getter, setter, and deleter all show 'property.' prefix in their qualnames; NEW in extra91: first standalone getter qualname invariant for abstractproperty in abcdepclsmethods91 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abstractproperty.getter.__qualname__.__eq__"
  args: ["property.getter"]
  expected: true

invariant abc_extra91.abstractclassmethod_base_is_classmethod:
  description: "abc.abstractclassmethod.__bases__[0].__name__.__eq__('classmethod') returns True — abstractclassmethod subclasses the built-in classmethod descriptor; this gives abstractclassmethod the descriptor protocol behavior of classmethod while adding __isabstractmethod__ support; abstractstaticmethod similarly subclasses staticmethod and abstractproperty subclasses property; all three deprecated classes follow the same pattern of subclassing the corresponding built-in descriptor; NEW in extra91: first standalone base class name invariant for abstractclassmethod in abcdepclsmethods91 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abstractclassmethod.__bases__[0].__name__.__eq__"
  args: ["classmethod"]
  expected: true

invariant abc_extra91.abstractproperty_init_class_is_wrapper_descriptor:
  description: "abc.abstractproperty.__init__.__class__.__name__.__eq__('wrapper_descriptor') returns True — abstractproperty.__init__ is a 'wrapper_descriptor' (C-level), unlike abstractclassmethod.__init__ and abstractstaticmethod.__init__ which are Python 'function' objects; this is because abstractproperty.__init__ is inherited from the built-in property type (which is implemented in C), whereas abstractclassmethod and abstractstaticmethod define their own Python-level __init__; NEW in extra91: first standalone __init__ class name invariant for abstractproperty in abcdepclsmethods91 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abstractproperty.__init__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true
