spec: threading_extra37
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra36.zspec.zsdl."
    - "Prior specs covered: Thread/__name__/__qualname__.__len__()==6; Thread method __qualname__.__len__() for start(12)/run(10)/join(11)/is_alive(15)/__init__(15)/__repr__(15)/getName(14)/setName(14); Event method __qualname__.__len__() for set(9)/clear(11)/wait(10)/is_set(12); Condition method __qualname__.__len__() for wait(14)/notify(16)/notify_all(20)/wait_for(18)/__init__(18)/__enter__(19); Semaphore/__name__/__qualname__.__len__()==9 and __init__(18)/__exit__(18); Barrier/__name__/__qualname__.__len__()==7; Timer/__name__/__qualname__.__len__()==5; threading.local.__name__/__qualname__.__len__()==6; Lock.__module__.__len__()==9; Lock.__name__.__len__()==4; RLock.__dict__.__class__.__name__.__len__()==12; Semaphore.__mro__.__len__()==2; Timer.__mro__.__len__()==2; BoundedSemaphore/__bases__[0].__name__.__len__()==9; current_thread/__name__.__len__()==14; main_thread/__name__.__len__()==11; threading.__all__.__len__()==28; threading.TIMEOUT_MAX.__class__.__name__.__len__()==5."
    - "This spec covers: active_count.__name__.__len__() (12 — 'active_count'); threading.enumerate.__name__.__len__() (9 — 'enumerate', the threading-specific enumerate function); settrace.__name__.__len__() (8 — 'settrace'); setprofile.__name__.__len__() (10 — 'setprofile'); stack_size.__name__.__len__() (10 — 'stack_size', same length as setprofile); threading.__all__.__class__.__name__.__len__() (4 — 'list')."
    - "Key findings: threading.active_count.__name__ is 'active_count' (12 chars) — the function that returns the number of Thread objects currently alive. threading.enumerate.__name__ is 'enumerate' (9 chars) — the threading module's enumerate is distinct from the built-in; its __name__ is the short local name. threading.settrace.__name__ is 'settrace' (8 chars) — sets a trace function for all threads. threading.setprofile.__name__ is 'setprofile' (10 chars). threading.stack_size.__name__ is 'stack_size' (10 chars) — coincidentally equal to setprofile. threading.__all__.__class__.__name__ is 'list' (4 chars) — confirming that threading.__all__ is an ordinary list, not a tuple."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread management module-level function __name__.__len__() — extra37 namespace
#
# threading.active_count.__name__ is 'active_count' (12 chars). threading.
# enumerate.__name__ is 'enumerate' (9 chars) — the threading module's version
# of enumerate, distinct from the built-in (its __name__ gives only the local
# function name 'enumerate'). No prior threading spec records active_count.
# __name__.__len__() or threading.enumerate.__name__.__len__() as standalone
# values. These two are recorded together for the first time in the extra37
# namespace.
# ---------------------------------------------------------------------------

table threading_extra37.thread_mgmt_function_name_lengths:
  description: "threading thread-management function __name__.__len__(): active_count(12), enumerate(9)"
  kind: python_call_eq
  category: string_properties
  id_prefix: threadmgmtlen37

  columns: [id, function, args, expected, description]
  rows:
    - [active_count,
       active_count.__name__.__len__,
       [],
       12,
       "len(threading.active_count.__name__) == 12 — 'active_count' (returns the number of Thread objects currently alive)"]
    - [enumerate,
       enumerate.__name__.__len__,
       [],
       9,
       "len(threading.enumerate.__name__) == 9 — 'enumerate' (threading-specific enumerate of live threads; distinct from the built-in)"]

# ---------------------------------------------------------------------------
# Tracing and profiling function __name__.__len__() — extra37 namespace
#
# threading.settrace.__name__ is 'settrace' (8 chars) — the function that sets
# a trace function for all threads started from the threading module. threading.
# setprofile.__name__ is 'setprofile' (10 chars) — the profiling counterpart.
# threading.stack_size.__name__ is 'stack_size' (10 chars) — coincidentally
# equal to setprofile in length. No prior threading spec records settrace,
# setprofile, or stack_size __name__.__len__() values. These three are recorded
# together for the first time in the extra37 namespace.
# ---------------------------------------------------------------------------

table threading_extra37.trace_profile_function_name_lengths:
  description: "threading tracing/profiling/stack function __name__.__len__(): settrace(8), setprofile(10), stack_size(10)"
  kind: python_call_eq
  category: string_properties
  id_prefix: traceproflen37

  columns: [id, function, args, expected, description]
  rows:
    - [settrace,
       settrace.__name__.__len__,
       [],
       8,
       "len(threading.settrace.__name__) == 8 — 'settrace' (sets a trace function for all threads started from threading)"]
    - [setprofile,
       setprofile.__name__.__len__,
       [],
       10,
       "len(threading.setprofile.__name__) == 10 — 'setprofile' (profiling counterpart of settrace)"]
    - [stack_size,
       stack_size.__name__.__len__,
       [],
       10,
       "len(threading.stack_size.__name__) == 10 — 'stack_size' (coincidentally equal to setprofile; gets/sets thread stack size)"]

# ---------------------------------------------------------------------------
# threading.__all__.__class__.__name__.__len__() — extra37 namespace
#
# threading.__all__ is a list (not a tuple), so threading.__all__.__class__.
# __name__ is 'list' (4 chars). Prior specs recorded threading.__all__.__len__()
# == 28, but not __all__.__class__.__name__.__len__(). This confirms that
# threading uses a mutable list for its __all__, unlike some modules that use
# tuples. No prior threading spec records __all__.__class__.__name__.__len__() in
# the extra37 namespace.
# ---------------------------------------------------------------------------

invariant threading_extra37.all_classname_len:
  description: "len(threading.__all__.__class__.__name__) == 4 — '__all__' is a 'list' (mutable, unlike tuple-based __all__ in some modules)"
  category: module_metadata
  kind: python_call_eq
  function: threading.__all__.__class__.__name__.__len__
  args: []
  expected: 4
