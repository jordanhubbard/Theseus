spec: lodash_partition
version: ">=4.0.0"
backend: node(lodash.partition)

docs: https://lodash.com/docs/#partition

provenance:
  derived_from:
    - "lodash.partition README — https://www.npmjs.com/package/lodash.partition"
    - "Test vectors verified with lodash.partition@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.partition exports the _.partition function directly as module.exports."
    - "partition(collection, predicate) returns [[matches], [non-matches]]."
    - "String predicate checks truthiness of the named property."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns two-element array: [matching, non-matching]."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_partition.partition:
  kind: node_module_call_eq
  function: ~
  category: partition
  id_prefix: lpart

  columns: [id, args, expected]
  rows:
    - [by_prop,  [[{"active": true, "n": "a"}, {"active": false, "n": "b"}, {"active": true, "n": "c"}], "active"],
       [[{"active": true, "n": "a"}, {"active": true, "n": "c"}],
        [{"active": false, "n": "b"}]]]
    - [by_match, [[{"n": 1}, {"n": 2}, {"n": 1}], {"n": 1}],
       [[{"n": 1}, {"n": 1}], [{"n": 2}]]]
