spec: http_extra
version: ">=3.11"
backend: python_module(http)

docs: https://docs.python.org/3/library/http.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.html — Python http package documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/__init__.py"
    - "http_status.zspec.zsdl — that spec covers HTTPStatus members, descriptions, and numeric values"
  notes:
    - "This spec covers the http package's class name and module metadata."
    - "http.HTTPStatus.__name__ == 'HTTPStatus' — enum class name."
    - "http.HTTPStatus.__module__ == 'http' — class lives in the http package."
    - "http.HTTPMethod.__name__ == 'HTTPMethod' — available since Python 3.11."
    - "http.HTTPMethod.__module__ == 'http' — class lives in the http package."
    - "http.HTTPStatus.OK.value == 200 — the integer code for 200 OK."
    - "http.HTTPStatus.NOT_FOUND.value == 404 — the integer code for 404 Not Found."
    - "http.HTTPStatus.OK.phrase == 'OK' — short phrase for 200 OK."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class metadata — HTTPStatus and HTTPMethod
# ---------------------------------------------------------------------------

table http_extra.class_metadata:
  kind: python_call_eq
  category: class_metadata
  id_prefix: meta

  columns: [id, description, function, args, expected]
  rows:
    - [HTTPStatus_name,    "HTTPStatus.__name__ == 'HTTPStatus'",   HTTPStatus.__name__.__eq__,    ["HTTPStatus"],  true]
    - [HTTPStatus_module,  "HTTPStatus.__module__ == 'http'",       HTTPStatus.__module__.__eq__,  ["http"],        true]
    - [HTTPMethod_name,    "HTTPMethod.__name__ == 'HTTPMethod'",   HTTPMethod.__name__.__eq__,    ["HTTPMethod"],  true]
    - [HTTPMethod_module,  "HTTPMethod.__module__ == 'http'",       HTTPMethod.__module__.__eq__,  ["http"],        true]

# ---------------------------------------------------------------------------
# HTTPStatus member values — OK (200) and NOT_FOUND (404)
# ---------------------------------------------------------------------------

invariant http_extra.HTTPStatus.OK_value:
  description: "HTTPStatus.OK.value == 200"
  category: HTTPStatus_values
  kind: python_call_eq
  function: HTTPStatus.OK.value.__eq__
  args: [200]
  expected: true

invariant http_extra.HTTPStatus.NOT_FOUND_value:
  description: "HTTPStatus.NOT_FOUND.value == 404"
  category: HTTPStatus_values
  kind: python_call_eq
  function: HTTPStatus.NOT_FOUND.value.__eq__
  args: [404]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus member phrases
# ---------------------------------------------------------------------------

invariant http_extra.HTTPStatus.OK_phrase:
  description: "HTTPStatus.OK.phrase == 'OK'"
  category: HTTPStatus_phrases
  kind: python_call_eq
  function: HTTPStatus.OK.phrase.__eq__
  args: ["OK"]
  expected: true
