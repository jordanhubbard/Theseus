    - ["cf3391011", operator.contains, [concurrent.futures.Future.__dict__,              "__float__"],   false]
    - ["cf3391012", operator.contains, [concurrent.futures.Future.__dict__,              "__complex__"], false]
    - ["cf3391013", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__int__"],     false]
    - ["cf3391014", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__float__"],   false]
    - ["cf3391015", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__complex__"], false]
    - ["cf3391016", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__int__"],     false]
    - ["cf3391017", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__float__"],   false]
    - ["cf3391018", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__complex__"], false]
