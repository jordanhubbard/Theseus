spec: cf3391
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 673 (cf3391): __int__, __float__, __complex__ dict-presence (int(x), float(x), complex(x)) for concurrent.futures types."
    - "Theme: __int__/__float__/__complex__ dict-presence (int(x), float(x), complex(x))."
    - "All values False — concurrent.futures types are high-level parallel execution primitives with no numeric conversion support."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor."
    - "Key finding (__int__): all 3 concurrent.futures classes return false for __int__. int() delegates to __int__ (numbers.Integral protocol) when defined. concurrent.futures types define no arithmetic protocol of any kind — confirmed false across waves 658–672 for all arithmetic, bitwise, reflected, in-place augmented assignment, unary numeric, and rounding operators. concurrent.futures.Future is a result handle with a PENDING/RUNNING/CANCELLED/FINISHED state machine; int(future) is not a valid Python expression for a state-machine object. ThreadPoolExecutor and ProcessPoolExecutor manage worker pools via submit()/map()/shutdown(); int(executor) is not defined."
    - "Key finding (__float__): all 3 concurrent.futures classes return false for __float__. float() delegates to __float__ (numbers.Real protocol). concurrent.futures types implement no numeric magnitude — a Future represents a pending asynchronous computation, not a scalar value that can be converted to float. ThreadPoolExecutor/ProcessPoolExecutor are lifecycle managers for worker pools; float(executor) is not a defined Python operation. No float conversion protocol is implemented by any concurrent.futures type."
    - "Key finding (__complex__): all 3 concurrent.futures classes return false for __complex__. complex() delegates to __complex__ (numbers.Complex protocol). concurrent.futures types are not complex number types. concurrent.futures.Future is a state-machine result handle, not a complex number; it cannot be passed to complex(). ThreadPoolExecutor/ProcessPoolExecutor are pool lifecycle managers; the pool configuration is not representable as a complex number and __complex__ is not defined on any executor type."
    - "All 9 values in this wave are false. concurrent.futures is a high-level parallel execution API operating entirely through method calls — submit(), map(), result(), cancel(), add_done_callback(), shutdown() — with no arithmetic, bitwise, unary numeric, numeric rounding, integer-index, or numeric conversion protocol of any kind."
    - "Cross-wave summary for cf subjects:"
    - "  Wave 658 (cf3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (cf3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (cf3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (cf3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (cf3226): __radd__/__rsub__/__rmul__ — all false for all 3."
    - "  Wave 663 (cf3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 3."
    - "  Wave 664 (cf3256): __rpow__/__rlshift__/__rrshift__ — all false for all 3."
    - "  Wave 665 (cf3271): __rand__/__ror__/__rxor__ — all false for all 3."
    - "  Wave 666 (cf3286): __iadd__/__isub__/__imul__ — all false for all 3."
    - "  Wave 667 (cf3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 3."
    - "  Wave 668 (cf3316): __ipow__/__ilshift__/__irshift__ — all false for all 3."
    - "  Wave 669 (cf3331): __iand__/__ior__/__ixor__ — all false for all 3."
    - "  Wave 670 (cf3346): __neg__/__pos__/__abs__ — all false for all 3."
    - "  Wave 671 (cf3361): __invert__/__floor__/__ceil__ — all false for all 3."
    - "  Wave 672 (cf3376): __trunc__/__round__/__index__ — all false for all 3."
    - "  Wave 673 (cf3391): __int__/__float__/__complex__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __int__ dict-presence — operator.contains(Cls.__dict__, '__int__')
#
# All 3 concurrent.futures classes return false for __int__.
# int() delegates to __int__ (numbers.Integral protocol) when defined.
# concurrent.futures.Future: a result handle with PENDING/RUNNING/CANCELLED/
#   FINISHED states; int(future) is not a valid Python expression for a
#   state-machine object. Future manages asynchronous results through
#   callbacks and state transitions, not numeric integer conversion.
# ThreadPoolExecutor/ProcessPoolExecutor: worker-pool lifecycle managers;
#   int(executor) is not defined. Pool configuration is not exposed
#   as an integer value.
# ---------------------------------------------------------------------------

table cf3391.int:
  description: "concurrent.futures types __int__ dict-presence checks; wave 673"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3391

  columns: [id, function, args, expected]
  rows:
    - ["cf3391001", operator.contains, [concurrent.futures.Future.__dict__,              "__int__"], false]
    - ["cf3391002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__int__"], false]
    - ["cf3391003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__int__"], false]

# ---------------------------------------------------------------------------
# __float__ dict-presence — operator.contains(Cls.__dict__, '__float__')
#
# All 3 concurrent.futures classes return false for __float__.
# float() delegates to __float__ (numbers.Real protocol). concurrent.futures
#   types implement no numeric magnitude.
# concurrent.futures.Future: a state-machine result handle, not a numeric type;
#   float(future) is not a meaningful operation. Future state is one of
#   PENDING/RUNNING/CANCELLED/FINISHED — none of these are a scalar value
#   that can be converted to float.
# ThreadPoolExecutor/ProcessPoolExecutor: executor types that encapsulate pools
#   of worker threads or processes; float(executor) is not a defined Python
#   operation. Pool configuration is accessed through constructor arguments
#   and context manager protocol, not float conversion methods.
# ---------------------------------------------------------------------------

table cf3391.float:
  description: "concurrent.futures types __float__ dict-presence checks; wave 673"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3391

  columns: [id, function, args, expected]
  rows:
    - ["cf3391004", operator.contains, [concurrent.futures.Future.__dict__,              "__float__"], false]
    - ["cf3391005", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__float__"], false]
    - ["cf3391006", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__float__"], false]

# ---------------------------------------------------------------------------
# __complex__ dict-presence — operator.contains(Cls.__dict__, '__complex__')
#
# All 3 concurrent.futures classes return false for __complex__.
# complex() delegates to __complex__ (numbers.Complex protocol). concurrent.futures
#   types are not complex number types.
# concurrent.futures.Future: a state-machine result handle, not a complex number;
#   it cannot be passed to complex(). Future's value is retrieved via result()
#   or callbacks, not via __complex__.
# ThreadPoolExecutor/ProcessPoolExecutor: pool lifecycle managers whose entire
#   API is submit(), map(), shutdown(), and context manager protocol.
#   The executor object itself is not a complex number; complex(executor) and
#   executor.__complex__() are not defined Python expressions.
# ---------------------------------------------------------------------------

table cf3391.complex:
  description: "concurrent.futures types __complex__ dict-presence checks; wave 673"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3391

  columns: [id, function, args, expected]
  rows:
    - ["cf3391007", operator.contains, [concurrent.futures.Future.__dict__,              "__complex__"], false]
    - ["cf3391008", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__complex__"], false]
    - ["cf3391009", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__complex__"], false]

# ---------------------------------------------------------------------------
# combined — __int__, __float__, __complex__ across all 3 cf subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __int__: false for all 3 — integer conversion is not defined.
# __float__: false for all 3 — float conversion is not defined.
# __complex__: false for all 3 — complex conversion is not defined.
# All 9 values are false.
# concurrent.futures is a high-level parallel execution API. Its entire public
#   surface is method-based: submit(), map(), result(), cancel(), done(),
#   running(), cancelled(), add_done_callback(), shutdown(). Waves 658–672
#   established that no arithmetic, bitwise, reflected, in-place augmented
#   assignment, unary numeric, or numeric rounding operator appears anywhere
#   in the concurrent.futures type hierarchy. The numeric conversion operators
#   tested here follow the same pattern.
# concurrent.futures.Future note: despite the name, Future is a state-machine
#   result handle — not a numeric, set, or dict-like type. __int__, __float__,
#   and __complex__ are all absent from its __dict__.
# ThreadPoolExecutor/ProcessPoolExecutor note: executor types encapsulate a
#   pool of worker threads or processes; they expose only lifecycle and dispatch
#   methods. No numeric conversion overloads are defined.
# ---------------------------------------------------------------------------

table cf3391.combined:
  description: "concurrent.futures types combined __int__/__float__/__complex__; wave 673"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
