spec: re_extra336
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.match() returns a Match object; all invariants test attributes of that object."
    - "group() with no arguments returns the entire match string."
    - "span() returns a tuple (start, end) — (0, 5) for 'hello' in 'hello world'."
    - "pos is the position in the string where the engine started searching — always 0 for match()."
    - "endpos is the length of the string searched — 11 for 'hello world'."
    - "string is the original string passed to match()."
    - "lastindex is the index of the last matched capturing group — 2 for pattern r'(h)(e)'."
    - "re.__class__.__name__ == 'Pattern' — the compiled pattern object's class name."
    - "re.pattern gives the pattern string used to compile the regex."
    - "span() returns a plain tuple; __eq__((0, 5)) compares element-by-element."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Match.group() — returns the entire matched substring
# ---------------------------------------------------------------------------

invariant re_extra336.match.group.eq:
  description: "re.match(r'hello', 'hello world').group().__eq__('hello') == True — group() returns the full match"
  category: match_attributes
  kind: python_call_eq
  function: "match('hello', 'hello world').group().__eq__"
  args: ["hello"]
  expected: true

# ---------------------------------------------------------------------------
# Match.span() — returns (start, end) tuple
# ---------------------------------------------------------------------------

invariant re_extra336.match.span.eq:
  description: "re.match(r'hello', 'hello world').span().__eq__((0, 5)) == True — span returns (start, end) positions"
  category: match_attributes
  kind: python_call_eq
  function: "match('hello', 'hello world').span().__eq__"
  args: [[0, 5]]
  expected: true

# ---------------------------------------------------------------------------
# Match.pos — start position of the search
# ---------------------------------------------------------------------------

invariant re_extra336.match.pos.eq:
  description: "re.match(r'hello', 'hello world').pos == 0 — match() always starts searching at position 0"
  category: match_attributes
  kind: python_call_eq
  function: "match('hello', 'hello world').pos.__eq__"
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# Match.endpos — end position of the search (length of the string)
# ---------------------------------------------------------------------------

invariant re_extra336.match.endpos.eq:
  description: "re.match(r'hello', 'hello world').endpos == 11 — endpos equals the length of the searched string"
  category: match_attributes
  kind: python_call_eq
  function: "match('hello', 'hello world').endpos.__eq__"
  args: [11]
  expected: true

# ---------------------------------------------------------------------------
# Match.string — the original string passed to match()
# ---------------------------------------------------------------------------

invariant re_extra336.match.string.eq:
  description: "re.match(r'hello', 'hello world').string.__eq__('hello world') == True — string attribute is the input string"
  category: match_attributes
  kind: python_call_eq
  function: "match('hello', 'hello world').string.__eq__"
  args: ["hello world"]
  expected: true

# ---------------------------------------------------------------------------
# Match.lastindex — index of the last matched capturing group
# ---------------------------------------------------------------------------

invariant re_extra336.match.lastindex.eq:
  description: "re.match(r'(h)(e)', 'hello').lastindex == 2 — two capturing groups, lastindex is 2"
  category: match_attributes
  kind: python_call_eq
  function: "match('(h)(e)', 'hello').lastindex.__eq__"
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# Match.re.__class__.__name__ == 'Pattern'
# ---------------------------------------------------------------------------

invariant re_extra336.match.re.class_name:
  description: "re.match(r'hello', 'hello world').re.__class__.__name__ == 'Pattern' — the .re attribute is a compiled Pattern object"
  category: match_attributes
  kind: python_call_eq
  function: "match('hello', 'hello world').re.__class__.__name__.__eq__"
  args: ["Pattern"]
  expected: true

# ---------------------------------------------------------------------------
# Match.re.pattern — the pattern string of the compiled regex
# ---------------------------------------------------------------------------

invariant re_extra336.match.re.pattern:
  description: "re.match(r'hello', 'hello world').re.pattern.__eq__('hello') == True — re.pattern is the original pattern string"
  category: match_attributes
  kind: python_call_eq
  function: "match('hello', 'hello world').re.pattern.__eq__"
  args: ["hello"]
  expected: true
