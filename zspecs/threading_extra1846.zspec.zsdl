spec: threading_extra1846
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module reference"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading.zspec.zsdl — covers class_names, function_names, TIMEOUT_MAX, active_count_ge_1, Lock behavior, Event, Semaphore._value"
    - "threading_extra.zspec.zsdl — covers module checks, local.__name__/__module__, get_ident, TIMEOUT_MAX, stack_size"
    - "threading_extra2.zspec.zsdl — covers class __name__ and function __name__ checks"
  notes:
    - "Wave 570 theme: arithmetic operator protocol (__add__/__sub__/__mul__/__truediv__/__floordiv__/__mod__) and comparison operator protocol (__gt__/__ge__/__le__/__ne__/__lt__/__eq__)."
    - "threading.Thread.__dict__.__contains__('__add__') == False — Thread is a pure Python class with no arithmetic protocol."
    - "threading.Thread.__dict__.__contains__('__eq__') == False — Thread uses object identity for equality (default from object)."
    - "threading.Event.__dict__.__contains__('__eq__') == False — Event does not define __eq__; uses object identity."
    - "threading.Condition.__dict__.__contains__('__eq__') == False — Condition does not define __eq__; uses object identity."
    - "threading.Semaphore.__dict__.__contains__('__eq__') == False — Semaphore does not define __eq__; uses object identity."
    - "threading.Barrier.__dict__.__contains__('__eq__') == False — Barrier does not define __eq__."
    - "threading.Timer.__dict__.__contains__('__add__') == False — Timer is a Thread subclass with no arithmetic protocol."
    - "threading.Lock.__class__.__dict__.__contains__('__add__') == False — Lock is a C-level type; its metaclass (type) does not define __add__ in its own __dict__."
    - "threading.BoundedSemaphore.__dict__.__contains__('acquire') == True — BoundedSemaphore overrides acquire to enforce the upper bound."
    - "threading.BoundedSemaphore.__dict__.__contains__('release') == True — BoundedSemaphore overrides release to enforce the upper bound."
    - "threading.Semaphore.__dict__.__contains__('acquire') == True — Semaphore defines acquire in its own __dict__."
    - "threading.Condition.__dict__.__contains__('wait') == True — Condition defines wait() for blocking until notified."
    - "threading.Condition.__dict__.__contains__('notify') == True — Condition defines notify() to wake one waiting thread."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operators for threading types
#
# All threading types (Thread, Event, Condition, Semaphore, Barrier, Timer)
# are pure Python classes. Lock is a C-level type. None define arithmetic
# dunder methods in their own __dict__.
# ---------------------------------------------------------------------------

table threading_extra1846.arithmetic_operators:
  description: "Arithmetic operator dunder methods absent from threading type own __dict__"
  kind: python_call_eq
  category: arithmetic_operators
  id_prefix: th1846

  columns: [id, function, args, expected]
  rows:
    - ["th1846001", threading.Thread.__dict__.__contains__,              ["__add__"], false]
    - ["th1846002", threading.Thread.__dict__.__contains__,              ["__sub__"], false]
    - ["th1846003", threading.Event.__dict__.__contains__,               ["__add__"], false]
    - ["th1846004", threading.Condition.__dict__.__contains__,           ["__add__"], false]
    - ["th1846005", threading.Semaphore.__dict__.__contains__,           ["__add__"], false]
    - ["th1846006", threading.Barrier.__dict__.__contains__,             ["__add__"], false]
    - ["th1846007", threading.Timer.__dict__.__contains__,               ["__add__"], false]
    - ["th1846008", threading.Lock.__class__.__dict__.__contains__,      ["__add__"], false]

# ---------------------------------------------------------------------------
# Table 2: comparison operators for threading types
#
# No threading type defines its own comparison dunder methods. All rely on
# the default object identity semantics inherited from object.
# ---------------------------------------------------------------------------

table threading_extra1846.comparison_operators:
  description: "Comparison operator dunder methods absent from threading type own __dict__"
  kind: python_call_eq
  category: comparison_operators
  id_prefix: th1846

  columns: [id, function, args, expected]
  rows:
    - ["th1846009", threading.Thread.__dict__.__contains__,              ["__eq__"], false]
    - ["th1846010", threading.Thread.__dict__.__contains__,              ["__lt__"], false]
    - ["th1846011", threading.Thread.__dict__.__contains__,              ["__gt__"], false]
    - ["th1846012", threading.Event.__dict__.__contains__,               ["__eq__"], false]
    - ["th1846013", threading.Condition.__dict__.__contains__,           ["__eq__"], false]
    - ["th1846014", threading.Semaphore.__dict__.__contains__,           ["__eq__"], false]
    - ["th1846015", threading.Barrier.__dict__.__contains__,             ["__eq__"], false]
    - ["th1846016", threading.Lock.__class__.__dict__.__contains__,      ["__eq__"], false]

# ---------------------------------------------------------------------------
# Table 3: BoundedSemaphore and Semaphore own __dict__ method membership
#
# BoundedSemaphore overrides acquire and release to enforce the upper bound.
# Semaphore defines acquire, release, and __init__ in its own __dict__.
# Condition defines acquire, release, wait, and notify in its own __dict__.
# ---------------------------------------------------------------------------

table threading_extra1846.semaphore_bounded_attrs:
  description: "Method presence in BoundedSemaphore, Semaphore, and Condition own __dict__"
  kind: python_call_eq
  category: semaphore_attrs
  id_prefix: th1846

  columns: [id, function, args, expected]
  rows:
    - ["th1846017", threading.BoundedSemaphore.__dict__.__contains__, ["acquire"],  true]
    - ["th1846018", threading.BoundedSemaphore.__dict__.__contains__, ["release"],  true]
    - ["th1846019", threading.BoundedSemaphore.__dict__.__contains__, ["__init__"], true]
    - ["th1846020", threading.Semaphore.__dict__.__contains__,        ["acquire"],  true]
    - ["th1846021", threading.Semaphore.__dict__.__contains__,        ["release"],  true]
    - ["th1846022", threading.Semaphore.__dict__.__contains__,        ["__init__"], true]
    - ["th1846023", threading.Condition.__dict__.__contains__,        ["acquire"],  true]
    - ["th1846024", threading.Condition.__dict__.__contains__,        ["release"],  true]
    - ["th1846025", threading.Condition.__dict__.__contains__,        ["wait"],     true]
    - ["th1846026", threading.Condition.__dict__.__contains__,        ["notify"],   true]
