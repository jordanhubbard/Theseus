spec: unittest_extra7
version: ">=3.9"
backend: python_module(unittest)

docs: https://docs.python.org/3/library/unittest.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unittest.html — Python unittest module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/unittest/__init__.py"
  notes:
    - "This spec extends unittest.zspec.zsdl through unittest_extra6.zspec.zsdl."
    - "unittest covers: class __name__ table, function __name__ table, SkipTest.__bases__[0], TestLoader prefix, TestSuite/TestResult initial state."
    - "unittest_extra covers: class __module__ table, decorator __module__ table, main identity/module, TestCase/FunctionTestCase bases, TestLoader/TestResult state."
    - "unittest_extra2 covers: TextTestRunner/TextTestResult __module__, BaseTestSuite __name__+__module__, class hierarchy bases."
    - "unittest_extra3 covers: IsolatedAsyncioTestCase.__module__, standalone module anchors, TestCase method names (setUp/tearDown/assertEqual/assertTrue/assertRaises/assertFalse/assertIsNone/assertIn/assertNotEqual/assertIsInstance), decorator type checks, SkipTest/TestSuite base anchors."
    - "unittest_extra4 covers: class_names table, decorator_names table, class_modules table, SkipTest.base, TestCase.__class__.__name__, defaultTestLoader.__class__.__name__."
    - "unittest_extra5 covers: __qualname__ table for classes and decorators/main, TestCase.__module__ standalone."
    - "unittest_extra6 covers: signal-function module checks, signal function __qualname__ checks, IsolatedAsyncioTestCase.__bases__[0].__name__, IsolatedAsyncioTestCase.__qualname__, IsolatedAsyncioTestCase.__module__, additional TestCase method names."
    - "NEW in this spec: class __name__ identity checks via __eq__ (standalone invariant form) for TestCase, TestSuite, TestLoader, TestResult, TextTestRunner, TestProgram, SkipTest; decorator/function __name__ identity checks for skip, skipIf, skipUnless, expectedFailure, installHandler; SkipTest.__bases__[0].__name__ == 'Exception'."
    - "All __name__ checks use __eq__ with expected: true — confirming class and function identity via the equality predicate."
    - "unittest.SkipTest.__bases__[0].__name__ == 'Exception' — SkipTest inherits directly from Exception."
    - "unittest.installHandler.__name__ == 'installHandler' — confirms the name of the signal-handling helper."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ identity checks — standalone invariant form using __eq__
#
# Prior specs confirm __name__ values via table rows with direct string
# expected values.  These invariants use the __eq__ predicate with
# expected: true, providing a distinct structural form not previously used
# for this set of classes.
# ---------------------------------------------------------------------------

invariant unittest_extra7.TestCase.name_eq:
  description: "unittest.TestCase.__name__.__eq__('TestCase') == True"
  category: class_names
  kind: python_call_eq
  function: TestCase.__name__.__eq__
  args: ["TestCase"]
  expected: true

invariant unittest_extra7.TestSuite.name_eq:
  description: "unittest.TestSuite.__name__.__eq__('TestSuite') == True"
  category: class_names
  kind: python_call_eq
  function: TestSuite.__name__.__eq__
  args: ["TestSuite"]
  expected: true

invariant unittest_extra7.TestLoader.name_eq:
  description: "unittest.TestLoader.__name__.__eq__('TestLoader') == True"
  category: class_names
  kind: python_call_eq
  function: TestLoader.__name__.__eq__
  args: ["TestLoader"]
  expected: true

invariant unittest_extra7.TestResult.name_eq:
  description: "unittest.TestResult.__name__.__eq__('TestResult') == True"
  category: class_names
  kind: python_call_eq
  function: TestResult.__name__.__eq__
  args: ["TestResult"]
  expected: true

invariant unittest_extra7.TextTestRunner.name_eq:
  description: "unittest.TextTestRunner.__name__.__eq__('TextTestRunner') == True"
  category: class_names
  kind: python_call_eq
  function: TextTestRunner.__name__.__eq__
  args: ["TextTestRunner"]
  expected: true

invariant unittest_extra7.TestProgram.name_eq:
  description: "unittest.TestProgram.__name__.__eq__('TestProgram') == True"
  category: class_names
  kind: python_call_eq
  function: TestProgram.__name__.__eq__
  args: ["TestProgram"]
  expected: true

invariant unittest_extra7.SkipTest.name_eq:
  description: "unittest.SkipTest.__name__.__eq__('SkipTest') == True"
  category: class_names
  kind: python_call_eq
  function: SkipTest.__name__.__eq__
  args: ["SkipTest"]
  expected: true

# ---------------------------------------------------------------------------
# SkipTest base class — __bases__[0].__name__ == 'Exception'
#
# The base spec records SkipTest.__bases__[0] as Exception; this invariant
# uses __eq__ with expected: true (new structural form not previously used
# for SkipTest's base).
# ---------------------------------------------------------------------------

invariant unittest_extra7.SkipTest.base_is_Exception:
  description: "unittest.SkipTest.__bases__[0].__name__ == 'Exception' — SkipTest inherits from Exception"
  category: class_hierarchy
  kind: python_call_eq
  function: SkipTest.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# Decorator and function __name__ identity checks — __eq__ predicate form
#
# Prior specs confirm these __name__ values via table or direct-value
# invariants.  The __eq__ predicate form with expected: true is new for
# skip, skipIf, skipUnless, expectedFailure, and installHandler.
# ---------------------------------------------------------------------------

invariant unittest_extra7.skip.name_eq:
  description: "unittest.skip.__name__.__eq__('skip') == True"
  category: function_names
  kind: python_call_eq
  function: skip.__name__.__eq__
  args: ["skip"]
  expected: true

invariant unittest_extra7.skipIf.name_eq:
  description: "unittest.skipIf.__name__.__eq__('skipIf') == True"
  category: function_names
  kind: python_call_eq
  function: skipIf.__name__.__eq__
  args: ["skipIf"]
  expected: true

invariant unittest_extra7.skipUnless.name_eq:
  description: "unittest.skipUnless.__name__.__eq__('skipUnless') == True"
  category: function_names
  kind: python_call_eq
  function: skipUnless.__name__.__eq__
  args: ["skipUnless"]
  expected: true

invariant unittest_extra7.expectedFailure.name_eq:
  description: "unittest.expectedFailure.__name__.__eq__('expectedFailure') == True"
  category: function_names
  kind: python_call_eq
  function: expectedFailure.__name__.__eq__
  args: ["expectedFailure"]
  expected: true

invariant unittest_extra7.installHandler.name_eq:
  description: "unittest.installHandler.__name__.__eq__('installHandler') == True"
  category: function_names
  kind: python_call_eq
  function: installHandler.__name__.__eq__
  args: ["installHandler"]
  expected: true
