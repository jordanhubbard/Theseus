spec: hashlib_extra189
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
  notes:
    - "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac' — len=11; implemented in _hashlib C extension."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib' — the underlying C extension module, not 'hashlib'."
    - "hashlib.scrypt.__name__ == 'scrypt' — len=6; implemented in _hashlib C extension."
    - "hashlib.scrypt.__module__ == '_hashlib' — same C extension as pbkdf2_hmac."
    - "Both pbkdf2_hmac and scrypt have __class__.__name__ == 'builtin_function_or_method'."
    - "Length ordering: len('scrypt') == 6 < len('pbkdf2_hmac') == 11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: hashlib.pbkdf2_hmac function identity — name and qualname
#
# hashlib.pbkdf2_hmac.__name__     == 'pbkdf2_hmac'  (len=11)
# hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac'
#
# pbkdf2_hmac is a builtin implemented in _hashlib; __name__ and __qualname__
# are both 'pbkdf2_hmac'.
# ---------------------------------------------------------------------------

table hashlib_extra189.pbkdf2_hmac_name_identity:
  description: "hashlib.pbkdf2_hmac name and qualname identity; new to extra189"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibkdf189

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_name_eq,
       hashlib.pbkdf2_hmac.__name__.__eq__,
       ["pbkdf2_hmac"],
       true,
       "hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac') == True — function is named 'pbkdf2_hmac'; len=11; new to extra189"]
    - [pbkdf2_name_len,
       hashlib.pbkdf2_hmac.__name__.__len__,
       [],
       11,
       "hashlib.pbkdf2_hmac.__name__.__len__() == 11 — 'pbkdf2_hmac' has 11 characters; new to extra189"]
    - [pbkdf2_qualname_eq,
       hashlib.pbkdf2_hmac.__qualname__.__eq__,
       ["pbkdf2_hmac"],
       true,
       "hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac') == True — qualname equals name for top-level builtins; new to extra189"]
    - [pbkdf2_module_eq,
       hashlib.pbkdf2_hmac.__module__.__eq__,
       ["_hashlib"],
       true,
       "hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') == True — implemented in _hashlib C extension, not in 'hashlib'; new to extra189"]

# ---------------------------------------------------------------------------
# Table 2: hashlib.scrypt function identity — name and qualname
#
# hashlib.scrypt.__name__     == 'scrypt'  (len=6)
# hashlib.scrypt.__qualname__ == 'scrypt'
# hashlib.scrypt.__module__   == '_hashlib'
#
# scrypt is a builtin in _hashlib; name and qualname are both 'scrypt'.
# ---------------------------------------------------------------------------

table hashlib_extra189.scrypt_name_identity:
  description: "hashlib.scrypt name and qualname identity; new to extra189"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibkdf189

  columns: [id, function, args, expected, description]
  rows:
    - [scrypt_name_eq,
       hashlib.scrypt.__name__.__eq__,
       ["scrypt"],
       true,
       "hashlib.scrypt.__name__.__eq__('scrypt') == True — function is named 'scrypt'; len=6; new to extra189"]
    - [scrypt_name_len,
       hashlib.scrypt.__name__.__len__,
       [],
       6,
       "hashlib.scrypt.__name__.__len__() == 6 — 'scrypt' has 6 characters; new to extra189"]
    - [scrypt_qualname_eq,
       hashlib.scrypt.__qualname__.__eq__,
       ["scrypt"],
       true,
       "hashlib.scrypt.__qualname__.__eq__('scrypt') == True — qualname equals name for top-level builtins; new to extra189"]
    - [scrypt_module_eq,
       hashlib.scrypt.__module__.__eq__,
       ["_hashlib"],
       true,
       "hashlib.scrypt.__module__.__eq__('_hashlib') == True — implemented in _hashlib C extension, not in 'hashlib'; new to extra189"]

# ---------------------------------------------------------------------------
# Table 3: pbkdf2_hmac and scrypt class identity and length ordering
#
# hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'
# hashlib.scrypt.__class__.__name__      == 'builtin_function_or_method'
# len('scrypt') == 6 < len('pbkdf2_hmac') == 11
#
# Both functions are C builtins; length ordering holds: scrypt(6) < pbkdf2_hmac(11).
# ---------------------------------------------------------------------------

table hashlib_extra189.class_and_length_ordering:
  description: "pbkdf2_hmac and scrypt class names and length ordering; new to extra189"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibkdf189

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_class_eq,
       hashlib.pbkdf2_hmac.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method') == True — pbkdf2_hmac is a C builtin; new to extra189"]
    - [scrypt_class_eq,
       hashlib.scrypt.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "hashlib.scrypt.__class__.__name__.__eq__('builtin_function_or_method') == True — scrypt is a C builtin; new to extra189"]
    - [scrypt_name_len_lt_pbkdf2,
       hashlib.scrypt.__name__.__len__,
       [],
       6,
       "hashlib.scrypt.__name__.__len__() == 6 — scrypt(6) < pbkdf2_hmac(11); length ordering holds; new to extra189"]
    - [pbkdf2_name_len_gt_scrypt,
       hashlib.pbkdf2_hmac.__name__.__len__,
       [],
       11,
       "hashlib.pbkdf2_hmac.__name__.__len__() == 11 — pbkdf2_hmac(11) > scrypt(6); length ordering holds; new to extra189"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra189
# ---------------------------------------------------------------------------

invariant hashlib_extra189.pbkdf2_name_is_pbkdf2_hmac:
  description: "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac' — function identity; len=11; new to extra189"
  category: identity
  kind: python_call_eq
  function: hashlib.pbkdf2_hmac.__name__.__eq__
  args: ["pbkdf2_hmac"]
  expected: true

invariant hashlib_extra189.pbkdf2_name_len_is_11:
  description: "hashlib.pbkdf2_hmac.__name__.__len__() == 11 — 'pbkdf2_hmac' has 11 characters; new to extra189"
  category: identity
  kind: python_call_eq
  function: hashlib.pbkdf2_hmac.__name__.__len__
  args: []
  expected: 11

invariant hashlib_extra189.pbkdf2_module_is_hashlib_c:
  description: "hashlib.pbkdf2_hmac.__module__ == '_hashlib' — C extension module, not the 'hashlib' Python wrapper; new to extra189"
  category: identity
  kind: python_call_eq
  function: hashlib.pbkdf2_hmac.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra189.scrypt_name_is_scrypt:
  description: "hashlib.scrypt.__name__ == 'scrypt' — function identity; len=6; new to extra189"
  category: identity
  kind: python_call_eq
  function: hashlib.scrypt.__name__.__eq__
  args: ["scrypt"]
  expected: true

invariant hashlib_extra189.scrypt_name_len_is_6:
  description: "hashlib.scrypt.__name__.__len__() == 6 — 'scrypt' has 6 characters; new to extra189"
  category: identity
  kind: python_call_eq
  function: hashlib.scrypt.__name__.__len__
  args: []
  expected: 6

invariant hashlib_extra189.scrypt_module_is_hashlib_c:
  description: "hashlib.scrypt.__module__ == '_hashlib' — C extension module, not the 'hashlib' Python wrapper; new to extra189"
  category: identity
  kind: python_call_eq
  function: hashlib.scrypt.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra189.pbkdf2_class_is_builtin:
  description: "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method' — pbkdf2_hmac is a C builtin; new to extra189"
  category: identity
  kind: python_call_eq
  function: hashlib.pbkdf2_hmac.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant hashlib_extra189.scrypt_class_is_builtin:
  description: "hashlib.scrypt.__class__.__name__ == 'builtin_function_or_method' — scrypt is a C builtin; new to extra189"
  category: identity
  kind: python_call_eq
  function: hashlib.scrypt.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
