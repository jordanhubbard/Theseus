spec: filecmp_extra3
version: ">=3.9"
backend: python_module(filecmp)

docs: https://docs.python.org/3/library/filecmp.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/filecmp.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/filecmp.py"
  notes:
    - "This spec extends filecmp.zspec.zsdl, filecmp_extra.zspec.zsdl, and filecmp_extra2.zspec.zsdl."
    - "filecmp.zspec.zsdl covers: cmp/cmpfiles/clear_cache __name__ table, dircmp.__name__, cmp.__module__, dircmp method names table, DEFAULT_IGNORES type and .git membership, clear_cache() return value."
    - "filecmp_extra.zspec.zsdl covers: dircmp.__bases__[0].__name__, dircmp.__module__, dircmp.__class__.__name__, DEFAULT_IGNORES VCS entries table and length, cmpfiles/clear_cache module, dircmp.hide type, cmpfiles/cmp __class__.__name__."
    - "filecmp_extra2.zspec.zsdl covers: cmp.__name__, cmpfiles.__name__, dircmp.__name__, DEFAULT_IGNORES.__class__.__name__, dircmp.__module__, dircmp.__bases__[0].__name__."
    - "This spec adds: clear_cache.__name__ (standalone invariant), dircmp.__qualname__, clear_cache.__module__, cmpfiles.__module__ (standalone), DEFAULT_BUFSIZE class name and minimum value check."
    - "filecmp.DEFAULT_BUFSIZE is an integer constant used as the default comparison buffer size; its value is at least 8192 bytes."
    - "filecmp.dircmp.__qualname__ == 'dircmp' — the class is not nested so __qualname__ == __name__."
    - "filecmp.clear_cache.__name__ == 'clear_cache' — plain function defined in filecmp."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# clear_cache function — __name__ and __module__
# __name__ was in the filecmp.zspec.zsdl table but not as a standalone invariant.
# __module__ is new (not covered in any prior filecmp spec).
# ---------------------------------------------------------------------------

invariant filecmp_extra3.clear_cache.name:
  description: "filecmp.clear_cache.__name__ == 'clear_cache'"
  category: functions
  kind: python_call_eq
  function: clear_cache.__name__.__eq__
  args: ["clear_cache"]
  expected: true

invariant filecmp_extra3.clear_cache.module:
  description: "filecmp.clear_cache.__module__ == 'filecmp'"
  category: functions
  kind: python_call_eq
  function: clear_cache.__module__.__eq__
  args: ["filecmp"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ table — cmp, cmpfiles, clear_cache
# Provides cross-verification as a table in addition to standalone invariants.
# ---------------------------------------------------------------------------

table filecmp_extra3.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [cmp,         cmp.__name__.__eq__,         ["cmp"],         true]
    - [cmpfiles,    cmpfiles.__name__.__eq__,     ["cmpfiles"],    true]
    - [clear_cache, clear_cache.__name__.__eq__,  ["clear_cache"], true]

# ---------------------------------------------------------------------------
# dircmp class — __qualname__
# New vector: __qualname__ not covered in any prior filecmp spec.
# ---------------------------------------------------------------------------

invariant filecmp_extra3.dircmp.qualname:
  description: "filecmp.dircmp.__qualname__ == 'dircmp' — class is not nested so __qualname__ == __name__"
  category: classnames
  kind: python_call_eq
  function: dircmp.__qualname__.__eq__
  args: ["dircmp"]
  expected: true

# ---------------------------------------------------------------------------
# DEFAULT_BUFSIZE — integer constant: class name and minimum value
# Not covered in any prior filecmp spec.
# ---------------------------------------------------------------------------

invariant filecmp_extra3.DEFAULT_BUFSIZE.class_name:
  description: "filecmp.DEFAULT_BUFSIZE.__class__.__name__ == 'int' — DEFAULT_BUFSIZE is an integer"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFSIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant filecmp_extra3.DEFAULT_BUFSIZE.minimum_value:
  description: "filecmp.DEFAULT_BUFSIZE >= 8192 — buffer size is at least 8 KiB"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFSIZE.__ge__
  args: [8192]
  expected: true

# ---------------------------------------------------------------------------
# cmpfiles — __module__ as a standalone invariant
# filecmp_extra.zspec.zsdl covers cmpfiles module via a table row;
# here it is a named standalone invariant for a distinct test ID.
# ---------------------------------------------------------------------------

invariant filecmp_extra3.cmpfiles.module:
  description: "filecmp.cmpfiles.__module__ == 'filecmp'"
  category: functions
  kind: python_call_eq
  function: cmpfiles.__module__.__eq__
  args: ["filecmp"]
  expected: true

# ---------------------------------------------------------------------------
# cmp function — standalone __name__ invariant
# Covered in filecmp_extra2 and the filecmp table; present here as an
# anchor invariant with a distinct spec-qualified ID.
# ---------------------------------------------------------------------------

invariant filecmp_extra3.cmp.name:
  description: "filecmp.cmp.__name__ == 'cmp'"
  category: functions
  kind: python_call_eq
  function: cmp.__name__.__eq__
  args: ["cmp"]
  expected: true

invariant filecmp_extra3.cmp.module:
  description: "filecmp.cmp.__module__ == 'filecmp'"
  category: functions
  kind: python_call_eq
  function: cmp.__module__.__eq__
  args: ["filecmp"]
  expected: true

# ---------------------------------------------------------------------------
# dircmp — __name__ and __module__ standalone invariants
# Covered in prior specs via tables; here as named invariants in extra3.
# ---------------------------------------------------------------------------

invariant filecmp_extra3.dircmp.name:
  description: "filecmp.dircmp.__name__ == 'dircmp'"
  category: classnames
  kind: python_call_eq
  function: dircmp.__name__.__eq__
  args: ["dircmp"]
  expected: true

invariant filecmp_extra3.dircmp.module:
  description: "filecmp.dircmp.__module__ == 'filecmp'"
  category: modules
  kind: python_call_eq
  function: dircmp.__module__.__eq__
  args: ["filecmp"]
  expected: true

invariant filecmp_extra3.dircmp.base_is_object:
  description: "filecmp.dircmp.__bases__[0].__name__ == 'object' — dircmp inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: dircmp.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
