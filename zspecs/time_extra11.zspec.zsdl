spec: time_extra11
version: ">=3.9"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html — Python time module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
    - "time.zspec.zsdl — covers gmtime/strptime/strftime/mktime/sleep __name__ (table), struct_time.__name__, epoch vectors"
    - "time_extra4.zspec.zsdl — covers __qualname__ table for time/sleep/monotonic/perf_counter/process_time/gmtime/localtime/mktime/strftime/strptime/struct_time"
    - "time_extra10.zspec.zsdl — covers __qualname__ standalone invariants for sleep/monotonic/perf_counter; struct_time.__bases__[0].__name__; __module__ table"
  notes:
    - "This spec extends time.zspec.zsdl and prior extras through time_extra10.zspec.zsdl."
    - "NEW in extra11 — Axis 1: __qualname__ for the _ns variant functions (time_ns, monotonic_ns, perf_counter_ns) — not covered in any prior spec."
    - "NEW in extra11 — Axis 2: struct_time.__qualname__ as a standalone extra11-namespace invariant."
    - "NEW in extra11 — Axis 3: __qualname__ for clock_gettime, clock_getres, get_clock_info — extended clock API not covered in extra4/extra10."
    - "time.time_ns.__qualname__ == 'time_ns' — verified Python 3.12."
    - "time.monotonic_ns.__qualname__ == 'monotonic_ns' — verified Python 3.12."
    - "time.perf_counter_ns.__qualname__ == 'perf_counter_ns' — verified Python 3.12."
    - "time.struct_time.__qualname__ == 'struct_time' — verified Python 3.12."
    - "time.clock_gettime.__qualname__ == 'clock_gettime' — verified Python 3.12."
    - "time.clock_getres.__qualname__ == 'clock_getres' — verified Python 3.12."
    - "time.get_clock_info.__qualname__ == 'get_clock_info' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for the nanosecond-resolution clock variants
#
# time_extra4 covers __qualname__ for the standard clock functions but does
# NOT include the _ns variants (time_ns, monotonic_ns, perf_counter_ns).
# These were added in Python 3.7 and have flat qualnames equal to their names.
# ---------------------------------------------------------------------------

table time_extra11.ns_function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qn

  columns: [id, function, args, expected]
  rows:
    - [time_ns,          time_ns.__qualname__.__eq__,          ["time_ns"],          true]
    - [monotonic_ns,     monotonic_ns.__qualname__.__eq__,     ["monotonic_ns"],     true]
    - [perf_counter_ns,  perf_counter_ns.__qualname__.__eq__,  ["perf_counter_ns"],  true]

# ---------------------------------------------------------------------------
# struct_time.__qualname__ — standalone extra11-namespace invariant
#
# time_extra4 covers struct_time.__qualname__ in a table. This spec anchors
# it as a standalone invariant in the extra11 namespace.
# ---------------------------------------------------------------------------

invariant time_extra11.struct_time.qualname:
  description: "time.struct_time.__qualname__ == 'struct_time' — flat qualname for C extension type"
  category: class_qualnames
  kind: python_call_eq
  function: struct_time.__qualname__.__eq__
  args: ["struct_time"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for extended clock API functions
#
# clock_gettime, clock_getres, and get_clock_info are part of the POSIX
# clock API added in Python 3.3. No prior spec checks their __qualname__.
# ---------------------------------------------------------------------------

invariant time_extra11.clock_gettime.qualname:
  description: "time.clock_gettime.__qualname__ == 'clock_gettime'"
  category: function_qualnames
  kind: python_call_eq
  function: clock_gettime.__qualname__.__eq__
  args: ["clock_gettime"]
  expected: true

invariant time_extra11.clock_getres.qualname:
  description: "time.clock_getres.__qualname__ == 'clock_getres'"
  category: function_qualnames
  kind: python_call_eq
  function: clock_getres.__qualname__.__eq__
  args: ["clock_getres"]
  expected: true

invariant time_extra11.get_clock_info.qualname:
  description: "time.get_clock_info.__qualname__ == 'get_clock_info'"
  category: function_qualnames
  kind: python_call_eq
  function: get_clock_info.__qualname__.__eq__
  args: ["get_clock_info"]
  expected: true
