spec: types_extra11
version: ">=3.9"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
    - "types.zspec.zsdl — covers __name__ for FunctionType/MethodType/ModuleType/NoneType/GeneratorType/MappingProxyType/SimpleNamespace/LambdaType/CoroutineType/AsyncGeneratorType/UnionType"
    - "types_extra.zspec.zsdl — covers __name__ for CodeType/BuiltinFunctionType/TracebackType/FrameType"
    - "types_extra2.zspec.zsdl — covers __module__ and __bases__[0].__name__ for major types"
    - "types_extra5.zspec.zsdl — covers __qualname__ for FunctionType/MethodType/GeneratorType/CoroutineType/ModuleType; BuiltinFunctionType/AsyncGeneratorType/LambdaType/SimpleNamespace/MappingProxyType/DynamicClassAttribute"
    - "types_extra6.zspec.zsdl — covers __qualname__ for CellType/CodeType/FrameType/TracebackType/NoneType/EllipsisType/NotImplementedType; __bases__[0] for BuiltinFunctionType/LambdaType/MappingProxyType/CellType"
    - "types_extra7.zspec.zsdl — covers GenericAlias/UnionType/descriptor types __name__/__qualname__/__module__"
    - "types_extra8.zspec.zsdl — covers descriptor types __module__/__bases__[0]; CapsuleType; DynamicClassAttribute/__name__/__module__; SimpleNamespace/__bases__[0]; UnionType/__bases__[0]"
    - "types_extra9.zspec.zsdl — covers type __name__ via boolean __eq__ for all major types"
    - "types_extra10.zspec.zsdl — covers __bases__.__len__ == 1 for FunctionType/LambdaType/CodeType/MethodType"
  notes:
    - "This spec adds new axes: __name__.__len__() for C-level types (structural length checks); MRO[0] self-identity for selected types; __module__ standalone invariants for MappingProxyType/SimpleNamespace/NoneType not yet covered standalone."
    - "NOT yet covered: types.FunctionType.__name__.__len__() == 8 — 'function' is 8 characters."
    - "NOT yet covered: types.MethodType.__name__.__len__() == 6 — 'method' is 6 characters."
    - "NOT yet covered: types.ModuleType.__name__.__len__() == 6 — 'module' is 6 characters."
    - "NOT yet covered: types.GeneratorType.__name__.__len__() == 9 — 'generator' is 9 characters."
    - "NOT yet covered: types.CoroutineType.__name__.__len__() == 9 — 'coroutine' is 9 characters."
    - "NOT yet covered: types.SimpleNamespace.__name__.__len__() == 15 — 'SimpleNamespace' is 15 characters."
    - "NOT yet covered: types.MappingProxyType.__name__.__len__() == 12 — 'mappingproxy' is 12 characters."
    - "NOT yet covered: types.FunctionType.__mro__[0].__name__ == 'function' — MRO[0] is the class itself."
    - "NOT yet covered: types.ModuleType.__mro__[0].__name__ == 'module' — MRO[0] is the class itself."
    - "NOT yet covered: types.SimpleNamespace.__mro__[0].__name__ == 'SimpleNamespace' — MRO[0] is the class itself."
    - "NOT yet covered: types.MappingProxyType.__module__ == 'builtins' as a standalone invariant."
    - "NOT yet covered: types.NoneType.__module__ == 'builtins' as a standalone invariant (extra4 covers it in table; not yet standalone)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ string lengths — structural checks
#
# types_extra9 verifies __name__ values via boolean __eq__. No prior spec
# checks the __len__() of any type's __name__ string in the types module.
# These structural checks are a distinct axis from equality.
# ---------------------------------------------------------------------------

table types_extra11.class_name_lengths:
  kind: python_call_eq
  category: class_names
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [FunctionType,  FunctionType.__name__.__len__,  [], 8]
    - [MethodType,    MethodType.__name__.__len__,    [], 6]
    - [ModuleType,    ModuleType.__name__.__len__,    [], 6]
    - [GeneratorType, GeneratorType.__name__.__len__, [], 9]
    - [CoroutineType, CoroutineType.__name__.__len__, [], 9]

# ---------------------------------------------------------------------------
# Additional __name__ lengths — SimpleNamespace and MappingProxyType
#
# SimpleNamespace.__name__ == 'SimpleNamespace' (15 chars).
# MappingProxyType.__name__ == 'mappingproxy' (12 chars).
# Neither length has been verified in any prior spec.
# ---------------------------------------------------------------------------

invariant types_extra11.SimpleNamespace.name_len:
  description: "types.SimpleNamespace.__name__.__len__() == 15 — 'SimpleNamespace' is 15 characters"
  category: class_names
  kind: python_call_eq
  function: SimpleNamespace.__name__.__len__
  args: []
  expected: 15

invariant types_extra11.MappingProxyType.name_len:
  description: "types.MappingProxyType.__name__.__len__() == 12 — 'mappingproxy' is 12 characters"
  category: class_names
  kind: python_call_eq
  function: MappingProxyType.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# MRO[0] self-identity — FunctionType, ModuleType, SimpleNamespace
#
# Prior specs check MRO entries at index >=1 for various types.
# No prior types spec verifies MRO[0] (which is always the class itself).
# These three invariants confirm the self-identity property for representative
# types from different origins (C-level, C-level, Python-level).
# ---------------------------------------------------------------------------

invariant types_extra11.FunctionType.mro_first:
  description: "types.FunctionType.__mro__[0].__name__ == 'function' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: FunctionType.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "function"

invariant types_extra11.ModuleType.mro_first:
  description: "types.ModuleType.__mro__[0].__name__ == 'module' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: ModuleType.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "module"

invariant types_extra11.SimpleNamespace.mro_first:
  description: "types.SimpleNamespace.__mro__[0].__name__ == 'SimpleNamespace' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: SimpleNamespace.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "SimpleNamespace"

# ---------------------------------------------------------------------------
# Standalone __module__ invariants for MappingProxyType and NoneType
#
# types_extra2 covers these in a table but no spec has them as standalone
# invariants for individual machine-readable indexing.
# types_extra4 covers MappingProxyType and NoneType __module__ in a table row.
# These add them as explicit standalone invariants.
# ---------------------------------------------------------------------------

invariant types_extra11.MappingProxyType.module:
  description: "types.MappingProxyType.__module__ == 'builtins' — C-level type; standalone invariant"
  category: class_modules
  kind: python_call_eq
  function: MappingProxyType.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant types_extra11.NoneType.module:
  description: "types.NoneType.__module__ == 'builtins' — C-level type; standalone invariant"
  category: class_modules
  kind: python_call_eq
  function: NoneType.__module__.__eq__
  args: ["builtins"]
  expected: true
