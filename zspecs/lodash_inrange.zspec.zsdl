spec: lodash_inrange
version: ">=4.0.0"
backend: node(lodash.inrange)

docs: https://lodash.com/docs/#inRange

provenance:
  derived_from:
    - "lodash.inrange README — https://www.npmjs.com/package/lodash.inrange"
    - "Test vectors verified with lodash.inrange@4.0.3 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.inrange exports the _.inRange function directly as module.exports."
    - "inRange(number, start, end) checks if number is in the half-open range [start, end)."
    - "With two args, inRange(number, end) uses 0 as start."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_inrange.inrange:
  kind: node_module_call_eq
  function: ~
  category: inrange
  id_prefix: linr

  columns: [id, args, expected]
  rows:
    - [inside,       [3, 1, 5],   true]
    - [below,        [0, 1, 5],   false]
    - [at_end,       [5, 1, 5],   false]
    - [at_start,     [1, 1, 5],   true]
    - [two_arg,      [3, 5],      true]
    - [two_arg_out,  [6, 5],      false]
