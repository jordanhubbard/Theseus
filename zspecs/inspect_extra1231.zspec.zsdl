spec: inspect_extra1231
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks inspect.__dict__.__contains__ for 'signature', 'Parameter', 'Signature', 'isfunction', 'isclass', 'ismodule', 'getmembers', 'getsource', 'ismethod', 'isbuiltin', 'getdoc', 'getfile', 'isframe', 'iscode', 'isroutine', 'iscoroutinefunction', and absent keys — not covered in _extra1201/_extra1216"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1231.dict_contains_classes_and_signature:
  description: "inspect.__dict__.__contains__ for classes and signature function"
  kind: python_call_eq
  category: dict_contains_classes_and_signature
  id_prefix: ip1231dc
  columns: [id, function, args, expected]
  rows:
    - [ip1231dc001, inspect.__dict__.__contains__, ["signature"],    true]
    - [ip1231dc002, inspect.__dict__.__contains__, ["Parameter"],    true]
    - [ip1231dc003, inspect.__dict__.__contains__, ["Signature"],    true]
    - [ip1231dc004, inspect.__dict__.__contains__, ["isfunction"],   true]
    - [ip1231dc005, inspect.__dict__.__contains__, ["isclass"],      true]
    - [ip1231dc006, inspect.__dict__.__contains__, ["ismodule"],     true]
    - [ip1231dc007, inspect.__dict__.__contains__, ["getmembers"],   true]
    - [ip1231dc008, inspect.__dict__.__contains__, ["getsource"],    true]

table inspect_extra1231.dict_contains_predicate_functions:
  description: "inspect.__dict__.__contains__ for predicate and introspection functions"
  kind: python_call_eq
  category: dict_contains_predicate_functions
  id_prefix: ip1231pf
  columns: [id, function, args, expected]
  rows:
    - [ip1231pf001, inspect.__dict__.__contains__, ["ismethod"],             true]
    - [ip1231pf002, inspect.__dict__.__contains__, ["isbuiltin"],            true]
    - [ip1231pf003, inspect.__dict__.__contains__, ["getdoc"],               true]
    - [ip1231pf004, inspect.__dict__.__contains__, ["getfile"],              true]
    - [ip1231pf005, inspect.__dict__.__contains__, ["isframe"],              true]
    - [ip1231pf006, inspect.__dict__.__contains__, ["iscode"],               true]
    - [ip1231pf007, inspect.__dict__.__contains__, ["isroutine"],            true]
    - [ip1231pf008, inspect.__dict__.__contains__, ["iscoroutinefunction"],  true]

table inspect_extra1231.dict_contains_more_and_absent:
  description: "inspect.__dict__.__contains__ for additional helpers and absent keys"
  kind: python_call_eq
  category: dict_contains_more_and_absent
  id_prefix: ip1231ma
  columns: [id, function, args, expected]
  rows:
    - [ip1231ma001, inspect.__dict__.__contains__, ["BoundArguments"],       true]
    - [ip1231ma002, inspect.__dict__.__contains__, ["FullArgSpec"],          true]
    - [ip1231ma003, inspect.__dict__.__contains__, ["getmodule"],            true]
    - [ip1231ma004, inspect.__dict__.__contains__, ["isasyncgenfunction"],   true]
    - [ip1231ma005, inspect.__dict__.__contains__, ["nonexistent_fn"],       false]
    - [ip1231ma006, inspect.__dict__.__contains__, ["partial"],              false]
    - [ip1231ma007, inspect.__dict__.__contains__, ["reduce"],               false]
    - [ip1231ma008, inspect.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
