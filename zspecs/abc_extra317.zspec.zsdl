spec: abc_extra317
version: ">=3.9"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — numbers module documentation"
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "The numeric abstract base classes (Number, Complex, Real, Rational, Integral) live in the 'numbers' module, not in collections.abc."
    - "numbers.Number.__module__ == 'numbers' — all five numeric ABCs are defined in the numbers module."
    - "The tower is strictly linear: Number > Complex > Real > Rational > Integral."
    - "numbers.Number.__bases__[0].__name__ == 'object' — Number inherits from object."
    - "numbers.Complex.__bases__[0].__name__ == 'Number'."
    - "numbers.Real.__bases__[0].__name__ == 'Complex'."
    - "numbers.Rational.__bases__[0].__name__ == 'Real'."
    - "numbers.Integral.__bases__[0].__name__ == 'Rational'."
    - "collections.abc.Set.__module__ == 'collections.abc'."
    - "collections.abc.Set.__bases__[0].__name__ == 'Collection' (not 'object')."
    - "collections.abc.MutableSet.__bases__[0].__name__ == 'Set'."
    - "collections.abc.Awaitable.__module__ == 'collections.abc'."
    - "collections.abc.Awaitable.__bases__[0].__name__ == 'object'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Numeric tower — __name__ and __module__ for each ABC
#
# All five numeric abstract base classes are defined in the 'numbers' module.
# Their __name__ values equal their unqualified class names.
# ---------------------------------------------------------------------------

table abc_extra317.numeric_tower.names:
  description: "Numeric tower ABCs have the expected __name__ values"
  kind: python_call_eq
  category: numeric_names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [Number,   Number.__name__.__eq__,   ["Number"],   true]
    - [Complex,  Complex.__name__.__eq__,  ["Complex"],  true]
    - [Real,     Real.__name__.__eq__,     ["Real"],     true]
    - [Rational, Rational.__name__.__eq__, ["Rational"], true]
    - [Integral, Integral.__name__.__eq__, ["Integral"], true]

table abc_extra317.numeric_tower.modules:
  description: "Numeric tower ABCs all have __module__ == 'numbers'"
  kind: python_call_eq
  category: numeric_modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Number,   Number.__module__.__eq__,   ["numbers"], true]
    - [Complex,  Complex.__module__.__eq__,  ["numbers"], true]
    - [Real,     Real.__module__.__eq__,     ["numbers"], true]
    - [Rational, Rational.__module__.__eq__, ["numbers"], true]
    - [Integral, Integral.__module__.__eq__, ["numbers"], true]

# ---------------------------------------------------------------------------
# Numeric tower — inheritance chain via __bases__[0].__name__
#
# The hierarchy is strictly linear. Each level's first (and only) base is
# the level immediately above it. Number's base is the universal root object.
# ---------------------------------------------------------------------------

invariant abc_extra317.Number.base:
  description: "numbers.Number.__bases__[0].__name__ == 'object'"
  category: numeric_hierarchy
  kind: python_call_eq
  function: Number.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant abc_extra317.Complex.base:
  description: "numbers.Complex.__bases__[0].__name__ == 'Number'"
  category: numeric_hierarchy
  kind: python_call_eq
  function: Complex.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Number"

invariant abc_extra317.Real.base:
  description: "numbers.Real.__bases__[0].__name__ == 'Complex'"
  category: numeric_hierarchy
  kind: python_call_eq
  function: Real.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Complex"

invariant abc_extra317.Rational.base:
  description: "numbers.Rational.__bases__[0].__name__ == 'Real'"
  category: numeric_hierarchy
  kind: python_call_eq
  function: Rational.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Real"

invariant abc_extra317.Integral.base:
  description: "numbers.Integral.__bases__[0].__name__ == 'Rational'"
  category: numeric_hierarchy
  kind: python_call_eq
  function: Integral.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Rational"

# ---------------------------------------------------------------------------
# collections.abc.Set — name, module, and base class
#
# collections.abc.Set is the abstract base for immutable sets. Despite its
# name, its first base is Collection (not object), because Set extends
# Collection for the contains/iter/len protocol.
# These invariants use a second backend import alias; the function chain
# uses the fully-qualified dotted path from the module root.
# ---------------------------------------------------------------------------

invariant abc_extra317.Set.name:
  description: "collections.abc.Set.__name__ == 'Set'"
  category: abc_set
  kind: python_call_eq
  backend: python_module(collections.abc)
  function: Set.__name__.__eq__
  args: ["Set"]
  expected: true

invariant abc_extra317.Set.module:
  description: "collections.abc.Set.__module__ == 'collections.abc'"
  category: abc_set
  kind: python_call_eq
  backend: python_module(collections.abc)
  function: Set.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra317.Set.base:
  description: "collections.abc.Set.__bases__[0].__name__ == 'Collection'"
  category: abc_set
  kind: python_call_eq
  backend: python_module(collections.abc)
  function: Set.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Collection"

# ---------------------------------------------------------------------------
# collections.abc.MutableSet — name, module, and base class
#
# collections.abc.MutableSet adds mutation methods (add, discard) to Set.
# Its first base is Set.
# ---------------------------------------------------------------------------

invariant abc_extra317.MutableSet.name:
  description: "collections.abc.MutableSet.__name__ == 'MutableSet'"
  category: abc_mutable_set
  kind: python_call_eq
  backend: python_module(collections.abc)
  function: MutableSet.__name__.__eq__
  args: ["MutableSet"]
  expected: true

invariant abc_extra317.MutableSet.module:
  description: "collections.abc.MutableSet.__module__ == 'collections.abc'"
  category: abc_mutable_set
  kind: python_call_eq
  backend: python_module(collections.abc)
  function: MutableSet.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra317.MutableSet.base:
  description: "collections.abc.MutableSet.__bases__[0].__name__ == 'Set'"
  category: abc_mutable_set
  kind: python_call_eq
  backend: python_module(collections.abc)
  function: MutableSet.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Set"

# ---------------------------------------------------------------------------
# collections.abc.Awaitable — name and module
#
# collections.abc.Awaitable is the ABC for objects that can be used in
# await expressions. It inherits directly from object.
# ---------------------------------------------------------------------------

invariant abc_extra317.Awaitable.name:
  description: "collections.abc.Awaitable.__name__ == 'Awaitable'"
  category: abc_awaitable
  kind: python_call_eq
  backend: python_module(collections.abc)
  function: Awaitable.__name__.__eq__
  args: ["Awaitable"]
  expected: true

invariant abc_extra317.Awaitable.module:
  description: "collections.abc.Awaitable.__module__ == 'collections.abc'"
  category: abc_awaitable
  kind: python_call_eq
  backend: python_module(collections.abc)
  function: Awaitable.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra317.Awaitable.base:
  description: "collections.abc.Awaitable.__bases__[0].__name__ == 'object'"
  category: abc_awaitable
  kind: python_call_eq
  backend: python_module(collections.abc)
  function: Awaitable.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"
