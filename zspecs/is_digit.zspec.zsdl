spec: is_digit
version: ">=1.0.2"
backend: node(is-digit)

docs: https://www.npmjs.com/package/is-digit

provenance:
  derived_from:
    - "is-digit README — https://www.npmjs.com/package/is-digit"
    - "Test vectors verified with is-digit via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "is-digit source"
  notes:
    - "is-digit is an npm package. Install: npm install is-digit"
    - "Returns true if the single character is a decimal digit (0-9). Multi-character strings return false."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_digit.check:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: isdig

  columns: [id, args, expected]
  rows:
    - [one,    ["1"], true]
    - [zero,   ["0"], true]
    - [letter, ["a"], false]
    - [multi,  ["12"], false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:24:41Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
