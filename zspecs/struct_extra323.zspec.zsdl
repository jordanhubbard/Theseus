spec: struct_extra323
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# calcsize — network byte order (!) and special format characters
# '!' is an alias for '>' (big-endian, network byte order per RFC 1700).
# All sizes are platform-independent for these format characters.
# ---------------------------------------------------------------------------

# Network byte-order (!) format characters: I, H, B

table struct_extra323.calcsize.network_order:
  description: "calcsize with '!' (network byte order) prefix — equivalent to '>' big-endian"
  kind: python_call_eq
  category: calcsize
  function: calcsize
  id_prefix: calcsize_net

  columns: [id, args, expected]
  rows:
    - [bang_I, ["!I"], 4]
    - [bang_H, ["!H"], 2]
    - [bang_B, ["!B"], 1]

# Special single-character format strings (no byte-order prefix = native, but all 1 byte)

table struct_extra323.calcsize.special_chars:
  description: "calcsize for special format characters: c (char), ? (bool), x (pad byte)"
  kind: python_call_eq
  category: calcsize
  function: calcsize
  id_prefix: calcsize_special

  columns: [id, args, expected]
  rows:
    - [c_char,    ["c"],  1]
    - [q_bool,    ["?"],  1]
    - [x_pad,     ["x"],  1]
    - [2x_pad,    ["2x"], 2]

# Multi-element formats with big-endian prefix

invariant struct_extra323.calcsize.big_endian_3I:
  description: "struct.calcsize('>3I') == 12 — three unsigned 32-bit ints, 3 × 4 = 12 bytes"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: [">3I"]
  expected: 12
