spec: abc_extra252
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "collections.abc.Mapping.__name__ == 'Mapping' (len=7); __module__ == 'collections.abc' (len=15); __bases__[0].__name__ == 'Collection' (len=10)."
    - "collections.abc.Mapping.__abstractmethods__ == frozenset(['__getitem__', '__iter__', '__len__']) — 3 abstract methods."
    - "collections.abc.MutableMapping.__name__ == 'MutableMapping' (len=14); __bases__[0].__name__ == 'Mapping' (len=7)."
    - "collections.abc.MutableMapping.__abstractmethods__ == frozenset(['__delitem__', '__getitem__', '__iter__', '__len__', '__setitem__']) — 5 abstract methods."
    - "collections.abc.Sequence.__name__ == 'Sequence' (len=8); __bases__[0].__name__ == 'Reversible' (len=10)."
    - "collections.abc.Sequence.__abstractmethods__ == frozenset(['__getitem__', '__len__']) — 2 abstract methods (most minimal of the four)."
    - "collections.abc.MutableSequence.__name__ == 'MutableSequence' (len=15); __bases__[0].__name__ == 'Sequence' (len=8)."
    - "collections.abc.MutableSequence.__abstractmethods__ == frozenset(['__delitem__', '__getitem__', '__len__', '__setitem__', 'insert']) — 5 abstract methods including 'insert' (the only non-dunder)."
    - "All four classes share __module__ == 'collections.abc' (len=15). Mapping(len=7) < Sequence(len=8) < MutableMapping(len=14) < MutableSequence(len=15)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

