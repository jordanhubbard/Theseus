# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra252
# ---------------------------------------------------------------------------

invariant abc_extra252.sequence_has_fewest_abstract_methods:
  description: "collections.abc.Sequence.__abstractmethods__.__len__() == 2 — Sequence requires only __getitem__ and __len__ to be overridden; MutableSequence, Mapping, and MutableMapping all require 5, 3, and 5 abstract methods respectively; Sequence's 2-method requirement is the most minimal contract among all four ABCs in this spec; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Sequence.__abstractmethods__.__len__
  args: []
  expected: 2

invariant abc_extra252.mutable_sequence_insert_is_non_dunder:
  description: "collections.abc.MutableSequence.__abstractmethods__.__contains__('insert') returns True — 'insert' is the sole non-dunder abstract method in MutableSequence's frozenset of 5 abstract methods; all other abstract methods across Mapping, MutableMapping, Sequence, and MutableSequence are dunder methods (__getitem__, __setitem__, __delitem__, __iter__, __len__); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: MutableSequence.__abstractmethods__.__contains__
  args: ["insert"]
  expected: true
