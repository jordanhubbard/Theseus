spec: urllib_robotparser_extra2
version: ">=3.0"
backend: python_module(urllib.robotparser)

docs: https://docs.python.org/3/library/urllib.robotparser.html

provenance:
  derived_from:
    - "Python urllib.robotparser documentation — https://docs.python.org/3/library/urllib.robotparser.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/robotparser.py"
    - "urllib_robotparser.zspec.zsdl — covers RobotFileParser.__name__, __module__, method names (set_url/read/parse/can_fetch/crawl_delay/request_rate), initial url/disallow_all/allow_all/entries/default_entry, set_url returns None, crawl_delay/request_rate return None"
  notes:
    - "This spec extends urllib_robotparser.zspec.zsdl with axes not yet covered."
    - "RobotFileParser.__qualname__ == 'RobotFileParser' — top-level class, qualname equals name."
    - "RobotFileParser.__class__.__name__ == 'type' — it is a class object."
    - "RobotFileParser.__bases__[0].__name__ == 'object' — no special base class."
    - "Method __qualname__ values follow the pattern 'RobotFileParser.method_name'."
    - "RobotFileParser().mtime() == 0 — initial modification time (Unix epoch)."
    - "RobotFileParser().modified() returns None — sets last_checked but has no return value."
    - "RobotFileParser().last_checked is 0 initially (before modified() is called)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# RobotFileParser.__qualname__ — top-level class, qualname equals name
# (urllib_robotparser.zspec.zsdl covers __name__ and __module__ only)
# ---------------------------------------------------------------------------

invariant urllib_robotparser_extra2.class_qualname:
  description: "urllib.robotparser.RobotFileParser.__qualname__ == 'RobotFileParser'"
  category: identity
  kind: python_call_eq
  function: RobotFileParser.__qualname__.__eq__
  args: ["RobotFileParser"]
  expected: true

# ---------------------------------------------------------------------------
# RobotFileParser.__class__.__name__ — it is a class object (type)
# (not in any prior spec)
# ---------------------------------------------------------------------------

invariant urllib_robotparser_extra2.class_is_type:
  description: "urllib.robotparser.RobotFileParser.__class__.__name__ == 'type'"
  category: identity
  kind: python_call_eq
  function: RobotFileParser.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# RobotFileParser base class — object
# (not in any prior spec)
# ---------------------------------------------------------------------------

invariant urllib_robotparser_extra2.base_is_object:
  description: "urllib.robotparser.RobotFileParser.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: RobotFileParser.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Method __qualname__ checks — all public methods
# (urllib_robotparser.zspec.zsdl covers __name__ only; __qualname__ is new)
# ---------------------------------------------------------------------------

table urllib_robotparser_extra2.method_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: mqname

  columns: [id, function, args, expected]
  rows:
    - [set_url,      RobotFileParser.set_url.__qualname__.__eq__,      ["RobotFileParser.set_url"],      true]
    - [read,         RobotFileParser.read.__qualname__.__eq__,         ["RobotFileParser.read"],         true]
    - [parse,        RobotFileParser.parse.__qualname__.__eq__,        ["RobotFileParser.parse"],        true]
    - [can_fetch,    RobotFileParser.can_fetch.__qualname__.__eq__,    ["RobotFileParser.can_fetch"],    true]
    - [crawl_delay,  RobotFileParser.crawl_delay.__qualname__.__eq__,  ["RobotFileParser.crawl_delay"],  true]
    - [request_rate, RobotFileParser.request_rate.__qualname__.__eq__, ["RobotFileParser.request_rate"], true]
    - [mtime,        RobotFileParser.mtime.__qualname__.__eq__,        ["RobotFileParser.mtime"],        true]
    - [modified,     RobotFileParser.modified.__qualname__.__eq__,     ["RobotFileParser.modified"],     true]

# ---------------------------------------------------------------------------
# mtime() — returns 0 before read() or modified() is called
# (not in any prior spec)
# ---------------------------------------------------------------------------

invariant urllib_robotparser_extra2.initial_mtime:
  description: "RobotFileParser().mtime() == 0 — initial modification time is Unix epoch"
  category: behavior
  kind: python_call_eq
  function: RobotFileParser
  args: []
  method: mtime
  method_args: []
  expected: 0

# ---------------------------------------------------------------------------
# modified() — returns None (it sets last_checked but returns nothing)
# (not in any prior spec)
# ---------------------------------------------------------------------------

invariant urllib_robotparser_extra2.modified_returns_none:
  description: "RobotFileParser().modified() == None"
  category: behavior
  kind: python_call_eq
  function: RobotFileParser
  args: []
  method: modified
  method_args: []
  expected: null

