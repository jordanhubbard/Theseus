spec: xmlrpc_client_extra
version: ">=3.9"
backend: python_module(xmlrpc.client)

docs: https://docs.python.org/3/library/xmlrpc.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xmlrpc.client.html — Python xmlrpc.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xmlrpc/client.py"
  notes:
    - "Extends xmlrpc_client.zspec.zsdl."
    - "xmlrpc_client.zspec.zsdl covers: class __name__ table (ServerProxy, Fault, ProtocolError, MultiCall, Binary, DateTime, ResponseError, Unmarshaller, Marshaller), Fault.__bases__[0].__name__=='Error', ProtocolError.__bases__[0].__name__=='Error', loads/__name__, dumps/__name__, type checks for ServerProxy/Fault/ProtocolError/Binary/DateTime, Binary.data roundtrip, Fault.faultCode/faultString, dumps returns str."
    - "This spec adds: ServerProxy.__module__, Fault.__name__ and __module__, ProtocolError.__name__, Binary.__name__, DateTime.__name__, Error.__name__, Error.__bases__[0].__name__=='Exception', Error.__module__, individual invariant cross-checks not already in the base spec."
    - "xmlrpc.client.ServerProxy.__module__ == 'xmlrpc.client'."
    - "xmlrpc.client.Error is the root exception; all xmlrpc.client exceptions inherit from it."
    - "xmlrpc.client.Error.__bases__[0].__name__ == 'Exception' — Error directly subclasses Exception."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — ServerProxy, Fault, ProtocolError, Binary, DateTime, Error
# ---------------------------------------------------------------------------

invariant xmlrpc_client_extra.ServerProxy.name:
  description: "xmlrpc.client.ServerProxy.__name__ == 'ServerProxy'"
  category: class_names
  kind: python_call_eq
  function: ServerProxy.__name__.__eq__
  args: ["ServerProxy"]
  expected: true

invariant xmlrpc_client_extra.Fault.name:
  description: "xmlrpc.client.Fault.__name__ == 'Fault'"
  category: class_names
  kind: python_call_eq
  function: Fault.__name__.__eq__
  args: ["Fault"]
  expected: true

invariant xmlrpc_client_extra.ProtocolError.name:
  description: "xmlrpc.client.ProtocolError.__name__ == 'ProtocolError'"
  category: class_names
  kind: python_call_eq
  function: ProtocolError.__name__.__eq__
  args: ["ProtocolError"]
  expected: true

invariant xmlrpc_client_extra.Binary.name:
  description: "xmlrpc.client.Binary.__name__ == 'Binary'"
  category: class_names
  kind: python_call_eq
  function: Binary.__name__.__eq__
  args: ["Binary"]
  expected: true

invariant xmlrpc_client_extra.DateTime.name:
  description: "xmlrpc.client.DateTime.__name__ == 'DateTime'"
  category: class_names
  kind: python_call_eq
  function: DateTime.__name__.__eq__
  args: ["DateTime"]
  expected: true

invariant xmlrpc_client_extra.Error.name:
  description: "xmlrpc.client.Error.__name__ == 'Error'"
  category: class_names
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# Module checks — ServerProxy and Error live in xmlrpc.client
# ---------------------------------------------------------------------------

invariant xmlrpc_client_extra.ServerProxy.module:
  description: "xmlrpc.client.ServerProxy.__module__ == 'xmlrpc.client'"
  category: modules
  kind: python_call_eq
  function: ServerProxy.__module__.__eq__
  args: ["xmlrpc.client"]
  expected: true

invariant xmlrpc_client_extra.Error.module:
  description: "xmlrpc.client.Error.__module__ == 'xmlrpc.client'"
  category: modules
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["xmlrpc.client"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — Error inherits from Exception
# ---------------------------------------------------------------------------

invariant xmlrpc_client_extra.Error.base_is_Exception:
  description: "xmlrpc.client.Error.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Exception hierarchy — Fault and ProtocolError both inherit from Error
# ---------------------------------------------------------------------------

invariant xmlrpc_client_extra.Fault.base_is_Error:
  description: "xmlrpc.client.Fault.__bases__[0].__name__ == 'Error'"
  category: hierarchy
  kind: python_call_eq
  function: Fault.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"

invariant xmlrpc_client_extra.ProtocolError.base_is_Error:
  description: "xmlrpc.client.ProtocolError.__bases__[0].__name__ == 'Error'"
  category: hierarchy
  kind: python_call_eq
  function: ProtocolError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"

# ---------------------------------------------------------------------------
# Type identity checks — key classes are proper types
# ---------------------------------------------------------------------------

invariant xmlrpc_client_extra.ServerProxy.is_type:
  description: "xmlrpc.client.ServerProxy.__class__.__name__ == 'type'"
  category: type_identity
  kind: python_call_eq
  function: ServerProxy.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant xmlrpc_client_extra.Fault.is_type:
  description: "xmlrpc.client.Fault.__class__.__name__ == 'type'"
  category: type_identity
  kind: python_call_eq
  function: Fault.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant xmlrpc_client_extra.Error.is_type:
  description: "xmlrpc.client.Error.__class__.__name__ == 'type'"
  category: type_identity
  kind: python_call_eq
  function: Error.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant xmlrpc_client_extra.Binary.is_type:
  description: "xmlrpc.client.Binary.__class__.__name__ == 'type'"
  category: type_identity
  kind: python_call_eq
  function: Binary.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant xmlrpc_client_extra.DateTime.is_type:
  description: "xmlrpc.client.DateTime.__class__.__name__ == 'type'"
  category: type_identity
  kind: python_call_eq
  function: DateTime.__class__.__name__.__eq__
  args: ["type"]
  expected: true
