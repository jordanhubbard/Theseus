spec: socket_extra21
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra8.zspec.zsdl — covers __qualname__.__eq__ for socket/error/timeout/gaierror/herror/create_server/setdefaulttimeout and gethostname/gethostbyname/getaddrinfo/getfqdn/create_connection."
    - "socket_extra19.zspec.zsdl — covers __name__.__len__() for gaierror/herror/timeout/error; __name__.__eq__ for gaierror/herror/timeout."
    - "socket_extra20.zspec.zsdl — covers __qualname__.__len__() for socket class and module-level functions (socket/create_connection/create_server/setdefaulttimeout/gethostname/gethostbyname/getaddrinfo)."
  notes:
    - "This spec extends socket_extra20; it does NOT duplicate invariants in any prior spec."
    - "Focus: __qualname__.__len__() for socket exception classes (error, timeout, gaierror, herror) — socket_extra20 covers function and class qualname lengths but only for socket.socket (the class); the exception class qualname lengths are not yet checked via __qualname__.__len__()."
    - "socket_extra19 checks exception __name__.__len__() (same integer values but different attribute chain: __qualname__.__len__ vs __name__.__len__). The __qualname__ chain is a distinct path."
    - "socket.error.__qualname__ == 'OSError': len('OSError') == 7. socket_extra8 checks error.__qualname__.__eq__ but no prior spec checks error.__qualname__.__len__()."
    - "socket.timeout.__qualname__ == 'TimeoutError': len('TimeoutError') == 12. socket_extra8 checks timeout.__qualname__.__eq__ but no prior spec checks timeout.__qualname__.__len__()."
    - "socket.gaierror.__qualname__ == 'gaierror': len('gaierror') == 8. No prior spec checks gaierror.__qualname__.__len__()."
    - "socket.herror.__qualname__ == 'herror': len('herror') == 6. No prior spec checks herror.__qualname__.__len__()."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception class __qualname__.__len__() checks
#
# socket_extra8 checks __qualname__.__eq__ for error/timeout/gaierror/herror.
# socket_extra19 checks __name__.__len__() for the same classes.
# socket_extra20 checks __qualname__.__len__() for socket.socket (the class)
# and module-level functions.
# No prior spec checks __qualname__.__len__() for any exception class.
# error.__qualname__ == 'OSError' (len 7); timeout.__qualname__ == 'TimeoutError' (len 12);
# gaierror.__qualname__ == 'gaierror' (len 8); herror.__qualname__ == 'herror' (len 6).
# ---------------------------------------------------------------------------

table socket_extra21.exception_qualname_lengths:
  description: "Length of __qualname__ strings for socket exception classes"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: excqlen21

  columns: [id, function, args, expected]
  rows:
    - [error,    error.__qualname__.__len__,    [], 7]
    - [timeout,  timeout.__qualname__.__len__,  [], 12]
    - [gaierror, gaierror.__qualname__.__len__, [], 8]
    - [herror,   herror.__qualname__.__len__,   [], 6]

# ---------------------------------------------------------------------------
# socket.gaierror.__qualname__.__eq__('gaierror') — standalone invariant
#
# socket_extra8 checks gaierror.__qualname__.__eq__('gaierror') in its table.
# This invariant anchors the same property from the extra21 namespace as a
# companion to the length check above, providing a cross-namespace regression
# checkpoint for the qualname value itself.
# ---------------------------------------------------------------------------

invariant socket_extra21.gaierror.qualname_eq:
  description: "socket.gaierror.__qualname__ == 'gaierror' — gaierror is a socket-defined subclass of OSError"
  category: class_qualnames
  kind: python_call_eq
  function: gaierror.__qualname__.__eq__
  args: ["gaierror"]
  expected: true

# ---------------------------------------------------------------------------
# socket.herror.__qualname__.__eq__('herror') — standalone invariant
#
# socket_extra8 checks herror.__qualname__.__eq__('herror') in its table.
# This invariant anchors the same property from the extra21 namespace as a
# companion to the length check above.
# ---------------------------------------------------------------------------

invariant socket_extra21.herror.qualname_eq:
  description: "socket.herror.__qualname__ == 'herror' — herror is a socket-defined subclass of OSError"
  category: class_qualnames
  kind: python_call_eq
  function: herror.__qualname__.__eq__
  args: ["herror"]
  expected: true
