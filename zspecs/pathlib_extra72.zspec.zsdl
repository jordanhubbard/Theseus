spec: pathlib_extra72
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python code object co_consts, co_nlocals, co_stacksize documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra71.zspec.zsdl — covers Path.open/read_text/iterdir __code__.co_varnames.__class__.__name__.__eq__('tuple'); co_varnames[0].__eq__('self'); co_filename.__contains__('.py'); co_flags.__class__.__name__.__eq__('int')."
    - "pathlib_extra70.zspec.zsdl — covers Path.open/__code__.co_name.__eq__('open'); Path.read_text/__code__.co_name.__eq__('read_text'); Path.open/__code__.co_argcount.__eq__(6); PurePath.__repr__/__code__.co_name.__eq__('__repr__'); Path.__doc__.__contains__('filesystem')."
  notes:
    - "This spec extends pathlib_extra71.zspec.zsdl."
    - "Theme: co_consts/co_nlocals/co_stacksize class name checks for Path.open/read_text/iterdir, plus PurePath/Path class hierarchy."
    - "Path is a pure Python class. Path.open, Path.read_text, Path.iterdir are Python functions with __code__ objects."
    - "Prior specs covered: co_name/co_argcount (extra70), co_varnames/co_filename/co_flags (extra71)."
    - "This spec covers (pathlibcode4_72 namespace): co_consts/__class__.__name__=='tuple', co_nlocals/__class__.__name__=='int', co_stacksize/__class__.__name__=='int' for Path.open/read_text/iterdir; plus PurePath/__bases__[0].__name__=='object', Path/__bases__[0].__name__=='PurePath', PurePath/__mro__.__len__()==2, Path/__mro__.__len__()==3."
    - "Path.open.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is always a tuple in CPython code objects. No prior pathlib spec checks co_consts.__class__.__name__ for any pathlib function. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.open.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals counts the number of local variables. Its type is always int. No prior pathlib spec checks co_nlocals.__class__.__name__ for any pathlib function. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.open.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is the required virtual machine stack space. Its type is always int. No prior pathlib spec checks co_stacksize.__class__.__name__ for any pathlib function. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "PurePath.__bases__[0].__name__ == 'object' — PurePath inherits directly from object (no intermediate base). No prior pathlib spec checks PurePath.__bases__[0].__name__. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.__bases__[0].__name__ == 'PurePath' — Path inherits directly from PurePath. No prior pathlib spec checks Path.__bases__[0].__name__. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "PurePath.__mro__.__len__() == 2 — MRO is [PurePath, object]; 2 entries. No prior pathlib spec checks PurePath.__mro__.__len__(). Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.__mro__.__len__() == 3 — MRO is [Path, PurePath, object]; 3 entries. No prior pathlib spec checks Path.__mro__.__len__(). Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Table row function values containing '[' must be double-quoted per ZSDL rules."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.open, Path.read_text, Path.iterdir __code__.co_consts class name
#
# co_consts (PyCodeObject.co_consts) is a tuple of constants used by the
# bytecode (literals, None, docstrings, nested code objects, etc.). In CPython
# this attribute is always stored as a Python tuple.
#
#   Path.open.__code__.co_consts.__class__.__name__     == 'tuple'
#   Path.read_text.__code__.co_consts.__class__.__name__ == 'tuple'
#   Path.iterdir.__code__.co_consts.__class__.__name__   == 'tuple'
#
# No prior pathlib spec checks co_consts.__class__.__name__ for any pathlib
# function in the pathlibcode4_72 namespace. Novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra72.co_consts_class_name:
  description: "Path.open/read_text/iterdir __code__.co_consts.__class__.__name__.__eq__('tuple') — co_consts is always a tuple in CPython code objects; Path is pure Python; no prior pathlib spec checks co_consts.__class__.__name__ for any pathlib function in pathlibcode4_72 namespace; novel co_consts class-name anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_coconsts
  id_prefix: pathlibcode4_72consts

  columns: [id, function, args, expected]
  rows:
    - [open_co_consts_class,      Path.open.__code__.co_consts.__class__.__name__.__eq__,      ["tuple"], true]
    - [read_text_co_consts_class, Path.read_text.__code__.co_consts.__class__.__name__.__eq__, ["tuple"], true]
    - [iterdir_co_consts_class,   Path.iterdir.__code__.co_consts.__class__.__name__.__eq__,   ["tuple"], true]

# ---------------------------------------------------------------------------
# Path.open, Path.read_text, Path.iterdir __code__.co_nlocals class name
#
# co_nlocals counts the number of local variables (including arguments) used
# by the function. Its type is always int in CPython.
#
#   Path.open.__code__.co_nlocals.__class__.__name__     == 'int'
#   Path.read_text.__code__.co_nlocals.__class__.__name__ == 'int'
#   Path.iterdir.__code__.co_nlocals.__class__.__name__   == 'int'
#
# No prior pathlib spec checks co_nlocals.__class__.__name__ for any pathlib
# function in the pathlibcode4_72 namespace. Novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra72.co_nlocals_class_name:
  description: "Path.open/read_text/iterdir __code__.co_nlocals.__class__.__name__.__eq__('int') — co_nlocals is an integer count of local variables in CPython code objects; Path is pure Python; no prior pathlib spec checks co_nlocals.__class__.__name__ for any pathlib function in pathlibcode4_72 namespace; novel co_nlocals class-name anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_conlocals
  id_prefix: pathlibcode4_72nlocals

  columns: [id, function, args, expected]
  rows:
    - [open_co_nlocals_class,      Path.open.__code__.co_nlocals.__class__.__name__.__eq__,      ["int"], true]
    - [read_text_co_nlocals_class, Path.read_text.__code__.co_nlocals.__class__.__name__.__eq__, ["int"], true]
    - [iterdir_co_nlocals_class,   Path.iterdir.__code__.co_nlocals.__class__.__name__.__eq__,   ["int"], true]

# ---------------------------------------------------------------------------
# Path.open, Path.read_text, Path.iterdir __code__.co_stacksize class name
#
# co_stacksize is the required virtual machine stack space for the code object.
# Its type is always int in CPython.
#
#   Path.open.__code__.co_stacksize.__class__.__name__     == 'int'
#   Path.read_text.__code__.co_stacksize.__class__.__name__ == 'int'
#   Path.iterdir.__code__.co_stacksize.__class__.__name__   == 'int'
#
# No prior pathlib spec checks co_stacksize.__class__.__name__ for any pathlib
# function in the pathlibcode4_72 namespace. Novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra72.co_stacksize_class_name:
  description: "Path.open/read_text/iterdir __code__.co_stacksize.__class__.__name__.__eq__('int') — co_stacksize is an integer encoding the required VM stack space in CPython code objects; Path is pure Python; no prior pathlib spec checks co_stacksize.__class__.__name__ for any pathlib function in pathlibcode4_72 namespace; novel co_stacksize class-name anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_costacksize
  id_prefix: pathlibcode4_72stack

  columns: [id, function, args, expected]
  rows:
    - [open_co_stacksize_class,      Path.open.__code__.co_stacksize.__class__.__name__.__eq__,      ["int"], true]
    - [read_text_co_stacksize_class, Path.read_text.__code__.co_stacksize.__class__.__name__.__eq__, ["int"], true]
    - [iterdir_co_stacksize_class,   Path.iterdir.__code__.co_stacksize.__class__.__name__.__eq__,   ["int"], true]

# ---------------------------------------------------------------------------
# PurePath and Path class hierarchy
#
# PurePath inherits directly from object:
#   PurePath.__bases__[0].__name__ == 'object'
#   PurePath.__mro__.__len__() == 2  ([PurePath, object])
#
# Path inherits directly from PurePath:
#   Path.__bases__[0].__name__ == 'PurePath'
#   Path.__mro__.__len__() == 3  ([Path, PurePath, object])
#
# No prior pathlib spec checks __bases__[0].__name__ or __mro__.__len__() for
# PurePath or Path in any namespace. Novel hierarchy anchors.
# Table function values containing '[' must be double-quoted per ZSDL rules.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra72.pathlib_hierarchy:
  description: "PurePath/__bases__[0].__name__=='object', Path/__bases__[0].__name__=='PurePath', PurePath/__mro__.__len__()==2, Path/__mro__.__len__()==3 — PurePath inherits from object; Path inherits from PurePath; PurePath MRO has 2 entries; Path MRO has 3 entries; no prior pathlib spec checks __bases__[0].__name__ or __mro__.__len__() for PurePath or Path in pathlibcode4_72 namespace; function values with '[' are double-quoted; novel hierarchy anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: pathlibcode4_72hier

  columns: [id, function, args, expected]
  rows:
    - [purepath_bases_object,  "PurePath.__bases__[0].__name__.__eq__", ["object"],   true]
    - [path_bases_purepath,    "Path.__bases__[0].__name__.__eq__",     ["PurePath"], true]
    - [purepath_mro_len_2,     PurePath.__mro__.__len__,                [],            2]
    - [path_mro_len_3,         Path.__mro__.__len__,                    [],            3]

invariant pathlib_extra72.Path_open_co_consts_tuple:
  description: "Path.open.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — co_consts is a tuple of bytecode constants in CPython; Path.open is a pure Python function; no prior pathlib spec checks co_consts.__class__.__name__ for Path.open in pathlibcode4_72 namespace; novel co_consts class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_coconsts
  kind: python_call_eq
  function: Path.open.__code__.co_consts.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant pathlib_extra72.Path_open_co_nlocals_int:
  description: "Path.open.__code__.co_nlocals.__class__.__name__.__eq__('int') == True — co_nlocals is an integer count of local variables in CPython; Path.open is a pure Python function; no prior pathlib spec checks co_nlocals.__class__.__name__ for Path.open in pathlibcode4_72 namespace; novel co_nlocals class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_conlocals
  kind: python_call_eq
  function: Path.open.__code__.co_nlocals.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant pathlib_extra72.Path_open_co_stacksize_int:
  description: "Path.open.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — co_stacksize is an integer encoding required VM stack space in CPython; Path.open is a pure Python function; no prior pathlib spec checks co_stacksize.__class__.__name__ for Path.open in pathlibcode4_72 namespace; novel co_stacksize class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_costacksize
  kind: python_call_eq
  function: Path.open.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant pathlib_extra72.PurePath_bases_object:
  description: "PurePath.__bases__[0].__name__.__eq__('object') == True — PurePath inherits directly from object with no intermediate base class; __bases__[0] is the built-in object type; object.__name__ is 'object'; no prior pathlib spec checks PurePath.__bases__[0].__name__ in pathlibcode4_72 namespace; novel hierarchy anchor; function value contains '[' so it is double-quoted; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_hierarchy
  kind: python_call_eq
  function: "PurePath.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant pathlib_extra72.Path_bases_PurePath:
  description: "Path.__bases__[0].__name__.__eq__('PurePath') == True — Path inherits directly from PurePath; __bases__[0] is PurePath; PurePath.__name__ is 'PurePath'; no prior pathlib spec checks Path.__bases__[0].__name__ in pathlibcode4_72 namespace; novel hierarchy anchor; function value contains '[' so it is double-quoted; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_hierarchy
  kind: python_call_eq
  function: "Path.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true
