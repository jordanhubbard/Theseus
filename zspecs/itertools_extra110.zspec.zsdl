# ---------------------------------------------------------------------------
# Table 1: itertools C-extension type __init__ method type names — group 1
#
# Wave 262 theme: all itertools C-extension types are defined without a custom
# tp_init slot, so they inherit __init__ from object. The inherited __init__
# is a 'wrapper_descriptor' (the C slot wrapper for object.__init__). This
# contrasts with their __new__ allocators which are 'builtin_function_or_method'.
# This table covers count, cycle, repeat, chain, compress, islice, starmap.
#
# type(itertools.count.__init__).__name__ == 'wrapper_descriptor'
# type(itertools.cycle.__init__).__name__ == 'wrapper_descriptor'
# type(itertools.repeat.__init__).__name__ == 'wrapper_descriptor'
# type(itertools.chain.__init__).__name__ == 'wrapper_descriptor'
# type(itertools.compress.__init__).__name__ == 'wrapper_descriptor'
# type(itertools.islice.__init__).__name__ == 'wrapper_descriptor'
# type(itertools.starmap.__init__).__name__ == 'wrapper_descriptor'
#
# New to extra110.
# ---------------------------------------------------------------------------

table itertools_extra110.init_type_group1:
  description: "itertools C-extension type __init__ type is 'wrapper_descriptor' (inherited from object) for count/cycle/repeat/chain/compress/islice/starmap; wave 262; new to extra110"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertoolsinit110

  columns: [id, function, args, expected, description]
  rows:
    - [count_init_type_wrapper,
       "count.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.count.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.count is a C-extension type that does not define a custom tp_init slot; it inherits __init__ from object; the inherited __init__ is exposed as a 'wrapper_descriptor' (a C slot wrapper); str.__eq__('wrapper_descriptor') returns True; new to extra110"]
    - [cycle_init_type_wrapper,
       "cycle.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.cycle.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.cycle is a C-extension type without a custom tp_init; it inherits object.__init__ as a 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra110"]
    - [repeat_init_type_wrapper,
       "repeat.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.repeat.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.repeat is a C-extension type without a custom tp_init; it inherits object.__init__ as a 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra110"]
    - [chain_init_type_wrapper,
       "chain.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.chain.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.chain is a C-extension type without a custom tp_init; it inherits object.__init__ as a 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra110"]
    - [compress_init_type_wrapper,
       "compress.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.compress.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.compress is a C-extension type without a custom tp_init; it inherits object.__init__ as a 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra110"]
    - [islice_init_type_wrapper,
       "islice.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.islice.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.islice is a C-extension type without a custom tp_init; it inherits object.__init__ as a 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra110"]
    - [starmap_init_type_wrapper,
       "starmap.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.starmap.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.starmap is a C-extension type without a custom tp_init; it inherits object.__init__ as a 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra110"]

# ---------------------------------------------------------------------------
# Table 2: itertools C-extension type __init__ method type names — group 2
#
# Wave 262 theme: continued verification that all itertools C-extension types
# inherit __init__ from object as a 'wrapper_descriptor'. This table covers
# product, permutations, combinations, combinations_with_replacement,
# accumulate, groupby, zip_longest, filterfalse, pairwise.
#
# type(itertools.product.__init__).__name__ == 'wrapper_descriptor'
# type(itertools.permutations.__init__).__name__ == 'wrapper_descriptor'
# type(itertools.combinations.__init__).__name__ == 'wrapper_descriptor'
# type(itertools.combinations_with_replacement.__init__).__name__ == 'wrapper_descriptor'
# type(itertools.accumulate.__init__).__name__ == 'wrapper_descriptor'
# type(itertools.groupby.__init__).__name__ == 'wrapper_descriptor'
# type(itertools.zip_longest.__init__).__name__ == 'wrapper_descriptor'
# type(itertools.filterfalse.__init__).__name__ == 'wrapper_descriptor'
# type(itertools.pairwise.__init__).__name__ == 'wrapper_descriptor'
#
# New to extra110.
# ---------------------------------------------------------------------------

table itertools_extra110.init_type_group2:
  description: "itertools C-extension type __init__ type is 'wrapper_descriptor' for product/permutations/combinations/combinations_with_replacement/accumulate/groupby/zip_longest/filterfalse/pairwise; wave 262; new to extra110"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertoolsinit2110

  columns: [id, function, args, expected, description]
  rows:
    - [product_init_type_wrapper,
       "product.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.product.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.product is a C-extension type without a custom tp_init; it inherits object.__init__ as a 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra110"]
    - [permutations_init_type_wrapper,
       "permutations.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.permutations.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.permutations is a C-extension type without a custom tp_init; it inherits object.__init__ as a 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra110"]
    - [combinations_init_type_wrapper,
       "combinations.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.combinations.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.combinations is a C-extension type without a custom tp_init; it inherits object.__init__ as a 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra110"]
    - [combinations_wr_init_type_wrapper,
       "combinations_with_replacement.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.combinations_with_replacement.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.combinations_with_replacement is a C-extension type without a custom tp_init; it inherits object.__init__ as a 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra110"]
    - [accumulate_init_type_wrapper,
       "accumulate.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.accumulate.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.accumulate is a C-extension type without a custom tp_init; it inherits object.__init__ as a 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra110"]
    - [groupby_init_type_wrapper,
       "groupby.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.groupby.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.groupby is a C-extension type without a custom tp_init; it inherits object.__init__ as a 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra110"]
    - [zip_longest_init_type_wrapper,
       "zip_longest.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.zip_longest.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.zip_longest is a C-extension type without a custom tp_init; it inherits object.__init__ as a 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra110"]
    - [filterfalse_init_type_wrapper,
       "filterfalse.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.filterfalse.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.filterfalse is a C-extension type without a custom tp_init; it inherits object.__init__ as a 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra110"]
    - [pairwise_init_type_wrapper,
       "pairwise.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.pairwise.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.pairwise is a C-extension type (added in Python 3.10) without a custom tp_init; it inherits object.__init__ as a 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra110"]

# ---------------------------------------------------------------------------
# Table 3: itertools C-extension type __init__ qualnames
#
# Wave 262 theme: since all itertools C-extension types inherit __init__ from
# object (the base type), they all share the same __init__ descriptor object
# (itertools.count.__init__ is itertools.cycle.__init__). The __qualname__ of
# this shared 'wrapper_descriptor' is 'object.__init__' — the standard qualname
# for the inherited slot wrapper. The length of 'object.__init__' is 15.
#
# itertools.count.__init__.__qualname__ == 'object.__init__'
# itertools.cycle.__init__.__qualname__ == 'object.__init__'
# itertools.product.__init__.__qualname__ == 'object.__init__'
# itertools.accumulate.__init__.__qualname__ == 'object.__init__'
# itertools.combinations_with_replacement.__init__.__qualname__ == 'object.__init__'
# len('object.__init__') == 15
#
# New to extra110.
# ---------------------------------------------------------------------------

table itertools_extra110.init_qualnames:
  description: "itertools C-extension type __init__ qualnames are all 'object.__init__' (inherited; len 15); count/cycle/product/accumulate/combinations_with_replacement shown; wave 262; new to extra110"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsiqn110

  columns: [id, function, args, expected, description]
  rows:
    - [count_init_qualname_eq,
       "count.__init__.__qualname__.__eq__",
       ["object.__init__"],
       true,
       "itertools.count.__init__.__qualname__.__eq__('object.__init__') == True — itertools.count inherits __init__ from object without overriding it; the inherited 'wrapper_descriptor' has __qualname__ 'object.__init__' indicating it belongs to the object class; str.__eq__('object.__init__') returns True; new to extra110"]
    - [cycle_init_qualname_eq,
       "cycle.__init__.__qualname__.__eq__",
       ["object.__init__"],
       true,
       "itertools.cycle.__init__.__qualname__.__eq__('object.__init__') == True — itertools.cycle inherits __init__ from object; the wrapper_descriptor has __qualname__ 'object.__init__'; str.__eq__('object.__init__') returns True; new to extra110"]
    - [product_init_qualname_eq,
       "product.__init__.__qualname__.__eq__",
       ["object.__init__"],
       true,
       "itertools.product.__init__.__qualname__.__eq__('object.__init__') == True — itertools.product inherits __init__ from object; the wrapper_descriptor has __qualname__ 'object.__init__'; str.__eq__('object.__init__') returns True; new to extra110"]
    - [accumulate_init_qualname_eq,
       "accumulate.__init__.__qualname__.__eq__",
       ["object.__init__"],
       true,
       "itertools.accumulate.__init__.__qualname__.__eq__('object.__init__') == True — itertools.accumulate inherits __init__ from object; the wrapper_descriptor has __qualname__ 'object.__init__'; str.__eq__('object.__init__') returns True; new to extra110"]
    - [combinations_wr_init_qualname_eq,
       "combinations_with_replacement.__init__.__qualname__.__eq__",
       ["object.__init__"],
       true,
       "itertools.combinations_with_replacement.__init__.__qualname__.__eq__('object.__init__') == True — itertools.combinations_with_replacement inherits __init__ from object; the wrapper_descriptor has __qualname__ 'object.__init__'; str.__eq__('object.__init__') returns True; new to extra110"]
    - [count_init_qualname_len_15,
       "count.__init__.__qualname__.__len__",
       [],
       15,
       "itertools.count.__init__.__qualname__.__len__() == 15 — 'object.__init__' has 15 characters: o-b-j-e-c-t-.-_-_-i-n-i-t-_-_; str.__len__() returns 15; int.__eq__(15) returns True; new to extra110"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra110
# ---------------------------------------------------------------------------

invariant itertools_extra110.count_init_type:
  description: "type(itertools.count.__init__).__name__ == 'wrapper_descriptor' — inherited from object; C types without tp_init use object.__init__; wave 262; new to extra110"
  kind: python_call_eq
  function: count.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant itertools_extra110.pairwise_init_type:
  description: "type(itertools.pairwise.__init__).__name__ == 'wrapper_descriptor' — pairwise (added 3.10) inherits object.__init__; wave 262; new to extra110"
  kind: python_call_eq
  function: pairwise.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant itertools_extra110.count_init_qualname:
  description: "itertools.count.__init__.__qualname__ == 'object.__init__' — shared wrapper_descriptor from object base class; wave 262; new to extra110"
  kind: python_call_eq
  function: count.__init__.__qualname__.__eq__
  args: ["object.__init__"]
  expected: true

invariant itertools_extra110.combinations_wr_init_type:
  description: "type(itertools.combinations_with_replacement.__init__).__name__ == 'wrapper_descriptor' — inherits object.__init__; wave 262; new to extra110"
  kind: python_call_eq
  function: combinations_with_replacement.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant itertools_extra110.init_qualname_len:
  description: "itertools.count.__init__.__qualname__.__len__() == 15 — 'object.__init__' is 15 chars; shared by all itertools C types; wave 262; new to extra110"
  kind: python_call_eq
  function: count.__init__.__qualname__.__len__
  args: []
  expected: 15
