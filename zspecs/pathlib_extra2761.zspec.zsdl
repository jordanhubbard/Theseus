spec: pathlib_extra2761
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers existing pathlib invariants"
    - "pathlib_extra2746.zspec.zsdl — covers __round__/__divmod__/__pow__ dict-presence"
    - "pathlib_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
    - "pathlib_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 631 (pathlib_extra2761) theme: __matmul__, __truediv__, and __iadd__ dict-presence checks."
    - "pathlib.PurePath defines __truediv__ in its own __dict__ — the / operator is used for path joining (e.g., PurePath('a') / 'b')."
    - "pathlib.PurePosixPath, pathlib.PureWindowsPath, and pathlib.Path inherit __truediv__ from PurePath and do NOT define it in their own __dict__."
    - "None of the pathlib classes define __matmul__ or __iadd__ in their own __dict__."
    - "__matmul__ supports the @ operator; pathlib path objects are filesystem path types, not matrix/numeric types."
    - "__iadd__ supports the += operator; pathlib path objects do not implement in-place addition semantics."
    - "Covers pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, and pathlib.Path."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __matmul__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2761.no_matmul_in_pathlib_classes:
  description: "__matmul__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the @ matrix-multiplication protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2761

  columns: [id, function, args, expected]
  rows:
    - ["pp2761001", "pathlib.PurePath.__dict__.__contains__",        ["__matmul__"], false]
    - ["pp2761002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__matmul__"], false]
    - ["pp2761003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__matmul__"], false]
    - ["pp2761004", "pathlib.Path.__dict__.__contains__",            ["__matmul__"], false]

# ---------------------------------------------------------------------------
# __truediv__ dict-presence — pathlib path classes
# PurePath defines __truediv__ for path joining; subclasses inherit and do not re-define it
# ---------------------------------------------------------------------------

table pathlib_extra2761.truediv_presence_in_pathlib_classes:
  description: "__truediv__ is defined in pathlib.PurePath __dict__ (path joining via / operator) but absent from PurePosixPath, PureWindowsPath, and Path own __dict__s (they inherit it)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2761

  columns: [id, function, args, expected]
  rows:
    - ["pp2761005", "pathlib.PurePath.__dict__.__contains__",        ["__truediv__"], true]
    - ["pp2761006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__truediv__"], false]
    - ["pp2761007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__truediv__"], false]
    - ["pp2761008", "pathlib.Path.__dict__.__contains__",            ["__truediv__"], false]

# ---------------------------------------------------------------------------
# __iadd__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2761.no_iadd_in_pathlib_classes:
  description: "__iadd__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the += in-place addition protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2761

  columns: [id, function, args, expected]
  rows:
    - ["pp2761009",  "pathlib.PurePath.__dict__.__contains__",        ["__iadd__"], false]
    - ["pp2761010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__iadd__"], false]
    - ["pp2761011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__iadd__"], false]
    - ["pp2761012", "pathlib.Path.__dict__.__contains__",            ["__iadd__"], false]

# ---------------------------------------------------------------------------
# Complementary: PurePath has __truediv__ for path joining but not __matmul__ or __iadd__
# Confirms the asymmetry: only / is meaningful for path objects, not @ or +=
# ---------------------------------------------------------------------------

table pathlib_extra2761.pathlib_truediv_but_not_matmul_or_iadd:
  description: "pathlib.PurePath defines __str__/__truediv__/__fspath__ but NOT __matmul__/__iadd__; pathlib.Path defines stat/exists/open but NOT __matmul__/__iadd__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2761

  columns: [id, function, args, expected]
  rows:
    - ["pp2761013", "pathlib.PurePath.__dict__.__contains__", ["__str__"],     true]
    - ["pp2761014", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"], true]
    - ["pp2761015", "pathlib.PurePath.__dict__.__contains__", ["__fspath__"],  true]
    - ["pp2761016", "pathlib.PurePath.__dict__.__contains__", ["__matmul__"],  false]
    - ["pp2761017", "pathlib.PurePath.__dict__.__contains__", ["__iadd__"],    false]
    - ["pp2761018", "pathlib.Path.__dict__.__contains__",     ["stat"],        true]
    - ["pp2761019", "pathlib.Path.__dict__.__contains__",     ["exists"],      true]
    - ["pp2761020", "pathlib.Path.__dict__.__contains__",     ["open"],        true]
    - ["pp2761021", "pathlib.Path.__dict__.__contains__",     ["__matmul__"],  false]
    - ["pp2761022", "pathlib.Path.__dict__.__contains__",     ["__truediv__"], false]
    - ["pp2761023", "pathlib.Path.__dict__.__contains__",     ["__iadd__"],    false]
