spec: signal_extra11
version: ">=3.9"
backend: python_module(signal)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/signal.html — Python signal module documentation"
    - "POSIX.1-2017 — The Open Group Base Specifications Issue 7, 2018 Edition"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
  notes:
    - "Extends signal.zspec.zsdl through signal_extra10.zspec.zsdl."
    - "signal_extra covers: SIG_DFL/SIG_IGN/SIGABRT/SIGFPE/SIGILL/SIGINT/SIGSEGV/SIGTERM __class__.__name__; SIGHUP/SIGKILL in signal_extra3."
    - "signal_extra2 covers: Signals/Handlers __name__/__bases__[0].__name__; SIG_DFL/SIG_IGN/SIGTERM/SIGINT __class__.__name__ standalone."
    - "signal_extra3 covers: SIGHUP/SIGKILL __class__.__name__."
    - "signal_extra4 covers: Signals.__qualname__.__eq__('Signals'); Handlers.__qualname__.__eq__('Handlers')."
    - "signal_extra10 covers: function __qualname__.__len__; Signals/Handlers __mro__ length and member names."
    - "This spec adds: __class__.__qualname__ for enum members SIGTERM/SIGHUP/SIGKILL (prior specs use __class__.__name__, not __class__.__qualname__); __class__.__qualname__ for SIG_DFL/SIG_IGN; Signals.__qualname__.__len__()==7; Handlers.__qualname__.__len__()==8. These are all distinct attribute chains from any prior invariant."
    - "signal.SIGTERM.__class__.__qualname__ == 'Signals' — __class__.__qualname__ is a distinct attribute from __class__.__name__; no prior signal spec accesses __qualname__ via the __class__ path on any signal member."
    - "signal.SIG_DFL.__class__.__qualname__ == 'Handlers' — same rationale; all prior SIG_DFL specs use __class__.__name__."
    - "signal.SIG_IGN.__class__.__qualname__ == 'Handlers' — same rationale."
    - "signal.Signals.__qualname__.__len__() == 7 — len('Signals') == 7. signal_extra4 checks __qualname__.__eq__; signal_extra10 checks function qualname lengths but NOT Signals/Handlers qualname lengths."
    - "signal.Handlers.__qualname__.__len__() == 8 — len('Handlers') == 8. Same gap as Signals.__qualname__.__len__()."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Signals enum member __class__.__qualname__ checks
#
# signal_extra, signal_extra2, and signal_extra3 check __class__.__name__ for
# SIGTERM, SIGHUP, SIGKILL (and others). No prior signal spec accesses
# __class__.__qualname__ (as opposed to __class__.__name__) on any signal or
# handler enum member. For top-level classes, __qualname__ == __name__, but
# the attribute path is distinct and constitutes a different invariant.
# SIGTERM.__class__.__qualname__ == 'Signals'
# SIGHUP.__class__.__qualname__ == 'Signals'
# SIGKILL.__class__.__qualname__ == 'Signals'
# ---------------------------------------------------------------------------

table signal_extra11.signals_member_class_qualnames:
  description: "SIGTERM/SIGHUP/SIGKILL __class__.__qualname__ == 'Signals' — distinct from __class__.__name__"
  kind: python_call_eq
  category: enum_identity
  id_prefix: smcqn11

  columns: [id, function, args, expected]
  rows:
    - [SIGTERM, "SIGTERM.__class__.__qualname__.__eq__", ["Signals"], true]
    - [SIGHUP,  "SIGHUP.__class__.__qualname__.__eq__",  ["Signals"], true]
    - [SIGKILL, "SIGKILL.__class__.__qualname__.__eq__", ["Signals"], true]

# ---------------------------------------------------------------------------
# Handlers enum member __class__.__qualname__ checks
#
# signal_extra and signal_extra2 check SIG_DFL.__class__.__name__ == 'Handlers'
# and SIG_IGN.__class__.__name__ == 'Handlers'. No prior spec uses the
# __class__.__qualname__ path on either handler member. The __qualname__ of the
# Handlers class is 'Handlers' — equal to __name__ but accessed via a
# distinct attribute chain.
# ---------------------------------------------------------------------------

invariant signal_extra11.SIG_DFL.class_qualname:
  description: "signal.SIG_DFL.__class__.__qualname__ == 'Handlers' — distinct from __class__.__name__"
  category: enum_identity
  kind: python_call_eq
  function: SIG_DFL.__class__.__qualname__.__eq__
  args: ["Handlers"]
  expected: true

invariant signal_extra11.SIG_IGN.class_qualname:
  description: "signal.SIG_IGN.__class__.__qualname__ == 'Handlers' — distinct from __class__.__name__"
  category: enum_identity
  kind: python_call_eq
  function: SIG_IGN.__class__.__qualname__.__eq__
  args: ["Handlers"]
  expected: true

# ---------------------------------------------------------------------------
# Signals and Handlers __qualname__ string lengths
#
# signal_extra4 verifies Signals.__qualname__.__eq__('Signals') and
# Handlers.__qualname__.__eq__('Handlers'). signal_extra10 checks function
# __qualname__ lengths (signal/getsignal/etc.) but does NOT check the
# __qualname__ length of the Signals or Handlers enum classes themselves.
# len('Signals') == 7; len('Handlers') == 8.
# ---------------------------------------------------------------------------

invariant signal_extra11.Signals.qualname_len:
  description: "signal.Signals.__qualname__.__len__() == 7 — len('Signals') == 7"
  category: enum_qualnames
  kind: python_call_eq
  function: Signals.__qualname__.__len__
  args: []
  expected: 7

invariant signal_extra11.Handlers.qualname_len:
  description: "signal.Handlers.__qualname__.__len__() == 8 — len('Handlers') == 8"
  category: enum_qualnames
  kind: python_call_eq
  function: Handlers.__qualname__.__len__
  args: []
  expected: 8
