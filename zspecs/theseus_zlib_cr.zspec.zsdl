spec: theseus_zlib_cr
version: ">=3.8"
backend: python_cleanroom(theseus_zlib_cr)
blocks: zlib

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/zlib.html"
  not_derived_from:
    - "CPython source: Lib/zlib.py"
  notes:
    - "Clean-room zlib module wrapping _zlib C extension. Do NOT import zlib."

error_model: python_exceptions

invariant theseus_zlib_cr.zlib2_compress:
  description: "compress and decompress round-trip correctly"
  category: behavior
  kind: python_call_eq
  function: zlib2_compress
  args: []
  expected: true

invariant theseus_zlib_cr.zlib2_crc32:
  description: "crc32 returns expected checksum for known data"
  category: behavior
  kind: python_call_eq
  function: zlib2_crc32
  args: []
  expected: true

invariant theseus_zlib_cr.zlib2_adler32:
  description: "adler32 returns expected checksum for known data"
  category: behavior
  kind: python_call_eq
  function: zlib2_adler32
  args: []
  expected: true
