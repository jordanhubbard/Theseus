spec: pyarrow_rust
version: ">=3.9"
backend: rust_module(pyarrow_rust)

docs: https://arrow.apache.org/docs/python/

provenance:
  derived_from:
    - "https://arrow.apache.org/docs/python/ — PyArrow documentation"
    - "https://arrow.apache.org/docs/format/ — Apache Arrow format"
  not_derived_from:
    - "pyarrow source: pyarrow/__init__.py"
  notes:
    - "PyArrow provides Python bindings for Apache Arrow columnar data format."
    - "pa.array([1, 2, 3]) creates an Arrow int64 array."
    - "pa.array([1, 2, 3]).to_pylist() == [1, 2, 3]."
    - "pa.array(['a', 'b']).type == pa.string()."
    - "pa.array([1, 2, 3]).type == pa.int64()."
    - "Expose pa_array_len(lst) -> int: len(pa.array(lst))."
    - "Expose pa_array_tolist(lst) -> list: pa.array(lst).to_pylist()."
    - "Expose pa_array_type_str(lst) -> str: str(pa.array(lst).type)."
    - "pa.array([1,2,3]).type == int64 → str is 'int64'."
    - "pa.array(['a','b']).type == string → str is 'string'."
    - "All test vectors verified against pyarrow 19.0.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# pa_array_len — array length
table pyarrow_rust.array.length:
  kind: python_call_eq
  category: length
  id_prefix: pa_len
  function: pa_array_len

  columns: [id, args, expected]
  rows:
    - [three,  [[1, 2, 3]], 3]
    - [empty,  [[]],        0]
    - [five,   [[1, 2, 3, 4, 5]], 5]

# pa_array_tolist — roundtrip via to_pylist
table pyarrow_rust.array.tolist:
  kind: python_call_eq
  category: tolist
  id_prefix: pa_tpl
  function: pa_array_tolist

  columns: [id, args, expected]
  rows:
    - [ints,   [[1, 2, 3]], [1, 2, 3]]
    - [empty,  [[]], []]

# pa_array_type_str — type string representation
table pyarrow_rust.array.type_str:
  kind: python_call_eq
  category: type_str
  id_prefix: pa_typ
  function: pa_array_type_str

  columns: [id, args, expected]
  rows:
    - [int64,  [[1, 2, 3]],    "int64"]
    - [str_type, [["a", "b"]], "string"]

