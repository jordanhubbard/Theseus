spec: lodash_keyby
version: ">=4.0.0"
backend: node(lodash.keyby)

docs: https://lodash.com/docs/#keyBy

provenance:
  derived_from:
    - "lodash.keyby README — https://www.npmjs.com/package/lodash.keyby"
    - "Test vectors verified with lodash.keyby@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.keyby exports the _.keyBy function directly as module.exports."
    - "keyBy(collection, iteratee) creates an object keyed by the iteratee result."
    - "String iteratee plucks a property to use as the key."
    - "If multiple items produce the same key, the last one wins."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns object keyed by iteratee."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_keyby.keyby:
  kind: node_module_call_eq
  function: ~
  category: keyby
  id_prefix: lkby

  columns: [id, args, expected]
  rows:
    - [by_id,   [[{"id": "a", "v": 1}, {"id": "b", "v": 2}], "id"],
       {"a": {"id": "a", "v": 1}, "b": {"id": "b", "v": 2}}]
    - [by_name, [[{"name": "x", "n": 10}, {"name": "y", "n": 20}], "name"],
       {"x": {"name": "x", "n": 10}, "y": {"name": "y", "n": 20}}]

