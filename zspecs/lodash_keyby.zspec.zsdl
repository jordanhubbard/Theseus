spec: lodash_keyby
version: ">=4.0.0"
backend: node(lodash.keyby)

docs: https://lodash.com/docs/#keyBy

provenance:
  derived_from:
    - "lodash.keyby README — https://www.npmjs.com/package/lodash.keyby"
    - "Test vectors verified with lodash.keyby@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.keyby exports the _.keyBy function directly as module.exports."
    - "keyBy(collection, key) creates an object keyed by the given property."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns keyed object. No errors for array inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_keyby.keyby:
  kind: node_module_call_eq
  function: ~
  category: keyby
  id_prefix: lkeyby

  columns: [id, args, expected]
  rows:
    - [by_id,  [[{"id": "a", "v": 1}, {"id": "b", "v": 2}], "id"],
       {"a": {"id": "a", "v": 1}, "b": {"id": "b", "v": 2}}]
