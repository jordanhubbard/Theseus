spec: weakref_extra13
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
  notes:
    - "This spec extends weakref.zspec.zsdl through weakref_extra12.zspec.zsdl."
    - "weakref_extra12 covers: WeakMethod.__bases__[0].__name__=='ReferenceType'; WeakMethod.__mro__[0].__name__=='WeakMethod'; WeakValueDictionary/WeakKeyDictionary mro_len==8; WeakValueDictionary.__mro__[-1].__name__=='object'; ProxyType/CallableProxyType mro_len==2 and mro[0]; WeakKeyDictionary.__mro__[0].__name__=='WeakKeyDictionary'."
    - "weakref_extra11 covers: ref.__bases__.__len__()==1; ref.__bases__[0].__name__=='object'; ref.__mro__.__len__()==2; ref.__mro__[-1].__name__=='object'; ProxyType/CallableProxyType __bases__.__len__()==1 and __bases__[0].__name__=='object'; getweakrefcount/getweakrefs __module__=='_weakref'."
    - "weakref_extra10 covers __qualname__ for WeakValueDictionary/WeakSet/WeakKeyDictionary/finalize."
    - "weakref_extra8 covers mro[-1] table for WeakKeyDictionary/WeakSet/finalize/WeakMethod; mro[1] for WeakValueDictionary/WeakKeyDictionary; mro_len for WeakSet/finalize/WeakMethod."
    - "weakref_extra7 covers mro[0] for WeakValueDictionary/WeakKeyDictionary/WeakSet; proxy.__module__."
    - "NOT yet covered: getweakrefcount.__qualname__ == 'getweakrefcount' — __qualname__ of the C builtin function."
    - "NOT yet covered: getweakrefs.__qualname__ == 'getweakrefs' — __qualname__ of the C builtin function."
    - "NOT yet covered: ref.__mro__[0].__name__ == 'ReferenceType' — the first MRO entry of the ref C type."
    - "NOT yet covered: finalize.__mro__[0].__name__ == 'finalize' — first MRO entry is the class itself."
    - "NOT yet covered: finalize.__mro__[1].__name__ == 'object' — finalize.__mro__ is [finalize, object]; second entry is object."
    - "NOT yet covered: WeakSet.__mro__[1].__name__ == 'object' — WeakSet.__mro__ is [WeakSet, object]; second entry is object (not in extra8 mro[1] table)."
    - "NOT yet covered: WeakSet.__bases__.__len__() == 1 — WeakSet has exactly one direct base class."
    - "NOT yet covered: WeakKeyDictionary.__bases__.__len__() == 1 — WeakKeyDictionary has exactly one direct base class."
    - "NOT yet covered: WeakKeyDictionary.__bases__[0].__name__ == 'MutableMapping' — direct base class of WeakKeyDictionary."
    - "NOT yet covered: WeakValueDictionary.__bases__.__len__() == 1 — WeakValueDictionary has exactly one direct base class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# getweakrefcount and getweakrefs — __qualname__ attributes
#
# weakref_extra.getweakrefcount.name and weakref_extra.getweakrefs.name cover
# the __name__ attribute. weakref_extra11 covers __module__ for both functions.
# No prior spec checks __qualname__ for either C builtin. For C builtins,
# __qualname__ equals __name__ (both are 'getweakrefcount'/'getweakrefs').
# ---------------------------------------------------------------------------

invariant weakref_extra13.getweakrefcount.qualname:
  description: "weakref.getweakrefcount.__qualname__ == 'getweakrefcount' — qualname of C builtin"
  category: function_attrs
  kind: python_call_eq
  function: getweakrefcount.__qualname__.__eq__
  args: ["getweakrefcount"]
  expected: true

invariant weakref_extra13.getweakrefs.qualname:
  description: "weakref.getweakrefs.__qualname__ == 'getweakrefs' — qualname of C builtin"
  category: function_attrs
  kind: python_call_eq
  function: getweakrefs.__qualname__.__eq__
  args: ["getweakrefs"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.ref — MRO first entry
#
# weakref_extra11 covers ref.__mro__.__len__()==2 and ref.__mro__[-1].__name__=='object'.
# No prior spec checks ref.__mro__[0].__name__. For any class, the first MRO entry
# is the class itself. ref is exposed in the module namespace as ReferenceType,
# and its __name__ (and thus __mro__[0].__name__) is 'ReferenceType'.
# ---------------------------------------------------------------------------

invariant weakref_extra13.ref.mro_first:
  description: "weakref.ref.__mro__[0].__name__ == 'ReferenceType' — first MRO entry is the class itself"
  category: mro
  kind: python_call_eq
  function: ref.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "ReferenceType"

# ---------------------------------------------------------------------------
# weakref.finalize — MRO entries
#
# weakref_extra8 covers finalize.__mro__.__len__()==2 (as mro_len invariant).
# weakref_extra8 table covers finalize.__mro__[-1].__name__=='object'.
# No prior spec checks finalize.__mro__[0].__name__ or finalize.__mro__[1].__name__
# as standalone invariants. finalize.__mro__ is [finalize, object] (len==2).
# ---------------------------------------------------------------------------

invariant weakref_extra13.finalize.mro_first:
  description: "weakref.finalize.__mro__[0].__name__ == 'finalize' — first MRO entry is the class itself"
  category: mro
  kind: python_call_eq
  function: finalize.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "finalize"

invariant weakref_extra13.finalize.mro_second:
  description: "weakref.finalize.__mro__[1].__name__ == 'object' — second and last MRO entry is object"
  category: mro
  kind: python_call_eq
  function: finalize.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# weakref.WeakSet — MRO[1] and __bases__ length
#
# weakref_extra8 covers mro[1] for WeakValueDictionary/WeakKeyDictionary only.
# weakref_extra7 covers WeakSet.__mro__[0].__name__ (mro_first).
# No prior spec checks WeakSet.__mro__[1].__name__ as a standalone invariant.
# WeakSet.__mro__ is [WeakSet, object] (len==2), so mro[1].__name__ == 'object'.
# No prior spec checks WeakSet.__bases__.__len__() as a standalone invariant either.
# ---------------------------------------------------------------------------

invariant weakref_extra13.WeakSet.mro_second:
  description: "weakref.WeakSet.__mro__[1].__name__ == 'object' — second and last MRO entry is object"
  category: mro
  kind: python_call_eq
  function: WeakSet.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

invariant weakref_extra13.WeakSet.bases_len:
  description: "weakref.WeakSet.__bases__.__len__() == 1 — WeakSet has exactly one direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: WeakSet.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# WeakKeyDictionary — __bases__ count and direct base class name
#
# weakref_extra.WeakKeyDictionary.base_name covers __bases__[0].__name__ via the
# extra namespace. weakref_extra2.WeakKeyDictionary.base_name re-anchors it.
# No prior spec checks WeakKeyDictionary.__bases__.__len__() as a standalone
# invariant. WeakKeyDictionary inherits from MutableMapping only (single base).
# ---------------------------------------------------------------------------

invariant weakref_extra13.WeakKeyDictionary.bases_len:
  description: "weakref.WeakKeyDictionary.__bases__.__len__() == 1 — WeakKeyDictionary has exactly one direct base"
  category: class_hierarchy
  kind: python_call_eq
  function: WeakKeyDictionary.__bases__.__len__
  args: []
  expected: 1

invariant weakref_extra13.WeakKeyDictionary.base_name:
  description: "weakref.WeakKeyDictionary.__bases__[0].__name__ == 'MutableMapping' — direct base via ABC chain"
  category: class_hierarchy
  kind: python_call_eq
  function: WeakKeyDictionary.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "MutableMapping"

# ---------------------------------------------------------------------------
# WeakValueDictionary — __bases__ count and direct base class name
#
# weakref_extra.WeakValueDictionary.base_name and weakref_extra2 cover the base
# class name. No prior spec checks WeakValueDictionary.__bases__.__len__() as a
# standalone invariant. Like WeakKeyDictionary, it inherits from MutableMapping only.
# ---------------------------------------------------------------------------

invariant weakref_extra13.WeakValueDictionary.bases_len:
  description: "weakref.WeakValueDictionary.__bases__.__len__() == 1 — WeakValueDictionary has exactly one direct base"
  category: class_hierarchy
  kind: python_call_eq
  function: WeakValueDictionary.__bases__.__len__
  args: []
  expected: 1

invariant weakref_extra13.WeakValueDictionary.base_name:
  description: "weakref.WeakValueDictionary.__bases__[0].__name__ == 'MutableMapping' — direct base via ABC chain"
  category: class_hierarchy
  kind: python_call_eq
  function: WeakValueDictionary.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "MutableMapping"
