spec: _io_extra
version: ">=3.9"
backend: python_module(_io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec extends the _io C accelerator module."
    - "Extends io.zspec.zsdl, io_extra.zspec.zsdl, io_extra2.zspec.zsdl, io_extra3.zspec.zsdl, io_extra4.zspec.zsdl, and _io.zspec.zsdl."
    - "_io.zspec.zsdl covers: BytesIO/__name__, StringIO/__name__, BytesIO/__module__, StringIO/__module__, UnsupportedOperation/__name__, UnsupportedOperation base class, BytesIO read/getvalue/tell/readable/seekable, StringIO read/getvalue/tell."
    - "io_extra4.zspec.zsdl covers (via io backend): IOBase/__name__, IOBase/__module__, IOBase/is_type, RawIOBase class metadata, BufferedIOBase class metadata, TextIOBase class metadata, StringIO/BytesIO/FileIO/BufferedReader/BufferedWriter class names and modules."
    - "This spec adds standalone _io-backend invariants for: IOBase/__name__, IOBase/__module__, RawIOBase/__name__, FileIO/__name__, BytesIO/__name__, StringIO/__name__, BufferedRandom/__name__, TextIOWrapper/__name__, IncrementalNewlineDecoder/__name__, and is_type checks for each."
    - "_io.IOBase.__module__ == '_io' — the class is defined in the C extension."
    - "_io.BufferedRandom is the C class for reading and writing to the same file; __name__ == 'BufferedRandom'."
    - "_io.TextIOWrapper is the C class for wrapping a binary stream as text; __name__ == 'TextIOWrapper'."
    - "_io.IncrementalNewlineDecoder is a helper class for newline translation; __name__ == 'IncrementalNewlineDecoder'."
    - "All expected values verified by running Python 3.12 _io on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IOBase — class name and module
# ---------------------------------------------------------------------------

invariant _io_extra.IOBase.name:
  description: "_io.IOBase.__name__ == 'IOBase'"
  category: classnames
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true

invariant _io_extra.IOBase.module:
  description: "_io.IOBase.__module__ == '_io'"
  category: classnames
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["_io"]
  expected: true

invariant _io_extra.IOBase.is_type:
  description: "_io.IOBase.__class__.__name__ == 'type' — IOBase is a class object"
  category: classnames
  kind: python_call_eq
  function: IOBase.__class__.__name__.__eq__
  args: ["type"]
  expected: true

