spec: multiprocessing_extra2251
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py, Lib/multiprocessing/synchronize.py, Lib/multiprocessing/queues.py"
  notes:
    - "Wave 2251 (_extra2251): callable protocol and function-attribute dict-presence — __call__, __code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__ checks."
    - "Classes checked: multiprocessing.Process, multiprocessing.synchronize.Lock, multiprocessing.synchronize.RLock, multiprocessing.synchronize.Semaphore, multiprocessing.synchronize.Event, multiprocessing.queues.Queue."
    - "__call__ is NOT in __dict__ for any of these classes — none of them implement a __call__ method in their own class body."
    - "__code__ is NOT in __dict__ for any of these classes — __code__ is a function-object attribute holding bytecode, not a class attribute."
    - "__globals__ is NOT in __dict__ for any of these classes — __globals__ is a function-object attribute referencing module globals."
    - "__defaults__ is NOT in __dict__ for any of these classes — __defaults__ is a function-object attribute for positional-parameter defaults."
    - "__kwdefaults__ is NOT in __dict__ for any of these classes — __kwdefaults__ is a function-object attribute for keyword-only defaults."
    - "__annotations__ is NOT in __dict__ for any of these classes — none of the six class bodies declare annotated class-level variables."
    - "__builtins__ is NOT in __dict__ for any of these classes — __builtins__ is a module-level name injected by the import machinery."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __call__ dict-presence — all 6 multiprocessing classes
#
# __call__ is NOT in the __dict__ of any multiprocessing class checked here.
# Process and the synchronize/queues primitives do not define __call__ in their
# own class body. All 6 return False.
# ---------------------------------------------------------------------------

table multiprocessing_extra2251.call_dict_presence:
  description: "__call__ dict-presence for mp.Process/sync.Lock/RLock/Semaphore/Event/queues.Queue — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2251

  columns: [id, function, args, expected]
  rows:
    - ["mp2251001", "multiprocessing.Process.__dict__.__contains__", ["__call__"], false]
    - ["mp2251002", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__call__"], false]
    - ["mp2251003", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__call__"], false]
    - ["mp2251004", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__call__"], false]
    - ["mp2251005", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__call__"], false]
    - ["mp2251006", "multiprocessing.queues.Queue.__dict__.__contains__", ["__call__"], false]

