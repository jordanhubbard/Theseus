spec: uuid_extra1351
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 537 (_extra1351): focuses on __slots__ and __weakref__ attribute checks at the class __dict__ level."
    - "uuid.UUID defines __slots__ = ('int', 'is_safe', '__weakref__') — so both '__slots__' and '__weakref__' appear in UUID.__dict__."
    - "uuid.UUID.__dict__.__contains__('__slots__') == True — UUID explicitly declares __slots__."
    - "uuid.UUID.__dict__.__contains__('__weakref__') == True — __weakref__ is listed in UUID.__slots__, making it a descriptor in UUID.__dict__."
    - "uuid.UUID.__dict__.__contains__('__dict__') == False — because UUID uses __slots__, instances have no instance __dict__."
    - "uuid.SafeUUID is an IntEnum subclass (enum.Enum); its __dict__ has no __slots__, __weakref__, or __dict__ descriptors."
    - "SafeUUID.__dict__.__contains__('__slots__') == False — IntEnum subclasses do not add __slots__."
    - "SafeUUID.__dict__.__contains__('__weakref__') == False — SafeUUID inherits weakref from Enum base without a descriptor in its own __dict__."
    - "SafeUUID.__dict__.__contains__('__dict__') == False — enum members are not stored as instance __dict__."
    - "uuid.UUID.__dict__ contains property descriptors: hex, int, bytes, urn, variant, version, is_safe."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table uuid_extra1351.uuid_class_slot_weakref_dict_checks:
  description: "uuid.UUID class __dict__ containment checks for __slots__, __weakref__, and __dict__ descriptors; UUID uses __slots__ so both __slots__ and __weakref__ appear in its __dict__ but __dict__ does not"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: uu1351uc
  columns: [id, function, args, expected]
  rows:
    - [uu1351uc001, uuid.UUID.__dict__.__contains__, ["__slots__"],    true]
    - [uu1351uc002, uuid.UUID.__dict__.__contains__, ["__weakref__"],  true]
    - [uu1351uc003, uuid.UUID.__dict__.__contains__, ["__dict__"],     false]
    - [uu1351uc004, uuid.UUID.__dict__.__contains__, ["hex"],          true]
    - [uu1351uc005, uuid.UUID.__dict__.__contains__, ["int"],          true]
    - [uu1351uc006, uuid.UUID.__dict__.__contains__, ["bytes"],        true]

table uuid_extra1351.safeuuid_class_slot_weakref_dict_checks:
  description: "uuid.SafeUUID (IntEnum subclass) class __dict__ containment checks for __slots__, __weakref__, and __dict__ descriptors; enum subclasses do not add these descriptors to their own __dict__"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: uu1351su
  columns: [id, function, args, expected]
  rows:
    - [uu1351su001, uuid.SafeUUID.__dict__.__contains__, ["__slots__"],    false]
    - [uu1351su002, uuid.SafeUUID.__dict__.__contains__, ["__weakref__"],  false]
    - [uu1351su003, uuid.SafeUUID.__dict__.__contains__, ["__dict__"],     false]
    - [uu1351su004, uuid.UUID.__dict__.__contains__,     ["__slots__"],    true]
    - [uu1351su005, uuid.UUID.__dict__.__contains__,     ["__weakref__"],  true]
    - [uu1351su006, uuid.UUID.__dict__.__contains__,     ["__dict__"],     false]

table uuid_extra1351.uuid_slot_content_and_property_checks:
  description: "uuid.UUID __slots__ tuple content and property descriptor presence checks; __slots__ lists 'int', 'is_safe', '__weakref__' — confirming UUID is a slotted pure-Python class"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: uu1351sp
  columns: [id, function, args, expected]
  rows:
    - [uu1351sp001, uuid.UUID.__dict__.__contains__, ["urn"],       true]
    - [uu1351sp002, uuid.UUID.__dict__.__contains__, ["variant"],   true]
    - [uu1351sp003, uuid.UUID.__dict__.__contains__, ["version"],   true]
    - [uu1351sp004, uuid.UUID.__dict__.__contains__, ["is_safe"],   true]
    - [uu1351sp005, uuid.UUID.__dict__.__contains__, ["__slots__"], true]
    - [uu1351sp006, uuid.SafeUUID.__dict__.__contains__, ["__slots__"], false]
