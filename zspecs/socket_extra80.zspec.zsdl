spec: socket_extra80
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra79.zspec.zsdl — covers socket.gethostname/gethostbyname/getaddrinfo/getnameinfo/setdefaulttimeout/getdefaulttimeout/inet_aton/inet_ntoa/htons __class__.__name__/__module__/__qualname__ (table + invariants)."
    - "socket_extra78.zspec.zsdl — covers socket.socket/__name__/__module__ / socket.error/__name__/__module__ / socket.gaierror/herror identity (table + invariants)."
    - "socket_extra77.zspec.zsdl — covers gaierror/herror __dict__ key membership / AddressFamily/SocketKind __mro__[0]/__mro__[5] __name__ (table + invariants)."
    - "socket_extra76.zspec.zsdl — covers socket.socket/__dict__.__contains__ / AddressFamily/SocketKind/__class__/__name__/__module__ (table + invariants)."
    - "socket_extra35.zspec.zsdl — covers AddressFamily/SocketKind/__mro__.__len__()==6 (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra79; it does NOT duplicate invariants present in those files."
    - "Wave 247 theme: socket AF_INET/AF_INET6/AF_UNIX/SOCK_STREAM/SOCK_DGRAM/SOCK_RAW constant identity and AddressFamily/SocketKind enum class identity."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily' — AF_INET is an AddressFamily IntEnum member. No prior socket spec checks AF_INET.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET6.__class__.__name__ == 'AddressFamily' — AF_INET6 is an AddressFamily IntEnum member. No prior socket spec checks AF_INET6.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' — AF_UNIX is an AddressFamily IntEnum member. No prior socket spec checks AF_UNIX.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — SOCK_STREAM is a SocketKind IntEnum member. No prior socket spec checks SOCK_STREAM.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind' — SOCK_DGRAM is a SocketKind IntEnum member. No prior socket spec checks SOCK_DGRAM.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_RAW.__class__.__name__ == 'SocketKind' — SOCK_RAW is a SocketKind IntEnum member. No prior socket spec checks SOCK_RAW.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__eq__(2) == True — AF_INET has integer value 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET6.__eq__(30) == True — AF_INET6 has integer value 30 on macOS/BSD. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__eq__(1) == True — SOCK_STREAM has integer value 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.__eq__(2) == True — SOCK_DGRAM has integer value 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__name__ == 'AddressFamily' — AddressFamily enum class name. No prior socket spec checks AddressFamily.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__module__ == 'socket' — AddressFamily is defined in socket. No prior socket spec checks AddressFamily.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__name__ == 'SocketKind' — SocketKind enum class name. No prior socket spec checks SocketKind.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__module__ == 'socket' — SocketKind is defined in socket. No prior socket spec checks SocketKind.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__module__ == 'socket' — AddressFamily class module. No prior socket spec checks AF_INET.__class__.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__module__ == 'socket' — SocketKind class module. No prior socket spec checks SOCK_STREAM.__class__.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET/__class__/__name__ / AF_INET6/__class__/__name__ / AF_UNIX/__class__/__name__
#
# Wave 247 theme: AddressFamily enum constant class name identity.
#
# AF_INET, AF_INET6, AF_UNIX are all AddressFamily IntEnum members.
# Their __class__.__name__ is 'AddressFamily'.
# No prior socket spec checks AF_INET/__class__/__name__, AF_INET6/__class__/__name__,
# or AF_UNIX/__class__/__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra80.af_family_class_names:
  description: "socket.AF_INET/__class__/__name__.__eq__('AddressFamily')==True / AF_INET6/__class__/__name__.__eq__('AddressFamily')==True / AF_UNIX/__class__/__name__.__eq__('AddressFamily')==True — AF_INET/AF_INET6/AF_UNIX are all AddressFamily IntEnum members; no prior socket spec checks these __class__.__name__ values; first class name anchor for AF_INET/AF_INET6/AF_UNIX"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra80

  columns: [id, function, args, expected]
  rows:
    - [af_inet_class_name_addressfamily,  AF_INET.__class__.__name__.__eq__,  ["AddressFamily"], true]
    - [af_inet6_class_name_addressfamily, AF_INET6.__class__.__name__.__eq__, ["AddressFamily"], true]
    - [af_unix_class_name_addressfamily,  AF_UNIX.__class__.__name__.__eq__,  ["AddressFamily"], true]

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM/__class__/__name__ / SOCK_DGRAM/__class__/__name__ / SOCK_RAW/__class__/__name__
#
# Wave 247 theme: SocketKind enum constant class name identity.
#
# SOCK_STREAM, SOCK_DGRAM, SOCK_RAW are all SocketKind IntEnum members.
# Their __class__.__name__ is 'SocketKind'.
# No prior socket spec checks any of these __class__.__name__ values.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra80.sock_kind_class_names:
  description: "socket.SOCK_STREAM/__class__/__name__.__eq__('SocketKind')==True / SOCK_DGRAM/__class__/__name__.__eq__('SocketKind')==True / SOCK_RAW/__class__/__name__.__eq__('SocketKind')==True — SOCK_STREAM/SOCK_DGRAM/SOCK_RAW are all SocketKind IntEnum members; no prior socket spec checks these __class__.__name__ values; first class name anchor for SOCK_STREAM/SOCK_DGRAM/SOCK_RAW"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra80

  columns: [id, function, args, expected]
  rows:
    - [sock_stream_class_name_socketkind, SOCK_STREAM.__class__.__name__.__eq__, ["SocketKind"], true]
    - [sock_dgram_class_name_socketkind,  SOCK_DGRAM.__class__.__name__.__eq__,  ["SocketKind"], true]
    - [sock_raw_class_name_socketkind,    SOCK_RAW.__class__.__name__.__eq__,    ["SocketKind"], true]

# ---------------------------------------------------------------------------
# socket.AF_INET.__eq__(2) / AF_INET6.__eq__(30) / SOCK_STREAM.__eq__(1) / SOCK_DGRAM.__eq__(2)
#
# Wave 247 theme: socket constant integer value identity.
#
# AF_INET == 2 (universal), AF_INET6 == 30 (macOS/BSD), SOCK_STREAM == 1, SOCK_DGRAM == 2.
# No prior socket spec checks any of these __eq__ calls.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra80.socket_constant_values:
  description: "socket.AF_INET/__eq__(2)==True / AF_INET6/__eq__(30)==True / SOCK_STREAM/__eq__(1)==True / SOCK_DGRAM/__eq__(2)==True — AF_INET==2 (universal); AF_INET6==30 (macOS/BSD); SOCK_STREAM==1; SOCK_DGRAM==2; no prior socket spec checks these integer equality values; first numeric value anchor for AF_INET/AF_INET6/SOCK_STREAM/SOCK_DGRAM"
  kind: python_call_eq
  category: const_values
  id_prefix: socketextra80

  columns: [id, function, args, expected]
  rows:
    - [af_inet_eq_2,      AF_INET.__eq__,      [2],  true]
    - [af_inet6_eq_30,    AF_INET6.__eq__,     [30], true]
    - [sock_stream_eq_1,  SOCK_STREAM.__eq__,  [1],  true]
    - [sock_dgram_eq_2,   SOCK_DGRAM.__eq__,   [2],  true]

# ---------------------------------------------------------------------------
# socket.AddressFamily/__name__ / AddressFamily/__module__
# socket.SocketKind/__name__ / SocketKind/__module__
# socket.AF_INET/__class__/__module__ / SOCK_STREAM/__class__/__module__
#
# Wave 247 theme: AddressFamily and SocketKind enum class identity.
#
# AddressFamily.__name__ == 'AddressFamily', AddressFamily.__module__ == 'socket'.
# SocketKind.__name__ == 'SocketKind', SocketKind.__module__ == 'socket'.
# AF_INET.__class__.__module__ == 'socket', SOCK_STREAM.__class__.__module__ == 'socket'.
# No prior socket spec checks any of these attributes.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra80.addressfamily_socketkind_class_identity:
  description: "socket.AddressFamily/__name__.__eq__('AddressFamily')==True / AddressFamily/__module__.__eq__('socket')==True / SocketKind/__name__.__eq__('SocketKind')==True / SocketKind/__module__.__eq__('socket')==True / AF_INET/__class__/__module__.__eq__('socket')==True / SOCK_STREAM/__class__/__module__.__eq__('socket')==True — AddressFamily/SocketKind are enum classes defined in socket; no prior socket spec checks these name/module attributes; first class identity anchor for AddressFamily and SocketKind"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra80

  columns: [id, function, args, expected]
  rows:
    - [addressfamily_name_eq,          AddressFamily.__name__.__eq__,          ["AddressFamily"], true]
    - [addressfamily_module_eq,        AddressFamily.__module__.__eq__,        ["socket"],        true]
    - [socketkind_name_eq,             SocketKind.__name__.__eq__,             ["SocketKind"],    true]
    - [socketkind_module_eq,           SocketKind.__module__.__eq__,           ["socket"],        true]
    - [af_inet_class_module_socket,    AF_INET.__class__.__module__.__eq__,    ["socket"],        true]
    - [sock_stream_class_module_socket, SOCK_STREAM.__class__.__module__.__eq__, ["socket"],      true]

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__name__.__eq__('AddressFamily') — standalone
#
# AF_INET is an AddressFamily IntEnum member. No prior socket spec checks
# AF_INET.__class__.__name__. First __class__.__name__ standalone for socket.AF_INET.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra80.af_inet_class_name_addressfamily:
  description: "socket.AF_INET.__class__.__name__.__eq__('AddressFamily') == True — AF_INET is an AddressFamily IntEnum member; no prior socket spec checks AF_INET.__class__.__name__; first __class__.__name__ standalone for socket.AF_INET"
  category: class_attrs
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

