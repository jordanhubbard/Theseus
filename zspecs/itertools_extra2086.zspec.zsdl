spec: itertools_extra2086
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2086 (_extra2086): __format__, __bytes__, __fspath__, __buffer__, __release_buffer__ dict-presence checks for itertools C extension types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All itertools types are C extension types (defined in Modules/itertoolsmodule.c); none define __format__, __bytes__, __fspath__, __buffer__, or __release_buffer__ in their own __dict__."
    - "itertools.chain, cycle, count, zip_longest, product, permutations, combinations, combinations_with_replacement, accumulate, compress, dropwhile, filterfalse, groupby, islice, pairwise, repeat, starmap, takewhile — all False for all 5 protocols."
    - "itertools._tee and itertools._grouper (internal helper types) also define none of the 5 protocol dunders."
    - "C extension iterator types expose iteration via tp_iternext at the C level, not via Python-visible protocol dunders in __dict__."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __format__ dict-presence for itertools types
#
# No itertools C extension type defines __format__ in its own __dict__.
# They inherit the default __format__ from object.
# ---------------------------------------------------------------------------

table itertools_extra2086.format_protocol:
  description: "itertools types __format__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2086

  columns: [id, function, args, expected]
  rows:
    - ["it2086001", "itertools.chain.__dict__.__contains__", ["__format__"], false]
    - ["it2086002", "itertools.cycle.__dict__.__contains__", ["__format__"], false]
    - ["it2086003", "itertools.count.__dict__.__contains__", ["__format__"], false]
    - ["it2086004", "itertools.zip_longest.__dict__.__contains__", ["__format__"], false]
    - ["it2086005", "itertools.product.__dict__.__contains__", ["__format__"], false]
    - ["it2086006", "itertools.permutations.__dict__.__contains__", ["__format__"], false]
    - ["it2086007", "itertools.combinations.__dict__.__contains__", ["__format__"], false]

# ---------------------------------------------------------------------------
# Table 2: __bytes__ dict-presence for itertools types
#
# Iterator types produce sequences of objects; they do not convert to bytes.
# __bytes__ is absent from all itertools C extension type __dict__ entries.
# ---------------------------------------------------------------------------

table itertools_extra2086.bytes_protocol:
  description: "itertools types __bytes__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2086

  columns: [id, function, args, expected]
  rows:
    - ["it2086008", "itertools.chain.__dict__.__contains__", ["__bytes__"], false]
    - ["it2086009", "itertools.cycle.__dict__.__contains__", ["__bytes__"], false]
    - ["it2086010", "itertools.count.__dict__.__contains__", ["__bytes__"], false]
    - ["it2086011", "itertools.accumulate.__dict__.__contains__", ["__bytes__"], false]
    - ["it2086012", "itertools.compress.__dict__.__contains__", ["__bytes__"], false]
    - ["it2086013", "itertools.dropwhile.__dict__.__contains__", ["__bytes__"], false]
    - ["it2086014", "itertools.filterfalse.__dict__.__contains__", ["__bytes__"], false]

# ---------------------------------------------------------------------------
# Table 3: __fspath__ dict-presence for itertools types
#
# Iterator types are not path-like objects. None define __fspath__ in their
# own __dict__. The os.fspath() protocol is irrelevant to itertools.
# ---------------------------------------------------------------------------

table itertools_extra2086.fspath_protocol:
  description: "itertools types __fspath__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2086

  columns: [id, function, args, expected]
  rows:
    - ["it2086015", "itertools.groupby.__dict__.__contains__", ["__fspath__"], false]
    - ["it2086016", "itertools.islice.__dict__.__contains__", ["__fspath__"], false]
    - ["it2086017", "itertools.pairwise.__dict__.__contains__", ["__fspath__"], false]
    - ["it2086018", "itertools.repeat.__dict__.__contains__", ["__fspath__"], false]
    - ["it2086019", "itertools.starmap.__dict__.__contains__", ["__fspath__"], false]
    - ["it2086020", "itertools.takewhile.__dict__.__contains__", ["__fspath__"], false]
    - ["it2086021", "itertools.combinations_with_replacement.__dict__.__contains__", ["__fspath__"], false]

# ---------------------------------------------------------------------------
# Table 4: __buffer__ / __release_buffer__ dict-presence for itertools types
#
# Buffer protocol dunders are absent from all itertools types. These are
# lazy iterator objects, not contiguous memory buffer providers.
# ---------------------------------------------------------------------------

table itertools_extra2086.buffer_protocol:
  description: "itertools types __buffer__/__release_buffer__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2086

  columns: [id, function, args, expected]
  rows:
    - ["it2086022", "itertools.chain.__dict__.__contains__", ["__buffer__"], false]
    - ["it2086023", "itertools.chain.__dict__.__contains__", ["__release_buffer__"], false]
    - ["it2086024", "itertools.cycle.__dict__.__contains__", ["__buffer__"], false]
    - ["it2086025", "itertools.cycle.__dict__.__contains__", ["__release_buffer__"], false]
    - ["it2086026", "itertools.product.__dict__.__contains__", ["__buffer__"], false]
    - ["it2086027", "itertools.product.__dict__.__contains__", ["__release_buffer__"], false]
    - ["it2086028", "itertools.permutations.__dict__.__contains__", ["__buffer__"], false]
    - ["it2086029", "itertools.permutations.__dict__.__contains__", ["__release_buffer__"], false]
    - ["it2086030", "itertools.combinations.__dict__.__contains__", ["__buffer__"], false]
    - ["it2086031", "itertools.combinations.__dict__.__contains__", ["__release_buffer__"], false]
    - ["it2086032", "itertools.accumulate.__dict__.__contains__", ["__buffer__"], false]
    - ["it2086033", "itertools.accumulate.__dict__.__contains__", ["__release_buffer__"], false]

# ---------------------------------------------------------------------------
# Table 5: Internal helper types __tee and _grouper protocol checks
#
# itertools._tee and itertools._grouper are internal C types exposed in
# the itertools namespace. Neither defines any of the 5 wave-2086 dunders.
# ---------------------------------------------------------------------------

table itertools_extra2086.internal_types_protocol:
  description: "itertools._tee and _grouper dict-presence for all 5 wave-2086 protocols — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2086

  columns: [id, function, args, expected]
  rows:
    - ["it2086034", "itertools._tee.__dict__.__contains__", ["__format__"], false]
    - ["it2086035", "itertools._tee.__dict__.__contains__", ["__bytes__"], false]
    - ["it2086036", "itertools._tee.__dict__.__contains__", ["__fspath__"], false]
    - ["it2086037", "itertools._tee.__dict__.__contains__", ["__buffer__"], false]
    - ["it2086038", "itertools._tee.__dict__.__contains__", ["__release_buffer__"], false]
    - ["it2086039", "itertools._grouper.__dict__.__contains__", ["__format__"], false]
    - ["it2086040", "itertools._grouper.__dict__.__contains__", ["__bytes__"], false]
    - ["it2086041", "itertools._grouper.__dict__.__contains__", ["__fspath__"], false]
    - ["it2086042", "itertools._grouper.__dict__.__contains__", ["__buffer__"], false]
    - ["it2086043", "itertools._grouper.__dict__.__contains__", ["__release_buffer__"], false]
