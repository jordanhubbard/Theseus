spec: io_extra273
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
  notes:
    - "io.StringIO is a C-extension class with __module__ == '_io'."
    - "All io.StringIO methods (read, write, readline, seek, tell, getvalue, close, truncate) are method_descriptor objects."
    - "Each method's __qualname__ is 'StringIO.<method_name>'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: StringIO method __name__ identity
# ---------------------------------------------------------------------------

table io_extra273.stringio_method_names:
  description: "io.StringIO method __name__ identity for read, write, readline, seek, tell, getvalue, close, truncate"
  kind: python_call_eq
  category: identity
  id_prefix: nm

  columns: [id, function, args, expected, description]
  rows:
    - [read_name,      StringIO.read.__name__.__eq__,      ["read"],      true, "io.StringIO.read.__name__ == 'read'"]
    - [write_name,     StringIO.write.__name__.__eq__,     ["write"],     true, "io.StringIO.write.__name__ == 'write'"]
    - [readline_name,  StringIO.readline.__name__.__eq__,  ["readline"],  true, "io.StringIO.readline.__name__ == 'readline'"]
    - [seek_name,      StringIO.seek.__name__.__eq__,      ["seek"],      true, "io.StringIO.seek.__name__ == 'seek'"]
    - [tell_name,      StringIO.tell.__name__.__eq__,      ["tell"],      true, "io.StringIO.tell.__name__ == 'tell'"]
    - [getvalue_name,  StringIO.getvalue.__name__.__eq__,  ["getvalue"],  true, "io.StringIO.getvalue.__name__ == 'getvalue'"]
    - [close_name,     StringIO.close.__name__.__eq__,     ["close"],     true, "io.StringIO.close.__name__ == 'close'"]
    - [truncate_name,  StringIO.truncate.__name__.__eq__,  ["truncate"],  true, "io.StringIO.truncate.__name__ == 'truncate'"]

# ---------------------------------------------------------------------------
# Table: StringIO method __class__.__name__ (all method_descriptor)
# ---------------------------------------------------------------------------

table io_extra273.stringio_method_classes:
  description: "io.StringIO method __class__.__name__ for read, write, readline, seek, tell, getvalue, close, truncate"
  kind: python_call_eq
  category: identity
  id_prefix: cls

  columns: [id, function, args, expected, description]
  rows:
    - [read_class,     StringIO.read.__class__.__name__.__eq__,     ["method_descriptor"], true, "io.StringIO.read.__class__.__name__ == 'method_descriptor'"]
    - [write_class,    StringIO.write.__class__.__name__.__eq__,    ["method_descriptor"], true, "io.StringIO.write.__class__.__name__ == 'method_descriptor'"]
    - [readline_class, StringIO.readline.__class__.__name__.__eq__, ["method_descriptor"], true, "io.StringIO.readline.__class__.__name__ == 'method_descriptor'"]
    - [seek_class,     StringIO.seek.__class__.__name__.__eq__,     ["method_descriptor"], true, "io.StringIO.seek.__class__.__name__ == 'method_descriptor'"]
    - [tell_class,     StringIO.tell.__class__.__name__.__eq__,     ["method_descriptor"], true, "io.StringIO.tell.__class__.__name__ == 'method_descriptor'"]
    - [getvalue_class, StringIO.getvalue.__class__.__name__.__eq__, ["method_descriptor"], true, "io.StringIO.getvalue.__class__.__name__ == 'method_descriptor'"]
    - [close_class,    StringIO.close.__class__.__name__.__eq__,    ["method_descriptor"], true, "io.StringIO.close.__class__.__name__ == 'method_descriptor'"]
    - [truncate_class, StringIO.truncate.__class__.__name__.__eq__, ["method_descriptor"], true, "io.StringIO.truncate.__class__.__name__ == 'method_descriptor'"]

# ---------------------------------------------------------------------------
# Table: StringIO method __qualname__ identity
# ---------------------------------------------------------------------------

table io_extra273.stringio_method_qualnames:
  description: "io.StringIO method __qualname__ for read, write, readline, seek, tell, getvalue, close, truncate"
  kind: python_call_eq
  category: identity
  id_prefix: qn

  columns: [id, function, args, expected, description]
  rows:
    - [read_qualname,     StringIO.read.__qualname__.__eq__,     ["StringIO.read"],     true, "io.StringIO.read.__qualname__ == 'StringIO.read'"]
    - [write_qualname,    StringIO.write.__qualname__.__eq__,    ["StringIO.write"],    true, "io.StringIO.write.__qualname__ == 'StringIO.write'"]
    - [readline_qualname, StringIO.readline.__qualname__.__eq__, ["StringIO.readline"], true, "io.StringIO.readline.__qualname__ == 'StringIO.readline'"]
    - [seek_qualname,     StringIO.seek.__qualname__.__eq__,     ["StringIO.seek"],     true, "io.StringIO.seek.__qualname__ == 'StringIO.seek'"]
    - [tell_qualname,     StringIO.tell.__qualname__.__eq__,     ["StringIO.tell"],     true, "io.StringIO.tell.__qualname__ == 'StringIO.tell'"]
    - [getvalue_qualname, StringIO.getvalue.__qualname__.__eq__, ["StringIO.getvalue"], true, "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue'"]
    - [close_qualname,    StringIO.close.__qualname__.__eq__,    ["StringIO.close"],    true, "io.StringIO.close.__qualname__ == 'StringIO.close'"]
    - [truncate_qualname, StringIO.truncate.__qualname__.__eq__, ["StringIO.truncate"], true, "io.StringIO.truncate.__qualname__ == 'StringIO.truncate'"]

# ---------------------------------------------------------------------------
# Standalone invariants: StringIO class identity and method cross-checks
# ---------------------------------------------------------------------------

invariant io_extra273.StringIO.module:
  description: "io.StringIO.__module__ == '_io' — StringIO is implemented in the C extension _io"
  category: identity
  kind: python_call_eq
  function: StringIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra273.StringIO.name:
  description: "io.StringIO.__name__ == 'StringIO'"
  category: identity
  kind: python_call_eq
  function: StringIO.__name__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra273.StringIO.read.is_method_descriptor:
  description: "io.StringIO.read is a method_descriptor (C-extension method)"
  category: identity
  kind: python_call_eq
  function: StringIO.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra273.StringIO.getvalue.is_method_descriptor:
  description: "io.StringIO.getvalue is a method_descriptor (C-extension method)"
  category: identity
  kind: python_call_eq
  function: StringIO.getvalue.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true
