spec: re3181
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 659 (re3181): __truediv__, __floordiv__, __mod__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "No re class defines __truediv__ in its own __dict__: the / operator has no meaning for compiled patterns, match objects, or flag enumerations."
    - "No re class defines __floordiv__ in its own __dict__: re types have no arithmetic floor-division protocol."
    - "No re class defines __mod__ in its own __dict__: re.RegexFlag is an IntFlag subclass; any arithmetic it supports is inherited from int/IntFlag base classes, not stored in re.RegexFlag.__dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __truediv__ dict-presence — operator.contains(Cls.__dict__, '__truediv__')
#
# No re class defines __truediv__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum whose division semantics, if any, come from base-class inheritance.
# ---------------------------------------------------------------------------

table re3181.truediv:
  description: "re types __truediv__ dict-presence checks; wave 659"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3181

  columns: [id, function, args, expected]
  rows:
    - ["re3181001", operator.contains, [re.Pattern.__dict__,   "__truediv__"], false]
    - ["re3181002", operator.contains, [re.Match.__dict__,     "__truediv__"], false]
    - ["re3181003", operator.contains, [re.RegexFlag.__dict__, "__truediv__"], false]

