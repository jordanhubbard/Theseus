spec: multiprocessing_extra33
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing_extra32.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() for Pool/Queue/Lock/Event/Semaphore/Barrier, Process method __qualname__.__len__() for start/run/join/terminate/is_alive/kill, Pool method __qualname__.__len__() tables, AuthenticationError/ProcessError/BufferTooShort __bases__[0].__name__, Process/Pool/AuthenticationError/ProcessError __mro__.__len__(), __all__ metadata, class __dict__.__class__.__name__.__len__() for Process/AuthenticationError/ProcessError, Pool class metadata, DefaultContext method qualname lengths, BufferTooShort/TimeoutError qualname lengths, synchronize.Lock/Event/Semaphore identity and hierarchy, queues.Queue identity and hierarchy, Process.__bases__[0].__name__.__len__()==11, Process.__dict__.__class__.__name__.__len__()==12, exception class __name__.__len__() and __mro__.__len__() tables, cpu_count/__name__.__len__()==9, current_process/__name__.__len__()==15."
    - "This spec covers: Process.__init__.__qualname__.__len__()==20 ('BaseProcess.__init__'); BaseProcess.__name__.__len__()==11 ('BaseProcess'); BaseProcess.__qualname__.__len__()==11 ('BaseProcess'); BaseProcess.__mro__.__len__()==2 (BaseProcess + object); BaseProcess.__module__.__len__()==23 ('multiprocessing.process')."
    - "Process.__init__.__qualname__ == 'BaseProcess.__init__' (20 chars) — Process inherits __init__ from BaseProcess, so the qualname carries BaseProcess's name rather than Process's name."
    - "BaseProcess.__name__ == 'BaseProcess' (11 chars) — the abstract base class for all process implementations."
    - "BaseProcess.__qualname__ == 'BaseProcess' (11 chars) — equals __name__; BaseProcess is a top-level class, not nested."
    - "BaseProcess.__mro__.__len__() == 2 — (BaseProcess, object) — BaseProcess directly subclasses object with no intermediary."
    - "BaseProcess.__module__ == 'multiprocessing.process' (23 chars) — the internal module, same length as the public multiprocessing.Process.__module__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process.__init__ qualname length — extra33 namespace
#
# Process.__init__ is inherited from BaseProcess:
#   Process.__init__.__qualname__ == 'BaseProcess.__init__' (20 chars)
# This mirrors the pattern seen for other Process methods — start, run, join,
# terminate, is_alive, and kill all have qualnames beginning 'BaseProcess.'
# because they are defined on BaseProcess and inherited by the platform-specific
# Process subclass.
# No prior multiprocessing spec has measured Process.__init__.__qualname__.__len__()
# as a table row or invariant.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra33.Process_init_qualname_len:
  description: "multiprocessing.Process.__init__.__qualname__.__len__() == 20 — 'BaseProcess.__init__' has 20 characters; inherits from BaseProcess"
  category: method_names
  kind: python_call_eq
  function: Process.__init__.__qualname__.__len__
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# multiprocessing.process.BaseProcess class metadata — extra33 namespace
#
# BaseProcess is the abstract base class for all process objects. It lives in
# the internal multiprocessing.process submodule and is not directly accessible
# from the public multiprocessing namespace. Key metadata:
#   BaseProcess.__name__     == 'BaseProcess' (11 chars)
#   BaseProcess.__qualname__ == 'BaseProcess' (11 chars)  — equals __name__
#   BaseProcess.__mro__      == (BaseProcess, object)     — depth 2
#   BaseProcess.__module__   == 'multiprocessing.process' (23 chars)
#
# Note: __name__ and __qualname__ are equal (11) because BaseProcess is a
# top-level class (not a nested class). The MRO depth (2) is shallower than
# the public Process class (depth 3 = Process, BaseProcess, object).
# The module string 'multiprocessing.process' has the same length (23) as
# the public Process.__module__ == 'multiprocessing' is only 15 chars —
# but Process.__module__ was measured as 23 in prior specs because the
# platform-specific subclass is in 'multiprocessing.context' (23 chars).
# Actually BaseProcess.__module__ == 'multiprocessing.process' (23 chars),
# which was noted in extra12 for the equality check but not for __len__().
# ---------------------------------------------------------------------------

table multiprocessing_extra33.baseprocess_class_metadata:
  description: "multiprocessing.process.BaseProcess class metadata __len__() in extra33 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: bprocmeta33

  columns: [id, function, args, expected]
  rows:
    - [name_len,     "process.BaseProcess.__name__.__len__",     [], 11]
    - [qualname_len, "process.BaseProcess.__qualname__.__len__", [], 11]
    - [module_len,   "process.BaseProcess.__module__.__len__",   [], 23]

invariant multiprocessing_extra33.BaseProcess_mro_len:
  description: "multiprocessing.process.BaseProcess.__mro__.__len__() == 2 — (BaseProcess, object); shallower than Process (depth 3)"
  category: class_hierarchy
  kind: python_call_eq
  function: process.BaseProcess.__mro__.__len__
  args: []
  expected: 2

invariant multiprocessing_extra33.BaseProcess_name_len:
  description: "multiprocessing.process.BaseProcess.__name__.__len__() == 11 — 'BaseProcess' has 11 characters; equals __qualname__ length"
  category: class_names
  kind: python_call_eq
  function: process.BaseProcess.__name__.__len__
  args: []
  expected: 11
