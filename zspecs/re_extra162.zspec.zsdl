spec: re_extra162
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.RegexFlag enum class identity attributes and re.IGNORECASE flag value."
    - "re.RegexFlag is an IntFlag enum introduced in Python 3.11 (previously the flags were plain integers)."
    - "re.RegexFlag.__name__ == 'RegexFlag' (len=9; the public class name of the enum)."
    - "re.RegexFlag.__module__ == 're' (len=2; the public module — same as io.RawIOBase.__module__ == 'io')."
    - "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (len=7; RegexFlag extends IntFlag from the enum module)."
    - "re.IGNORECASE.__class__.__name__ == 'RegexFlag' (len=9; IGNORECASE is an instance of RegexFlag)."
    - "re.IGNORECASE == 2 (the integer value of the IGNORECASE flag; 2 == 1 << 1)."
    - "The __bases__[0].__name__ == 'IntFlag' reveals the MRO: RegexFlag inherits from IntFlag which inherits from int and Flag."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.RegexFlag enum class identity attributes
# __name__ = 'RegexFlag' (len=9), __module__ = 're' (len=2)
# __bases__[0].__name__ = 'IntFlag' — RegexFlag extends IntFlag.
# RegexFlag is an IntFlag subclass that groups all re module flags.
# ---------------------------------------------------------------------------

table re_extra162.RegexFlag_class_identity:
  description: "re.RegexFlag class identity: __name__='RegexFlag' (len=9), __module__='re' (len=2), __bases__[0].__name__='IntFlag'; RegexFlag is an IntFlag subclass grouping all re module flags"
  kind: python_call_eq
  category: identity
  id_prefix: regflag162

  columns: [id, function, args, expected, description]
  rows:
    - [regflag_name,    re.RegexFlag.__name__.__eq__,                   ["RegexFlag"],  true, "re.RegexFlag.__name__ == 'RegexFlag' (RegexFlag is the IntFlag enum class that groups all regular expression flags in the re module; introduced in Python 3.11 to replace the previous pattern of bare integer flag values; 'RegexFlag' has 9 characters: 'Regex' (5) + 'Flag' (4) = 9; the 'Regex' prefix identifies it as a re-module type; 'Flag' suffix signals its IntFlag nature; RegexFlag members include IGNORECASE, MULTILINE, DOTALL, VERBOSE, ASCII, UNICODE, LOCALE, and more)"]
    - [regflag_mod,     re.RegexFlag.__module__.__eq__,                  ["re"],         true, "re.RegexFlag.__module__ == 're' (RegexFlag's module is the public 're' module; 're' has 2 characters — the shortest possible module name; this mirrors io.RawIOBase.__module__ == 'io' (also 2 chars) established in io_extra165; both 're' and 'io' are 2-character public module names; RegexFlag is defined in the public 're' namespace, not a private '_re' extension; the short module name 're' reflects Python's convention for the regular expressions standard library module)"]
    - [regflag_base0,   "re.RegexFlag.__bases__[0].__name__.__eq__",     ["IntFlag"],    true, "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (RegexFlag's first base class is IntFlag from the enum module; IntFlag is itself a subclass of int and Flag, making RegexFlag instances both valid integers and enum members; 'IntFlag' has 7 characters: 'Int' (3) + 'Flag' (4) = 7; the IntFlag base means re module flag values can be combined with bitwise OR (|) and behave as integers in contexts expecting int; this is why re.IGNORECASE | re.MULTILINE produces a valid combined flag value)"]
    - [regflag_name_len, re.RegexFlag.__name__.__len__,                  [],             9,    "re.RegexFlag.__name__.__len__() == 9 ('RegexFlag' has 9 characters: 'Regex' (5) + 'Flag' (4) = 9; the name length 9 is the same as io.RawIOBase.__name__.__len__() == 9 established in io_extra165 ('RawIOBase' also has 9 chars); coincidentally, re.IGNORECASE.__class__.__name__ == 'RegexFlag' — so IGNORECASE.__class__.__name__.__len__() is also 9; 'RegexFlag' (9) is longer than 'IntFlag' (7) — the base class has a shorter name than its derived class)"]

# ---------------------------------------------------------------------------
# re.IGNORECASE flag value and class identity
# IGNORECASE is a member of RegexFlag with integer value 2 (= 1 << 1).
# IGNORECASE.__class__.__name__ == 'RegexFlag' (not 'int' or 'IntFlag').
# The integer value 2 is verified — IGNORECASE is the second flag bit.
# ---------------------------------------------------------------------------

table re_extra162.IGNORECASE_flag_identity:
  description: "re.IGNORECASE identity: __class__.__name__='RegexFlag' (len=9), integer value=2 (=1<<1); IGNORECASE is a RegexFlag member; 2 is the smallest non-trivial flag value"
  kind: python_call_eq
  category: identity
  id_prefix: regflag162

  columns: [id, function, args, expected, description]
  rows:
    - [ic_class_name,  re.IGNORECASE.__class__.__name__.__eq__,  ["RegexFlag"],  true, "re.IGNORECASE.__class__.__name__ == 'RegexFlag' (IGNORECASE is an instance of the RegexFlag enum class, not a plain int; its __class__ is RegexFlag, not int or IntFlag; this is confirmed by the len=9 class name 'RegexFlag' which is identical to re.RegexFlag.__name__; IGNORECASE makes the pattern case-insensitive — [A-Z] matches [a-z] and vice versa; the POSIX equivalent is the -i flag in grep/sed)"]
    - [ic_value_eq,    re.IGNORECASE.__eq__,                      [2],           true, "re.IGNORECASE == 2 (IGNORECASE has integer value 2 = 1 << 1; as an IntFlag member it is a power of 2 to allow bitwise OR combination with other flags; flag value 1 is reserved for re.ASCII (also known as re.A); value 2 is the second flag bit; the integer value 2 enables IGNORECASE to be detected with bitwise AND: (flags & 2) != 0 means IGNORECASE is set; re.IGNORECASE is also accessible as re.I — the single-letter alias)"]
    - [ic_class_len,   re.IGNORECASE.__class__.__name__.__len__, [],             9,    "re.IGNORECASE.__class__.__name__.__len__() == 9 ('RegexFlag' has 9 characters; this confirms that IGNORECASE's class name length equals re.RegexFlag.__name__ length (both 9); the 9-character class name 'RegexFlag' is longer than its base class name 'IntFlag' (7 chars) by 2 characters — the 'Re' prefix that distinguishes the re-module flag class from the generic enum base class; length 9 is shared with re.RegexFlag.__name__ and also with io.RawIOBase.__name__ across modules)"]
    - [ic_value_int,   re.IGNORECASE.__int__,                     [],            2,    "int(re.IGNORECASE) == 2 (calling __int__() on the IGNORECASE flag member returns its integer value 2; as an IntFlag instance, IGNORECASE supports __int__ directly; this is the same value as the equality check: re.IGNORECASE == 2; the integer representation 2 is how re flags were originally expressed before RegexFlag was introduced — legacy code may pass integer 2 directly to re.compile(pattern, 2) to get case-insensitive matching; the __int__() call confirms the underlying integer value without comparison)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra162.RegexFlag_name_is_RegexFlag:
  description: "re.RegexFlag.__name__ == 'RegexFlag' — the class name is 'RegexFlag' with 9 characters; RegexFlag is the IntFlag enum introduced in Python 3.11 to collect all re module flag constants into a properly typed enum; before 3.11, re.IGNORECASE was a plain integer; the 9-character name 'RegexFlag' uses the 'Regex' prefix (5 chars) to identify the module context and 'Flag' suffix (4 chars) to identify the enum type; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.RegexFlag.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra162.RegexFlag_module_is_re:
  description: "re.RegexFlag.__module__ == 're' — RegexFlag's module is the public 're' namespace with only 2 characters; 're' is one of Python's shortest standard library module names; the 2-character module name mirrors io.RawIOBase.__module__ == 'io' (also 2 chars) established in io_extra165; RegexFlag is defined and exported at the 're' module level, not from a private submodule; the public module name contrasts with C-extension types like io.FileIO which have __module__ == '_io'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.RegexFlag.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra162.RegexFlag_base_is_IntFlag:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag's first base class is IntFlag from Python's enum module; IntFlag (7 chars) is shorter than RegexFlag (9 chars) — the base class has a shorter name than the derived class; IntFlag enables bitwise operations on enum members and treats them as integers; this base means all RegexFlag members (IGNORECASE, MULTILINE, DOTALL, etc.) support | for combining flags and & for testing flags; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.RegexFlag.__bases__[0].__name__.__eq__"
  args: ["IntFlag"]
  expected: true

invariant re_extra162.IGNORECASE_value_is_2:
  description: "re.IGNORECASE == 2 — the IGNORECASE flag has integer value 2 (= 1 << 1); as a power of 2, it can be combined with other RegexFlag members using bitwise OR without overlap; flag value 1 is re.ASCII, value 2 is re.IGNORECASE, value 4 is re.LOCALE, value 8 is re.UNICODE, value 16 is re.MULTILINE, etc.; the value 2 is the smallest flag value for a case-sensitivity modifier; re.IGNORECASE can also be specified as the string '(?i)' inline in a pattern; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.IGNORECASE.__eq__
  args: [2]
  expected: true

