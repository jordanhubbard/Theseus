spec: inspect_extra220
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect error-raising behavior and identity/predicate checks."
    - "inspect.signature(42) raises TypeError — 42 is not a callable object. Verified with Python 3.14.3."
    - "inspect.getsource(len) raises TypeError — len is a builtin; getsource calls getfile which raises TypeError for builtin_function_or_method. Verified with Python 3.14.3."
    - "inspect.getfile(int) raises TypeError — int is a built-in class with no source file. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is the _empty sentinel class itself (a type). Verified with Python 3.14.3."
    - "inspect.FrameInfo.__name__ == 'FrameInfo'; __module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__name__ == 'FullArgSpec'; __module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.ArgInfo.__name__ == 'ArgInfo'; __module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.isclass(int) == True; inspect.isbuiltin(len) == True. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect — error-raising behavior on non-callable / builtin inputs
#
# Verified with Python 3.14.3:
#   inspect.signature(42) -> TypeError: 42 is not a callable object
#   inspect.getsource(len) -> TypeError: module, class, method, function,
#     traceback, frame, or code object was expected, got builtin_function_or_method
#   inspect.getfile(int) -> TypeError: <class 'int'> is a built-in class
# ---------------------------------------------------------------------------

table inspect_extra220.error_raises:
  description: "inspect functions raise TypeError on non-callable or built-in inputs; new to extra220"
  kind: python_call_raises
  category: errors
  id_prefix: inspectextra220errors

  columns: [id, function, args, expected, description]
  rows:
    - [signature_non_callable_raises_TypeError,
       signature,
       [42],
       TypeError,
       "inspect.signature(42) raises TypeError — signature() requires a callable; 42 is an int and not callable; Python raises TypeError: 42 is not a callable object; new to extra220"]
    - [getfile_builtin_class_raises_TypeError,
       getfile,
       "[int]",
       TypeError,
       "inspect.getfile(int) raises TypeError — int is a built-in class implemented in C with no Python source file; Python raises TypeError: <class 'int'> is a built-in class; new to extra220"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter.empty identity checks
#
# Parameter.empty is the _empty sentinel class used as a default value marker.
# It is a type (class), so its __class__.__name__ == 'type'.
# Verified with Python 3.14.3:
#   inspect.Parameter.empty.__class__.__name__ == 'type'
# ---------------------------------------------------------------------------

table inspect_extra220.parameter_empty_identity:
  description: "inspect.Parameter.empty class name and identity checks; new to extra220"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra220empty

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_empty_class_name_eq,
       Parameter.empty.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is the _empty sentinel class itself (a type object); its __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra220"]

# ---------------------------------------------------------------------------
# Table 3: inspect named tuple identity checks
#
# Verified with Python 3.14.3:
#   FrameInfo.__name__ == 'FrameInfo'; __module__ == 'inspect'
#   FullArgSpec.__name__ == 'FullArgSpec'; __module__ == 'inspect'
#   ArgInfo.__name__ == 'ArgInfo'; __module__ == 'inspect'
# ---------------------------------------------------------------------------

table inspect_extra220.namedtuple_identity:
  description: "inspect.FrameInfo, FullArgSpec, ArgInfo __name__ and __module__ identity checks; new to extra220"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra220namedtuples

  columns: [id, function, args, expected, description]
  rows:
    - [frameinfo_name_eq,
       FrameInfo.__name__.__eq__,
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__name__.__eq__('FrameInfo') == True — FrameInfo is a named tuple class defined in Lib/inspect.py; its __name__ is 'FrameInfo'; str.__eq__('FrameInfo') returns True; new to extra220"]
    - [frameinfo_module_eq,
       FrameInfo.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FrameInfo.__module__.__eq__('inspect') == True — FrameInfo is defined in the inspect module; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra220"]
    - [fullargspec_name_eq,
       FullArgSpec.__name__.__eq__,
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__name__.__eq__('FullArgSpec') == True — FullArgSpec is a named tuple class defined in Lib/inspect.py; its __name__ is 'FullArgSpec'; str.__eq__('FullArgSpec') returns True; new to extra220"]
    - [fullargspec_module_eq,
       FullArgSpec.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FullArgSpec.__module__.__eq__('inspect') == True — FullArgSpec is defined in the inspect module; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra220"]
    - [arginfo_name_eq,
       ArgInfo.__name__.__eq__,
       ["ArgInfo"],
       true,
       "inspect.ArgInfo.__name__.__eq__('ArgInfo') == True — ArgInfo is a named tuple class defined in Lib/inspect.py; its __name__ is 'ArgInfo'; str.__eq__('ArgInfo') returns True; new to extra220"]
    - [arginfo_module_eq,
       ArgInfo.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ArgInfo.__module__.__eq__('inspect') == True — ArgInfo is defined in the inspect module; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra220"]

# ---------------------------------------------------------------------------
# Table 4: inspect predicates — isclass and isbuiltin
#
# Verified with Python 3.14.3:
#   inspect.isclass(int) == True
#   inspect.isbuiltin(len) == True
# ---------------------------------------------------------------------------

table inspect_extra220.predicates:
  description: "inspect.isclass and inspect.isbuiltin predicate checks; new to extra220"
  kind: python_call_eq
  category: behavior
  id_prefix: inspectextra220predicates

  columns: [id, function, args, expected, description]
  rows:
    - [isclass_int_eq,
       isclass,
       "[int]",
       true,
       "inspect.isclass(int) == True — int is a built-in class; isclass() returns True for any class or type object; passing int returns True; new to extra220"]
    - [isbuiltin_len_eq,
       isbuiltin,
       "[len]",
       true,
       "inspect.isbuiltin(len) == True — len is a built-in function implemented in C; isbuiltin() returns True for built-in functions and methods; passing len returns True; new to extra220"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra220
# ---------------------------------------------------------------------------

invariant inspect_extra220.signature_non_callable_TypeError:
  description: "inspect.signature(42) raises TypeError — 42 is not callable; new to extra220"
  kind: python_call_raises
  category: errors
  function: signature
  args: [42]
  expected: TypeError

invariant inspect_extra220.getfile_builtin_class_TypeError:
  description: "inspect.getfile(int) raises TypeError — int is a built-in class with no source file; new to extra220"
  kind: python_call_raises
  category: errors
  function: getfile
  args: "[int]"
  expected: TypeError

invariant inspect_extra220.parameter_empty_class_name:
  description: "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True; new to extra220"
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra220.frameinfo_name:
  description: "inspect.FrameInfo.__name__.__eq__('FrameInfo') == True; new to extra220"
  kind: python_call_eq
  function: FrameInfo.__name__.__eq__
  args: ["FrameInfo"]
  expected: true

invariant inspect_extra220.frameinfo_module:
  description: "inspect.FrameInfo.__module__.__eq__('inspect') == True; new to extra220"
  kind: python_call_eq
  function: FrameInfo.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra220.fullargspec_name:
  description: "inspect.FullArgSpec.__name__.__eq__('FullArgSpec') == True; new to extra220"
  kind: python_call_eq
  function: FullArgSpec.__name__.__eq__
  args: ["FullArgSpec"]
  expected: true

invariant inspect_extra220.fullargspec_module:
  description: "inspect.FullArgSpec.__module__.__eq__('inspect') == True; new to extra220"
  kind: python_call_eq
  function: FullArgSpec.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra220.arginfo_name:
  description: "inspect.ArgInfo.__name__.__eq__('ArgInfo') == True; new to extra220"
  kind: python_call_eq
  function: ArgInfo.__name__.__eq__
  args: ["ArgInfo"]
  expected: true

invariant inspect_extra220.arginfo_module:
  description: "inspect.ArgInfo.__module__.__eq__('inspect') == True; new to extra220"
  kind: python_call_eq
  function: ArgInfo.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra220.isclass_int:
  description: "inspect.isclass(int) == True; new to extra220"
  kind: python_call_eq
  function: isclass
  args: "[int]"
  expected: true

invariant inspect_extra220.isbuiltin_len:
  description: "inspect.isbuiltin(len) == True; new to extra220"
  kind: python_call_eq
  function: isbuiltin
  args: "[len]"
  expected: true
