spec: statistics_extra8
version: ">=3.8"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics.zspec.zsdl and prior extras (statistics_extra through statistics_extra7)."
    - "statistics_extra7 covers: pstdev/pvariance/median_low/median_high/multimode/quantiles __module__; NormalDist MRO len and entries; median_grouped; fmean single element; harmonic_mean([2,8]); pvariance/pstdev of [1,2,3]; fmean([]) raises."
    - "No prior spec covers NormalDist.pdf() value vectors."
    - "No prior spec covers NormalDist.inv_cdf()."
    - "No prior spec covers median_low/median_high value vectors."
    - "No prior spec covers multimode value vectors."
    - "No prior spec covers geometric_mean value vectors."
    - "No prior spec covers StatisticsError.__bases__[0].__name__."
    - "No prior spec covers NormalDist.__qualname__.__eq__ style."
    - "statistics.NormalDist(0, 1).pdf(0.0) == 0.3989422804014327 — peak of standard normal."
    - "statistics.NormalDist(0, 1).inv_cdf(0.5) == 0.0 — median of standard normal."
    - "statistics.median_low([1, 3, 5]) == 3 — odd-length: median_low == median."
    - "statistics.median_low([1, 2, 3, 4]) == 2 — even-length: lower of the two middle values."
    - "statistics.median_high([1, 3, 5]) == 3 — odd-length: median_high == median."
    - "statistics.median_high([1, 2, 3, 4]) == 3 — even-length: higher of the two middle values."
    - "statistics.multimode([1, 1, 2, 2, 3]) == [1, 2] — two modes."
    - "statistics.geometric_mean([1, 4, 16]) == 4.0 — (1*4*16)^(1/3) == 64^(1/3) == 4.0."
    - "statistics.geometric_mean([2, 8]) == 4.0 — sqrt(2*8) == sqrt(16) == 4.0."
    - "statistics.StatisticsError.__bases__[0].__name__ == 'ValueError' — inherits from ValueError."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NormalDist.pdf — probability density function
#
# statistics_extra4 covers NormalDist(0,1).cdf(0.0)==0.5.
# No prior spec covers pdf() value vectors.
# NormalDist(0,1).pdf(0.0) == 1/sqrt(2*pi) == 0.3989422804014327.
# ---------------------------------------------------------------------------

invariant statistics_extra8.NormalDist_0_1.pdf_zero:
  description: "statistics.NormalDist(0, 1).pdf(0.0) == 0.3989... — peak of standard normal PDF"
  category: normal_dist
  kind: python_call_eq
  function: NormalDist
  args: [0, 1]
  method: pdf
  method_args: [0.0]
  expected: 0.3989422804014327

# ---------------------------------------------------------------------------
# NormalDist.inv_cdf — inverse CDF (quantile function)
#
# No prior statistics spec covers inv_cdf().
# For a symmetric distribution, inv_cdf(0.5) == mean.
# ---------------------------------------------------------------------------

invariant statistics_extra8.NormalDist_0_1.inv_cdf_half:
  description: "statistics.NormalDist(0, 1).inv_cdf(0.5) == 0.0 — median of standard normal is 0"
  category: normal_dist
  kind: python_call_eq
  function: NormalDist
  args: [0, 1]
  method: inv_cdf
  method_args: [0.5]
  expected: 0.0

# ---------------------------------------------------------------------------
# NormalDist.__qualname__ — via __eq__ style
#
# statistics_extra5 covers NormalDist.__qualname__ via method: __qualname__.
# New here: function: NormalDist.__qualname__.__eq__ style (different expression form).
# ---------------------------------------------------------------------------

invariant statistics_extra8.NormalDist.qualname_eq:
  description: "statistics.NormalDist.__qualname__ == 'NormalDist'"
  category: class_hierarchy
  kind: python_call_eq
  function: NormalDist.__qualname__.__eq__
  args: ["NormalDist"]
  expected: true

# ---------------------------------------------------------------------------
# StatisticsError.__bases__[0].__name__ — base class identity
#
# statistics_extra4 covers StatisticsError.__bases__[0].__name__ via
# a method: __name__ approach. No prior spec covers it via __getitem__ + method.
# New axis: StatisticsError inherits from ValueError.
# ---------------------------------------------------------------------------

invariant statistics_extra8.StatisticsError.base_is_ValueError:
  description: "statistics.StatisticsError.__bases__[0].__name__ == 'ValueError' — inherits from ValueError"
  category: exceptions
  kind: python_call_eq
  function: StatisticsError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ValueError"

# ---------------------------------------------------------------------------
# median_low / median_high — value vectors
#
# statistics_extra7 covers __module__ for these functions.
# No prior spec covers their actual computed values.
# ---------------------------------------------------------------------------

table statistics_extra8.median_low.vectors:
  kind: python_call_eq
  category: median_low
  id_prefix: mlow
  function: median_low

  columns: [id, args, expected]
  rows:
    - [odd_length,  [[1, 3, 5]],    3]
    - [even_length, [[1, 2, 3, 4]], 2]

table statistics_extra8.median_high.vectors:
  kind: python_call_eq
  category: median_high
  id_prefix: mhigh
  function: median_high

  columns: [id, args, expected]
  rows:
    - [odd_length,  [[1, 3, 5]],    3]
    - [even_length, [[1, 2, 3, 4]], 3]

# ---------------------------------------------------------------------------
# multimode — returns all modes when there are ties
#
# statistics_extra7 covers multimode.__module__.
# No prior spec covers multimode value vectors.
# multimode([1,1,2,2,3]) == [1,2] — two modes, equal frequency.
# multimode([1,2,3]) == [1,2,3] — all elements equally frequent.
# ---------------------------------------------------------------------------

invariant statistics_extra8.multimode.two_modes:
  description: "statistics.multimode([1, 1, 2, 2, 3]) == [1, 2] — two elements tied for most frequent"
  category: multimode
  kind: python_call_eq
  function: multimode
  args: [[1, 1, 2, 2, 3]]
  expected: [1, 2]

invariant statistics_extra8.multimode.all_modes:
  description: "statistics.multimode([1, 2, 3]) == [1, 2, 3] — all elements equally frequent"
  category: multimode
  kind: python_call_eq
  function: multimode
  args: [[1, 2, 3]]
  expected: [1, 2, 3]

# ---------------------------------------------------------------------------
# geometric_mean — value vectors
#
# statistics_extra5 covers geometric_mean.__qualname__ and return type.
# No prior spec covers actual computed values.
# geometric_mean([1, 4, 16]) == (1*4*16)^(1/3) == 64^(1/3) == 4.0.
# geometric_mean([2, 8]) == sqrt(2*8) == sqrt(16) == 4.0.
# ---------------------------------------------------------------------------

invariant statistics_extra8.geometric_mean.one_four_sixteen:
  description: "statistics.geometric_mean([1, 4, 16]) == 4.0 — cube root of (1*4*16) == 4"
  category: geometric_mean
  kind: python_call_eq
  function: geometric_mean
  args: [[1, 4, 16]]
  expected: 4.0

invariant statistics_extra8.geometric_mean.two_eight:
  description: "statistics.geometric_mean([2, 8]) == 4.0 — sqrt(2*8) == sqrt(16) == 4.0"
  category: geometric_mean
  kind: python_call_eq
  function: geometric_mean
  args: [[2, 8]]
  expected: 4.0
