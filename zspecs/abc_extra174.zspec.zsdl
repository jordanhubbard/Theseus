spec: abc_extra174
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.ABCMeta dunder methods — abc.ABCMeta.__new__.__name__=='__new__' (len=7); abc.ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15); abc.ABCMeta.__subclasses__.__name__=='__subclasses__' (len=14); abc.ABCMeta.__module__.__eq__('abc')==True (ABCMeta is defined in abc.py); abc.ABCMeta.__qualname__.__eq__('ABCMeta')==True (top-level class); abc.ABC.__init_subclass__.__name__=='__init_subclass__' (len=17); abc.ABC.__subclasshook__.__name__=='__subclasshook__' (len=16)."
    - "abc.ABCMeta.__new__.__name__ == '__new__' (len=7: _-_-n-e-w-_-_ = 7). abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15: ABCMeta=7+'.'=1+'__new__'=7=15). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__subclasses__.__name__ == '__subclasses__' (len=14: _(1)_(2)s(3)u(4)b(5)c(6)l(7)a(8)s(9)s(10)e(11)s(12)_(13)_(14) = 14 chars). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__module__ == 'abc' (top-level module where ABCMeta is defined). abc.ABCMeta.__qualname__ == 'ABCMeta' (top-level class, no enclosing class or function). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__init_subclass__.__name__ == '__init_subclass__' (len=17: _(1)_(2)i(3)n(4)i(5)t(6)_(7)s(8)u(9)b(10)c(11)l(12)a(13)s(14)s(15)_(16)_(17)=17). abc.ABC.__subclasshook__.__name__ == '__subclasshook__' (len=16: _(1)_(2)s(3)u(4)b(5)c(6)l(7)a(8)s(9)s(10)h(11)o(12)o(13)k(14)_(15)_(16)=16). NAME LENGTHS: __subclasshook__=16 < __init_subclass__=17. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABCMeta.__new__ name and qualname identity
#
# ABCMeta.__new__.__name__ == '__new__' (len=7)
# ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15)
#
# ABCMeta.__new__ is the constructor method called when creating a new ABCMeta
# class. Its qualname includes the enclosing class name.
# New to extra174.
# ---------------------------------------------------------------------------

table abc_extra174.abcmeta_new_identity:
  description: "ABCMeta.__new__.__name__ '__new__' len 7; ABCMeta.__new__.__qualname__ 'ABCMeta.__new__' len 15; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetadunders174

  columns: [id, function, args, expected, description]
  rows:
    - [new_name_eq,
       ABCMeta.__new__.__name__.__eq__,
       ["__new__"],
       true,
       "abc.ABCMeta.__new__.__name__.__eq__('__new__') == True — ABCMeta.__new__ is the constructor invoked when creating a new class with ABCMeta as its metaclass; its __name__ is '__new__' (7 chars: _-_-n-e-w-_-_); str.__eq__('__new__') returns True; new to extra174"]
    - [new_name_len_7,
       ABCMeta.__new__.__name__.__len__,
       [],
       7,
       "abc.ABCMeta.__new__.__name__.__len__() == 7 — '__new__' has 7 characters: two leading underscores + 'new'=3 + two trailing underscores = 7; str.__len__() returns 7; new to extra174"]
    - [new_qualname_eq,
       ABCMeta.__new__.__qualname__.__eq__,
       ["ABCMeta.__new__"],
       true,
       "abc.ABCMeta.__new__.__qualname__.__eq__('ABCMeta.__new__') == True — __qualname__ is the qualified name including the enclosing class; for a method on ABCMeta, it is 'ABCMeta.__new__' (15 chars: ABCMeta=7+'.'=1+'__new__'=7=15); str.__eq__('ABCMeta.__new__') returns True; new to extra174"]
    - [new_qualname_len_15,
       ABCMeta.__new__.__qualname__.__len__,
       [],
       15,
       "abc.ABCMeta.__new__.__qualname__.__len__() == 15 — 'ABCMeta.__new__' has 15 characters: 'ABCMeta'=7 + '.'=1 + '__new__'=7 = 15; str.__len__() returns 15; new to extra174"]
    - [new_qualname_class,
       ABCMeta.__new__.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "abc.ABCMeta.__new__.__qualname__.__class__.__name__.__eq__('str') == True — __qualname__ is a str object; its class name is 'str'; str.__eq__('str') returns True; new to extra174"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABCMeta class-level identity
#
# ABCMeta.__module__ == 'abc'
# ABCMeta.__qualname__ == 'ABCMeta'
# ABCMeta.__subclasses__.__name__ == '__subclasses__' (len=14)
#
# ABCMeta is defined at the top level of abc.py. __subclasses__ is an inherited
# built-in method on every class. New to extra174.
# ---------------------------------------------------------------------------

table abc_extra174.abcmeta_class_identity:
  description: "ABCMeta.__module__ 'abc'; ABCMeta.__qualname__ 'ABCMeta'; ABCMeta.__subclasses__.__name__ '__subclasses__' len 14; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetadunders174

  columns: [id, function, args, expected, description]
  rows:
    - [module_eq_abc,
       ABCMeta.__module__.__eq__,
       ["abc"],
       true,
       "abc.ABCMeta.__module__.__eq__('abc') == True — ABCMeta is defined in abc.py at the top level of the abc package; its __module__ is 'abc'; str.__eq__('abc') returns True; new to extra174"]
    - [qualname_eq_abcmeta,
       ABCMeta.__qualname__.__eq__,
       ["ABCMeta"],
       true,
       "abc.ABCMeta.__qualname__.__eq__('ABCMeta') == True — ABCMeta is a top-level class with no enclosing class or function; its __qualname__ equals its __name__ which is 'ABCMeta'; str.__eq__('ABCMeta') returns True; new to extra174"]
    - [qualname_len_7,
       ABCMeta.__qualname__.__len__,
       [],
       7,
       "abc.ABCMeta.__qualname__.__len__() == 7 — 'ABCMeta' has 7 characters: A-B-C-M-e-t-a; same length as '__new__'=7; str.__len__() returns 7; new to extra174"]
    - [subclasses_name_eq,
       ABCMeta.__subclasses__.__name__.__eq__,
       ["__subclasses__"],
       true,
       "abc.ABCMeta.__subclasses__.__name__.__eq__('__subclasses__') == True — __subclasses__ is a built-in method inherited by every class that returns a list of immediate subclasses; its __name__ is '__subclasses__' (14 chars); str.__eq__('__subclasses__') returns True; new to extra174"]
    - [subclasses_name_len_14,
       ABCMeta.__subclasses__.__name__.__len__,
       [],
       14,
       "abc.ABCMeta.__subclasses__.__name__.__len__() == 14 — '__subclasses__' has 14 characters: _(1)_(2)s(3)u(4)b(5)c(6)l(7)a(8)s(9)s(10)e(11)s(12)_(13)_(14) = 14; str.__len__() returns 14; new to extra174"]

# ---------------------------------------------------------------------------
# Table 3: abc.ABC dunder methods — __init_subclass__ and __subclasshook__
#
# ABC.__init_subclass__.__name__ == '__init_subclass__' (len=17)
# ABC.__subclasshook__.__name__ == '__subclasshook__' (len=16)
#
# __init_subclass__ is called when a class is subclassed; __subclasshook__
# is the ABC hook for virtual subclass checks. NAME LENGTHS: hook=16 < init_subclass=17.
# New to extra174.
# ---------------------------------------------------------------------------

table abc_extra174.abc_dunder_methods:
  description: "ABC.__init_subclass__.__name__ '__init_subclass__' len 17; ABC.__subclasshook__.__name__ '__subclasshook__' len 16; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetadunders174

  columns: [id, function, args, expected, description]
  rows:
    - [init_subclass_name_eq,
       ABC.__init_subclass__.__name__.__eq__,
       ["__init_subclass__"],
       true,
       "abc.ABC.__init_subclass__.__name__.__eq__('__init_subclass__') == True — __init_subclass__ is a classmethod called on a base class when it is subclassed; Python 3.6+; its __name__ is '__init_subclass__' (17 chars: __=2+init_subclass=13+__=2=17); str.__eq__('__init_subclass__') returns True; new to extra174"]
    - [init_subclass_name_len_17,
       ABC.__init_subclass__.__name__.__len__,
       [],
       17,
       "abc.ABC.__init_subclass__.__name__.__len__() == 17 — '__init_subclass__' has 17 characters: two leading underscores + 'init_subclass'=13 + two trailing underscores = 17; longer than '__subclasshook__'=16; str.__len__() returns 17; new to extra174"]
    - [subclasshook_name_eq,
       ABC.__subclasshook__.__name__.__eq__,
       ["__subclasshook__"],
       true,
       "abc.ABC.__subclasshook__.__name__.__eq__('__subclasshook__') == True — __subclasshook__ is a classmethod on ABCMeta subclasses that can override isinstance() checks; its __name__ is '__subclasshook__' (16 chars: __=2+subclasshook=12+__=2=16); str.__eq__('__subclasshook__') returns True; new to extra174"]
    - [subclasshook_name_len_16,
       ABC.__subclasshook__.__name__.__len__,
       [],
       16,
       "abc.ABC.__subclasshook__.__name__.__len__() == 16 — '__subclasshook__' has 16 characters: _(1)_(2)s(3)u(4)b(5)c(6)l(7)a(8)s(9)s(10)h(11)o(12)o(13)k(14)_(15)_(16) = 16; str.__len__() returns 16; shorter than __init_subclass__=17; new to extra174"]
    - [init_subclass_len_17,
       ABC.__init_subclass__.__name__.__len__,
       [],
       17,
       "abc.ABC.__init_subclass__.__name__.__len__() == 17 — '__init_subclass__' has 17 characters: _(1)_(2)i(3)n(4)i(5)t(6)_(7)s(8)u(9)b(10)c(11)l(12)a(13)s(14)s(15)_(16)_(17) = 17; NAME LENGTHS: __subclasshook__=16 < __init_subclass__=17; str.__len__() returns 17; new to extra174"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra174
# ---------------------------------------------------------------------------

invariant abc_extra174.abcmeta_new_name_eq:
  description: "abc.ABCMeta.__new__.__name__ == '__new__' — metaclass constructor; name len=7 (same as ABCMeta qualname len); new to extra174"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__new__.__name__.__eq__
  args: ["__new__"]
  expected: true

invariant abc_extra174.abcmeta_new_qualname_eq:
  description: "abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' — qualified name with enclosing class; len=15 (ABCMeta=7+'.'=1+'__new__'=7=15); new to extra174"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__new__.__qualname__.__eq__
  args: ["ABCMeta.__new__"]
  expected: true

invariant abc_extra174.abcmeta_module_eq_abc:
  description: "abc.ABCMeta.__module__ == 'abc' — ABCMeta is defined at the top level of the abc module; new to extra174"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra174.abcmeta_qualname_eq:
  description: "abc.ABCMeta.__qualname__ == 'ABCMeta' — top-level class; __qualname__ equals __name__ for non-nested classes; new to extra174"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__qualname__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra174.abcmeta_subclasses_name_eq:
  description: "abc.ABCMeta.__subclasses__.__name__ == '__subclasses__' — built-in method on all classes returning immediate subclasses list; name len=14; new to extra174"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__subclasses__.__name__.__eq__
  args: ["__subclasses__"]
  expected: true

invariant abc_extra174.abc_init_subclass_name_eq:
  description: "abc.ABC.__init_subclass__.__name__ == '__init_subclass__' — classmethod called when ABC is subclassed; name len=17; new to extra174"
  category: identity
  kind: python_call_eq
  function: ABC.__init_subclass__.__name__.__eq__
  args: ["__init_subclass__"]
  expected: true

invariant abc_extra174.abc_subclasshook_name_len_16:
  description: "abc.ABC.__subclasshook__.__name__.__len__() == 16 — '__subclasshook__' has 16 chars (_(1)_(2)s..k(14)_(15)_(16)); shorter than __init_subclass__=17; new to extra174"
  category: identity
  kind: python_call_eq
  function: ABC.__subclasshook__.__name__.__len__
  args: []
  expected: 16

invariant abc_extra174.abc_subclasshook_name_eq:
  description: "abc.ABC.__subclasshook__.__name__ == '__subclasshook__' — ABC hook for virtual subclass isinstance() checks; name len=16; new to extra174"
  category: identity
  kind: python_call_eq
  function: ABC.__subclasshook__.__name__.__eq__
  args: ["__subclasshook__"]
  expected: true
