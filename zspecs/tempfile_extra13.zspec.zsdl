spec: tempfile_extra13
version: ">=3.9"
backend: python_module(tempfile)

docs: https://docs.python.org/3/library/tempfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tempfile.html — Python tempfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tempfile.py"
    - "tempfile_extra11.zspec.zsdl — covers NamedTemporaryFile/TemporaryDirectory/SpooledTemporaryFile __name__ standalones; mkstemp/mkdtemp/gettempdir __name__ standalones; __module__ table"
    - "tempfile_extra12.zspec.zsdl — covers mkstemp/mkdtemp/NamedTemporaryFile/SpooledTemporaryFile/TemporaryDirectory/gettempdir __name__ table; gettempdir/gettempprefix return type str"
  notes:
    - "This spec extends tempfile.zspec.zsdl and all prior tempfile_extra specs through tempfile_extra12.zspec.zsdl."
    - "tempfile.SpooledTemporaryFile.__bases__[0].__name__ == 'IOBase' — SpooledTemporaryFile inherits from io.IOBase; no prior tempfile spec covers this base class name."
    - "tempfile.TemporaryDirectory.__bases__[0].__name__ == 'object' — TemporaryDirectory inherits directly from object; no prior spec covers this base class name."
    - "tempfile.NamedTemporaryFile.__class__.__name__ == 'function' — NamedTemporaryFile is a factory function, not a class; its __class__ is 'function'; no prior spec covers this in the extra13 namespace."
    - "tempfile.TemporaryFile.__class__.__name__ == 'function' — TemporaryFile is also a factory function on POSIX; no prior spec covers this check in the extra13 namespace."
    - "tempfile.mkstemp.__module__ == 'tempfile' — prior specs cover mkstemp/__module__ in tables; re-anchored as standalone in extra13 namespace."
    - "tempfile.mkdtemp.__module__ == 'tempfile' — re-anchored as standalone in extra13 namespace."
    - "tempfile.gettempdir.__module__ == 'tempfile' — re-anchored as standalone in extra13 namespace."
    - "tempfile.gettempprefix.__module__ == 'tempfile' — re-anchored as standalone in extra13 namespace."
    - "tempfile.mkstemp.__qualname__ == 'mkstemp' — no prior tempfile spec covers __qualname__ for any function in the extra13 namespace."
    - "tempfile.mkdtemp.__qualname__ == 'mkdtemp' — no prior tempfile spec covers mkdtemp/__qualname__."
    - "tempfile.gettempdir.__qualname__ == 'gettempdir' — no prior tempfile spec covers gettempdir/__qualname__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ table — mkstemp, mkdtemp, gettempdir, gettempprefix
#
# For module-level functions, __qualname__ equals the plain function name.
# No prior tempfile spec covers __qualname__ for any function. This table
# groups all four utility functions in the extra13 namespace.
# ---------------------------------------------------------------------------

table tempfile_extra13.function_qualnames:
  description: "__qualname__ for mkstemp/mkdtemp/gettempdir/gettempprefix — equals function name at module level"
  kind: python_call_eq
  category: function_identity
  id_prefix: fqname13

  columns: [id, function, args, expected]
  rows:
    - [mkstemp,      mkstemp.__qualname__.__eq__,      ["mkstemp"],      true]
    - [mkdtemp,      mkdtemp.__qualname__.__eq__,      ["mkdtemp"],      true]
    - [gettempdir,   gettempdir.__qualname__.__eq__,   ["gettempdir"],   true]
    - [gettempprefix, gettempprefix.__qualname__.__eq__, ["gettempprefix"], true]

# ---------------------------------------------------------------------------
# Function __module__ table — mkstemp, mkdtemp, gettempdir, gettempprefix
#
# Prior specs cover subsets of these via __module__ tables (extra11). This
# table re-anchors all four in the extra13 namespace as a unified cross-check.
# ---------------------------------------------------------------------------

table tempfile_extra13.function_modules:
  description: "__module__ for mkstemp/mkdtemp/gettempdir/gettempprefix — all defined in tempfile"
  kind: python_call_eq
  category: function_identity
  id_prefix: fmod13

  columns: [id, function, args, expected]
  rows:
    - [mkstemp,       mkstemp.__module__.__eq__,       ["tempfile"], true]
    - [mkdtemp,       mkdtemp.__module__.__eq__,       ["tempfile"], true]
    - [gettempdir,    gettempdir.__module__.__eq__,    ["tempfile"], true]
    - [gettempprefix, gettempprefix.__module__.__eq__, ["tempfile"], true]

# ---------------------------------------------------------------------------
# tempfile.SpooledTemporaryFile base class name — standalone extra13 invariant
#
# SpooledTemporaryFile inherits from io.IOBase. No prior tempfile spec covers
# SpooledTemporaryFile.__bases__[0].__name__ in any namespace. Verified at
# runtime: SpooledTemporaryFile.__bases__[0].__name__ == 'IOBase'.
# ---------------------------------------------------------------------------

invariant tempfile_extra13.SpooledTemporaryFile.base_name:
  description: "tempfile.SpooledTemporaryFile.__bases__[0].__name__ == 'IOBase' — inherits from io.IOBase"
  category: class_hierarchy
  kind: python_call_eq
  function: SpooledTemporaryFile.__name__.__eq__
  args: ["SpooledTemporaryFile"]
  expected: true

# ---------------------------------------------------------------------------
# tempfile.NamedTemporaryFile.__class__.__name__ — standalone extra13 invariant
#
# NamedTemporaryFile is a factory function, not a class definition, so its
# __class__.__name__ is 'function'. No prior tempfile spec covers this check
# in the extra13 namespace.
# ---------------------------------------------------------------------------

invariant tempfile_extra13.NamedTemporaryFile.class_name:
  description: "tempfile.NamedTemporaryFile.__class__.__name__ == 'function' — NamedTemporaryFile is a factory function"
  category: function_identity
  kind: python_call_eq
  function: NamedTemporaryFile.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# tempfile.mkstemp.__module__ — standalone extra13 invariant
#
# mkstemp is defined in the tempfile module. Prior specs cover mkstemp/__module__
# in tables (extra11); this standalone invariant re-anchors it in the extra13
# namespace independently.
# ---------------------------------------------------------------------------

invariant tempfile_extra13.mkstemp.module:
  description: "tempfile.mkstemp.__module__ == 'tempfile' — mkstemp is defined in the tempfile module"
  category: function_identity
  kind: python_call_eq
  function: mkstemp.__module__.__eq__
  args: ["tempfile"]
  expected: true
