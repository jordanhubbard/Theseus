spec: threading_extra268
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.current_thread, main_thread, active_count, enumerate, settrace, setprofile are all pure Python functions: __class__.__name__ == 'function'."
    - "threading.stack_size is a C builtin: __class__.__name__ == 'builtin_function_or_method', __module__ == '_thread'."
    - "All pure Python functions have __module__ == 'threading' (len=9)."
    - "current_thread.__name__ (14) is longest among the pure Python functions in this spec."
    - "settrace.__name__ (8) == setprofile.__name__[:8]... actually settrace(8) < setprofile(10) < active_count(12) < main_thread(11) < current_thread(14)."
    - "enumerate.__name__ (9) == module name 'threading'[-9:]... actually enumerate(9) < setprofile(10) < main_thread(11) < active_count(12) < current_thread(14)."
    - "settrace.__name__ (8) is shortest among pure Python functions in spec."
    - "stack_size.__name__ (10) == setprofile.__name__ (10) — tied; but stack_size is a C builtin from _thread."
    - "All qualnames equal names (module-level, no nesting)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading module-level functions: current_thread, main_thread, active_count, enumerate
#
# All plain Python functions in threading (len=9).
# current_thread.__name__ (14) is longest in table.
# settrace.__name__ (8) tied... but settrace is in the next table.
# enumerate.__name__ (9) equals module name length.
# main_thread.__name__ (11).
# active_count.__name__ (12).
# current_thread.__name__ (14).
# ---------------------------------------------------------------------------

table threading_extra268.thread_query_functions_identity:
  description: "threading.current_thread(14), main_thread(11), active_count(12), enumerate(9) identity — all pure Python functions in threading(9); current_thread(14) longest; enumerate(9) equals module name length; main_thread(11) < active_count(12) < current_thread(14); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex268q

  columns: [id, function, args, expected, description]
  rows:
    - [ct_name_eq,         current_thread.__name__.__eq__,             ["current_thread"],             true, "threading.current_thread.__name__ == 'current_thread'; verified with Python 3.14.3"]
    - [ct_name_len,        current_thread.__name__.__len__,            [],                             14,   "threading.current_thread.__name__.__len__() == 14 — longest name among pure Python functions in spec; verified with Python 3.14.3"]
    - [ct_qn_eq,           current_thread.__qualname__.__eq__,         ["current_thread"],             true, "threading.current_thread.__qualname__ == 'current_thread' — qualname equals name; verified with Python 3.14.3"]
    - [ct_mod_eq,          current_thread.__module__.__eq__,           ["threading"],                  true, "threading.current_thread.__module__ == 'threading'; verified with Python 3.14.3"]
    - [ct_mod_len,         current_thread.__module__.__len__,          [],                             9,    "threading.current_thread.__module__.__len__() == 9; verified with Python 3.14.3"]
    - [ct_cls_eq,          current_thread.__class__.__name__.__eq__,   ["function"],                   true, "threading.current_thread.__class__.__name__ == 'function' — pure Python function; verified with Python 3.14.3"]
    - [mt_name_eq,         main_thread.__name__.__eq__,                ["main_thread"],                true, "threading.main_thread.__name__ == 'main_thread'; verified with Python 3.14.3"]
    - [mt_name_len,        main_thread.__name__.__len__,               [],                             11,   "threading.main_thread.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [mt_qn_eq,           main_thread.__qualname__.__eq__,            ["main_thread"],                true, "threading.main_thread.__qualname__ == 'main_thread' — qualname equals name; verified with Python 3.14.3"]
    - [mt_mod_eq,          main_thread.__module__.__eq__,              ["threading"],                  true, "threading.main_thread.__module__ == 'threading'; verified with Python 3.14.3"]
    - [mt_cls_eq,          main_thread.__class__.__name__.__eq__,      ["function"],                   true, "threading.main_thread.__class__.__name__ == 'function' — pure Python function; verified with Python 3.14.3"]
    - [ac_name_eq,         active_count.__name__.__eq__,               ["active_count"],               true, "threading.active_count.__name__ == 'active_count'; verified with Python 3.14.3"]
    - [ac_name_len,        active_count.__name__.__len__,              [],                             12,   "threading.active_count.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [ac_qn_eq,           active_count.__qualname__.__eq__,           ["active_count"],               true, "threading.active_count.__qualname__ == 'active_count' — qualname equals name; verified with Python 3.14.3"]
    - [ac_mod_eq,          active_count.__module__.__eq__,             ["threading"],                  true, "threading.active_count.__module__ == 'threading'; verified with Python 3.14.3"]
    - [ac_cls_eq,          active_count.__class__.__name__.__eq__,     ["function"],                   true, "threading.active_count.__class__.__name__ == 'function' — pure Python function; verified with Python 3.14.3"]
    - [en_name_eq,         enumerate.__name__.__eq__,                  ["enumerate"],                  true, "threading.enumerate.__name__ == 'enumerate'; verified with Python 3.14.3"]
    - [en_name_len,        enumerate.__name__.__len__,                 [],                             9,    "threading.enumerate.__name__.__len__() == 9 — equals module name 'threading' length; verified with Python 3.14.3"]
    - [en_qn_eq,           enumerate.__qualname__.__eq__,              ["enumerate"],                  true, "threading.enumerate.__qualname__ == 'enumerate' — qualname equals name; verified with Python 3.14.3"]
    - [en_mod_eq,          enumerate.__module__.__eq__,                ["threading"],                  true, "threading.enumerate.__module__ == 'threading'; verified with Python 3.14.3"]
    - [en_cls_eq,          enumerate.__class__.__name__.__eq__,        ["function"],                   true, "threading.enumerate.__class__.__name__ == 'function' — pure Python function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# threading settrace, setprofile, stack_size identity
#
# settrace and setprofile are pure Python functions in threading.
# stack_size is a C builtin from _thread (__class__.__name__ == 'builtin_function_or_method').
# settrace.__name__ (8) is shortest in spec.
# setprofile.__name__ (10) == stack_size.__name__ (10) — tied.
# stack_size.__module__ == '_thread' — from C extension.
# ---------------------------------------------------------------------------

table threading_extra268.settrace_setprofile_stacksize_identity:
  description: "threading.settrace(8), setprofile(10), stack_size(10) identity — settrace and setprofile are pure Python functions in threading(9); stack_size is C builtin from _thread; settrace(8) shortest in spec; setprofile==stack_size names(10) tied; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex268s

  columns: [id, function, args, expected, description]
  rows:
    - [st_name_eq,         settrace.__name__.__eq__,                   ["settrace"],                   true, "threading.settrace.__name__ == 'settrace'; verified with Python 3.14.3"]
    - [st_name_len,        settrace.__name__.__len__,                  [],                             8,    "threading.settrace.__name__.__len__() == 8 — shortest name in spec; verified with Python 3.14.3"]
    - [st_qn_eq,           settrace.__qualname__.__eq__,               ["settrace"],                   true, "threading.settrace.__qualname__ == 'settrace' — qualname equals name; verified with Python 3.14.3"]
    - [st_mod_eq,          settrace.__module__.__eq__,                 ["threading"],                  true, "threading.settrace.__module__ == 'threading'; verified with Python 3.14.3"]
    - [st_cls_eq,          settrace.__class__.__name__.__eq__,         ["function"],                   true, "threading.settrace.__class__.__name__ == 'function' — pure Python function; verified with Python 3.14.3"]
    - [sp_name_eq,         setprofile.__name__.__eq__,                 ["setprofile"],                 true, "threading.setprofile.__name__ == 'setprofile'; verified with Python 3.14.3"]
    - [sp_name_len,        setprofile.__name__.__len__,                [],                             10,   "threading.setprofile.__name__.__len__() == 10 — tied with stack_size; verified with Python 3.14.3"]
    - [sp_qn_eq,           setprofile.__qualname__.__eq__,             ["setprofile"],                 true, "threading.setprofile.__qualname__ == 'setprofile' — qualname equals name; verified with Python 3.14.3"]
    - [sp_mod_eq,          setprofile.__module__.__eq__,               ["threading"],                  true, "threading.setprofile.__module__ == 'threading'; verified with Python 3.14.3"]
    - [sp_cls_eq,          setprofile.__class__.__name__.__eq__,       ["function"],                   true, "threading.setprofile.__class__.__name__ == 'function' — pure Python function; verified with Python 3.14.3"]
    - [ss_name_eq,         stack_size.__name__.__eq__,                 ["stack_size"],                 true, "threading.stack_size.__name__ == 'stack_size'; verified with Python 3.14.3"]
    - [ss_name_len,        stack_size.__name__.__len__,                [],                             10,   "threading.stack_size.__name__.__len__() == 10 — tied with setprofile; verified with Python 3.14.3"]
    - [ss_qn_eq,           stack_size.__qualname__.__eq__,             ["stack_size"],                 true, "threading.stack_size.__qualname__ == 'stack_size' — qualname equals name; verified with Python 3.14.3"]
    - [ss_mod_eq,          stack_size.__module__.__eq__,               ["_thread"],                    true, "threading.stack_size.__module__ == '_thread' — C builtin from _thread extension; verified with Python 3.14.3"]
    - [ss_mod_len,         stack_size.__module__.__len__,              [],                             7,    "threading.stack_size.__module__.__len__() == 7 — '_thread' len=7; verified with Python 3.14.3"]
    - [ss_cls_eq,          stack_size.__class__.__name__.__eq__,       ["builtin_function_or_method"], true, "threading.stack_size.__class__.__name__ == 'builtin_function_or_method' — C builtin; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra268
# ---------------------------------------------------------------------------

invariant threading_extra268.current_thread_is_longest_name:
  description: "threading.current_thread.__name__.__len__() == 14 — longest name among the pure Python functions in this spec; main_thread(11) < active_count(12) < current_thread(14)"
  category: identity
  kind: python_call_eq
  function: current_thread.__name__.__len__
  args: []
  expected: 14

invariant threading_extra268.settrace_is_shortest_name:
  description: "threading.settrace.__name__.__len__() == 8 — shortest name in spec; shorter than enumerate(9), setprofile(10), main_thread(11), active_count(12), current_thread(14)"
  category: identity
  kind: python_call_eq
  function: settrace.__name__.__len__
  args: []
  expected: 8

invariant threading_extra268.stack_size_module_is_thread_extension:
  description: "threading.stack_size.__module__ == '_thread' (len=7) — stack_size comes from the C extension _thread, unlike all other functions in this spec which have __module__ == 'threading'"
  category: identity
  kind: python_call_eq
  function: stack_size.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra268.setprofile_name_len_equals_stack_size:
  description: "threading.setprofile.__name__.__len__() == 10 == threading.stack_size.__name__.__len__() — setprofile and stack_size names are both length 10; setprofile is pure Python, stack_size is a C builtin"
  category: identity
  kind: python_call_eq
  function: setprofile.__name__.__len__
  args: []
  expected: 10

invariant threading_extra268.all_pure_python_functions_share_module:
  description: "threading.current_thread.__module__ == 'threading' — all pure Python functions in this spec (current_thread, main_thread, active_count, enumerate, settrace, setprofile) share __module__ == 'threading'; stack_size is the exception with __module__ == '_thread'"
  category: identity
  kind: python_call_eq
  function: current_thread.__module__.__eq__
  args: ["threading"]
  expected: true
