spec: asyncio_extra35
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec extends asyncio_extra34.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__() (C extension), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__() == 95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), create_task/run_coroutine_threadsafe __qualname__.__len__(), Queue.__mro__.__len__() == 3, BoundedSemaphore.__mro__.__len__() == 5, Queue method __qualname__.__len__() tables, wait_for/shield/sleep module/name lengths, timeout class identity, TaskGroup class identity, Task/Future MRO depths and base name lengths, PriorityQueue/LifoQueue/Lock/Semaphore/Condition/Event MRO depths and base name lengths."
    - "This spec covers: Queue.put.__name__.__len__()==3; Queue.get.__name__.__len__()==3; Queue.empty.__name__.__len__()==5; Queue.full.__name__.__len__()==4; Queue.qsize.__name__.__len__()==5; Lock.acquire.__name__.__len__()==7; Lock.release.__name__.__len__()==7; Lock.locked.__name__.__len__()==6; Event.wait.__name__.__len__()==4; Event.is_set.__name__.__len__()==6."
    - "Method __name__ (short name only, no class prefix) is distinct from __qualname__ (which includes 'Queue.' prefix). Queue.put.__name__ == 'put' (3 chars) while Queue.put.__qualname__ == 'Queue.put' (9 chars)."
    - "Queue.put and Queue.get share the same __name__ length (3) — both are 3-character names ('put', 'get')."
    - "Lock.acquire and Lock.release share the same __name__ length (7) — both are 7-character names ('acquire', 'release')."
    - "Lock.locked.__name__ == 'locked' (6 chars) — one character shorter than 'acquire' and 'release'."
    - "Event.is_set.__name__ == 'is_set' (6 chars); Event.wait.__name__ == 'wait' (4 chars) — 'is_set' is longer due to the underscore-separated compound name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Queue method __name__.__len__() — extra35 namespace
#
# Method __name__ gives the short unqualified name ('put', 'get', etc.) while
# __qualname__ gives the class-prefixed form ('Queue.put', 'Queue.get', etc.).
# Prior specs have fully covered __qualname__.__len__() for these methods.
# This spec measures __name__.__len__() — a different attribute — giving the
# short name length without the class prefix:
#   Queue.put.__name__   == 'put'   (3 chars)
#   Queue.get.__name__   == 'get'   (3 chars)
#   Queue.empty.__name__ == 'empty' (5 chars)
#   Queue.full.__name__  == 'full'  (4 chars)
#   Queue.qsize.__name__ == 'qsize' (5 chars)
# ---------------------------------------------------------------------------

table asyncio_extra35.queue_method_name_lengths:
  description: "asyncio.Queue method __name__.__len__() in extra35 namespace — short name without class prefix"
  kind: python_call_eq
  category: method_names
  id_prefix: qmethodnamelen35

  columns: [id, function, args, expected]
  rows:
    - [put,   Queue.put.__name__.__len__,   [], 3]
    - [get,   Queue.get.__name__.__len__,   [], 3]
    - [empty, Queue.empty.__name__.__len__, [], 5]
    - [full,  Queue.full.__name__.__len__,  [], 4]
    - [qsize, Queue.qsize.__name__.__len__, [], 5]

# ---------------------------------------------------------------------------
# asyncio Lock method __name__.__len__() — extra35 namespace
#
# Lock.acquire, Lock.release, and Lock.locked have these short name lengths:
#   Lock.acquire.__name__ == 'acquire' (7 chars)
#   Lock.release.__name__ == 'release' (7 chars)
#   Lock.locked.__name__  == 'locked'  (6 chars)
# acquire and release share the same __name__ length (7); locked is one
# character shorter (6). In contrast, __qualname__ lengths are:
#   Lock.acquire.__qualname__ == 'Lock.acquire' (12 chars)
#   Lock.release.__qualname__ == 'Lock.release' (12 chars)
#   Lock.locked.__qualname__  == 'Lock.locked'  (11 chars)
# Prior specs covered __qualname__.__len__() for acquire/release (12/12) but
# not __name__.__len__(). Lock.locked.__qualname__.__len__() == 11 is also
# novel — not covered in any prior asyncio spec.
# ---------------------------------------------------------------------------

table asyncio_extra35.lock_method_name_lengths:
  description: "asyncio.Lock method __name__.__len__() in extra35 namespace — acquire/release/locked short name lengths"
  kind: python_call_eq
  category: method_names
  id_prefix: lockmethodnamelen35

  columns: [id, function, args, expected]
  rows:
    - [acquire, Lock.acquire.__name__.__len__, [], 7]
    - [release, Lock.release.__name__.__len__, [], 7]
    - [locked,  Lock.locked.__name__.__len__,  [], 6]

invariant asyncio_extra35.Lock_locked_qualname_len:
  description: "asyncio.Lock.locked.__qualname__.__len__() == 11 — 'Lock.locked' has 11 characters; one shorter than acquire/release (12 each)"
  category: method_names
  kind: python_call_eq
  function: Lock.locked.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# asyncio Event method __name__.__len__() — extra35 namespace
#
# Event.wait and Event.is_set have these short name lengths:
#   Event.wait.__name__   == 'wait'   (4 chars)
#   Event.is_set.__name__ == 'is_set' (6 chars)
# is_set (6) is longer than wait (4) because 'is_set' is a compound name
# with an underscore. Prior specs covered __qualname__.__len__() for both
# (10 for wait, 12 for is_set) but not the short __name__.__len__() form.
# ---------------------------------------------------------------------------

table asyncio_extra35.event_method_name_lengths:
  description: "asyncio.Event method __name__.__len__() in extra35 namespace — wait/is_set short name lengths"
  kind: python_call_eq
  category: method_names
  id_prefix: eventmethodnamelen35

  columns: [id, function, args, expected]
  rows:
    - [wait,   Event.wait.__name__.__len__,   [], 4]
    - [is_set, Event.is_set.__name__.__len__, [], 6]

# ---------------------------------------------------------------------------
# Standalone invariants — extra35
# ---------------------------------------------------------------------------

invariant asyncio_extra35.Queue_put_name_len:
  description: "asyncio.Queue.put.__name__.__len__() == 3 — 'put' is 3 characters; __name__ (short) vs __qualname__ (9 chars, 'Queue.put')"
  category: method_names
  kind: python_call_eq
  function: Queue.put.__name__.__len__
  args: []
  expected: 3

invariant asyncio_extra35.Event_is_set_name_len:
  description: "asyncio.Event.is_set.__name__.__len__() == 6 — 'is_set' is 6 characters including the underscore; longer than Event.wait (4 chars)"
  category: method_names
  kind: python_call_eq
  function: Event.is_set.__name__.__len__
  args: []
  expected: 6
