spec: decimal_extra196
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra195.zspec.zsdl — covers __name__ lengths for Decimal, Context, signals"
  notes:
    - "This spec covers decimal class __doc__.__class__.__name__ identity not covered by prior decimal_extra specs."
    - "decimal.Decimal.__doc__.__class__.__name__ == 'str'; the main decimal type has a str docstring; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__doc__.__class__.__name__ == 'str'; the arithmetic context class has a str docstring; confirmed Python 3.14.3 macOS."
    - "decimal.InvalidOperation.__doc__.__class__.__name__ == 'NoneType'; this signal class has __doc__ == None; confirmed Python 3.14.3 macOS."
    - "decimal.DivisionByZero.__doc__.__class__.__name__ == 'NoneType'; this signal class has __doc__ == None; confirmed Python 3.14.3 macOS."
    - "decimal.Overflow.__doc__.__class__.__name__ == 'NoneType'; this signal class has __doc__ == None; confirmed Python 3.14.3 macOS."
    - "decimal.Underflow.__doc__.__class__.__name__ == 'NoneType'; this signal class has __doc__ == None; confirmed Python 3.14.3 macOS."
    - "decimal.Inexact.__doc__.__class__.__name__ == 'NoneType'; this signal class has __doc__ == None; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__add__.__doc__.__class__.__name__ == 'str'; the __add__ method has a str docstring; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal core class __doc__.__class__.__name__ identity
# Decimal, Context — 'str'; Decimal.__add__ — 'str'
# ---------------------------------------------------------------------------

table decimal_extra196.core_class_doc_class_names:
  description: "decimal core class __doc__.__class__.__name__: Decimal and Context are 'str'; Decimal.__add__ is 'str'"
  kind: python_call_eq
  category: doc_identity
  id_prefix: decimaldocs196

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_doc_class_name,     decimal.Decimal.__doc__.__class__.__name__.__eq__,     ["str"],    true, "decimal.Decimal.__doc__.__class__.__name__ == 'str'; the main arbitrary-precision decimal type; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [context_doc_class_name,     decimal.Context.__doc__.__class__.__name__.__eq__,     ["str"],    true, "decimal.Context.__doc__.__class__.__name__ == 'str'; controls precision, rounding mode and signal handling; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [decimal_add_doc_class_name, decimal.Decimal.__add__.__doc__.__class__.__name__.__eq__, ["str"], true, "decimal.Decimal.__add__.__doc__.__class__.__name__ == 'str'; the __add__ method docstring is a str; confirmed Python 3.14.3 macOS"]
    - [decimal_doc_class_name_len, decimal.Decimal.__doc__.__class__.__name__.__len__,     [], 3, "decimal.Decimal.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]
    - [context_doc_class_name_len, decimal.Context.__doc__.__class__.__name__.__len__,     [], 3, "decimal.Context.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]

