    - [divisionbyzero_doc_class_name,       decimal.DivisionByZero.__doc__.__class__.__name__.__eq__,  ["NoneType"], true, "decimal.DivisionByZero.__doc__.__class__.__name__ == 'NoneType'; this signal class has __doc__ == None at Python 3.14.3 macOS"]
