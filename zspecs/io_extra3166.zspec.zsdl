spec: io3166
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 658 (io3166): __add__, __sub__, __mul__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper, io.IOBase."
    - "No io class defines __add__ in its own __dict__: io stream classes are I/O abstractions, not numeric types."
    - "No io class defines __sub__ in its own __dict__: io stream classes do not support arithmetic subtraction."
    - "No io class defines __mul__ in its own __dict__: io stream classes do not support arithmetic multiplication."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __add__ dict-presence — operator.contains(Cls.__dict__, '__add__')
#
# No io class defines __add__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions with no arithmetic protocol.
# ---------------------------------------------------------------------------

