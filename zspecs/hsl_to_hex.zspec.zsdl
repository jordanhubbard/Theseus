spec: hsl_to_hex
version: ">=1.0.0"
backend: node(hsl-to-hex)

docs: https://www.npmjs.com/package/hsl-to-hex

provenance:
  derived_from:
    - "hsl-to-hex README — https://www.npmjs.com/package/hsl-to-hex"
    - "Test vectors verified with hsl-to-hex via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "hsl-to-hex source"
  notes:
    - "hsl-to-hex is an npm package. Install: npm install hsl-to-hex"
    - "Converts HSL color values (hue 0-360, saturation 0-100, lightness 0-100) to a hex color string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a hex color string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table hsl_to_hex.hslToHex:
  kind: node_module_call_eq
  function: ~
  category: color
  id_prefix: hsl2hex

  columns: [id, args, expected]
  rows:
    - [red,    [0, 100, 50],    "#ff0000"]
    - [green,  [120, 100, 50],  "#00ff00"]
    - [blue,   [240, 100, 50],  "#0000ff"]
    - [white,  [0, 0, 100],     "#ffffff"]

