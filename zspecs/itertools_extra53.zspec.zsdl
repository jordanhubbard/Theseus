spec: itertools_extra53
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra52.zspec.zsdl."
    - "Prior specs covered __module__.__eq__('itertools') for: starmap/dropwhile/takewhile/filterfalse (extra3/extra15/extra25); combinations/permutations/combinations_with_replacement (extra3/extra14); accumulate (extra3/extra14). Prior specs covered __module__.__len__()==9 for: accumulate (extra14/extra29); filterfalse (extra29); chain (extra3/extra28); product/cycle (extra52). Prior specs covered __module__.__class__.__name__=='str' for: groupby/chain/compress/islice/zip_longest/accumulate (extra52). No prior spec records __module__.__class__.__name__.__eq__('str') for starmap/dropwhile/takewhile/filterfalse/combinations/permutations/combinations_with_replacement."
    - "This spec covers: itertools.starmap.__module__.__class__.__name__.__eq__('str')==true; itertools.dropwhile.__module__.__class__.__name__.__eq__('str')==true; itertools.takewhile.__module__.__class__.__name__.__eq__('str')==true; itertools.filterfalse.__module__.__class__.__name__.__eq__('str')==true; itertools.combinations.__module__.__class__.__name__.__eq__('str')==true; itertools.permutations.__module__.__class__.__name__.__eq__('str')==true; itertools.combinations_with_replacement.__module__.__class__.__name__.__eq__('str')==true; itertools.starmap.__module__.__len__()==9; itertools.dropwhile.__module__.__len__()==9; itertools.takewhile.__module__.__len__()==9; itertools.combinations.__module__.__len__()==9; itertools.permutations.__module__.__len__()==9."
    - "Key findings: All itertools C-level types store their __module__ as the Python string 'itertools' (9 chars). Since this string is a Python str object, its __class__ is the str built-in type, and str.__name__ == 'str' (3 chars). The types covered here (starmap, dropwhile, takewhile, filterfalse, combinations, permutations, combinations_with_replacement) had their __module__.__eq__ confirmed in prior specs (extra3/extra14/extra15/extra25) but no prior spec records __module__.__class__.__name__.__eq__('str') for any of these seven types. Additionally, __module__.__len__()==9 was confirmed for filterfalse (extra29) and accumulate (extra14/extra29) but not for starmap/dropwhile/takewhile/combinations/permutations. The combinations_with_replacement __module__.__len__ is also not recorded. All twelve invariants are new to extra53."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools type __module__.__class__.__name__ == 'str' — extra53 namespace
#
# All itertools types are C-level types defined in Modules/itertoolsmodule.c.
# Their __module__ attribute is the Python string 'itertools' (9 chars). Since
# this string is a Python str object, its __class__ is the str built-in type,
# and str.__name__ == 'str' (3 chars). Prior extra52 established this pattern
# for groupby/chain/compress/islice/zip_longest/accumulate. The seven types
# below (starmap, dropwhile, takewhile, filterfalse, combinations, permutations,
# combinations_with_replacement) had __module__.__eq__('itertools') confirmed
# in prior specs but no prior spec records __module__.__class__.__name__.__eq__
# for any of them. All seven checks below are new to extra53.
# ---------------------------------------------------------------------------

table itertools_extra53.module_string_class_name:
  description: "itertools type __module__.__class__.__name__ == 'str' — all itertools C-level types store __module__ as a Python str object; str.__name__ == 'str' (3 chars); extra52 covered 6 types; these 7 are new to extra53"
  kind: python_call_eq
  category: identity
  id_prefix: itertmod53

  columns: [id, function, args, expected, description]
  rows:
    - [starmap_module_class_name,
       starmap.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.starmap.__module__.__class__.__name__ == 'str' — starmap is a C-level type in Modules/itertoolsmodule.c that maps a function across argument tuples from an iterable; __module__ is the Python string 'itertools' (9 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra3/extra15/extra25 confirmed starmap.__module__.__eq__('itertools'); this is the first __module__.__class__.__name__ check for starmap; new to extra53"]
    - [dropwhile_module_class_name,
       dropwhile.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.dropwhile.__module__.__class__.__name__ == 'str' — dropwhile is a C-level type in Modules/itertoolsmodule.c that drops elements while a predicate is true; __module__ is the Python string 'itertools' (9 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra3/extra15/extra25 confirmed dropwhile.__module__.__eq__('itertools'); this is the first __module__.__class__.__name__ check for dropwhile; new to extra53"]
    - [takewhile_module_class_name,
       takewhile.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.takewhile.__module__.__class__.__name__ == 'str' — takewhile is a C-level type in Modules/itertoolsmodule.c that takes elements while a predicate is true; __module__ is the Python string 'itertools' (9 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra3/extra15/extra25 confirmed takewhile.__module__.__eq__('itertools'); this is the first __module__.__class__.__name__ check for takewhile; new to extra53"]
    - [filterfalse_module_class_name,
       filterfalse.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.filterfalse.__module__.__class__.__name__ == 'str' — filterfalse is a C-level type in Modules/itertoolsmodule.c that filters elements for which a predicate is false; __module__ is the Python string 'itertools' (9 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra3/extra15/extra29 confirmed filterfalse.__module__.__eq__('itertools') and __module__.__len__()==9; this is the first __module__.__class__.__name__ check for filterfalse; new to extra53"]
    - [combinations_module_class_name,
       combinations.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.combinations.__module__.__class__.__name__ == 'str' — combinations is a C-level type in Modules/itertoolsmodule.c that yields r-length subsequences of elements without replacement; __module__ is the Python string 'itertools' (9 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra3/extra14 confirmed combinations.__module__.__eq__('itertools'); this is the first __module__.__class__.__name__ check for combinations; new to extra53"]
    - [permutations_module_class_name,
       permutations.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.permutations.__module__.__class__.__name__ == 'str' — permutations is a C-level type in Modules/itertoolsmodule.c that yields r-length tuples of elements in sorted order without repeated elements; __module__ is the Python string 'itertools' (9 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra3/extra14 confirmed permutations.__module__.__eq__('itertools'); this is the first __module__.__class__.__name__ check for permutations; new to extra53"]
    - [combinations_with_replacement_module_class_name,
       "combinations_with_replacement.__module__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.combinations_with_replacement.__module__.__class__.__name__ == 'str' — combinations_with_replacement is a C-level type in Modules/itertoolsmodule.c that yields r-length subsequences allowing individual elements to be repeated; __module__ is the Python string 'itertools' (9 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra3/extra9 confirmed combinations_with_replacement.__module__.__eq__('itertools'); this is the first __module__.__class__.__name__ check for combinations_with_replacement; new to extra53"]

# ---------------------------------------------------------------------------
# itertools type __module__.__len__() — extra53 namespace
#
# Prior specs recorded __module__.__len__()==9 for chain (extra3/extra28),
# accumulate (extra14/extra29), filterfalse (extra29), and product/cycle (extra52).
# The types below (starmap, dropwhile, takewhile, combinations, permutations)
# had __module__.__eq__('itertools') confirmed but not __module__.__len__() as
# explicit row invariants. All five checks below are new to extra53.
# ---------------------------------------------------------------------------

table itertools_extra53.module_string_len:
  description: "itertools type __module__.__len__()==9 — 'itertools' is 9 chars; these types had __module__.__eq__ confirmed in prior specs but __module__.__len__() not recorded as explicit rows; new dimension in extra53"
  kind: python_call_eq
  category: identity
  id_prefix: itertmod53

  columns: [id, function, args, expected, description]
  rows:
    - [starmap_module_len,
       starmap.__module__.__len__,
       [],
       9,
       "itertools.starmap.__module__.__len__() == 9 — 'itertools' has 9 characters; starmap applies a function to arguments obtained from a tuple iterable; prior extra3/extra15/extra25 confirmed starmap.__module__.__eq__('itertools') but did not record __module__.__len__() as an explicit row for starmap; new to extra53"]
    - [dropwhile_module_len,
       dropwhile.__module__.__len__,
       [],
       9,
       "itertools.dropwhile.__module__.__len__() == 9 — 'itertools' has 9 characters; dropwhile drops elements from an iterable while predicate is true, then returns the rest; prior extra3/extra15/extra25 confirmed dropwhile.__module__.__eq__('itertools') but did not record __module__.__len__() as an explicit row for dropwhile; new to extra53"]
    - [takewhile_module_len,
       takewhile.__module__.__len__,
       [],
       9,
       "itertools.takewhile.__module__.__len__() == 9 — 'itertools' has 9 characters; takewhile returns elements from an iterable as long as predicate is true; prior extra3/extra15/extra25 confirmed takewhile.__module__.__eq__('itertools') but did not record __module__.__len__() as an explicit row for takewhile; new to extra53"]
    - [combinations_module_len,
       combinations.__module__.__len__,
       [],
       9,
       "itertools.combinations.__module__.__len__() == 9 — 'itertools' has 9 characters; combinations yields r-length subsequences without replacement from the input iterable; prior extra3/extra14 confirmed combinations.__module__.__eq__('itertools') but did not record __module__.__len__() as an explicit row; new to extra53"]
    - [permutations_module_len,
       permutations.__module__.__len__,
       [],
       9,
       "itertools.permutations.__module__.__len__() == 9 — 'itertools' has 9 characters; permutations yields successive r-length permutations of elements in the input iterable; prior extra3/extra14 confirmed permutations.__module__.__eq__('itertools') but did not record __module__.__len__() as an explicit row; new to extra53"]
