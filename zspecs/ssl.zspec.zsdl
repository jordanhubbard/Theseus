spec: ssl
version: ">=3.6"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ssl.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "ssl source: internal CPython _ssl C extension"
  notes:
    - "No actual TLS connections are made; invariants test class names, hierarchy, constants, and attribute presence only."
    - "ssl.CERT_NONE, ssl.CERT_OPTIONAL, ssl.CERT_REQUIRED are members of ssl.VerifyMode (an IntEnum); they compare equal to 0, 1, 2 respectively via __eq__."
    - "ssl.HAS_SNI and ssl.HAS_ALPN are plain booleans; their __class__.__name__ == 'bool'."
    - "ssl.PROTOCOL_TLS was deprecated in Python 3.10 and removed in 3.12; this spec uses PROTOCOL_TLS_CLIENT and PROTOCOL_TLS_SERVER only."
    - "SSLError inherits from OSError (not Exception) — this is intentional and matches POSIX errno semantics."
    - "SSLCertVerificationError was added in Python 3.7 as a subclass of SSLError."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "ssl raises ssl.SSLError (subclass of OSError) for TLS-level failures and ssl.SSLCertVerificationError for certificate verification failures."
  stderr: "null"
  stickiness: "N/A — all tested invariants are stateless constant and class attribute reads."
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

table ssl.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [sslerror,                SSLError.__name__.__eq__,                ["SSLError"],                true]
    - [sslcontext,              SSLContext.__name__.__eq__,              ["SSLContext"],              true]
    - [sslsocket,               SSLSocket.__name__.__eq__,               ["SSLSocket"],               true]
    - [sslcertverificationerror, SSLCertVerificationError.__name__.__eq__, ["SSLCertVerificationError"], true]

# ---------------------------------------------------------------------------
# Hierarchy checks — base class of SSLError is OSError
# ---------------------------------------------------------------------------

invariant ssl.hierarchy.sslerror_base:
  description: "ssl.SSLError.__bases__[0].__name__ == 'OSError' — SSLError is a subclass of OSError"
  category: hierarchy
  kind: python_call_eq
  function: SSLError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# Module check
# ---------------------------------------------------------------------------

invariant ssl.module.sslerror_module:
  description: "ssl.SSLError.__module__ == 'ssl'"
  category: modules
  kind: python_call_eq
  function: SSLError.__module__.__eq__
  args: ["ssl"]
  expected: true

# ---------------------------------------------------------------------------
# VerifyMode enum constants — CERT_NONE=0, CERT_OPTIONAL=1, CERT_REQUIRED=2
# Members of ssl.VerifyMode (IntEnum) compare equal to ints via __eq__.
# ---------------------------------------------------------------------------

table ssl.verify_mode_constants:
  kind: python_call_eq
  category: constants
  id_prefix: verify

  columns: [id, function, args, expected]
  rows:
    - [none,     CERT_NONE.__eq__,     [0], true]
    - [optional, CERT_OPTIONAL.__eq__,  [1], true]
    - [required, CERT_REQUIRED.__eq__,  [2], true]

# ---------------------------------------------------------------------------
# Boolean feature flags — HAS_SNI and HAS_ALPN are plain booleans
# ---------------------------------------------------------------------------

table ssl.feature_flags:
  kind: python_call_eq
  category: constants
  id_prefix: flag

  columns: [id, function, args, expected]
  rows:
    - [has_sni,  HAS_SNI.__class__.__name__.__eq__,  ["bool"], true]
    - [has_alpn, HAS_ALPN.__class__.__name__.__eq__, ["bool"], true]
