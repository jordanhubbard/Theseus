spec: uuid_extra244
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 244 theme: uuid.UUID dunder method __name__ and __qualname__ identity."
    - "uuid.UUID.__eq__.__name__ == '__eq__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__name__ == '__lt__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__name__ == '__hash__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__name__ == '__int__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__name__ == '__str__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__name__ == '__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__name__ == '__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.__eq__).__name__ == 'function'. All UUID dunder methods are plain Python functions (not C builtins). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__qualname__ == 'UUID.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__qualname__ == 'UUID.__str__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__qualname__ == 'UUID.__int__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All UUID dunder methods are Python-level functions (type 'function'), not C builtins — UUID is a pure Python class defined in Lib/uuid.py."
    - "Note: __qualname__ for all UUID dunders follows the 'UUID.<dunder>' pattern, confirming they are defined directly on the UUID class (not inherited or nested)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__eq__.__name__.__eq__('__eq__')
# uuid.UUID.__lt__.__name__.__eq__('__lt__')
# uuid.UUID.__hash__.__name__.__eq__('__hash__')
# uuid.UUID.__int__.__name__.__eq__('__int__')
# uuid.UUID.__str__.__name__.__eq__('__str__')
# uuid.UUID.__repr__.__name__.__eq__('__repr__')
# uuid.UUID.__init__.__name__.__eq__('__init__')
#
# Wave 244 theme: uuid.UUID dunder method __name__ identity.
#
# UUID is a pure Python class defined in Lib/uuid.py. All its dunder methods
# are plain Python functions (type 'function'), not C builtins. Each dunder
# method's __name__ is the exact dunder name string (e.g., '__eq__', '__lt__').
# This is the expected behaviour for Python-defined methods. Verified Python
# 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra244.UUID_dunder_method_names:
  description: "uuid.UUID dunder method __name__ identity — UUID.__eq__/__name__.__eq__('__eq__')==True / UUID.__lt__/__name__.__eq__('__lt__')==True / UUID.__hash__/__name__.__eq__('__hash__')==True / UUID.__int__/__name__.__eq__('__int__')==True / UUID.__str__/__name__.__eq__('__str__')==True / UUID.__repr__/__name__.__eq__('__repr__')==True / UUID.__init__/__name__.__eq__('__init__')==True — all UUID dunders are Python functions; __name__ equals the dunder name string; wave 244 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: uuiddunder244

  columns: [id, function, args, expected, description]
  rows:
    - [eq_name,    UUID.__eq__.__name__.__eq__,    ["__eq__"],    true, "UUID.__eq__.__name__ == '__eq__'; Python-defined comparison dunder"]
    - [lt_name,    UUID.__lt__.__name__.__eq__,    ["__lt__"],    true, "UUID.__lt__.__name__ == '__lt__'; Python-defined ordering dunder"]
    - [hash_name,  UUID.__hash__.__name__.__eq__,  ["__hash__"],  true, "UUID.__hash__.__name__ == '__hash__'; Python-defined hash dunder"]
    - [int_name,   UUID.__int__.__name__.__eq__,   ["__int__"],   true, "UUID.__int__.__name__ == '__int__'; Python-defined integer conversion dunder"]
    - [str_name,   UUID.__str__.__name__.__eq__,   ["__str__"],   true, "UUID.__str__.__name__ == '__str__'; Python-defined string representation dunder"]
    - [repr_name,  UUID.__repr__.__name__.__eq__,  ["__repr__"],  true, "UUID.__repr__.__name__ == '__repr__'; Python-defined repr dunder"]
    - [init_name,  UUID.__init__.__name__.__eq__,  ["__init__"],  true, "UUID.__init__.__name__ == '__init__'; Python-defined constructor dunder"]

# ---------------------------------------------------------------------------
# type(uuid.UUID.__eq__).__name__.__eq__('function')
# type(uuid.UUID.__lt__).__name__.__eq__('function')
# type(uuid.UUID.__hash__).__name__.__eq__('function')
# type(uuid.UUID.__int__).__name__.__eq__('function')
#
# Wave 244 theme: uuid.UUID dunder method type identity.
#
# All UUID dunder methods are plain Python 'function' objects, not C builtins
# (which would be 'builtin_function_or_method' or 'method_descriptor'). This
# confirms that UUID is a pure Python class. The type name is 'function' for
# all methods defined with def inside a Python class body. Verified Python
# 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra244.UUID_dunder_method_types:
  description: "uuid.UUID dunder method type identity — type(UUID.__eq__).__name__.__eq__('function')==True / type(UUID.__lt__).__name__.__eq__('function')==True / type(UUID.__hash__).__name__.__eq__('function')==True / type(UUID.__int__).__name__.__eq__('function')==True — all UUID dunders are plain Python function objects (not C builtins); UUID is a pure Python class from Lib/uuid.py; wave 244 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: uuiddunder244

  columns: [id, function, args, expected, description]
  rows:
    - [eq_type,   UUID.__eq__.__class__.__name__.__eq__,   ["function"], true, "type(UUID.__eq__).__name__ == 'function'; UUID is pure Python, not C-backed"]
    - [lt_type,   UUID.__lt__.__class__.__name__.__eq__,   ["function"], true, "type(UUID.__lt__).__name__ == 'function'; UUID is pure Python, not C-backed"]
    - [hash_type, UUID.__hash__.__class__.__name__.__eq__, ["function"], true, "type(UUID.__hash__).__name__ == 'function'; UUID is pure Python, not C-backed"]
    - [int_type,  UUID.__int__.__class__.__name__.__eq__,  ["function"], true, "type(UUID.__int__).__name__ == 'function'; UUID is pure Python, not C-backed"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__')
# uuid.UUID.__repr__.__qualname__.__eq__('UUID.__repr__')
# uuid.UUID.__str__.__qualname__.__eq__('UUID.__str__')
# uuid.UUID.__hash__.__qualname__.__eq__('UUID.__hash__')
# uuid.UUID.__eq__.__qualname__.__eq__('UUID.__eq__')
# uuid.UUID.__lt__.__qualname__.__eq__('UUID.__lt__')
# uuid.UUID.__int__.__qualname__.__eq__('UUID.__int__')
#
# Wave 244 theme: uuid.UUID dunder method __qualname__ identity.
#
# For Python methods defined directly on a class, __qualname__ follows the
# pattern 'ClassName.method_name'. All UUID dunder methods have __qualname__
# in the form 'UUID.<dunder>', confirming they are defined directly on the UUID
# class body (not inherited, not nested). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra244.UUID_dunder_method_qualnames:
  description: "uuid.UUID dunder method __qualname__ identity — UUID.__init__/__qualname__.__eq__('UUID.__init__')==True / UUID.__repr__/__qualname__.__eq__('UUID.__repr__')==True / UUID.__str__/__qualname__.__eq__('UUID.__str__')==True / UUID.__hash__/__qualname__.__eq__('UUID.__hash__')==True / UUID.__eq__/__qualname__.__eq__('UUID.__eq__')==True / UUID.__lt__/__qualname__.__eq__('UUID.__lt__')==True / UUID.__int__/__qualname__.__eq__('UUID.__int__')==True — __qualname__ follows 'UUID.<dunder>' pattern for all; wave 244 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: uuiddunder244

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname,  UUID.__init__.__qualname__.__eq__,  ["UUID.__init__"],  true, "UUID.__init__.__qualname__ == 'UUID.__init__'; defined directly on UUID class"]
    - [repr_qualname,  UUID.__repr__.__qualname__.__eq__,  ["UUID.__repr__"],  true, "UUID.__repr__.__qualname__ == 'UUID.__repr__'; defined directly on UUID class"]
    - [str_qualname,   UUID.__str__.__qualname__.__eq__,   ["UUID.__str__"],   true, "UUID.__str__.__qualname__ == 'UUID.__str__'; defined directly on UUID class"]
    - [hash_qualname,  UUID.__hash__.__qualname__.__eq__,  ["UUID.__hash__"],  true, "UUID.__hash__.__qualname__ == 'UUID.__hash__'; defined directly on UUID class"]
    - [eq_qualname,    UUID.__eq__.__qualname__.__eq__,    ["UUID.__eq__"],    true, "UUID.__eq__.__qualname__ == 'UUID.__eq__'; defined directly on UUID class"]
    - [lt_qualname,    UUID.__lt__.__qualname__.__eq__,    ["UUID.__lt__"],    true, "UUID.__lt__.__qualname__ == 'UUID.__lt__'; defined directly on UUID class"]
    - [int_qualname,   UUID.__int__.__qualname__.__eq__,   ["UUID.__int__"],   true, "UUID.__int__.__qualname__ == 'UUID.__int__'; defined directly on UUID class"]

# ---------------------------------------------------------------------------
# uuid.UUID.__eq__.__name__.__eq__('__eq__') — standalone
#
# uuid.UUID.__eq__.__name__ is '__eq__'. UUID.__eq__ is the equality comparison
# method for UUID objects. It is a plain Python function defined in Lib/uuid.py
# that compares two UUID instances by their integer representation. Because UUID
# is a pure Python class, UUID.__eq__ is a 'function' type (not 'method_descriptor'
# or 'slot_wrapper'). Its __name__ is '__eq__' and its __qualname__ is 'UUID.__eq__'.
# This is the first standalone anchor for UUID.__eq__.__name__ under uuiddunder244.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra244.UUID_eq_name:
  description: "uuid.UUID.__eq__.__name__.__eq__('__eq__') == True — UUID.__eq__ is a Python function (not C builtin) for comparing UUIDs by integer value; __name__ is '__eq__'; __qualname__ is 'UUID.__eq__'; UUID is pure Python (Lib/uuid.py); first standalone for UUID.__eq__.__name__ under uuiddunder244; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: UUID.__eq__.__name__.__eq__
  args: ["__eq__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__hash__.__qualname__.__eq__('UUID.__hash__') — standalone
#
# uuid.UUID.__hash__.__qualname__ is 'UUID.__hash__'. UUID.__hash__ is the hash
# method for UUID objects, defined in Lib/uuid.py. It is a Python function that
# computes the hash of a UUID by hashing its integer representation. The __qualname__
# follows the 'UUID.__hash__' pattern, confirming it is defined directly on the
# UUID class. UUID objects are hashable and can be used as dictionary keys or
# set members. This is the first standalone anchor for UUID.__hash__.__qualname__
# under uuiddunder244. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra244.UUID_hash_qualname:
  description: "uuid.UUID.__hash__.__qualname__.__eq__('UUID.__hash__') == True — UUID.__hash__ computes the hash of a UUID via its integer representation; __qualname__ is 'UUID.__hash__' confirming it is defined directly on the UUID class; UUID objects are hashable (usable as dict keys/set members); first standalone for UUID.__hash__.__qualname__ under uuiddunder244; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: UUID.__hash__.__qualname__.__eq__
  args: ["UUID.__hash__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__int__.__qualname__.__eq__('UUID.__int__') — standalone
#
# uuid.UUID.__int__.__qualname__ is 'UUID.__int__'. UUID.__int__ is the integer
# conversion method that returns the UUID as a 128-bit integer. It is defined
# as a Python property getter in Lib/uuid.py. The raw UUID bytes are converted
# to an integer via the .int attribute, which is what __int__ returns. The
# __qualname__ 'UUID.__int__' confirms it is defined directly on the UUID class.
# This is the first standalone anchor for UUID.__int__.__qualname__ under
# uuiddunder244. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra244.UUID_int_qualname:
  description: "uuid.UUID.__int__.__qualname__.__eq__('UUID.__int__') == True — UUID.__int__ returns the UUID as a 128-bit integer; __qualname__ is 'UUID.__int__' confirming direct definition on UUID class; the .int attribute stores the underlying 128-bit integer value; first standalone for UUID.__int__.__qualname__ under uuiddunder244; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: UUID.__int__.__qualname__.__eq__
  args: ["UUID.__int__"]
  expected: true
