spec: lodash_words
version: ">=4.0.0"
backend: node(lodash.words)

docs: https://lodash.com/docs/#words

provenance:
  derived_from:
    - "lodash.words README — https://www.npmjs.com/package/lodash.words"
    - "Test vectors verified with lodash.words@4.2.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.words exports the _.words function directly as module.exports."
    - "words(string) splits string into words using Unicode word boundaries."
    - "Splits on whitespace, case transitions, and punctuation."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of word strings."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_words.words:
  kind: node_module_call_eq
  function: ~
  category: words
  id_prefix: lwrds

  columns: [id, args, expected]
  rows:
    - [spaced,    ["hello world"],    ["hello", "world"]]
    - [camel,     ["camelCase"],      ["camel", "Case"]]
    - [hyphen,    ["foo-bar-baz"],    ["foo", "bar", "baz"]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:51:39Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
