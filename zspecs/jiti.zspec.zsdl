spec: jiti
version: ">=2.0.0"
backend: node(jiti)

docs: https://github.com/unjs/jiti#readme

provenance:
  derived_from:
    - "Jiti README — https://github.com/unjs/jiti#readme"
    - "Test vectors verified with jiti via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "jiti source"
  notes:
    - "Runtime TypeScript / ESM loader for CJS — used by Nuxt, ESLint configs, Tailwind."
    - "Install: npm install jiti"
    - "v2 ESM only; named export createJiti(parentURL) returns the loader function with .import / .resolve / .cache / .options / .transform attached."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Constructor never throws on valid options; resolve/import throw on bad paths."
  stderr: "null"
  stickiness: "Per-loader cache; shared across calls on the same instance."
  codes: {}

invariant jiti.has_createJiti:
  description: "createJiti is exported as a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "createJiti.constructor.name"}
  expected: "Function"

invariant jiti.createJiti_arity:
  description: "createJiti takes (parentURL, options) — function.length 1 (options optional)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "createJiti.length"}
  expected: 1

invariant jiti.instance_typeof_function:
  description: "createJiti(...) returns a function (the loader)"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: createJiti
  entry_args: ["file:///tmp/x"]
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant jiti.instance_has_import:
  description: "Loader has .import (async)"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: createJiti
  entry_args: ["file:///tmp/x"]
  chain:
    - {get: "import.constructor.name"}
  expected: "AsyncFunction"

invariant jiti.instance_has_resolve:
  description: "Loader has .resolve"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: createJiti
  entry_args: ["file:///tmp/x"]
  chain:
    - {get: "resolve.constructor.name"}
  expected: "Function"

invariant jiti.instance_has_cache:
  description: "Loader has .cache (Object.create(null) — so no .constructor; check via hasOwnProperty)"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: createJiti
  entry_args: ["file:///tmp/x"]
  chain:
    - {method: hasOwnProperty, args: ["cache"]}
  expected: true

invariant jiti.instance_has_options:
  description: "Loader has .options (an object)"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: createJiti
  entry_args: ["file:///tmp/x"]
  chain:
    - {get: options}
    - {get: "constructor.name"}
  expected: "Object"

invariant jiti.instance_has_transform:
  description: "Loader has .transform (for direct source transformation)"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: createJiti
  entry_args: ["file:///tmp/x"]
  chain:
    - {get: "transform.constructor.name"}
  expected: "Function"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:42:22Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
