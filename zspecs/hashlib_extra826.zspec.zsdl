spec: hashlib_extra826
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - hashlib
  not_derived_from:
    - hmac
    - secrets
  notes:
    - Covers HASH object method qualnames via blake2b, blake2s, and sha3_256
    - Qualname checks verify CPython method identity strings
  created_at: "2026-04-12"

table hashlib_extra826.blake2b_qualnames:
  description: blake2b HASH object method qualnames
  kind: python_call_eq
  category: qualname
  id_prefix: hl826bl
  columns: [id, function, args, expected]
  rows:
    - [hl826bl001, hashlib.blake2b.update.__qualname__.__eq__, ["blake2b.update"], true]
    - [hl826bl002, hashlib.blake2b.digest.__qualname__.__eq__, ["blake2b.digest"], true]
    - [hl826bl003, hashlib.blake2b.hexdigest.__qualname__.__eq__, ["blake2b.hexdigest"], true]
    - [hl826bl004, hashlib.blake2b.copy.__qualname__.__eq__, ["blake2b.copy"], true]

table hashlib_extra826.blake2s_qualnames:
  description: blake2s HASH object method qualnames
  kind: python_call_eq
  category: qualname
  id_prefix: hl826bs
  columns: [id, function, args, expected]
  rows:
    - [hl826bs001, hashlib.blake2s.update.__qualname__.__eq__, ["blake2s.update"], true]
    - [hl826bs002, hashlib.blake2s.digest.__qualname__.__eq__, ["blake2s.digest"], true]
    - [hl826bs003, hashlib.blake2s.hexdigest.__qualname__.__eq__, ["blake2s.hexdigest"], true]
    - [hl826bs004, hashlib.blake2s.copy.__qualname__.__eq__, ["blake2s.copy"], true]

table hashlib_extra826.sha3_256_qualnames:
  description: sha3_256 HASH object method qualnames
  kind: python_call_eq
  category: qualname
  id_prefix: hl826sh
  columns: [id, function, args, expected]
  rows:
    - [hl826sh001, hashlib.sha3_256.update.__qualname__.__eq__, ["sha3_256.update"], true]
    - [hl826sh002, hashlib.sha3_256.digest.__qualname__.__eq__, ["sha3_256.digest"], true]
    - [hl826sh003, hashlib.sha3_256.hexdigest.__qualname__.__eq__, ["sha3_256.hexdigest"], true]
    - [hl826sh004, hashlib.sha3_256.copy.__qualname__.__eq__, ["sha3_256.copy"], true]
