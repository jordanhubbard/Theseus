spec: abc_extra2446
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2446: __enter__/__exit__ context manager protocol dict-presence checks."
    - "abc.ABC is a helper base class; it does not define __enter__ or __exit__ in its own __dict__."
    - "abc.ABCMeta is a metaclass; it does not define __enter__ or __exit__ in its own __dict__."
    - "abc.abstractmethod is a plain function (decorator); its __dict__ does not contain __enter__ or __exit__."
    - "abc.abstractclassmethod, abc.abstractstaticmethod, abc.abstractproperty are deprecated type objects; none define __enter__ or __exit__ in their own __dict__."
    - "None of the abc constructs define __aenter__ or __aexit__ (async context manager protocol)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

table abc_extra2446.abc_sync_cm_enter:
  description: "abc.ABC, abc.ABCMeta __enter__ sync context manager dict-presence — all false"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2446

  columns: [id, function, args, expected]
  rows:
    - ["ab2446001", "abc.ABC.__dict__.__contains__", ["__enter__"], false]
    - ["ab2446002", "abc.ABC.__dict__.__contains__", ["__exit__"], false]
    - ["ab2446003", "abc.ABCMeta.__dict__.__contains__", ["__enter__"], false]
    - ["ab2446004", "abc.ABCMeta.__dict__.__contains__", ["__exit__"], false]

