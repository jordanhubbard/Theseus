spec: _struct
version: ">=3.3"
backend: python_module(_struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "_struct source: Modules/_struct.c (CPython C accelerator for struct)"
  not_derived_from:
    - "CPython source: Lib/struct.py (pure-Python shim)"
  notes:
    - "_struct is the C extension backend for the struct module. It exposes the Struct class, the error exception, and the top-level pack/unpack/calcsize functions."
    - "Struct('i') wraps the native signed 32-bit integer format; .size is always 4 bytes on all supported platforms."
    - "Struct('I') wraps the native unsigned 32-bit integer format; .size is also 4 bytes."
    - "Struct('>H') wraps big-endian unsigned 16-bit; .size is 2 bytes."
    - "Struct('i').pack(42) returns a bytes object of length 4."
    - "error is the exception raised for pack/unpack errors; it is a direct subclass of Exception."
    - "calcsize, pack, and unpack are module-level functions exposed by the C extension."
    - "All expected values verified by running Python 3.12 _struct module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "_struct.error is raised for invalid format strings and buffer size mismatches. It is a subclass of Exception."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Class name and module checks
# ---------------------------------------------------------------------------

invariant _struct.Struct_name:
  description: "Struct.__name__ == 'Struct'"
  category: classnames
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

invariant _struct.Struct_module:
  description: "Struct.__module__ == '_struct' — comes from C extension"
  category: classnames
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

invariant _struct.error_name:
  description: "error.__name__ == 'error'"
  category: classnames
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant _struct.error_base:
  description: "error.__bases__[0].__name__ == 'Exception'"
  category: classnames
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant _struct.calcsize_name:
  description: "calcsize.__name__ == 'calcsize'"
  category: functions
  kind: python_call_eq
  function: calcsize.__name__.__eq__
  args: ["calcsize"]
  expected: true

invariant _struct.pack_name:
  description: "pack.__name__ == 'pack'"
  category: functions
  kind: python_call_eq
  function: pack.__name__.__eq__
  args: ["pack"]
  expected: true

invariant _struct.unpack_name:
  description: "unpack.__name__ == 'unpack'"
  category: functions
  kind: python_call_eq
  function: unpack.__name__.__eq__
  args: ["unpack"]
  expected: true

# ---------------------------------------------------------------------------
# Struct instance: size attribute checks
# ---------------------------------------------------------------------------

invariant _struct.Struct_i_size:
  description: "Struct('i').size == 4 — signed 32-bit integer is 4 bytes"
  category: struct_size
  kind: python_call_eq
  function: Struct
  args: ["i"]
  method: size.__eq__
  method_args: [4]
  expected: true

invariant _struct.Struct_I_size:
  description: "Struct('I').size == 4 — unsigned 32-bit integer is 4 bytes"
  category: struct_size
  kind: python_call_eq
  function: Struct
  args: ["I"]
  method: size.__eq__
  method_args: [4]
  expected: true

invariant _struct.Struct_big_endian_H_size:
  description: "Struct('>H').size == 2 — big-endian unsigned 16-bit short is 2 bytes"
  category: struct_size
  kind: python_call_eq
  function: Struct
  args: [">H"]
  method: size.__eq__
  method_args: [2]
  expected: true

# ---------------------------------------------------------------------------
# Struct instance: return type check
# ---------------------------------------------------------------------------

invariant _struct.Struct_i_instance_type:
  description: "Struct('i').__class__.__name__ == 'Struct'"
  category: struct_type
  kind: python_call_eq
  function: Struct
  args: ["i"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# Struct.pack return type check
# ---------------------------------------------------------------------------

invariant _struct.Struct_i_pack_len:
  description: "Struct('i').pack(42).__len__() == 4 — packed bytes length equals struct size"
  category: pack_output
  kind: python_call_eq
  function: Struct
  args: ["i"]
  method: pack
  method_args: [42]
  method_chain: __len__
  method_chain_args: []
  expected: 4
