       ["bytes"],
       false,
       "functools.partial.__doc__.__class__.__name__.__eq__('bytes') == False — __doc__ is a str, not bytes; __eq__('bytes') returns False; negative cross-check; verified with Python 3.14.3"]
    - [partial_doc_not_none,
       partial.__doc__.__class__.__name__.__eq__,
       ["NoneType"],
       false,
       "functools.partial.__doc__.__class__.__name__.__eq__('NoneType') == False — __doc__ is a non-None str; __eq__('NoneType') returns False; negative cross-check; verified with Python 3.14.3"]

