spec: functools_extra214
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools_extra.zspec.zsdl — covers __name__ and __module__ checks, WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES class names, partial instance class name"
    - "functools_extra2.zspec.zsdl — covers reduce/total_ordering/singledispatch/cached_property/wraps __name__ dunder identity and reduce sum behavior"
  notes:
    - "functools.lru_cache.__annotations__.__class__.__name__ == 'dict' — lru_cache is a Python function; its __annotations__ attribute is an empty dict (no annotated parameters in the decorator factory signature). Verified with Python 3.14.3."
    - "functools.wraps.__annotations__.__class__.__name__ == 'dict' — wraps is a Python function; its __annotations__ is an empty dict. Verified with Python 3.14.3."
    - "functools.cache.__annotations__.__class__.__name__ == 'dict' — cache is a Python function (added in 3.9); its __annotations__ is an empty dict. Verified with Python 3.14.3."
    - "functools.partial.__doc__.__class__.__name__ == 'str' — partial is a C-level type; its __doc__ is a plain Python str. Verified with Python 3.14.3."
    - "functools.partial.__doc__.__len__() == 83 — the docstring 'Create a new function with partial application of the given arguments\\nand keywords.' is exactly 83 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __annotations__.__class__.__name__ for lru_cache, wraps, and cache
#
# All three are Python-level decorator functions whose __annotations__ attribute
# is an empty dict (no type annotations on their parameters).
#
# functools.lru_cache.__annotations__.__class__.__name__ == 'dict'
# functools.wraps.__annotations__.__class__.__name__    == 'dict'
# functools.cache.__annotations__.__class__.__name__    == 'dict'
# ---------------------------------------------------------------------------

table functools_extra214.annotations_class_names:
  description: "functools lru_cache/wraps/cache __annotations__.__class__.__name__ checks in functannotations214 namespace — lru_cache is a Python function whose __annotations__ is an empty dict (class 'dict'); wraps is a Python decorator factory whose __annotations__ is also an empty dict; cache (added in 3.9) is a Python function whose __annotations__ is an empty dict; all three decorator functions lack type annotations on their parameters; __annotations__.__class__.__name__.__eq__('dict')==True for each; verified with Python 3.14.3"
  kind: python_call_eq
  category: annotations
  id_prefix: functannotations214

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_ann_cls,
       lru_cache.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "functools.lru_cache.__annotations__.__class__.__name__ == 'dict' — lru_cache is a Python-defined decorator factory; its __annotations__ is an empty dict; __class__.__name__ is 'dict'; __eq__('dict') returns True; verified with Python 3.14.3"]
    - [wraps_ann_cls,
       wraps.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "functools.wraps.__annotations__.__class__.__name__ == 'dict' — wraps is a Python-defined decorator factory for preserving function metadata; its __annotations__ is an empty dict; __class__.__name__ is 'dict'; __eq__('dict') returns True; verified with Python 3.14.3"]
    - [cache_ann_cls,
       cache.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "functools.cache.__annotations__.__class__.__name__ == 'dict' — cache (added in Python 3.9) is a Python-defined function wrapping lru_cache(maxsize=None); its __annotations__ is an empty dict; __class__.__name__ is 'dict'; __eq__('dict') returns True; verified with Python 3.14.3"]
    - [lru_cache_ann_not_list,
       lru_cache.__annotations__.__class__.__name__.__eq__,
       ["list"],
       false,
       "functools.lru_cache.__annotations__.__class__.__name__ == 'dict' (not 'list') — __annotations__ is a dict, not a list; __eq__('list') returns False; negative cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: __annotations__.__class__.__name__ negative cross-checks
#
# All annotation dicts are 'dict', not 'set', 'tuple', or 'NoneType'.
# ---------------------------------------------------------------------------

table functools_extra214.annotations_class_names_negative:
  description: "functools __annotations__.__class__.__name__ negative cross-checks in functannotations214 namespace — lru_cache/wraps/cache all have __annotations__ of class 'dict'; confirms they are NOT 'set', 'tuple', or 'NoneType'; each __class__.__name__.__eq__('<wrong_type>') returns False; verified with Python 3.14.3"
  kind: python_call_eq
  category: annotations
  id_prefix: functannotations214n

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_ann_not_set,
       lru_cache.__annotations__.__class__.__name__.__eq__,
       ["set"],
       false,
       "functools.lru_cache.__annotations__.__class__.__name__.__eq__('set') == False — __annotations__ is a dict, not a set; __eq__('set') returns False; verified with Python 3.14.3"]
    - [wraps_ann_not_tuple,
