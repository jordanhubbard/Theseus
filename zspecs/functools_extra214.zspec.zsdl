table functools_extra214.partial_doc_attrs:
  description: "functools.partial.__doc__ class name and length checks in functannotations214 namespace — partial is a C-level type; its __doc__ is a Python str (class 'str'); the docstring 'Create a new function with partial application of the given arguments\\nand keywords.' is exactly 83 characters; __doc__.__class__.__name__.__eq__('str')==True; __doc__.__len__()==83; negative: __class__.__name__.__eq__('bytes')==False; negative: __len__().__eq__(80)==False; verified with Python 3.14.3"
  kind: python_call_eq
  category: partial_doc
  id_prefix: functannotations214p

  columns: [id, function, args, expected, description]
  rows:
    - [partial_doc_cls_str,
       partial.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__ == 'str' — partial is a C-level type; its __doc__ is a Python str; __class__.__name__ is 'str'; __eq__('str') returns True; verified with Python 3.14.3"]
    - [partial_doc_len_83,
       partial.__doc__.__len__,
