       ["tuple"],
       false,
       "functools.wraps.__annotations__.__class__.__name__.__eq__('tuple') == False — __annotations__ is a dict, not a tuple; __eq__('tuple') returns False; verified with Python 3.14.3"]
    - [cache_ann_not_nonetype,
       cache.__annotations__.__class__.__name__.__eq__,
       ["NoneType"],
       false,
       "functools.cache.__annotations__.__class__.__name__.__eq__('NoneType') == False — __annotations__ is a dict object (never None); __eq__('NoneType') returns False; verified with Python 3.14.3"]
    - [lru_cache_ann_not_str,
       lru_cache.__annotations__.__class__.__name__.__eq__,
       ["str"],
       false,
       "functools.lru_cache.__annotations__.__class__.__name__.__eq__('str') == False — __annotations__ is a dict, not a str; __eq__('str') returns False; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
