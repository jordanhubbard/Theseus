spec: upper_case
version: ">=3.0.0"
backend: node(upper-case)

docs: https://www.npmjs.com/package/upper-case

provenance:
  derived_from:
    - "upper-case README — https://www.npmjs.com/package/upper-case"
    - "Test vectors verified with upper-case via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "upper-case source"
  notes:
    - "upper-case is an npm package. Install: npm install upper-case"
    - "Converts a string to upper case."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table upper_case.upperCase:
  kind: node_module_call_eq
  function: upperCase
  category: string
  id_prefix: ucase

  columns: [id, args, expected]
  rows:
    - [lower,  ["hello world"],  "HELLO WORLD"]
    - [mixed,  ["FooBar"],       "FOOBAR"]
    - [upper,  ["HELLO"],        "HELLO"]
