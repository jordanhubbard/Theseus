spec: concurrent_futures_extra362
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "concurrent.futures.wait and as_completed both live in module concurrent.futures._base"
    - "FIRST_COMPLETED, FIRST_EXCEPTION, and ALL_COMPLETED are string constants with empty string values"
    - "These constants are used as the when= argument to concurrent.futures.wait()"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra362.function_names:
  description: "Verify __name__ attribute of concurrent.futures wait and as_completed functions"
  kind: python_call_eq
  category: identity
  id_prefix: cf362n

  columns: [id, function, args, expected]
  rows:
    - [cf362n001, concurrent.futures.wait.__name__.__eq__, ["wait"], true]
    - [cf362n002, concurrent.futures.as_completed.__name__.__eq__, ["as_completed"], true]

table concurrent_futures_extra362.function_modules:
  description: "Verify __module__ attribute of concurrent.futures wait and as_completed functions"
  kind: python_call_eq
  category: identity
  id_prefix: cf362m

  columns: [id, function, args, expected]
  rows:
    - [cf362m001, concurrent.futures.wait.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf362m002, concurrent.futures.as_completed.__module__.__eq__, ["concurrent.futures._base"], true]

table concurrent_futures_extra362.wait_constants:
  description: "Verify values of concurrent.futures wait-condition constants"
  kind: python_call_eq
  category: identity
  id_prefix: cf362c

  columns: [id, function, args, expected]
  rows:
    - [cf362c001, concurrent.futures.FIRST_COMPLETED.__eq__, [""], true]
    - [cf362c002, concurrent.futures.FIRST_EXCEPTION.__eq__, [""], true]
    - [cf362c003, concurrent.futures.ALL_COMPLETED.__eq__, [""], true]
