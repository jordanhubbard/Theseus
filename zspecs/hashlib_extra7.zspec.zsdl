spec: hashlib_extra7
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"
  - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "FIPS 202 — SHA-3 Standard, NIST, August 2015"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/_sha512module.c"
    - "CPython source: Modules/md5module.c"
    - "CPython source: Modules/_sha3/sha3module.c"
  notes:
    - "This spec extends hashlib.zspec.zsdl, hashlib_extra.zspec.zsdl, hashlib_extra2.zspec.zsdl, hashlib_extra3.zspec.zsdl, hashlib_extra4.zspec.zsdl, hashlib_extra5.zspec.zsdl, hashlib_extra6.zspec.zsdl."
    - "It does NOT duplicate invariants present in those files."
    - "hashlib_extra4 and hashlib_extra5 cover new.__name__ == 'new' and new.__module__ == 'hashlib' — not repeated here."
    - "hashlib_extra3/4/5 cover algorithms_guaranteed/available class names and __contains__ for sha256/sha1/md5/sha512/sha3_256/blake2b — not repeated here."
    - "hashlib_extra5 covers sha256(b'').digest_size == 32, md5(b'').digest_size == 16, sha1(b'').digest_size == 20 — not repeated here."
    - "This spec adds: hashlib.new('sha512').digest_size == 64 via the new() factory (not the sha512 constructor directly)."
    - "This spec adds: hashlib.new('sha384').digest_size == 48 via new() — sha384 not covered in any prior spec via new()."
    - "This spec adds: hashlib.new('sha3_256').digest_size == 32 via new() — sha3_256 via new() not covered in any prior spec."
    - "This spec adds: hashlib.new('sha256').block_size == 64 via new() — prior specs check via sha256(b'') constructor, not new()."
    - "This spec adds: hashlib.new('sha256').__class__.__name__ — the HASH class name returned by new()."
    - "This spec adds: hashlib.new('sha256').name == 'sha256' via the new() factory — prior specs check via sha256(b'').name."
    - "This spec adds: hashlib.sha384 digest_size == 48 (via constructor) — not covered in any prior spec."
    - "This spec adds: hashlib.sha224 digest_size == 28 (via constructor) — not covered in any prior spec."
    - "hashlib.new('sha256').digest_size == 32, .name == 'sha256', .block_size == 64 — FIPS 180-4 Section 1."
    - "hashlib.new('sha512').digest_size == 64 — SHA-512 produces 512 bits = 64 bytes per FIPS 180-4."
    - "hashlib.new('sha384').digest_size == 48 — SHA-384 produces 384 bits = 48 bytes per FIPS 180-4."
    - "hashlib.new('sha3_256').digest_size == 32 — SHA3-256 produces 256 bits = 32 bytes per FIPS 202."
    - "hashlib.sha384(b'').digest_size == 48 — verified with Python 3.12."
    - "hashlib.sha224(b'').digest_size == 28 — SHA-224 produces 224 bits = 28 bytes per FIPS 180-4."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new() — digest_size for algorithms not previously tested via new()
#
# Prior specs test digest_size via direct constructors (sha256(b''), md5(b''), etc.).
# Here we use the hashlib.new() factory function — orthogonal coverage.
# ---------------------------------------------------------------------------

invariant hashlib_extra7.new.sha256.digest_size:
  description: "hashlib.new('sha256').digest_size == 32 — SHA-256 via new() produces 32 bytes"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha256"]
  method: digest_size.__eq__
  method_args: [32]
  expected: true

invariant hashlib_extra7.new.sha512.digest_size:
  description: "hashlib.new('sha512').digest_size == 64 — SHA-512 via new() produces 64 bytes"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha512"]
  method: digest_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra7.new.sha384.digest_size:
  description: "hashlib.new('sha384').digest_size == 48 — SHA-384 via new() produces 48 bytes"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha384"]
  method: digest_size.__eq__
  method_args: [48]
  expected: true

invariant hashlib_extra7.new.md5.digest_size:
  description: "hashlib.new('md5').digest_size == 16 — MD5 via new() produces 16 bytes"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["md5"]
  method: digest_size.__eq__
  method_args: [16]
  expected: true

invariant hashlib_extra7.new.sha3_256.digest_size:
  description: "hashlib.new('sha3_256').digest_size == 32 — SHA3-256 via new() produces 32 bytes"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha3_256"]
  method: digest_size.__eq__
  method_args: [32]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new() — block_size via the factory
#
# Prior specs check block_size via direct constructors.
# Using new() is orthogonal and validates the factory returns complete objects.
# ---------------------------------------------------------------------------

invariant hashlib_extra7.new.sha256.block_size:
  description: "hashlib.new('sha256').block_size == 64 — SHA-256 via new() uses 64-byte blocks"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha256"]
  method: block_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra7.new.sha512.block_size:
  description: "hashlib.new('sha512').block_size == 128 — SHA-512 via new() uses 128-byte blocks"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha512"]
  method: block_size.__eq__
  method_args: [128]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new() — name attribute via the factory
#
# hashlib_extra5 covers sha256(b'').name == 'sha256' via the direct constructor.
# Here we check the same attribute accessed via hashlib.new() — new coverage.
# ---------------------------------------------------------------------------

invariant hashlib_extra7.new.sha256.name_attr:
  description: "hashlib.new('sha256').name == 'sha256'"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha256"]
  method: name.__eq__
  method_args: ["sha256"]
  expected: true

invariant hashlib_extra7.new.md5.name_attr:
  description: "hashlib.new('md5').name == 'md5'"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["md5"]
  method: name.__eq__
  method_args: ["md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha384 and hashlib.sha224 — digest_size via direct constructors
#
# Prior specs cover sha256/sha1/md5/sha512 digest_size via direct constructors.
# sha384 and sha224 (FIPS 180-4 truncated variants) are not in any prior spec.
# ---------------------------------------------------------------------------

invariant hashlib_extra7.sha384.digest_size:
  description: "hashlib.sha384(b'').digest_size == 48 — SHA-384 produces 384 bits = 48 bytes"
  category: digest_size
  kind: python_call_eq
  function: sha384
  args: [!hex ""]
  method: digest_size.__eq__
  method_args: [48]
  expected: true

invariant hashlib_extra7.sha224.digest_size:
  description: "hashlib.sha224(b'').digest_size == 28 — SHA-224 produces 224 bits = 28 bytes"
  category: digest_size
  kind: python_call_eq
  function: sha224
  args: [!hex ""]
  method: digest_size.__eq__
  method_args: [28]
  expected: true

# ---------------------------------------------------------------------------
# Digest size table — sha256, sha512, sha1, md5 via the new() factory
# Presented as a compact table for cross-algorithm comparison.
# ---------------------------------------------------------------------------

table hashlib_extra7.new_digest_sizes:
  description: "hashlib.new(alg).digest_size for standard algorithms"
  kind: python_call_eq
  category: new_factory
  id_prefix: ds
  function: new

  columns: [id, args, method, method_args, expected]
  rows:
    - [sha1,   ["sha1"],   digest_size.__eq__, [20], true]
    - [sha256, ["sha256"], digest_size.__eq__, [32], true]
    - [sha512, ["sha512"], digest_size.__eq__, [64], true]
    - [md5,    ["md5"],    digest_size.__eq__, [16], true]

# ---------------------------------------------------------------------------
# algorithms_guaranteed — sha384 and sha224 membership
#
# Prior specs check sha256/sha1/md5/sha512/sha3_256/blake2b membership.
# sha384 and sha224 are also guaranteed by FIPS 180-4 and available on
# all standard CPython builds — new coverage.
# ---------------------------------------------------------------------------

invariant hashlib_extra7.algorithms_guaranteed.contains_sha384:
  description: "hashlib.algorithms_guaranteed.__contains__('sha384') == True"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha384"]
  expected: true

invariant hashlib_extra7.algorithms_guaranteed.contains_sha224:
  description: "hashlib.algorithms_guaranteed.__contains__('sha224') == True"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha224"]
  expected: true
