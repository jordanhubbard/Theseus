spec: binascii_extra4
version: ">=3.9"
backend: python_module(binascii)

docs: https://docs.python.org/3/library/binascii.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/binascii.html — Python binascii module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/binascii.c"
  notes:
    - "This spec extends binascii.zspec.zsdl, binascii_extra.zspec.zsdl, binascii_extra2.zspec.zsdl, and binascii_extra3.zspec.zsdl."
    - "binascii_extra.zspec.zsdl: __name__ for hexlify/unhexlify/b2a_base64/a2b_base64/crc32/crc_hqx; __module__ for hexlify; Error/__name__/__bases__; Incomplete/__name__; hexlify(dead)/unhexlify('dead') values."
    - "binascii_extra2.zspec.zsdl: __name__ for hexlify/unhexlify/b2a_hex/a2b_hex/crc32/crc_hqx; __module__ for hexlify/crc32; Error/__name__/__bases__; Incomplete/__name__/__bases__; b2a_hex/a2b_hex values; crc_hqx(b'',0)==0."
    - "binascii_extra3.zspec.zsdl: __name__ table for hexlify/unhexlify/crc32/b2a_base64/a2b_base64/b2a_hex/a2b_hex; hexlify(hello)/unhexlify(hello)/crc32(hello)/a2b_base64(hello) values; Error/__name__/__bases__; Incomplete/__name__."
    - "Focus: __module__ checks for unhexlify, b2a_hex, a2b_hex, crc_hqx not covered by prior specs; Error/__module__; Incomplete/__module__; __qualname__ checks; b2a_base64 output value; crc_hqx with non-empty data."
    - "binascii built-in functions report __module__ == 'binascii'."
    - "binascii.Error.__module__ == 'binascii' — the exception class is defined in the binascii C module."
    - "binascii.Incomplete.__module__ == 'binascii' — the exception class is defined in the binascii C module."
    - "binascii.b2a_base64(b'hello') == b'aGVsbG8=\\n' — base64 encoding with trailing newline."
    - "binascii.crc_hqx(b'A', 0) == 49664 — CRC-CCITT of b'A' with initial value 0, verified on Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks — functions not covered in prior specs
# binascii_extra.__module__.hexlify and binascii_extra2.__module__.hexlify/crc32 exist.
# We add: unhexlify, b2a_hex, a2b_hex, crc_hqx, b2a_base64, a2b_base64.
# ---------------------------------------------------------------------------

table binascii_extra4.function_modules:
  kind: python_call_eq
  category: module
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [unhexlify,  unhexlify.__module__.__eq__,  ["binascii"], true]
    - [b2a_hex,    b2a_hex.__module__.__eq__,    ["binascii"], true]
    - [a2b_hex,    a2b_hex.__module__.__eq__,    ["binascii"], true]
    - [crc_hqx,    crc_hqx.__module__.__eq__,    ["binascii"], true]
    - [b2a_base64, b2a_base64.__module__.__eq__,  ["binascii"], true]
    - [a2b_base64, a2b_base64.__module__.__eq__,  ["binascii"], true]

# ---------------------------------------------------------------------------
# Exception class __module__ checks — not covered in any prior binascii spec
# ---------------------------------------------------------------------------

invariant binascii_extra4.Error.module:
  description: "binascii.Error.__module__ == 'binascii'"
  category: exceptions
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["binascii"]
  expected: true

invariant binascii_extra4.Incomplete.module:
  description: "binascii.Incomplete.__module__ == 'binascii'"
  category: exceptions
  kind: python_call_eq
  function: Incomplete.__module__.__eq__
  args: ["binascii"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ checks — not covered in any prior binascii spec
# binascii C-extension functions have __qualname__ equal to their __name__.
# ---------------------------------------------------------------------------

table binascii_extra4.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [hexlify,    hexlify.__qualname__.__eq__,    ["hexlify"],    true]
    - [unhexlify,  unhexlify.__qualname__.__eq__,  ["unhexlify"],  true]
    - [b2a_hex,    b2a_hex.__qualname__.__eq__,    ["b2a_hex"],    true]
    - [a2b_hex,    a2b_hex.__qualname__.__eq__,    ["a2b_hex"],    true]
    - [crc32,      crc32.__qualname__.__eq__,      ["crc32"],      true]
    - [crc_hqx,    crc_hqx.__qualname__.__eq__,    ["crc_hqx"],    true]

# ---------------------------------------------------------------------------
# Exception class __qualname__ checks
# ---------------------------------------------------------------------------

invariant binascii_extra4.Error.qualname:
  description: "binascii.Error.__qualname__ == 'Error'"
  category: exceptions
  kind: python_call_eq
  function: Error.__qualname__.__eq__
  args: ["Error"]
  expected: true

invariant binascii_extra4.Incomplete.qualname:
  description: "binascii.Incomplete.__qualname__ == 'Incomplete'"
  category: exceptions
  kind: python_call_eq
  function: Incomplete.__qualname__.__eq__
  args: ["Incomplete"]
  expected: true

# ---------------------------------------------------------------------------
# b2a_base64 — output value
# No prior spec verifies the actual output of b2a_base64.
# b2a_base64(b'hello') == b'aGVsbG8=\n' (RFC 4648 base64 with trailing newline).
# ---------------------------------------------------------------------------

invariant binascii_extra4.b2a_base64.hello:
  description: "binascii.b2a_base64(b'hello') == b'aGVsbG8=\\n'"
  category: base64
  kind: python_call_eq
  function: b2a_base64
  args: [!hex 68656c6c6f]
  expected: !ascii "aGVsbG8=\n"

# ---------------------------------------------------------------------------
# b2a_base64 — output length
# b2a_base64(b'hello') produces 9 bytes: 'aGVsbG8=\n' (8 base64 chars + 1 newline).
# ---------------------------------------------------------------------------

invariant binascii_extra4.b2a_base64.hello_length:
  description: "binascii.b2a_base64(b'hello').__len__() == 9"
  category: base64
  kind: python_call_eq
  function: b2a_base64
  args: [!hex 68656c6c6f]
  method: __len__
  expected: 9

# ---------------------------------------------------------------------------
# crc_hqx — non-empty data vector
# binascii_extra2 covers crc_hqx(b'', 0) == 0 (empty input).
# We add crc_hqx(b'A', 0) == 49664, verified on Python 3.12.
# ---------------------------------------------------------------------------

invariant binascii_extra4.crc_hqx.byte_A:
  description: "binascii.crc_hqx(b'A', 0) == 49664 — CRC-CCITT of b'A' with initial CRC 0"
  category: crc_hqx
  kind: python_call_eq
  function: crc_hqx
  args: [!hex 41, 0]
  expected: 49664

# ---------------------------------------------------------------------------
# hexlify — output class name
# Confirms that hexlify returns a bytes object (class name 'bytes').
# ---------------------------------------------------------------------------

invariant binascii_extra4.hexlify.returns_bytes:
  description: "binascii.hexlify(b'hello').__class__.__name__ == 'bytes'"
  category: hexlify
  kind: python_call_eq
  function: hexlify
  args: [!hex 68656c6c6f]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true
