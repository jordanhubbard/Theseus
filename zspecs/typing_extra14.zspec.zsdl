spec: typing_extra14
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "PEP 484 — Type Hints"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing.zspec.zsdl through typing_extra13.zspec.zsdl."
    - "typing_extra5 covers Any.__class__.__name__ == '_SpecialForm' (pre-3.14 behaviour)."
    - "typing_extra2 covers Union.__class__.__name__ == 'type' and Optional.__class__.__name__ == '_SpecialForm'."
    - "typing_extra8 covers Callable.__class__.__name__ == '_SpecialForm'."
    - "typing_extra6 covers Optional._name == 'Optional' in a table row."
    - "typing_extra12 covers ClassVar._name == 'ClassVar' as a standalone invariant."
    - "NOT yet covered: typing.Any.__name__ == 'Any' — in Python 3.14+, Any has a metaclass (_AnyMeta) that exposes __name__."
    - "NOT yet covered: typing.Union.__name__ == 'Union' — Union is a plain type in Python 3.14+."
    - "NOT yet covered: typing.Callable.__name__ == 'Callable' — Callable exposes __name__ via its metaclass."
    - "NOT yet covered: typing.Optional.__name__ == 'Optional' — Optional is a _SpecialForm with a __name__ attribute."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Any.__name__ — standalone invariant
#
# In Python 3.14+, typing.Any uses a metaclass (_AnyMeta) that provides
# __name__ == 'Any'. Prior specs check Any.__class__.__name__ == '_SpecialForm'
# (Python < 3.14) or '_AnyMeta'. No prior spec checks Any.__name__ directly.
# ---------------------------------------------------------------------------

invariant typing_extra14.Any.name:
  description: "typing.Any.__name__ == 'Any'"
  category: class_names
  kind: python_call_eq
  function: Any.__name__.__eq__
  args: ["Any"]
  expected: true

# ---------------------------------------------------------------------------
# Union.__name__ — standalone invariant
#
# In Python 3.14+, typing.Union is a plain type object with __name__ == 'Union'.
# Prior specs check Union.__class__.__name__ == 'type' (extra2) but never
# access Union.__name__ directly as a standalone invariant.
# ---------------------------------------------------------------------------

invariant typing_extra14.Union.name:
  description: "typing.Union.__name__ == 'Union'"
  category: class_names
  kind: python_call_eq
  function: Union.__name__.__eq__
  args: ["Union"]
  expected: true

# ---------------------------------------------------------------------------
# Callable.__name__ — standalone invariant
#
# typing.Callable exposes __name__ == 'Callable' via its special-form
# infrastructure. Prior specs check Callable.__class__.__name__ (extra8)
# and Callable._name (extra6 table). No prior spec checks Callable.__name__
# directly as a standalone invariant.
# ---------------------------------------------------------------------------

invariant typing_extra14.Callable.name:
  description: "typing.Callable.__name__ == 'Callable'"
  category: class_names
  kind: python_call_eq
  function: Callable.__name__.__eq__
  args: ["Callable"]
  expected: true

# ---------------------------------------------------------------------------
# Optional.__name__ — standalone invariant
#
# typing.Optional is a _SpecialForm. Prior specs check Optional.__class__.__name__
# (extra2) and Optional._name (extra6 table). No prior spec checks
# Optional.__name__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant typing_extra14.Optional.name:
  description: "typing.Optional.__name__ == 'Optional'"
  category: class_names
  kind: python_call_eq
  function: Optional.__name__.__eq__
  args: ["Optional"]
  expected: true

# ---------------------------------------------------------------------------
# Callable._name — standalone invariant
#
# typing_extra6 covers Optional._name in a table row but not Callable._name.
# typing_extra12 covers ClassVar._name as a standalone invariant.
# Callable._name == 'Callable' is a distinct axis not yet covered standalone.
# ---------------------------------------------------------------------------

invariant typing_extra14.Callable._name:
  description: "typing.Callable._name == 'Callable' — internal _SpecialForm name attribute"
  category: class_names
  kind: python_call_eq
  function: Callable._name.__eq__
  args: ["Callable"]
  expected: true

# ---------------------------------------------------------------------------
# Table: __name__ for all four special-form / type-level typing constructs
#
# Bundles the four new __name__ invariants as table rows for machine indexing.
# All four are newly covered by this spec; prior specs only covered _name or
# __class__.__name__, not __name__ directly.
# ---------------------------------------------------------------------------

table typing_extra14.special_form_names:
  description: "typing special forms and type constructs expose __name__"
  kind: python_call_eq
  category: class_names
  id_prefix: sfname

  columns: [id, function, args, expected]
  rows:
    - [Any,      Any.__name__.__eq__,      ["Any"],      true]
    - [Union,    Union.__name__.__eq__,    ["Union"],    true]
    - [Callable, Callable.__name__.__eq__, ["Callable"], true]
    - [Optional, Optional.__name__.__eq__, ["Optional"], true]
