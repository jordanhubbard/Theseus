spec: uuid_extra2131
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid.zspec.zsdl — covers UUID construction, hex, str, int, bytes, version, variant attrs"
    - "uuid_extra.zspec.zsdl — covers SafeUUID enum values, uuid1/uuid3/uuid4/uuid5 function names"
  notes:
    - "Wave extra2131, theme: exception protocol dict-presence."
    - "Checks whether exception-related protocol attributes (__cause__, __context__, __traceback__, __suppress_context__, __notes__, args, with_traceback) appear in the __dict__ of uuid types."
    - "uuid.UUID is a non-exception class that uses __slots__; exception protocol attributes are absent from its __dict__."
    - "uuid.SafeUUID is an IntEnum subclass (non-exception); exception protocol attributes are absent from its __dict__."
    - "The uuid module exposes no exception subclasses of its own; ValueError is raised for invalid inputs but it is a builtin, not defined in uuid."
    - "__cause__, __context__, __traceback__, __suppress_context__ are instance attrs set by CPython — NOT in any class __dict__."
    - "args and with_traceback live in BaseException.__dict__, not in UUID or SafeUUID __dict__."
    - "UUID.__dict__ contains: __slots__, __init__, __hash__, __eq__, __lt__, __gt__, __le__, __ge__, __repr__, __str__, __setattr__, __int__, bytes, bytes_le, fields, hex, urn, variant, version, int, is_safe, time, clock_seq, node, and others."
    - "SafeUUID.__dict__ contains: safe, unsafe, unknown, __new__, _generate_next_value_, and standard IntEnum infrastructure keys."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID — exception protocol attributes absent from class __dict__
# UUID uses __slots__ and is not an exception type.
# ---------------------------------------------------------------------------

table uuid_extra2131.uuid_exception_protocol:
  kind: python_call_eq
  category: exception_protocol
  id_prefix: uu2131

  columns: [id, function, args, expected]
  rows:
    - ["uu2131001", UUID.__dict__.__contains__, ["__cause__"],             false]
    - ["uu2131002", UUID.__dict__.__contains__, ["__context__"],           false]
    - ["uu2131003", UUID.__dict__.__contains__, ["__traceback__"],         false]
    - ["uu2131004", UUID.__dict__.__contains__, ["__suppress_context__"],  false]
    - ["uu2131005", UUID.__dict__.__contains__, ["__notes__"],             false]
    - ["uu2131006", UUID.__dict__.__contains__, ["args"],                  false]
    - ["uu2131007", UUID.__dict__.__contains__, ["with_traceback"],        false]

# ---------------------------------------------------------------------------
# SafeUUID — exception protocol attributes absent from class __dict__
# SafeUUID is an IntEnum subclass, not an exception type.
# ---------------------------------------------------------------------------

table uuid_extra2131.safeuuid_exception_protocol:
  kind: python_call_eq
  category: exception_protocol
  id_prefix: uu2131

  columns: [id, function, args, expected]
  rows:
    - ["uu2131008", SafeUUID.__dict__.__contains__, ["__cause__"],             false]
    - ["uu2131009", SafeUUID.__dict__.__contains__, ["__context__"],           false]
    - ["uu2131010", SafeUUID.__dict__.__contains__, ["__traceback__"],         false]
    - ["uu2131011", SafeUUID.__dict__.__contains__, ["__suppress_context__"],  false]
    - ["uu2131012", SafeUUID.__dict__.__contains__, ["__notes__"],             false]
    - ["uu2131013", SafeUUID.__dict__.__contains__, ["args"],                  false]
    - ["uu2131014", SafeUUID.__dict__.__contains__, ["with_traceback"],        false]

# ---------------------------------------------------------------------------
# UUID — positive presence: known real attributes ARE in __dict__
# Confirms __dict__.__contains__ works correctly for UUID.
# ---------------------------------------------------------------------------

table uuid_extra2131.uuid_real_attrs:
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2131

  columns: [id, function, args, expected]
  rows:
    - ["uu2131015", UUID.__dict__.__contains__, ["__slots__"],   true]
    - ["uu2131016", UUID.__dict__.__contains__, ["__hash__"],    true]
    - ["uu2131017", UUID.__dict__.__contains__, ["__eq__"],      true]
    - ["uu2131018", UUID.__dict__.__contains__, ["hex"],         true]
    - ["uu2131019", UUID.__dict__.__contains__, ["bytes"],       true]
    - ["uu2131020", UUID.__dict__.__contains__, ["int"],         true]
    - ["uu2131021", UUID.__dict__.__contains__, ["version"],     true]
    - ["uu2131022", UUID.__dict__.__contains__, ["variant"],     true]

# ---------------------------------------------------------------------------
# SafeUUID — positive presence: known enum members ARE in __dict__
# ---------------------------------------------------------------------------

table uuid_extra2131.safeuuid_real_attrs:
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2131

  columns: [id, function, args, expected]
  rows:
    - ["uu2131023", SafeUUID.__dict__.__contains__, ["safe"],    true]
    - ["uu2131024", SafeUUID.__dict__.__contains__, ["unsafe"],  true]
    - ["uu2131025", SafeUUID.__dict__.__contains__, ["unknown"], true]
    - ["uu2131026", SafeUUID.__dict__.__contains__, ["__new__"], true]
