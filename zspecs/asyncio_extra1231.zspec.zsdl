spec: asyncio_extra1231
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio.__dict__.__contains__ for Queue, Task, Future, Lock, Event, Semaphore, run, sleep, gather, wait_for, create_task, StreamReader, StreamWriter, Barrier, TaskGroup, BoundedSemaphore, Runner, timeout, shield, wait"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio.__dict__.__contains__ for class names, coroutine functions, and absent names (Thread, Process, nonexistent); also checks qualname identity for Queue, Task, Future, Lock, Event, Semaphore — behaviors not covered by extra1201 (__bases__/__mro__ lengths) or extra1216 (__mro__.__len__ per class)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra1231.dict_contains_classes:
  description: "asyncio.__dict__ contains the expected synchronization and IO class names: Queue, Task, Future, Lock, Event, Semaphore, StreamReader, StreamWriter, Barrier, TaskGroup, BoundedSemaphore"
  kind: python_call_eq
  category: module_interface
  id_prefix: as1231dc
  columns: [id, function, args, expected]
  rows:
    - [as1231dc001, asyncio.__dict__.__contains__, ["Queue"],            true]
    - [as1231dc002, asyncio.__dict__.__contains__, ["Task"],             true]
    - [as1231dc003, asyncio.__dict__.__contains__, ["Future"],           true]
    - [as1231dc004, asyncio.__dict__.__contains__, ["Lock"],             true]
    - [as1231dc005, asyncio.__dict__.__contains__, ["Event"],            true]
    - [as1231dc006, asyncio.__dict__.__contains__, ["Semaphore"],        true]
    - [as1231dc007, asyncio.__dict__.__contains__, ["StreamReader"],     true]
    - [as1231dc008, asyncio.__dict__.__contains__, ["StreamWriter"],     true]
    - [as1231dc009, asyncio.__dict__.__contains__, ["Barrier"],          true]
    - [as1231dc010, asyncio.__dict__.__contains__, ["TaskGroup"],        true]
    - [as1231dc011, asyncio.__dict__.__contains__, ["BoundedSemaphore"], true]
    - [as1231dc012, asyncio.__dict__.__contains__, ["Runner"],           true]

table asyncio_extra1231.dict_contains_functions:
  description: "asyncio.__dict__ contains the expected coroutine function names: run, sleep, gather, wait_for, create_task, shield, wait, timeout, timeout_at"
  kind: python_call_eq
  category: module_interface
  id_prefix: as1231df
  columns: [id, function, args, expected]
  rows:
    - [as1231df001, asyncio.__dict__.__contains__, ["run"],         true]
    - [as1231df002, asyncio.__dict__.__contains__, ["sleep"],       true]
    - [as1231df003, asyncio.__dict__.__contains__, ["gather"],      true]
    - [as1231df004, asyncio.__dict__.__contains__, ["wait_for"],    true]
    - [as1231df005, asyncio.__dict__.__contains__, ["create_task"], true]
    - [as1231df006, asyncio.__dict__.__contains__, ["shield"],      true]
    - [as1231df007, asyncio.__dict__.__contains__, ["wait"],        true]
    - [as1231df008, asyncio.__dict__.__contains__, ["timeout"],     true]
    - [as1231df009, asyncio.__dict__.__contains__, ["timeout_at"],  true]

table asyncio_extra1231.dict_absent_names_and_qualnames:
  description: "asyncio.__dict__ does NOT contain Thread, Process, nonexistent, Lock2; and asyncio class __qualname__ values equal their simple names"
  kind: python_call_eq
  category: module_interface
  id_prefix: as1231qa
  columns: [id, function, args, expected]
  rows:
    - [as1231qa001, asyncio.__dict__.__contains__, ["Thread"],      false]
    - [as1231qa002, asyncio.__dict__.__contains__, ["Process"],     false]
    - [as1231qa003, asyncio.__dict__.__contains__, ["nonexistent"], false]
    - [as1231qa004, asyncio.__dict__.__contains__, ["Lock2"],       false]
    - [as1231qa005, asyncio.__dict__.__contains__, ["Future2"],     false]
    - [as1231qa006, asyncio.Queue.__qualname__.__eq__,    ["Queue"],    true]
    - [as1231qa007, asyncio.Task.__qualname__.__eq__,     ["Task"],     true]
    - [as1231qa008, asyncio.Future.__qualname__.__eq__,   ["Future"],   true]
    - [as1231qa009, asyncio.Lock.__qualname__.__eq__,     ["Lock"],     true]
    - [as1231qa010, asyncio.Event.__qualname__.__eq__,    ["Event"],    true]
    - [as1231qa011, asyncio.Semaphore.__qualname__.__eq__, ["Semaphore"], true]
    - [as1231qa012, asyncio.run.__qualname__.__eq__,      ["run"],      true]
