spec: pad_left
version: ">=2.1.0"
backend: node(pad-left)

docs: https://www.npmjs.com/package/pad-left

provenance:
  derived_from:
    - "pad-left README — https://www.npmjs.com/package/pad-left"
    - "Test vectors verified with pad-left via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "pad-left source"
  notes:
    - "pad-left is an npm package. Install: npm install pad-left"
    - "padLeft(str, len, ch) pads str on the left with ch (default space) to at least length len."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the padded string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table pad_left.padLeft:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: padleft

  columns: [id, args, expected]
  rows:
    - [space_pad, ["hi", 5],        "   hi"]
    - [zero_pad,  ["42", 6, "0"],   "000042"]
