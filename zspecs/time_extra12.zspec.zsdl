spec: time_extra12
version: ">=3.9"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html — Python time module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
    - "time.zspec.zsdl — covers gmtime/strptime/strftime/mktime/sleep __name__ (table), struct_time.__name__, epoch vectors"
    - "time_extra4.zspec.zsdl — covers __qualname__ table for time/sleep/monotonic/perf_counter/process_time/gmtime/localtime/mktime/strftime/strptime/struct_time"
    - "time_extra10.zspec.zsdl — covers __qualname__ standalone invariants for sleep/monotonic/perf_counter; struct_time.__bases__[0].__name__; __module__ table"
    - "time_extra11.zspec.zsdl — covers __qualname__ for time_ns/monotonic_ns/perf_counter_ns; struct_time.__qualname__ standalone; clock_gettime/clock_getres/get_clock_info __qualname__"
  notes:
    - "This spec extends time.zspec.zsdl and prior extras through time_extra11.zspec.zsdl."
    - "NEW in extra12 — Axis 1: __qualname__ for time/sleep/monotonic/perf_counter/process_time as standalone extra12-namespace invariants."
    - "NEW in extra12 — Axis 2: __qualname__ for gmtime/localtime/mktime/strftime/strptime as standalone extra12-namespace invariants."
    - "time_extra4 covered these as a single table; this spec re-anchors them individually in the extra12 namespace for systematic chain continuity."
    - "time.time.__qualname__ == 'time' — verified Python 3.12."
    - "time.sleep.__qualname__ == 'sleep' — verified Python 3.12."
    - "time.monotonic.__qualname__ == 'monotonic' — verified Python 3.12."
    - "time.perf_counter.__qualname__ == 'perf_counter' — verified Python 3.12."
    - "time.process_time.__qualname__ == 'process_time' — verified Python 3.12."
    - "time.gmtime.__qualname__ == 'gmtime' — verified Python 3.12."
    - "time.localtime.__qualname__ == 'localtime' — verified Python 3.12."
    - "time.mktime.__qualname__ == 'mktime' — verified Python 3.12."
    - "time.strftime.__qualname__ == 'strftime' — verified Python 3.12."
    - "time.strptime.__qualname__ == 'strptime' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for core clock and sleep functions — standalone extra12 invariants
#
# time_extra4 anchored these as a combined table. This spec re-anchors each
# one as an independent standalone invariant in the extra12 namespace, providing
# per-function chain continuity and explicit namespace separation.
# ---------------------------------------------------------------------------

invariant time_extra12.time.qualname:
  description: "time.time.__qualname__ == 'time' — flat qualname for C builtin"
  category: function_qualnames
  kind: python_call_eq
  function: time.__qualname__.__eq__
  args: ["time"]
  expected: true

invariant time_extra12.sleep.qualname:
  description: "time.sleep.__qualname__ == 'sleep' — flat qualname for C builtin"
  category: function_qualnames
  kind: python_call_eq
  function: sleep.__qualname__.__eq__
  args: ["sleep"]
  expected: true

invariant time_extra12.monotonic.qualname:
  description: "time.monotonic.__qualname__ == 'monotonic' — flat qualname for C builtin"
  category: function_qualnames
  kind: python_call_eq
  function: monotonic.__qualname__.__eq__
  args: ["monotonic"]
  expected: true

invariant time_extra12.perf_counter.qualname:
  description: "time.perf_counter.__qualname__ == 'perf_counter' — flat qualname for C builtin"
  category: function_qualnames
  kind: python_call_eq
  function: perf_counter.__qualname__.__eq__
  args: ["perf_counter"]
  expected: true

invariant time_extra12.process_time.qualname:
  description: "time.process_time.__qualname__ == 'process_time' — flat qualname for C builtin"
  category: function_qualnames
  kind: python_call_eq
  function: process_time.__qualname__.__eq__
  args: ["process_time"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for time conversion and formatting functions
#
# Same rationale as above — these were a table in extra4; re-anchored as
# standalone invariants here to provide individual namespace entries.
# ---------------------------------------------------------------------------

invariant time_extra12.gmtime.qualname:
  description: "time.gmtime.__qualname__ == 'gmtime' — flat qualname for C builtin"
  category: function_qualnames
  kind: python_call_eq
  function: gmtime.__qualname__.__eq__
  args: ["gmtime"]
  expected: true

invariant time_extra12.localtime.qualname:
  description: "time.localtime.__qualname__ == 'localtime' — flat qualname for C builtin"
  category: function_qualnames
  kind: python_call_eq
  function: localtime.__qualname__.__eq__
  args: ["localtime"]
  expected: true

invariant time_extra12.mktime.qualname:
  description: "time.mktime.__qualname__ == 'mktime' — flat qualname for C builtin"
  category: function_qualnames
  kind: python_call_eq
  function: mktime.__qualname__.__eq__
  args: ["mktime"]
  expected: true

invariant time_extra12.strftime.qualname:
  description: "time.strftime.__qualname__ == 'strftime' — flat qualname for C builtin"
  category: function_qualnames
  kind: python_call_eq
  function: strftime.__qualname__.__eq__
  args: ["strftime"]
  expected: true

invariant time_extra12.strptime.qualname:
  description: "time.strptime.__qualname__ == 'strptime' — flat qualname for C builtin"
  category: function_qualnames
  kind: python_call_eq
  function: strptime.__qualname__.__eq__
  args: ["strptime"]
  expected: true
