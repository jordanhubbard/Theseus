spec: concurrent_futures_extra112
version: ">=3.11"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra111.zspec.zsdl."
    - "This spec covers: wave 255 theme — concurrent.futures.ThreadPoolExecutor and ProcessPoolExecutor method co_qualname attributes (Python 3.11+) not covered in extra89-extra111. Prior specs covered: __qualname__ strings (extra89, extra94, extra97), __init__ co_argcount (extra94, extra104), and module/mro/bases identity (extra90, extra95). NOT previously covered: co_qualname values for executor methods. NEW in extra112: ThreadPoolExecutor.submit.__code__.co_qualname=='ThreadPoolExecutor.submit' (len=25); ThreadPoolExecutor.shutdown.__code__.co_qualname=='ThreadPoolExecutor.shutdown' (len=27); ThreadPoolExecutor.__init__.__code__.co_qualname=='ThreadPoolExecutor.__init__' (len=27, tied longest for TPE); ProcessPoolExecutor.submit.__code__.co_qualname=='ProcessPoolExecutor.submit' (len=26); ProcessPoolExecutor.shutdown.__code__.co_qualname=='ProcessPoolExecutor.shutdown' (len=28, longest in spec); ProcessPoolExecutor.__init__.__code__.co_qualname=='ProcessPoolExecutor.__init__' (len=28, tied longest); ProcessPoolExecutor.map.__code__.co_qualname=='ProcessPoolExecutor.map' (len=23, shortest PPE co_qualname). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "ThreadPoolExecutor method co_qualname length ordering: submit=25 < shutdown==__init__==27 (tied longest for TPE). ProcessPoolExecutor method co_qualname length ordering: map=23 (shortest PPE) < submit=26 < shutdown==__init__==28 (tied longest in spec). All co_qualname values match the corresponding __qualname__ values (confirmed: co_qualname==__qualname__ for module-level class methods). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "ProcessPoolExecutor.__init__.__code__.co_argcount == 5 (self, max_workers, mp_context, initializer, initargs). ThreadPoolExecutor.__init__.__code__.co_argcount == 5 (self, max_workers, thread_name_prefix, initializer, initargs). Both have the same co_argcount=5. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor method co_qualname — extra112
#
# Wave 255 theme: TPE method co_qualname values (Python 3.11+).
#
# concurrent.futures.ThreadPoolExecutor.submit.__code__.co_qualname   == 'ThreadPoolExecutor.submit'   (len=25)
# concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_qualname == 'ThreadPoolExecutor.shutdown' (len=27)
# concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_qualname == 'ThreadPoolExecutor.__init__' (len=27, tied longest)
# ---------------------------------------------------------------------------

table concurrent_futures_extra112.cf_tpe_coqualname:
  description: "concurrent.futures.ThreadPoolExecutor method co_qualname checks in cftpe112 namespace — wave 255 theme: co_qualname is a Python 3.11+ code object attribute; for module-level class methods, co_qualname equals __qualname__; concurrent.futures.ThreadPoolExecutor.submit.__code__.co_qualname.__eq__('ThreadPoolExecutor.submit')==True (len=25: 'ThreadPoolExecutor.'=19+'submit'=6=25; co_qualname matches TPE.submit.__qualname__ from extra97; co_argcount=2: self and fn, then *args and **kwargs are variadic); concurrent.futures.ThreadPoolExecutor.submit.__code__.co_qualname.__len__()==25; concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_qualname.__eq__('ThreadPoolExecutor.shutdown')==True (len=27: 'ThreadPoolExecutor.'=19+'shutdown'=8=27; tied longest co_qualname for TPE; co_argcount=2: self and wait); concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_qualname.__len__()==27; concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_qualname.__eq__('ThreadPoolExecutor.__init__')==True (len=27: 'ThreadPoolExecutor.'=19+'__init__'=8=27; tied longest with shutdown; co_argcount=5: self, max_workers, thread_name_prefix, initializer, initargs); concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_qualname.__len__()==27; concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__(5)==True; compare TPE co_qualname lengths: submit=25 < shutdown==__init__==27 (tied longest); co_qualname length ordering mirrors __qualname__ length ordering; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cftpe112

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_sub_coq_eq,   concurrent.futures.ThreadPoolExecutor.submit.__code__.co_qualname.__eq__,    ["ThreadPoolExecutor.submit"],    true, "TPE.submit co_qualname == 'ThreadPoolExecutor.submit' (len=25, Python 3.11+); verified with Python 3.14.3"]
    - [tpe_sub_coq_len,  concurrent.futures.ThreadPoolExecutor.submit.__code__.co_qualname.__len__,   [],                               25,   "TPE.submit co_qualname.__len__() == 25 ('ThreadPoolExecutor.submit'=25); verified with Python 3.14.3"]
    - [tpe_sub_argc,     concurrent.futures.ThreadPoolExecutor.submit.__code__.co_argcount.__eq__,    [2],                              true, "TPE.submit.__code__.co_argcount == 2 (self and fn); verified with Python 3.14.3"]
    - [tpe_sdn_coq_eq,   concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_qualname.__eq__,  ["ThreadPoolExecutor.shutdown"],  true, "TPE.shutdown co_qualname == 'ThreadPoolExecutor.shutdown' (len=27, tied longest for TPE); verified with Python 3.14.3"]
    - [tpe_sdn_coq_len,  concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_qualname.__len__, [],                               27,   "TPE.shutdown co_qualname.__len__() == 27 ('ThreadPoolExecutor.shutdown'=27, tied longest for TPE); verified with Python 3.14.3"]
    - [tpe_sdn_argc,     concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_argcount.__eq__,  [2],                              true, "TPE.shutdown.__code__.co_argcount == 2 (self and wait); verified with Python 3.14.3"]
    - [tpe_ini_coq_eq,   concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_qualname.__eq__,  ["ThreadPoolExecutor.__init__"],  true, "TPE.__init__ co_qualname == 'ThreadPoolExecutor.__init__' (len=27, tied longest for TPE); verified with Python 3.14.3"]
    - [tpe_ini_coq_len,  concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_qualname.__len__, [],                               27,   "TPE.__init__ co_qualname.__len__() == 27 (tied with shutdown); verified with Python 3.14.3"]
    - [tpe_ini_argc,     concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__,  [5],                              true, "TPE.__init__.__code__.co_argcount == 5 (self, max_workers, thread_name_prefix, initializer, initargs); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.ProcessPoolExecutor method co_qualname — extra112
#
# Wave 255 theme: PPE method co_qualname values (Python 3.11+).
#
# concurrent.futures.ProcessPoolExecutor.map.__code__.co_qualname      == 'ProcessPoolExecutor.map'      (len=23, shortest PPE)
# concurrent.futures.ProcessPoolExecutor.submit.__code__.co_qualname   == 'ProcessPoolExecutor.submit'   (len=26)
# concurrent.futures.ProcessPoolExecutor.shutdown.__code__.co_qualname == 'ProcessPoolExecutor.shutdown' (len=28, longest in spec)
# concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_qualname == 'ProcessPoolExecutor.__init__' (len=28, tied longest)
# ---------------------------------------------------------------------------

table concurrent_futures_extra112.cf_ppe_coqualname:
  description: "concurrent.futures.ProcessPoolExecutor method co_qualname checks in cftpe112 namespace — wave 255 theme: concurrent.futures.ProcessPoolExecutor.map.__code__.co_qualname.__eq__('ProcessPoolExecutor.map')==True (len=23: 'ProcessPoolExecutor.'=20+'map'=3=23; shortest PPE co_qualname; PPE defines its own map override, so co_qualname uses PPE prefix not Executor prefix — compare: TPE inherits map from Executor, so TPE.map co_qualname would be 'Executor.map'); concurrent.futures.ProcessPoolExecutor.map.__code__.co_qualname.__len__()==23; concurrent.futures.ProcessPoolExecutor.submit.__code__.co_qualname.__eq__('ProcessPoolExecutor.submit')==True (len=26: 'ProcessPoolExecutor.'=20+'submit'=6=26; co_argcount=2: self and fn); concurrent.futures.ProcessPoolExecutor.submit.__code__.co_qualname.__len__()==26; concurrent.futures.ProcessPoolExecutor.shutdown.__code__.co_qualname.__eq__('ProcessPoolExecutor.shutdown')==True (len=28: 'ProcessPoolExecutor.'=20+'shutdown'=8=28; tied longest in spec; co_argcount=2: self and wait); concurrent.futures.ProcessPoolExecutor.shutdown.__code__.co_qualname.__len__()==28; concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_qualname.__eq__('ProcessPoolExecutor.__init__')==True (len=28: 'ProcessPoolExecutor.'=20+'__init__'=8=28; tied longest with shutdown; co_argcount=5: self, max_workers, mp_context, initializer, initargs); concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_qualname.__len__()==28; compare PPE co_qualname lengths: map=23 (shortest PPE) < submit=26 < shutdown==__init__==28 (tied longest); compare TPE vs PPE longest co_qualname: TPE=27 < PPE=28 (1 char longer because 'ProcessPoolExecutor'=19 vs 'ThreadPoolExecutor'=18); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cftpe112a

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_map_coq_eq,   concurrent.futures.ProcessPoolExecutor.map.__code__.co_qualname.__eq__,      ["ProcessPoolExecutor.map"],      true, "PPE.map co_qualname == 'ProcessPoolExecutor.map' (len=23, shortest PPE co_qualname); verified with Python 3.14.3"]
    - [ppe_map_coq_len,  concurrent.futures.ProcessPoolExecutor.map.__code__.co_qualname.__len__,     [],                               23,   "PPE.map co_qualname.__len__() == 23 ('ProcessPoolExecutor.map'=23, shortest PPE); verified with Python 3.14.3"]
    - [ppe_sub_coq_eq,   concurrent.futures.ProcessPoolExecutor.submit.__code__.co_qualname.__eq__,   ["ProcessPoolExecutor.submit"],   true, "PPE.submit co_qualname == 'ProcessPoolExecutor.submit' (len=26); verified with Python 3.14.3"]
    - [ppe_sub_coq_len,  concurrent.futures.ProcessPoolExecutor.submit.__code__.co_qualname.__len__,  [],                               26,   "PPE.submit co_qualname.__len__() == 26 ('ProcessPoolExecutor.submit'=26); verified with Python 3.14.3"]
    - [ppe_sub_argc,     concurrent.futures.ProcessPoolExecutor.submit.__code__.co_argcount.__eq__,   [2],                              true, "PPE.submit.__code__.co_argcount == 2 (self and fn); verified with Python 3.14.3"]
    - [ppe_sdn_coq_eq,   concurrent.futures.ProcessPoolExecutor.shutdown.__code__.co_qualname.__eq__, ["ProcessPoolExecutor.shutdown"], true, "PPE.shutdown co_qualname == 'ProcessPoolExecutor.shutdown' (len=28, tied longest in spec); verified with Python 3.14.3"]
    - [ppe_sdn_coq_len,  concurrent.futures.ProcessPoolExecutor.shutdown.__code__.co_qualname.__len__, [],                              28,   "PPE.shutdown co_qualname.__len__() == 28 (tied longest in spec); verified with Python 3.14.3"]
    - [ppe_ini_coq_eq,   concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_qualname.__eq__, ["ProcessPoolExecutor.__init__"], true, "PPE.__init__ co_qualname == 'ProcessPoolExecutor.__init__' (len=28, tied longest in spec); verified with Python 3.14.3"]
    - [ppe_ini_coq_len,  concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_qualname.__len__, [],                              28,   "PPE.__init__ co_qualname.__len__() == 28 (tied with shutdown, longest in spec); verified with Python 3.14.3"]
    - [ppe_ini_argc,     concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__, [5],                              true, "PPE.__init__.__code__.co_argcount == 5 (self, max_workers, mp_context, initializer, initargs); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures executor co_qualname comparison table — extra112
#
# Wave 255 theme: TPE vs PPE co_qualname length comparisons.
# ---------------------------------------------------------------------------

table concurrent_futures_extra112.cf_executor_coqualname_compare:
  description: "concurrent.futures executor co_qualname length comparison checks in cftpe112 namespace — wave 255 theme: cross-executor comparisons showing PPE co_qualname lengths exceed TPE by exactly 1 char for all shared methods (because 'ProcessPoolExecutor'=19 chars > 'ThreadPoolExecutor'=18 chars by 1); concurrent.futures.ProcessPoolExecutor.submit.__code__.co_qualname.__len__()==26 vs concurrent.futures.ThreadPoolExecutor.submit.__code__.co_qualname.__len__()==25 (PPE.submit=26, TPE.submit=25, difference=1); concurrent.futures.ProcessPoolExecutor.shutdown.__code__.co_qualname.__len__()==28 vs concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_qualname.__len__()==27 (PPE.shutdown=28, TPE.shutdown=27, difference=1); concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_qualname.__len__()==28 vs concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_qualname.__len__()==27 (PPE.__init__=28, TPE.__init__=27, difference=1); compare with Future co_qualname lengths from extra111: Future.done=11 (shortest) vs ProcessPoolExecutor.map=23 (shortest PPE) vs ProcessPoolExecutor.shutdown=28 (longest overall); TPE.__init__ and TPE.shutdown are tied at co_qualname len=27 (both end in 8-char names: '__init__'=8, 'shutdown'=8); PPE.__init__ and PPE.shutdown are tied at co_qualname len=28; TPE.submit co_qualname len=25 < TPE.shutdown co_qualname len=27 (because 'submit'=6 < 'shutdown'=8 by 2); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cftpe112b

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_sub_26,   concurrent.futures.ProcessPoolExecutor.submit.__code__.co_qualname.__len__,   [],  26,  "PPE.submit co_qualname len=26 (1 more than TPE.submit=25); verified with Python 3.14.3"]
    - [tpe_sub_25,   concurrent.futures.ThreadPoolExecutor.submit.__code__.co_qualname.__len__,   [],   25,  "TPE.submit co_qualname len=25 (1 fewer than PPE.submit=26); verified with Python 3.14.3"]
    - [ppe_sdn_28,   concurrent.futures.ProcessPoolExecutor.shutdown.__code__.co_qualname.__len__, [],  28,  "PPE.shutdown co_qualname len=28 (1 more than TPE.shutdown=27); verified with Python 3.14.3"]
    - [tpe_sdn_27,   concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_qualname.__len__, [],   27,  "TPE.shutdown co_qualname len=27 (1 fewer than PPE.shutdown=28); verified with Python 3.14.3"]
    - [ppe_ini_28,   concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_qualname.__len__, [],  28,  "PPE.__init__ co_qualname len=28 (tied with PPE.shutdown, longest in spec); verified with Python 3.14.3"]
    - [tpe_ini_27,   concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_qualname.__len__, [],   27,  "TPE.__init__ co_qualname len=27 (tied with TPE.shutdown, longest for TPE); verified with Python 3.14.3"]
    - [ppe_map_23,   concurrent.futures.ProcessPoolExecutor.map.__code__.co_qualname.__len__,     [],   23,  "PPE.map co_qualname len=23 (shortest PPE co_qualname in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra112
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra112.TPE_shutdown_coqualname_len_27:
  description: "concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_qualname.__len__() == 27 — 'ThreadPoolExecutor.shutdown' = 'ThreadPoolExecutor.'=19 + 'shutdown'=8 = 27; co_qualname is a Python 3.11+ code object attribute (spec requires version >=3.11); concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_qualname.__eq__('ThreadPoolExecutor.shutdown')==True; co_qualname matches TPE.shutdown.__qualname__ (from extra97); concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_argcount==2 (self and wait); concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_name=='shutdown' (len=8); note: TPE.shutdown co_qualname len=27 ties with TPE.__init__ co_qualname len=27 (both end in 8-char names: 'shutdown'=8 == '__init__'=8); compare: PPE.shutdown co_qualname len=28 (1 char longer because 'ProcessPoolExecutor'=19 vs 'ThreadPoolExecutor'=18); first standalone TPE.shutdown co_qualname length invariant; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_qualname.__len__
  args: []
  expected: 27

invariant concurrent_futures_extra112.PPE_shutdown_coqualname_len_28:
  description: "concurrent.futures.ProcessPoolExecutor.shutdown.__code__.co_qualname.__len__() == 28 — 'ProcessPoolExecutor.shutdown' = 'ProcessPoolExecutor.'=20 + 'shutdown'=8 = 28; tied longest co_qualname in this spec (tied with PPE.__init__=28); concurrent.futures.ProcessPoolExecutor.shutdown.__code__.co_qualname.__eq__('ProcessPoolExecutor.shutdown')==True; co_qualname matches PPE.shutdown.__qualname__ (from extra97); concurrent.futures.ProcessPoolExecutor.shutdown.__code__.co_argcount==2 (self and wait); compare: TPE.shutdown co_qualname len=27 < PPE.shutdown co_qualname len=28 (1 char longer because 'ProcessPoolExecutor'=19 > 'ThreadPoolExecutor'=18 by 1); co_qualname length ordering for all methods in spec: PPE.map=23 < TPE.submit=25 < PPE.submit=26 < TPE.shutdown=TPE.__init__=27 < PPE.shutdown=PPE.__init__=28 (longest); first standalone PPE.shutdown co_qualname length invariant; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.shutdown.__code__.co_qualname.__len__
  args: []
  expected: 28

invariant concurrent_futures_extra112.PPE_init_argc_5:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount == 5 — PPE.__init__ takes self, max_workers, mp_context, initializer, initargs (5 parameters); concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_qualname=='ProcessPoolExecutor.__init__' (len=28, Python 3.11+); concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_name=='__init__' (len=8); compare: TPE.__init__.__code__.co_argcount==5 (same count — both executors have 5 init params; the parameter names differ: TPE uses thread_name_prefix, PPE uses mp_context); PPE.map.__code__.co_argcount==2 (fewest args in PPE methods); first standalone PPE.__init__ argcount invariant in cftpe112 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__
  args: [5]
  expected: true

invariant concurrent_futures_extra112.TPE_submit_coqualname_len_25:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__code__.co_qualname.__len__() == 25 — 'ThreadPoolExecutor.submit' = 'ThreadPoolExecutor.'=19 + 'submit'=6 = 25; concurrent.futures.ThreadPoolExecutor.submit.__code__.co_qualname.__eq__('ThreadPoolExecutor.submit')==True; co_qualname matches TPE.submit.__qualname__ (from extra89/extra97); concurrent.futures.ThreadPoolExecutor.submit.__code__.co_argcount==2 (self and fn); concurrent.futures.ThreadPoolExecutor.submit.__code__.co_name=='submit' (len=6); compare: TPE.submit co_qualname len=25 < TPE.shutdown co_qualname len=27 (submit=6 chars < shutdown=8 chars, difference=2); compare: PPE.submit co_qualname len=26 (1 more than TPE.submit=25); the difference between all TPE and PPE co_qualname lengths is exactly 1 (because 'ProcessPoolExecutor'=19 > 'ThreadPoolExecutor'=18 by exactly 1 char); first standalone TPE.submit co_qualname length invariant in cftpe112 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.submit.__code__.co_qualname.__len__
  args: []
  expected: 25

invariant concurrent_futures_extra112.PPE_map_coqualname_len_23:
  description: "concurrent.futures.ProcessPoolExecutor.map.__code__.co_qualname.__len__() == 23 — 'ProcessPoolExecutor.map' = 'ProcessPoolExecutor.'=20 + 'map'=3 = 23; shortest PPE co_qualname in this spec; concurrent.futures.ProcessPoolExecutor.map.__code__.co_qualname.__eq__('ProcessPoolExecutor.map')==True; co_qualname matches PPE.map.__qualname__ (from extra97); note: PPE overrides Executor.map (not inherited), so PPE.map co_qualname uses 'ProcessPoolExecutor.' prefix rather than 'Executor.' prefix (compare: TPE.map is inherited and has co_qualname 'Executor.map' with len=12); PPE.map.__code__.co_argcount==2 (same as TPE.map); the difference between PPE.map co_qualname len=23 and PPE.submit co_qualname len=26 is 3 (because 'map'=3 chars vs 'submit'=6 chars, difference=3); first standalone PPE.map co_qualname length invariant in cftpe112 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.map.__code__.co_qualname.__len__
  args: []
  expected: 23
