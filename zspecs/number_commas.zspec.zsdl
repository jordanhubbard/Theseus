spec: number_commas
version: ">=1.0.1"
backend: node(number-commas)

docs: https://www.npmjs.com/package/number-commas

provenance:
  derived_from:
    - "number-commas README — https://www.npmjs.com/package/number-commas"
    - "Test vectors verified with number-commas via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "number-commas source"
  notes:
    - "number-commas is an npm package. Install: npm install number-commas"
    - "Formats a number by inserting comma separators at thousands boundaries."
    - "Exports a named 'numberCommas' function."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table number_commas.number_commas:
  kind: node_module_call_eq
  function: numberCommas
  category: numbers
  id_prefix: numcom

  columns: [id, args, expected]
  rows:
    - [small,    [100],        "100"]
    - [thousands, [1000],      "1,000"]
    - [millions,  [1234567],   "1,234,567"]
    - [decimal,   [1234567.89], "1,234,567.89"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:04:58Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
