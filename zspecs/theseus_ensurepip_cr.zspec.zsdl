spec: theseus_ensurepip_cr
version: ">=3.4"
backend: python_cleanroom(theseus_ensurepip_cr)
blocks: ensurepip

docs: https://docs.python.org/3/library/ensurepip.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ensurepip.html"
  not_derived_from:
    - "CPython source: Lib/ensurepip/__init__.py"
  notes:
    - "Clean-room ensurepip module. Do NOT import ensurepip."

error_model: python_exceptions

invariant theseus_ensurepip_cr.enspip2_version:
  description: "version() returns pip version string"
  category: behavior
  kind: python_call_eq
  function: enspip2_version
  args: []
  expected: true

invariant theseus_ensurepip_cr.enspip2_bootstrap:
  description: "bootstrap() function exists and is callable"
  category: behavior
  kind: python_call_eq
  function: enspip2_bootstrap
  args: []
  expected: true

invariant theseus_ensurepip_cr.enspip2_uninstall:
  description: "_uninstall() function exists for pip cleanup"
  category: behavior
  kind: python_call_eq
  function: enspip2_uninstall
  args: []
  expected: true
