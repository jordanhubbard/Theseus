spec: modulefinder_extra2
version: ">=3.9"
backend: python_module(modulefinder)

docs: https://docs.python.org/3/library/modulefinder.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/modulefinder.html — Python modulefinder module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/modulefinder.py"
  notes:
    - "This spec extends modulefinder.zspec.zsdl and modulefinder_extra.zspec.zsdl."
    - "Focus: __name__, __module__, __qualname__, __bases__ attributes for ModuleFinder and Module classes, plus integer constants."
    - "LOAD_FROM_CACHE and LOAD_SOURCE are integer constants defined in the modulefinder module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# class_names — ModuleFinder, Module
# ---------------------------------------------------------------------------

table modulefinder_extra2.class_names:
  kind: python_call_eq
  category: names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [ModuleFinder, ModuleFinder.__name__.__eq__, ["ModuleFinder"], true]
    - [Module,       Module.__name__.__eq__,       ["Module"],       true]

# ---------------------------------------------------------------------------
# class_modules — ModuleFinder, Module
# ---------------------------------------------------------------------------

invariant modulefinder_extra2.ModuleFinder.module:
  description: "modulefinder.ModuleFinder.__module__ == 'modulefinder'"
  category: modules
  kind: python_call_eq
  function: ModuleFinder.__module__.__eq__
  args: ["modulefinder"]
  expected: true

invariant modulefinder_extra2.Module.module:
  description: "modulefinder.Module.__module__ == 'modulefinder'"
  category: modules
  kind: python_call_eq
  function: Module.__module__.__eq__
  args: ["modulefinder"]
  expected: true

# ---------------------------------------------------------------------------
# class_bases — ModuleFinder, Module both inherit from object
# ---------------------------------------------------------------------------

invariant modulefinder_extra2.ModuleFinder.base:
  description: "modulefinder.ModuleFinder.__bases__[0].__name__ == 'object'"
  category: bases
  kind: python_call_eq
  function: ModuleFinder.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant modulefinder_extra2.Module.base:
  description: "modulefinder.Module.__bases__[0].__name__ == 'object'"
  category: bases
  kind: python_call_eq
  function: Module.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# qualnames — ModuleFinder, Module
# ---------------------------------------------------------------------------

invariant modulefinder_extra2.ModuleFinder.qualname:
  description: "modulefinder.ModuleFinder.__qualname__ == 'ModuleFinder'"
  category: qualnames
  kind: python_call_eq
  function: ModuleFinder.__qualname__.__eq__
  args: ["ModuleFinder"]
  expected: true

invariant modulefinder_extra2.Module.qualname:
  description: "modulefinder.Module.__qualname__ == 'Module'"
  category: qualnames
  kind: python_call_eq
  function: Module.__qualname__.__eq__
  args: ["Module"]
  expected: true

# ---------------------------------------------------------------------------
# constants — LOAD_FROM_CACHE and LOAD_SOURCE are integers
# ---------------------------------------------------------------------------

invariant modulefinder_extra2.LOAD_FROM_CACHE.class_name:
  description: "modulefinder.LOAD_FROM_CACHE.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: LOAD_FROM_CACHE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant modulefinder_extra2.LOAD_SOURCE.class_name:
  description: "modulefinder.LOAD_SOURCE.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: LOAD_SOURCE.__class__.__name__.__eq__
  args: ["int"]
  expected: true
