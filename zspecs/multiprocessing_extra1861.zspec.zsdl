spec: multiprocessing_extra1861
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 571 theme: bitwise operators (__or__/__and__/__xor__/__invert__) and in-place operators (__iadd__/__imul__/__ior__)."
    - "multiprocessing.Process is a pure-Python class; no bitwise or in-place operator dunders in own __dict__."
    - "multiprocessing.pool.Pool and multiprocessing.pool.AsyncResult are pure-Python classes; no bitwise or in-place operator dunders."
    - "multiprocessing.managers.BaseManager is a pure-Python class; no bitwise or in-place operator dunders."
    - "multiprocessing module exports synchronization primitives: Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Barrier."
    - "multiprocessing module exports shared memory types: Value, Array."
    - "multiprocessing.Manager is a factory function that returns a SyncManager instance."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: bitwise operators absent from multiprocessing class own __dict__
# ---------------------------------------------------------------------------

table multiprocessing_extra1861.bitwise_operators:
  description: "Bitwise operator dunder methods absent from multiprocessing class own __dict__"
  kind: python_call_eq
  category: bitwise_operators
  id_prefix: mp1861

  columns: [id, function, args, expected]
  rows:
    - ["mp1861001", multiprocessing.Process.__dict__.__contains__,             ["__or__"],      false]
    - ["mp1861002", multiprocessing.Process.__dict__.__contains__,             ["__and__"],     false]
    - ["mp1861003", multiprocessing.pool.Pool.__dict__.__contains__,           ["__or__"],      false]
    - ["mp1861004", multiprocessing.pool.Pool.__dict__.__contains__,           ["__and__"],     false]
    - ["mp1861005", multiprocessing.managers.BaseManager.__dict__.__contains__, ["__or__"],     false]
    - ["mp1861006", multiprocessing.pool.AsyncResult.__dict__.__contains__,    ["__or__"],      false]
    - ["mp1861007", multiprocessing.Process.__dict__.__contains__,             ["__xor__"],     false]
    - ["mp1861008", multiprocessing.Process.__dict__.__contains__,             ["__invert__"],  false]

# ---------------------------------------------------------------------------
# Table 2: in-place operators absent from multiprocessing class own __dict__
# ---------------------------------------------------------------------------

table multiprocessing_extra1861.inplace_operators:
  description: "In-place operator dunder methods absent from multiprocessing class own __dict__"
  kind: python_call_eq
  category: inplace_operators
  id_prefix: mp1861

  columns: [id, function, args, expected]
  rows:
    - ["mp1861009", multiprocessing.Process.__dict__.__contains__,             ["__iadd__"], false]
    - ["mp1861010", multiprocessing.Process.__dict__.__contains__,             ["__ior__"],  false]
    - ["mp1861011", multiprocessing.pool.Pool.__dict__.__contains__,           ["__iadd__"], false]
    - ["mp1861012", multiprocessing.pool.Pool.__dict__.__contains__,           ["__ior__"],  false]
    - ["mp1861013", multiprocessing.managers.BaseManager.__dict__.__contains__, ["__iadd__"], false]
    - ["mp1861014", multiprocessing.pool.AsyncResult.__dict__.__contains__,    ["__iadd__"], false]
    - ["mp1861015", multiprocessing.Process.__dict__.__contains__,             ["__imul__"], false]
    - ["mp1861016", multiprocessing.pool.Pool.__dict__.__contains__,           ["__imul__"], false]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing synchronization primitives in module dict
# ---------------------------------------------------------------------------

table multiprocessing_extra1861.mp_sync_primitives:
  description: "multiprocessing module exports synchronization primitives, shared memory types, and Manager"
  kind: python_call_eq
  category: module_contents
  id_prefix: mp1861

  columns: [id, function, args, expected]
  rows:
    - ["mp1861017", multiprocessing.__dict__.__contains__, ["Lock"],             true]
    - ["mp1861018", multiprocessing.__dict__.__contains__, ["RLock"],            true]
    - ["mp1861019", multiprocessing.__dict__.__contains__, ["Semaphore"],        true]
    - ["mp1861020", multiprocessing.__dict__.__contains__, ["BoundedSemaphore"], true]
    - ["mp1861021", multiprocessing.__dict__.__contains__, ["Event"],            true]
    - ["mp1861022", multiprocessing.__dict__.__contains__, ["Condition"],        true]
    - ["mp1861023", multiprocessing.__dict__.__contains__, ["Barrier"],          true]
    - ["mp1861024", multiprocessing.__dict__.__contains__, ["Value"],            true]
    - ["mp1861025", multiprocessing.__dict__.__contains__, ["Array"],            true]
    - ["mp1861026", multiprocessing.__dict__.__contains__, ["Manager"],          true]
