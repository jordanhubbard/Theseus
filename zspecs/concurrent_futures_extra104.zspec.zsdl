spec: concurrent_futures_extra104
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec extends concurrent_futures_extra103.zspec.zsdl."
    - "This spec covers: wave 254 theme — ThreadPoolExecutor and ProcessPoolExecutor __init__ code attributes, and Executor.__enter__/__exit__ method class names. NEW in extra104: type(ThreadPoolExecutor.__init__).__name__=='function' (Python-defined); ThreadPoolExecutor.__init__.__qualname__=='ThreadPoolExecutor.__init__' (len=27); ThreadPoolExecutor.__init__.__code__.co_name=='__init__' (co_argcount=5: self, max_workers, thread_name_prefix, initializer, initargs); ProcessPoolExecutor.__init__.__code__.co_name=='__init__' (co_argcount=5: same pattern); Executor.__enter__.__qualname__=='Executor.__enter__' (len=18); Executor.__exit__.__qualname__=='Executor.__exit__' (len=17); Executor.__enter__.__code__.co_argcount==1 (self only); Executor.__exit__.__code__.co_argcount==4 (self, exc_type, exc_val, exc_tb); Future.__init__.__code__.co_name=='__init__' (co_argcount=1, self only). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ThreadPoolExecutor.__init__.__code__.co_argcount == 5. The five parameters are self, max_workers, thread_name_prefix, initializer, and initargs. ProcessPoolExecutor.__init__.__code__.co_argcount is also 5: self, max_workers, initializer, initargs, and max_tasks_per_child. Both have the same co_argcount despite different parameter names. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Executor.__enter__.__code__.co_argcount == 1 (self only). Executor.__exit__.__code__.co_argcount == 4 (self, exc_type, exc_val, exc_tb). Both are Python-defined functions (type='function') in concurrent.futures._base. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Future.__init__.__code__.co_argcount == 1. Future.__init__ takes only self — no additional constructor arguments. Future objects are created internally by executors, not by end users. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ThreadPoolExecutor and ProcessPoolExecutor __init__ code attributes — extra104
#
# Wave 254 theme: executor __init__ code object attributes.
#
# ThreadPoolExecutor.__init__.__code__.co_name     == '__init__' (co_argcount=5)
# ThreadPoolExecutor.__init__.__qualname__         == 'ThreadPoolExecutor.__init__' (len=27)
# ProcessPoolExecutor.__init__.__code__.co_name    == '__init__' (co_argcount=5)
# ProcessPoolExecutor.__init__.__qualname__        == 'ProcessPoolExecutor.__init__' (len=28)
# ---------------------------------------------------------------------------

table concurrent_futures_extra104.cf_executor_init_code_attrs:
  description: "ThreadPoolExecutor and ProcessPoolExecutor __init__ code attribute checks in cfcode104 namespace — wave 254 theme: ThreadPoolExecutor.__init__.__code__.co_name.__eq__('__init__')==True; ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__(5)==True (params: self, max_workers, thread_name_prefix, initializer, initargs); ThreadPoolExecutor.__init__.__qualname__.__eq__('ThreadPoolExecutor.__init__')==True (len=27); type(ThreadPoolExecutor.__init__).__name__.__eq__('function')==True (Python-defined); ProcessPoolExecutor.__init__.__code__.co_name.__eq__('__init__')==True; ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__(5)==True (params: self, max_workers, initializer, initargs, max_tasks_per_child — same count, different names); ProcessPoolExecutor.__init__.__qualname__.__eq__('ProcessPoolExecutor.__init__')==True (len=28, longest qualname in spec); type(ProcessPoolExecutor.__init__).__name__.__eq__('function')==True; compare qualname lengths: Future.__init__=15, Executor.__exit__=17, Executor.__enter__=18, ThreadPoolExecutor.__init__=27, ProcessPoolExecutor.__init__=28 (longest); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfcode104

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_init_co_name,  concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_name.__eq__,    ["__init__"], true, "ThreadPoolExecutor.__init__.__code__.co_name == '__init__'; verified with Python 3.14.3"]
    - [tpe_init_co_argc,  concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__, [5],         true, "ThreadPoolExecutor.__init__.__code__.co_argcount == 5 (self, max_workers, thread_name_prefix, initializer, initargs); verified with Python 3.14.3"]
    - [tpe_init_qn_eq,    concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__,         ["ThreadPoolExecutor.__init__"], true, "ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' (len=27); verified with Python 3.14.3"]
    - [tpe_init_qn_len,   concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__,        [],          27,   "ThreadPoolExecutor.__init__.__qualname__.__len__() == 27; verified with Python 3.14.3"]
    - [ppe_init_co_name,  concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_name.__eq__,   ["__init__"], true, "ProcessPoolExecutor.__init__.__code__.co_name == '__init__'; verified with Python 3.14.3"]
    - [ppe_init_co_argc,  concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__, [5],        true, "ProcessPoolExecutor.__init__.__code__.co_argcount == 5 (self, max_workers, initializer, initargs, max_tasks_per_child); verified with Python 3.14.3"]
    - [ppe_init_qn_eq,    concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__eq__,        ["ProcessPoolExecutor.__init__"], true, "ProcessPoolExecutor.__init__.__qualname__ == 'ProcessPoolExecutor.__init__' (len=28, longest qualname in spec); verified with Python 3.14.3"]
    - [ppe_init_qn_len,   concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__,       [],          28,   "ProcessPoolExecutor.__init__.__qualname__.__len__() == 28 ('ProcessPoolExecutor.__init__'=28, longest); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Executor.__enter__ and __exit__ method code attributes — extra104
#
# Wave 254 theme: Executor context manager method code attributes.
#
# Executor.__enter__.__qualname__ == 'Executor.__enter__'  (len=18, co_argcount=1)
# Executor.__exit__.__qualname__  == 'Executor.__exit__'   (len=17, co_argcount=4)
# ---------------------------------------------------------------------------

table concurrent_futures_extra104.cf_executor_enter_exit_attrs:
  description: "Executor.__enter__ and __exit__ method code attribute checks in cfcode104 namespace — wave 254 theme: type(Executor.__enter__).__name__.__eq__('function')==True (Python-defined); Executor.__enter__.__qualname__.__eq__('Executor.__enter__')==True (len=18: 'Executor.'=9+'__enter__'=9=18); Executor.__enter__.__code__.co_name.__eq__('__enter__')==True; Executor.__enter__.__code__.co_argcount.__eq__(1)==True (self only — __enter__ returns self); type(Executor.__exit__).__name__.__eq__('function')==True (Python-defined); Executor.__exit__.__qualname__.__eq__('Executor.__exit__')==True (len=17: 'Executor.'=9+'__exit__'=8=17); Executor.__exit__.__code__.co_name.__eq__('__exit__')==True; Executor.__exit__.__code__.co_argcount.__eq__(4)==True (self, exc_type, exc_val, exc_tb); compare: __enter__ has fewer args (1) than __exit__ (4); __enter__ qualname (len=18) is longer than __exit__ (len=17) despite __exit__ having more parameters; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfcode104a

  columns: [id, function, args, expected, description]
  rows:
    - [enter_type_eq,    concurrent.futures.Executor.__enter__.__class__.__name__.__eq__,     ["function"],            true, "type(Executor.__enter__).__name__ == 'function' (Python-defined); verified with Python 3.14.3"]
    - [enter_qn_eq,      concurrent.futures.Executor.__enter__.__qualname__.__eq__,           ["Executor.__enter__"],  true, "Executor.__enter__.__qualname__ == 'Executor.__enter__' (len=18); verified with Python 3.14.3"]
    - [enter_qn_len,     concurrent.futures.Executor.__enter__.__qualname__.__len__,          [],                      18,   "Executor.__enter__.__qualname__.__len__() == 18 ('Executor.__enter__'=18); verified with Python 3.14.3"]
    - [enter_co_name,    concurrent.futures.Executor.__enter__.__code__.co_name.__eq__,       ["__enter__"],           true, "Executor.__enter__.__code__.co_name == '__enter__'; verified with Python 3.14.3"]
    - [enter_co_argc,    concurrent.futures.Executor.__enter__.__code__.co_argcount.__eq__,   [1],                     true, "Executor.__enter__.__code__.co_argcount == 1 (self only — __enter__ returns self); verified with Python 3.14.3"]
    - [exit_type_eq,     concurrent.futures.Executor.__exit__.__class__.__name__.__eq__,      ["function"],            true, "type(Executor.__exit__).__name__ == 'function' (Python-defined); verified with Python 3.14.3"]
    - [exit_qn_eq,       concurrent.futures.Executor.__exit__.__qualname__.__eq__,            ["Executor.__exit__"],   true, "Executor.__exit__.__qualname__ == 'Executor.__exit__' (len=17); verified with Python 3.14.3"]
    - [exit_qn_len,      concurrent.futures.Executor.__exit__.__qualname__.__len__,           [],                      17,   "Executor.__exit__.__qualname__.__len__() == 17 ('Executor.__exit__'=17); verified with Python 3.14.3"]
    - [exit_co_name,     concurrent.futures.Executor.__exit__.__code__.co_name.__eq__,        ["__exit__"],            true, "Executor.__exit__.__code__.co_name == '__exit__'; verified with Python 3.14.3"]
    - [exit_co_argc,     concurrent.futures.Executor.__exit__.__code__.co_argcount.__eq__,    [4],                     true, "Executor.__exit__.__code__.co_argcount == 4 (self, exc_type, exc_val, exc_tb); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Future.__init__ code attributes — extra104
#
# Wave 254 theme: Future.__init__ code object attributes.
#
# Future.__init__.__code__.co_name     == '__init__' (co_argcount=1, self only)
# Future.__init__.__qualname__         == 'Future.__init__'  (len=15)
# ---------------------------------------------------------------------------

table concurrent_futures_extra104.cf_future_init_code_attrs:
  description: "concurrent.futures.Future.__init__ code attribute checks in cfcode104 namespace — wave 254 theme: Future.__init__.__code__.co_name.__eq__('__init__')==True; Future.__init__.__code__.co_argcount.__eq__(1)==True (self only — Future objects are created by executors, not end users, so __init__ takes no extra arguments); Future.__init__.__qualname__.__eq__('Future.__init__')==True (len=15: 'Future.'=7+'__init__'=8=15); type(Future.__init__).__name__.__eq__('function')==True (Python-defined); compare co_argcount values: Future.__init__=1 (smallest), Executor.__enter__=1 (tied), Executor.__exit__=4, ThreadPoolExecutor.__init__=5, ProcessPoolExecutor.__init__=5 (tied largest); compare qualname lengths: Future.__init__=15 (shortest), Executor.__exit__=17, Executor.__enter__=18, ThreadPoolExecutor.__init__=27, ProcessPoolExecutor.__init__=28 (longest); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfcode104b

  columns: [id, function, args, expected, description]
  rows:
    - [fut_init_co_name,  concurrent.futures.Future.__init__.__code__.co_name.__eq__,     ["__init__"],      true, "Future.__init__.__code__.co_name == '__init__'; verified with Python 3.14.3"]
    - [fut_init_co_argc,  concurrent.futures.Future.__init__.__code__.co_argcount.__eq__,  [1],              true, "Future.__init__.__code__.co_argcount == 1 (self only — no extra constructor args); verified with Python 3.14.3"]
    - [fut_init_qn_eq,    concurrent.futures.Future.__init__.__qualname__.__eq__,          ["Future.__init__"], true, "Future.__init__.__qualname__ == 'Future.__init__' (len=15); verified with Python 3.14.3"]
    - [fut_init_qn_len,   concurrent.futures.Future.__init__.__qualname__.__len__,         [],               15,   "Future.__init__.__qualname__.__len__() == 15 ('Future.__init__'=15, shortest method qualname in spec); verified with Python 3.14.3"]
    - [fut_init_type_eq,  concurrent.futures.Future.__init__.__class__.__name__.__eq__,    ["function"],     true, "type(Future.__init__).__name__ == 'function' (Python-defined); verified with Python 3.14.3"]
    - [tpe_init_type_eq,  concurrent.futures.ThreadPoolExecutor.__init__.__class__.__name__.__eq__, ["function"], true, "type(ThreadPoolExecutor.__init__).__name__ == 'function' (Python-defined); verified with Python 3.14.3"]
    - [ppe_init_type_eq,  concurrent.futures.ProcessPoolExecutor.__init__.__class__.__name__.__eq__, ["function"], true, "type(ProcessPoolExecutor.__init__).__name__ == 'function' (Python-defined); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra104
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra104.ThreadPoolExecutor_init_co_argcount_5:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount == 5 — the five parameters are self, max_workers, thread_name_prefix, initializer, and initargs; ThreadPoolExecutor.__init__.__qualname__=='ThreadPoolExecutor.__init__' (len=27); type(ThreadPoolExecutor.__init__).__name__=='function' (Python-defined in Lib/concurrent/futures/thread.py); compare: ProcessPoolExecutor.__init__.__code__.co_argcount is also 5 (self, max_workers, initializer, initargs, max_tasks_per_child) — same count, different parameter names; Future.__init__.__code__.co_argcount==1 (much fewer — Future takes no user arguments); NEW in extra104: first standalone ThreadPoolExecutor.__init__ argcount invariant in cfcode104 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__
  args: [5]
  expected: true

invariant concurrent_futures_extra104.ProcessPoolExecutor_init_co_argcount_5:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount == 5 — the five parameters are self, max_workers, initializer, initargs, and max_tasks_per_child; ProcessPoolExecutor.__init__.__qualname__=='ProcessPoolExecutor.__init__' (len=28, longest qualname in this spec); type(ProcessPoolExecutor.__init__).__name__=='function' (Python-defined in Lib/concurrent/futures/process.py); compare: ThreadPoolExecutor.__init__.__code__.co_argcount is also 5 (same count, different names); Future.__init__.__code__.co_argcount==1; ProcessPoolExecutor.__init__.__qualname__.__len__()==28 > ThreadPoolExecutor.__init__.__qualname__.__len__()==27 (one char longer); NEW in extra104: first standalone ProcessPoolExecutor.__init__ argcount invariant in cfcode104 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__
  args: [5]
  expected: true

invariant concurrent_futures_extra104.Executor_enter_co_argcount_1:
  description: "concurrent.futures.Executor.__enter__.__code__.co_argcount == 1 — __enter__ takes only self and returns self (enabling use as a context manager: 'with executor as e: ...'); Executor.__enter__.__qualname__=='Executor.__enter__' (len=18); type(Executor.__enter__).__name__=='function' (Python-defined); compare: Executor.__exit__.__code__.co_argcount==4 (self, exc_type, exc_val, exc_tb — four times as many params); ThreadPoolExecutor.__init__.__code__.co_argcount==5 (most params in spec); Future.__init__.__code__.co_argcount==1 (tied with __enter__ for fewest params); __enter__ returning self is the standard context manager protocol for executors; NEW in extra104: first standalone Executor.__enter__ argcount invariant in cfcode104 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.Executor.__enter__.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant concurrent_futures_extra104.Executor_exit_co_argcount_4:
  description: "concurrent.futures.Executor.__exit__.__code__.co_argcount == 4 — __exit__ takes self, exc_type, exc_val, and exc_tb (the standard context manager __exit__ signature); Executor.__exit__.__qualname__=='Executor.__exit__' (len=17); type(Executor.__exit__).__name__=='function' (Python-defined); Executor.__exit__ calls self.shutdown(wait=True) to clean up the executor when the 'with' block exits; compare: Executor.__enter__.__code__.co_argcount==1 (self only); the difference in argcount between __enter__ (1) and __exit__ (4) follows the Python context manager protocol; NEW in extra104: first standalone Executor.__exit__ argcount invariant in cfcode104 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.Executor.__exit__.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant concurrent_futures_extra104.Future_init_co_argcount_1:
  description: "concurrent.futures.Future.__init__.__code__.co_argcount == 1 — Future.__init__ takes only self; Future objects are created internally by executors (via submit()), not directly by users, so no user-facing constructor arguments are needed; Future.__init__.__qualname__=='Future.__init__' (len=15, shortest method qualname in this spec); type(Future.__init__).__name__=='function' (Python-defined in Lib/concurrent/futures/_base.py); compare co_argcount values across this spec: Future.__init__=1 (tied with Executor.__enter__ for fewest), Executor.__exit__=4, ThreadPoolExecutor.__init__=5, ProcessPoolExecutor.__init__=5 (most); NEW in extra104: first standalone Future.__init__ argcount invariant in cfcode104 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.Future.__init__.__code__.co_argcount.__eq__
  args: [1]
  expected: true
