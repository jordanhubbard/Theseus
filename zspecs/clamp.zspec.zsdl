spec: clamp
version: ">=1.0.1"
backend: node(clamp)

docs: https://www.npmjs.com/package/clamp

provenance:
  derived_from:
    - "clamp README — https://www.npmjs.com/package/clamp"
    - "Test vectors verified with clamp via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "clamp source"
  notes:
    - "clamp is an npm package. Install: npm install clamp"
    - "Clamps a number between a minimum and maximum value."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table clamp.clamp:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: clamp

  columns: [id, args, expected]
  rows:
    - [within,  [5, 0, 10],   5]
    - [below,   [-5, 0, 10],  0]
    - [above,   [15, 0, 10],  10]
    - [at_min,  [0, 0, 10],   0]
    - [at_max,  [10, 0, 10],  10]
