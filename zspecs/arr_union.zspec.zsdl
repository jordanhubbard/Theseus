spec: arr_union
version: ">=3.1.0"
backend: node(arr-union)

docs: https://www.npmjs.com/package/arr-union

provenance:
  derived_from:
    - "arr-union README — https://www.npmjs.com/package/arr-union"
    - "Test vectors verified with arr-union via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "arr-union source"
  notes:
    - "arr-union is an npm package. Install: npm install arr-union"
    - "Returns the union of two or more arrays (all unique elements from all arrays)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array containing all unique elements from all input arrays."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table arr_union.union:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: aunion

  columns: [id, args, expected]
  rows:
    - [overlap,   [[1, 2], [2, 3]],         [1, 2, 3]]
    - [extra,     [[1, 2, 3], [3, 4]],       [1, 2, 3, 4]]
    - [from_empty, [[], [1, 2]],             [1, 2]]

