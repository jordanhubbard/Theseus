spec: hashlib_extra83
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra82.zspec.zsdl — covers sha1/sha224/sha384/sha3_224/sha3_384/sha3_512/shake_128/shake_256 __name__/__qualname__/__module__/__class__.__name__ (table + invariants)."
    - "hashlib_extra81.zspec.zsdl — covers sha256/__name__/__qualname__/__module__ / md5/__name__/__qualname__/__module__ / new/__class__/__name__/__module__/__qualname__ / algorithms_available/__class__/__name__ / sha512/__name__ (table + invariants)."
    - "hashlib_extra80.zspec.zsdl — covers blake2b/blake2s class-level size constants and hexdigest/__class__/__name__ (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra82; it does NOT duplicate invariants present in those files."
    - "Wave 247 theme: hashlib sha256/sha512/md5/sha1 __doc__ class name and algorithms_guaranteed/algorithms_available membership."
    - "hashlib.sha256.__doc__.__class__.__name__ == 'str' — the docstring is a str. No prior hashlib spec checks sha256.__doc__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__doc__.__class__.__name__ == 'str' — the docstring is a str. No prior hashlib spec checks sha512.__doc__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__doc__.__class__.__name__ == 'str' — the docstring is a str. No prior hashlib spec checks md5.__doc__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__doc__.__class__.__name__ == 'str' — the docstring is a str. No prior hashlib spec checks sha1.__doc__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha256') == True — sha256 is guaranteed on all platforms. No prior hashlib spec checks this. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha512') == True — sha512 is guaranteed. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('md5') == True — md5 is guaranteed. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha1') == True — sha1 is guaranteed. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True — sha3_256 is guaranteed. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('blake2b') == True — blake2b is guaranteed. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__contains__('sha256') == True — sha256 is available. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__name__ == 'set' — algorithms_available is a set. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — algorithms_guaranteed is a set. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__doc__.__class__.__name__ == 'str' — the docstring is a str. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__doc__.__class__.__name__ == 'str' — the docstring is a str. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha256/__doc__/__class__/__name__ and sha512/__doc__/__class__/__name__
#
# Wave 247 theme: sha256/sha512 docstring class name.
#
# hashlib.sha256.__doc__.__class__.__name__ == 'str' — the docstring is a str.
# hashlib.sha512.__doc__.__class__.__name__ == 'str' — the docstring is a str.
# No prior hashlib spec checks sha256.__doc__.__class__.__name__ or
# sha512.__doc__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra83.sha256_sha512_doc_class_name:
  description: "hashlib.sha256/__doc__/__class__/__name__.__eq__('str')==True / sha512/__doc__/__class__/__name__.__eq__('str')==True — docstrings on sha256 and sha512 are str objects; no prior hashlib spec checks sha256/__doc__/__class__/__name__ or sha512/__doc__/__class__/__name__; first __doc__.__class__.__name__ anchor for sha256 and sha512"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra83

  columns: [id, function, args, expected]
  rows:
    - [sha256_doc_class_name_str, sha256.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sha512_doc_class_name_str, sha512.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# hashlib.md5/__doc__/__class__/__name__ and sha1/__doc__/__class__/__name__
# hashlib.blake2b/__doc__/__class__/__name__ and blake2s/__doc__/__class__/__name__
#
# Wave 247 theme: md5/sha1/blake2b/blake2s docstring class name.
#
# All four have __doc__.__class__.__name__ == 'str'. No prior hashlib spec
# checks any of these. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra83.md5_sha1_blake2_doc_class_name:
  description: "hashlib.md5/__doc__/__class__/__name__.__eq__('str')==True / sha1/__doc__/__class__.__name__.__eq__('str')==True / blake2b/__doc__/__class__/__name__.__eq__('str')==True / blake2s/__doc__/__class__/__name__.__eq__('str')==True — docstrings on md5/sha1/blake2b/blake2s are str objects; no prior hashlib spec checks these __doc__.__class__.__name__ values; first __doc__.__class__.__name__ anchor for md5/sha1/blake2b/blake2s"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra83

  columns: [id, function, args, expected]
  rows:
    - [md5_doc_class_name_str,    md5.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [sha1_doc_class_name_str,   sha1.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [blake2b_doc_class_name_str, blake2b.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [blake2s_doc_class_name_str, blake2s.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed membership: sha256/sha512/md5/sha1
#
# Wave 247 theme: algorithms_guaranteed set membership for core algorithms.
#
# hashlib.algorithms_guaranteed is a frozenset guaranteed to be present on all
# Python platforms. sha256/sha512/md5/sha1 are all guaranteed.
# No prior hashlib spec checks these __contains__ calls on algorithms_guaranteed.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra83.algorithms_guaranteed_core:
  description: "hashlib.algorithms_guaranteed/__contains__('sha256')==True / __contains__('sha512')==True / __contains__('md5')==True / __contains__('sha1')==True — sha256/sha512/md5/sha1 are all in algorithms_guaranteed; no prior hashlib spec checks these __contains__ calls; first membership anchor for algorithms_guaranteed core algorithms"
  kind: python_call_eq
  category: module_attrs
  id_prefix: hashlibextra83

  columns: [id, function, args, expected]
  rows:
    - [algorithms_guaranteed_sha256, algorithms_guaranteed.__contains__, ["sha256"], true]
    - [algorithms_guaranteed_sha512, algorithms_guaranteed.__contains__, ["sha512"], true]
    - [algorithms_guaranteed_md5,    algorithms_guaranteed.__contains__, ["md5"],    true]
    - [algorithms_guaranteed_sha1,   algorithms_guaranteed.__contains__, ["sha1"],   true]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed membership: sha3_256/blake2b
# hashlib.algorithms_available membership: sha256
# hashlib.algorithms_available/__class__/__name__ and algorithms_guaranteed/__class__/__name__
#
# Wave 247 theme: algorithms_guaranteed extended membership and set class names.
#
# sha3_256 and blake2b are in algorithms_guaranteed. sha256 is in
# algorithms_available. Both sets have __class__.__name__ == 'set'.
# No prior hashlib spec checks any of these. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra83.algorithms_sets_membership_class:
  description: "hashlib.algorithms_guaranteed/__contains__('sha3_256')==True / __contains__('blake2b')==True / algorithms_available/__contains__('sha256')==True / algorithms_available/__class__/__name__.__eq__('set')==True / algorithms_guaranteed/__class__.__name__.__eq__('set')==True — sha3_256/blake2b are guaranteed; both algorithm sets are frozensets reported as 'set'; no prior hashlib spec checks these; first extended membership and class name anchor for algorithms sets"
  kind: python_call_eq
  category: module_attrs
  id_prefix: hashlibextra83

  columns: [id, function, args, expected]
  rows:
    - [algorithms_guaranteed_sha3_256,      algorithms_guaranteed.__contains__,          ["sha3_256"], true]
    - [algorithms_guaranteed_blake2b,       algorithms_guaranteed.__contains__,          ["blake2b"],  true]
    - [algorithms_available_sha256,         algorithms_available.__contains__,           ["sha256"],   true]
    - [algorithms_available_class_name_set, algorithms_available.__class__.__name__.__eq__, ["set"],   true]
    - [algorithms_guaranteed_class_name_set, algorithms_guaranteed.__class__.__name__.__eq__, ["set"], true]

# ---------------------------------------------------------------------------
# hashlib.sha256.__doc__.__class__.__name__.__eq__('str') — standalone
#
# sha256's docstring is a str. No prior hashlib spec checks sha256.__doc__.__class__.__name__.
# First __doc__.__class__.__name__ standalone for hashlib.sha256.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra83.sha256_doc_class_name_str:
  description: "hashlib.sha256.__doc__.__class__.__name__.__eq__('str') == True — sha256's docstring is a str object; no prior hashlib spec checks sha256.__doc__.__class__.__name__; first __doc__.__class__.__name__ standalone for hashlib.sha256"
  category: class_attrs
  kind: python_call_eq
  function: sha256.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha256') — standalone
#
# 'sha256' is in algorithms_guaranteed. No prior hashlib spec checks this.
# First algorithms_guaranteed.__contains__ standalone for 'sha256'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra83.algorithms_guaranteed_sha256:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256') == True — sha256 is present in algorithms_guaranteed on all Python platforms; no prior hashlib spec checks algorithms_guaranteed.__contains__('sha256'); first membership standalone for sha256 in algorithms_guaranteed"
  category: module_attrs
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('blake2b') — standalone
#
# 'blake2b' is in algorithms_guaranteed. No prior hashlib spec checks this.
# First algorithms_guaranteed.__contains__ standalone for 'blake2b'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra83.algorithms_guaranteed_blake2b:
  description: "hashlib.algorithms_guaranteed.__contains__('blake2b') == True — blake2b is guaranteed on all Python platforms; no prior hashlib spec checks algorithms_guaranteed.__contains__('blake2b'); first membership standalone for blake2b in algorithms_guaranteed"
  category: module_attrs
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__class__.__name__.__eq__('set') — standalone
#
# algorithms_available is a frozenset; __class__.__name__ == 'set'.
# No prior hashlib spec checks algorithms_available.__class__.__name__.
# First __class__.__name__ standalone for algorithms_available.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra83.algorithms_available_class_name_set:
  description: "hashlib.algorithms_available.__class__.__name__.__eq__('set') == True — algorithms_available is a frozenset whose __class__.__name__ is 'set'; no prior hashlib spec checks algorithms_available.__class__.__name__; first __class__.__name__ standalone for algorithms_available"
  category: module_attrs
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__doc__.__class__.__name__.__eq__('str') — standalone
#
# blake2b's docstring is a str. No prior hashlib spec checks blake2b.__doc__.__class__.__name__.
# First __doc__.__class__.__name__ standalone for hashlib.blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra83.blake2b_doc_class_name_str:
  description: "hashlib.blake2b.__doc__.__class__.__name__.__eq__('str') == True — blake2b's docstring is a str object; no prior hashlib spec checks blake2b.__doc__.__class__.__name__; first __doc__.__class__.__name__ standalone for hashlib.blake2b"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
