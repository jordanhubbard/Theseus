spec: typing_extra32
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing_extra31.zspec.zsdl."
    - "Prior specs covered: TypeVar/__name__/__module__/__qualname__/__init__.__name__, Protocol/__module__/__qualname__/__bases__[0].__name__, Generic/__module__/__qualname__/__bases__[0].__name__, NamedTuple/__name__/__module__, TypedDict/__name__/__module__, get_type_hints/__name__, overload/__name__, cast/__name__, TYPE_CHECKING value, TypeVar/Protocol/Generic __module__.__len__() and __name__.__len__(), get_type_hints/overload/cast __qualname__, get_args name/qualname, get_origin name."
    - "This spec covers: __module__.__len__() for Any/Union/Optional/Callable/ClassVar/Final/Literal; __name__.__len__() for Any/Union/Optional/Callable/ClassVar/Final/Literal; __name__.__len__() for overload/cast/get_type_hints/no_type_check/get_args/get_origin; __qualname__.__len__() for overload/cast/get_type_hints/no_type_check/get_args/get_origin."
    - "Any/Union/Optional/Callable/ClassVar/Final/Literal all have __module__ == 'typing' (length 6) — they are Special Forms defined in Lib/typing.py."
    - "typing.Any.__name__ == 'Any' (length 3) — shortest __name__ among typing Special Forms."
    - "typing.get_type_hints.__name__.__len__() == 14; no_type_check.__name__.__len__() == 13."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() for Any/Union/Optional/Callable/ClassVar/Final/Literal
#
# These are all Special Forms or similar constructs defined in Lib/typing.py.
# All have __module__ == 'typing' (length 6), the same as TypeVar/Protocol/
# Generic recorded in extra31. This table extends coverage to the Special Forms.
# ---------------------------------------------------------------------------

table typing_extra32.special_form_module_lens:
  description: "__module__.__len__() for typing Special Forms — all 'typing' (6)"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [Any,      Any.__module__.__len__,      [], 6]
    - [Union,    Union.__module__.__len__,    [], 6]
    - [Optional, Optional.__module__.__len__, [], 6]
    - [Callable, Callable.__module__.__len__, [], 6]
    - [ClassVar, ClassVar.__module__.__len__, [], 6]
    - [Final,    Final.__module__.__len__,    [], 6]
    - [Literal,  Literal.__module__.__len__,  [], 6]

# ---------------------------------------------------------------------------
# __name__.__len__() for Any/Union/Optional/Callable/ClassVar/Final/Literal
#
# Special Form __name__ values range from 3 (Any) to 8 (Optional/Callable/
# ClassVar). Union and Final share length 5; Literal has length 7.
# No prior typing spec records __name__.__len__() for these Special Forms.
# ---------------------------------------------------------------------------

table typing_extra32.special_form_name_lens:
  description: "__name__.__len__() for typing Special Forms — lengths vary from 3 (Any) to 8 (Optional/Callable/ClassVar)"
  kind: python_call_eq
  category: name_attr_lengths
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [Any,      Any.__name__.__len__,      [], 3]
    - [Union,    Union.__name__.__len__,    [], 5]
    - [Optional, Optional.__name__.__len__, [], 8]
    - [Callable, Callable.__name__.__len__, [], 8]
    - [ClassVar, ClassVar.__name__.__len__, [], 8]
    - [Final,    Final.__name__.__len__,    [], 5]
    - [Literal,  Literal.__name__.__len__,  [], 7]

# ---------------------------------------------------------------------------
# __name__.__len__() for overload/cast/get_type_hints/no_type_check/
# get_args/get_origin
#
# These are module-level functions in typing. Their __name__ lengths vary from
# 4 (cast) to 14 (get_type_hints). extra31 recorded __qualname__ equality for
# overload/cast/get_type_hints, and __name__/__qualname__ equality for get_args
# and get_origin.__name__. This table records the __len__() values for all six.
# ---------------------------------------------------------------------------

table typing_extra32.function_name_lens:
  description: "__name__.__len__() for typing module-level functions"
  kind: python_call_eq
  category: name_attr_lengths
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [overload,        overload.__name__.__len__,        [], 8]
    - [cast,            cast.__name__.__len__,            [], 4]
    - [get_type_hints,  get_type_hints.__name__.__len__,  [], 14]
    - [no_type_check,   no_type_check.__name__.__len__,   [], 13]
    - [get_args,        get_args.__name__.__len__,        [], 8]
    - [get_origin,      get_origin.__name__.__len__,      [], 10]

# ---------------------------------------------------------------------------
# typing.Any.__name__.__len__() == 3 — standalone
#
# typing.Any.__name__ is 'Any', with length 3 — the shortest __name__ among
# all typing Special Forms and module-level functions measured across extra specs.
# This anchors the lower bound of the name-length range for the typing module.
# ---------------------------------------------------------------------------

invariant typing_extra32.Any.name_len:
  description: "typing.Any.__name__.__len__() == 3 — 'Any' is the shortest __name__ among measured typing constructs"
  category: name_attr_lengths
  kind: python_call_eq
  function: Any.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# typing.get_type_hints.__name__.__len__() == 14 — standalone
#
# get_type_hints.__name__ is 'get_type_hints', length 14 — the longest __name__
# among the module-level typing functions measured in extra32. It exceeds
# no_type_check (13) and get_origin (10).
# ---------------------------------------------------------------------------

invariant typing_extra32.get_type_hints.name_len:
  description: "typing.get_type_hints.__name__.__len__() == 14 — 'get_type_hints' is the longest __name__ among typing module-level functions measured here"
  category: name_attr_lengths
  kind: python_call_eq
  function: get_type_hints.__name__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# typing.Optional.__name__.__len__() == 8 — standalone
#
# Optional, Callable, and ClassVar all have __name__ length 8 — the longest
# among the Special Forms in this spec. Re-anchored for Optional as a standalone
# to highlight the three-way tie at length 8.
# ---------------------------------------------------------------------------

invariant typing_extra32.Optional.name_len:
  description: "typing.Optional.__name__.__len__() == 8 — 'Optional' has length 8; tied with Callable and ClassVar for longest Special Form __name__"
  category: name_attr_lengths
  kind: python_call_eq
  function: Optional.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# typing.get_args.__module__.__len__() == 6 — standalone
#
# get_args.__module__ is 'typing', length 6. extra31 recorded get_args.__name__
# and __qualname__ equality but not the module length. This invariant closes
# that gap and confirms get_args follows the same module pattern as all other
# typing constructs measured in this series.
# ---------------------------------------------------------------------------

invariant typing_extra32.get_args.module_len:
  description: "typing.get_args.__module__.__len__() == 6 — 'typing' has length 6; consistent with all other typing module constructs"
  category: module_attr_lengths
  kind: python_call_eq
  function: get_args.__module__.__len__
  args: []
  expected: 6
