spec: threading_extra231
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading.settrace, threading.setprofile, threading.excepthook, and threading.ExceptHookArgs identity contracts."
    - "threading.settrace.__name__ == 'settrace' — Python-level function in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.settrace.__module__ == 'threading' — defined in the threading module. Verified with Python 3.14.3."
    - "threading.setprofile.__name__ == 'setprofile' — Python-level function in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.setprofile.__module__ == 'threading' — defined in the threading module. Verified with Python 3.14.3."
    - "threading.excepthook.__name__ == '_excepthook' — threading.excepthook is actually the C built-in _thread._excepthook; its __name__ is '_excepthook'. Verified with Python 3.14.3."
    - "threading.excepthook.__module__ == '_thread' — the underlying C function is in the _thread module. Verified with Python 3.14.3."
    - "threading.ExceptHookArgs.__name__ == '_ExceptHookArgs' — the class is defined in _thread as _ExceptHookArgs. Verified with Python 3.14.3."
    - "threading.ExceptHookArgs.__module__ == '_thread' — ExceptHookArgs class is defined in the C extension _thread module. Verified with Python 3.14.3."
    - "threading.settrace.__name__.__len__() == 8 — 'settrace' has 8 characters. Verified with Python 3.14.3."
    - "threading.setprofile.__name__.__len__() == 10 — 'setprofile' has 10 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.settrace identity contracts
#
# threading.settrace.__name__ == 'settrace'
# threading.settrace.__qualname__ == 'settrace'
# threading.settrace.__module__ == 'threading'
# threading.settrace.__name__.__len__() == 8
# threading.settrace.__qualname__.__len__() == 8
#
# New to extra231.
# ---------------------------------------------------------------------------

table threading_extra231.settrace_identity:
  description: "threading.settrace identity contracts: __name__, __qualname__, __module__, name length; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra231settraceid

  columns: [id, function, args, expected, description]
  rows:
    - [settrace_name_eq,
       settrace.__name__.__eq__,
       ["settrace"],
       true,
       "threading.settrace.__name__ == 'settrace' — settrace is a top-level function in Lib/threading.py that sets a trace function for all threads; __name__.__eq__('settrace') returns True; new to extra231"]
    - [settrace_qualname_eq,
       settrace.__qualname__.__eq__,
       ["settrace"],
       true,
       "threading.settrace.__qualname__ == 'settrace' — settrace is a top-level function with unqualified qualname 'settrace'; __qualname__.__eq__('settrace') returns True; new to extra231"]
    - [settrace_module_eq,
       settrace.__module__.__eq__,
       ["threading"],
       true,
       "threading.settrace.__module__ == 'threading' — settrace is defined in Lib/threading.py; __module__.__eq__('threading') returns True; new to extra231"]
    - [settrace_name_len_8,
       settrace.__name__.__len__,
       [],
       8,
       "threading.settrace.__name__.__len__() == 8 — 'settrace' has exactly 8 characters (s-e-t-t-r-a-c-e); __len__() returns 8; new to extra231"]
    - [settrace_qualname_len_8,
       settrace.__qualname__.__len__,
       [],
       8,
       "threading.settrace.__qualname__.__len__() == 8 — qualname 'settrace' has exactly 8 characters; __len__() returns 8; new to extra231"]

# ---------------------------------------------------------------------------
# Table 2: threading.setprofile identity contracts
#
# threading.setprofile.__name__ == 'setprofile'
# threading.setprofile.__qualname__ == 'setprofile'
# threading.setprofile.__module__ == 'threading'
# threading.setprofile.__name__.__len__() == 10
# threading.setprofile.__qualname__.__len__() == 10
#
# New to extra231.
# ---------------------------------------------------------------------------

table threading_extra231.setprofile_identity:
  description: "threading.setprofile identity contracts: __name__, __qualname__, __module__, name length; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra231setprofileid

  columns: [id, function, args, expected, description]
  rows:
    - [setprofile_name_eq,
       setprofile.__name__.__eq__,
       ["setprofile"],
       true,
       "threading.setprofile.__name__ == 'setprofile' — setprofile is a top-level function in Lib/threading.py that sets a profile function for all threads; __name__.__eq__('setprofile') returns True; new to extra231"]
    - [setprofile_qualname_eq,
       setprofile.__qualname__.__eq__,
       ["setprofile"],
       true,
       "threading.setprofile.__qualname__ == 'setprofile' — setprofile is a top-level function with unqualified qualname 'setprofile'; __qualname__.__eq__('setprofile') returns True; new to extra231"]
    - [setprofile_module_eq,
       setprofile.__module__.__eq__,
       ["threading"],
       true,
       "threading.setprofile.__module__ == 'threading' — setprofile is defined in Lib/threading.py; __module__.__eq__('threading') returns True; new to extra231"]
    - [setprofile_name_len_10,
       setprofile.__name__.__len__,
       [],
       10,
       "threading.setprofile.__name__.__len__() == 10 — 'setprofile' has exactly 10 characters (s-e-t-p-r-o-f-i-l-e); __len__() returns 10; new to extra231"]
    - [setprofile_qualname_len_10,
       setprofile.__qualname__.__len__,
       [],
       10,
       "threading.setprofile.__qualname__.__len__() == 10 — qualname 'setprofile' has exactly 10 characters; __len__() returns 10; new to extra231"]

# ---------------------------------------------------------------------------
# Table 3: threading.excepthook and ExceptHookArgs C-level identity
#
# threading.excepthook.__name__ == '_excepthook'  (C-level backing name)
# threading.excepthook.__module__ == '_thread'     (implemented in _thread C extension)
# threading.ExceptHookArgs.__name__ == '_ExceptHookArgs'
# threading.ExceptHookArgs.__module__ == '_thread'
# threading.excepthook.__name__.__len__() == 12
#
# Note: threading.excepthook is the built-in _thread._excepthook re-exported.
# New to extra231.
# ---------------------------------------------------------------------------

table threading_extra231.excepthook_excepthookargs_identity:
  description: "threading.excepthook and ExceptHookArgs C-level identity: __name__ and __module__ of underlying _thread objects; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra231xhookid

  columns: [id, function, args, expected, description]
  rows:
    - [excepthook_name_eq,
       excepthook.__name__.__eq__,
       ["_excepthook"],
       true,
       "threading.excepthook.__name__ == '_excepthook' — threading.excepthook is the C built-in _thread._excepthook re-exported; its actual __name__ is '_excepthook'; __name__.__eq__('_excepthook') returns True; new to extra231"]
    - [excepthook_module_eq,
       excepthook.__module__.__eq__,
       ["_thread"],
       true,
       "threading.excepthook.__module__ == '_thread' — the underlying C function is in the _thread extension module; __module__.__eq__('_thread') returns True; new to extra231"]
    - [ExceptHookArgs_name_eq,
       ExceptHookArgs.__name__.__eq__,
       ["_ExceptHookArgs"],
       true,
       "threading.ExceptHookArgs.__name__ == '_ExceptHookArgs' — the class is defined in _thread C extension as _ExceptHookArgs; __name__.__eq__('_ExceptHookArgs') returns True; new to extra231"]
    - [ExceptHookArgs_module_eq,
       ExceptHookArgs.__module__.__eq__,
       ["_thread"],
       true,
       "threading.ExceptHookArgs.__module__ == '_thread' — ExceptHookArgs class is defined in the C extension _thread module; __module__.__eq__('_thread') returns True; new to extra231"]
    - [excepthook_name_len_12,
       excepthook.__name__.__len__,
       [],
       12,
       "threading.excepthook.__name__.__len__() == 12 — '_excepthook' has exactly 12 characters (_-e-x-c-e-p-t-h-o-o-k with leading underscore = 12); __len__() returns 12; new to extra231"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra231
# ---------------------------------------------------------------------------

invariant threading_extra231.settrace_name_eq:
  description: "threading.settrace.__name__ == 'settrace'; new to extra231"
  kind: python_call_eq
  function: settrace.__name__.__eq__
  args: ["settrace"]
  expected: true

invariant threading_extra231.settrace_qualname_eq:
  description: "threading.settrace.__qualname__ == 'settrace'; new to extra231"
  kind: python_call_eq
  function: settrace.__qualname__.__eq__
  args: ["settrace"]
  expected: true

invariant threading_extra231.settrace_module_eq:
  description: "threading.settrace.__module__ == 'threading'; new to extra231"
  kind: python_call_eq
  function: settrace.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra231.settrace_name_len_8:
  description: "threading.settrace.__name__.__len__() == 8 — 'settrace' has 8 characters; new to extra231"
  kind: python_call_eq
  function: settrace.__name__.__len__
  args: []
  expected: 8

invariant threading_extra231.setprofile_name_eq:
  description: "threading.setprofile.__name__ == 'setprofile'; new to extra231"
  kind: python_call_eq
  function: setprofile.__name__.__eq__
  args: ["setprofile"]
  expected: true

invariant threading_extra231.setprofile_qualname_eq:
  description: "threading.setprofile.__qualname__ == 'setprofile'; new to extra231"
  kind: python_call_eq
  function: setprofile.__qualname__.__eq__
  args: ["setprofile"]
  expected: true

invariant threading_extra231.setprofile_module_eq:
  description: "threading.setprofile.__module__ == 'threading'; new to extra231"
  kind: python_call_eq
  function: setprofile.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra231.setprofile_name_len_10:
  description: "threading.setprofile.__name__.__len__() == 10 — 'setprofile' has 10 characters; new to extra231"
  kind: python_call_eq
  function: setprofile.__name__.__len__
  args: []
  expected: 10

invariant threading_extra231.excepthook_name_eq:
  description: "threading.excepthook.__name__ == '_excepthook' — C-level backing name; new to extra231"
  kind: python_call_eq
  function: excepthook.__name__.__eq__
  args: ["_excepthook"]
  expected: true

invariant threading_extra231.excepthook_module_eq:
  description: "threading.excepthook.__module__ == '_thread' — implemented in C extension; new to extra231"
  kind: python_call_eq
  function: excepthook.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra231.ExceptHookArgs_name_eq:
  description: "threading.ExceptHookArgs.__name__ == '_ExceptHookArgs'; new to extra231"
  kind: python_call_eq
  function: ExceptHookArgs.__name__.__eq__
  args: ["_ExceptHookArgs"]
  expected: true

invariant threading_extra231.ExceptHookArgs_module_eq:
  description: "threading.ExceptHookArgs.__module__ == '_thread'; new to extra231"
  kind: python_call_eq
  function: ExceptHookArgs.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra231.excepthook_name_len_12:
  description: "threading.excepthook.__name__.__len__() == 12 — '_excepthook' has 12 characters including leading underscore; new to extra231"
  kind: python_call_eq
  function: excepthook.__name__.__len__
  args: []
  expected: 12
