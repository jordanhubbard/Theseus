spec: elasticsearch_rust
version: ">=3.9"
backend: rust_module(elasticsearch_rust)

docs: https://elasticsearch-py.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "https://elasticsearch-py.readthedocs.io/en/latest/ — Elasticsearch Python client"
  not_derived_from:
    - "elasticsearch source: elasticsearch/__init__.py"
  notes:
    - "elasticsearch-py is the Python client for Elasticsearch."
    - "elasticsearch.Elasticsearch is available."
    - "elasticsearch.__version__ is a non-empty string."
    - "elasticsearch.Elasticsearch.__name__ == 'Elasticsearch'."
    - "Expose es_has_client() -> bool: hasattr(elasticsearch, 'Elasticsearch')."
    - "Expose es_client_name() -> str: elasticsearch.Elasticsearch.__name__."
    - "Expose es_version_nonempty() -> bool: len(elasticsearch.__version__) > 0."
    - "All test vectors verified against elasticsearch 8.17.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# es_has_client — Elasticsearch client present
invariant elasticsearch_rust.module.has_client:
  description: "elasticsearch.Elasticsearch is available"
  category: module
  kind: python_call_eq
  function: es_has_client
  args: []
  expected: true

# es_client_name — class name
invariant elasticsearch_rust.client.class_name:
  description: "elasticsearch.Elasticsearch.__name__ == 'Elasticsearch'"
  category: client
  kind: python_call_eq
  function: es_client_name
  args: []
  expected: "Elasticsearch"

# es_version_nonempty — version non-empty
invariant elasticsearch_rust.version.nonempty:
  description: "elasticsearch.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: es_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:19:04Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
