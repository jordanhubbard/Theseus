spec: itertools_extra279
version: ">=3.12"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "itertools.batched (Python 3.12+) is a C-level type: __class__.__name__ == 'type'; __module__ == 'itertools'."
    - "batched.__name__ == 'batched' (7 chars); __qualname__ == 'batched'."
    - "batched.__doc__ is not None — the type ships with a docstring."
    - "itertools.pairwise (Python 3.10+) is a C-level type: __class__.__name__ == 'type'; __module__ == 'itertools'."
    - "pairwise.__name__ == 'pairwise' (8 chars); __qualname__ == 'pairwise'."
    - "pairwise.__doc__ is not None — the type ships with a docstring."
    - "batched([1,2,3,4,5], 2).__next__() == (1, 2) — first batch is the first n elements as a tuple; harness normalizes to [1, 2]."
    - "pairwise([1,2,3,4]).__next__() == (1, 2) — first pair; tuple normalized to list [1, 2]."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.batched — C-level type identity (Python 3.12+)
#
# batched is a C-level type: __class__.__name__ == 'type'.
# __name__ == 'batched' (7 chars); __module__ == 'itertools'.
# __qualname__ == 'batched'; __doc__ is not None.
# ---------------------------------------------------------------------------

table itertools_extra279.batched_identity:
  description: "itertools.batched type identity — __name__, __module__, __qualname__, __class__.__name__, doc presence; name length; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex279ba

  columns: [id, function, args, expected, description]
  rows:
    - [ba_name_eq,  batched.__name__.__eq__,           ["batched"],   true,  "itertools.batched.__name__ == 'batched'; verified with Python 3.14.3"]
    - [ba_name_len, batched.__name__.__len__,            [],           7,     "itertools.batched.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [ba_mod_eq,   batched.__module__.__eq__,           ["itertools"], true,  "itertools.batched.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [ba_qn_eq,    batched.__qualname__.__eq__,         ["batched"],   true,  "itertools.batched.__qualname__ == 'batched' (top-level type); verified with Python 3.14.3"]
    - [ba_cls_eq,   batched.__class__.__name__.__eq__,   ["type"],      true,  "itertools.batched.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [ba_doc_none, batched.__doc__.__eq__,              [null],        false, "itertools.batched.__doc__ is not None — batched ships with a docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# itertools.pairwise — C-level type identity (Python 3.10+)
#
# pairwise is a C-level type: __class__.__name__ == 'type'.
# __name__ == 'pairwise' (8 chars); __module__ == 'itertools'.
# __qualname__ == 'pairwise'; __doc__ is not None.
# ---------------------------------------------------------------------------

table itertools_extra279.pairwise_identity:
  description: "itertools.pairwise type identity — __name__, __module__, __qualname__, __class__.__name__, doc presence; name length; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex279pw

  columns: [id, function, args, expected, description]
  rows:
    - [pw_name_eq,  pairwise.__name__.__eq__,           ["pairwise"],  true,  "itertools.pairwise.__name__ == 'pairwise'; verified with Python 3.14.3"]
    - [pw_name_len, pairwise.__name__.__len__,            [],           8,     "itertools.pairwise.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [pw_mod_eq,   pairwise.__module__.__eq__,           ["itertools"], true,  "itertools.pairwise.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [pw_qn_eq,    pairwise.__qualname__.__eq__,         ["pairwise"],  true,  "itertools.pairwise.__qualname__ == 'pairwise' (top-level type); verified with Python 3.14.3"]
    - [pw_cls_eq,   pairwise.__class__.__name__.__eq__,   ["type"],      true,  "itertools.pairwise.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [pw_doc_none, pairwise.__doc__.__eq__,              [null],        false, "itertools.pairwise.__doc__ is not None — pairwise ships with a docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra279
# ---------------------------------------------------------------------------

invariant itertools_extra279.batched_is_type:
  description: "itertools.batched.__class__.__name__ == 'type' — batched is a C-level type, not a function (Python 3.12+)"
  category: identity
  kind: python_call_eq
  function: batched.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra279.batched_module_is_itertools:
  description: "itertools.batched.__module__ == 'itertools' — batched is registered in the itertools C extension module"
  category: identity
  kind: python_call_eq
  function: batched.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra279.batched_name_length_is_7:
  description: "itertools.batched.__name__.__len__() == 7 — 'batched' has 7 characters"
  category: identity
  kind: python_call_eq
  function: batched.__name__.__len__
  args: []
  expected: 7

invariant itertools_extra279.batched_doc_is_not_none:
  description: "itertools.batched.__doc__.__eq__(None) == False — batched ships with a non-None docstring"
  category: behavior
  kind: python_call_eq
  function: batched.__doc__.__eq__
  args: [null]
  expected: false

invariant itertools_extra279.pairwise_is_type:
  description: "itertools.pairwise.__class__.__name__ == 'type' — pairwise is a C-level type, not a function (Python 3.10+)"
  category: identity
  kind: python_call_eq
  function: pairwise.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra279.pairwise_module_is_itertools:
  description: "itertools.pairwise.__module__ == 'itertools' — pairwise is registered in the itertools C extension module"
  category: identity
  kind: python_call_eq
  function: pairwise.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra279.pairwise_name_length_is_8:
  description: "itertools.pairwise.__name__.__len__() == 8 — 'pairwise' has 8 characters"
  category: identity
  kind: python_call_eq
  function: pairwise.__name__.__len__
  args: []
  expected: 8

invariant itertools_extra279.pairwise_doc_is_not_none:
  description: "itertools.pairwise.__doc__.__eq__(None) == False — pairwise ships with a non-None docstring"
  category: behavior
  kind: python_call_eq
  function: pairwise.__doc__.__eq__
  args: [null]
  expected: false
