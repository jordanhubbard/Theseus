spec: asyncio_extra122
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — Python asyncio queue documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec extends asyncio_extra121.zspec.zsdl."
    - "This spec covers: wave 261 theme — asyncio.Queue class method co_varnames element equality not previously covered. Prior specs covered: extra65 covered Queue.__init__.__code__.co_varnames[0]=='self' and co_varnames.__class__.__name__=='tuple'; extra71 covered Queue.__init__.__code__.co_varnames.__class__.__name__=='tuple'; extra73 covered Queue.put/__code__/co_argcount==2 and Queue.get/__code__/co_argcount==1. NOT previously covered: Queue.put.__code__.co_varnames[1].__eq__('item'); Queue.put.__code__.co_varnames[2].__eq__('putter'); Queue.put.__code__.co_varnames.__len__()==3; Queue.get.__code__.co_varnames[1].__eq__('getter'); Queue.get.__code__.co_varnames.__len__()==2; Queue.__init__.__code__.co_varnames[1].__eq__('maxsize'); Queue.__init__.__code__.co_varnames.__len__()==2; Queue.put_nowait.__code__.co_varnames[1].__eq__('item'); Queue.get_nowait.__code__.co_varnames[1].__eq__('item'); Queue.put co_qualname len; Queue.get co_qualname len. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Queue.put.__code__.co_varnames == ('self', 'item', 'putter'): len=3. co_argcount==2 (self+item; putter is a local variable, not a parameter). co_varnames[1]='item' (len=4: the item to enqueue; tied with 'self'=4). co_varnames[2]='putter' (len=6: a local asyncio.Future created to park the coroutine when the queue is full; analogous to 'fut' in Lock.acquire). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Queue.get.__code__.co_varnames == ('self', 'getter'): len=2. co_argcount==1 (self only; getter is a local asyncio.Future). co_varnames[1]='getter' (len=6: a local Future created to park the coroutine when the queue is empty; symmetric with 'putter' in Queue.put). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Queue.__init__.__code__.co_varnames == ('self', 'maxsize'): len=2. co_argcount==2 (self+maxsize; maxsize is a real parameter with default=0). co_varnames[1]='maxsize' (len=7: controls the maximum number of items in the queue; 0 means unbounded). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Queue.put_nowait.__code__.co_varnames == ('self', 'item'): len=2. asyncio.Queue.get_nowait.__code__.co_varnames == ('self', 'item'): len=2. Both nowait methods use 'item' at index 1 (put_nowait enqueues without blocking; get_nowait dequeues without blocking and uses 'item' as a local to hold the retrieved item). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue.put and Queue.get co_varnames element equality — extra122
#
# Wave 261 theme: Queue.put co_varnames[1]='item', [2]='putter'; Queue.get co_varnames[1]='getter'.
#
# Queue.put.__code__.co_varnames  == ('self', 'item', 'putter')  len=3
# Queue.get.__code__.co_varnames  == ('self', 'getter')          len=2
# Queue.put co_qualname == 'Queue.put'  (len=9)
# Queue.get co_qualname == 'Queue.get'  (len=9, tied)
# ---------------------------------------------------------------------------

table asyncio_extra122.queue_put_get_co_varnames:
  description: "asyncio.Queue.put and Queue.get co_varnames element equality checks in queuecv122 namespace — wave 261 theme: first element-level coverage of Queue.put and Queue.get co_varnames; Queue.put.__code__.co_varnames==('self','item','putter') len=3: co_argcount==2 (self+item are real parameters; putter is a local); co_varnames[1].__eq__('item')==True (len=4: the item to enqueue; 'item'=4 is tied with 'self'=4 in length; Queue.put(self, item) enqueues item and awaits if the queue is full at maxsize); co_varnames[2].__eq__('putter')==True (len=6: putter is a local asyncio.Future created when the queue is full; the coroutine parks on putter and resumes when a get() call notifies it; analogous to 'fut' in Lock.acquire and Semaphore.acquire: len=6 vs fut=3 — a more descriptive name); co_varnames.__len__()==3 (3 is more than Queue.get=2 and Queue.__init__=2; put has one extra local 'putter' beyond its two parameters self+item); Queue.get.__code__.co_varnames==('self','getter') len=2: co_argcount==1 (self only; getter is a local, not a parameter); co_varnames[1].__eq__('getter')==True (len=6: getter is a local Future created when the queue is empty; the coroutine parks on getter until a put() call notifies it; symmetric with 'putter' in Queue.put: same len=6, both are Future locals using the queue operation name as suffix); co_varnames.__len__()==2 (2 is more than Lock.acquire=2: both have len=2 but for different reasons — Lock.acquire has 'self'+'fut' while Queue.get has 'self'+'getter'); Queue.put.__code__.co_qualname=='Queue.put' (len=9: 'Queue.'=6+'put'=3=9; tied with Queue.get qualname='Queue.get' len=9); element length ordering in put: self==item=4 (tied, shortest) < putter=6 (longest local); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: queuecv122

  columns: [id, function, args, expected, description]
  rows:
    - [put_vlen,    Queue.put.__code__.co_varnames.__len__,       [],           3,    "Queue.put co_varnames.__len__() == 3 (('self','item','putter'); 1 more than Queue.get=2); verified with Python 3.14.3"]
    - [put_v1_eq,   "Queue.put.__code__.co_varnames[1].__eq__",   ["item"],     true, "Queue.put co_varnames[1] == 'item' (len=4; item to enqueue; tied with self=4); verified with Python 3.14.3"]
    - [put_v1_len,  "Queue.put.__code__.co_varnames[1].__len__",  [],           4,    "Queue.put co_varnames[1].__len__() == 4 ('item'=4; tied with 'self'=4); verified with Python 3.14.3"]
    - [put_v2_eq,   "Queue.put.__code__.co_varnames[2].__eq__",   ["putter"],   true, "Queue.put co_varnames[2] == 'putter' (len=6; local Future; not a parameter); verified with Python 3.14.3"]
    - [put_v2_len,  "Queue.put.__code__.co_varnames[2].__len__",  [],           6,    "Queue.put co_varnames[2].__len__() == 6 ('putter'=6; longer than 'item'=4; local Future for parking); verified with Python 3.14.3"]
    - [put_qn_eq,   Queue.put.__code__.co_qualname.__eq__,        ["Queue.put"], true, "Queue.put.__code__.co_qualname == 'Queue.put' (len=9); verified with Python 3.14.3"]
    - [put_qn_len,  Queue.put.__code__.co_qualname.__len__,       [],           9,    "Queue.put.__code__.co_qualname.__len__() == 9 ('Queue.'=6+'put'=3=9); verified with Python 3.14.3"]
    - [get_vlen,    Queue.get.__code__.co_varnames.__len__,       [],           2,    "Queue.get co_varnames.__len__() == 2 (('self','getter'); 1 fewer than put=3); verified with Python 3.14.3"]
    - [get_v1_eq,   "Queue.get.__code__.co_varnames[1].__eq__",   ["getter"],   true, "Queue.get co_varnames[1] == 'getter' (len=6; local Future for parking when empty); verified with Python 3.14.3"]
    - [get_qn_len,  Queue.get.__code__.co_qualname.__len__,       [],           9,    "Queue.get.__code__.co_qualname.__len__() == 9 (tied with Queue.put=9: 'Queue.get'='Queue.'=6+'get'=3=9); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Queue.__init__ co_varnames element equality — extra122
#
# Wave 261 theme: Queue.__init__ co_varnames[1]='maxsize'; co_varnames len=2.
#
# Queue.__init__.__code__.co_varnames[0] == 'self'    (len=4)
# Queue.__init__.__code__.co_varnames[1] == 'maxsize' (len=7, longest in __init__)
# Queue.__init__.__code__.co_varnames.__len__() == 2
# Queue.__init__.__code__.co_qualname == 'Queue.__init__' (len=14)
# ---------------------------------------------------------------------------

table asyncio_extra122.queue_init_co_varnames:
  description: "asyncio.Queue.__init__ co_varnames element equality checks in queuecv122a namespace — wave 261 theme: Queue.__init__ co_varnames element equality; co_varnames==('self','maxsize') len=2: co_argcount==2 (self+maxsize are both real parameters; maxsize has default=0); co_varnames[1].__eq__('maxsize')==True (len=7: maxsize controls the maximum number of items the queue can hold; when maxsize==0 (default) the queue is unbounded; when maxsize>0 queue.put() blocks if len(queue)==maxsize; 'maxsize'=7: 'max'=3+'size'=4=7; longest element in Queue.__init__ co_varnames: 7 > self=4); co_varnames.__len__()==2 (tied with Queue.get=2; Queue.__init__ has exactly 2 parameters: self+maxsize; no local-only variables in __init__); co_qualname=='Queue.__init__' (len=14: 'Queue.'=6+'__init__'=8=14); compare: Queue.put co_varnames.__len__()==3 (1 more than __init__=2: put has an extra local 'putter'); Queue.get co_varnames.__len__()==2 (tied with __init__=2 but for different reasons: __init__ has 2 real params while get has 1 param + 1 local); element length ordering: self=4 < maxsize=7 (3 more than self); Queue.__init__ has no equal-length elements (unlike Queue.put where self==item=4); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: queuecv122a

  columns: [id, function, args, expected, description]
  rows:
    - [init_vlen,    Queue.__init__.__code__.co_varnames.__len__,       [],            2,    "Queue.__init__ co_varnames.__len__() == 2 (('self','maxsize'); tied with Queue.get=2); verified with Python 3.14.3"]
    - [init_v1_eq,   "Queue.__init__.__code__.co_varnames[1].__eq__",   ["maxsize"],   true, "Queue.__init__ co_varnames[1] == 'maxsize' (len=7; queue size limit; 0=unbounded); verified with Python 3.14.3"]
    - [init_v1_len,  "Queue.__init__.__code__.co_varnames[1].__len__",  [],            7,    "Queue.__init__ co_varnames[1].__len__() == 7 ('maxsize'=7; longest in __init__: 3 more than self=4); verified with Python 3.14.3"]
    - [init_qn_eq,   Queue.__init__.__code__.co_qualname.__eq__,        ["Queue.__init__"], true, "Queue.__init__.__code__.co_qualname == 'Queue.__init__' (len=14); verified with Python 3.14.3"]
    - [init_qn_len,  Queue.__init__.__code__.co_qualname.__len__,       [],            14,   "Queue.__init__.__code__.co_qualname.__len__() == 14 ('Queue.'=6+'__init__'=8=14); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Queue nowait methods co_varnames and cross-comparison — extra122
#
# Wave 261 theme: put_nowait/get_nowait co_varnames[1]='item', cross-compare.
#
# Queue.put_nowait.__code__.co_varnames == ('self', 'item')  len=2
# Queue.get_nowait.__code__.co_varnames == ('self', 'item')  len=2
# Both use 'item' at index 1 (put_nowait enqueues, get_nowait retrieves).
# ---------------------------------------------------------------------------

table asyncio_extra122.queue_nowait_and_cross_compare:
  description: "asyncio Queue put_nowait/get_nowait co_varnames and cross-comparison in queuecv122b namespace — wave 261 theme: nowait methods co_varnames element equality and Queue method co_varnames length ordering; Queue.put_nowait.__code__.co_varnames==('self','item') len=2: co_argcount==2 (self+item; no local variables unlike put which has 'putter'); co_varnames[1].__eq__('item')==True (len=4: 'item' at index 1 is the same name as Queue.put co_varnames[1]='item'=4; put_nowait enqueues immediately and raises QueueFull if maxsize reached, so it needs no parking Future local); Queue.get_nowait.__code__.co_varnames==('self','item') len=2: co_argcount==1 (self only; 'item' is a local variable holding the retrieved element from _queue.popleft()); co_varnames[1].__eq__('item')==True (len=4: 'item' is the same name as put_nowait co_varnames[1]='item'=4; get_nowait raises QueueEmpty immediately if empty, so it needs no parking Future local; uses 'item' to name the popped element); co_varnames.__len__()==2 (tied with put_nowait=2 and Queue.get=2 and Queue.__init__=2; all Queue methods with 2 co_varnames have different structures: __init__ has 2 real params, get has 1 param+1 local, get_nowait has 1 param+1 local, put_nowait has 2 real params); Queue method co_varnames length ordering: put=3 (most: has extra 'putter' local) > get==__init__==put_nowait==get_nowait=2 (all tied at 2: get has 'getter' local, __init__ has 'maxsize' param, put_nowait has 'item' param, get_nowait has 'item' local); Queue.put_nowait.__code__.co_qualname.__len__()==16 ('Queue.put_nowait'='Queue.'=6+'put_nowait'=10=16); Queue.get_nowait.__code__.co_qualname.__len__()==16 (tied: 'Queue.get_nowait'='Queue.'=6+'get_nowait'=10=16); qualname length ordering: Queue.__init__=14 < put==get=9 (wait: __init__=14 > put=9; corrected: put==get=9 < __init__=14 < put_nowait==get_nowait=16); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: queuecv122b

  columns: [id, function, args, expected, description]
  rows:
    - [pnw_vlen,    Queue.put_nowait.__code__.co_varnames.__len__,       [],          2,    "Queue.put_nowait co_varnames.__len__() == 2 (('self','item'); tied with get_nowait/get/__init__=2); verified with Python 3.14.3"]
    - [pnw_v1_eq,   "Queue.put_nowait.__code__.co_varnames[1].__eq__",   ["item"],    true, "Queue.put_nowait co_varnames[1] == 'item' (len=4; item to enqueue; tied with Queue.put co_varnames[1]='item'); verified with Python 3.14.3"]
    - [pnw_v1_len,  "Queue.put_nowait.__code__.co_varnames[1].__len__",  [],          4,    "Queue.put_nowait co_varnames[1].__len__() == 4 ('item'=4; tied with Queue.put co_varnames[1]='item'=4); verified with Python 3.14.3"]
    - [pnw_qn_len,  Queue.put_nowait.__code__.co_qualname.__len__,       [],          16,   "Queue.put_nowait co_qualname.__len__() == 16 ('Queue.put_nowait': 'Queue.'=6+'put_nowait'=10=16); verified with Python 3.14.3"]
    - [gnw_vlen,    Queue.get_nowait.__code__.co_varnames.__len__,       [],          2,    "Queue.get_nowait co_varnames.__len__() == 2 (('self','item'); tied with put_nowait=2); verified with Python 3.14.3"]
    - [gnw_v1_eq,   "Queue.get_nowait.__code__.co_varnames[1].__eq__",   ["item"],    true, "Queue.get_nowait co_varnames[1] == 'item' (len=4; holds popped element; tied with put_nowait co_varnames[1]='item'); verified with Python 3.14.3"]
    - [gnw_qn_len,  Queue.get_nowait.__code__.co_qualname.__len__,       [],          16,   "Queue.get_nowait co_qualname.__len__() == 16 (tied with put_nowait=16: 'Queue.get_nowait'='Queue.'=6+'get_nowait'=10=16); verified with Python 3.14.3"]
    - [put_vlen3,   Queue.put.__code__.co_varnames.__len__,              [],          3,    "Queue.put co_varnames.__len__() == 3 (1 more than all other Queue methods=2; 'putter' local makes it 3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra122
# ---------------------------------------------------------------------------

invariant asyncio_extra122.queue_put_v1_item:
  description: "asyncio.Queue.put.__code__.co_varnames[1].__eq__('item') returns True — Queue.put co_varnames[1]='item' (len=4); co_varnames==('self','item','putter') len=3; 'item' is the second parameter of Queue.put(self, item): the value to enqueue; Queue.put is a coroutine (async def) that enqueues item and if the queue is at maxsize, creates a Future ('putter') and waits for a get() to free space; 'item'=4 is tied in length with 'self'=4 (both 4-char strings); Queue.put.__code__.co_argcount==2 (self+item are the 2 parameters; putter at index 2 is a local not counted in co_argcount); compare: Queue.get co_varnames[1]='getter' (len=6, 2 more than 'item'=4; getter vs item reflects the symmetry between put and get); Queue.__init__ co_varnames[1]='maxsize' (len=7, 3 more than 'item'=4); Queue.put_nowait co_varnames[1]='item' (len=4, same name and length as Queue.put co_varnames[1]='item': both put and put_nowait use 'item' as their item parameter); Queue.put.__code__.co_qualname=='Queue.put' (len=9); first standalone Queue.put co_varnames[1] equality invariant in queuecv122 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "Queue.put.__code__.co_varnames[1].__eq__"
  args: ["item"]
  expected: true

invariant asyncio_extra122.queue_put_v2_putter:
  description: "asyncio.Queue.put.__code__.co_varnames[2].__eq__('putter') returns True — Queue.put co_varnames[2]='putter' (len=6); 'putter' is a local asyncio.Future variable (not a parameter: co_argcount==2, only self+item); 'putter' is created when Queue.put is called and the queue is full (len==maxsize>0): the coroutine creates a Future, appends it to self._putters, awaits it, and resumes when a get() call pops an item and resolves the Future; 'putter'=6 chars: 'put'=3+'ter'=3=6 — the agent doing the put operation; analogous to 'getter'=6 in Queue.get and 'fut'=3 in Lock.acquire and Semaphore.acquire (both are parking Futures); co_varnames.__len__()==3 (put has 3 co_varnames — 1 more than get=2 — because put has an extra local 'putter' for producer-side parking while Queue.get has 'getter' for consumer-side parking); Queue.put.__code__.co_qualname=='Queue.put' (len=9: shortest qualname in this spec — shorter than '__init__'=14 and 'put_nowait'=16); first standalone Queue.put co_varnames[2] equality invariant in queuecv122 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "Queue.put.__code__.co_varnames[2].__eq__"
  args: ["putter"]
  expected: true

invariant asyncio_extra122.queue_get_v1_getter:
  description: "asyncio.Queue.get.__code__.co_varnames[1].__eq__('getter') returns True — Queue.get co_varnames[1]='getter' (len=6); co_varnames==('self','getter') len=2; 'getter' is a local asyncio.Future (not a parameter: co_argcount==1, only self); 'getter' is created when the queue is empty: the coroutine creates a Future, appends it to self._getters, awaits it, and resumes when a put() call enqueues an item and resolves the Future; 'getter'=6: 'get'=3+'ter'=3=6 — symmetric with 'putter'=6 in Queue.put (same length, same suffix pattern: both are -ter agent nouns from the queue operation name); compare: Lock.acquire co_varnames[1]='fut'=3 (shorter at 3 chars: Lock uses a generic 'fut' while Queue uses descriptive 'getter'/'putter'); Queue.get.__code__.co_qualname=='Queue.get' (len=9: tied with Queue.put=9: both are 3-char method names prefixed by 'Queue.'=6); co_varnames.__len__()==2 (same count as Queue.__init__=2 and put_nowait=2 and get_nowait=2; but Queue.get has 1 param+1 local while __init__ has 2 params); first standalone Queue.get co_varnames[1] equality invariant in queuecv122 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "Queue.get.__code__.co_varnames[1].__eq__"
  args: ["getter"]
  expected: true

invariant asyncio_extra122.queue_init_v1_maxsize:
  description: "asyncio.Queue.__init__.__code__.co_varnames[1].__eq__('maxsize') returns True — Queue.__init__ co_varnames[1]='maxsize' (len=7); co_varnames==('self','maxsize') len=2; 'maxsize' is a real parameter (co_argcount==2: self+maxsize; maxsize has a default value of 0); maxsize controls the maximum number of items the queue can hold: when maxsize==0 (default) the queue is unbounded; when maxsize>0 and len(queue)==maxsize, Queue.put creates a 'putter' Future and waits; 'maxsize'=7: 'max'=3+'size'=4=7; 'maxsize' is the longest element in Queue.__init__ co_varnames (7 > 'self'=4: 3 more); compare: Queue.put co_varnames[2]='putter'=6 (1 shorter than 'maxsize'=7); Queue.get co_varnames[1]='getter'=6 (1 shorter than 'maxsize'=7); Queue.put co_varnames[1]='item'=4 (3 shorter than 'maxsize'=7); Queue.__init__.__code__.co_qualname=='Queue.__init__' (len=14: longest qualname among Queue.put=9, Queue.get=9; shorter than put_nowait=16, get_nowait=16); compare: asyncio.Semaphore.__init__ co_varnames[1]='value'=5 (2 shorter than 'maxsize'=7); first standalone Queue.__init__ co_varnames[1] equality invariant in queuecv122a namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "Queue.__init__.__code__.co_varnames[1].__eq__"
  args: ["maxsize"]
  expected: true

invariant asyncio_extra122.queue_put_co_varnames_len_3:
  description: "asyncio.Queue.put.__code__.co_varnames.__len__() == 3 — co_varnames==('self','item','putter'); Queue.put is the only Queue method in this spec with 3 co_varnames; 3 is 1 more than Queue.get=2, Queue.__init__=2, Queue.put_nowait=2, Queue.get_nowait=2 (all other Queue methods have co_varnames.__len__()==2); the extra element 'putter' (index 2, len=6) is a local Future variable not a parameter (co_argcount==2: only self+item are counted); Queue.put has more co_varnames than Queue.get (3 vs 2) even though both are coroutines that potentially block — this is because Queue.put's producer-side parking Future ('putter') needs a distinct local name while Queue.get's consumer-side parking Future ('getter') also needs its own local; both put and get have exactly one extra local beyond their parameters; Queue.put.__code__.co_qualname=='Queue.put' (len=9); Queue.put.__code__.co_argcount==2 (self+item; putter is local, not counted); compare: Lock.acquire co_varnames.__len__()==2 (has 'self'+'fut': shorter name for the parking Future); asyncio.Semaphore.acquire co_varnames.__len__()==2 (same structure as Lock.acquire); Queue.put has more co_varnames than both Lock.acquire and Semaphore.acquire (3 vs 2) because Queue.put has 2 real parameters (self+item) while Lock/Semaphore.acquire have only 1 (self); first standalone Queue.put co_varnames length invariant in queuecv122 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: Queue.put.__code__.co_varnames.__len__
  args: []
  expected: 3

