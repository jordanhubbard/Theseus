spec: itertools_extra97
version: ">=3.9"
backend: python_module(itertools)
extends: itertools_extra96

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra96.zspec.zsdl."
    - "This spec covers: itertools C-type __doc__.__class__.__name__ for all iterator types (all 'str'); product and combinations __dict__ membership (Wave 254)."
    - "All itertools C-type __doc__.__class__.__name__ == 'str' — C extension types store their docstring as a Python str. Verified with Python 3.14.3."
    - "itertools.product.__dict__.__contains__('__new__') == True. Verified with Python 3.14.3."
    - "itertools.product.__dict__.__contains__('__iter__') == True. Verified with Python 3.14.3."
    - "itertools.product.__dict__.__contains__('__next__') == True. Verified with Python 3.14.3."
    - "itertools.product.__dict__.__contains__('__reduce__') == False — not in product's __dict__ in Python 3.14.3. Verified with Python 3.14.3."
    - "itertools.product.__dict__.__contains__('__doc__') == True. Verified with Python 3.14.3."
    - "itertools.product.__dict__.__contains__('__sizeof__') == True. Verified with Python 3.14.3."
    - "itertools.combinations.__dict__.__contains__('__new__') == True. Verified with Python 3.14.3."
    - "itertools.combinations.__dict__.__contains__('__iter__') == True. Verified with Python 3.14.3."
    - "itertools.combinations.__dict__.__contains__('__next__') == True. Verified with Python 3.14.3."
    - "itertools.combinations.__dict__.__contains__('__reduce__') == False — not in combinations' __dict__ in Python 3.14.3. Verified with Python 3.14.3."
    - "itertools.combinations.__dict__.__contains__('__setstate__') == False — not in combinations' __dict__ in Python 3.14.3. Verified with Python 3.14.3."
    - "itertools.combinations.__dict__.__contains__('__doc__') == True. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools C-type __doc__.__class__.__name__ for chain/product/combinations/permutations/accumulate
#
# Wave 254 theme: itertools C-type __doc__ is always a Python str.
#
# itertools.chain.__doc__.__class__.__name__ == 'str'
# itertools.product.__doc__.__class__.__name__ == 'str'
# itertools.combinations.__doc__.__class__.__name__ == 'str'
# itertools.permutations.__doc__.__class__.__name__ == 'str'
# itertools.accumulate.__doc__.__class__.__name__ == 'str'
#
# C extension types store their docstring as a Python str object.
# New to extra97.
# ---------------------------------------------------------------------------

table itertools_extra97.doc_class_name_group1:
  description: "itertools.chain/product/combinations/permutations/accumulate __doc__.__class__.__name__ == 'str'; C-type docstrings are Python str objects; wave 254; new to extra97"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsdocmem97

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_class_name_eq_str,
       "chain.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.chain.__doc__.__class__.__name__.__eq__('str') == True — chain is a C extension type; its __doc__ attribute is a Python str object containing the C-defined docstring; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra97"]
    - [product_doc_class_name_eq_str,
       "product.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.product.__doc__.__class__.__name__.__eq__('str') == True — product is a C extension type; its __doc__ attribute is a Python str object containing the C-defined docstring; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra97"]
    - [combinations_doc_class_name_eq_str,
       "combinations.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.combinations.__doc__.__class__.__name__.__eq__('str') == True — combinations is a C extension type; its __doc__ is a Python str; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra97"]
    - [permutations_doc_class_name_eq_str,
       "permutations.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.permutations.__doc__.__class__.__name__.__eq__('str') == True — permutations is a C extension type; its __doc__ is a Python str; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra97"]
    - [accumulate_doc_class_name_eq_str,
       "accumulate.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.accumulate.__doc__.__class__.__name__.__eq__('str') == True — accumulate is a C extension type; its __doc__ is a Python str; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra97"]

