# ---------------------------------------------------------------------------
# Table 3: product __dict__ membership
#
# Wave 254 theme: itertools.product type __dict__ membership.
#
# itertools.product.__dict__.__contains__('__new__') == True
# itertools.product.__dict__.__contains__('__iter__') == True
# itertools.product.__dict__.__contains__('__next__') == True
# itertools.product.__dict__.__contains__('__reduce__') == False
# itertools.product.__dict__.__contains__('__doc__') == True
# itertools.product.__dict__.__contains__('__sizeof__') == True
#
# product is a C extension type; __reduce__ is not in its own __dict__.
# product uniquely has __sizeof__ for memory reporting. New to extra97.
# ---------------------------------------------------------------------------

table itertools_extra97.product_dict_membership:
  description: "itertools.product.__dict__ membership: __new__/True, __iter__/True, __next__/True, __reduce__/False, __doc__/True, __sizeof__/True; wave 254; new to extra97"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsdocmem97

  columns: [id, function, args, expected, description]
  rows:
    - [product_dict_contains_new,
       "product.__dict__.__contains__",
       ["__new__"],
       true,
       "itertools.product.__dict__.__contains__('__new__') == True — product is a C extension type that defines its own tp_new slot; '__new__' appears in the type __dict__; mappingproxy.__contains__('__new__') returns True; new to extra97"]
    - [product_dict_contains_iter,
       "product.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.product.__dict__.__contains__('__iter__') == True — product implements the iterator protocol via tp_iter; '__iter__' appears in the type __dict__; mappingproxy.__contains__('__iter__') returns True; new to extra97"]
    - [product_dict_contains_next,
       "product.__dict__.__contains__",
       ["__next__"],
       true,
       "itertools.product.__dict__.__contains__('__next__') == True — product implements tp_iternext; '__next__' appears in the type __dict__; mappingproxy.__contains__('__next__') returns True; new to extra97"]
    - [product_dict_not_contains_reduce,
       "product.__dict__.__contains__",
       ["__reduce__"],
       false,
       "itertools.product.__dict__.__contains__('__reduce__') == False — product does not define its own __reduce__ in Python 3.14.3; mappingproxy.__contains__('__reduce__') returns False; new to extra97"]
    - [product_dict_contains_doc,
       "product.__dict__.__contains__",
       ["__doc__"],
       true,
       "itertools.product.__dict__.__contains__('__doc__') == True — product has a C-defined docstring stored as '__doc__' in its type __dict__; mappingproxy.__contains__('__doc__') returns True; new to extra97"]
    - [product_dict_contains_sizeof,
       "product.__dict__.__contains__",
       ["__sizeof__"],
       true,
       "itertools.product.__dict__.__contains__('__sizeof__') == True — product defines __sizeof__ to report memory consumption of the product state; it appears in the type __dict__; mappingproxy.__contains__('__sizeof__') returns True; new to extra97"]

# ---------------------------------------------------------------------------
# Table 4: combinations and combinations_with_replacement __dict__ membership
#
# Wave 254 theme: itertools.combinations and combinations_with_replacement
# type __dict__ membership.
#
# itertools.combinations.__dict__.__contains__('__new__') == True
# itertools.combinations.__dict__.__contains__('__iter__') == True
# itertools.combinations.__dict__.__contains__('__next__') == True
# itertools.combinations.__dict__.__contains__('__reduce__') == False
# itertools.combinations.__dict__.__contains__('__setstate__') == False
# itertools.combinations.__dict__.__contains__('__doc__') == True
#
# Neither __reduce__ nor __setstate__ is in combinations' __dict__ in
# Python 3.14.3. New to extra97.
# ---------------------------------------------------------------------------

table itertools_extra97.combinations_dict_membership:
  description: "itertools.combinations.__dict__ membership: __new__/True, __iter__/True, __next__/True, __reduce__/False, __setstate__/False, __doc__/True; wave 254; new to extra97"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsdocmem97

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_dict_contains_new,
       "combinations.__dict__.__contains__",
       ["__new__"],
       true,
       "itertools.combinations.__dict__.__contains__('__new__') == True — combinations is a C extension type that defines its own tp_new slot; '__new__' appears in the type __dict__; mappingproxy.__contains__('__new__') returns True; new to extra97"]
    - [combinations_dict_contains_iter,
       "combinations.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.combinations.__dict__.__contains__('__iter__') == True — combinations implements the iterator protocol; '__iter__' appears in the type __dict__; mappingproxy.__contains__('__iter__') returns True; new to extra97"]
    - [combinations_dict_contains_next,
       "combinations.__dict__.__contains__",
       ["__next__"],
       true,
       "itertools.combinations.__dict__.__contains__('__next__') == True — combinations implements tp_iternext; '__next__' appears in the type __dict__; mappingproxy.__contains__('__next__') returns True; new to extra97"]
    - [combinations_dict_not_contains_reduce,
       "combinations.__dict__.__contains__",
       ["__reduce__"],
       false,
       "itertools.combinations.__dict__.__contains__('__reduce__') == False — combinations does not define its own __reduce__ in Python 3.14.3; mappingproxy.__contains__('__reduce__') returns False; new to extra97"]
    - [combinations_dict_not_contains_setstate,
       "combinations.__dict__.__contains__",
       ["__setstate__"],
       false,
       "itertools.combinations.__dict__.__contains__('__setstate__') == False — combinations does not define __setstate__ in Python 3.14.3; mappingproxy.__contains__('__setstate__') returns False; new to extra97"]
    - [combinations_dict_contains_doc,
       "combinations.__dict__.__contains__",
       ["__doc__"],
       true,
       "itertools.combinations.__dict__.__contains__('__doc__') == True — combinations has a C-defined docstring stored as '__doc__' in its type __dict__; mappingproxy.__contains__('__doc__') returns True; new to extra97"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra97
# ---------------------------------------------------------------------------

invariant itertools_extra97.chain_doc_class_name_eq_str:
  description: "itertools.chain.__doc__.__class__.__name__ == 'str' — C extension type docstrings are Python str objects; wave 254; new to extra97"
  kind: python_call_eq
  function: chain.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra97.product_dict_contains_sizeof:
  description: "itertools.product.__dict__.__contains__('__sizeof__') == True — product defines __sizeof__ for memory reporting; wave 254; new to extra97"
  kind: python_call_eq
  function: product.__dict__.__contains__
  args: ["__sizeof__"]
  expected: true

invariant itertools_extra97.product_dict_not_contains_reduce:
  description: "itertools.product.__dict__.__contains__('__reduce__') == False — __reduce__ not in product's own __dict__ in Python 3.14.3; wave 254; new to extra97"
  kind: python_call_eq
  function: product.__dict__.__contains__
  args: ["__reduce__"]
  expected: false

invariant itertools_extra97.combinations_dict_not_contains_setstate:
  description: "itertools.combinations.__dict__.__contains__('__setstate__') == False — __setstate__ not in combinations' __dict__ in Python 3.14.3; wave 254; new to extra97"
  kind: python_call_eq
  function: combinations.__dict__.__contains__
  args: ["__setstate__"]
  expected: false

invariant itertools_extra97.filterfalse_doc_class_name_eq_str:
  description: "itertools.filterfalse.__doc__.__class__.__name__ == 'str' — C extension type docstrings are Python str objects; wave 254; new to extra97"
  kind: python_call_eq
  function: filterfalse.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
