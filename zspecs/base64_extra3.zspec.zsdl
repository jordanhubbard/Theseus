spec: base64_extra3
version: ">=3.9"
backend: python_module(base64)

docs: https://docs.python.org/3/library/base64.html
rfcs:
  - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/base64.html — Python base64 module documentation"
    - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings, October 2006"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/base64.py"
  notes:
    - "This spec extends base64.zspec.zsdl, base64_extra.zspec.zsdl, and base64_extra2.zspec.zsdl."
    - "Focus: __qualname__ checks for base64 module functions."
    - "For top-level module functions, __qualname__ == __name__ (no enclosing class)."
    - "base64.b64encode.__qualname__ == 'b64encode' — function defined at module scope."
    - "base64.b64encode.__module__ == 'base64' (new vector; base64_extra2 covers b16encode/b85encode/encodebytes/decodebytes module)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — encode functions
# For module-level functions, __qualname__ == __name__ (no enclosing class).
# None of the prior base64 specs check __qualname__.
# ---------------------------------------------------------------------------

table base64_extra3.encode_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [b64encode,         b64encode.__qualname__.__eq__,         ["b64encode"],         true]
    - [b16encode,         b16encode.__qualname__.__eq__,         ["b16encode"],         true]
    - [b32encode,         b32encode.__qualname__.__eq__,         ["b32encode"],         true]
    - [urlsafe_b64encode, urlsafe_b64encode.__qualname__.__eq__, ["urlsafe_b64encode"], true]
    - [encodebytes,       encodebytes.__qualname__.__eq__,       ["encodebytes"],       true]

# ---------------------------------------------------------------------------
# __qualname__ checks — decode functions
# ---------------------------------------------------------------------------

table base64_extra3.decode_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [b64decode,         b64decode.__qualname__.__eq__,         ["b64decode"],         true]
    - [b16decode,         b16decode.__qualname__.__eq__,         ["b16decode"],         true]
    - [b32decode,         b32decode.__qualname__.__eq__,         ["b32decode"],         true]
    - [urlsafe_b64decode, urlsafe_b64decode.__qualname__.__eq__, ["urlsafe_b64decode"], true]
    - [decodebytes,       decodebytes.__qualname__.__eq__,       ["decodebytes"],       true]

# ---------------------------------------------------------------------------
# __module__ for b64encode — not covered in any prior base64 spec
# (base64_extra2 covers b16encode, b85encode, encodebytes, decodebytes)
# ---------------------------------------------------------------------------

invariant base64_extra3.module.b64encode:
  description: "base64.b64encode.__module__ == 'base64'"
  category: module
  kind: python_call_eq
  function: b64encode.__module__.__eq__
  args: ["base64"]
  expected: true

invariant base64_extra3.module.b64decode:
  description: "base64.b64decode.__module__ == 'base64'"
  category: module
  kind: python_call_eq
  function: b64decode.__module__.__eq__
  args: ["base64"]
  expected: true

invariant base64_extra3.module.urlsafe_b64encode:
  description: "base64.urlsafe_b64encode.__module__ == 'base64'"
  category: module
  kind: python_call_eq
  function: urlsafe_b64encode.__module__.__eq__
  args: ["base64"]
  expected: true

invariant base64_extra3.module.urlsafe_b64decode:
  description: "base64.urlsafe_b64decode.__module__ == 'base64'"
  category: module
  kind: python_call_eq
  function: urlsafe_b64decode.__module__.__eq__
  args: ["base64"]
  expected: true
