spec: lightgbm_rust
version: ">=3.9"
backend: rust_module(lightgbm_rust)

docs: https://lightgbm.readthedocs.io/en/latest/pythonapi/lightgbm.LGBMClassifier.html

provenance:
  derived_from:
    - "https://lightgbm.readthedocs.io/en/latest/ — LightGBM documentation"
  not_derived_from:
    - "lightgbm source: lightgbm/sklearn.py"
  notes:
    - "LightGBM is a gradient boosting framework."
    - "LGBMClassifier(n_estimators=50).get_params()['n_estimators'] == 50."
    - "LGBMClassifier(num_leaves=31).get_params()['num_leaves'] == 31 — default."
    - "LGBMClassifier(num_leaves=15).get_params()['num_leaves'] == 15."
    - "LGBMClassifier().get_params()['boosting_type'] == 'gbdt'."
    - "Expose lgbm_n_estimators(n) -> int: LGBMClassifier(n_estimators=n).get_params()['n_estimators']."
    - "Expose lgbm_num_leaves(n) -> int: LGBMClassifier(num_leaves=n).get_params()['num_leaves']."
    - "Expose lgbm_boosting_type() -> str: LGBMClassifier().get_params()['boosting_type']."
    - "All test vectors verified against lightgbm 4.6.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# lgbm_n_estimators — n_estimators parameter roundtrip
table lightgbm_rust.params.n_estimators:
  kind: python_call_eq
  category: n_estimators
  id_prefix: lgbm_ne
  function: lgbm_n_estimators

  columns: [id, args, expected]
  rows:
    - [fifty,   [50],  50]
    - [hundred, [100], 100]

# lgbm_num_leaves — num_leaves parameter
table lightgbm_rust.params.num_leaves:
  kind: python_call_eq
  category: num_leaves
  id_prefix: lgbm_nl
  function: lgbm_num_leaves

  columns: [id, args, expected]
  rows:
    - [fifteen,      [15], 15]
    - [thirty_one,   [31], 31]

# lgbm_boosting_type — default boosting type is 'gbdt'
invariant lightgbm_rust.params.boosting_type:
  description: "LGBMClassifier default boosting_type == 'gbdt'"
  category: boosting_type
  kind: python_call_eq
  function: lgbm_boosting_type
  args: []
  expected: "gbdt"

