spec: theseus_socket_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_socket_cr3)
blocks: socket

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html"
    - "RFC 791 — Internet Protocol (IPv4 addresses)"
    - "POSIX socket(7) documentation"
  notes:
    - "Clean-room extended socket utilities. Do NOT import socket."
    - "inet_aton(ip_string): pack IPv4 address from dotted-quad string to 4-byte bytes."
    - "inet_ntoa(packed_ip): convert 4-byte packed IPv4 address to dotted-quad string."
    - "htons(x): convert 16-bit integer from host byte order to network (big-endian) byte order."
    - "socket3_inet_aton(): inet_aton('192.168.1.1') — check first byte is 192 — returns True."
    - "socket3_inet_ntoa(): inet_ntoa(b'\\xc0\\xa8\\x01\\x01') == '192.168.1.1'."
    - "socket3_htons(): ntohs(htons(1234)) == 1234 (round-trip)."
    - "Zero-arg invariant signatures — def socket3_inet_aton(): return bool"
    - "inet_aton: split IP by '.', convert each octet to int, pack as 4 unsigned bytes."
    - "inet_ntoa: unpack 4 bytes as unsigned ints, join with '.'."
    - "htons: on big-endian, htons(x)==x; on little-endian, swap bytes."
    - "ntohs: inverse of htons; ntohs(htons(x)) == x always."
    - "Export: inet_aton(addr), inet_ntoa(packed), htons(x), ntohs(x), htonl(x), ntohl(x)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_socket_cr3.inet_aton:
  description: "inet_aton('192.168.1.1')[0] == 192"
  category: inet_aton
  kind: python_call_eq
  function: socket3_inet_aton
  args: []
  expected: true

invariant theseus_socket_cr3.inet_ntoa:
  description: "inet_ntoa(b'\\xc0\\xa8\\x01\\x01') == '192.168.1.1'"
  category: inet_ntoa
  kind: python_call_eq
  function: socket3_inet_ntoa
  args: []
  expected: "192.168.1.1"

invariant theseus_socket_cr3.htons_roundtrip:
  description: "ntohs(htons(1234)) == 1234"
  category: htons
  kind: python_call_eq
  function: socket3_htons_roundtrip
  args: []
  expected: 1234
