spec: threading_extra1861
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module reference"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading.zspec.zsdl — covers class_names, function_names, TIMEOUT_MAX, active_count_ge_1, Lock behavior, Event, Semaphore._value"
    - "threading_extra.zspec.zsdl — covers module checks, local.__name__/__module__, get_ident, TIMEOUT_MAX, stack_size"
    - "threading_extra1846.zspec.zsdl — covers arithmetic and comparison operator dunders for threading types"
  notes:
    - "Wave 571 theme: bitwise operators (__or__/__and__/__xor__) and in-place operators (__iadd__/__ior__) for threading types."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.Barrier, threading.Timer are pure Python classes."
    - "threading.Lock is a C-level type alias; threading.Lock.__class__ is <class 'type'>."
    - "None of the threading types define bitwise or in-place operator dunder methods in their own __dict__."
    - "threading.local is a C-level type. Its __dict__ contains __init__, __new__, __getattribute__, __setattr__, __delattr__ but not __repr__, __copy__, or __deepcopy__."
    - "threading.local.__dict__.__contains__('__dict__') == False — local uses C-level per-thread storage, not a Python-level __dict__ slot in the class dict."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: bitwise operators for threading types
#
# All threading types (Thread, Event, Condition, Semaphore, Barrier) are pure
# Python classes. Lock is a C-level type. None define bitwise dunder methods
# in their own __dict__.
# ---------------------------------------------------------------------------

table threading_extra1861.bitwise_operators:
  description: "Bitwise operator dunder methods absent from threading type own __dict__"
  kind: python_call_eq
  category: bitwise_operators
  id_prefix: th1861

  columns: [id, function, args, expected]
  rows:
    - ["th1861001", threading.Thread.__dict__.__contains__,              ["__or__"],  false]
    - ["th1861002", threading.Thread.__dict__.__contains__,              ["__and__"], false]
    - ["th1861003", threading.Thread.__dict__.__contains__,              ["__xor__"], false]
    - ["th1861004", threading.Event.__dict__.__contains__,               ["__or__"],  false]
    - ["th1861005", threading.Condition.__dict__.__contains__,           ["__or__"],  false]
    - ["th1861006", threading.Semaphore.__dict__.__contains__,           ["__or__"],  false]
    - ["th1861007", threading.Barrier.__dict__.__contains__,             ["__or__"],  false]
    - ["th1861008", threading.Lock.__class__.__dict__.__contains__,      ["__or__"],  false]

# ---------------------------------------------------------------------------
# Table 2: in-place operators for threading types
#
# None of the threading types define in-place operator dunder methods in
# their own __dict__.
# ---------------------------------------------------------------------------

table threading_extra1861.inplace_operators:
  description: "In-place operator dunder methods absent from threading type own __dict__"
  kind: python_call_eq
  category: inplace_operators
  id_prefix: th1861

  columns: [id, function, args, expected]
  rows:
    - ["th1861009", threading.Thread.__dict__.__contains__,              ["__iadd__"], false]
    - ["th1861010", threading.Thread.__dict__.__contains__,              ["__ior__"],  false]
    - ["th1861011", threading.Event.__dict__.__contains__,               ["__iadd__"], false]
    - ["th1861012", threading.Condition.__dict__.__contains__,           ["__iadd__"], false]
    - ["th1861013", threading.Semaphore.__dict__.__contains__,           ["__iadd__"], false]
    - ["th1861014", threading.Barrier.__dict__.__contains__,             ["__iadd__"], false]
    - ["th1861015", threading.Timer.__dict__.__contains__,               ["__iadd__"], false]
    - ["th1861016", threading.Lock.__class__.__dict__.__contains__,      ["__iadd__"], false]

# ---------------------------------------------------------------------------
# Table 3: threading.local own __dict__ attribute membership
#
# threading.local is a C-level type that provides per-thread attribute
# storage. It defines __init__, __new__, __getattribute__, __setattr__, and
# __delattr__ in its own __dict__, but not __repr__, __copy__, __deepcopy__,
# or a Python-level __dict__ descriptor.
# ---------------------------------------------------------------------------

table threading_extra1861.threading_local_attrs:
  description: "threading.local own __dict__ attribute membership"
  kind: python_call_eq
  category: threading_local_attrs
  id_prefix: th1861

  columns: [id, function, args, expected]
  rows:
    - ["th1861017", threading.__dict__.__contains__,         ["local"],            true]
    - ["th1861018", threading.local.__dict__.__contains__,   ["__dict__"],         false]
    - ["th1861019", threading.local.__dict__.__contains__,   ["__init__"],         true]
    - ["th1861020", threading.local.__dict__.__contains__,   ["__new__"],          true]
    - ["th1861021", threading.local.__dict__.__contains__,   ["__getattribute__"], true]
    - ["th1861022", threading.local.__dict__.__contains__,   ["__setattr__"],      true]
    - ["th1861023", threading.local.__dict__.__contains__,   ["__delattr__"],      true]
    - ["th1861024", threading.local.__dict__.__contains__,   ["__repr__"],         false]
    - ["th1861025", threading.local.__dict__.__contains__,   ["__copy__"],         false]
    - ["th1861026", threading.local.__dict__.__contains__,   ["__deepcopy__"],     false]
