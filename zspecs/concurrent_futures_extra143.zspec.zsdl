spec: concurrent_futures_extra143
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.ThreadPoolExecutor — ThreadPoolExecutor documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py, Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.ThreadPoolExecutor.submit — __qualname__=='ThreadPoolExecutor.submit' (len=25); __module__=='concurrent.futures.thread' (len=25); __doc__.__len__()==248; co_argcount==2 ('self','fn'); co_varnames.__len__()==7. concurrent.futures.ThreadPoolExecutor.shutdown — __qualname__=='ThreadPoolExecutor.shutdown' (len=27); __module__=='concurrent.futures.thread' (len=25); __doc__.__len__()==491; co_argcount==2 ('self','wait'); co_varnames.__len__()==5. concurrent.futures.ThreadPoolExecutor.__init__ — __qualname__=='ThreadPoolExecutor.__init__' (len=27); __module__=='concurrent.futures.thread' (len=25); co_argcount==5; co_varnames.__len__()==6. concurrent.futures.ThreadPoolExecutor.map — __qualname__=='Executor.map' (len=12: defined on base Executor class); __module__=='concurrent.futures._base' (len=24); __doc__.__len__()==1063; co_argcount==2; co_varnames.__len__()==8. concurrent.futures.ThreadPoolExecutor.__name__=='ThreadPoolExecutor' (len=18); __module__=='concurrent.futures.thread' (len=25); __bases__[0].__name__=='Executor' (len=8). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "ThreadPoolExecutor.__init__, submit, and shutdown all have __module__=='concurrent.futures.thread' (len=25). map inherits from Executor and has __module__=='concurrent.futures._base' (len=24). shutdown and __init__ tie for longest qualname at len=27; submit is len=25; map has the shortest at len=12 (because it shows the Executor base class qualname). TPE.__doc__ is None (no class docstring). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor class identity — extra143
#
# ThreadPoolExecutor.__name__              == 'ThreadPoolExecutor' (len=18)
# ThreadPoolExecutor.__module__            == 'concurrent.futures.thread' (len=25)
# ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'           (len=8)
# ThreadPoolExecutor.__doc__               == None
# ---------------------------------------------------------------------------

table concurrent_futures_extra143.tpe_class_identity:
  description: "concurrent.futures.ThreadPoolExecutor class identity checks — ThreadPoolExecutor.__name__.__eq__('ThreadPoolExecutor')==True (len=18: 'ThreadPool'=10+'Executor'=8=18); ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread')==True (len=25: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'thread'=6=25; the concrete thread-based implementation module); ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True (len=8: 'Executor'=8, the abstract base class from concurrent.futures._base); ThreadPoolExecutor.__doc__ is None (no class-level docstring on ThreadPoolExecutor itself); ThreadPoolExecutor.__name__.__len__()==18; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpe_id143

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,   concurrent.futures.ThreadPoolExecutor.__name__.__eq__,              ["ThreadPoolExecutor"],            true,  "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' (len=18); verified with Python 3.14.3"]
    - [name_len,  concurrent.futures.ThreadPoolExecutor.__name__.__len__,              [],                                18,    "concurrent.futures.ThreadPoolExecutor.__name__.__len__() == 18; verified with Python 3.14.3"]
    - [mod_eq,    concurrent.futures.ThreadPoolExecutor.__module__.__eq__,            ["concurrent.futures.thread"],     true,  "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (len=25); verified with Python 3.14.3"]
    - [mod_len,   concurrent.futures.ThreadPoolExecutor.__module__.__len__,            [],                                25,    "concurrent.futures.ThreadPoolExecutor.__module__.__len__() == 25; verified with Python 3.14.3"]
    - [base_eq,   "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],                      true,  "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' (len=8); verified with Python 3.14.3"]
    - [base_len,  "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__len__", [],                               8,     "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__len__() == 8; verified with Python 3.14.3"]

