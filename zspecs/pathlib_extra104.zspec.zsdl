spec: pathlib_extra104
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra99

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra99.zspec.zsdl."
    - "This spec covers: pathlib.Path method class names (__class__.__name__ for individual methods of the concrete Path class)."
    - "pathlib.Path is a pure Python class (not a C extension); all its methods are 'function' (plain Python functions), not 'method_descriptor' or 'wrapper_descriptor'."
    - "pathlib.Path.open.__class__.__name__ = 'function' — Path.open is a pure Python method."
    - "pathlib.Path.read_text.__class__.__name__ = 'function' — Path.read_text is a pure Python method."
    - "pathlib.Path.write_text.__class__.__name__ = 'function' — Path.write_text is a pure Python method."
    - "pathlib.Path.read_bytes.__class__.__name__ = 'function' — Path.read_bytes is a pure Python method."
    - "pathlib.Path.write_bytes.__class__.__name__ = 'function' — Path.write_bytes is a pure Python method."
    - "pathlib.Path.mkdir.__class__.__name__ = 'function' — Path.mkdir is a pure Python method."
    - "pathlib.Path.stat.__class__.__name__ = 'function' — Path.stat is a pure Python method."
    - "pathlib.Path.exists.__class__.__name__ = 'function' — Path.exists is a pure Python method."
    - "pathlib.Path.is_file.__class__.__name__ = 'function' — Path.is_file is a pure Python method."
    - "pathlib.Path.iterdir.__class__.__name__ = 'function' — Path.iterdir is a pure Python method."
    - "pathlib.Path.__mro__.__len__() = 3 (Path, PurePath, object)."
    - "pathlib.Path.open.__qualname__ = 'Path.open' (length 9)."
    - "pathlib.Path.read_text.__qualname__ = 'Path.read_text' (length 14)."
    - "pathlib.Path.write_text.__qualname__ = 'Path.write_text' (length 15)."
    - "pathlib.Path.mkdir.__qualname__ = 'Path.mkdir' (length 10)."
    - "pathlib.Path.exists.__qualname__ = 'Path.exists' (length 11)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path I/O method class names
# Path is a pure Python class; all methods are 'function' (not C descriptors).
# This contrasts sharply with io.BytesIO/StringIO where methods are
# 'method_descriptor' or 'wrapper_descriptor'.
# ---------------------------------------------------------------------------

table pathlib_extra104.Path_IO_method_class_names:
  description: "pathlib.Path I/O methods (open, read_text, write_text, read_bytes, write_bytes) all have __class__.__name__ == 'function' (pure Python methods)"
  kind: python_call_eq
  category: method_class_names
  id_prefix: pathlibmethodcls104

  columns: [id, function, args, expected, description]
  rows:
    - [path_open_cls,       Path.open.__class__.__name__.__eq__,        ["function"], true,  "Path.open is a pure Python function (not a C method_descriptor)"]
    - [path_rdtxt_cls,      Path.read_text.__class__.__name__.__eq__,   ["function"], true,  "Path.read_text is a pure Python function"]
    - [path_wrtxt_cls,      Path.write_text.__class__.__name__.__eq__,  ["function"], true,  "Path.write_text is a pure Python function"]
    - [path_rdbyt_cls,      Path.read_bytes.__class__.__name__.__eq__,  ["function"], true,  "Path.read_bytes is a pure Python function"]
    - [path_wrbyt_cls,      Path.write_bytes.__class__.__name__.__eq__, ["function"], true,  "Path.write_bytes is a pure Python function"]
    - [path_open_not_md,    Path.open.__class__.__name__.__eq__,        ["method_descriptor"], false, "Path.open is NOT a method_descriptor (it is a pure Python function)"]
    - [path_rdtxt_not_wd,   Path.read_text.__class__.__name__.__eq__,   ["wrapper_descriptor"], false, "Path.read_text is NOT a wrapper_descriptor (it is a pure Python function)"]
    - [path_open_name_eq,   Path.open.__name__.__eq__,                  ["open"],      true,  "Path.open.__name__ == 'open' (Python function carries its source name)"]
    - [path_rdtxt_name_eq,  Path.read_text.__name__.__eq__,             ["read_text"], true,  "Path.read_text.__name__ == 'read_text'"]
    - [path_wrtxt_name_eq,  Path.write_text.__name__.__eq__,            ["write_text"], true, "Path.write_text.__name__ == 'write_text'"]

# ---------------------------------------------------------------------------
# pathlib.Path filesystem method class names
# stat, exists, is_file, is_dir, iterdir, mkdir are all 'function'.
# ---------------------------------------------------------------------------

table pathlib_extra104.Path_filesystem_method_class_names:
  description: "pathlib.Path filesystem methods (stat, exists, is_file, is_dir, iterdir, mkdir, touch, rmdir, unlink, glob) all have __class__.__name__ == 'function'"
  kind: python_call_eq
  category: method_class_names
  id_prefix: pathlibmethodcls104

  columns: [id, function, args, expected, description]
  rows:
    - [path_stat_cls,     Path.stat.__class__.__name__.__eq__,      ["function"], true, "Path.stat is a pure Python function"]
    - [path_exists_cls,   Path.exists.__class__.__name__.__eq__,    ["function"], true, "Path.exists is a pure Python function"]
    - [path_isfile_cls,   Path.is_file.__class__.__name__.__eq__,   ["function"], true, "Path.is_file is a pure Python function"]
    - [path_isdir_cls,    Path.is_dir.__class__.__name__.__eq__,    ["function"], true, "Path.is_dir is a pure Python function"]
    - [path_iterdir_cls,  Path.iterdir.__class__.__name__.__eq__,   ["function"], true, "Path.iterdir is a pure Python function"]
    - [path_mkdir_cls,    Path.mkdir.__class__.__name__.__eq__,     ["function"], true, "Path.mkdir is a pure Python function"]
    - [path_touch_cls,    Path.touch.__class__.__name__.__eq__,     ["function"], true, "Path.touch is a pure Python function"]
    - [path_rmdir_cls,    Path.rmdir.__class__.__name__.__eq__,     ["function"], true, "Path.rmdir is a pure Python function"]
    - [path_unlink_cls,   Path.unlink.__class__.__name__.__eq__,    ["function"], true, "Path.unlink is a pure Python function"]
    - [path_glob_cls,     Path.glob.__class__.__name__.__eq__,      ["function"], true, "Path.glob is a pure Python function"]
    - [path_chmod_cls,    Path.chmod.__class__.__name__.__eq__,     ["function"], true, "Path.chmod is a pure Python function"]
    - [path_rename_cls,   Path.rename.__class__.__name__.__eq__,    ["function"], true, "Path.rename is a pure Python function"]

# ---------------------------------------------------------------------------
# pathlib.Path method qualname lengths
# Qualnames follow 'Path.<method_name>' pattern.
# ---------------------------------------------------------------------------

table pathlib_extra104.Path_method_qualname_lengths:
  description: "pathlib.Path method __qualname__ values and their lengths; all follow the 'Path.<method>' pattern"
  kind: python_call_eq
  category: method_class_names
  id_prefix: pathlibmethodcls104

  columns: [id, function, args, expected, description]
  rows:
    - [path_open_qn_len,    Path.open.__qualname__.__len__,       [], 9,  "Path.open.__qualname__ is 'Path.open' (5 + 1 + 3 = 9 chars)"]
    - [path_mkdir_qn_len,   Path.mkdir.__qualname__.__len__,      [], 10, "Path.mkdir.__qualname__ is 'Path.mkdir' (5 + 1 + 5 = 10 + wait: 'Path.mkdir' = 10 chars)"]
    - [path_exists_qn_len,  Path.exists.__qualname__.__len__,     [], 11, "Path.exists.__qualname__ is 'Path.exists' (11 chars)"]
    - [path_rdtxt_qn_len,   Path.read_text.__qualname__.__len__,  [], 14, "Path.read_text.__qualname__ is 'Path.read_text' (14 chars)"]
    - [path_wrtxt_qn_len,   Path.write_text.__qualname__.__len__, [], 15, "Path.write_text.__qualname__ is 'Path.write_text' (15 chars)"]
    - [path_mro_len,        Path.__mro__.__len__,                 [], 3,  "Path.__mro__.__len__() == 3 (Path, PurePath, object)"]
    - [path_stat_name_eq,   Path.stat.__name__.__eq__,            ["stat"],     true, "Path.stat.__name__ == 'stat'"]
    - [path_exists_name_eq, Path.exists.__name__.__eq__,          ["exists"],   true, "Path.exists.__name__ == 'exists'"]
    - [path_isfile_name_eq, Path.is_file.__name__.__eq__,         ["is_file"],  true, "Path.is_file.__name__ == 'is_file'"]
    - [path_mkdir_name_eq,  Path.mkdir.__name__.__eq__,           ["mkdir"],    true, "Path.mkdir.__name__ == 'mkdir'"]
    - [path_iterdir_name_eq,Path.iterdir.__name__.__eq__,         ["iterdir"],  true, "Path.iterdir.__name__ == 'iterdir'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra104.Path.open_is_function:
  description: "pathlib.Path.open.__class__.__name__ == 'function' (Path is a pure Python class defined in pathlib; its methods are ordinary Python functions, unlike C extension types where methods are 'method_descriptor')"
  category: method_class_names
  kind: python_call_eq
  function: Path.open.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra104.Path.read_text_is_function:
  description: "pathlib.Path.read_text.__class__.__name__ == 'function' (Path.read_text is a pure Python method; all pathlib.Path I/O methods are ordinary Python functions)"
  category: method_class_names
  kind: python_call_eq
  function: Path.read_text.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra104.Path.mkdir_is_function:
  description: "pathlib.Path.mkdir.__class__.__name__ == 'function' (Path.mkdir is a pure Python method; the entire pathlib.Path API is implemented in pure Python, not as C extensions)"
  category: method_class_names
  kind: python_call_eq
  function: Path.mkdir.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra104.Path.exists_qualname_len_11:
  description: "pathlib.Path.exists.__qualname__.__len__() == 11 (the qualname 'Path.exists' has exactly 11 characters: 4 for 'Path' + 1 for '.' + 6 for 'exists')"
  category: method_class_names
  kind: python_call_eq
  function: Path.exists.__qualname__.__len__
  args: []
  expected: 11

invariant pathlib_extra104.Path.mro_len_3:
  description: "pathlib.Path.__mro__.__len__() == 3 (the MRO of Path is [Path, PurePath, object])"
  category: method_class_names
  kind: python_call_eq
  function: Path.__mro__.__len__
  args: []
  expected: 3
