spec: io_extra54
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra53.zspec.zsdl — covers io.IOBase.__class__.__name__.__eq__('ABCMeta'); io.FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader/TextIOWrapper __class__.__name__.__len__()==4; io.open.__name__.__len__()==4; io.open.__qualname__.__len__()==4; io.open.__class__.__name__.__eq__('builtin_function_or_method')."
    - "io_extra4.zspec.zsdl — covers FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader/TextIOWrapper/BufferedRandom/UnsupportedOperation __class__.__name__.__eq__('type')."
    - "io_extra33.zspec.zsdl — covers open.__qualname__.__eq__('open')."
    - "io_extra3.zspec.zsdl — covers open.__name__.__eq__('open')."
  notes:
    - "This spec extends io_extra53.zspec.zsdl."
    - "Prior specs collectively covered: io.IOBase.__class__.__name__=='ABCMeta' equality (io_extra53); concrete class __class__.__name__=='type' equality (io_extra4); concrete class __class__.__name__.__len__()==4 (io_extra53); open.__class__.__name__=='builtin_function_or_method' equality (io_extra53); open.__qualname__/__name__ equality and length. NO prior io spec checks __class__.__qualname__ for any io object — all __qualname__ anchors in this spec are novel."
    - "This spec covers: io.FileIO.__class__.__qualname__.__eq__('type') (NOVEL — FileIO is a concrete C-extension class; its metaclass is 'type'; __qualname__=='type'==__name__ for the builtin type metaclass; no prior io spec checks FileIO.__class__.__qualname__; novel __qualname__ path anchor in io_extra54 namespace); io.BytesIO.__class__.__qualname__.__eq__('type') (NOVEL); io.StringIO.__class__.__qualname__.__eq__('type') (NOVEL); io.BufferedWriter.__class__.__qualname__.__eq__('type') (NOVEL); io.BufferedReader.__class__.__qualname__.__eq__('type') (NOVEL); io.TextIOWrapper.__class__.__qualname__.__eq__('type') (NOVEL); io.IOBase.__class__.__qualname__.__eq__('ABCMeta') (NOVEL — IOBase uses ABCMeta metaclass; ABCMeta.__qualname__=='ABCMeta'==ABCMeta.__name__; no prior io spec checks IOBase.__class__.__qualname__; novel); io.open.__class__.__qualname__.__eq__('builtin_function_or_method') (NOVEL — io.open is the builtin open() function; its type's __qualname__ is 'builtin_function_or_method'; io_extra53 anchors open.__class__.__name__ via __name__; no prior io spec checks open.__class__.__qualname__; novel); io.DEFAULT_BUFFER_SIZE.__class__.__qualname__.__eq__('int') (NOVEL — DEFAULT_BUFFER_SIZE==131072 is a plain int; its __class__ is int; int.__qualname__=='int'; no prior io spec checks DEFAULT_BUFFER_SIZE.__class__.__qualname__; novel)."
    - "io.FileIO.__class__.__qualname__ == 'type'. FileIO is a concrete C-extension class whose metaclass is the standard 'type'. For top-level builtin types, __qualname__==__name__=='type'. io_extra4 anchors the equality via __name__; no prior io spec accesses __class__.__qualname__. Novel __qualname__ path anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.IOBase.__class__.__qualname__ == 'ABCMeta'. IOBase is an abstract base class whose metaclass is ABCMeta. ABCMeta is a top-level class in the abc module so its __qualname__=='ABCMeta'==__name__. io_extra53 anchors IOBase.__class__.__name__=='ABCMeta' via __name__; no prior io spec accesses IOBase.__class__.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.open.__class__.__qualname__ == 'builtin_function_or_method'. io.open is the builtin open() function. Its type is builtin_function_or_method, whose __qualname__=='builtin_function_or_method'==__name__. io_extra53 anchors open.__class__.__name__ via __name__; no prior io spec checks open.__class__.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__qualname__ == 'int'. DEFAULT_BUFFER_SIZE is the integer constant 8192 (or 131072 on some platforms). Its type is int, whose __qualname__=='int'. No prior io spec checks DEFAULT_BUFFER_SIZE.__class__.__qualname__ or any DEFAULT_BUFFER_SIZE class identity. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io concrete class __class__.__qualname__ equality
#
# The concrete C-extension io classes all have the standard 'type' metaclass.
# For top-level builtin types, __qualname__==__name__=='type':
#
#   FileIO.__class__.__qualname__        == 'type'
#   BytesIO.__class__.__qualname__       == 'type'
#   StringIO.__class__.__qualname__      == 'type'
#   BufferedWriter.__class__.__qualname__ == 'type'
#   BufferedReader.__class__.__qualname__ == 'type'
#   TextIOWrapper.__class__.__qualname__ == 'type'
#
# Prior specs (io_extra4, io_extra) anchor __class__.__name__ for these
# classes; no prior io spec checks __class__.__qualname__ for any of them.
# All six __qualname__ path anchors are novel in the io_extra54 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra54.concrete_class_qualname_eq:
  description: "io concrete class __class__.__qualname__.__eq__('type') for FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader/TextIOWrapper — all use 'type' metaclass; for top-level builtin types __qualname__==__name__=='type'; prior specs anchor via __name__ path; no prior io spec checks __class__.__qualname__ for any io class; all six novel __qualname__ path anchors in io_extra54 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioclsqual54

  columns: [id, function, args, expected]
  rows:
    - [FileIO_class_qualname,         FileIO.__class__.__qualname__.__eq__,         ["type"], true]
    - [BytesIO_class_qualname,        BytesIO.__class__.__qualname__.__eq__,        ["type"], true]
    - [StringIO_class_qualname,       StringIO.__class__.__qualname__.__eq__,       ["type"], true]
    - [BufferedWriter_class_qualname, BufferedWriter.__class__.__qualname__.__eq__, ["type"], true]
    - [BufferedReader_class_qualname, BufferedReader.__class__.__qualname__.__eq__, ["type"], true]
    - [TextIOWrapper_class_qualname,  TextIOWrapper.__class__.__qualname__.__eq__,  ["type"], true]

# ---------------------------------------------------------------------------
# io.IOBase.__class__.__qualname__ — ABCMeta metaclass qualname
#
# IOBase (and RawIOBase, BufferedIOBase, TextIOBase) are abstract base classes
# in the _io module whose metaclass is ABCMeta from the abc module.
# ABCMeta is a top-level class so its __qualname__=='ABCMeta'==__name__:
#
#   IOBase.__class__.__qualname__  == 'ABCMeta'
#
# io_extra53 anchors IOBase.__class__.__name__=='ABCMeta' via the __name__
# path. No prior io spec accesses IOBase.__class__.__qualname__.
# Novel __qualname__ path anchor in the io_extra54 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra54.IOBase_class_qualname_ABCMeta:
  description: "io.IOBase.__class__.__qualname__ == 'ABCMeta' — IOBase is an abstract base class whose metaclass is ABCMeta; ABCMeta is a top-level class so __qualname__=='ABCMeta'==__name__; io_extra53 anchors IOBase.__class__.__name__=='ABCMeta' via __name__ path; no prior io spec checks IOBase.__class__.__qualname__; novel __qualname__ path anchor in io_extra54 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__class__.__qualname__.__eq__
  args: ["ABCMeta"]
  expected: true

# ---------------------------------------------------------------------------
# io.open.__class__.__qualname__
#
# io.open is the builtin open() function from the _io C extension.
# Its type is builtin_function_or_method, whose qualname is:
#
#   open.__class__.__qualname__  == 'builtin_function_or_method'
#
# io_extra53 anchors open.__class__.__name__=='builtin_function_or_method'
# via the __name__ path. No prior io spec checks open.__class__.__qualname__.
# Novel __qualname__ path anchor in the io_extra54 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra54.open_class_qualname_eq:
  description: "io.open.__class__.__qualname__ == 'builtin_function_or_method' — io.open is the builtin open() function; its type is builtin_function_or_method; for builtin types __qualname__==__name__; io_extra53 anchors open.__class__.__name__ via __name__ path; no prior io spec checks open.__class__.__qualname__; novel __qualname__ path anchor in io_extra54 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: open.__class__.__qualname__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE.__class__.__qualname__
#
# io.DEFAULT_BUFFER_SIZE is an integer constant (typically 8192). Its type
# is int, whose __qualname__ is 'int' (top-level builtin, __qualname__==__name__):
#
#   DEFAULT_BUFFER_SIZE.__class__.__qualname__  == 'int'
#
# No prior io spec checks DEFAULT_BUFFER_SIZE.__class__.__qualname__ or
# any DEFAULT_BUFFER_SIZE class identity attribute.
# Novel anchor in the io_extra54 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra54.DEFAULT_BUFFER_SIZE_class_qualname_eq:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__qualname__ == 'int' — DEFAULT_BUFFER_SIZE is a plain integer constant; its __class__ is int; int is a top-level builtin type so __qualname__=='int'==__name__; no prior io spec checks DEFAULT_BUFFER_SIZE.__class__.__qualname__ or any class identity for this constant; novel anchor in io_extra54 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: constant_identity
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__qualname__.__eq__
  args: ["int"]
  expected: true
