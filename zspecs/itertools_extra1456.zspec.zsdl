       true,
       "itertools.accumulate.__dict__.__contains__('__iter__') == True — accumulate is a C extension iterator; __iter__ defined in own class __dict__ as wrapper_descriptor; new to extra1456"]
    - [it1456id006,
       "combinations.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.combinations.__dict__.__contains__('__iter__') == True — combinations is a C extension iterator; __iter__ defined in own class __dict__ as wrapper_descriptor; new to extra1456"]
    - [it1456id007,
       "product.__dict__.__contains__",
