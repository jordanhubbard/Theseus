# ---------------------------------------------------------------------------
# Standalone invariants — extra1456
# ---------------------------------------------------------------------------

invariant itertools_extra1456.chain_iter_in_dict:
  description: "'__iter__' in itertools.chain.__dict__ — chain is a C extension iterator implementing tp_iter; wave 544; new to extra1456"
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__iter__"]
  expected: true

invariant itertools_extra1456.chain_next_in_dict:
  description: "'__next__' in itertools.chain.__dict__ — chain is a C extension iterator implementing tp_iternext; wave 544; new to extra1456"
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__next__"]
  expected: true

invariant itertools_extra1456.chain_contains_not_in_dict:
  description: "'__contains__' not in itertools.chain.__dict__ — chain is an iterator, not a container; wave 544; new to extra1456"
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__contains__"]
  expected: false

invariant itertools_extra1456.chain_iter_is_wrapper_descriptor:
  description: "itertools.chain.__iter__.__class__.__name__ == 'wrapper_descriptor' — __iter__ is a C extension tp_iter slot; wave 544; new to extra1456"
  kind: python_call_eq
  function: chain.__iter__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true
