# ---------------------------------------------------------------------------
# Table 3: itertools class __contains__ dict absence
#
# Wave 544 theme: '__contains__' not in own __dict__ for itertools classes.
# All itertools objects are iterators, not containers — they do not implement
# the container protocol (__contains__/tp_as_sequence->sq_contains).
# ---------------------------------------------------------------------------

table itertools_extra1456.contains_dict_membership:
  description: "itertools classes: '__contains__' not in own __dict__ for chain, count, cycle, repeat, accumulate, combinations, product, islice; wave 544; new to extra1456"
  kind: python_call_eq
  category: contains_dict_membership
  id_prefix: it1456cd

  columns: [id, function, args, expected, description]
  rows:
    - [it1456cd001,
       "chain.__dict__.__contains__",
       ["__contains__"],
       false,
       "itertools.chain.__dict__.__contains__('__contains__') == False — chain is an iterator, not a container; no __contains__ in own class __dict__; new to extra1456"]
    - [it1456cd002,
       "count.__dict__.__contains__",
       ["__contains__"],
       false,
