spec: itertools_extra1456
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools_extra1441.zspec.zsdl — covers __subclasshook__, __instancecheck__, __subclasscheck__ ABC-machinery checks"
    - "itertools_extra1426.zspec.zsdl — covers __format__ and __dir__ checks for itertools classes"
  notes:
    - "Wave 544 (_extra1456): focuses on __iter__, __next__, and __contains__ container/iterable protocol method presence checks for itertools classes."
    - "All itertools classes are C extension iterators — they define both '__iter__' and '__next__' in their own __dict__ as wrapper_descriptor. Verified Python 3.14.4."
    - "itertools.chain.__dict__['__iter__'].__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.4."
    - "itertools.chain.__dict__['__next__'].__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.4."
    - "itertools.count.__dict__['__iter__'].__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.4."
    - "itertools.count.__dict__['__next__'].__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.4."
    - "itertools.cycle.__dict__['__iter__'].__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.4."
    - "itertools.repeat.__dict__['__iter__'].__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.4."
    - "itertools.accumulate.__dict__['__iter__'].__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.4."
    - "itertools.combinations.__dict__['__iter__'].__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.4."
    - "itertools.product.__dict__['__iter__'].__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.4."
    - "itertools.islice.__dict__['__iter__'].__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.4."
    - "None of chain, count, cycle, repeat, accumulate, combinations, product, islice define '__contains__' in their own __dict__ — itertools objects are iterators, not containers. Verified Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools class __iter__ dict presence and type
#
# Wave 544 theme: '__iter__' is present in own __dict__ for all itertools
# classes and has type wrapper_descriptor. All itertools objects are iterators
# that implement tp_iter in C, which surfaces as wrapper_descriptor.
# ---------------------------------------------------------------------------

table itertools_extra1456.iter_dict_membership:
  description: "itertools classes: '__iter__' in own __dict__ for chain, count, cycle, repeat, accumulate, combinations, product, islice; wave 544; new to extra1456"
  kind: python_call_eq
  category: iter_dict_membership
  id_prefix: it1456id

  columns: [id, function, args, expected, description]
  rows:
    - [it1456id001,
       "chain.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.chain.__dict__.__contains__('__iter__') == True — chain is a C extension iterator; __iter__ defined in own class __dict__ as wrapper_descriptor; new to extra1456"]
    - [it1456id002,
       "count.__dict__.__contains__",
