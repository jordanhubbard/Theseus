spec: rich_extra_rust
version: ">=3.9"
backend: rust_module(rich_extra_rust)

docs: https://rich.readthedocs.io/

provenance:
  derived_from:
    - "https://rich.readthedocs.io/ — Rich library documentation"
  not_derived_from:
    - "rich source: rich/markup.py"
  notes:
    - "Additional Rich operations not in rich_rust (markup, table, panel)."
    - "rich.markup.escape('[bold]hello[/bold]') == '\\[bold]hello\\[/bold]'."
    - "rich.markup.escape('hello') == 'hello' — no markup, unchanged."
    - "Expose markup_escape(s) -> str: rich.markup.escape(s)."
    - "Expose markup_render_len(s) -> int: len of rendered string (without markup)."
    - "Expose strip_markup(s) -> str: rich.markup.strip(s) — text without markup."
    - "rich.markup.strip('[bold]hello[/bold]') == 'hello'."
    - "rich.markup.strip('no markup') == 'no markup'."
    - "All test vectors verified against rich 14.0.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# markup_escape — escape Rich markup
table rich_extra_rust.markup.escape:
  kind: python_call_eq
  category: escape
  id_prefix: re_esc
  function: markup_escape

  columns: [id, args, expected]
  rows:
    - [no_markup, ["hello"],             "hello"]
    - [plain,     ["hello world"],       "hello world"]
    - [brackets,  ["[not markup]"],      "\\[not markup]"]

# strip_markup — remove markup tags
table rich_extra_rust.markup.strip:
  kind: python_call_eq
  category: strip
  id_prefix: re_strip
  function: strip_markup

  columns: [id, args, expected]
  rows:
    - [bold,    ["[bold]hello[/bold]"], "hello"]
    - [no_tag,  ["no markup"],         "no markup"]
    - [nested,  ["[red]hi[/red]"],     "hi"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
