spec: theseus_urllib_robotparser_cr
version: ">=3.8"
backend: python_cleanroom(theseus_urllib_robotparser_cr)
blocks: urllib.robotparser

docs: https://docs.python.org/3/library/urllib.robotparser.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/urllib.robotparser.html"
  not_derived_from:
    - "CPython source: Lib/urllib/robotparser.py"
  notes:
    - "Clean-room urllib.robotparser module. Do NOT import urllib.robotparser."
    - "RobotFileParser parses robots.txt files."

error_model: python_exceptions

invariant theseus_urllib_robotparser_cr.robotparser2_allow:
  description: "can_fetch returns True for allowed path"
  category: behavior
  kind: python_call_eq
  function: robotparser2_allow
  args: []
  expected: true

invariant theseus_urllib_robotparser_cr.robotparser2_disallow:
  description: "can_fetch returns False for disallowed path"
  category: behavior
  kind: python_call_eq
  function: robotparser2_disallow
  args: []
  expected: true

invariant theseus_urllib_robotparser_cr.robotparser2_wildcard:
  description: "wildcard user-agent applies to all agents"
  category: behavior
  kind: python_call_eq
  function: robotparser2_wildcard
  args: []
  expected: true
