spec: uuid_extra1921
version: ">=3.9"
backend: python_module(uuid)

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 575 (_extra1921): __slots__ inheritance checks, __abstractmethods__ set membership, __subclasshook__ dict presence, __init_subclass__ dict presence."
    - "uuid.UUID is a Python class that defines __slots__ = ('int', 'is_safe', '__weakref__'); uuid.UUID.__dict__.__contains__('__slots__') == True."
    - "uuid.SafeUUID is an IntEnum subclass (bases: Enum); it does not define __slots__ in its own __dict__."
    - "Neither uuid.UUID nor uuid.SafeUUID define __abstractmethods__, __subclasshook__, or __init_subclass__ in their own __dict__."
    - "uuid.UUID.__dict__ contains __weakref__ (from __slots__) but not __dict__ (slots prevent instance __dict__)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table uuid_extra1921.slots_protocol:
  description: "uuid types __slots__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1921

  columns: [id, function, args, expected]
  rows:
    - ["uu1921001", "uuid.UUID.__dict__.__contains__", ["__slots__"], true]
    - ["uu1921002", "uuid.SafeUUID.__dict__.__contains__", ["__slots__"], false]
    - ["uu1921003", "uuid.UUID.__dict__.__contains__", ["__weakref__"], true]
    - ["uu1921004", "uuid.UUID.__dict__.__contains__", ["__dict__"], false]
    - ["uu1921005", "uuid.SafeUUID.__dict__.__contains__", ["__weakref__"], false]
    - ["uu1921006", "uuid.SafeUUID.__dict__.__contains__", ["__dict__"], false]
    - ["uu1921007", "uuid.UUID.__dict__.__contains__", ["__class_getitem__"], false]
    - ["uu1921008", "uuid.SafeUUID.__dict__.__contains__", ["__class_getitem__"], false]

