    - ["uu1921013", "uuid.UUID.__dict__.__contains__", ["__isabstractmethod__"], false]
    - ["uu1921014", "uuid.SafeUUID.__dict__.__contains__", ["__isabstractmethod__"], false]
    - ["uu1921015", "uuid.UUID.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["uu1921016", "uuid.SafeUUID.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["uu1921017", "uuid.UUID.__dict__.__contains__", ["__mro_entries__"], false]
    - ["uu1921018", "uuid.SafeUUID.__dict__.__contains__", ["__mro_entries__"], false]

