spec: asyncio_extra84
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/taskgroups.py"
    - "CPython source: Lib/asyncio/timeouts.py"
  notes:
    - "This spec extends asyncio_extra83.zspec.zsdl."
    - "This spec covers: wave 246 theme — asyncio TaskGroup class identity and timeout/timeout_at function identity. NEW in extra84: TaskGroup.__name__=='TaskGroup'; TaskGroup.__module__=='asyncio.taskgroups'; TaskGroup.__bases__[0].__name__=='object'; TaskGroup.__mro__.__len__()==2; TaskGroup.__qualname__=='TaskGroup'; asyncio.timeout.__class__.__name__=='function'; asyncio.timeout.__module__=='asyncio.timeouts'; asyncio.timeout_at.__class__.__name__=='function'; asyncio.timeout_at.__module__=='asyncio.timeouts'; asyncio.wait.__code__.co_name=='wait'; asyncio.wait.__code__.co_argcount==1; asyncio.wait_for.__code__.co_name=='wait_for'; asyncio.wait_for.__code__.co_argcount==2; asyncio.all_tasks.__class__.__name__=='builtin_function_or_method'; asyncio.current_task.__class__.__name__=='builtin_function_or_method'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TaskGroup.__name__ == 'TaskGroup'. TaskGroup is a top-level class in asyncio.taskgroups. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TaskGroup.__module__ == 'asyncio.taskgroups'. TaskGroup is defined in the asyncio.taskgroups submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TaskGroup.__bases__[0].__name__ == 'object'. TaskGroup directly subclasses object (no intermediate base). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TaskGroup.__mro__.__len__() == 2. MRO is [TaskGroup, object], length 2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TaskGroup.__qualname__ == 'TaskGroup'. Simple unqualified class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.timeout.__class__.__name__ == 'function'. asyncio.timeout is a regular Python function (not a class), it returns an asyncio.Timeout context manager. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.timeout.__module__ == 'asyncio.timeouts'. timeout is defined in the asyncio.timeouts submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.timeout_at.__class__.__name__ == 'function'. asyncio.timeout_at is a regular Python function, like timeout. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.timeout_at.__module__ == 'asyncio.timeouts'. timeout_at is defined in the asyncio.timeouts submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.wait.__code__.co_name == 'wait'. co_name is the function name as a string. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.wait.__code__.co_argcount == 1. wait takes one positional arg (fs); timeout and return_when are keyword-only (co_kwonlyargcount==2). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.wait_for.__code__.co_name == 'wait_for'. co_name is the function name as a string. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.wait_for.__code__.co_argcount == 2. wait_for takes two positional args (fut, timeout). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.all_tasks.__class__.__name__ == 'builtin_function_or_method'. all_tasks is a C-level builtin from _asyncio, not a Python function. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.current_task.__class__.__name__ == 'builtin_function_or_method'. current_task is a C-level builtin from _asyncio, not a Python function. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio TaskGroup class identity — extra84
#
# Wave 246 theme: asyncio TaskGroup class identity and timeout/timeout_at function identity.
#
# TaskGroup.__name__ == 'TaskGroup'
# TaskGroup.__module__ == 'asyncio.taskgroups'
# TaskGroup.__bases__[0].__name__ == 'object'
# TaskGroup.__mro__.__len__() == 2
# TaskGroup.__qualname__ == 'TaskGroup'
# ---------------------------------------------------------------------------

table asyncio_extra84.TaskGroup_identity:
  description: "asyncio TaskGroup class identity checks in asyncioextra84 namespace — wave 246 theme: asyncio TaskGroup class identity and timeout/timeout_at function identity; TaskGroup.__name__=='TaskGroup'; TaskGroup.__module__=='asyncio.taskgroups'; TaskGroup.__bases__[0].__name__=='object' (TaskGroup directly subclasses object); TaskGroup.__mro__.__len__()==2 (MRO is [TaskGroup, object]); TaskGroup.__qualname__=='TaskGroup'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra84

  columns: [id, function, args, expected, description]
  rows:
    - [tg_name,         TaskGroup.__name__.__eq__,                   ["TaskGroup"],           true, "TaskGroup.__name__ == 'TaskGroup' — top-level class name; verified with Python 3.14.3"]
    - [tg_module,       TaskGroup.__module__.__eq__,                  ["asyncio.taskgroups"],  true, "TaskGroup.__module__ == 'asyncio.taskgroups' — defined in asyncio.taskgroups submodule; verified with Python 3.14.3"]
    - [tg_base_name,    "TaskGroup.__bases__[0].__name__.__eq__",     ["object"],              true, "TaskGroup.__bases__[0].__name__ == 'object' — TaskGroup directly subclasses object; verified with Python 3.14.3"]
    - [tg_mro_len,      "TaskGroup.__mro__.__len__",                  [],                      2,    "TaskGroup.__mro__.__len__() == 2 — MRO is [TaskGroup, object]; verified with Python 3.14.3"]
    - [tg_qualname,     TaskGroup.__qualname__.__eq__,                ["TaskGroup"],           true, "TaskGroup.__qualname__ == 'TaskGroup' — simple unqualified class name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio timeout/timeout_at function identity — extra84
#
# asyncio.timeout.__class__.__name__ == 'function'
# asyncio.timeout.__module__ == 'asyncio.timeouts'
# asyncio.timeout_at.__class__.__name__ == 'function'
# asyncio.timeout_at.__module__ == 'asyncio.timeouts'
# ---------------------------------------------------------------------------

table asyncio_extra84.timeout_and_timeout_at_identity:
  description: "asyncio timeout and timeout_at function identity checks in asyncioextra84 namespace — wave 246 theme: asyncio TaskGroup class identity and timeout/timeout_at function identity; asyncio.timeout.__class__.__name__=='function' (timeout is a regular Python function not a class); asyncio.timeout.__module__=='asyncio.timeouts'; asyncio.timeout_at.__class__.__name__=='function'; asyncio.timeout_at.__module__=='asyncio.timeouts'; both functions are defined in asyncio.timeouts submodule; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra84a

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_class,    timeout.__class__.__name__.__eq__,    ["function"],         true, "asyncio.timeout.__class__.__name__ == 'function' — timeout is a regular Python function; verified with Python 3.14.3"]
    - [timeout_module,   timeout.__module__.__eq__,            ["asyncio.timeouts"], true, "asyncio.timeout.__module__ == 'asyncio.timeouts' — defined in asyncio.timeouts submodule; verified with Python 3.14.3"]
    - [timeout_at_class, timeout_at.__class__.__name__.__eq__, ["function"],         true, "asyncio.timeout_at.__class__.__name__ == 'function' — timeout_at is a regular Python function; verified with Python 3.14.3"]
    - [timeout_at_mod,   timeout_at.__module__.__eq__,         ["asyncio.timeouts"], true, "asyncio.timeout_at.__module__ == 'asyncio.timeouts' — defined in asyncio.timeouts submodule; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio wait/wait_for code object checks — extra84
#
# asyncio.wait.__code__.co_name == 'wait'
# asyncio.wait.__code__.co_argcount == 1
# asyncio.wait_for.__code__.co_name == 'wait_for'
# asyncio.wait_for.__code__.co_argcount == 2
# ---------------------------------------------------------------------------

table asyncio_extra84.wait_and_wait_for_code:
  description: "asyncio wait and wait_for __code__ attribute checks in asyncioextra84 namespace — wave 246 theme: asyncio TaskGroup class identity and timeout/timeout_at function identity; asyncio.wait.__code__.co_name=='wait'; asyncio.wait.__code__.co_argcount==1 (fs is positional; timeout and return_when are keyword-only); asyncio.wait_for.__code__.co_name=='wait_for'; asyncio.wait_for.__code__.co_argcount==2 (fut and timeout are positional); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra84b

  columns: [id, function, args, expected, description]
  rows:
    - [wait_co_name,     wait.__code__.co_name.__eq__,     ["wait"],     true, "asyncio.wait.__code__.co_name == 'wait' — code object function name; verified with Python 3.14.3"]
    - [wait_co_argcount, "wait.__code__.co_argcount.__eq__", [1],        true, "asyncio.wait.__code__.co_argcount == 1 — fs is positional; timeout/return_when are keyword-only; verified with Python 3.14.3"]
    - [wf_co_name,       wait_for.__code__.co_name.__eq__, ["wait_for"], true, "asyncio.wait_for.__code__.co_name == 'wait_for' — code object function name; verified with Python 3.14.3"]
    - [wf_co_argcount,   "wait_for.__code__.co_argcount.__eq__", [2],    true, "asyncio.wait_for.__code__.co_argcount == 2 — fut and timeout are positional args; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio all_tasks/current_task class name checks — extra84
#
# asyncio.all_tasks.__class__.__name__ == 'builtin_function_or_method'
# asyncio.current_task.__class__.__name__ == 'builtin_function_or_method'
# ---------------------------------------------------------------------------

table asyncio_extra84.builtin_task_functions:
  description: "asyncio all_tasks and current_task class name checks in asyncioextra84 namespace — wave 246 theme: asyncio TaskGroup class identity and timeout/timeout_at function identity; asyncio.all_tasks.__class__.__name__=='builtin_function_or_method' (all_tasks is a C-level builtin from _asyncio); asyncio.current_task.__class__.__name__=='builtin_function_or_method' (current_task is a C-level builtin from _asyncio); TaskGroup.__module__=='asyncio.taskgroups' (cross-check); timeout.__module__=='asyncio.timeouts' (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra84c

  columns: [id, function, args, expected, description]
  rows:
    - [all_tasks_class,    all_tasks.__class__.__name__.__eq__,    ["builtin_function_or_method"], true, "asyncio.all_tasks.__class__.__name__ == 'builtin_function_or_method' — all_tasks is a C-level builtin from _asyncio; verified with Python 3.14.3"]
    - [current_task_class, current_task.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "asyncio.current_task.__class__.__name__ == 'builtin_function_or_method' — current_task is a C-level builtin from _asyncio; verified with Python 3.14.3"]
    - [tg_module_cross,    TaskGroup.__module__.__eq__,            ["asyncio.taskgroups"],         true, "TaskGroup.__module__ == 'asyncio.taskgroups' — cross-check; verified with Python 3.14.3"]
    - [timeout_mod_cross,  timeout.__module__.__eq__,              ["asyncio.timeouts"],           true, "asyncio.timeout.__module__ == 'asyncio.timeouts' — cross-check; verified with Python 3.14.3"]
    - [wait_name_cross,    wait.__code__.co_name.__eq__,           ["wait"],                       true, "asyncio.wait.__code__.co_name == 'wait' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra84
# ---------------------------------------------------------------------------

invariant asyncio_extra84.TaskGroup_name:
  description: "asyncio.TaskGroup.__name__.__eq__('TaskGroup') returns True — TaskGroup is a top-level class defined in asyncio.taskgroups; NEW in extra84: first standalone __name__ invariant for TaskGroup in asyncioextra84 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: TaskGroup.__name__.__eq__
  args: ["TaskGroup"]
  expected: true

invariant asyncio_extra84.TaskGroup_module:
  description: "asyncio.TaskGroup.__module__.__eq__('asyncio.taskgroups') returns True — TaskGroup is defined in the asyncio.taskgroups submodule; NEW in extra84: first standalone __module__ invariant for TaskGroup in asyncioextra84 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: TaskGroup.__module__.__eq__
  args: ["asyncio.taskgroups"]
  expected: true

invariant asyncio_extra84.TaskGroup_mro_len:
  description: "asyncio.TaskGroup.__mro__.__len__() == 2 — MRO is [TaskGroup, object], so length is 2; TaskGroup directly subclasses object with no intermediate bases; NEW in extra84: first standalone __mro__.__len__ invariant for TaskGroup in asyncioextra84 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: TaskGroup.__mro__.__len__
  args: []
  expected: 2

invariant asyncio_extra84.timeout_class_name:
  description: "asyncio.timeout.__class__.__name__.__eq__('function') returns True — asyncio.timeout is a regular Python function that returns an asyncio.Timeout context manager, not a class; NEW in extra84: first standalone __class__.__name__ invariant for asyncio.timeout in asyncioextra84 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: timeout.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant asyncio_extra84.wait_for_co_argcount:
  description: "asyncio.wait_for.__code__.co_argcount == 2 — wait_for takes two positional arguments: fut (the awaitable) and timeout; NEW in extra84: first standalone co_argcount invariant for wait_for in asyncioextra84 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: wait_for.__code__.co_argcount.__eq__
  args: [2]
  expected: true
