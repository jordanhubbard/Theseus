spec: socket_extra370
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "socket.gethostbyname.__name__ == 'gethostbyname'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__name__ == 'getaddrinfo'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getnameinfo.__name__ == 'getnameinfo'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getnameinfo.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__name__ == 'setdefaulttimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getdefaulttimeout.__name__ == 'getdefaulttimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getdefaulttimeout.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__name__ == 'create_connection'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: gethostbyname, getnameinfo, setdefaulttimeout, getdefaulttimeout are C builtins in _socket (Modules/socketmodule.c); __module__ is '_socket'."
    - "Note: getaddrinfo and create_connection are Python-level functions defined in Lib/socket.py; __module__ is 'socket'."
    - "Note: getaddrinfo is implemented in Python (Lib/socket.py) as a wrapper around the C-level getaddrinfo; it adds filtering logic and thus lives at the Python level with __module__=='socket'."
    - "Note: create_connection is a high-level Python helper in Lib/socket.py that creates a connected socket with optional timeout and source address; __module__=='socket'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.gethostbyname.__name__ / socket.gethostbyname.__module__
# socket.getaddrinfo.__name__ / socket.getaddrinfo.__module__
# socket.getnameinfo.__name__ / socket.getnameinfo.__module__
# socket.setdefaulttimeout.__name__ / socket.setdefaulttimeout.__module__
# socket.getdefaulttimeout.__name__ / socket.getdefaulttimeout.__module__
# socket.create_connection.__name__ / socket.create_connection.__module__
#
# Wave 370 theme: socket module function identity.
#
# The socket module is a hybrid of C builtins and Python-level wrappers.
# C builtins in _socket (Modules/socketmodule.c) include: gethostbyname,
# getnameinfo, setdefaulttimeout, getdefaulttimeout. These have __module__
# == '_socket'.
#
# Python-level functions in Lib/socket.py include: getaddrinfo and
# create_connection. These have __module__ == 'socket'. getaddrinfo wraps
# the C-level getaddrinfo and adds filtering; create_connection is a
# high-level helper for making TCP connections with optional timeout and
# source address binding.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra370.function_dunder_name:
  description: "socket function __name__ identity — gethostbyname/getnameinfo/setdefaulttimeout/getdefaulttimeout are C builtins in _socket; getaddrinfo/create_connection are Python-level in Lib/socket.py; all __name__ values match the public function name; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: socketfnid370

  columns: [id, function, args, expected]
  rows:
    - [gethostbyname_name,    gethostbyname.__name__.__eq__,    ["gethostbyname"],    true]
    - [getaddrinfo_name,      getaddrinfo.__name__.__eq__,      ["getaddrinfo"],      true]
    - [getnameinfo_name,      getnameinfo.__name__.__eq__,      ["getnameinfo"],      true]
    - [setdefaulttimeout_name, setdefaulttimeout.__name__.__eq__, ["setdefaulttimeout"], true]
    - [getdefaulttimeout_name, getdefaulttimeout.__name__.__eq__, ["getdefaulttimeout"], true]
    - [create_connection_name, create_connection.__name__.__eq__, ["create_connection"], true]

table socket_extra370.function_dunder_module:
  description: "socket function __module__ identity — gethostbyname/getnameinfo/setdefaulttimeout/getdefaulttimeout report __module__=='_socket' (C builtins); getaddrinfo/create_connection report __module__=='socket' (Python-level in Lib/socket.py); verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: socketfnid370

  columns: [id, function, args, expected]
  rows:
    - [gethostbyname_module,    gethostbyname.__module__.__eq__,    ["_socket"], true]
    - [getaddrinfo_module,      getaddrinfo.__module__.__eq__,      ["socket"],  true]
    - [getnameinfo_module,      getnameinfo.__module__.__eq__,      ["_socket"], true]
    - [setdefaulttimeout_module, setdefaulttimeout.__module__.__eq__, ["_socket"], true]
    - [getdefaulttimeout_module, getdefaulttimeout.__module__.__eq__, ["_socket"], true]
    - [create_connection_module, create_connection.__module__.__eq__, ["socket"],  true]

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__module__ == 'socket' — standalone
#
# socket.getaddrinfo is a Python-level function defined in Lib/socket.py.
# It translates a host/port pair into a sequence of 5-tuples suitable for
# creating a socket connection. It wraps the lower-level C-level getaddrinfo
# but adds Python-level filtering and type checking. Because it is defined
# in Python, its __module__ is 'socket' (not '_socket'). It accepts host,
# port, family, type, proto, and flags arguments. Verified Python 3.14.3
# macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra370.getaddrinfo_module:
  description: "socket.getaddrinfo.__module__.__eq__('socket') == True — getaddrinfo is a Python-level wrapper in Lib/socket.py; translates host/port to 5-tuples for socket creation; __module__ is 'socket' (not '_socket'); verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: getaddrinfo.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_connection.__module__ == 'socket' — standalone
#
# socket.create_connection is a high-level convenience function defined in
# Lib/socket.py. It creates a TCP socket and connects it to a given
# (host, port) address, with optional timeout and source address. It handles
# address resolution via getaddrinfo and tries each result in sequence.
# It was added in Python 2.6. Its __module__ is 'socket' since it is a
# pure-Python function in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin
# 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra370.create_connection_module:
  description: "socket.create_connection.__module__.__eq__('socket') == True — create_connection is a pure-Python helper in Lib/socket.py; creates a connected TCP socket with optional timeout and source address; added Python 2.6; __module__ is 'socket'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: create_connection.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gethostbyname.__module__ == '_socket' — standalone
#
# socket.gethostbyname is a C builtin defined in Modules/socketmodule.c.
# It translates a host name (e.g., 'localhost') to an IPv4 address string
# (e.g., '127.0.0.1'). It is a thin wrapper around the POSIX gethostbyname(3)
# call and is deprecated in favor of getaddrinfo for new code (gethostbyname
# does not support IPv6). Its __module__ is '_socket'. Verified Python 3.14.3
# macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra370.gethostbyname_module:
  description: "socket.gethostbyname.__module__.__eq__('_socket') == True — gethostbyname is a C builtin in Modules/socketmodule.c; wraps POSIX gethostbyname(3); IPv4 only; deprecated in favor of getaddrinfo; __module__ is '_socket'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: gethostbyname.__module__.__eq__
  args: ["_socket"]
  expected: true
