spec: uuid_extra1966
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
    - "CPython source: Lib/uuid.py"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 1966 (_extra1966): __enter__/__exit__, __aenter__/__aexit__, __del__ dict-presence checks."
    - "uuid.UUID does not define __enter__ or __exit__ (not a context manager)."
    - "uuid.SafeUUID is an IntEnum subclass and does not define context manager protocol."
    - "Neither uuid.UUID nor uuid.SafeUUID define __del__, __aenter__, or __aexit__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra1966.uuid_context_manager_protocol:
  description: "uuid.UUID __enter__/__exit__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1966

  columns: [id, function, args, expected]
  rows:
    - ["uu1966001", "uuid.UUID.__dict__.__contains__", ["__enter__"], false]
    - ["uu1966002", "uuid.UUID.__dict__.__contains__", ["__exit__"], false]
    - ["uu1966003", "uuid.UUID.__dict__.__contains__", ["__aenter__"], false]
    - ["uu1966004", "uuid.UUID.__dict__.__contains__", ["__aexit__"], false]
    - ["uu1966005", "uuid.UUID.__dict__.__contains__", ["__del__"], false]

table uuid_extra1966.safeuuid_context_manager_protocol:
  description: "uuid.SafeUUID __enter__/__exit__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1966

  columns: [id, function, args, expected]
  rows:
    - ["uu1966006", "uuid.SafeUUID.__dict__.__contains__", ["__enter__"], false]
    - ["uu1966007", "uuid.SafeUUID.__dict__.__contains__", ["__exit__"], false]
    - ["uu1966008", "uuid.SafeUUID.__dict__.__contains__", ["__aenter__"], false]
    - ["uu1966009", "uuid.SafeUUID.__dict__.__contains__", ["__aexit__"], false]
    - ["uu1966010", "uuid.SafeUUID.__dict__.__contains__", ["__del__"], false]

table uuid_extra1966.uuid_async_context_manager_protocol:
  description: "uuid.UUID async context manager protocol absence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1966

  columns: [id, function, args, expected]
  rows:
    - ["uu1966011", "uuid.UUID.__dict__.__contains__", ["__aenter__"], false]
    - ["uu1966012", "uuid.UUID.__dict__.__contains__", ["__aexit__"], false]
    - ["uu1966013", "uuid.SafeUUID.__dict__.__contains__", ["__aenter__"], false]
    - ["uu1966014", "uuid.SafeUUID.__dict__.__contains__", ["__aexit__"], false]

table uuid_extra1966.uuid_finalizer_checks:
  description: "uuid types __del__ finalizer absence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1966

  columns: [id, function, args, expected]
  rows:
    - ["uu1966015", "uuid.UUID.__dict__.__contains__", ["__del__"], false]
    - ["uu1966016", "uuid.SafeUUID.__dict__.__contains__", ["__del__"], false]

table uuid_extra1966.uuid_negative_protocol_matrix:
  description: "uuid.UUID and uuid.SafeUUID full negative protocol matrix"
