spec: functools_extra2296
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 600 (_extra2296): __module__ and __qualname__ attribute value checks."
    - "Subjects: functools.partial, functools.partialmethod, functools._lru_cache_wrapper, functools.cached_property, functools.singledispatchmethod, functools.reduce, functools.lru_cache."
    - "functools.reduce is implemented in _functools (C extension); __module__ == '_functools', __qualname__ == 'reduce'."
    - "All other subjects are pure Python; __module__ == 'functools'."
    - "functools.partial.__qualname__ == 'partial' (top-level class)."
    - "functools.partialmethod.__qualname__ == 'partialmethod' (top-level class)."
    - "functools._lru_cache_wrapper.__qualname__ == '_lru_cache_wrapper' (top-level class)."
    - "functools.cached_property.__qualname__ == 'cached_property' (top-level class)."
    - "functools.singledispatchmethod.__qualname__ == 'singledispatchmethod' (top-level class)."
    - "functools.lru_cache.__qualname__ == 'lru_cache' (top-level class)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

