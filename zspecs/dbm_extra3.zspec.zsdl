spec: dbm_extra3
version: ">=3.9"
backend: python_module(dbm)

docs: https://docs.python.org/3/library/dbm.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dbm.html — Python dbm module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dbm/__init__.py"
  notes:
    - "This spec extends dbm.zspec.zsdl, dbm_extra.zspec.zsdl, and dbm_extra2.zspec.zsdl."
    - "dbm.zspec.zsdl covers: open/__name__, whichdb/__name__, whichdb nonexistent returns None, error is tuple."
    - "dbm_extra.zspec.zsdl covers: open/__name__; whichdb/__name__/__module__/is_function; error/__name__/__module__/is_type/base_is_OSError/bases_len; dumb/__name__/open_name/error_name."
    - "dbm_extra2.zspec.zsdl covers: dbm.__name__; dbm.__package__; open class is not None; dumb.open/__module__; dumb._Database/__name__/__module__; ndbm/__name__; attr_names table."
    - "This spec adds: __qualname__ for open, whichdb, and error — not covered in any prior dbm spec."
    - "This spec also adds: dbm._names.__class__.__name__ == 'list' — _names holds the list of available backend module names."
    - "dbm.open is a C builtin or Python function depending on build; for C builtins __qualname__ == __name__."
    - "dbm.whichdb is a Python function; __qualname__ == __name__ for module-level functions."
    - "dbm.error is an exception class; as a top-level class __qualname__ == __name__ == 'error'."
    - "dbm._names is the list of backend module name strings (e.g. ['dbm.sqlite3', 'dbm.gnu', 'dbm.ndbm', 'dbm.dumb'])."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for module-level callables and exception class
# None of the prior dbm specs check __qualname__ for any symbol.
# ---------------------------------------------------------------------------

table dbm_extra3.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [open,    open.__qualname__.__eq__,    ["open"],    true]
    - [whichdb, whichdb.__qualname__.__eq__,  ["whichdb"], true]
    - [error,   error.__qualname__.__eq__,    ["error"],   true]

# ---------------------------------------------------------------------------
# dbm._names — list of available backends
# _names is a plain list object; __class__.__name__ == 'list'.
# Not covered in any prior dbm spec.
# ---------------------------------------------------------------------------

invariant dbm_extra3._names.class_is_list:
  description: "dbm._names.__class__.__name__ == 'list' — _names is a list of backend module names"
  category: module_attrs
  kind: python_call_eq
  function: _names.__class__.__name__.__eq__
  args: ["list"]
  expected: true
