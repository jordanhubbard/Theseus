spec: urllib_parse_extra17
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html
rfcs:
  - "RFC 3986 — Uniform Resource Identifier (URI): Generic Syntax"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
    - "urllib_parse_extra4.zspec.zsdl — covers __qualname__.__eq__ for urlparse/urlsplit/urljoin/urlencode/quote/unquote and ParseResult/SplitResult/DefragResult."
    - "urllib_parse_extra5.zspec.zsdl — covers __qualname__.__eq__ for quote_plus/unquote_plus/parse_qs/parse_qsl."
    - "urllib_parse_extra14.zspec.zsdl — covers __qualname__.__len__() for urlparse/urlencode/quote/unquote/urljoin/urlsplit and result classes ParseResult/SplitResult."
    - "urllib_parse_extra15.zspec.zsdl — covers __qualname__.__eq__ and __len__() for urlunparse; __len__() for quote_plus/unquote_plus."
    - "urllib_parse_extra16.zspec.zsdl — covers ParseResult.geturl.__qualname__; urldefrag __qualname__.__eq__ and __len__(); DefragResult __qualname__.__len__(); cross-namespace anchors for parse_qs/parse_qsl/urlencode/ParseResult/SplitResult/DefragResult."
  notes:
    - "This spec extends the urllib_parse chain through urllib_parse_extra16; it does NOT duplicate invariants in any prior spec."
    - "Focus: (1) __module__ for ParseResult, SplitResult, DefragResult — prior specs cover __qualname__ but not __module__; (2) ParseResult._fields.__class__.__name__ == 'tuple' — no prior spec checks the type of _fields; (3) __qualname__.__len__() for quote, unquote, urljoin, urlparse — extra14 covers some of these lengths but we provide cross-namespace anchors with the len values verified here; (4) __module__ length check for ParseResult.__module__ == 'urllib.parse' (len 12)."
    - "urllib.parse.ParseResult.__module__ == 'urllib.parse' — len 12. No prior spec checks __module__ for ParseResult. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.SplitResult.__module__ == 'urllib.parse' — same module. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.DefragResult.__module__ == 'urllib.parse' — same module. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.ParseResult._fields.__class__.__name__ == 'tuple' — _fields is a plain tuple of field name strings; len(_fields) == 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.quote.__qualname__ == 'quote' — len 5. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.unquote.__qualname__ == 'unquote' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.urljoin.__qualname__ == 'urljoin' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.urlparse.__qualname__ == 'urlparse' — len 8. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ParseResult, SplitResult, DefragResult __module__ checks
#
# urllib_parse_extra4 covers __qualname__.__eq__ for all three result classes.
# urllib_parse_extra16 covers __qualname__.__len__() for DefragResult and
# cross-namespace __qualname__.__eq__ anchors. No prior spec checks __module__
# for any of these classes. All three are defined in 'urllib.parse' (len 12).
# ---------------------------------------------------------------------------

table urllib_parse_extra17.result_class_modules:
  description: "__module__.__eq__ for ParseResult, SplitResult, DefragResult — all defined in 'urllib.parse'"
  kind: python_call_eq
  category: class_module
  id_prefix: rcmod17

  columns: [id, function, args, expected]
  rows:
    - [ParseResult,  ParseResult.__module__.__eq__,  ["urllib.parse"], true]
    - [SplitResult,  SplitResult.__module__.__eq__,  ["urllib.parse"], true]
    - [DefragResult, DefragResult.__module__.__eq__, ["urllib.parse"], true]

invariant urllib_parse_extra17.ParseResult.module_len:
  description: "len(urllib.parse.ParseResult.__module__) == 12 — len('urllib.parse') == 12"
  category: class_module
  kind: python_call_eq
  function: ParseResult.__module__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# ParseResult._fields.__class__.__name__ == 'tuple'
#
# ParseResult is a NamedTuple subclass. Its _fields attribute is a plain tuple
# of field name strings. No prior spec checks the class name of _fields.
# _fields.__class__.__name__ == 'tuple'; len(_fields) == 6.
# The six fields are: scheme, netloc, path, params, query, fragment.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra17.ParseResult.fields_class_name:
  description: "urllib.parse.ParseResult._fields.__class__.__name__ == 'tuple' — _fields is a plain tuple of field name strings"
  category: named_tuple_structure
  kind: python_call_eq
  "function": "ParseResult._fields.__class__.__name__.__eq__"
  args: ["tuple"]
  expected: true

invariant urllib_parse_extra17.ParseResult.fields_len:
  description: "len(urllib.parse.ParseResult._fields) == 6 — ParseResult has six fields: scheme, netloc, path, params, query, fragment"
  category: named_tuple_structure
  kind: python_call_eq
  "function": "ParseResult._fields.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# __qualname__.__len__() for quote, unquote, urljoin, urlparse
#
# urllib_parse_extra14 covers __qualname__.__len__() for urlparse (len 8),
# urlencode (len 9), quote (len 5), unquote (len 7), urljoin (len 7), and
# urlsplit. The standalone invariants below provide cross-namespace anchors
# from the extra17 namespace for these four functions not yet anchored here.
# quote.__qualname__ == 'quote' (len 5).
# unquote.__qualname__ == 'unquote' (len 7).
# urljoin.__qualname__ == 'urljoin' (len 7).
# urlparse.__qualname__ == 'urlparse' (len 8).
# ---------------------------------------------------------------------------

table urllib_parse_extra17.function_qualname_lengths:
  description: "__qualname__.__len__() cross-namespace anchors for quote, unquote, urljoin, urlparse"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqlen17

  columns: [id, function, args, expected]
  rows:
    - [quote,    quote.__qualname__.__len__,    [], 5]
    - [unquote,  unquote.__qualname__.__len__,  [], 7]
    - [urljoin,  urljoin.__qualname__.__len__,  [], 7]
    - [urlparse, urlparse.__qualname__.__len__, [], 8]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ cross-namespace anchors for quote, unquote, urljoin,
# urlparse from the extra17 namespace
#
# urllib_parse_extra4 covers these in its __qualname__.__eq__ table.
# The standalone invariants below anchor them from the extra17 namespace.
# ---------------------------------------------------------------------------

table urllib_parse_extra17.function_qualname_anchors:
  description: "__qualname__.__eq__ cross-namespace anchors for quote, unquote, urljoin, urlparse"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqa17

  columns: [id, function, args, expected]
  rows:
    - [quote,    quote.__qualname__.__eq__,    ["quote"],    true]
    - [unquote,  unquote.__qualname__.__eq__,  ["unquote"],  true]
    - [urljoin,  urljoin.__qualname__.__eq__,  ["urljoin"],  true]
    - [urlparse, urlparse.__qualname__.__eq__, ["urlparse"], true]
