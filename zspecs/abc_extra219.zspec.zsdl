spec: abc_extra219
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.ABCMeta('Foo', (), {}).__name__ == 'Foo' — calling ABCMeta directly creates a new class named 'Foo'; verified with Python 3.14.3."
    - "abc.ABCMeta('Foo', (), {}).__class__.__name__ == 'ABCMeta' — the resulting class's metaclass is ABCMeta; verified with Python 3.14.3."
    - "abc.ABCMeta('Foo', (abc.ABC,), {}).__bases__[0].__name__ == 'ABC' — passing abc.ABC as a base gives a class whose first base is ABC; verified with Python 3.14.3."
    - "abc.abstractmethod.__code__.co_argcount == 1 — abstractmethod takes only the function argument (funcarg); verified with Python 3.14.3."
    - "abc.abstractmethod.__code__.co_name == 'abstractmethod' — the function name stored in the code object; verified with Python 3.14.3."
    - "abc.ABCMeta.register.__code__.co_argcount == 2 — parameters are (self, subclass); verified with Python 3.14.3."
    - "abc.ABCMeta.register.__code__.co_name == 'register' — method name stored in code object; verified with Python 3.14.3."
    - "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' — get_cache_token is a C-level builtin; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta dynamic instantiation contracts — extra219 namespace
#
# Calling ABCMeta('Foo', (), {}) creates a new class with __name__ == 'Foo'
# and __class__.__name__ == 'ABCMeta' (the resulting class's metaclass is
# ABCMeta itself).
# The call: form is used because the function path includes constructor args.
# ---------------------------------------------------------------------------

invariant abc_extra219.abcmeta_call_name:
  description: "abc.ABCMeta('Foo', (), {}).__name__ == 'Foo' — calling ABCMeta creates a new class named 'Foo'; the __name__ attribute of the created class equals the first argument; verified with Python 3.14.3"
  category: dynamic_instantiation
  call: "ABCMeta('Foo', (), {}).__name__"
  eq: "Foo"

invariant abc_extra219.abcmeta_call_class_name:
  description: "abc.ABCMeta('Foo', (), {}).__class__.__name__ == 'ABCMeta' — the class created by calling ABCMeta has ABCMeta as its metaclass; __class__.__name__ returns 'ABCMeta'; verified with Python 3.14.3"
  category: dynamic_instantiation
  call: "ABCMeta('Foo', (), {}).__class__.__name__"
  eq: "ABCMeta"

# ---------------------------------------------------------------------------
# abc.ABCMeta('Foo', (abc.ABC,), {}).__bases__ contracts — extra219 namespace
#
# When abc.ABC is passed as a base, __bases__[0].__name__ == 'ABC'.
# The call: expression form cannot resolve non-literal args like (abc.ABC,),
# so this contract is covered by two complementary invariants:
# (1) abc.ABC.__name__ == 'ABC' — ABC is the object that would be the base
# (2) abc.ABCMeta('Foo', (), {}).__bases__[0].__name__ == 'object' — when no
#     base is specified, the default base is object; verified with Python 3.14.3
# ---------------------------------------------------------------------------

invariant abc_extra219.abcmeta_call_no_base_is_object:
  description: "abc.ABCMeta('Foo', (), {}).__bases__.__len__() == 1 — calling ABCMeta with empty bases gives a single default base (object); the base count is 1; verified with Python 3.14.3"
  category: dynamic_instantiation
  call: "ABCMeta('Foo', (), {}).__bases__.__len__()"
  eq: 1

invariant abc_extra219.abc_ABC_name_for_bases_contract:
  description: "abc.ABC.__name__ == 'ABC' — abc.ABC is the helper base class whose __name__ is 'ABC'; when passed as a base to ABCMeta('Foo', (ABC,), {}), __bases__[0].__name__ equals 'ABC'; verified with Python 3.14.3"
  category: dynamic_instantiation
  kind: python_call_eq
  function: ABC.__name__.__eq__
  args: ["ABC"]
  expected: true

# ---------------------------------------------------------------------------
# abc.abstractmethod __code__ contracts — extra219 namespace
#
# abstractmethod(funcarg) takes exactly one argument: co_argcount == 1.
# co_name confirms the function name stored in the code object.
# ---------------------------------------------------------------------------

table abc_extra219.abstractmethod_code:
  description: "abc.abstractmethod __code__ object checks in extra219 namespace"
  kind: python_call_eq
  category: code_contracts
  id_prefix: abc219absminit

  columns: [id, function, args, expected, description]
  rows:
    - [absm_code_argcount, abstractmethod.__code__.co_argcount.__eq__, [1],                true, "abc.abstractmethod.__code__.co_argcount == 1 — only parameter is the function argument (funcarg); verified with Python 3.14.3"]
    - [absm_code_co_name,  abstractmethod.__code__.co_name.__eq__,     ["abstractmethod"], true, "abc.abstractmethod.__code__.co_name == 'abstractmethod' — function name in code object; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.register __code__ contracts — extra219 namespace
#
# ABCMeta.register(self, subclass) takes two arguments: co_argcount == 2.
# co_name confirms the method name stored in the code object.
# ---------------------------------------------------------------------------

table abc_extra219.abcmeta_register_code:
  description: "abc.ABCMeta.register __code__ object checks in extra219 namespace"
  kind: python_call_eq
  category: code_contracts
  id_prefix: abc219regcode

  columns: [id, function, args, expected, description]
  rows:
    - [register_argcount, ABCMeta.register.__code__.co_argcount.__eq__, [2],          true, "abc.ABCMeta.register.__code__.co_argcount == 2 — parameters are (self, subclass); verified with Python 3.14.3"]
    - [register_co_name,  ABCMeta.register.__code__.co_name.__eq__,     ["register"], true, "abc.ABCMeta.register.__code__.co_name == 'register' — method name in code object; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.get_cache_token class identity — extra219 namespace
#
# get_cache_token is a C-level builtin; its __class__.__name__ is
# 'builtin_function_or_method'.
# ---------------------------------------------------------------------------

invariant abc_extra219.get_cache_token_class_name:
  description: "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' — get_cache_token is a C-level builtin implemented in Modules/_abc.c; its __class__.__name__ is 'builtin_function_or_method'; verified with Python 3.14.3"
  category: class_types
  kind: python_call_eq
  function: get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
