spec: threading_extra1756
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 564 (_extra1756): arithmetic operator protocol dict-presence checks."
    - "threading.Thread: Python class inheriting from object — not a numeric type; all eight arithmetic dunders absent from __dict__."
    - "threading.Event: Python class inheriting from object — not a numeric type; all eight arithmetic dunders absent."
    - "threading.Lock: alias for _thread.lock (C extension type) — not a numeric type; all eight arithmetic dunders absent."
    - "threading.Condition: Python class wrapping a lock — not a numeric type; all eight arithmetic dunders absent."
    - "Complementary checks: threading.TIMEOUT_MAX.__class__.__name__ is 'float' (a module-level constant giving the maximum timeout value)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operator protocol dict-presence checks for threading types
#
# Wave 564 theme: which threading types define __add__, __sub__, __mul__,
# __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__.
#
# threading.Thread: represents a thread of execution; manages lifecycle
#   (start, join, run) — not a numeric type, no arithmetic operators.
# threading.Event: one-shot signalling primitive (set/clear/wait) — not
#   a numeric type, no arithmetic operators.
# threading.Lock: mutual exclusion primitive from _thread module — not
#   a numeric type, no arithmetic operators.
# threading.Condition: condition variable built on a lock (acquire/release/
#   wait/notify) — not a numeric type, no arithmetic operators.
# ---------------------------------------------------------------------------

table threading_extra1756.arithmetic_operators:
  description: "threading types arithmetic operator dict-presence checks — all False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1756

  columns: [id, function, args, expected]
  rows:
    - ["th1756001", "threading.Thread.__dict__.__contains__", ["__add__"], false]
    - ["th1756002", "threading.Thread.__dict__.__contains__", ["__sub__"], false]
    - ["th1756003", "threading.Thread.__dict__.__contains__", ["__mul__"], false]
    - ["th1756004", "threading.Thread.__dict__.__contains__", ["__truediv__"], false]
    - ["th1756005", "threading.Thread.__dict__.__contains__", ["__floordiv__"], false]
    - ["th1756006", "threading.Thread.__dict__.__contains__", ["__pow__"], false]
    - ["th1756007", "threading.Thread.__dict__.__contains__", ["__neg__"], false]
    - ["th1756008", "threading.Thread.__dict__.__contains__", ["__pos__"], false]
    - ["th1756009", "threading.Event.__dict__.__contains__", ["__add__"], false]
    - ["th1756010", "threading.Event.__dict__.__contains__", ["__sub__"], false]
    - ["th1756011", "threading.Event.__dict__.__contains__", ["__mul__"], false]
    - ["th1756012", "threading.Event.__dict__.__contains__", ["__neg__"], false]
    - ["th1756013", "threading.Condition.__dict__.__contains__", ["__add__"], false]
    - ["th1756014", "threading.Condition.__dict__.__contains__", ["__mul__"], false]
    - ["th1756015", "threading.Condition.__dict__.__contains__", ["__truediv__"], false]

# ---------------------------------------------------------------------------
# Table 2: TIMEOUT_MAX type check and extended arithmetic absence for threading
#
# Unique checks not covered in earlier waves:
# threading.TIMEOUT_MAX is a module-level float constant (sys.maxsize on most
# platforms, exposed as a float) — its __class__.__name__ is "float".
# This is a unique threading-specific check contrasting with class __dict__
# checks. Additional arithmetic absence checks cover floordiv/pow/pos for
# Event and Condition, and all eight checks for Lock (via Lock type).
# ---------------------------------------------------------------------------

table threading_extra1756.timeout_max_and_arithmetic_contrast:
  description: "threading.TIMEOUT_MAX is float; Lock/Event/Condition lack all arithmetic dunders — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1756

  columns: [id, function, args, expected]
  rows:
    - ["th1756016", "threading.TIMEOUT_MAX.__class__.__name__.__eq__", ["float"], true]
    - ["th1756017", "threading.Event.__dict__.__contains__", ["__truediv__"], false]
    - ["th1756018", "threading.Event.__dict__.__contains__", ["__floordiv__"], false]
    - ["th1756019", "threading.Event.__dict__.__contains__", ["__pow__"], false]
    - ["th1756020", "threading.Event.__dict__.__contains__", ["__pos__"], false]
    - ["th1756021", "threading.Condition.__dict__.__contains__", ["__sub__"], false]
    - ["th1756022", "threading.Condition.__dict__.__contains__", ["__floordiv__"], false]
    - ["th1756023", "threading.Condition.__dict__.__contains__", ["__pow__"], false]
    - ["th1756024", "threading.Condition.__dict__.__contains__", ["__neg__"], false]
    - ["th1756025", "threading.Condition.__dict__.__contains__", ["__pos__"], false]
