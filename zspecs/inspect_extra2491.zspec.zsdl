spec: inspect_extra2491
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: __setitem__, __delitem__, and __missing__ dict-presence checks for inspect module classes."
    - "Theme: mutable item access and missing-key protocol — checking class __dict__ membership via __contains__."
    - "inspect.Parameter, Signature, BoundArguments, FrameInfo, FullArgSpec, Attribute, ClosureVars — none define __setitem__, __delitem__, or __missing__."
    - "inspect.Parameter is a frozen-style named-tuple-like class representing a single function parameter; it is not a mapping and exposes no item-mutation protocol. Verified with Python 3.14."
    - "inspect.Signature is an immutable record of a callable's signature; it provides __getitem__-like access to parameters via the .parameters mapping attribute, but Signature itself defines no __setitem__, __delitem__, or __missing__. Verified with Python 3.14."
    - "inspect.BoundArguments holds bound argument values; it exposes .arguments (an OrderedDict), but BoundArguments itself defines no item-mutation protocol. Verified with Python 3.14."
    - "inspect.FrameInfo, FullArgSpec, Attribute, ClosureVars are lightweight named-tuple subclasses or dataclasses used to return structured introspection results; none are mappings. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter and inspect.Signature — item protocol absence
#
# Theme: __setitem__, __delitem__, __missing__ absent from class __dict__.
# Parameter represents a single parameter in a Signature; Signature holds
# an ordered mapping of parameters. Neither class is itself a mutable mapping.
# ---------------------------------------------------------------------------

table inspect_extra2491.parameter_signature_item_protocol:
  description: "__setitem__, __delitem__, __missing__ absent from inspect.Parameter and inspect.Signature __dict__; wave 2491"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: in2491

  columns: [id, function, args, expected]
  rows:
    - ["in2491-001", "Parameter.__dict__.__contains__", ["__setitem__"], false]
    - ["in2491-002", "Parameter.__dict__.__contains__", ["__delitem__"], false]
    - ["in2491-003", "Parameter.__dict__.__contains__", ["__missing__"], false]
    - ["in2491-004", "Signature.__dict__.__contains__", ["__setitem__"], false]
    - ["in2491-005", "Signature.__dict__.__contains__", ["__delitem__"], false]
    - ["in2491-006", "Signature.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# Table 2: inspect.BoundArguments — item protocol absence
#
# Theme: __setitem__, __delitem__, __missing__ absent from BoundArguments.__dict__.
# BoundArguments is the result of Signature.bind(); it stores bound values in
# .arguments (an OrderedDict) but does not itself expose item-mutation protocol.
# ---------------------------------------------------------------------------

table inspect_extra2491.bound_arguments_item_protocol:
  description: "__setitem__, __delitem__, __missing__ absent from inspect.BoundArguments __dict__; wave 2491"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: in2491

  columns: [id, function, args, expected]
  rows:
    - ["in2491-007", "BoundArguments.__dict__.__contains__", ["__setitem__"], false]
    - ["in2491-008", "BoundArguments.__dict__.__contains__", ["__delitem__"], false]
    - ["in2491-009", "BoundArguments.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# Table 3: inspect named-tuple result classes — item protocol absence
#
# Theme: __setitem__, __delitem__, __missing__ absent from FrameInfo, FullArgSpec,
# Attribute, and ClosureVars — the structured result types returned by
# inspect introspection functions.
# These are named-tuple subclasses or dataclasses; they expose indexed access
# via the tuple protocol, not the mutable mapping protocol.
# ---------------------------------------------------------------------------

table inspect_extra2491.result_types_item_protocol:
  description: "__setitem__, __delitem__, __missing__ absent from inspect.FrameInfo, FullArgSpec, Attribute, ClosureVars __dict__; wave 2491"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: in2491

  columns: [id, function, args, expected]
  rows:
    - ["in2491-010", "FrameInfo.__dict__.__contains__", ["__setitem__"], false]
    - ["in2491-011", "FrameInfo.__dict__.__contains__", ["__delitem__"], false]
    - ["in2491-012", "FrameInfo.__dict__.__contains__", ["__missing__"], false]
    - ["in2491-013", "FullArgSpec.__dict__.__contains__", ["__setitem__"], false]
    - ["in2491-014", "FullArgSpec.__dict__.__contains__", ["__delitem__"], false]
    - ["in2491-015", "FullArgSpec.__dict__.__contains__", ["__missing__"], false]
    - ["in2491-016", "Attribute.__dict__.__contains__", ["__setitem__"], false]
    - ["in2491-017", "Attribute.__dict__.__contains__", ["__delitem__"], false]
    - ["in2491-018", "Attribute.__dict__.__contains__", ["__missing__"], false]
    - ["in2491-019", "ClosureVars.__dict__.__contains__", ["__setitem__"], false]
    - ["in2491-020", "ClosureVars.__dict__.__contains__", ["__delitem__"], false]
    - ["in2491-021", "ClosureVars.__dict__.__contains__", ["__missing__"], false]
