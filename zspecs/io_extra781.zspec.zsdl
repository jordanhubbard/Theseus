spec: io_extra781
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "Python standard library documentation: io module"
    - "CPython source: Lib/io.py"
  not_derived_from:
    - "Any third-party IO library"
  notes:
    - "Covers __qualname__ identity checks for io.StringIO and io.BytesIO methods"
    - "All qualnames reflect the class-level (not module-level) naming convention"
  created_at: "2026-04-12"

table io_extra781.name:
  description: "Verifies __qualname__ strings for io.StringIO and io.BytesIO methods"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: io781xx
  columns: [id, function, args, expected]
  rows:
    - [io781xx001, io.StringIO.__init__.__qualname__.__eq__, ["StringIO.__init__"], true]
    - [io781xx002, io.StringIO.read.__qualname__.__eq__, ["StringIO.read"], true]
    - [io781xx003, io.StringIO.write.__qualname__.__eq__, ["StringIO.write"], true]
    - [io781xx004, io.StringIO.readline.__qualname__.__eq__, ["StringIO.readline"], true]
    - [io781xx005, io.StringIO.readlines.__qualname__.__eq__, ["StringIO.readlines"], true]
    - [io781xx006, io.StringIO.getvalue.__qualname__.__eq__, ["StringIO.getvalue"], true]
    - [io781xx007, io.StringIO.seek.__qualname__.__eq__, ["StringIO.seek"], true]
    - [io781xx008, io.StringIO.tell.__qualname__.__eq__, ["StringIO.tell"], true]
    - [io781xx009, io.StringIO.truncate.__qualname__.__eq__, ["StringIO.truncate"], true]
    - [io781xx010, io.StringIO.close.__qualname__.__eq__, ["StringIO.close"], true]
    - [io781xx011, io.BytesIO.getvalue.__qualname__.__eq__, ["BytesIO.getvalue"], true]
    - [io781xx012, io.BytesIO.getbuffer.__qualname__.__eq__, ["BytesIO.getbuffer"], true]
