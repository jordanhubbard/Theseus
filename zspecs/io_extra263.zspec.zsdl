spec: io_extra263
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE, SEEK_* constants, TextIOWrapper/BufferedRandom/UnsupportedOperation class identity"
  notes:
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' and __module__ == '_io' (C implementation)."
    - "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — immediate base in the C hierarchy."
    - "read/write/readline/seek/tell/flush/close are method_descriptor objects on TextIOWrapper directly."
    - "readlines and writelines are inherited from _IOBase; their __qualname__ is '_IOBase.readlines' and '_IOBase.writelines'."
    - "All method qualnames verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TextIOWrapper — class identity: name, module, base
# ---------------------------------------------------------------------------

invariant io_extra263.TextIOWrapper.class_name:
  description: "io.TextIOWrapper.__name__ == 'TextIOWrapper'"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra263.TextIOWrapper.module:
  description: "io.TextIOWrapper.__module__ == '_io'"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra263.TextIOWrapper.base_name:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase'"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_TextIOBase"

# ---------------------------------------------------------------------------
# TextIOWrapper — method qualnames: read, write, readline
# ---------------------------------------------------------------------------

table io_extra263.TextIOWrapper.method_qualnames_rw:
  description: "read/write/readline are defined directly on TextIOWrapper"
  kind: python_call_eq
  category: identity
  id_prefix: method_qualname

  columns: [id, function, args, expected, description]
  rows:
    - [read_qualname,     TextIOWrapper.read.__qualname__.__eq__,     ["TextIOWrapper.read"],     true, "read qualname"]
    - [write_qualname,    TextIOWrapper.write.__qualname__.__eq__,    ["TextIOWrapper.write"],    true, "write qualname"]
    - [readline_qualname, TextIOWrapper.readline.__qualname__.__eq__, ["TextIOWrapper.readline"], true, "readline qualname"]

# ---------------------------------------------------------------------------
# TextIOWrapper — method qualnames: seek, tell, flush, close
# ---------------------------------------------------------------------------

table io_extra263.TextIOWrapper.method_qualnames_seek:
  description: "seek/tell/flush/close are defined directly on TextIOWrapper"
  kind: python_call_eq
  category: identity
  id_prefix: method_qualname

  columns: [id, function, args, expected, description]
  rows:
    - [seek_qualname,  TextIOWrapper.seek.__qualname__.__eq__,  ["TextIOWrapper.seek"],  true, "seek qualname"]
    - [tell_qualname,  TextIOWrapper.tell.__qualname__.__eq__,  ["TextIOWrapper.tell"],  true, "tell qualname"]
    - [flush_qualname, TextIOWrapper.flush.__qualname__.__eq__, ["TextIOWrapper.flush"], true, "flush qualname"]
    - [close_qualname, TextIOWrapper.close.__qualname__.__eq__, ["TextIOWrapper.close"], true, "close qualname"]

# ---------------------------------------------------------------------------
# TextIOWrapper — readlines/writelines inherited from _IOBase
# ---------------------------------------------------------------------------

invariant io_extra263.TextIOWrapper.readlines_qualname:
  description: "io.TextIOWrapper.readlines.__qualname__ == '_IOBase.readlines' (inherited)"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.readlines.__qualname__.__eq__
  args: ["_IOBase.readlines"]
  expected: true

invariant io_extra263.TextIOWrapper.writelines_qualname:
  description: "io.TextIOWrapper.writelines.__qualname__ == '_IOBase.writelines' (inherited)"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.writelines.__qualname__.__eq__
  args: ["_IOBase.writelines"]
  expected: true

# ---------------------------------------------------------------------------
# TextIOWrapper — method descriptor class names
# ---------------------------------------------------------------------------

table io_extra263.TextIOWrapper.method_class_names:
  description: "read/write/seek are method_descriptor objects"
  kind: python_call_eq
  category: identity
  id_prefix: method_class

  columns: [id, function, args, expected, description]
  rows:
    - [read_class,  TextIOWrapper.read.__class__.__name__.__eq__,  ["method_descriptor"], true, "read is method_descriptor"]
    - [write_class, TextIOWrapper.write.__class__.__name__.__eq__, ["method_descriptor"], true, "write is method_descriptor"]
    - [seek_class,  TextIOWrapper.seek.__class__.__name__.__eq__,  ["method_descriptor"], true, "seek is method_descriptor"]
