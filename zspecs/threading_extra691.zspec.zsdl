spec: threading_extra691
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers _DummyThread, _MainThread, Thread method docs, and synchronization primitive docs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra691.dummy_main_thread_identity:
  description: "threading._DummyThread and _MainThread identity attributes"
  kind: python_call_eq
  category: internal_thread_identity
  id_prefix: th691dt
  columns: [id, function, args, expected]
  rows:
    - [th691dt001, threading._DummyThread.__qualname__.__eq__, ["_DummyThread"], true]
    - [th691dt002, threading._DummyThread.__module__.__eq__, ["threading"], true]
    - [th691dt003, threading._DummyThread.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th691dt004, threading._MainThread.__qualname__.__eq__, ["_MainThread"], true]
    - [th691dt005, threading._MainThread.__module__.__eq__, ["threading"], true]

table threading_extra691.thread_method_docs:
  description: "threading.Thread method docstring presence"
  kind: python_call_eq
  category: thread_method_docs
  id_prefix: th691tm
  columns: [id, function, args, expected]
  rows:
    - [th691tm001, threading.Thread.__init__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th691tm002, threading.Thread.start.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th691tm003, threading.Thread.join.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th691tm004, threading.Thread.run.__doc__.__class__.__name__.__eq__, ["str"], true]

table threading_extra691.sync_primitive_docs:
  description: "threading synchronization primitive wait method docstring presence"
  kind: python_call_eq
  category: sync_primitive_docs
  id_prefix: th691sp
  columns: [id, function, args, expected]
  rows:
    - [th691sp001, threading.Condition.wait.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th691sp002, threading.Barrier.wait.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th691sp003, threading.Event.wait.__doc__.__class__.__name__.__eq__, ["str"], true]
