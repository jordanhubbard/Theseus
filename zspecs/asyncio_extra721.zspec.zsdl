spec: asyncio_extra721
version: ">=3.9"
backend: python_module(asyncio)
docs: Cover asyncio Lock, Semaphore, Event, Condition, and Queue class identity via qualname and module attributes
provenance:
  derived_from: asyncio standard library documentation
  not_derived_from: any third-party asyncio wrapper
  notes: Validates class identity invariants for asyncio synchronization primitives and queue types
  created_at: "2026-04-12"
error_model: python_exceptions

table asyncio_extra721.lock_identity:
  description: asyncio.Lock class identity checks via qualname and module
  kind: python_call_eq
  category: class_identity
  id_prefix: as721lo
  columns: [id, function, args, expected]
  as721lo001: [asyncio.Lock.__qualname__.__eq__, ["Lock"], true]
  as721lo002: [asyncio.Lock.__module__.__eq__, ["asyncio.locks"], true]
  as721lo003: [asyncio.Lock.__doc__.__class__.__name__.__eq__, ["str"], true]

