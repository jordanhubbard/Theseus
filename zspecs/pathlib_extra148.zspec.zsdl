spec: pathlib_extra148
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: __doc__ lengths for pathlib.Path (393), pathlib.PurePath (356), pathlib.PosixPath (107), pathlib.WindowsPath (105), and pathlib.PurePosixPath (176); also __doc__ class type identity (all str), class __name__ lengths, __module__ identity, MRO lengths, and __bases__ structure."
    - "pathlib.Path.__doc__ == 393 characters (longest among the five covered classes; opens with 'PurePath subclass that can make system calls.')."
    - "pathlib.PurePath.__doc__ == 356 characters (second longest; opens with 'Base class for manipulating paths without I/O.')."
    - "pathlib.PurePosixPath.__doc__ == 176 characters (the longer of the two Pure concrete subclasses)."
    - "pathlib.PosixPath.__doc__ == 107 characters; pathlib.WindowsPath.__doc__ == 105 characters (nearly equal; both describe platform-specific Path subclasses)."
    - "pathlib.Path.__bases__ == ['PurePath'] (single base); pathlib.PosixPath.__bases__ == ['Path', 'PurePosixPath'] (multiple inheritance)."
    - "pathlib.PurePath.__bases__ == ['object'] (root of the pathlib hierarchy)."
    - "Path MRO length == 3; PurePosixPath MRO length == 3; PurePath MRO length == 2."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib class __doc__ lengths and doc type identity
# Path.__doc__ == 393 chars (str); PurePath.__doc__ == 356 chars (str).
# PurePosixPath.__doc__ == 176 chars (str); PosixPath.__doc__ == 107 chars (str).
# WindowsPath.__doc__ == 105 chars (str).
# All five have non-None docstrings of type str.
# ---------------------------------------------------------------------------

table pathlib_extra148.class_doc_lengths:
  description: "pathlib class __doc__ lengths: Path=393, PurePath=356, PurePosixPath=176, PosixPath=107, WindowsPath=105; all are str"
  kind: python_call_eq
  category: doc_identity
  id_prefix: pathlibdoc148

  columns: [id, function, args, expected, description]
  rows:
    - [path_doc_cls,      Path.__doc__.__class__.__name__.__eq__,          ["str"], true, "pathlib.Path.__doc__ is a str (non-None; describes Path as 'PurePath subclass that can make system calls')"]
    - [path_doc_len,      Path.__doc__.__len__,                             [],     393,  "pathlib.Path.__doc__.__len__() == 393 (longest __doc__ among the five covered classes)"]
    - [purepath_doc_cls,  PurePath.__doc__.__class__.__name__.__eq__,       ["str"], true, "pathlib.PurePath.__doc__ is a str (describes PurePath as 'Base class for manipulating paths without I/O')"]
    - [purepath_doc_len,  PurePath.__doc__.__len__,                         [],     356,  "pathlib.PurePath.__doc__.__len__() == 356 (second longest; 37 chars shorter than Path.__doc__)"]
    - [pureposix_doc_cls, PurePosixPath.__doc__.__class__.__name__.__eq__,  ["str"], true, "pathlib.PurePosixPath.__doc__ is a str (describes POSIX-specific pure path behavior)"]
    - [pureposix_doc_len, PurePosixPath.__doc__.__len__,                    [],     176,  "pathlib.PurePosixPath.__doc__.__len__() == 176 (third longest; 'Pure' prefix but with platform note)"]
    - [posix_doc_cls,     PosixPath.__doc__.__class__.__name__.__eq__,      ["str"], true, "pathlib.PosixPath.__doc__ is a str (describes POSIX system-capable path)"]
    - [posix_doc_len,     PosixPath.__doc__.__len__,                        [],     107,  "pathlib.PosixPath.__doc__.__len__() == 107 (shorter than PurePosixPath because concrete class docs are more concise)"]
    - [winpath_doc_cls,   WindowsPath.__doc__.__class__.__name__.__eq__,    ["str"], true, "pathlib.WindowsPath.__doc__ is a str (describes Windows system-capable path)"]
    - [winpath_doc_len,   WindowsPath.__doc__.__len__,                      [],     105,  "pathlib.WindowsPath.__doc__.__len__() == 105 (shortest among the five; 2 chars less than PosixPath)"]

# ---------------------------------------------------------------------------
# pathlib class __name__ lengths and __module__ identity
# Path.__name__ == 'Path' (4); PurePath.__name__ == 'PurePath' (8).
# PurePosixPath.__name__ == 'PurePosixPath' (13); PosixPath.__name__ == 'PosixPath' (9).
# WindowsPath.__name__ == 'WindowsPath' (11).
# All five have __module__ == 'pathlib' (7 chars).
# ---------------------------------------------------------------------------

table pathlib_extra148.class_name_and_module:
  description: "pathlib class __name__ lengths: Path=4, PurePath=8, PosixPath=9, WindowsPath=11, PurePosixPath=13; all __module__='pathlib' (7)"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibname148

  columns: [id, function, args, expected, description]
  rows:
    - [path_name_len,      Path.__name__.__len__,          [], 4,  "pathlib.Path.__name__.__len__() == 4 ('Path' is the shortest class name in pathlib)"]
    - [path_module_eq,     Path.__module__.__eq__,         ["pathlib"], true, "pathlib.Path.__module__ == 'pathlib'"]
    - [path_module_len,    Path.__module__.__len__,         [], 7,  "pathlib.Path.__module__.__len__() == 7 ('pathlib' has 7 characters)"]
    - [purepath_name_len,  PurePath.__name__.__len__,      [], 8,  "pathlib.PurePath.__name__.__len__() == 8 ('PurePath' has 8 characters)"]
    - [purepath_module_eq, PurePath.__module__.__eq__,      ["pathlib"], true, "pathlib.PurePath.__module__ == 'pathlib'"]
    - [pureposix_name_len, PurePosixPath.__name__.__len__, [], 13, "pathlib.PurePosixPath.__name__.__len__() == 13 ('PurePosixPath' is the longest name among the five)"]
    - [posix_name_len,     PosixPath.__name__.__len__,     [], 9,  "pathlib.PosixPath.__name__.__len__() == 9 ('PosixPath' has 9 characters)"]
    - [winpath_name_len,   WindowsPath.__name__.__len__,   [], 11, "pathlib.WindowsPath.__name__.__len__() == 11 ('WindowsPath' has 11 characters)"]

# ---------------------------------------------------------------------------
# pathlib class MRO lengths and base class structure
# PurePath MRO length == 2 ([PurePath, object]).
# Path MRO length == 3 ([Path, PurePath, object]).
# PurePosixPath MRO length == 3 ([PurePosixPath, PurePath, object]).
# PurePath.__bases__[0].__name__ == 'object'.
# Path.__bases__[0].__name__ == 'PurePath'.
# ---------------------------------------------------------------------------

table pathlib_extra148.class_mro_and_bases:
  description: "pathlib MRO lengths: PurePath=2, Path=3, PurePosixPath=3; bases: PurePath<-object, Path<-PurePath, PurePosixPath<-PurePath"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibmro148

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_mro_len,   "PurePath.__mro__.__len__",                      [], 2, "pathlib.PurePath.__mro__.__len__() == 2 ([PurePath, object]; root of the pathlib hierarchy)"]
    - [purepath_mro0_eq,   "PurePath.__mro__[0].__name__.__eq__",  ["PurePath"], true, "pathlib.PurePath.__mro__[0].__name__ == 'PurePath'"]
    - [purepath_mro1_eq,   "PurePath.__mro__[1].__name__.__eq__",  ["object"],   true, "pathlib.PurePath.__mro__[1].__name__ == 'object' (direct subclass of object)"]
    - [path_mro_len,       "Path.__mro__.__len__",                          [], 3, "pathlib.Path.__mro__.__len__() == 3 ([Path, PurePath, object])"]
    - [path_mro0_eq,       "Path.__mro__[0].__name__.__eq__",      ["Path"],     true, "pathlib.Path.__mro__[0].__name__ == 'Path'"]
    - [path_mro1_eq,       "Path.__mro__[1].__name__.__eq__",      ["PurePath"], true, "pathlib.Path.__mro__[1].__name__ == 'PurePath' (Path extends PurePath)"]
    - [path_base0_eq,      "Path.__bases__[0].__name__.__eq__",    ["PurePath"], true, "pathlib.Path.__bases__[0].__name__ == 'PurePath' (single declared base)"]
    - [pureposix_mro_len,  "PurePosixPath.__mro__.__len__",                [], 3, "pathlib.PurePosixPath.__mro__.__len__() == 3 ([PurePosixPath, PurePath, object])"]
    - [pureposix_mro1_eq,  "PurePosixPath.__mro__[1].__name__.__eq__", ["PurePath"], true, "pathlib.PurePosixPath.__mro__[1].__name__ == 'PurePath'"]
    - [purepath_base0_eq,  "PurePath.__bases__[0].__name__.__eq__", ["object"],  true, "pathlib.PurePath.__bases__[0].__name__ == 'object' (PurePath is the root; its only base is object)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra148.Path.doc_len_393:
  description: "pathlib.Path.__doc__.__len__() == 393 (the longest __doc__ among the five covered pathlib classes; Path's docstring opens with 'PurePath subclass that can make system calls.' and then describes platform-specific instantiation behavior, making it 37 characters longer than PurePath.__doc__ (356))"
  category: doc_identity
  kind: python_call_eq
  function: Path.__doc__.__len__
  args: []
  expected: 393

invariant pathlib_extra148.PurePath.doc_len_356:
  description: "pathlib.PurePath.__doc__.__len__() == 356 (the second longest __doc__ among the five covered classes; PurePath's docstring opens with 'Base class for manipulating paths without I/O.' and describes the PurePath interface without file-system operations)"
  category: doc_identity
  kind: python_call_eq
  function: PurePath.__doc__.__len__
  args: []
  expected: 356

invariant pathlib_extra148.PurePosixPath.doc_len_176:
  description: "pathlib.PurePosixPath.__doc__.__len__() == 176 (the third longest among the five covered classes; 'PurePath subclass for non-Windows systems.' plus a note that instantiating a PurePath on a POSIX system yields a PurePosixPath; longer than PosixPath (107) despite having 'Pure' prefix because it explains the fallback behavior)"
  category: doc_identity
  kind: python_call_eq
  function: PurePosixPath.__doc__.__len__
  args: []
  expected: 176

invariant pathlib_extra148.WindowsPath.doc_len_105:
  description: "pathlib.WindowsPath.__doc__.__len__() == 105 (the shortest __doc__ among the five covered classes; just 2 characters shorter than PosixPath.__doc__ (107); describes WindowsPath as 'Path subclass for Windows systems' with a note about instantiation)"
  category: doc_identity
  kind: python_call_eq
  function: WindowsPath.__doc__.__len__
  args: []
  expected: 105

invariant pathlib_extra148.PurePath.mro_len_2:
  description: "pathlib.PurePath.__mro__.__len__() == 2 ([PurePath, object]); the shortest MRO in pathlib, reflecting that PurePath is the root of the hierarchy and directly subclasses object; Path adds one entry (MRO length 3) by extending PurePath"
  category: class_identity
  kind: python_call_eq
  function: "PurePath.__mro__.__len__"
  args: []
  expected: 2

invariant pathlib_extra148.PurePosixPath.name_len_13:
  description: "pathlib.PurePosixPath.__name__.__len__() == 13 ('PurePosixPath' has 13 characters; the longest __name__ among the five covered classes — 'Pure' (4) + 'Posix' (5) + 'Path' (4) = 13; two more than WindowsPath (11) and four more than PosixPath (9))"
  category: class_identity
  kind: python_call_eq
  function: PurePosixPath.__name__.__len__
  args: []
  expected: 13
