    - ["as2791mx_t_ix",  Task.__dict__.__contains__,       ["__ixor__"],  false]
    - ["as2791mx_f_ia",  Future.__dict__.__contains__,     ["__iand__"],  false]
    - ["as2791mx_f_io",  Future.__dict__.__contains__,     ["__ior__"],   false]
    - ["as2791mx_f_ix",  Future.__dict__.__contains__,     ["__ixor__"],  false]
    - ["as2791mx_l_ia",  Lock.__dict__.__contains__,       ["__iand__"],  false]
    - ["as2791mx_l_io",  Lock.__dict__.__contains__,       ["__ior__"],   false]
    - ["as2791mx_l_ix",  Lock.__dict__.__contains__,       ["__ixor__"],  false]
    - ["as2791mx_e_ia",  Event.__dict__.__contains__,      ["__iand__"],  false]
    - ["as2791mx_e_io",  Event.__dict__.__contains__,      ["__ior__"],   false]
    - ["as2791mx_e_ix",  Event.__dict__.__contains__,      ["__ixor__"],  false]
    - ["as2791mx_s_ia",  Semaphore.__dict__.__contains__,  ["__iand__"],  false]
    - ["as2791mx_s_io",  Semaphore.__dict__.__contains__,  ["__ior__"],   false]
    - ["as2791mx_s_ix",  Semaphore.__dict__.__contains__,  ["__ixor__"],  false]
    - ["as2791mx_c_ia",  Condition.__dict__.__contains__,  ["__iand__"],  false]
    - ["as2791mx_c_io",  Condition.__dict__.__contains__,  ["__ior__"],   false]
    - ["as2791mx_c_ix",  Condition.__dict__.__contains__,  ["__ixor__"],  false]
    - ["as2791mx_b_ia",  Barrier.__dict__.__contains__,    ["__iand__"],  false]
    - ["as2791mx_b_io",  Barrier.__dict__.__contains__,    ["__ior__"],   false]
    - ["as2791mx_b_ix",  Barrier.__dict__.__contains__,    ["__ixor__"],  false]
