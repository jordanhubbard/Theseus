spec: asyncio_extra2791
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronisation primitives documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio task and future documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "asyncio_extra.zspec.zsdl — covers __name__ and __module__ checks for Queue, Task, Future, Lock, Event, Semaphore, Condition"
    - "asyncio_extra2.zspec.zsdl — covers module checks for event loop classes and exception classes"
    - "asyncio_extra2776.zspec.zsdl — covers __isub__, __imul__, __itruediv__ dict-presence checks"
  notes:
    - "Wave 633 theme: __iand__, __ior__, and __ixor__ dict-presence checks (in-place bitwise operators)."
    - "None of the asyncio synchronisation or task primitives define __iand__, __ior__, or __ixor__ in their __dict__."
    - "Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier are async coordination primitives, not bitwise-set types."
    - "asyncio.Barrier was added in Python 3.11; version constraint >=3.9 applies to all other types."
    - "All eight types checked: Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue, asyncio.Task, asyncio.Future — __iand__/__ior__/__ixor__
# dict-presence checks
#
# Queue is an async FIFO queue; Task wraps a coroutine; Future is a low-level
# awaitable. None of them define in-place bitwise operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2791.queue_task_future_operator_dict:
  description: "asyncio.Queue, Task, Future __iand__, __ior__, __ixor__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2791qtf

  columns: [id, function, args, expected]
  rows:
    - ["as2791qtf_q_iand",  Queue.__dict__.__contains__,  ["__iand__"],  false]
    - ["as2791qtf_q_ior",   Queue.__dict__.__contains__,  ["__ior__"],   false]
    - ["as2791qtf_q_ixor",  Queue.__dict__.__contains__,  ["__ixor__"],  false]
    - ["as2791qtf_t_iand",  Task.__dict__.__contains__,   ["__iand__"],  false]
    - ["as2791qtf_t_ior",   Task.__dict__.__contains__,   ["__ior__"],   false]
    - ["as2791qtf_t_ixor",  Task.__dict__.__contains__,   ["__ixor__"],  false]
    - ["as2791qtf_f_iand",  Future.__dict__.__contains__, ["__iand__"],  false]
    - ["as2791qtf_f_ior",   Future.__dict__.__contains__, ["__ior__"],   false]
    - ["as2791qtf_f_ixor",  Future.__dict__.__contains__, ["__ixor__"],  false]

# ---------------------------------------------------------------------------
# asyncio.Lock, asyncio.Event, asyncio.Semaphore — __iand__/__ior__/__ixor__
# dict-presence checks
#
# Lock, Event, and Semaphore are async synchronisation primitives defined in
# asyncio.locks. They do not implement in-place bitwise operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2791.lock_event_semaphore_operator_dict:
  description: "asyncio.Lock, Event, Semaphore __iand__, __ior__, __ixor__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2791les

  columns: [id, function, args, expected]
  rows:
    - ["as2791les_l_iand",  Lock.__dict__.__contains__,      ["__iand__"],  false]
    - ["as2791les_l_ior",   Lock.__dict__.__contains__,      ["__ior__"],   false]
    - ["as2791les_l_ixor",  Lock.__dict__.__contains__,      ["__ixor__"],  false]
    - ["as2791les_e_iand",  Event.__dict__.__contains__,     ["__iand__"],  false]
    - ["as2791les_e_ior",   Event.__dict__.__contains__,     ["__ior__"],   false]
    - ["as2791les_e_ixor",  Event.__dict__.__contains__,     ["__ixor__"],  false]
    - ["as2791les_s_iand",  Semaphore.__dict__.__contains__, ["__iand__"],  false]
    - ["as2791les_s_ior",   Semaphore.__dict__.__contains__, ["__ior__"],   false]
    - ["as2791les_s_ixor",  Semaphore.__dict__.__contains__, ["__ixor__"],  false]

# ---------------------------------------------------------------------------
# asyncio.Condition and asyncio.Barrier — __iand__/__ior__/__ixor__
# dict-presence checks
#
# Condition is a combination lock/condition variable. Barrier (added in 3.11)
# is a synchronisation barrier. Neither defines in-place bitwise operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2791.condition_barrier_operator_dict:
  description: "asyncio.Condition and Barrier __iand__, __ior__, __ixor__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2791cb

  columns: [id, function, args, expected]
  rows:
    - ["as2791cb_c_iand",  Condition.__dict__.__contains__, ["__iand__"],  false]
    - ["as2791cb_c_ior",   Condition.__dict__.__contains__, ["__ior__"],   false]
    - ["as2791cb_c_ixor",  Condition.__dict__.__contains__, ["__ixor__"],  false]
    - ["as2791cb_b_iand",  Barrier.__dict__.__contains__,   ["__iand__"],  false]
    - ["as2791cb_b_ior",   Barrier.__dict__.__contains__,   ["__ior__"],   false]
    - ["as2791cb_b_ixor",  Barrier.__dict__.__contains__,   ["__ixor__"],  false]

# ---------------------------------------------------------------------------
# Full 8×3 cross-type matrix — all asyncio types, all three in-place bitwise operator dunders
#
# Consolidates the full 8×3 dict-presence check in one table.
# Every cell is False: Queue, Task, Future, Lock, Event, Semaphore, Condition,
# and Barrier do not define &=, |=, or ^= operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2791.all_types_iand_ior_ixor_matrix:
  description: "Full 8×3 dict-presence matrix for asyncio types vs __iand__/__ior__/__ixor__ — all 24 results are False; verified with Python 3.14.4"
