spec: fastapi_rust
version: ">=3.9"
backend: rust_module(fastapi_rust)

docs: https://fastapi.tiangolo.com/reference/

provenance:
  derived_from:
    - "https://fastapi.tiangolo.com/reference/ — FastAPI reference"
  not_derived_from:
    - "fastapi source: fastapi/applications.py"
  notes:
    - "FastAPI is a modern web framework for Python."
    - "FastAPI().title == 'FastAPI' — default title."
    - "FastAPI(title='MyApp').title == 'MyApp'."
    - "FastAPI().version == '0.1.0' — default version."
    - "FastAPI(version='2.0').version == '2.0'."
    - "Expose fastapi_title(title) -> str: FastAPI(title=title).title."
    - "Expose fastapi_version(version) -> str: FastAPI(version=version).version."
    - "Expose fastapi_default_title() -> str: FastAPI().title."
    - "All test vectors verified against fastapi 0.115.12."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# fastapi_title — custom title
table fastapi_rust.app.title:
  kind: python_call_eq
  category: title
  id_prefix: fa_title
  function: fastapi_title

  columns: [id, args, expected]
  rows:
    - [myapp,   ["MyApp"],   "MyApp"]
    - [api,     ["MyAPI"],   "MyAPI"]

# fastapi_version — custom version
table fastapi_rust.app.version:
  kind: python_call_eq
  category: version
  id_prefix: fa_ver
  function: fastapi_version

  columns: [id, args, expected]
  rows:
    - [two, ["2.0"], "2.0"]
    - [one, ["1.0"], "1.0"]

# fastapi_default_title — default is 'FastAPI'
invariant fastapi_rust.app.default_title:
  description: "FastAPI().title == 'FastAPI'"
  category: default_title
  kind: python_call_eq
  function: fastapi_default_title
  args: []
  expected: "FastAPI"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:16:04Z
  iterations: 1
  pass_count: 5
  fail_count: 0
