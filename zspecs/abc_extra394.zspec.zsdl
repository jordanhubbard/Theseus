spec: abc_extra394
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "abc.ABC.__doc__.__class__.__name__ == 'str'"
    - "abc.ABCMeta.__doc__.__class__.__name__ == 'str'"
    - "abc.abstractmethod.__doc__.__class__.__name__ == 'str'"
    - "abc.abstractproperty is still present in Python 3.14 (deprecated but not removed); __name__ == 'abstractproperty', __module__ == 'abc'"
    - "abc.abstractstaticmethod is still present in Python 3.14 (deprecated but not removed); __name__ == 'abstractstaticmethod', __module__ == 'abc'"
    - "abc.update_abstractmethods was added in Python 3.10; __name__ == 'update_abstractmethods', __module__ == 'abc'"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra394.doc_class_names:
  description: "Verify __doc__.__class__.__name__ for key abc objects (all docstrings are str)"
  kind: python_call_eq
  category: identity
  id_prefix: abc394dc

  columns: [id, function, args, expected]
  rows:
    - [abc394dc001, abc.ABC.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [abc394dc002, abc.ABCMeta.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [abc394dc003, abc.abstractmethod.__doc__.__class__.__name__.__eq__, ["str"], true]

table abc_extra394.deprecated_class_names:
  description: "Verify __name__ of deprecated abc classes still present in Python 3.14"
  kind: python_call_eq
  category: identity
  id_prefix: abc394dn

  columns: [id, function, args, expected]
  rows:
    - [abc394dn001, abc.abstractproperty.__name__.__eq__, ["abstractproperty"], true]
    - [abc394dn002, abc.abstractstaticmethod.__name__.__eq__, ["abstractstaticmethod"], true]

table abc_extra394.deprecated_class_modules:
  description: "Verify __module__ of deprecated abc classes still present in Python 3.14"
  kind: python_call_eq
  category: identity
  id_prefix: abc394dm

  columns: [id, function, args, expected]
  rows:
    - [abc394dm001, abc.abstractproperty.__module__.__eq__, ["abc"], true]
    - [abc394dm002, abc.abstractstaticmethod.__module__.__eq__, ["abc"], true]

table abc_extra394.update_abstractmethods_identity:
  description: "Verify __name__ and __module__ of abc.update_abstractmethods (added in Python 3.10)"
  kind: python_call_eq
  category: identity
  id_prefix: abc394ua

  columns: [id, function, args, expected]
  rows:
    - [abc394ua001, abc.update_abstractmethods.__name__.__eq__, ["update_abstractmethods"], true]
    - [abc394ua002, abc.update_abstractmethods.__module__.__eq__, ["abc"], true]
