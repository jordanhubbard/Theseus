spec: htmlspecialchars
version: ">=1.0.0"
backend: node(htmlspecialchars)

docs: https://www.npmjs.com/package/htmlspecialchars

provenance:
  derived_from:
    - "htmlspecialchars README — https://www.npmjs.com/package/htmlspecialchars"
    - "Test vectors verified with htmlspecialchars via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "htmlspecialchars source"
  notes:
    - "htmlspecialchars is an npm package. Install: npm install htmlspecialchars"
    - "htmlspecialchars(str) converts < > & into their HTML entity equivalents."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns HTML-escaped string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table htmlspecialchars.escape:
  kind: node_module_call_eq
  function: ~
  category: escape
  id_prefix: hsc

  columns: [id, args, expected]
  rows:
    - [tag,       ["<div>Test"],      "&lt;div&gt;Test"]
    - [ampersand, ["Tom & Jerry"],    "Tom &amp; Jerry"]
    - [plain,     ["plain text"],     "plain text"]
