spec: turtle_extra4
version: ">=3.9"
backend: python_module(turtle)

docs: https://docs.python.org/3/library/turtle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/turtle.html — Python turtle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/turtle.py"
  notes:
    - "This spec extends turtle.zspec.zsdl and turtle_extra through turtle_extra3.zspec.zsdl."
    - "turtle.zspec.zsdl covers: Turtle/Screen/RawTurtle/TurtleScreen/Vec2D/Pen __name__; forward/backward/penup/pendown/circle/done __name__."
    - "turtle_extra.zspec.zsdl covers: Turtle/Screen/Pen __name__+__module__; forward/backward/bgcolor/done __name__; function type checks."
    - "turtle_extra2.zspec.zsdl covers: right/left/speed __name__; Turtle.__qualname__; navigation function name table."
    - "turtle_extra3.zspec.zsdl covers: Vec2D/RawTurtle/TurtleScreen __module__; Screen.__qualname__; color/pencolor/fillcolor/goto/setheading __name__."
    - "This spec adds: forward/__module__, backward/__module__, right/__module__, left/__module__, penup/__module__, pendown/__module__; home/__name__, stamp/__name__, undo/__name__, xcor/__name__, ycor/__name__, dot/__name__, hideturtle/__name__."
    - "All module-level turtle functions are wrappers around a default Turtle instance."
    - "Function __module__ attributes are inspectable without a display or Tk instance."
    - "forward.__module__ == 'turtle' — the wrapper function belongs to the turtle module."
    - "home/__name__, stamp/__name__, undo/__name__, xcor/__name__, ycor/__name__, dot/__name__, hideturtle/__name__ are documented turtle API functions not yet covered."
    - "All expected values verified with Python 3.12 turtle on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# forward — module affiliation
# turtle.zspec.zsdl and turtle_extra both cover forward.__name__; __module__
# not yet covered in any prior spec.
# ---------------------------------------------------------------------------

invariant turtle_extra4.forward.module:
  description: "turtle.forward.__module__ == 'turtle'"
  category: functions
  kind: python_call_eq
  function: forward.__module__.__eq__
  args: ["turtle"]
  expected: true

# ---------------------------------------------------------------------------
# backward — module affiliation
# turtle.zspec.zsdl and turtle_extra cover backward.__name__; __module__ not
# yet covered.
# ---------------------------------------------------------------------------

invariant turtle_extra4.backward.module:
  description: "turtle.backward.__module__ == 'turtle'"
  category: functions
  kind: python_call_eq
  function: backward.__module__.__eq__
  args: ["turtle"]
  expected: true

# ---------------------------------------------------------------------------
# right — module affiliation
# turtle_extra2 covers right.__name__; __module__ not yet covered.
# ---------------------------------------------------------------------------

invariant turtle_extra4.right.module:
  description: "turtle.right.__module__ == 'turtle'"
  category: functions
  kind: python_call_eq
  function: right.__module__.__eq__
  args: ["turtle"]
  expected: true

# ---------------------------------------------------------------------------
# left — module affiliation
# turtle_extra2 covers left.__name__; __module__ not yet covered.
# ---------------------------------------------------------------------------

invariant turtle_extra4.left.module:
  description: "turtle.left.__module__ == 'turtle'"
  category: functions
  kind: python_call_eq
  function: left.__module__.__eq__
  args: ["turtle"]
  expected: true

# ---------------------------------------------------------------------------
# penup — module affiliation
# turtle.zspec.zsdl covers penup.__name__; __module__ not yet covered.
# ---------------------------------------------------------------------------

invariant turtle_extra4.penup.module:
  description: "turtle.penup.__module__ == 'turtle'"
  category: functions
  kind: python_call_eq
  function: penup.__module__.__eq__
  args: ["turtle"]
  expected: true

# ---------------------------------------------------------------------------
# pendown — module affiliation
# turtle.zspec.zsdl covers pendown.__name__; __module__ not yet covered.
# ---------------------------------------------------------------------------

invariant turtle_extra4.pendown.module:
  description: "turtle.pendown.__module__ == 'turtle'"
  category: functions
  kind: python_call_eq
  function: pendown.__module__.__eq__
  args: ["turtle"]
  expected: true

# ---------------------------------------------------------------------------
# home — function __name__
# turtle.home() moves the turtle to origin (0,0) facing east; its __name__
# is inspectable without a display. Not covered in any prior turtle spec.
# ---------------------------------------------------------------------------

invariant turtle_extra4.home.name:
  description: "turtle.home.__name__ == 'home'"
  category: functions
  kind: python_call_eq
  function: home.__name__.__eq__
  args: ["home"]
  expected: true

# ---------------------------------------------------------------------------
# stamp — function __name__
# turtle.stamp() stamps a copy of the turtle shape; __name__ not yet covered.
# ---------------------------------------------------------------------------

invariant turtle_extra4.stamp.name:
  description: "turtle.stamp.__name__ == 'stamp'"
  category: functions
  kind: python_call_eq
  function: stamp.__name__.__eq__
  args: ["stamp"]
  expected: true

# ---------------------------------------------------------------------------
# undo — function __name__
# turtle.undo() undoes the last turtle action; __name__ not yet covered.
# ---------------------------------------------------------------------------

invariant turtle_extra4.undo.name:
  description: "turtle.undo.__name__ == 'undo'"
  category: functions
  kind: python_call_eq
  function: undo.__name__.__eq__
  args: ["undo"]
  expected: true

# ---------------------------------------------------------------------------
# xcor — function __name__
# turtle.xcor() returns the turtle's current x-coordinate; not yet covered.
# ---------------------------------------------------------------------------

invariant turtle_extra4.xcor.name:
  description: "turtle.xcor.__name__ == 'xcor'"
  category: functions
  kind: python_call_eq
  function: xcor.__name__.__eq__
  args: ["xcor"]
  expected: true

# ---------------------------------------------------------------------------
# ycor — function __name__
# turtle.ycor() returns the turtle's current y-coordinate; not yet covered.
# ---------------------------------------------------------------------------

invariant turtle_extra4.ycor.name:
  description: "turtle.ycor.__name__ == 'ycor'"
  category: functions
  kind: python_call_eq
  function: ycor.__name__.__eq__
  args: ["ycor"]
  expected: true

# ---------------------------------------------------------------------------
# hideturtle — function __name__
# turtle.hideturtle() makes the turtle invisible; not yet covered.
# ---------------------------------------------------------------------------

invariant turtle_extra4.hideturtle.name:
  description: "turtle.hideturtle.__name__ == 'hideturtle'"
  category: functions
  kind: python_call_eq
  function: hideturtle.__name__.__eq__
  args: ["hideturtle"]
  expected: true

# ---------------------------------------------------------------------------
# dot — function __name__
# turtle.dot() draws a dot with the given diameter; not yet covered.
# ---------------------------------------------------------------------------

invariant turtle_extra4.dot.name:
  description: "turtle.dot.__name__ == 'dot'"
  category: functions
  kind: python_call_eq
  function: dot.__name__.__eq__
  args: ["dot"]
  expected: true

# ---------------------------------------------------------------------------
# Table: batch __module__ checks for navigation functions
# Confirms all six primary movement functions belong to the 'turtle' module.
# ---------------------------------------------------------------------------

table turtle_extra4.navigation_functions.modules:
  kind: python_call_eq
  category: functions
  id_prefix: navmod

  columns: [id, function, args, expected]
  rows:
    - [forward,  forward.__module__.__eq__,  ["turtle"], true]
    - [backward, backward.__module__.__eq__, ["turtle"], true]
    - [right,    right.__module__.__eq__,    ["turtle"], true]
    - [left,     left.__module__.__eq__,     ["turtle"], true]
    - [penup,    penup.__module__.__eq__,    ["turtle"], true]
    - [pendown,  pendown.__module__.__eq__,  ["turtle"], true]
