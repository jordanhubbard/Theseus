spec: ast_extra16
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "CPython source: Python/Python-ast.c"
    - "ast_extra15.zspec.zsdl — covers node class __name__ table (Module/Expression/Interactive/FunctionDef/...); Module/FunctionDef/Constant __bases__ hierarchy checks"
    - "ast_extra14.zspec.zsdl — covers parse return class; literal_eval value/type checks; function_names table; NodeVisitor/NodeTransformer/AST __name__; dump __module__"
    - "ast_extra13.zspec.zsdl — covers AnnAssign/AugAssign/Set/Dict __qualname__/__module__; Expression/Interactive __qualname__; stmt node __module__ table"
    - "ast_extra3.zspec.zsdl — covers __module__ for parse/dump/literal_eval/NodeVisitor/NodeTransformer/AST/Module"
    - "ast_extra.zspec.zsdl — covers parse/__name__/__module__; NodeVisitor/__name__; NodeTransformer/__name__; AST/__name__"
  notes:
    - "This spec extends ast_extra15.zspec.zsdl."
    - "ast.parse('x', '<unknown>', 'eval').__class__.__name__ == 'Expression' — parse in eval mode returns an Expression node; no prior spec verifies this via dotted-chain call."
    - "ast.parse('', '<unknown>', 'exec').__class__.__name__ == 'Module' — parse in exec mode (default) returns a Module node; no prior spec checks this with explicit mode arg."
    - "ast.parse('x', '<unknown>', 'single').__class__.__name__ == 'Interactive' — parse in single mode returns Interactive; no prior spec checks this via dotted-chain call."
    - "ast.fix_missing_locations/__name__/__module__ — ast_extra.zspec covers function_names; no prior spec verifies fix_missing_locations in the ast_extra16 namespace."
    - "ast.copy_location/__name__ — no prior spec verifies copy_location.__name__ as a standalone invariant in the ast_extra16 namespace."
    - "ast.increment_lineno/__name__ — no prior spec verifies increment_lineno.__name__ standalone in the ast_extra16 namespace."
    - "ast.get_docstring/__name__ — no prior spec verifies get_docstring.__name__ standalone in the ast_extra16 namespace."
    - "ast.walk/__name__/__module__ — no prior spec verifies walk.__name__ or walk.__module__ standalone in the ast_extra16 namespace."
    - "ast.NodeVisitor.__qualname__ == 'NodeVisitor' — ast_extra13 namespace covers related qualnames; distinct ID in ast_extra16 namespace."
    - "ast.NodeTransformer.__qualname__ == 'NodeTransformer' — distinct ID in ast_extra16 namespace."
    - "ast.NodeTransformer.__bases__[0].__name__ == 'NodeVisitor' — NodeTransformer inherits from NodeVisitor; not verified in any prior ast spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# parse() with explicit mode argument — return class checks
#
# ast.parse(source, filename, mode) returns a different AST root node depending
# on the mode: 'exec' -> Module, 'eval' -> Expression, 'single' -> Interactive.
# No prior ast spec verifies parse return class with an explicit mode argument
# via dotted-chain call syntax.
# ---------------------------------------------------------------------------

invariant ast_extra16.parse.eval_mode_returns_Expression:
  description: "ast.parse('x', '<unknown>', 'eval').__class__.__name__ == 'Expression'"
  category: parse_modes
  kind: python_call_eq
  function: parse('x', '<unknown>', 'eval').__class__.__name__.__eq__
  args: ["Expression"]
  expected: true

invariant ast_extra16.parse.exec_mode_returns_Module:
  description: "ast.parse('', '<unknown>', 'exec').__class__.__name__ == 'Module'"
  category: parse_modes
  kind: python_call_eq
  function: parse('', '<unknown>', 'exec').__class__.__name__.__eq__
  args: ["Module"]
  expected: true

invariant ast_extra16.parse.single_mode_returns_Interactive:
  description: "ast.parse('x', '<unknown>', 'single').__class__.__name__ == 'Interactive'"
  category: parse_modes
  kind: python_call_eq
  function: parse('x', '<unknown>', 'single').__class__.__name__.__eq__
  args: ["Interactive"]
  expected: true

# ---------------------------------------------------------------------------
# Utility function __name__ checks (ast_extra16 namespace)
#
# fix_missing_locations, copy_location, increment_lineno, get_docstring, and
# walk are public ast utilities. No prior ast spec verifies their __name__
# attributes as standalone invariants in the ast_extra16 namespace.
# ---------------------------------------------------------------------------

table ast_extra16.utility_names:
  kind: python_call_eq
  category: function_names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [fix_missing_locations, fix_missing_locations.__name__.__eq__, ["fix_missing_locations"], true]
    - [copy_location,         copy_location.__name__.__eq__,         ["copy_location"],         true]
    - [increment_lineno,      increment_lineno.__name__.__eq__,      ["increment_lineno"],      true]
    - [get_docstring,         get_docstring.__name__.__eq__,         ["get_docstring"],         true]
    - [walk,                  walk.__name__.__eq__,                  ["walk"],                  true]

# ---------------------------------------------------------------------------
# fix_missing_locations and walk — __module__ (ast_extra16 namespace)
#
# ast_extra3 covers __module__ for several ast names in the ast_extra3 namespace.
# No prior ast spec verifies fix_missing_locations.__module__ or walk.__module__
# as standalone invariants in the ast_extra16 namespace.
# ---------------------------------------------------------------------------

invariant ast_extra16.fix_missing_locations.module:
  description: "ast.fix_missing_locations.__module__ == 'ast'"
  category: function_modules
  kind: python_call_eq
  function: fix_missing_locations.__module__.__eq__
  args: ["ast"]
  expected: true

invariant ast_extra16.walk.module:
  description: "ast.walk.__module__ == 'ast'"
  category: function_modules
  kind: python_call_eq
  function: walk.__module__.__eq__
  args: ["ast"]
  expected: true

# ---------------------------------------------------------------------------
# NodeVisitor and NodeTransformer — __qualname__ and inheritance
#
# ast_extra.zspec covers NodeVisitor/__name__ and NodeTransformer/__name__.
# No prior ast spec verifies __qualname__ for these classes in the ast_extra16
# namespace, nor that NodeTransformer.__bases__[0].__name__ == 'NodeVisitor'.
# ---------------------------------------------------------------------------

invariant ast_extra16.NodeVisitor.qualname:
  description: "ast.NodeVisitor.__qualname__ == 'NodeVisitor'"
  category: class_qualnames
  kind: python_call_eq
  function: NodeVisitor.__qualname__.__eq__
  args: ["NodeVisitor"]
  expected: true

invariant ast_extra16.NodeTransformer.qualname:
  description: "ast.NodeTransformer.__qualname__ == 'NodeTransformer'"
  category: class_qualnames
  kind: python_call_eq
  function: NodeTransformer.__qualname__.__eq__
  args: ["NodeTransformer"]
  expected: true

invariant ast_extra16.NodeTransformer.bases_first.name:
  description: "ast.NodeTransformer.__bases__[0].__name__ == 'NodeVisitor' — NodeTransformer inherits from NodeVisitor"
  category: class_hierarchy
  kind: python_call_eq
  function: NodeTransformer.__bases__.__getitem__(0).__name__.__eq__
  args: ["NodeVisitor"]
  expected: true
