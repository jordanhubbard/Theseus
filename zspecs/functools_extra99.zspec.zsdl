spec: functools_extra99
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra98

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra98.zspec.zsdl."
    - "This spec covers: functools singledispatch and singledispatchmethod identity — the registry attribute, dispatch method, and related attrs; functools module identity (__name__, __package__, __loader__, __spec__) (Wave 254)."
    - "functools.singledispatch.__class__.__name__ == 'function' — singledispatch is a pure-Python decorator factory defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_name == 'singledispatch' — co_name matches the def statement. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_argcount == 1 — singledispatch takes a single positional argument (func). Verified with Python 3.14.3."
    - "functools.singledispatch.__qualname__ == 'singledispatch' (len 14) — module-scope function has simple qualname. Verified with Python 3.14.3."
    - "functools.singledispatch.__module__ == 'functools'. Verified with Python 3.14.3."
    - "A @singledispatch-wrapped function's .dispatch attribute __class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "A @singledispatch-wrapped function's .register attribute __class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "A @singledispatch-wrapped function's .registry attribute __class__.__name__ == 'mappingproxy'. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__class__.__name__ == 'type' — it is a class not a function. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__name__ == 'singledispatchmethod'. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__qualname__ == 'singledispatchmethod'. Verified with Python 3.14.3."
    - "functools.__name__ == 'functools'. Verified with Python 3.14.3."
    - "functools.__package__ == '' (empty string). Verified with Python 3.14.3."
    - "functools.__loader__.__class__.__name__ == 'SourceFileLoader' — functools is a pure-Python module loaded by SourceFileLoader. Verified with Python 3.14.3."
    - "functools.__spec__.__class__.__name__ == 'ModuleSpec'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: singledispatch code attrs (__class__.__name__, co_name, co_argcount, __module__)
#
# Wave 254 theme: functools.singledispatch code-object and module attributes.
#
# functools.singledispatch.__class__.__name__.__eq__('function') == True
# functools.singledispatch.__code__.co_name.__eq__('singledispatch') == True
# functools.singledispatch.__code__.co_argcount.__eq__(1) == True
# functools.singledispatch.__module__.__eq__('functools') == True
#
# singledispatch is a plain Python function; co_argcount is 1 (takes func); __module__ is 'functools'.
# New to extra99.
# ---------------------------------------------------------------------------

table functools_extra99.singledispatch_code_attrs:
  description: "functools.singledispatch __class__.__name__, co_name, co_argcount, __module__; pure-Python decorator factory; wave 254; new to extra99"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolssingledispatch99

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_class_name_eq_function,
       "singledispatch.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.singledispatch.__class__.__name__.__eq__('function') == True — singledispatch is a pure-Python decorator factory defined with 'def singledispatch' in Lib/functools.py; it is a plain Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra99"]
    - [singledispatch_co_name_eq,
       "singledispatch.__code__.co_name.__eq__",
       ["singledispatch"],
       true,
       "functools.singledispatch.__code__.co_name.__eq__('singledispatch') == True — co_name is the name from the def statement in Lib/functools.py; str.__eq__('singledispatch') returns True; new to extra99"]
    - [singledispatch_co_argcount_eq_1,
       "singledispatch.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.singledispatch.__code__.co_argcount.__eq__(1) == True — singledispatch takes a single positional argument (func, the function to be dispatched); co_argcount is 1; int.__eq__(1) returns True; new to extra99"]
    - [singledispatch_module_eq_functools,
       "singledispatch.__module__.__eq__",
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra99"]

# ---------------------------------------------------------------------------
# Table 2: singledispatch/singledispatchmethod class names and qualnames
#
# Wave 254 theme: singledispatch wrapper attrs and singledispatchmethod identity.
#
# singledispatch-wrapped function's .dispatch.__class__.__name__.__eq__('function') == True
# singledispatch-wrapped function's .register.__class__.__name__.__eq__('function') == True
# singledispatch-wrapped function's .registry.__class__.__name__.__eq__('mappingproxy') == True
# functools.singledispatchmethod.__class__.__name__.__eq__('type') == True
# functools.singledispatchmethod.__qualname__.__eq__('singledispatchmethod') == True
#
# A @singledispatch-decorated function gains .dispatch, .register, and .registry attributes.
# singledispatchmethod is a class (type), not a function. New to extra99.
# ---------------------------------------------------------------------------

table functools_extra99.singledispatch_wrapper_attrs:
  description: "singledispatch wrapper .dispatch/.register/.registry class names; singledispatchmethod class name and qualname; wave 254; new to extra99"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolssingledispatch99

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_qualname_len_14,
       "singledispatch.__qualname__.__len__",
       [],
       14,
       "functools.singledispatch.__qualname__.__len__() == 14 — __qualname__ is 'singledispatch' (14 characters); singledispatch is defined at module scope so qualname equals the def name; len('singledispatch') == 14; new to extra99"]
    - [singledispatchmethod_class_name_eq_type,
       "singledispatchmethod.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.singledispatchmethod.__class__.__name__.__eq__('type') == True — singledispatchmethod is a Python class (not a function) defined in Lib/functools.py; its metaclass is <class 'type'>; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra99"]
    - [singledispatchmethod_name_eq,
       "singledispatchmethod.__name__.__eq__",
       ["singledispatchmethod"],
       true,
       "functools.singledispatchmethod.__name__.__eq__('singledispatchmethod') == True — singledispatchmethod is a class defined with 'class singledispatchmethod:' in Lib/functools.py; __name__ is 'singledispatchmethod'; str.__eq__('singledispatchmethod') returns True; new to extra99"]
    - [singledispatchmethod_qualname_eq,
       "singledispatchmethod.__qualname__.__eq__",
       ["singledispatchmethod"],
       true,
       "functools.singledispatchmethod.__qualname__.__eq__('singledispatchmethod') == True — singledispatchmethod is defined at module scope; its __qualname__ is the simple class name 'singledispatchmethod'; str.__eq__('singledispatchmethod') returns True; new to extra99"]
    - [singledispatchmethod_module_eq_functools,
       "singledispatchmethod.__module__.__eq__",
       ["functools"],
       true,
       "functools.singledispatchmethod.__module__.__eq__('functools') == True — singledispatchmethod is defined in Lib/functools.py; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra99"]

# ---------------------------------------------------------------------------
# Table 3: functools module identity (__name__, __package__)
#
# Wave 254 theme: functools module string identity attributes.
#
# functools.__name__.__eq__('functools') == True
# functools.__package__.__eq__('') == True
# functools.__doc__.__class__.__name__.__eq__('str') == True
#
# functools is a top-level standard library module; __package__ is empty string.
# New to extra99.
# ---------------------------------------------------------------------------

table functools_extra99.module_string_identity:
  description: "functools.__name__, __package__, __doc__ class name; top-level stdlib module; wave 254; new to extra99"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolssingledispatch99

  columns: [id, function, args, expected, description]
  rows:
    - [functools_name_eq_functools,
       "__name__.__eq__",
       ["functools"],
       true,
       "functools.__name__.__eq__('functools') == True — the functools module's __name__ attribute reflects its dotted module name; for a top-level module like functools it is just 'functools'; str.__eq__('functools') returns True; new to extra99"]
    - [functools_package_eq_empty,
       "__package__.__eq__",
       [""],
       true,
       "functools.__package__.__eq__('') == True — functools is a top-level module (not inside a package); its __package__ attribute is the empty string ''; str.__eq__('') returns True; new to extra99"]
    - [functools_doc_class_name_eq_str,
       "__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.__doc__.__class__.__name__.__eq__('str') == True — functools has a module-level docstring; the __doc__ attribute is a plain Python string; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra99"]

# ---------------------------------------------------------------------------
# Table 4: functools.__spec__ and __loader__ class names
#
# Wave 254 theme: functools import machinery attributes.
#
# functools.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True
# functools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True
#
# functools is a pure-Python module loaded by importlib's SourceFileLoader.
# __spec__ is a ModuleSpec instance from importlib._bootstrap. New to extra99.
# ---------------------------------------------------------------------------

table functools_extra99.module_spec_loader:
  description: "functools.__loader__.__class__.__name__ == 'SourceFileLoader'; functools.__spec__.__class__.__name__ == 'ModuleSpec'; import machinery attrs; wave 254; new to extra99"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolssingledispatch99

  columns: [id, function, args, expected, description]
  rows:
    - [functools_loader_class_name_eq_SourceFileLoader,
       "__loader__.__class__.__name__.__eq__",
       ["SourceFileLoader"],
       true,
       "functools.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — functools is a pure-Python source module (Lib/functools.py); it is loaded by importlib.machinery.SourceFileLoader; __loader__.__class__.__name__ is 'SourceFileLoader'; str.__eq__('SourceFileLoader') returns True; new to extra99"]
    - [functools_spec_class_name_eq_ModuleSpec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "functools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — every importable module has a __spec__ attribute that is an importlib.machinery.ModuleSpec instance; __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra99"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra99
# ---------------------------------------------------------------------------

invariant functools_extra99.singledispatch_class_name:
  description: "functools.singledispatch.__class__.__name__ == 'function' — pure-Python decorator factory; wave 254; new to extra99"
  kind: python_call_eq
  function: singledispatch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra99.singledispatch_co_argcount:
  description: "functools.singledispatch.__code__.co_argcount == 1 — takes single argument func; wave 254; new to extra99"
  kind: python_call_eq
  function: singledispatch.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant functools_extra99.singledispatchmethod_class_name:
  description: "functools.singledispatchmethod.__class__.__name__ == 'type' — singledispatchmethod is a class not a function; wave 254; new to extra99"
  kind: python_call_eq
  function: singledispatchmethod.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra99.functools_name_eq_functools:
  description: "functools.__name__ == 'functools' — top-level stdlib module identity; wave 254; new to extra99"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra99.functools_loader_class_name:
  description: "functools.__loader__.__class__.__name__ == 'SourceFileLoader' — pure-Python source module; wave 254; new to extra99"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true
