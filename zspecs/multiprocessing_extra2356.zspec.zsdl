spec: multiprocessing_extra2356
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes:
    - "Checks .__init__.__class__.__name__ and .__new__.__class__.__name__ for multiprocessing classes"
    - "Both Process and Pool are pure Python and define custom __init__ — class name is 'function'"
    - "Both classes inherit __new__ from object — class name is 'builtin_function_or_method'"
  created_at: "2026-04-12"
error_model: python_exceptions

table multiprocessing_extra2356.process_init_type:
  description: "__init__ and __new__ implementation type for multiprocessing.Process (pure Python)"
  kind: python_call_eq
  category: init_type
  id_prefix: mp2356
  columns: [id, function, args, expected]
  rows:
    - ["mp2356001", multiprocessing.Process.__init__.__class__.__name__.__eq__, ["function"],                 true]
    - ["mp2356002", multiprocessing.Process.__new__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]

table multiprocessing_extra2356.pool_init_type:
  description: "__init__ and __new__ implementation type for multiprocessing.pool.Pool (pure Python)"
  kind: python_call_eq
  category: init_type
  id_prefix: mp2356
  columns: [id, function, args, expected]
  rows:
    - ["mp2356003", multiprocessing.pool.Pool.__init__.__class__.__name__.__eq__, ["function"],                 true]
    - ["mp2356004", multiprocessing.pool.Pool.__new__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]

table multiprocessing_extra2356.init_type_contrast:
  description: "Contrast: both Process and Pool use custom Python __init__ (not C wrapper_descriptor)"
  kind: python_call_eq
  category: init_type
  id_prefix: mp2356
  columns: [id, function, args, expected]
  rows:
    - ["mp2356005",  multiprocessing.Process.__init__.__class__.__name__.__eq__,   ["wrapper_descriptor"],       false]
    - ["mp2356006",  multiprocessing.pool.Pool.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"],       false]
    - ["mp2356007",  multiprocessing.Process.__new__.__class__.__name__.__eq__,    ["wrapper_descriptor"],       false]
    - ["mp2356008",  multiprocessing.pool.Pool.__new__.__class__.__name__.__eq__,  ["wrapper_descriptor"],       false]
    - ["mp2356009",  multiprocessing.Process.__init__.__class__.__name__.__eq__,   ["function"],                 true]
    - ["mp2356010",  multiprocessing.pool.Pool.__init__.__class__.__name__.__eq__, ["function"],                 true]
    - ["mp2356011",  multiprocessing.Process.__new__.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - ["mp2356012",  multiprocessing.pool.Pool.__new__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]

table multiprocessing_extra2356.init_class_identity:
  description: "Confirm __init__ __class__ identity using __class__.__name__ string equality"
  kind: python_call_eq
  category: init_type
  id_prefix: mp2356
  columns: [id, function, args, expected]
  rows:
    - ["mp2356013",  multiprocessing.Process.__init__.__class__.__name__.__eq__,   ["slot_wrapper"],  false]
    - ["mp2356014",  multiprocessing.pool.Pool.__init__.__class__.__name__.__eq__, ["slot_wrapper"],  false]
    - ["mp2356015",  multiprocessing.Process.__init__.__class__.__name__.__eq__,   ["method-wrapper"], false]
    - ["mp2356016",  multiprocessing.pool.Pool.__init__.__class__.__name__.__eq__, ["method-wrapper"], false]
    - ["mp2356017",  multiprocessing.Process.__new__.__class__.__name__.__eq__,    ["function"],       false]
    - ["mp2356018",  multiprocessing.pool.Pool.__new__.__class__.__name__.__eq__,  ["function"],       false]
    - ["mp2356019",  multiprocessing.Process.__init__.__class__.__name__.__eq__,   ["function"],       true]
    - ["mp2356020",  multiprocessing.pool.Pool.__init__.__class__.__name__.__eq__, ["function"],       true]
