spec: uuid_extra68
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra67.zspec.zsdl — covers NAMESPACE_DNS/URL/__class__/__name__=='UUID' / RESERVED_NCS/__contains__('NCS') / RFC_4122/__contains__('RFC') / RESERVED_MICROSOFT/__contains__('Microsoft') / RESERVED_FUTURE/__contains__('future') / UUID/__repr__/__code__/co_name=='__repr__' (table + invariants)."
    - "uuid_extra66.zspec.zsdl — covers UUID/__init__/__code__/co_varnames/__class__/__name__=='tuple'/__len__()==15 / SafeUUID/__name__/__module__/__class__/__name__/'EnumType'/__qualname__ / UUID/__str__/uuid4/uuid1 co_varnames class (table + invariants)."
    - "uuid_extra60.zspec.zsdl — covers UUID/__repr__/__str__/__hash__/__eq__/__code__/co_name and co_argcount / SafeUUID class identity (__class__/__name__=='type'/__module__=='uuid'/__qualname__=='SafeUUID') / SafeUUID/__bases__[0]/__name__=='IntEnum' (table + invariants)."
    - "uuid_extra56.zspec.zsdl — covers uuid4/uuid1/__code__/co_varnames/__class__/__name__=='tuple' (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra67; it does NOT duplicate invariants present in those files."
    - "Wave 243 theme: UUID __repr__/__eq__ co_varnames class + uuid3/uuid5 co_varnames class + SafeUUID.__doc__ + UUID co_flags class."
    - "uuid.UUID.__repr__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple for Python code objects; no prior uuid spec checks UUID.__repr__.__code__.co_varnames. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__code__.co_varnames.__class__.__name__ == 'tuple' — no prior uuid spec checks UUID.__eq__.__code__.co_varnames. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__code__.co_varnames.__class__.__name__ == 'tuple' — no prior uuid spec checks uuid3.__code__.co_varnames. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__code__.co_varnames.__class__.__name__ == 'tuple' — no prior uuid spec checks uuid5.__code__.co_varnames. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__doc__.__class__.__name__ == 'str' — SafeUUID is an IntEnum class; its __doc__ is 'An enumeration.' which is a str. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_flags.__class__.__name__ == 'int' — co_flags is always an int for Python code objects. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__code__.co_flags.__class__.__name__ == 'int' — co_flags is an int for UUID.__str__ code object. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__ and UUID.__eq__ __code__.co_varnames class name
#
# Wave 243 theme: UUID method code object co_varnames class identity.
#
# co_varnames is always a tuple for Python code objects. uuid_extra66 covers
# UUID.__init__, UUID.__str__, uuid4, and uuid1 co_varnames class. No prior
# uuid spec checks co_varnames class for UUID.__repr__ or UUID.__eq__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra68.UUID_repr_eq_co_varnames_class:
  description: "uuid.UUID/__repr__/__code__/co_varnames/__class__/__name__.__eq__('tuple')==True / UUID/__eq__/__code__/co_varnames/__class__/__name__.__eq__('tuple')==True — co_varnames is always a tuple for Python code objects; uuid_extra66 covers UUID.__init__/UUID.__str__/uuid4/uuid1; no prior uuid spec checks co_varnames class for UUID.__repr__ or UUID.__eq__; first co_varnames class anchor for UUID.__repr__ and UUID.__eq__"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidmore68

  columns: [id, function, args, expected]
  rows:
    - [UUID_repr_co_varnames_class_tuple, UUID.__repr__.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true]
    - [UUID_eq_co_varnames_class_tuple,   UUID.__eq__.__code__.co_varnames.__class__.__name__.__eq__,   ["tuple"], true]

# ---------------------------------------------------------------------------
# uuid.uuid3 and uuid5 __code__.co_varnames class name
#
# Wave 243 theme: uuid3 and uuid5 co_varnames class identity.
#
# uuid3 and uuid5 are pure-Python functions in Lib/uuid.py; their code objects'
# co_varnames are tuples. uuid_extra56 covers uuid4 and uuid1 co_varnames class.
# No prior uuid spec checks co_varnames class for uuid3 or uuid5.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra68.uuid3_uuid5_co_varnames_class:
  description: "uuid.uuid3/__code__/co_varnames/__class__/__name__.__eq__('tuple')==True / uuid5/__code__/co_varnames/__class__/__name__.__eq__('tuple')==True — co_varnames is always a tuple for Python code objects; uuid_extra56 covers uuid4/uuid1; no prior uuid spec checks co_varnames class for uuid3 or uuid5; first co_varnames class anchor for uuid3 and uuid5"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidmore68

  columns: [id, function, args, expected]
  rows:
    - [uuid3_co_varnames_class_tuple, uuid3.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true]
    - [uuid5_co_varnames_class_tuple, uuid5.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__doc__.__class__.__name__ == 'str'
#
# Wave 243 theme: SafeUUID docstring class identity.
#
# uuid.SafeUUID is an IntEnum subclass; its __doc__ is 'An enumeration.' which
# is a plain str. No prior uuid spec checks SafeUUID.__doc__ or
# SafeUUID.__doc__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra68.SafeUUID_doc_class:
  description: "uuid.SafeUUID/__doc__/__class__/__name__.__eq__('str')==True — SafeUUID is an IntEnum subclass; its __doc__ is 'An enumeration.' (a str); no prior uuid spec checks SafeUUID.__doc__ or SafeUUID.__doc__.__class__.__name__; first __doc__ class anchor for SafeUUID"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidmore68

  columns: [id, function, args, expected]
  rows:
    - [SafeUUID_doc_class_str, SafeUUID.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__ and UUID.__str__ __code__.co_flags class name
#
# Wave 243 theme: UUID method code object co_flags class identity.
#
# co_flags is always an int for Python code objects. No prior uuid spec checks
# co_flags class for any UUID method. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra68.UUID_init_str_co_flags_class:
  description: "uuid.UUID/__init__/__code__/co_flags/__class__/__name__.__eq__('int')==True / UUID/__str__/__code__/co_flags/__class__/__name__.__eq__('int')==True — co_flags is always an int for Python code objects; no prior uuid spec checks co_flags class for UUID.__init__ or UUID.__str__; first co_flags class anchor for UUID methods"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidmore68

  columns: [id, function, args, expected]
  rows:
    - [UUID_init_co_flags_class_int, UUID.__init__.__code__.co_flags.__class__.__name__.__eq__, ["int"], true]
    - [UUID_str_co_flags_class_int,  UUID.__str__.__code__.co_flags.__class__.__name__.__eq__,  ["int"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__.__code__.co_varnames.__class__.__name__.__eq__('tuple') — standalone
#
# UUID.__repr__ is a Python function; co_varnames is a tuple. No prior uuid
# spec checks co_varnames class for UUID.__repr__. First co_varnames class
# standalone for UUID.__repr__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra68.UUID_repr_co_varnames_class_tuple:
  description: "uuid.UUID.__repr__.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is a tuple for Python code objects; no prior uuid spec checks co_varnames class for UUID.__repr__; first co_varnames class standalone for UUID.__repr__"
  category: code_attrs
  kind: python_call_eq
  function: UUID.__repr__.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__eq__.__code__.co_varnames.__class__.__name__.__eq__('tuple') — standalone
#
# UUID.__eq__ is a Python function; co_varnames is a tuple. No prior uuid
# spec checks co_varnames class for UUID.__eq__. First co_varnames class
# standalone for UUID.__eq__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra68.UUID_eq_co_varnames_class_tuple:
  description: "uuid.UUID.__eq__.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is a tuple for Python code objects; no prior uuid spec checks co_varnames class for UUID.__eq__; first co_varnames class standalone for UUID.__eq__"
  category: code_attrs
  kind: python_call_eq
  function: UUID.__eq__.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid3.__code__.co_varnames.__class__.__name__.__eq__('tuple') — standalone
#
# uuid3 is a Python function; co_varnames is a tuple. No prior uuid spec
# checks co_varnames class for uuid3. First co_varnames class standalone for
# uuid3. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra68.uuid3_co_varnames_class_tuple:
  description: "uuid.uuid3.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is a tuple for Python code objects; no prior uuid spec checks co_varnames class for uuid3; first co_varnames class standalone for uuid3"
  category: code_attrs
  kind: python_call_eq
  function: uuid3.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__doc__.__class__.__name__.__eq__('str') — standalone
#
# SafeUUID.__doc__ is 'An enumeration.' which is a str. No prior uuid spec
# checks SafeUUID.__doc__ or SafeUUID.__doc__.__class__.__name__. First
# __doc__ class standalone for SafeUUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra68.SafeUUID_doc_class_str:
  description: "uuid.SafeUUID.__doc__.__class__.__name__.__eq__('str') == True — SafeUUID.__doc__ is 'An enumeration.' (a str); no prior uuid spec checks SafeUUID.__doc__ or SafeUUID.__doc__.__class__.__name__; first __doc__ class standalone for SafeUUID"
  category: class_attrs
  kind: python_call_eq
  function: SafeUUID.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_flags.__class__.__name__.__eq__('int') — standalone
#
# UUID.__init__ is a Python function; co_flags is an int. No prior uuid spec
# checks co_flags class for any UUID method. First co_flags class standalone
# for UUID.__init__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra68.UUID_init_co_flags_class_int:
  description: "uuid.UUID.__init__.__code__.co_flags.__class__.__name__.__eq__('int') == True — co_flags is an int for Python code objects; no prior uuid spec checks co_flags class for UUID.__init__; first co_flags class standalone for UUID.__init__"
  category: code_attrs
  kind: python_call_eq
  function: UUID.__init__.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true
