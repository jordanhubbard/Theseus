spec: in3361
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 671 (in3361): __invert__, __floor__, __ceil__ dict-presence checks for inspect types."
    - "Theme: __invert__/__floor__/__ceil__ dict-presence (unary ~x, math.floor(x), math.ceil(x))."
    - "All values False — inspect introspection types have no numeric protocol support."
    - "No inspect type defines __invert__, __floor__, or __ceil__ in its own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "None of these types implement bitwise inversion or rounding protocols directly."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3361.invert:
  description: "inspect types __invert__ dict-presence checks; wave 671"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3361
  columns: [id, function, args, expected]
  rows:
    - ["in3361001", operator.contains, [inspect.Parameter.__dict__,           "__invert__"], false]
    - ["in3361002", operator.contains, [inspect.Signature.__dict__,           "__invert__"], false]
    - ["in3361003", operator.contains, [inspect.BoundArguments.__dict__,      "__invert__"], false]
    - ["in3361004", operator.contains, [inspect.FrameInfo.__dict__,           "__invert__"], false]
    - ["in3361005", operator.contains, [inspect.ArgInfo.__dict__,             "__invert__"], false]
    - ["in3361006", operator.contains, [inspect.FullArgSpec.__dict__,         "__invert__"], false]
    - ["in3361007", operator.contains, [inspect.Attribute.__dict__,           "__invert__"], false]
    - ["in3361008", operator.contains, [inspect.ClassFoundException.__dict__, "__invert__"], false]
    - ["in3361009", operator.contains, [inspect.EndOfBlock.__dict__,          "__invert__"], false]

