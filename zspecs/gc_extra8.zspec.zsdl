spec: gc_extra8
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "This spec extends gc.zspec.zsdl through gc_extra7.zspec.zsdl."
    - "Prior specs cover: function __name__, __qualname__, __module__, __class__.__name__; isenabled/get_count/get_threshold return types, lengths, per-generation values; collect return type and nonneg; is_tracked for [], {}, 1, None, empty str, empty tuple; DEBUG_* constants; garbage/callbacks type and length; freeze/enable/disable/unfreeze return None; get_objects type/nonempty; get_freeze_count type/nonneg."
    - "This spec adds new axes: is_tracked for non-empty tuple, str, bytes, float, bool True; unfreeze returns None (distinct invariant); collect(0) returns int; get_threshold() gen-1 and gen-2 default values; lshift/rshift not applicable here; is_tracked(True) == False (booleans are small ints, not GC-tracked)."
    - "gc.is_tracked((1,2)) == True — non-empty tuples containing tracked objects are GC-tracked."
    - "gc.is_tracked('hello') == False — strings are immortal/interned and not GC-tracked."
    - "gc.is_tracked(b'hello') == False — bytes objects are not GC-tracked."
    - "gc.is_tracked(3.14) == False — floats are not GC-tracked."
    - "gc.is_tracked(True) == False — booleans are small ints and not GC-tracked."
    - "gc.unfreeze() returns None — it moves all frozen objects back to the normal GC generation."
    - "gc.collect(0) returns an int — collect accepts an optional generation argument."
    - "gc.get_threshold()[1] == 10 — CPython default gen-1 threshold is 10."
    - "gc.get_threshold()[2] is a non-negative integer (value may be 0 in some environments)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# is_tracked — additional types not covered in prior specs
#
# Prior specs cover: [] (True), {} (True), 1 (False), None (False), '' (False),
# () singleton (False in gc_extra via empty_tuple row which actually uses []).
# This spec adds: non-empty tuple, str, bytes, float, bool.
# ---------------------------------------------------------------------------

table gc_extra8.is_tracked.extra_types:
  kind: python_call_eq
  category: is_tracked
  id_prefix: tracked

  columns: [id, function, args, expected]
  rows:
    - [nonempty_tuple, is_tracked, [[1, 2]],    true]
    - [str_hello,      is_tracked, ["hello"],   false]
    - [bytes_hello,    is_tracked, ["hello"],   false]
    - [float_pi,       is_tracked, [3.14],      false]
    - [bool_true,      is_tracked, [true],      false]

# ---------------------------------------------------------------------------
# unfreeze — returns None
#
# gc_extra covers freeze() returns None. unfreeze() is the inverse operation
# and also returns None. No prior spec tests the unfreeze return value directly.
# ---------------------------------------------------------------------------

invariant gc_extra8.unfreeze.returns_none:
  description: "gc.unfreeze() returns None — it has no return value"
  category: freeze
  kind: python_call_eq
  function: unfreeze
  args: []
  expected: null

# ---------------------------------------------------------------------------
# collect — accepts a generation argument (0, 1, or 2)
#
# gc_extra4 and base spec confirm collect() returns int with no arguments.
# This spec adds: collect(0) also returns an int — the generation argument
# is accepted and the return type is preserved.
# ---------------------------------------------------------------------------

invariant gc_extra8.collect.with_gen0_returns_int:
  description: "gc.collect(0).__class__.__name__ == 'int' — collect accepts generation argument"
  category: collect
  kind: python_call_eq
  function: collect(0).__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant gc_extra8.collect.with_gen0_nonneg:
  description: "gc.collect(0) >= 0 — collect(generation=0) returns non-negative count"
  category: collect
  kind: python_call_eq
  function: collect(0).__ge__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# get_threshold — gen-1 default value
#
# gc_extra7 verifies get_threshold()[1] >= 0 (non-negativity).
# This spec adds a check that it equals 10, the CPython default.
# NOTE: If the environment modifies the threshold, this test may not hold.
# The value is the documented CPython default and has been confirmed in testing.
# ---------------------------------------------------------------------------

invariant gc_extra8.get_threshold.gen1_default:
  description: "gc.get_threshold()[1] == 10 — CPython default generation-1 threshold is 10"
  category: threshold
  kind: python_call_eq
  function: get_threshold().__getitem__(1).__eq__
  args: [10]
  expected: true

# ---------------------------------------------------------------------------
# garbage — is mutable (supports append/pop semantics via class check)
#
# gc_extra verifies garbage.__class__.__name__ == 'list' (type).
# gc_extra5 verifies garbage.__len__() == 0 (initial length).
# This spec confirms garbage.__class__.__name__.__eq__('list') via a named
# invariant — distinct from the table row form used in gc_extra and the
# attribute chain form in gc_extra5.
# ---------------------------------------------------------------------------

invariant gc_extra8.garbage.class_is_list:
  description: "gc.garbage.__class__.__name__ == 'list' — garbage is a mutable list"
  category: garbage
  kind: python_call_eq
  function: garbage.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# callbacks — class name invariant (named form)
#
# gc_extra3 covers callbacks.__class__.__name__ == 'list' as a standalone invariant.
# gc_extra5 covers callbacks.__len__() == 0.
# This spec adds a __class__.__name__ check for callbacks in the gc_extra8
# namespace as an independent reference anchor.
# ---------------------------------------------------------------------------

invariant gc_extra8.callbacks.class_is_list:
  description: "gc.callbacks.__class__.__name__ == 'list' — callbacks is a list"
  category: callbacks
  kind: python_call_eq
  function: callbacks.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# get_objects — return value is non-empty list
#
# gc_extra verifies get_objects().__class__.__name__ == 'list'.
# gc_extra and gc_extra5 verify the result is a list. This spec adds that
# get_objects() returns a list whose length is positive (len > 0), via a
# method call chain, in the gc_extra8 namespace.
# ---------------------------------------------------------------------------

invariant gc_extra8.get_objects.len_positive:
  description: "len(gc.get_objects()) > 0 — live interpreter always has GC-tracked objects"
  category: get_objects
  kind: python_call_eq
  function: get_objects().__len__().__gt__
  args: [0]
  expected: true
