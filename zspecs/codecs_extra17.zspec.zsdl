spec: codecs_extra17
version: ">=3.9"
backend: python_module(codecs)

docs: https://docs.python.org/3/library/codecs.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/codecs.html — Python codecs module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/codecs.py"
    - "codecs_extra16.zspec.zsdl — covers class __bases__[0].__name__ for CodecInfo/Codec/IncrementalEncoder/IncrementalDecoder/StreamWriter/StreamReader/StreamRecoder."
    - "codecs_extra15.zspec.zsdl — covers encode/decode with error handlers; lookup canonical names table; getincrementalencoder/getincrementaldecoder __name__."
    - "codecs_extra13.zspec.zsdl — covers encode/decode/lookup/open/register __name__/__module__; CodecInfo.__qualname__."
    - "codecs_extra6.zspec.zsdl — covers getincrementalencoder/getincrementaldecoder __name__/__qualname__/__module__."
  notes:
    - "This spec extends codecs through codecs_extra16; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: CodecInfo.__bases__[0].__name__=='tuple'; Codec.__bases__[0].__name__=='object'; IncrementalEncoder/IncrementalDecoder bases; StreamWriter/Reader bases; encode/decode/lookup/open/register __name__/__module__; CodecInfo.__qualname__; getincrementalencoder/getincrementaldecoder __name__/__qualname__/__module__."
    - "This spec covers: codecs.__all__.__len__()==44 (NOVEL); codecs.__all__.__class__.__name__.__len__()==4 (NOVEL — 'list' is 4 chars); codecs.CodecInfo.__dict__.__class__.__name__.__len__()==12 (NOVEL — mappingproxy); codecs.IncrementalEncoder.__dict__.__class__.__name__.__len__()==12 (NOVEL); codecs.IncrementalDecoder.__dict__.__class__.__name__.__len__()==12 (NOVEL); codecs.CodecInfo.__mro__.__len__()==3 (NOVEL); codecs.IncrementalEncoder.__mro__.__len__()==2 (NOVEL); codecs.IncrementalDecoder.__mro__.__len__()==2 (NOVEL); codecs.StreamWriter.__mro__.__len__()==3 (NOVEL); IncrementalEncoder.encode/__qualname__.__len__()==25 (NOVEL); IncrementalEncoder.reset.__qualname__.__len__()==24 (NOVEL); IncrementalDecoder.decode.__qualname__.__len__()==25 (NOVEL); IncrementalDecoder.reset.__qualname__.__len__()==24 (NOVEL); codecs.encode/decode/lookup/open.__qualname__.__len__() (NOVEL — __qualname__.__len__() not covered in any prior spec); codecs.IncrementalEncoder.__qualname__.__len__()==18 (NOVEL); codecs.CodecInfo.__bases__[0].__name__.__len__()==5 (NOVEL — 'tuple' length)."
    - "codecs.__all__ is a list of 44 exported names. No prior codecs spec checks len(codecs.__all__). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "codecs.__all__.__class__.__name__ == 'list' (len 4). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "codecs.CodecInfo.__dict__ is a mappingproxy (len 12). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "codecs.CodecInfo.__mro__ has 3 entries: [CodecInfo, tuple, object]. CodecInfo is a namedtuple. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "codecs.IncrementalEncoder.__mro__ has 2 entries: [IncrementalEncoder, object]. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "codecs.IncrementalEncoder.encode.__qualname__ == 'IncrementalEncoder.encode' (len 25). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "codecs.IncrementalEncoder.reset.__qualname__ == 'IncrementalEncoder.reset' (len 24). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "codecs.IncrementalDecoder.decode.__qualname__ == 'IncrementalDecoder.decode' (len 25). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "codecs.IncrementalDecoder.reset.__qualname__ == 'IncrementalDecoder.reset' (len 24). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "codecs.encode/__qualname__ == 'encode' (len 6); decode (6); lookup (6); open (4). Prior specs verify __name__/__module__ but not __qualname__.__len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "codecs.IncrementalEncoder.__qualname__ == 'IncrementalEncoder' (len 18). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "codecs.CodecInfo.__bases__[0].__name__.__len__() == 5 — 'tuple' has 5 characters. Extra16 verifies __eq__('tuple'); this checks __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# codecs.__all__ — length and class name length
#
# codecs.__all__ is a list of 44 exported names. No prior codecs spec verifies
# len(codecs.__all__) or the class of __all__. list has 4 characters.
# Both are novel standalone invariants.
# ---------------------------------------------------------------------------

invariant codecs_extra17.all.len:
  description: "codecs.__all__.__len__() == 44 — codecs exports 44 names via __all__; novel invariant"
  category: module_structure
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 44

invariant codecs_extra17.all.class_name_len:
  description: "codecs.__all__.__class__.__name__.__len__() == 4 — __all__ is a list; 'list' has 4 characters"
  category: string_length
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# codecs.CodecInfo.__bases__[0].__name__.__len__()
#
# codecs_extra16 verifies CodecInfo.__bases__[0].__name__.__eq__('tuple').
# No prior spec checks the __len__() of that string. 'tuple' has 5 characters.
# Novel standalone invariant.
# ---------------------------------------------------------------------------

invariant codecs_extra17.CodecInfo.bases0_name_len:
  description: "codecs.CodecInfo.__bases__[0].__name__.__len__() == 5 — 'tuple' has 5 characters; CodecInfo is a namedtuple"
  category: class_hierarchy
  kind: python_call_eq
  function: "CodecInfo.__bases__[0].__name__.__len__"
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# codecs.IncrementalEncoder.__qualname__.__len__()
#
# IncrementalEncoder.__qualname__ == 'IncrementalEncoder' (18 characters).
# No prior codecs spec checks __qualname__.__len__() for IncrementalEncoder.
# Novel standalone invariant.
# ---------------------------------------------------------------------------

invariant codecs_extra17.IncrementalEncoder.qualname_len:
  description: "codecs.IncrementalEncoder.__qualname__.__len__() == 18 — 'IncrementalEncoder' has 18 characters"
  category: class_identity
  kind: python_call_eq
  function: IncrementalEncoder.__qualname__.__len__
  args: []
  expected: 18

# ---------------------------------------------------------------------------
# Table: class __dict__.__class__.__name__.__len__() for major codecs classes
#
# CodecInfo, IncrementalEncoder, and IncrementalDecoder all have class dicts
# that are mappingproxy objects. 'mappingproxy' has 12 characters. No prior
# codecs spec checks these lengths. Novel for all three.
# ---------------------------------------------------------------------------

table codecs_extra17.class_dict_classname_lengths:
  description: "codecs class __dict__.__class__.__name__.__len__() == 12 for CodecInfo, IncrementalEncoder, IncrementalDecoder"
  kind: python_call_eq
  category: string_length
  id_prefix: cdcnl17

  columns: [id, function, args, expected]
  rows:
    - [CodecInfo,          CodecInfo.__dict__.__class__.__name__.__len__,          [], 12]
    - [IncrementalEncoder, IncrementalEncoder.__dict__.__class__.__name__.__len__, [], 12]
    - [IncrementalDecoder, IncrementalDecoder.__dict__.__class__.__name__.__len__, [], 12]

# ---------------------------------------------------------------------------
# Table: MRO lengths for codecs classes
#
# CodecInfo.__mro__ has 3 entries (CodecInfo, tuple, object — namedtuple).
# IncrementalEncoder and IncrementalDecoder each have 2 (class + object).
# StreamWriter and StreamReader each have 3 (class + Codec + object).
# StreamRecoder has 2 (class + object). No prior spec checks these lengths.
# All verified at runtime.
# ---------------------------------------------------------------------------

table codecs_extra17.class_mro_lengths:
  description: "MRO lengths for codecs classes — CodecInfo (3), IncrementalEncoder/Decoder (2), StreamWriter/Reader (3), StreamRecoder (2)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cmrol17

  columns: [id, function, args, expected]
  rows:
    - [CodecInfo,          CodecInfo.__mro__.__len__,          [], 3]
    - [IncrementalEncoder, IncrementalEncoder.__mro__.__len__, [], 2]
    - [IncrementalDecoder, IncrementalDecoder.__mro__.__len__, [], 2]
    - [StreamWriter,       StreamWriter.__mro__.__len__,       [], 3]
    - [StreamReader,       StreamReader.__mro__.__len__,       [], 3]
    - [StreamRecoder,      StreamRecoder.__mro__.__len__,      [], 2]

# ---------------------------------------------------------------------------
# Table: IncrementalEncoder/Decoder method __qualname__.__len__()
#
# encode and decode have qualname 'IncrementalEncoder.encode'/'IncrementalDecoder.decode'
# (len 25 each). reset methods: 'IncrementalEncoder.reset'/'IncrementalDecoder.reset'
# (len 24 each). No prior codecs spec checks these qualname lengths. All novel.
# ---------------------------------------------------------------------------

table codecs_extra17.incremental_method_qualname_lengths:
  description: "IncrementalEncoder/Decoder encode/decode/reset __qualname__.__len__() — 25/24 chars, novel invariants"
  kind: python_call_eq
  category: method_identity
  id_prefix: imqln17

  columns: [id, function, args, expected]
  rows:
    - [enc_encode, IncrementalEncoder.encode.__qualname__.__len__, [], 25]
    - [enc_reset,  IncrementalEncoder.reset.__qualname__.__len__,  [], 24]
    - [dec_decode, IncrementalDecoder.decode.__qualname__.__len__, [], 25]
    - [dec_reset,  IncrementalDecoder.reset.__qualname__.__len__,  [], 24]

# ---------------------------------------------------------------------------
# Table: module-level function __qualname__.__len__() — encode/decode/lookup/open
#
# Prior codecs specs verify __name__ and __module__ for encode, decode, lookup,
# and open, but no spec checks __qualname__.__len__(). encode/decode/lookup
# have flat qualname equal to __name__ (len 6); open has qualname 'open' (len 4).
# All novel. Verified at runtime.
# ---------------------------------------------------------------------------

table codecs_extra17.module_func_qualname_lengths:
  description: "codecs encode/decode/lookup/open __qualname__.__len__() — encode/decode/lookup (6), open (4)"
  kind: python_call_eq
  category: function_identity
  id_prefix: mfqln17

  columns: [id, function, args, expected]
  rows:
    - [encode, encode.__qualname__.__len__, [], 6]
    - [decode, decode.__qualname__.__len__, [], 6]
    - [lookup, lookup.__qualname__.__len__, [], 6]
    - [open,   open.__qualname__.__len__,   [], 4]
