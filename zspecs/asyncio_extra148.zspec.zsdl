spec: asyncio_extra148
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
  notes:
    - "This spec covers asyncio.__all__ — a tuple (not list) of length 95. asyncio.__all__.__class__.__name__=='tuple' (containers like list return 'list', but asyncio uses a tuple for __all__). asyncio.__all__.__len__()==95. Key members verified: 'run', 'sleep', 'Task', 'Future', 'Queue', 'Lock', 'gather', 'create_task', 'wait', 'timeout', 'Event', 'Semaphore'. asyncio.__spec__.name=='asyncio' (len=3: 'a'=1+'s'=1+'y'=1+'n'=1+'c'=1+'i'=1+'o'=1=7; actually len=7). asyncio.__name__=='asyncio' (len=7). asyncio.__package__=='asyncio' (len=7). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.__all__ is a tuple, not a list. asyncio.__all__.__class__.__name__=='tuple'. asyncio.__all__.__len__()==95. asyncio.__spec__.name.__len__()==7. All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.__all__ type and size — extra148
#
# asyncio.__all__.__class__.__name__ == 'tuple'   (NOT 'list')
# asyncio.__all__.__len__()          == 95
# asyncio.__spec__.name.__eq__('asyncio') == True (len=7)
# asyncio.__name__.__len__()         == 7
# asyncio.__package__.__eq__('asyncio') == True
# ---------------------------------------------------------------------------

table asyncio_extra148.asyncio_all_type_and_size:
  description: "asyncio.__all__ type and size checks in asyncio_all148 namespace — asyncio.__all__.__class__.__name__=='tuple' (asyncio exports its public API as a tuple, not a list); asyncio.__all__.__len__()==95 (95 public names exported by the asyncio package); asyncio.__spec__.name.__eq__('asyncio')==True (len=7: the import system name for the package); asyncio.__spec__.name.__len__()==7; asyncio.__name__.__eq__('asyncio')==True (the module's own __name__ attribute); asyncio.__name__.__len__()==7; asyncio.__package__.__eq__('asyncio')==True (the package that asyncio belongs to, which is itself since asyncio is a package); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: asyncio_all148

  columns: [id, function, args, expected, description]
  rows:
    - [all_cls_eq,   asyncio.__all__.__class__.__name__.__eq__,  ["tuple"],    true,  "asyncio.__all__.__class__.__name__ == 'tuple' (NOT list); verified with Python 3.14.3"]
    - [all_len,      asyncio.__all__.__len__,                     [],           95,    "asyncio.__all__.__len__() == 95 (95 public names); verified with Python 3.14.3"]
    - [spec_name_eq, asyncio.__spec__.name.__eq__,               ["asyncio"],  true,  "asyncio.__spec__.name == 'asyncio' (len=7); verified with Python 3.14.3"]
    - [spec_name_ln, asyncio.__spec__.name.__len__,               [],           7,     "asyncio.__spec__.name.__len__() == 7; verified with Python 3.14.3"]
    - [name_eq,      asyncio.__name__.__eq__,                    ["asyncio"],  true,  "asyncio.__name__ == 'asyncio' (len=7); verified with Python 3.14.3"]
    - [name_len,     asyncio.__name__.__len__,                    [],           7,     "asyncio.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [pkg_eq,       asyncio.__package__.__eq__,                 ["asyncio"],  true,  "asyncio.__package__ == 'asyncio' (package is itself); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.__all__ membership — core coroutine/task names — extra148
#
# 'run' in asyncio.__all__          == True
# 'sleep' in asyncio.__all__        == True
# 'gather' in asyncio.__all__       == True
# 'create_task' in asyncio.__all__  == True
# 'wait' in asyncio.__all__         == True
# 'timeout' in asyncio.__all__      == True
# ---------------------------------------------------------------------------

table asyncio_extra148.asyncio_all_coroutine_members:
  description: "asyncio.__all__ membership checks for core coroutine/task names in asyncio_all148 namespace — asyncio.__all__.__contains__('run')==True ('run' is the primary entry point for running a coroutine as an event loop, added in Python 3.7); asyncio.__all__.__contains__('sleep')==True ('sleep' is a coroutine that suspends execution for a given number of seconds); asyncio.__all__.__contains__('gather')==True ('gather' runs multiple coroutines concurrently and waits for them all); asyncio.__all__.__contains__('create_task')==True ('create_task' schedules a coroutine as a Task in the event loop); asyncio.__all__.__contains__('wait')==True ('wait' waits for futures given a set of futures); asyncio.__all__.__contains__('timeout')==True ('timeout' context manager for setting a timeout on a coroutine, added in Python 3.11); all confirmed present in the 95-item tuple; verified with Python 3.14.3"
  kind: python_call_eq
  category: membership
  id_prefix: asyncio_all148a

  columns: [id, function, args, expected, description]
  rows:
    - [has_run,         asyncio.__all__.__contains__,  ["run"],         true,  "asyncio.__all__.__contains__('run') == True; verified with Python 3.14.3"]
    - [has_sleep,       asyncio.__all__.__contains__,  ["sleep"],       true,  "asyncio.__all__.__contains__('sleep') == True; verified with Python 3.14.3"]
    - [has_gather,      asyncio.__all__.__contains__,  ["gather"],      true,  "asyncio.__all__.__contains__('gather') == True; verified with Python 3.14.3"]
    - [has_create_task, asyncio.__all__.__contains__,  ["create_task"], true,  "asyncio.__all__.__contains__('create_task') == True; verified with Python 3.14.3"]
    - [has_wait,        asyncio.__all__.__contains__,  ["wait"],        true,  "asyncio.__all__.__contains__('wait') == True; verified with Python 3.14.3"]
    - [has_timeout,     asyncio.__all__.__contains__,  ["timeout"],     true,  "asyncio.__all__.__contains__('timeout') == True (added in Python 3.11); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.__all__ membership — concurrency primitives — extra148
#
# 'Task' in asyncio.__all__      == True
# 'Future' in asyncio.__all__    == True
# 'Queue' in asyncio.__all__     == True
# 'Lock' in asyncio.__all__      == True
# 'Event' in asyncio.__all__     == True
# 'Semaphore' in asyncio.__all__ == True
# ---------------------------------------------------------------------------

table asyncio_extra148.asyncio_all_primitive_members:
  description: "asyncio.__all__ membership checks for concurrency primitives in asyncio_all148 namespace — asyncio.__all__.__contains__('Task')==True ('Task' is the primary class for scheduling coroutines as concurrent operations); asyncio.__all__.__contains__('Future')==True ('Future' represents an eventual result of an async operation); asyncio.__all__.__contains__('Queue')==True ('Queue' is an async FIFO queue for producer-consumer patterns); asyncio.__all__.__contains__('Lock')==True ('Lock' is an async mutual exclusion lock); asyncio.__all__.__contains__('Event')==True ('Event' is an async event for signaling between coroutines); asyncio.__all__.__contains__('Semaphore')==True ('Semaphore' limits concurrent access to a resource); all six primitive names are in the 95-item tuple; verified with Python 3.14.3"
  kind: python_call_eq
  category: membership
  id_prefix: asyncio_all148b

  columns: [id, function, args, expected, description]
  rows:
    - [has_task,      asyncio.__all__.__contains__,  ["Task"],      true,  "asyncio.__all__.__contains__('Task') == True; verified with Python 3.14.3"]
    - [has_future,    asyncio.__all__.__contains__,  ["Future"],    true,  "asyncio.__all__.__contains__('Future') == True; verified with Python 3.14.3"]
    - [has_queue,     asyncio.__all__.__contains__,  ["Queue"],     true,  "asyncio.__all__.__contains__('Queue') == True; verified with Python 3.14.3"]
    - [has_lock,      asyncio.__all__.__contains__,  ["Lock"],      true,  "asyncio.__all__.__contains__('Lock') == True; verified with Python 3.14.3"]
    - [has_event,     asyncio.__all__.__contains__,  ["Event"],     true,  "asyncio.__all__.__contains__('Event') == True; verified with Python 3.14.3"]
    - [has_semaphore, asyncio.__all__.__contains__,  ["Semaphore"], true,  "asyncio.__all__.__contains__('Semaphore') == True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra148
# ---------------------------------------------------------------------------

invariant asyncio_extra148.asyncio_all_is_tuple:
  description: "asyncio.__all__.__class__.__name__.__eq__('tuple') returns True — asyncio.__all__ is a tuple (not a list), unlike most modules that define __all__ as a list; asyncio.__all__.__class__.__name__=='tuple'; asyncio.__all__.__len__()==95 (95 public names); this is NEW territory in extra148: the first spec to verify asyncio.__all__.__class__.__name__; the tuple-vs-list distinction matters for consumers: tuples are immutable but support __contains__ and __len__ the same as lists; asyncio.__all__.__contains__('run')==True, __contains__('Task')==True, etc.; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: asyncio.__all__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant asyncio_extra148.asyncio_all_len_95:
  description: "asyncio.__all__.__len__() == 95 — asyncio exports 95 public names through its __all__ tuple; this is a large public API compared to abc (no __all__), multiprocessing (37 items, list), and concurrent.futures (14 items, list); the 95 names cover the full asyncio API: coroutine runners (run, sleep, gather, wait, timeout, create_task), concurrency primitives (Task, Future, Lock, Event, Queue, Semaphore), streams, transports, protocols, event loops, policies, and more; asyncio.__all__.__class__.__name__=='tuple'; NEW in extra148: first standalone asyncio.__all__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: asyncio.__all__.__len__
  args: []
  expected: 95

invariant asyncio_extra148.asyncio_spec_name_eq:
  description: "asyncio.__spec__.name.__eq__('asyncio') returns True — asyncio.__spec__.name is 'asyncio' (7 chars: 'a'+'s'+'y'+'n'+'c'+'i'+'o'); the ModuleSpec name attribute holds the fully-qualified module name as used by the import system; asyncio.__spec__.name.__len__()==7; asyncio.__name__=='asyncio' and asyncio.__package__=='asyncio' are all equal to 'asyncio'; asyncio.__all__.__len__()==95 (tuple); NEW in extra148: first standalone asyncio.__spec__.name equality invariant using this spec's id_prefix namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: asyncio.__spec__.name.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra148.asyncio_spec_name_len_7:
  description: "asyncio.__spec__.name.__len__() == 7 — asyncio.__spec__.name is 'asyncio' (7 chars); asyncio.__name__.__len__()==7 and asyncio.__package__.__len__()==7 are all 7; all three module identity attributes share the value 'asyncio' of length 7; compare with concurrent.futures.__spec__.name.__len__()==18 and multiprocessing.__spec__.name.__len__()==15 and abc.__spec__.name.__len__()==3; asyncio has the second-shortest module name among the four modules targeted in this batch; NEW in extra148: first standalone asyncio.__spec__.name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: asyncio.__spec__.name.__len__
  args: []
  expected: 7

invariant asyncio_extra148.asyncio_all_contains_run:
  description: "asyncio.__all__.__contains__('run') returns True — 'run' is one of the 95 names in asyncio.__all__ (a tuple); asyncio.run() was added in Python 3.7 as the primary high-level entry point for running a coroutine as the event loop; asyncio.__all__.__class__.__name__=='tuple'; asyncio.__all__.__len__()==95; other key co-residents in the tuple include 'sleep', 'gather', 'create_task', 'wait', 'timeout', 'Task', 'Future', 'Queue', 'Lock', 'Event', 'Semaphore'; NEW in extra148: first standalone asyncio.__all__ 'run' membership invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: membership
  kind: python_call_eq
  function: asyncio.__all__.__contains__
  args: ["run"]
  expected: true

invariant asyncio_extra148.asyncio_all_contains_task:
  description: "asyncio.__all__.__contains__('Task') returns True — 'Task' is one of the 95 names in asyncio.__all__ (a tuple); asyncio.Task is the main class for wrapping coroutines as concurrent tasks on the event loop; asyncio.__all__.__contains__('Future')==True, __contains__('Queue')==True, __contains__('Lock')==True all likewise; asyncio.__all__.__class__.__name__=='tuple'; asyncio.__all__.__len__()==95; NEW in extra148: first standalone asyncio.__all__ 'Task' membership invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: membership
  kind: python_call_eq
  function: asyncio.__all__.__contains__
  args: ["Task"]
  expected: true

invariant asyncio_extra148.asyncio_package_eq:
  description: "asyncio.__package__.__eq__('asyncio') returns True — asyncio.__package__ is 'asyncio' (7 chars); for a package, __package__ equals the package name itself (i.e., __name__); asyncio is a package (has __init__.py in Lib/asyncio/), so __package__=='asyncio'==__name__; asyncio.__spec__.name=='asyncio' also; asyncio.__all__.__len__()==95 (tuple); NEW in extra148: first standalone asyncio.__package__ equality invariant in this spec's namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: asyncio.__package__.__eq__
  args: ["asyncio"]
  expected: true
