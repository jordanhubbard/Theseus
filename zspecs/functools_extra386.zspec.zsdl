spec: functools_extra386
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' — WRAPPER_UPDATES is a tuple containing '__dict__', complementing WRAPPER_ASSIGNMENTS. Verified with Python 3.14.4."
    - "len(functools.WRAPPER_UPDATES) == 1 — only '__dict__' is in WRAPPER_UPDATES. Verified with Python 3.14.4."
    - "list(functools.WRAPPER_UPDATES) == ['__dict__'] — sole element is '__dict__'. Verified with Python 3.14.4."
    - "functools.reduce.__module__ == '_functools' — reduce is implemented in C (Modules/_functoolsmodule.c) and its __module__ is '_functools'. Verified with Python 3.14.4."
    - "functools.reduce.__qualname__ == 'reduce' — qualname of the C builtin is 'reduce'. Verified with Python 3.14.4."
    - "functools.partial.__doc__.__class__.__name__ == 'str' — partial carries a plain string docstring. Verified with Python 3.14.4."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.WRAPPER_UPDATES tuple identity
#
# functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'
# functools.WRAPPER_UPDATES.__len__() == 1
#
# WRAPPER_UPDATES is a module-level tuple that lists the attributes of the
# wrapper function that are updated (merged) by update_wrapper. It contains
# only '__dict__', meaning the wrapped function's __dict__ is merged into the
# wrapper's __dict__ rather than replaced.
# ---------------------------------------------------------------------------

table functools_extra386.wrapper_updates_identity:
  description: "functools.WRAPPER_UPDATES tuple class name and length; new to extra386"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswu386

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_updates_class_name_eq,
       "WRAPPER_UPDATES.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a module-level tuple listing attributes merged into the wrapper by update_wrapper; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra386"]
    - [wrapper_updates_len_eq,
       "WRAPPER_UPDATES.__len__",
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES contains exactly one element, '__dict__', which is merged rather than replaced into the wrapper function; new to extra386"]

# ---------------------------------------------------------------------------
# Table 2: functools.reduce and functools.partial identity
#
# functools.reduce.__module__ == '_functools'
# functools.reduce.__qualname__ == 'reduce'
# functools.partial.__doc__.__class__.__name__ == 'str'
#
# reduce is a C builtin in Modules/_functoolsmodule.c; its __module__ is
# '_functools' (the underlying C extension), not 'functools'. Its __qualname__
# is simply 'reduce'. partial, also a C type, carries a plain string docstring.
# ---------------------------------------------------------------------------

table functools_extra386.reduce_and_partial_identity:
  description: "functools.reduce __module__ and __qualname__ (C builtin), plus functools.partial docstring class; new to extra386"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsrp386

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_module_eq,
       "reduce.__module__.__eq__",
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is implemented in Modules/_functoolsmodule.c; its __module__ is '_functools' (the C extension module), not the re-exporting 'functools' package; str.__eq__('_functools') returns True; new to extra386"]
    - [reduce_qualname_eq,
       "reduce.__qualname__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — reduce is a top-level C builtin; its __qualname__ is 'reduce' with no enclosing class or function scope; str.__eq__('reduce') returns True; new to extra386"]
    - [partial_doc_class_name_eq,
       "partial.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — partial is a C type that carries a plain string docstring; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra386"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra386
# ---------------------------------------------------------------------------

invariant functools_extra386.wrapper_updates_class_name:
  description: "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' — module-level tuple listing attributes merged by update_wrapper; new to extra386"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra386.wrapper_updates_len:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — contains only '__dict__'; new to extra386"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra386.reduce_module:
  description: "functools.reduce.__module__ == '_functools' — C builtin from Modules/_functoolsmodule.c; __module__ is the C extension, not the re-exporting package; new to extra386"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra386.reduce_qualname:
  description: "functools.reduce.__qualname__ == 'reduce' — top-level C builtin with no enclosing scope; new to extra386"
  kind: python_call_eq
  function: reduce.__qualname__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra386.partial_doc_class_name:
  description: "functools.partial.__doc__.__class__.__name__ == 'str' — C type with plain string docstring; new to extra386"
  kind: python_call_eq
  function: partial.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
