spec: pyyaml_rust
version: ">=3.9"
backend: rust_module(pyyaml_rust)

docs: https://pyyaml.org/wiki/PyYAMLDocumentation

provenance:
  derived_from:
    - "https://pyyaml.org/wiki/PyYAMLDocumentation — PyYAML documentation"
    - "https://yaml.org/spec/1.1/ — YAML 1.1 specification (PyYAML default)"
  not_derived_from:
    - "PyYAML source: lib/yaml/__init__.py"
  notes:
    - "Clean-room Rust reimplementation of PyYAML safe_load, exposed via PyO3."
    - "safe_load(s) parses a YAML string and returns the Python object."
    - "safe_load('42') == 42 — integer scalar."
    - "safe_load('3.14') == 3.14 — float scalar."
    - "safe_load('true') == True — boolean (YAML 1.1 true)."
    - "safe_load('false') == False — boolean (YAML 1.1 false)."
    - "safe_load('null') == None — null value."
    - "safe_load('\"hello\"') == 'hello' — quoted string scalar."
    - "safe_load('[1, 2, 3]') == [1, 2, 3] — flow sequence."
    - "safe_load('a: 1') == {'a': 1} — block mapping."
    - "All test vectors verified against PyYAML 6.0.3."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# safe_load — scalar values
table pyyaml_rust.safe_load.scalars:
  kind: python_call_eq
  category: safe_load
  id_prefix: yaml_scalar
  function: safe_load

  columns: [id, args, expected]
  rows:
    - [integer,  ["42"],       42]
    - [float,    ["3.14"],     3.14]
    - [true,     ["true"],     true]
    - [false,    ["false"],    false]
    - [none,     ["null"],     null]
    - [string,   ["\"hello\""], "hello"]
    - [zero,     ["0"],         0]
    - [neg_int,  ["-7"],       -7]

# safe_load — sequences
invariant pyyaml_rust.safe_load.list123:
  description: "safe_load('[1, 2, 3]') == [1, 2, 3]"
  category: safe_load
  kind: python_call_eq
  function: safe_load
  args: ["[1, 2, 3]"]
  expected: [1, 2, 3]

invariant pyyaml_rust.safe_load.empty_list:
  description: "safe_load('[]') == []"
  category: safe_load
  kind: python_call_eq
  function: safe_load
  args: ["[]"]
  expected: []

# safe_load — mapping (dict result)
invariant pyyaml_rust.safe_load.simple_dict:
  description: "safe_load('a: 1') == {'a': 1}"
  category: safe_load
  kind: python_call_eq
  function: safe_load
  args: ["a: 1"]
  expected: {a: 1}

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T21:45:22Z
  iterations: 1
  pass_count: 11
  fail_count: 0
  total_invariants: 11
  notes: Synthesis succeeded in 1 iteration(s). 11 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
