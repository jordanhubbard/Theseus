spec: threading_extra45
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra44.zspec.zsdl."
    - "Prior specs covered: Thread/__name__/__qualname__.__len__()==6; Thread.__qualname__=='Thread'; Thread method __qualname__.__len__() for start/run/join/is_alive/__init__/__repr__/getName/setName; Event method __qualname__.__len__(); Condition method __qualname__.__len__(); Semaphore/__name__/__qualname__.__len__()==9; Barrier/__name__/__qualname__.__len__()==7; Timer/__name__/__qualname__.__len__()==5; local/__name__/__qualname__.__len__()==6; Lock/__name__.__len__()==4; RLock/__dict__.__class__.__name__.__len__()==12; current_thread/__name__/main_thread/__name__; threading.__all__.__len__()==28; TIMEOUT_MAX; active_count/enumerate/settrace/setprofile/stack_size __name__ lengths; Thread property __class__.__name__.__len__() for daemon/name/ident/native_id; Barrier/__name__/__module__=='Barrier'/'threading'; Condition/__name__/__module__=='Condition'/'threading'; Semaphore/__name__/__module__=='Semaphore'/'threading'; RLock/__name__/__module__=='RLock'/'threading'; Timer/__name__/__module__=='Timer'/'threading'; BoundedSemaphore/__name__/__module__=='BoundedSemaphore'/'threading'; BoundedSemaphore/__bases__[0].__name__=='Semaphore'; local/__name__=='_local'; TIMEOUT_MAX==9223372036.0; excepthook/__name__=='_excepthook'; Thread/__bases__[0].__name__=='object'; Thread/__mro__.__len__()==2; Event/__bases__[0].__name__=='object'; Event/__mro__.__len__()==2; Lock/__name__=='lock'; RLock/__qualname__=='RLock'; main_thread/__module__/current_thread/__module__/active_count/__module__=='threading'; enumerate/__name__/__module__=='enumerate'/'threading'; settrace/__name__=='settrace'; setprofile/__name__=='setprofile'; stack_size/__name__=='stack_size'."
    - "This spec covers: threading.Thread.__qualname__.__len__() == 6; threading.Event.__qualname__ == 'Event'; threading.Event.__qualname__.__len__() == 5; threading.Semaphore.__qualname__ == 'Semaphore'; threading.Semaphore.__qualname__.__len__() == 9; threading.BoundedSemaphore.__qualname__ == 'BoundedSemaphore'; threading.BoundedSemaphore.__qualname__.__len__() == 16; threading.Barrier.__qualname__ == 'Barrier'; threading.Timer.__qualname__ == 'Timer'."
    - "Key findings: threading.Thread.__qualname__.__len__() is 6 — 'Thread' is 6 chars; prior spec extra44 recorded Thread.__qualname__=='Thread' (the string equality) but not the __len__() call directly; this isolated length call is new to extra45. threading.Event.__qualname__ is 'Event' (5 chars) — pure-Python class defined at module level in Lib/threading.py; __qualname__ == __name__; prior specs recorded Event.__qualname__.__len__() in length tables and Event/__bases__[0].__name__=='object' but not the string equality for Event.__qualname__. threading.Semaphore.__qualname__ is 'Semaphore' (9 chars) — pure-Python class; prior specs recorded __name__=='Semaphore' and __module__=='threading' but not __qualname__ string equality. threading.BoundedSemaphore.__qualname__ is 'BoundedSemaphore' (16 chars) — pure-Python class defined at module level; prior specs recorded __name__=='BoundedSemaphore' and __module__=='threading' but not __qualname__ string equality. threading.Barrier.__qualname__ is 'Barrier' (7 chars) — pure-Python class; prior specs recorded __name__=='Barrier' and __module__=='threading' but not __qualname__ string equality. threading.Timer.__qualname__ is 'Timer' (5 chars) — pure-Python class; prior specs recorded __name__=='Timer' and __module__=='threading' but not __qualname__ string equality."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Thread __qualname__.__len__() — extra45 namespace
#
# threading.Thread.__qualname__.__len__() is 6 — 'Thread' is 6 chars.
# Prior spec extra44 recorded Thread.__qualname__ == 'Thread' (the string
# equality invariant), but no prior spec recorded the __len__() call on
# Thread.__qualname__ as a direct standalone invariant (only via table rows
# for __qualname__.__len__()==6 in earlier length-survey specs). This
# explicit __len__() method-call invariant is new to extra45.
# ---------------------------------------------------------------------------

invariant threading_extra45.Thread_qualname_len:
  description: "len(threading.Thread.__qualname__) == 6 — 'Thread' is 6 chars; pure-Python class at module level in Lib/threading.py; __qualname__ == __name__; prior spec extra44 recorded __qualname__=='Thread' but not the __len__() call"
  category: string_properties
  kind: python_call_eq
  function: Thread.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# threading.Event __qualname__ and __len__ — extra45 namespace
#
# threading.Event.__qualname__ is 'Event' (5 chars). Event is a pure-Python
# class defined at module level in Lib/threading.py; top-level so __qualname__
# == __name__. Prior specs recorded Event.__qualname__.__len__() in length
# survey tables and Event.__bases__[0].__name__=='object' and
# Event.__mro__.__len__()==2, but no prior spec recorded the string equality
# invariant for Event.__qualname__. The string equality and __len__() method
# call are both new to extra45.
# ---------------------------------------------------------------------------

table threading_extra45.Event_qualname:
  description: "threading.Event __qualname__ string equality and length — pure-Python class at module level; __qualname__ == __name__ == 'Event'; 5 chars"
  kind: python_call_eq
  category: identity
  id_prefix: evqn45

  columns: [id, function, args, expected, description]
  rows:
    - [event_qualname,
       Event.__qualname__.__eq__,
       ["Event"],
       true,
       "threading.Event.__qualname__ == 'Event' — pure-Python class at module level in Lib/threading.py; __qualname__ == __name__ (no enclosing class scope); 5 chars; synchronization primitive using an internal flag"]
    - [event_qualname_len,
       Event.__qualname__.__len__,
       [],
       5,
       "len(threading.Event.__qualname__) == 5 — 'Event' is 5 chars; same length as Timer.__qualname__ and threading.Timer.__name__; same length as Thread.__module__.__len__()-4"]

# ---------------------------------------------------------------------------
# threading.Semaphore __qualname__ and __len__ — extra45 namespace
#
# threading.Semaphore.__qualname__ is 'Semaphore' (9 chars). Semaphore is a
# pure-Python class defined at module level in Lib/threading.py. Prior specs
# recorded Semaphore/__name__=='Semaphore' and Semaphore/__module__=='threading'
# (via identity tables) and __qualname__.__len__()==9 (length survey), but not
# the string equality invariant for Semaphore.__qualname__. New here.
# ---------------------------------------------------------------------------

table threading_extra45.Semaphore_qualname:
  description: "threading.Semaphore __qualname__ string equality and length — pure-Python class at module level; __qualname__ == __name__ == 'Semaphore'; 9 chars"
  kind: python_call_eq
  category: identity
  id_prefix: semqn45

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_qualname,
       Semaphore.__qualname__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__qualname__ == 'Semaphore' — pure-Python class at module level in Lib/threading.py; __qualname__ == __name__ (no enclosing scope); 9 chars; counting semaphore synchronization primitive"]
    - [semaphore_qualname_len,
       Semaphore.__qualname__.__len__,
       [],
       9,
       "len(threading.Semaphore.__qualname__) == 9 — 'Semaphore' is 9 chars; same length as __module__ 'threading' (also 9 chars); same length as __name__"]

# ---------------------------------------------------------------------------
# threading.BoundedSemaphore __qualname__ and __len__ — extra45 namespace
#
# threading.BoundedSemaphore.__qualname__ is 'BoundedSemaphore' (16 chars).
# BoundedSemaphore is a pure-Python class defined at module level in
# Lib/threading.py that extends Semaphore to disallow release() calls that
# would exceed the initial value. Prior specs recorded __name__=='BoundedSemaphore'
# and __module__=='threading' and __bases__[0].__name__=='Semaphore' but not
# the __qualname__ string equality or __len__(). Both are new to extra45.
# ---------------------------------------------------------------------------

table threading_extra45.BoundedSemaphore_qualname:
  description: "threading.BoundedSemaphore __qualname__ string equality and length — pure-Python class at module level; __qualname__ == __name__ == 'BoundedSemaphore'; 16 chars"
  kind: python_call_eq
  category: identity
  id_prefix: bsemqn45

  columns: [id, function, args, expected, description]
  rows:
    - [boundedsemaphore_qualname,
       BoundedSemaphore.__qualname__.__eq__,
       ["BoundedSemaphore"],
       true,
       "threading.BoundedSemaphore.__qualname__ == 'BoundedSemaphore' — pure-Python class at module level in Lib/threading.py; __qualname__ == __name__; 16 chars; extends Semaphore to prevent over-release"]
    - [boundedsemaphore_qualname_len,
       BoundedSemaphore.__qualname__.__len__,
       [],
       16,
       "len(threading.BoundedSemaphore.__qualname__) == 16 — 'BoundedSemaphore' is 16 chars; longest class name among threading synchronization primitives"]

# ---------------------------------------------------------------------------
# threading.Barrier and Timer __qualname__ — extra45 namespace
#
# threading.Barrier.__qualname__ is 'Barrier' (7 chars) and
# threading.Timer.__qualname__ is 'Timer' (5 chars). Both are pure-Python
# classes defined at module level in Lib/threading.py; top-level so
# __qualname__ == __name__. Prior specs recorded __name__ and __module__
# string equality for both (Barrier in the Barrier identity table and Timer
# in the Timer identity table) but not __qualname__ string equality for either.
# Both invariants are new to extra45.
# ---------------------------------------------------------------------------

table threading_extra45.Barrier_Timer_qualnames:
  description: "threading.Barrier and Timer __qualname__ string equality — pure-Python classes at module level; __qualname__ == __name__ in each case"
  kind: python_call_eq
  category: identity
  id_prefix: btqn45

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_qualname,
       Barrier.__qualname__.__eq__,
       ["Barrier"],
       true,
       "threading.Barrier.__qualname__ == 'Barrier' — pure-Python class at module level in Lib/threading.py; __qualname__ == __name__ (no enclosing scope); 7 chars; reusable synchronization barrier for n threads"]
    - [timer_qualname,
       Timer.__qualname__.__eq__,
       ["Timer"],
       true,
       "threading.Timer.__qualname__ == 'Timer' — pure-Python class at module level in Lib/threading.py; __qualname__ == __name__ (no enclosing scope); 5 chars; Thread subclass that runs a function after a delay"]
