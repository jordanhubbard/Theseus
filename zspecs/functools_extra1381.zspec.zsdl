spec: functools_extra1381
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "Wave 539 (_extra1381): focuses on __abstractmethods__ and __isabstractmethod__ checks for functools classes."
    - "functools.partialmethod and functools.singledispatchmethod define __isabstractmethod__ as a property in their __dict__; functools.partial and functools.cached_property do not."
    - "No functools class has __abstractmethods__ in its __dict__ because none define abstract methods."
    - "All class __dict__ attributes are mappingproxy instances — confirmed for partial, partialmethod, cached_property, and singledispatchmethod."
    - "functools.partial.__dict__ contains 'func', 'args', and 'keywords' as public descriptor attributes."
    - "functools.singledispatchmethod.__dict__ contains 'register'; functools.cached_property.__dict__ contains '__init__'."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table functools_extra1381.isabstractmethod_property_in_dict:
  description: "functools classes that define __isabstractmethod__ as a property in their __dict__: partialmethod and singledispatchmethod; partial and cached_property do not"
  kind: python_call_eq
  category: abstractmethods_isabstractmethod_checks
  id_prefix: fu1381ia
  columns: [id, function, args, expected]
  rows:
    - [fu1381ia001, functools.partialmethod.__dict__.__contains__,      ["__isabstractmethod__"],  true]
    - [fu1381ia002, functools.singledispatchmethod.__dict__.__contains__, ["__isabstractmethod__"], true]
    - [fu1381ia003, functools.partial.__dict__.__contains__,            ["__isabstractmethod__"],  false]
    - [fu1381ia004, functools.cached_property.__dict__.__contains__,    ["__isabstractmethod__"],  false]
    - [fu1381ia005, functools.partialmethod.__isabstractmethod__.__class__.__name__.__eq__,        ["property"],  true]
    - [fu1381ia006, functools.singledispatchmethod.__isabstractmethod__.__class__.__name__.__eq__, ["property"],  true]

table functools_extra1381.abstractmethods_not_in_dict:
  description: "No functools class has __abstractmethods__ in its __dict__ — these classes define no abstract methods and none inherit an abstract-method registry"
  kind: python_call_eq
  category: abstractmethods_isabstractmethod_checks
  id_prefix: fu1381am
  columns: [id, function, args, expected]
  rows:
    - [fu1381am001, functools.partial.__dict__.__contains__,            ["__abstractmethods__"],  false]
    - [fu1381am002, functools.partialmethod.__dict__.__contains__,      ["__abstractmethods__"],  false]
    - [fu1381am003, functools.cached_property.__dict__.__contains__,    ["__abstractmethods__"],  false]
    - [fu1381am004, functools.singledispatchmethod.__dict__.__contains__, ["__abstractmethods__"], false]
    - [fu1381am005, functools.partial.__dict__.__class__.__name__.__eq__,            ["mappingproxy"],  true]
    - [fu1381am006, functools.singledispatchmethod.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

table functools_extra1381.dict_mappingproxy_and_public_attrs:
  description: "All functools class __dict__ attributes are mappingproxy; partial exposes public descriptor attrs 'func', 'args', 'keywords'; singledispatchmethod exposes 'register'"
  kind: python_call_eq
  category: abstractmethods_isabstractmethod_checks
  id_prefix: fu1381dp
  columns: [id, function, args, expected]
  rows:
    - [fu1381dp001, functools.partial.__dict__.__class__.__name__.__eq__,         ["mappingproxy"],  true]
    - [fu1381dp002, functools.partialmethod.__dict__.__class__.__name__.__eq__,   ["mappingproxy"],  true]
    - [fu1381dp003, functools.cached_property.__dict__.__class__.__name__.__eq__, ["mappingproxy"],  true]
    - [fu1381dp004, functools.partial.__dict__.__contains__,                      ["func"],           true]
    - [fu1381dp005, functools.partial.__dict__.__contains__,                      ["args"],           true]
    - [fu1381dp006, functools.partial.__dict__.__contains__,                      ["keywords"],       true]
    - [fu1381dp007, functools.singledispatchmethod.__dict__.__contains__,         ["register"],       true]
    - [fu1381dp008, functools.cached_property.__dict__.__contains__,              ["__init__"],       true]
