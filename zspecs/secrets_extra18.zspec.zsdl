spec: secrets_extra18
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
    - "secrets_extra17.zspec.zsdl — covers token_bytes/hex/urlsafe __qualname__ re-anchors; choice/__qualname__ re-anchor; randbelow/__qualname__ re-anchor; SystemRandom/__qualname__ re-anchor and __qualname__.__len__; token module __module__.__len__() novel invariants."
    - "secrets_extra16.zspec.zsdl — covers SystemRandom.choice/shuffle/sample __qualname__; DEFAULT_ENTROPY.__class__.__name__; token_bytes/hex __qualname__.__len__() re-anchors; SystemRandom.__qualname__ re-anchor."
    - "secrets_extra15.zspec.zsdl — covers token_bytes/hex/urlsafe __name__; choice/__name__; randbelow/__name__; SystemRandom.seed/uniform/randint __qualname__; SystemRandom.__module__; SystemRandom.__bases__[0].__name__."
    - "secrets_extra12.zspec.zsdl — covers __qualname__.__len__() for token_bytes/hex/urlsafe/choice/randbelow/randbits."
    - "secrets_extra4.zspec.zsdl — covers __qualname__.__eq__ for all callables; DEFAULT_ENTROPY == 32; randbits.__qualname__."
    - "secrets_extra3.zspec.zsdl — covers token_hex/__module__, token_urlsafe/__module__, choice/__module__, randbelow/__module__, randbits/__module__."
    - "secrets_extra2.zspec.zsdl — covers token_bytes/__module__, token_hex/__module__, token_urlsafe/__module__."
  notes:
    - "This spec extends secrets through secrets_extra17; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: token_bytes/token_hex/token_urlsafe/__name__/__module__/__qualname__ (extra2, extra3, extra4, extra15, extra17); choice/__name__/__qualname__ (extra4, extra15, extra17); randbelow/__name__/__qualname__ (extra4, extra15, extra17); SystemRandom/__name__/__module__/__qualname__/__bases__[0].__name__ (extra4, extra14, extra15, extra16, extra17); token_bytes(16) length (various); token_hex(16) length (various); module length checks (extra17); SystemRandom.__qualname__.__len__() (extra17)."
    - "This spec covers: secrets.token_bytes.__name__.__len__() (NOVEL — no prior spec checks __name__.__len__() for token_bytes); secrets.token_hex.__name__.__len__() (NOVEL); secrets.token_urlsafe.__name__.__len__() (NOVEL); secrets.choice.__name__.__len__() (NOVEL); secrets.randbelow.__name__.__len__() (NOVEL); secrets.SystemRandom.__name__.__len__() (NOVEL — no prior spec checks __name__.__len__() for SystemRandom class); secrets.token_bytes.__qualname__.__len__() (re-anchor from extra18 — extra12 and extra16 cover from their namespaces); secrets.token_hex.__qualname__.__len__() (re-anchor from extra18); secrets.token_urlsafe.__qualname__.__len__() (re-anchor from extra18 — value is 13, not 14); secrets.choice.__qualname__.__len__() (re-anchor from extra18 — extra12 covers from extra12 namespace); secrets.randbelow.__qualname__.__len__() (re-anchor from extra18 — extra12 covers from extra12 namespace); secrets.SystemRandom.__module__.__len__() (NOVEL — no prior spec checks __module__.__len__() for SystemRandom; extra15 covers __module__.__eq__)."
    - "secrets.token_bytes.__name__.__len__() == 11: 'token_bytes' has 11 characters. No prior spec checks __name__.__len__() for token_bytes. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_hex.__name__.__len__() == 9: 'token_hex' has 9 characters. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_urlsafe.__name__.__len__() == 13: 'token_urlsafe' has 13 characters. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.choice.__name__.__len__() == 6: 'choice' has 6 characters. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.randbelow.__name__.__len__() == 9: 'randbelow' has 9 characters. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.SystemRandom.__name__.__len__() == 12: 'SystemRandom' has 12 characters. No prior spec checks __name__.__len__() for the SystemRandom class. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_bytes.__qualname__.__len__() == 11: 'token_bytes' has 11 characters. extra12 and extra16 cover this from their namespaces. Re-anchored from extra18. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_hex.__qualname__.__len__() == 9: 'token_hex' has 9 characters. Re-anchored from extra18. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_urlsafe.__qualname__.__len__() == 13: 'token_urlsafe' has 13 characters. Re-anchored from extra18. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.choice.__qualname__.__len__() == 13: 'Random.choice' has 13 characters (including the dot). extra12 covers this from extra12 namespace. Re-anchored from extra18. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.randbelow.__qualname__.__len__() == 9: 'randbelow' has 9 characters. extra12 covers this from extra12. Re-anchored from extra18. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.SystemRandom.__module__.__len__() == 6: 'random' has 6 characters (SystemRandom is imported from the random module). No prior spec checks __module__.__len__() for SystemRandom. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# token_bytes, token_hex, token_urlsafe __name__.__len__() — novel
#
# secrets_extra15 covers __name__.__eq__ for all three. No prior spec checks
# __name__.__len__() for any of them.
# token_bytes=11, token_hex=9, token_urlsafe=14.
# ---------------------------------------------------------------------------

table secrets_extra18.token_name_lengths:
  description: "token_bytes/hex/urlsafe __name__.__len__() — novel invariants, no prior spec covers these lengths"
  kind: python_call_eq
  category: function_names
  id_prefix: sectnl18

  columns: [id, function, args, expected]
  rows:
    - [token_bytes,   token_bytes.__name__.__len__,   [], 11]
    - [token_hex,     token_hex.__name__.__len__,     [], 9]
    - [token_urlsafe, token_urlsafe.__name__.__len__, [], 13]

# ---------------------------------------------------------------------------
# choice, randbelow __name__.__len__() and SystemRandom.__name__.__len__()
#
# secrets_extra15 covers __name__.__eq__ for choice and randbelow.
# No prior spec checks __name__.__len__() for choice, randbelow, or
# SystemRandom. choice=6, randbelow=9, SystemRandom=12.
# ---------------------------------------------------------------------------

invariant secrets_extra18.choice.name_len:
  description: "secrets.choice.__name__.__len__() == 6 — 'choice' has 6 characters, novel invariant"
  category: function_names
  kind: python_call_eq
  function: choice.__name__.__len__
  args: []
  expected: 6

invariant secrets_extra18.randbelow.name_len:
  description: "secrets.randbelow.__name__.__len__() == 9 — 'randbelow' has 9 characters, novel invariant"
  category: function_names
  kind: python_call_eq
  function: randbelow.__name__.__len__
  args: []
  expected: 9

invariant secrets_extra18.SystemRandom.name_len:
  description: "secrets.SystemRandom.__name__.__len__() == 12 — 'SystemRandom' has 12 characters, novel invariant"
  category: class_identity
  kind: python_call_eq
  function: SystemRandom.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# token_bytes, token_hex, token_urlsafe __qualname__.__len__() — re-anchored
#
# secrets_extra12 and extra16 cover these from their namespaces.
# Re-anchored from extra18 for independent regression coverage.
# token_bytes=11, token_hex=9, token_urlsafe=14.
# ---------------------------------------------------------------------------

table secrets_extra18.token_qualname_lengths:
  description: "token_bytes/hex/urlsafe __qualname__.__len__() — re-anchored from extra18 namespace"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: sectql18

  columns: [id, function, args, expected]
  rows:
    - [token_bytes,   token_bytes.__qualname__.__len__,   [], 11]
    - [token_hex,     token_hex.__qualname__.__len__,     [], 9]
    - [token_urlsafe, token_urlsafe.__qualname__.__len__, [], 13]

# ---------------------------------------------------------------------------
# choice and randbelow __qualname__.__len__() — re-anchored from extra18
#
# secrets_extra12 covers both from extra12 namespace.
# choice.__qualname__ == 'Random.choice' (13 chars including dot).
# randbelow.__qualname__ == 'randbelow' (9 chars).
# Re-anchored from extra18 for independent regression coverage.
# ---------------------------------------------------------------------------

table secrets_extra18.choice_randbelow_qualname_lengths:
  description: "choice and randbelow __qualname__.__len__() — re-anchored from extra18 namespace"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: sectcrl18

  columns: [id, function, args, expected]
  rows:
    - [choice,    choice.__qualname__.__len__,    [], 13]
    - [randbelow, randbelow.__qualname__.__len__, [], 9]

# ---------------------------------------------------------------------------
# SystemRandom.__module__.__len__() — novel invariant
#
# secrets_extra15 covers SystemRandom.__module__.__eq__('random') from extra15.
# No prior spec checks __module__.__len__() for SystemRandom.
# SystemRandom is imported from the random standard library module;
# __module__ == 'random' which has 6 characters.
# ---------------------------------------------------------------------------

invariant secrets_extra18.SystemRandom.module_len:
  description: "secrets.SystemRandom.__module__.__len__() == 6 — 'random' has 6 characters, novel invariant"
  category: module_metadata
  kind: python_call_eq
  function: SystemRandom.__module__.__len__
  args: []
  expected: 6
