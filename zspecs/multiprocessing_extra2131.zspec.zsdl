spec: multiprocessing_extra2131
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "Wave (_extra2131): exception protocol dict-presence — checking __cause__, __context__, __traceback__, __suppress_context__, __notes__, args, with_traceback in class __dict__."
    - "multiprocessing exception classes (ProcessError, BufferTooShort, AuthenticationError, TimeoutError) are genuine exception subclasses."
    - "Exception protocol attributes are instance-level, set by the interpreter at raise time; they never appear in the class __dict__."
    - "args and with_traceback are inherited from BaseException and are not redefined in multiprocessing exception class __dict__ entries."
    - "Non-exception types (Process, synchronize.Lock) likewise contain no exception protocol attrs in their class dicts."
    - "multiprocessing.ProcessLookupError does not exist as a module-level name; it is not included in this wave."
    - "multiprocessing.synchronize.Lock is the full qualified path to the Lock synchronization primitive."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table multiprocessing_extra2131.processError_exception_protocol:
  description: "multiprocessing.ProcessError.__dict__ exception protocol dict-presence — base exception type, all attrs absent from class dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2131

  columns: [id, function, args, expected]
  rows:
    - ["mp2131001", "multiprocessing.ProcessError.__dict__.__contains__", ["__cause__"], false]
    - ["mp2131002", "multiprocessing.ProcessError.__dict__.__contains__", ["__context__"], false]
    - ["mp2131003", "multiprocessing.ProcessError.__dict__.__contains__", ["__traceback__"], false]
    - ["mp2131004", "multiprocessing.ProcessError.__dict__.__contains__", ["__suppress_context__"], false]
    - ["mp2131005", "multiprocessing.ProcessError.__dict__.__contains__", ["__notes__"], false]
    - ["mp2131006", "multiprocessing.ProcessError.__dict__.__contains__", ["args"], false]
    - ["mp2131007", "multiprocessing.ProcessError.__dict__.__contains__", ["with_traceback"], false]

