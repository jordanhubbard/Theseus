# threading.Event.set.__qualname__ == 'Event.set' (len 9)
# threading.Event.set.__code__.co_argcount == 1
#
# Event.__init__ initializes the internal flag to False.
# Event.set sets the flag to True and notifies all waiting threads.
# Both take only self. New to extra137.
# ---------------------------------------------------------------------------

