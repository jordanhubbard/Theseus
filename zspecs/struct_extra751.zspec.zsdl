spec: struct_extra751
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions

docs:
  summary: struct module-level function and type class names, plus module attributes
  tags: [struct, builtin_function_or_method, type, member_descriptor, module]

provenance:
  derived_from:
    - python_stdlib_struct
  not_derived_from:
    - cpython_source
  notes:
    - Covers __class__.__name__ for pack, unpack, pack_into, unpack_from, iter_unpack, calcsize
    - Covers __class__.__name__ for Struct and error types
    - Covers __class__.__name__ for Struct descriptor attributes size and format
    - Covers __module__ for pack and calcsize
  created_at: "2026-04-12"

table struct_extra751.name:
  description: struct module-level function class types and module membership
  kind: python_call_eq
  category: class_type
  id_prefix: st751xx
  columns: [id, function, args, expected]
  rows:
    - [st751xx001, struct.pack.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [st751xx002, struct.unpack.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [st751xx003, struct.pack_into.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [st751xx004, struct.unpack_from.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [st751xx005, struct.iter_unpack.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [st751xx006, struct.calcsize.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [st751xx007, struct.Struct.__class__.__name__.__eq__, ["type"], true]
    - [st751xx008, struct.error.__class__.__name__.__eq__, ["type"], true]
    - [st751xx009, struct.Struct.size.__class__.__name__.__eq__, ["member_descriptor"], true]
    - [st751xx010, struct.Struct.format.__class__.__name__.__eq__, ["member_descriptor"], true]
    - [st751xx011, struct.pack.__module__.__eq__, ["struct"], true]
    - [st751xx012, struct.calcsize.__module__.__eq__, ["struct"], true]
