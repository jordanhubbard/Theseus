spec: asyncio_extra3
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "Extends asyncio.zspec.zsdl, asyncio_events.zspec.zsdl, asyncio_extra.zspec.zsdl, asyncio_extra2.zspec.zsdl."
    - "asyncio_extra.zspec.zsdl covers __name__ and __module__ for Task, Future, Queue, Lock, Semaphore, Event, Condition, and top-level function names."
    - "asyncio_extra2.zspec.zsdl covers AbstractEventLoop and BaseEventLoop __module__, and __name__ rechecks for sync primitives."
    - "This spec covers __qualname__ for Task, Future, Queue, Lock, Event, Semaphore, Condition; function __qualname__ for gather, sleep, create_task; newer Python 3.11+ classes Barrier, TaskGroup, Runner; and wait/__name__."
    - "asyncio.Task.__qualname__ == 'Task' (no nested class, defined at module scope in asyncio.tasks)."
    - "asyncio.Future.__qualname__ == 'Future'."
    - "asyncio.Queue.__qualname__ == 'Queue'."
    - "asyncio.Lock.__qualname__ == 'Lock'."
    - "asyncio.Event.__qualname__ == 'Event'."
    - "asyncio.Semaphore.__qualname__ == 'Semaphore'."
    - "asyncio.Condition.__qualname__ == 'Condition'."
    - "asyncio.gather.__qualname__ == 'gather'."
    - "asyncio.sleep.__qualname__ == 'sleep'."
    - "asyncio.create_task.__qualname__ == 'create_task'."
    - "asyncio.wait.__name__ == 'wait'."
    - "asyncio.shield.__name__ == 'shield'."
    - "asyncio.Barrier is available in Python 3.11+ with __name__ == 'Barrier'."
    - "asyncio.TaskGroup is available in Python 3.11+ with __name__ == 'TaskGroup'."
    - "asyncio.Runner is available in Python 3.11+ with __name__ == 'Runner'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for core asyncio classes
#
# For top-level classes (not nested), __qualname__ equals __name__.
# These complement the __name__ checks in asyncio_extra and asyncio_extra2.
# ---------------------------------------------------------------------------

table asyncio_extra3.class_qualnames:
  description: "asyncio classes have correct __qualname__ (equals __name__ for top-level classes)"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Task,      Task.__qualname__.__eq__,      ["Task"],      true]
    - [Future,    Future.__qualname__.__eq__,    ["Future"],    true]
    - [Queue,     Queue.__qualname__.__eq__,     ["Queue"],     true]
    - [Lock,      Lock.__qualname__.__eq__,      ["Lock"],      true]
    - [Event,     Event.__qualname__.__eq__,     ["Event"],     true]
    - [Semaphore, Semaphore.__qualname__.__eq__, ["Semaphore"], true]
    - [Condition, Condition.__qualname__.__eq__, ["Condition"], true]

# ---------------------------------------------------------------------------
# __qualname__ checks for top-level asyncio functions
#
# gather, sleep, and create_task are plain functions defined at module scope
# in asyncio.tasks; their __qualname__ equals their __name__.
# ---------------------------------------------------------------------------

invariant asyncio_extra3.gather.qualname:
  description: "asyncio.gather.__qualname__ == 'gather'"
  category: function_qualnames
  kind: python_call_eq
  function: gather.__qualname__.__eq__
  args: ["gather"]
  expected: true

invariant asyncio_extra3.sleep.qualname:
  description: "asyncio.sleep.__qualname__ == 'sleep'"
  category: function_qualnames
  kind: python_call_eq
  function: sleep.__qualname__.__eq__
  args: ["sleep"]
  expected: true

invariant asyncio_extra3.create_task.qualname:
  description: "asyncio.create_task.__qualname__ == 'create_task'"
  category: function_qualnames
  kind: python_call_eq
  function: create_task.__qualname__.__eq__
  args: ["create_task"]
  expected: true

# ---------------------------------------------------------------------------
# Additional function name checks
#
# wait and shield are top-level asyncio coroutine functions not yet covered
# in earlier specs with a dedicated __name__ check.
# ---------------------------------------------------------------------------

invariant asyncio_extra3.wait.name:
  description: "asyncio.wait.__name__ == 'wait'"
  category: function_names
  kind: python_call_eq
  function: wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant asyncio_extra3.shield.name:
  description: "asyncio.shield.__name__ == 'shield'"
  category: function_names
  kind: python_call_eq
  function: shield.__name__.__eq__
  args: ["shield"]
  expected: true

invariant asyncio_extra3.wait_for.name:
  description: "asyncio.wait_for.__name__ == 'wait_for'"
  category: function_names
  kind: python_call_eq
  function: wait_for.__name__.__eq__
  args: ["wait_for"]
  expected: true

# ---------------------------------------------------------------------------
# Queue subclass names
#
# asyncio exports PriorityQueue and LifoQueue alongside Queue.
# Their __qualname__ values match their __name__ values (top-level classes).
# ---------------------------------------------------------------------------

invariant asyncio_extra3.PriorityQueue.qualname:
  description: "asyncio.PriorityQueue.__qualname__ == 'PriorityQueue'"
  category: qualnames
  kind: python_call_eq
  function: PriorityQueue.__qualname__.__eq__
  args: ["PriorityQueue"]
  expected: true

invariant asyncio_extra3.LifoQueue.qualname:
  description: "asyncio.LifoQueue.__qualname__ == 'LifoQueue'"
  category: qualnames
  kind: python_call_eq
  function: LifoQueue.__qualname__.__eq__
  args: ["LifoQueue"]
  expected: true

# ---------------------------------------------------------------------------
# Python 3.11+ additions: Barrier, TaskGroup, Runner
#
# asyncio.Barrier — a synchronization primitive added in Python 3.11.
# asyncio.TaskGroup — structured concurrency context manager (Python 3.11+).
# asyncio.Runner — manages an event loop for running async code (Python 3.11+).
# ---------------------------------------------------------------------------

invariant asyncio_extra3.Barrier.name:
  description: "asyncio.Barrier.__name__ == 'Barrier' (Python 3.11+)"
  category: classes_311
  kind: python_call_eq
  function: Barrier.__name__.__eq__
  args: ["Barrier"]
  expected: true
  version: ">=3.11"

invariant asyncio_extra3.Barrier.module:
  description: "asyncio.Barrier.__module__ == 'asyncio.locks' (Python 3.11+)"
  category: classes_311
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true
  version: ">=3.11"

invariant asyncio_extra3.TaskGroup.name:
  description: "asyncio.TaskGroup.__name__ == 'TaskGroup' (Python 3.11+)"
  category: classes_311
  kind: python_call_eq
  function: TaskGroup.__name__.__eq__
  args: ["TaskGroup"]
  expected: true
  version: ">=3.11"

invariant asyncio_extra3.TaskGroup.module:
  description: "asyncio.TaskGroup.__module__ == 'asyncio.taskgroups' (Python 3.11+)"
  category: classes_311
  kind: python_call_eq
  function: TaskGroup.__module__.__eq__
  args: ["asyncio.taskgroups"]
  expected: true
  version: ">=3.11"

invariant asyncio_extra3.Runner.name:
  description: "asyncio.Runner.__name__ == 'Runner' (Python 3.11+)"
  category: classes_311
  kind: python_call_eq
  function: Runner.__name__.__eq__
  args: ["Runner"]
  expected: true
  version: ">=3.11"

invariant asyncio_extra3.Runner.module:
  description: "asyncio.Runner.__module__ == 'asyncio.runners' (Python 3.11+)"
  category: classes_311
  kind: python_call_eq
  function: Runner.__module__.__eq__
  args: ["asyncio.runners"]
  expected: true
  version: ">=3.11"
