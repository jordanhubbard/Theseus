spec: functools_extra309
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.lru_cache(-1) does NOT raise — negative maxsize is accepted and treated as unbounded cache."
    - "functools.reduce(func, []) with no initializer raises TypeError — empty iterable has no defined result."
    - "functools.total_ordering raises ValueError when applied to a class with no ordering operation (< > <= >=). A class with only __eq__ triggers the error."
    - "functools.cmp_to_key is a C-level built-in: __module__ == '_functools'."
    - "functools.partial.__name__ == 'partial'; __module__ == 'functools'."
    - "functools.total_ordering.__code__.co_argcount == 1 — the decorator takes exactly one argument (the class to decorate)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# cmp_to_key module identity
#
# functools.cmp_to_key is implemented in the C extension _functools.
# Its __module__ is '_functools', not 'functools'.
# Verified: functools.cmp_to_key.__module__ == '_functools'.
# ---------------------------------------------------------------------------

invariant functools_extra309.cmp_to_key_module:
  description: "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is implemented in C extension _functools"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true

# ---------------------------------------------------------------------------
# partial class name and module
#
# functools.partial is a C-level type. Its __name__ is 'partial' and its
# __module__ is 'functools' (the public module re-exports it).
# Verified: functools.partial.__name__ == 'partial',
#           functools.partial.__module__ == 'functools'.
# ---------------------------------------------------------------------------

invariant functools_extra309.partial_name:
  description: "functools.partial.__name__ == 'partial'"
  category: identity
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra309.partial_module:
  description: "functools.partial.__module__ == 'functools'"
  category: identity
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

# ---------------------------------------------------------------------------
# total_ordering code object attributes
#
# functools.total_ordering is a pure-Python decorator function.
# Its code object records: co_argcount == 1 (takes one class argument),
# co_name == 'total_ordering'.
# Verified with Python 3.14.4.
# ---------------------------------------------------------------------------

invariant functools_extra309.total_ordering_co_argcount:
  description: "functools.total_ordering.__code__.co_argcount == 1 — the decorator takes exactly one argument (the class)"
  category: identity
  kind: python_call_eq
  function: total_ordering.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant functools_extra309.total_ordering_co_name:
  description: "functools.total_ordering.__code__.co_name == 'total_ordering'"
  category: identity
  kind: python_call_eq
  function: total_ordering.__code__.co_name.__eq__
  args: ["total_ordering"]
  expected: true

# ---------------------------------------------------------------------------
# reduce error on empty sequence
#
# functools.reduce(func, []) with no initializer raises TypeError.
# The harness resolves 'int' from the module namespace as a callable;
# passing it an empty list triggers the TypeError.
# Verified: reduce(int, []) -> TypeError: reduce() of empty iterable with
#           no initial value.
# ---------------------------------------------------------------------------

invariant functools_extra309.reduce_empty_TypeError:
  description: "functools.reduce(int, []) raises TypeError — reduce of empty iterable with no initial value"
  category: errors
  kind: python_call_raises
  function: reduce
  args: "[int, []]"
  expected: TypeError

# ---------------------------------------------------------------------------
# lru_cache negative maxsize — no error
#
# functools.lru_cache(-1) is accepted without error. Negative maxsize is
# treated as unbounded cache (equivalent to None). Verified: no exception.
# The invariant below confirms lru_cache is a Python function, demonstrating
# that the symbol resolves and is callable.
# ---------------------------------------------------------------------------

invariant functools_extra309.lru_cache_is_function:
  description: "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is a Python-level function"
  category: identity
  kind: python_call_eq
  function: lru_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true
