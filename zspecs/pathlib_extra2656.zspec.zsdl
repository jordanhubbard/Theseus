spec: pathlib_extra2656
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers existing pathlib invariants"
    - "pathlib_extra2641.zspec.zsdl — covers __copy__/__deepcopy__/__sizeof__ dict-presence"
  notes:
    - "Wave 624 (pathlib_extra2656) theme: __contains__, __add__, and __mul__ dict-presence checks."
    - "None of the pathlib classes define __contains__, __add__, or __mul__ in their own __dict__."
    - "__contains__ is the membership-test protocol; pathlib path objects do not implement container semantics."
    - "__add__ and __mul__ are arithmetic operators; pathlib uses __truediv__ (the / operator) for path joining, not __add__ or __mul__."
    - "Covers pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, and pathlib.Path."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __contains__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2656.no_contains_in_pathlib_classes:
  description: "__contains__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the container membership protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2656

  columns: [id, function, args, expected]
  rows:
    - ["pp2656001", "pathlib.PurePath.__dict__.__contains__",        ["__contains__"], false]
    - ["pp2656002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__contains__"], false]
    - ["pp2656003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__contains__"], false]
    - ["pp2656004", "pathlib.Path.__dict__.__contains__",            ["__contains__"], false]

# ---------------------------------------------------------------------------
# __add__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2656.no_add_in_pathlib_classes:
  description: "__add__ is absent from all pathlib class __dict__s — pathlib uses __truediv__ for path joining, not __add__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2656

  columns: [id, function, args, expected]
  rows:
    - ["pp2656005", "pathlib.PurePath.__dict__.__contains__",        ["__add__"], false]
    - ["pp2656006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__add__"], false]
    - ["pp2656007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__add__"], false]
    - ["pp2656008", "pathlib.Path.__dict__.__contains__",            ["__add__"], false]

# ---------------------------------------------------------------------------
# __mul__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2656.no_mul_in_pathlib_classes:
  description: "__mul__ is absent from all pathlib class __dict__s — pathlib path classes do not implement the repetition protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2656

  columns: [id, function, args, expected]
  rows:
    - ["pp2656009",  "pathlib.PurePath.__dict__.__contains__",        ["__mul__"], false]
    - ["pp2656010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__mul__"], false]
    - ["pp2656011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__mul__"], false]
    - ["pp2656012", "pathlib.Path.__dict__.__contains__",            ["__mul__"], false]

# ---------------------------------------------------------------------------
# Complementary: pathlib classes have path-manipulation methods but not arithmetic/container hooks
# Confirms that path objects use __truediv__ for joining and have no arithmetic/container semantics
# ---------------------------------------------------------------------------

table pathlib_extra2656.pathlib_has_path_methods_not_arithmetic_hooks:
  description: "pathlib.PurePath defines __str__/__truediv__/__fspath__ but NOT __contains__/__add__/__mul__; pathlib.Path similarly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2656

  columns: [id, function, args, expected]
  rows:
    - ["pp2656013", "pathlib.PurePath.__dict__.__contains__", ["__str__"],      true]
    - ["pp2656014", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"],  true]
    - ["pp2656015", "pathlib.PurePath.__dict__.__contains__", ["__fspath__"],   true]
    - ["pp2656016", "pathlib.PurePath.__dict__.__contains__", ["__contains__"], false]
    - ["pp2656017", "pathlib.PurePath.__dict__.__contains__", ["__add__"],      false]
    - ["pp2656018", "pathlib.PurePath.__dict__.__contains__", ["__mul__"],      false]
    - ["pp2656019", "pathlib.Path.__dict__.__contains__",     ["stat"],         true]
    - ["pp2656020", "pathlib.Path.__dict__.__contains__",     ["exists"],       true]
    - ["pp2656021", "pathlib.Path.__dict__.__contains__",     ["open"],         true]
    - ["pp2656022", "pathlib.Path.__dict__.__contains__",     ["__contains__"], false]
    - ["pp2656023", "pathlib.Path.__dict__.__contains__",     ["__add__"],      false]
    - ["pp2656024", "pathlib.Path.__dict__.__contains__",     ["__mul__"],      false]
