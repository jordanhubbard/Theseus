spec: concurrent_futures_extra2041
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2041): __lshift__, __rshift__, __and__, __or__, __xor__, __invert__ dict-presence checks."
    - "concurrent.futures types (Future, ThreadPoolExecutor, ProcessPoolExecutor, Executor) are concurrency primitives."
    - "None of these types define bit-shift, bitwise AND/OR/XOR, or bitwise NOT protocols in their own __dict__."
    - "Executor is an abstract base class; ThreadPoolExecutor and ProcessPoolExecutor extend it."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra2041.lshift_protocol:
  description: "concurrent.futures types __lshift__/__rlshift__/__ilshift__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2041

  columns: [id, function, args, expected]
  rows:
    - ["cf2041001", "concurrent.futures.Future.__dict__.__contains__", ["__lshift__"], false]
    - ["cf2041002", "concurrent.futures.Future.__dict__.__contains__", ["__rlshift__"], false]
    - ["cf2041003", "concurrent.futures.Future.__dict__.__contains__", ["__ilshift__"], false]
    - ["cf2041004", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__lshift__"], false]
    - ["cf2041005", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__rlshift__"], false]
    - ["cf2041006", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__ilshift__"], false]
    - ["cf2041007", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__lshift__"], false]
    - ["cf2041008", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__rlshift__"], false]
    - ["cf2041009", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__ilshift__"], false]
    - ["cf2041010", "concurrent.futures.Executor.__dict__.__contains__", ["__lshift__"], false]
    - ["cf2041011", "concurrent.futures.Executor.__dict__.__contains__", ["__rlshift__"], false]
    - ["cf2041012", "concurrent.futures.Executor.__dict__.__contains__", ["__ilshift__"], false]

