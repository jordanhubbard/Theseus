spec: asyncio_extra209
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py, Lib/asyncio/tasks.py"
  notes:
    - "asyncio.sleep.__annotations__.__class__.__name__ == 'dict' — annotations is always a plain dict; asyncio.sleep has no type annotations on Python 3.14.3, so the dict is empty ({}) but its class is still 'dict'."
    - "asyncio.run.__annotations__.__class__.__name__ == 'dict' — asyncio.run also carries no annotations on 3.14.3; __annotations__ == {}."
    - "asyncio.Lock.__dict__.__contains__('acquire') returns True — Lock.acquire() is defined directly on the class in Lib/asyncio/locks.py; it is a coroutine that acquires the lock, blocking until it is free."
    - "asyncio.Lock.__dict__.__contains__('release') returns True — Lock.release() is defined directly on the class; it releases the lock and wakes a waiter if any."
    - "asyncio.Event.__dict__.__contains__('set') returns True — Event.set() is defined directly on the class in asyncio.locks; it sets the internal flag to True and wakes all waiters."
    - "asyncio.Event.__dict__.__contains__('wait') returns True — Event.wait() is defined directly on the class; it is a coroutine that blocks until the internal flag is True."
    - "asyncio.Lock.__dict__ keys on Python 3.14.3: __module__, __firstlineno__, __doc__, __init__, __repr__, locked, acquire, release, _wake_up_first, __static_attributes__."
    - "asyncio.Event.__dict__ keys on Python 3.14.3: __module__, __firstlineno__, __doc__, __init__, __repr__, is_set, set, clear, wait, __static_attributes__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.sleep and asyncio.run __annotations__ class name checks
#
# asyncio.sleep.__annotations__.__class__.__name__  == 'dict'
# asyncio.run.__annotations__.__class__.__name__    == 'dict'
# asyncio.sleep.__annotations__.__len__()           == 0
# asyncio.run.__annotations__.__len__()             == 0
# ---------------------------------------------------------------------------

table asyncio_extra209.annotations_class_name:
  description: "asyncio.sleep and asyncio.run __annotations__.__class__.__name__ checks in asyncioannotations209 namespace — sleep.__annotations__.__class__.__name__=='dict' (annotations is always a plain dict object; asyncio.sleep has no type annotations on Python 3.14.3 so the dict is empty but its class is still 'dict'); run.__annotations__.__class__.__name__=='dict' (asyncio.run likewise carries no annotations on 3.14.3); sleep.__annotations__.__len__()==0 (empty dict); run.__annotations__.__len__()==0 (empty dict); verified with Python 3.14.3"
  kind: python_call_eq
  category: annotations
  id_prefix: asyncioannotations209

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_annotations_class_name,   "asyncio.sleep.__annotations__.__class__.__name__.__eq__",   ["dict"], true, "asyncio.sleep.__annotations__.__class__.__name__ == 'dict'; verified Python 3.14.3"]
    - [run_annotations_class_name,     "asyncio.run.__annotations__.__class__.__name__.__eq__",     ["dict"], true, "asyncio.run.__annotations__.__class__.__name__ == 'dict'; verified Python 3.14.3"]
    - [sleep_annotations_len,          "asyncio.sleep.__annotations__.__len__",                     [],       0,    "asyncio.sleep.__annotations__.__len__() == 0 (no type annotations); verified Python 3.14.3"]
    - [run_annotations_len,            "asyncio.run.__annotations__.__len__",                       [],       0,    "asyncio.run.__annotations__.__len__() == 0 (no type annotations); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.Lock.__dict__ membership checks
#
# asyncio.Lock.__dict__.__contains__('acquire')  == True
# asyncio.Lock.__dict__.__contains__('release')  == True
# asyncio.Lock.__dict__.__contains__('locked')   == True
# asyncio.Lock.__dict__.__contains__('__repr__') == True
# ---------------------------------------------------------------------------

table asyncio_extra209.lock_dict_membership:
  description: "asyncio.Lock.__dict__ membership checks in asyncioannotations209 namespace — Lock.__dict__.__contains__('acquire')==True (Lock.acquire() is a coroutine defined directly on the class in Lib/asyncio/locks.py; it acquires the lock, blocking until it is free); Lock.__dict__.__contains__('release')==True (Lock.release() releases the lock and notifies one waiter); Lock.__dict__.__contains__('locked')==True (Lock.locked() returns True if the lock is currently held); Lock.__dict__.__contains__('__repr__')==True (Lock.__repr__ is defined on the class to show lock state); all four are in Lock.__dict__ (not inherited); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: asyncioannotations209a

  columns: [id, function, args, expected, description]
  rows:
    - [lock_dict_has_acquire,   "asyncio.Lock.__dict__.__contains__",   ["acquire"],   true, "asyncio.Lock.__dict__.__contains__('acquire') == True; verified Python 3.14.3"]
    - [lock_dict_has_release,   "asyncio.Lock.__dict__.__contains__",   ["release"],   true, "asyncio.Lock.__dict__.__contains__('release') == True; verified Python 3.14.3"]
    - [lock_dict_has_locked,    "asyncio.Lock.__dict__.__contains__",   ["locked"],    true, "asyncio.Lock.__dict__.__contains__('locked') == True; verified Python 3.14.3"]
    - [lock_dict_has_repr,      "asyncio.Lock.__dict__.__contains__",   ["__repr__"],  true, "asyncio.Lock.__dict__.__contains__('__repr__') == True; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Event.__dict__ membership checks
#
# asyncio.Event.__dict__.__contains__('set')    == True
# asyncio.Event.__dict__.__contains__('wait')   == True
# asyncio.Event.__dict__.__contains__('clear')  == True
# asyncio.Event.__dict__.__contains__('is_set') == True
# ---------------------------------------------------------------------------

table asyncio_extra209.event_dict_membership:
  description: "asyncio.Event.__dict__ membership checks in asyncioannotations209 namespace — Event.__dict__.__contains__('set')==True (Event.set() sets the internal flag to True and wakes all coroutines waiting on wait()); Event.__dict__.__contains__('wait')==True (Event.wait() is a coroutine that blocks until set() is called); Event.__dict__.__contains__('clear')==True (Event.clear() resets the internal flag to False); Event.__dict__.__contains__('is_set')==True (Event.is_set() returns True if the internal flag is set); all four methods are defined directly on asyncio.Event in asyncio.locks on Python 3.14.3; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: asyncioannotations209b

  columns: [id, function, args, expected, description]
  rows:
    - [event_dict_has_set,    "asyncio.Event.__dict__.__contains__",   ["set"],    true, "asyncio.Event.__dict__.__contains__('set') == True; verified Python 3.14.3"]
    - [event_dict_has_wait,   "asyncio.Event.__dict__.__contains__",   ["wait"],   true, "asyncio.Event.__dict__.__contains__('wait') == True; verified Python 3.14.3"]
    - [event_dict_has_clear,  "asyncio.Event.__dict__.__contains__",   ["clear"],  true, "asyncio.Event.__dict__.__contains__('clear') == True; verified Python 3.14.3"]
    - [event_dict_has_is_set, "asyncio.Event.__dict__.__contains__",   ["is_set"], true, "asyncio.Event.__dict__.__contains__('is_set') == True; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra209
# ---------------------------------------------------------------------------

invariant asyncio_extra209.sleep_annotations_class_name_dict:
  description: "asyncio.sleep.__annotations__.__class__.__name__.__eq__('dict') returns True — asyncio.sleep.__annotations__ is a plain dict; on Python 3.14.3 asyncio.sleep carries no PEP-3107 type annotations so the dict is empty ({}), but __annotations__.__class__.__name__ is 'dict' (len=4: d-i-c-t); __annotations__ is always a dict object even when empty; NEW in extra209: first standalone asyncio.sleep annotations class name invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: annotations
  kind: python_call_eq
  function: asyncio.sleep.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant asyncio_extra209.run_annotations_class_name_dict:
  description: "asyncio.run.__annotations__.__class__.__name__.__eq__('dict') returns True — asyncio.run.__annotations__ is a plain dict; asyncio.run has no type annotations on Python 3.14.3 so the dict is empty; __annotations__.__class__.__name__ is 'dict'; asyncio.run(coro, *, debug=None, loop_factory=None) is the main entry point for running a coroutine; NEW in extra209; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: annotations
  kind: python_call_eq
  function: asyncio.run.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant asyncio_extra209.sleep_annotations_len_zero:
  description: "asyncio.sleep.__annotations__.__len__() returns 0 — asyncio.sleep has no PEP-3107 type annotations on Python 3.14.3; __annotations__ is an empty dict with length 0; asyncio.sleep(delay=0, result=None) takes two parameters but neither has an annotation; compare: __code__.co_varnames has 5 entries ('delay', 'result', 'loop', 'future', 'h') while __annotations__ has 0; NEW in extra209; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: annotations
  kind: python_call_eq
  function: asyncio.sleep.__annotations__.__len__
  args: []
  expected: 0

invariant asyncio_extra209.lock_dict_contains_acquire:
  description: "asyncio.Lock.__dict__.__contains__('acquire') returns True — asyncio.Lock defines acquire() directly in its class body in Lib/asyncio/locks.py; Lock.acquire() is a coroutine that acquires the lock, blocking until it is free; if the lock is unlocked it locks it immediately and returns True; if locked it suspends until the lock is released; 'acquire' is in Lock.__dict__ (not inherited from a base class); NEW in extra209; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Lock.__dict__.__contains__
  args: ["acquire"]
  expected: true

invariant asyncio_extra209.lock_dict_contains_release:
  description: "asyncio.Lock.__dict__.__contains__('release') returns True — asyncio.Lock defines release() directly in its class body; Lock.release() releases the lock; if any coroutines are waiting for the lock one of them is woken and given the lock; if the lock is already unlocked raises RuntimeError; 'release' is in Lock.__dict__ (not inherited); NEW in extra209; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Lock.__dict__.__contains__
  args: ["release"]
  expected: true

invariant asyncio_extra209.event_dict_contains_set:
  description: "asyncio.Event.__dict__.__contains__('set') returns True — asyncio.Event defines set() directly in its class body in asyncio.locks; Event.set() sets the internal flag to True and wakes all coroutines blocked in wait(); once set the flag remains True until clear() is called; 'set' is in Event.__dict__ (not inherited); NEW in extra209; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Event.__dict__.__contains__
  args: ["set"]
  expected: true

invariant asyncio_extra209.event_dict_contains_wait:
  description: "asyncio.Event.__dict__.__contains__('wait') returns True — asyncio.Event defines wait() directly in its class body; Event.wait() is a coroutine that blocks until the internal flag is True; if the flag is already True it returns immediately; if set() was called before wait() the coroutine proceeds without blocking; 'wait' is in Event.__dict__ (not inherited); NEW in extra209; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Event.__dict__.__contains__
  args: ["wait"]
  expected: true

invariant asyncio_extra209.run_annotations_len_zero:
  description: "asyncio.run.__annotations__.__len__() returns 0 — asyncio.run has no type annotations on Python 3.14.3; __annotations__ is an empty dict ({}); asyncio.run(coro, *, debug=None, loop_factory=None) is the top-level entry point for running asyncio programs; the function has parameters but none are annotated; len==0 confirms the dict is empty; NEW in extra209; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: annotations
  kind: python_call_eq
  function: asyncio.run.__annotations__.__len__
  args: []
  expected: 0
