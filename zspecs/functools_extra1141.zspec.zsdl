spec: functools_extra1141
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks WRAPPER_ASSIGNMENTS.__len__()==5, WRAPPER_UPDATES.__len__()==1, partial.func.__class__.__name__ when wrapping a builtin, lru_cache.__class__.__name__, cmp_to_key qualname/module/class, total_ordering module — not covered in _extra1111/_extra1126"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1141.wrapper_assignments_updates_lens:
  description: "functools.WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES length and element class identity"
  kind: python_call_eq
  category: wrapper_assignments_updates_lens
  id_prefix: fn1141wa
  columns: [id, function, args, expected]
  rows:
    - [fn1141wa001, functools.WRAPPER_ASSIGNMENTS.__len__,                           [],                               5]
    - [fn1141wa002, functools.WRAPPER_UPDATES.__len__,                               [],                               1]
    - [fn1141wa003, functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__,         ["tuple"],                        true]
    - [fn1141wa004, functools.WRAPPER_UPDATES.__class__.__name__.__eq__,             ["tuple"],                        true]
    - [fn1141wa005, functools.WRAPPER_ASSIGNMENTS.__contains__,                      ["__module__"],                   true]
    - [fn1141wa006, functools.WRAPPER_ASSIGNMENTS.__contains__,                      ["__qualname__"],                  true]
    - [fn1141wa007, functools.WRAPPER_ASSIGNMENTS.__contains__,                      ["__doc__"],                      true]
    - [fn1141wa008, functools.WRAPPER_UPDATES.__contains__,                          ["__dict__"],                     true]

table functools_extra1141.partial_func_builtin_class:
  description: "functools.partial wrapping a builtin: .func.__class__.__name__, lru_cache class identity"
  kind: python_call_eq
  category: partial_func_builtin_class
  id_prefix: fn1141pb
  columns: [id, function, args, expected]
  rows:
    - [fn1141pb001, functools.partial.__new__.__qualname__.__eq__,                   ["partial.__new__"],              true]
    - [fn1141pb002, functools.partial.__new__.__class__.__name__.__eq__,             ["builtin_function_or_method"],   true]
    - [fn1141pb003, functools.lru_cache.__class__.__name__.__eq__,                   ["function"],                     true]
    - [fn1141pb004, functools.lru_cache.__module__.__eq__,                           ["functools"],                    true]
    - [fn1141pb005, functools.lru_cache.__doc__.__class__.__name__.__eq__,           ["str"],                          true]
    - [fn1141pb006, functools.reduce.__doc__.__class__.__name__.__eq__,              ["str"],                          true]
    - [fn1141pb007, functools.reduce.__qualname__.__eq__,                            ["reduce"],                       true]
    - [fn1141pb008, functools.cmp_to_key.__doc__.__class__.__name__.__eq__,          ["str"],                          true]

table functools_extra1141.cmp_to_key_total_ordering_identity:
  description: "functools.cmp_to_key and total_ordering qualname, module, and class identity"
  kind: python_call_eq
  category: cmp_to_key_total_ordering_identity
  id_prefix: fn1141ct
  columns: [id, function, args, expected]
  rows:
    - [fn1141ct001, functools.cmp_to_key.__qualname__.__eq__,                        ["cmp_to_key"],                   true]
    - [fn1141ct002, functools.cmp_to_key.__module__.__eq__,                          ["functools"],                    true]
    - [fn1141ct003, functools.cmp_to_key.__class__.__name__.__eq__,                  ["builtin_function_or_method"],   true]
    - [fn1141ct004, functools.total_ordering.__qualname__.__eq__,                    ["total_ordering"],               true]
    - [fn1141ct005, functools.total_ordering.__module__.__eq__,                      ["functools"],                    true]
    - [fn1141ct006, functools.total_ordering.__class__.__name__.__eq__,              ["function"],                     true]
    - [fn1141ct007, functools.total_ordering.__doc__.__class__.__name__.__eq__,      ["str"],                          true]
    - [fn1141ct008, functools.singledispatchmethod.__qualname__.__eq__,              ["singledispatchmethod"],          true]
