spec: theseus_types_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_types_cr2)
blocks: types

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html"
  notes:
    - "Clean-room extended types utilities. Do NOT import types."
    - "SimpleNamespace(**kwargs): object with settable attributes via kwargs."
    - "MappingProxyType(mapping): read-only proxy of a dict."
    - "types2_namespace(): SimpleNamespace(x=1).x == 1."
    - "types2_mapping_proxy(): MappingProxyType({'a': 1})['a'] == 1."
    - "types2_namespace_repr(): 'x=1' in repr(SimpleNamespace(x=1))."
    - "Zero-arg invariant signatures — def types2_namespace(): return hardcoded_result"
    - "SimpleNamespace stores kwargs as instance attributes accessible via dot notation."
    - "MappingProxyType wraps a dict and raises TypeError on write operations."
    - "Export: SimpleNamespace, MappingProxyType."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_types_cr2.namespace:
  description: "SimpleNamespace(x=1).x == 1"
  category: SimpleNamespace
  kind: python_call_eq
  function: types2_namespace
  args: []
  expected: 1

invariant theseus_types_cr2.mapping_proxy:
  description: "MappingProxyType({'a': 1})['a'] == 1"
  category: MappingProxyType
  kind: python_call_eq
  function: types2_mapping_proxy
  args: []
  expected: 1

invariant theseus_types_cr2.namespace_repr:
  description: "'x=1' in repr(SimpleNamespace(x=1))"
  category: SimpleNamespace
  kind: python_call_eq
  function: types2_namespace_repr
  args: []
  expected: true
