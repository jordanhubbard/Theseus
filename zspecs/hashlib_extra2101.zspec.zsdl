spec: hashlib_extra2101
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c, Modules/_blake2/blake2module.c"
  notes:
    - "Wave extra2101 (hashlib_extra2101): __class_getitem__, __init_subclass__, __subclasshook__, __mro_entries__ dict-presence checks."
    - "hashlib exposes hash objects via C extension types: _hashlib.HASH (md5, sha1, sha224, sha256, sha384, sha512, sha3_*), _hashlib.HASHXOF (shake_128, shake_256), _blake2.blake2b, _blake2.blake2s."
    - "None of the hashlib hash classes define __class_getitem__ in their own __dict__ — generic subscript notation is not supported."
    - "None define __init_subclass__ in their own __dict__ — the hook is inherited from object via C extension type machinery."
    - "None define __subclasshook__ in their own __dict__ — ABC virtual subclass checking is not customized for hash types."
    - "None define __mro_entries__ in their own __dict__ — MRO resolution protocol is absent from all hash types."
    - "hashlib.md5().__class__ and hashlib.sha256().__class__ both resolve to _hashlib.HASH — same dict tested twice for robustness."
    - "hashlib.shake_128().__class__ resolves to _hashlib.HASHXOF, a distinct C extension class with a subset of _hashlib.HASH methods."
    - "hashlib.blake2b().__class__ is _blake2.blake2b and hashlib.blake2s().__class__ is _blake2.blake2s — separate C extension types."
    - "All expected values verified by running Python 3.14.4 hashlib module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2101.class_getitem_protocol:
  description: "hashlib hash classes __class_getitem__ dict-presence checks — generic alias protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2101

  columns: [id, function, args, expected]
  rows:
    - ["hl2101001", "hashlib.md5().__class__.__dict__.__contains__", ["__class_getitem__"], false]
    - ["hl2101002", "hashlib.sha256().__class__.__dict__.__contains__", ["__class_getitem__"], false]
    - ["hl2101003", "hashlib.sha1().__class__.__dict__.__contains__", ["__class_getitem__"], false]
    - ["hl2101004", "hashlib.sha512().__class__.__dict__.__contains__", ["__class_getitem__"], false]
    - ["hl2101005", "hashlib.sha3_256().__class__.__dict__.__contains__", ["__class_getitem__"], false]
    - ["hl2101006", "hashlib.shake_128().__class__.__dict__.__contains__", ["__class_getitem__"], false]
    - ["hl2101007", "hashlib.blake2b().__class__.__dict__.__contains__", ["__class_getitem__"], false]

