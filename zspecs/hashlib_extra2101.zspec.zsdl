    - ["hl2101009", "hashlib.sha256().__class__.__dict__.__contains__", ["__init_subclass__"], false]
    - ["hl2101010", "hashlib.sha1().__class__.__dict__.__contains__", ["__init_subclass__"], false]
    - ["hl2101011", "hashlib.sha512().__class__.__dict__.__contains__", ["__init_subclass__"], false]
    - ["hl2101012", "hashlib.sha3_256().__class__.__dict__.__contains__", ["__init_subclass__"], false]
    - ["hl2101013", "hashlib.shake_128().__class__.__dict__.__contains__", ["__init_subclass__"], false]
    - ["hl2101014", "hashlib.blake2b().__class__.__dict__.__contains__", ["__init_subclass__"], false]

