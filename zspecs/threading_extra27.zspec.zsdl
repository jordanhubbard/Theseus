spec: threading_extra27
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends prior threading specs through threading_extra26.zspec.zsdl."
    - "threading_extra19 covers: Lock/RLock/Condition/Semaphore/Timer/Barrier/BoundedSemaphore __qualname__ eq table."
    - "threading_extra26 covers: Thread property fget qualnames; Barrier/BoundedSemaphore method qualnames; daemon fset; main_thread class; TIMEOUT_MAX class."
    - "NOT yet covered in any prior spec: threading.Thread.__module__ and Thread.__bases__[0].__name__ in extra27 namespace."
    - "NOT yet covered: threading.Lock.__module__ (== '_thread', C-level) in extra27 namespace."
    - "NOT yet covered: threading.RLock.__module__ in extra27 namespace."
    - "NOT yet covered: threading.Event.__module__ in extra27 namespace."
    - "NOT yet covered: threading.Condition.__module__ in extra27 namespace."
    - "NOT yet covered: threading.Semaphore.__module__ in extra27 namespace."
    - "NOT yet covered: threading.local.__qualname__ (== '_local') and __module__ (== '_thread') in extra27 namespace."
    - "Thread.__module__ == 'threading' — length 9."
    - "Thread.__bases__[0].__name__ == 'object' — Thread directly inherits from object (length 6)."
    - "Lock.__qualname__ == 'lock' — lowercase; C-level type from _thread module (length 4)."
    - "Lock.__module__ == '_thread' — defined in C extension module (length 7)."
    - "RLock.__qualname__ == 'RLock' — Python class in threading module (length 5)."
    - "RLock.__module__ == 'threading' — length 9."
    - "Event.__qualname__ == 'Event' — length 5."
    - "Event.__module__ == 'threading' — length 9."
    - "Condition.__qualname__ == 'Condition' — length 9."
    - "Condition.__module__ == 'threading' — length 9."
    - "Semaphore.__qualname__ == 'Semaphore' — length 9."
    - "Semaphore.__module__ == 'threading' — length 9."
    - "local.__qualname__ == '_local' — C-level type aliased as threading.local (length 6)."
    - "local.__module__ == '_thread' — defined in C extension module (length 7)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __module__ table — extra27 namespace
#
# threading.Thread.__module__ == 'threading' (length 9).
# threading.RLock.__module__ == 'threading' (length 9).
# threading.Event.__module__ == 'threading' (length 9).
# threading.Condition.__module__ == 'threading' (length 9).
# threading.Semaphore.__module__ == 'threading' (length 9).
# threading.Lock.__module__ == '_thread' (C-level, length 7).
# threading.local.__module__ == '_thread' (C-level, length 7).
# No prior spec checks these __module__ values.
# ---------------------------------------------------------------------------

table threading_extra27.class_modules:
  description: "threading class __module__ values in extra27 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: clsmod27

  columns: [id, function, args, expected]
  rows:
    - [Thread,    Thread.__module__.__eq__,    ["threading"], true]
    - [RLock,     RLock.__module__.__eq__,     ["threading"], true]
    - [Event,     Event.__module__.__eq__,     ["threading"], true]
    - [Condition, Condition.__module__.__eq__, ["threading"], true]
    - [Semaphore, Semaphore.__module__.__eq__, ["threading"], true]
    - [Lock,      Lock.__module__.__eq__,      ["_thread"],   true]
    - [local,     local.__module__.__eq__,     ["_thread"],   true]

# ---------------------------------------------------------------------------
# Class __module__ length table — extra27 namespace
#
# Lengths: threading(9) for Thread/RLock/Event/Condition/Semaphore;
#          _thread(7) for Lock and local.
# ---------------------------------------------------------------------------

table threading_extra27.class_module_lengths:
  description: "threading class __module__ lengths in extra27 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: clsmodlen27

  columns: [id, function, args, expected]
  rows:
    - [Thread,    Thread.__module__.__len__,    [], 9]
    - [RLock,     RLock.__module__.__len__,     [], 9]
    - [Event,     Event.__module__.__len__,     [], 9]
    - [Condition, Condition.__module__.__len__, [], 9]
    - [Semaphore, Semaphore.__module__.__len__, [], 9]
    - [Lock,      Lock.__module__.__len__,      [], 7]
    - [local,     local.__module__.__len__,     [], 7]

# ---------------------------------------------------------------------------
# C-level type __qualname__ table — extra27 namespace
#
# threading.Lock is a C-level type whose __qualname__ is 'lock' (lowercase),
# not 'Lock'. threading.local is a C-level type whose __qualname__ is '_local'.
# threading_extra19 checked class-level __qualname__ for Python classes.
# No prior spec checks Lock.__qualname__ or local.__qualname__.
# Lengths: lock(4), _local(6).
# ---------------------------------------------------------------------------

table threading_extra27.clevel_type_qualnames:
  description: "threading C-level type __qualname__ values in extra27 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: cltqn27

  columns: [id, function, args, expected]
  rows:
    - [Lock,  Lock.__qualname__.__eq__,  ["lock"],   true]
    - [local, local.__qualname__.__eq__, ["_local"], true]

# ---------------------------------------------------------------------------
# C-level type __qualname__ length table — extra27 namespace
#
# Lengths: lock(4), _local(6).
# ---------------------------------------------------------------------------

table threading_extra27.clevel_type_qualname_lengths:
  description: "threading C-level type __qualname__ lengths in extra27 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: cltqnlen27

  columns: [id, function, args, expected]
  rows:
    - [Lock,  Lock.__qualname__.__len__,  [], 4]
    - [local, local.__qualname__.__len__, [], 6]

# ---------------------------------------------------------------------------
# Thread.__bases__[0].__name__ — standalone extra27 invariant
#
# threading.Thread directly inherits from object (no intermediate class).
# Thread.__bases__[0].__name__ == 'object' (length 6).
# No prior spec checks this inheritance chain value.
# ---------------------------------------------------------------------------

invariant threading_extra27.Thread.bases_name:
  description: "threading.Thread.__bases__[0].__name__ == 'object' — Thread directly inherits from object"
  category: method_names
  kind: python_call_eq
  function: "Thread.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
