spec: logging_extra22
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends logging.zspec.zsdl through logging_extra21.zspec.zsdl."
    - "logging_extra21 covers: debug/info/warning/error/critical/exception/log __qualname__ as standalone invariants and table."
    - "logging_extra19 covers: Manager/PlaceHolder/LogRecord/Filter __class__.__name__ == 'type'."
    - "logging_extra11 covers: Logger/Handler/Formatter/StreamHandler MRO lengths via .mro(); logging_extra12 covers NullHandler/Filter/LogRecord/Filterer/FileHandler MRO lengths."
    - "Prior specs cover MRO lengths for all major logging classes but NOT __mro__[-1].__name__ entries."
    - "NOT yet covered in any prior spec: logging.Logger.__mro__[-1].__name__ == 'object' as a standalone invariant."
    - "NOT yet covered in any prior spec: logging.Handler.__mro__[-1].__name__ == 'object' as a standalone invariant."
    - "NOT yet covered in any prior spec: logging.Formatter.__mro__[-1].__name__ == 'object' as a standalone invariant."
    - "NOT yet covered in any prior spec: logging.Filter.__mro__[-1].__name__ == 'object' as a standalone invariant."
    - "NOT yet covered in any prior spec: logging.LogRecord.__mro__[-1].__name__ == 'object' as a standalone invariant."
    - "NOT yet covered in any prior spec: logging.Filterer.__mro__[-1].__name__ == 'object' as a standalone invariant."
    - "NOT yet covered in any prior spec: logging.StreamHandler.__mro__[-1].__name__ == 'object' as a standalone invariant."
    - "NOT yet covered in any prior spec: logging.FileHandler.__mro__[-1].__name__ == 'object' as a standalone invariant."
    - "NOT yet covered in any prior spec: logging.NullHandler.__mro__[-1].__name__ == 'object' as a standalone invariant."
    - "NOT yet covered in any prior spec: logging.__name__ == 'logging' as a module identity invariant."
    - "NOT yet covered in any prior spec: logging.__package__ == 'logging' as a module identity invariant."
    - "For every Python class, __mro__[-1].__name__ is always 'object' — the universal root."
    - "logging.__name__ == 'logging' — the logging package self-identifies by name."
    - "logging.__package__ == 'logging' — unlike most stdlib modules, logging is a package; its __package__ equals its __name__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# logging module identity — __name__ and __package__
#
# No prior logging spec records the module-level __name__ or __package__
# attributes as invariants. Unlike most stdlib top-level modules whose
# __package__ is '', logging is a package; its __package__ == 'logging'.
# ---------------------------------------------------------------------------

invariant logging_extra22.module.name:
  description: "logging.__name__ == 'logging' — module self-identifies by its own name"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["logging"]
  expected: true

invariant logging_extra22.module.package:
  description: "logging.__package__ == 'logging' — logging is a package; __package__ equals __name__"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["logging"]
  expected: true

# ---------------------------------------------------------------------------
# MRO terminal element — all nine major logging classes
#
# logging_extra11/12 record MRO lengths for all major logging classes.
# No prior spec records __mro__[-1].__name__ for any logging class.
# For every Python class, __mro__[-1].__name__ == 'object'.
# Logger, Handler, StreamHandler, NullHandler have Filterer in MRO (length 3–5);
# Formatter, Filter, LogRecord, Filterer inherit directly from object (length 2).
# ---------------------------------------------------------------------------

invariant logging_extra22.Logger.mro_last:
  description: "logging.Logger.__mro__[-1].__name__ == 'object' — MRO terminal element"
  category: class_hierarchy
  kind: python_call_eq
  function: "Logger.__mro__[-1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant logging_extra22.Handler.mro_last:
  description: "logging.Handler.__mro__[-1].__name__ == 'object' — MRO terminal element"
  category: class_hierarchy
  kind: python_call_eq
  function: "Handler.__mro__[-1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant logging_extra22.Formatter.mro_last:
  description: "logging.Formatter.__mro__[-1].__name__ == 'object' — MRO terminal element"
  category: class_hierarchy
  kind: python_call_eq
  function: "Formatter.__mro__[-1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant logging_extra22.Filter.mro_last:
  description: "logging.Filter.__mro__[-1].__name__ == 'object' — MRO terminal element"
  category: class_hierarchy
  kind: python_call_eq
  function: "Filter.__mro__[-1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant logging_extra22.LogRecord.mro_last:
  description: "logging.LogRecord.__mro__[-1].__name__ == 'object' — MRO terminal element"
  category: class_hierarchy
  kind: python_call_eq
  function: "LogRecord.__mro__[-1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant logging_extra22.Filterer.mro_last:
  description: "logging.Filterer.__mro__[-1].__name__ == 'object' — MRO terminal element"
  category: class_hierarchy
  kind: python_call_eq
  function: "Filterer.__mro__[-1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant logging_extra22.StreamHandler.mro_last:
  description: "logging.StreamHandler.__mro__[-1].__name__ == 'object' — MRO terminal element"
  category: class_hierarchy
  kind: python_call_eq
  function: "StreamHandler.__mro__[-1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant logging_extra22.FileHandler.mro_last:
  description: "logging.FileHandler.__mro__[-1].__name__ == 'object' — MRO terminal element"
  category: class_hierarchy
  kind: python_call_eq
  function: "FileHandler.__mro__[-1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant logging_extra22.NullHandler.mro_last:
  description: "logging.NullHandler.__mro__[-1].__name__ == 'object' — MRO terminal element"
  category: class_hierarchy
  kind: python_call_eq
  function: "NullHandler.__mro__[-1].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# MRO terminal element table — all nine major logging classes
#
# Consolidates __mro__[-1].__name__ == 'object' checks in a single table.
# Every Python class's MRO terminates at object.
# ---------------------------------------------------------------------------

table logging_extra22.class_mro_terminal_names:
  description: "__mro__[-1].__name__ == 'object' for all nine major logging classes"
  kind: python_call_eq
  category: class_hierarchy

  columns: [id, function, args, expected]
  rows:
    - [Logger,        "Logger.__mro__[-1].__name__.__eq__",        ["object"], true]
    - [Handler,       "Handler.__mro__[-1].__name__.__eq__",       ["object"], true]
    - [Formatter,     "Formatter.__mro__[-1].__name__.__eq__",     ["object"], true]
    - [Filter,        "Filter.__mro__[-1].__name__.__eq__",        ["object"], true]
    - [LogRecord,     "LogRecord.__mro__[-1].__name__.__eq__",     ["object"], true]
    - [Filterer,      "Filterer.__mro__[-1].__name__.__eq__",      ["object"], true]
    - [StreamHandler, "StreamHandler.__mro__[-1].__name__.__eq__", ["object"], true]
    - [FileHandler,   "FileHandler.__mro__[-1].__name__.__eq__",   ["object"], true]
    - [NullHandler,   "NullHandler.__mro__[-1].__name__.__eq__",   ["object"], true]
