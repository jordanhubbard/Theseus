spec: urllib_error_extra4
version: ">=3.0"
backend: python_module(urllib.error)

docs: https://docs.python.org/3/library/urllib.error.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.error.html — Python urllib.error module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/error.py"
  notes:
    - "This spec extends urllib_error.zspec.zsdl through urllib_error_extra3.zspec.zsdl."
    - "urllib_error.zspec.zsdl covers: __name__ table, __module__ table, URLError reason, URLError.__bases__[0].__name__ == 'OSError', HTTPError code 404/reason/url/code 500, HTTPError.__bases__[0].__name__ == 'URLError'."
    - "urllib_error_extra.zspec.zsdl covers: URLError/__name__, HTTPError.__name__, HTTPError.__bases__[0].__name__ == 'URLError' (duplicate)."
    - "urllib_error_extra2.zspec.zsdl covers: __qualname__ table, ContentTooShortError.__bases__[0].__name__ == 'URLError', qualname_is_str table, HTTPError code 403/msg 403."
    - "urllib_error_extra3.zspec.zsdl covers: class_type_identity table (__class__.__name__ == 'type'), HTTPError.__bases__.__len__ == 2, HTTPError.__bases__[1].__name__ == 'addinfourl', URLError.__bases__.__len__ == 1, ContentTooShortError.__bases__.__len__ == 1, HTTPError 301 code/msg, HTTPError 500 msg/url."
    - "Focus: new axes not present in any prior urllib.error spec."
    - "URLError.__qualname__ identity via __eq__ (extra2 checks via __qualname__.__eq__ in a table; verify this axis is truly new by checking extra2 — it is in a table so these are separate standalone invariants)."
    - "HTTPError construction with code 200 ('OK') — no prior spec uses a 2xx success code; tests that HTTPError accepts any HTTP code."
    - "URLError.__name__ via direct __eq__ call (already in extra — skip); use ContentTooShortError.__name__ standalone invariant instead."
    - "HTTPError.__bases__[0].__name__ via __getitem__ with method chain — already covered; use url attribute for 301 URL check."
    - "URLError str() representation contains 'urlopen error' — str(URLError('test')) == '<urlopen error test>'."
    - "URLError args[0] == 'test' — the reason stored in args tuple."
    - "HTTPError code 200 and msg 200 — test 2xx code path not covered anywhere."
    - "ContentTooShortError.__qualname__ standalone invariant (extra2 covers it in a table row, but that is a table not a standalone invariant — this is a new distinct form)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Exception classes; raised by urllib.request operations on network failures or HTTP errors."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# URLError str() representation
#
# No prior spec checks the string representation of URLError.
# str(URLError('test')) == '<urlopen error test>'.
# ---------------------------------------------------------------------------

invariant urllib_error_extra4.URLError.str_repr:
  description: "str(URLError('test')) == '<urlopen error test>' — standard str representation"
  category: URLError
  kind: python_call_eq
  function: URLError
  args: ["test"]
  method: __str__
  method_args: []
  expected: "<urlopen error test>"

# ---------------------------------------------------------------------------
# URLError args — the reason is stored in the args tuple
#
# No prior spec checks URLError.args[0].
# ---------------------------------------------------------------------------

invariant urllib_error_extra4.URLError.args_0:
  description: "URLError('my reason').args[0] == 'my reason'"
  category: URLError
  kind: python_call_eq
  function: URLError
  args: ["my reason"]
  method: args.__getitem__
  method_args: [0]
  expected: "my reason"

# ---------------------------------------------------------------------------
# HTTPError construction — 200 OK code vector
#
# All prior specs use 4xx/5xx error codes (404, 403, 500) or 3xx (301).
# A 2xx success code is a new axis: HTTPError accepts any HTTP status code.
# ---------------------------------------------------------------------------

invariant urllib_error_extra4.httperror_200_code:
  description: "HTTPError('http://example.com', 200, 'OK', {}, None).code == 200"
  category: httperror
  kind: python_call_eq
  function: HTTPError
  args: ["http://example.com", 200, "OK", {}, null]
  method: code
  expected: 200

invariant urllib_error_extra4.httperror_200_msg:
  description: "HTTPError('http://example.com', 200, 'OK', {}, None).msg == 'OK'"
  category: httperror
  kind: python_call_eq
  function: HTTPError
  args: ["http://example.com", 200, "OK", {}, null]
  method: msg
  expected: "OK"

invariant urllib_error_extra4.httperror_200_url:
  description: "HTTPError('http://example.com', 200, 'OK', {}, None).url == 'http://example.com'"
  category: httperror
  kind: python_call_eq
  function: HTTPError
  args: ["http://example.com", 200, "OK", {}, null]
  method: url
  expected: "http://example.com"

# ---------------------------------------------------------------------------
# ContentTooShortError — reason attribute
#
# urllib_error.zspec.zsdl checks URLError.reason for a string reason.
# ContentTooShortError also inherits reason from URLError; not yet verified.
# ---------------------------------------------------------------------------

invariant urllib_error_extra4.ContentTooShortError.reason:
  description: "ContentTooShortError('too short', b'data').reason == 'too short'"
  category: ContentTooShortError
  kind: python_call_eq
  function: ContentTooShortError
  args: ["too short", !ascii "data"]
  method: reason
  expected: "too short"

# ---------------------------------------------------------------------------
# HTTPError reason attribute — separate from msg
#
# urllib_error.zspec.zsdl checks reason for the 404 case.
# The reason attribute for a 500 or 200 case has not been verified separately.
# HTTPError.reason is an alias for msg per the implementation.
# ---------------------------------------------------------------------------

invariant urllib_error_extra4.httperror_200_reason:
  description: "HTTPError('http://example.com', 200, 'OK', {}, None).reason == 'OK'"
  category: httperror
  kind: python_call_eq
  function: HTTPError
  args: ["http://example.com", 200, "OK", {}, null]
  method: reason
  expected: "OK"

# ---------------------------------------------------------------------------
# URLError __bases__ — base class name check
# urllib_error.zspec.zsdl checks __bases__[0].__name__ == 'OSError'.
# The __qualname__ of the base class has not been verified.
# ---------------------------------------------------------------------------

invariant urllib_error_extra4.URLError.base0_qualname:
  description: "urllib.error.URLError.__bases__[0].__qualname__ == 'OSError'"
  category: hierarchy
  kind: python_call_eq
  function: URLError.__bases__.__getitem__
  args: [0]
  method: __qualname__
  expected: "OSError"

# ---------------------------------------------------------------------------
# HTTPError.__bases__[0].__qualname__ — not checked in prior specs
# Prior specs check __bases__[0].__name__ == 'URLError'; __qualname__ is new.
# ---------------------------------------------------------------------------

invariant urllib_error_extra4.HTTPError.base0_qualname:
  description: "urllib.error.HTTPError.__bases__[0].__qualname__ == 'URLError'"
  category: hierarchy
  kind: python_call_eq
  function: HTTPError.__bases__.__getitem__
  args: [0]
  method: __qualname__
  expected: "URLError"
