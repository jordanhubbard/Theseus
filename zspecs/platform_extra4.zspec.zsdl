spec: platform_extra4
version: ">=3.9"
backend: python_module(platform)

docs: https://docs.python.org/3/library/platform.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/platform.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/platform.py"
  notes:
    - "This spec extends platform.zspec.zsdl, platform_extra.zspec.zsdl, platform_extra2.zspec.zsdl, and platform_extra3.zspec.zsdl."
    - "platform.zspec.zsdl covers: __name__ table for system/node/release/machine/processor/architecture/uname/python_version/python_implementation/python_version_tuple; python_impl_cpython; version_tuple_major/is_tuple/len3; python_version_is_str/nonempty; architecture_64bit; node_is_str; uname field types."
    - "platform_extra.zspec.zsdl covers: __name__ for release/version/python_build; return types for many functions."
    - "platform_extra2.zspec.zsdl covers: __module__ table for all functions; __name__ spot-checks for system/node/release/machine/python_compiler."
    - "platform_extra3.zspec.zsdl covers: version_tuple minor/micro element types; node/python_implementation nonempty; uname len and node nonempty; architecture linkage str; python_build buildno nonempty; python_version contains dot."
    - "This spec adds __qualname__ checks for platform functions and the uname_result class."
    - "For module-level functions, __qualname__ == __name__ (no enclosing scope)."
    - "platform.system.__qualname__ == 'system'."
    - "platform.node.__qualname__ == 'node'."
    - "platform.release.__qualname__ == 'release'."
    - "platform.version.__qualname__ == 'version'."
    - "platform.machine.__qualname__ == 'machine'."
    - "platform.processor.__qualname__ == 'processor'."
    - "platform.python_version.__qualname__ == 'python_version'."
    - "platform.python_implementation.__qualname__ == 'python_implementation'."
    - "platform.python_version_tuple.__qualname__ == 'python_version_tuple'."
    - "platform.uname.__qualname__ == 'uname'."
    - "platform.uname_result.__qualname__ == 'uname_result'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ checks
# Module-level functions: __qualname__ == __name__.
# Prior specs cover __name__ (platform.zspec + platform_extra + platform_extra2) and
# __module__ (platform_extra2) for these functions.
# ---------------------------------------------------------------------------

table platform_extra4.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [system,                system.__qualname__.__eq__,                ["system"],                true]
    - [node,                  node.__qualname__.__eq__,                  ["node"],                  true]
    - [release,               release.__qualname__.__eq__,               ["release"],               true]
    - [version,               version.__qualname__.__eq__,               ["version"],               true]
    - [machine,               machine.__qualname__.__eq__,               ["machine"],               true]
    - [processor,             processor.__qualname__.__eq__,             ["processor"],             true]
    - [python_version,        python_version.__qualname__.__eq__,        ["python_version"],        true]
    - [python_implementation, python_implementation.__qualname__.__eq__, ["python_implementation"], true]
    - [python_version_tuple,  python_version_tuple.__qualname__.__eq__,  ["python_version_tuple"],  true]
    - [uname,                 uname.__qualname__.__eq__,                 ["uname"],                 true]

# ---------------------------------------------------------------------------
# uname_result __qualname__ check
# uname_result is a named-tuple class defined at module level in platform.py.
# __qualname__ == 'uname_result' for a top-level class definition.
# ---------------------------------------------------------------------------

invariant platform_extra4.uname_result.qualname:
  description: "platform.uname_result.__qualname__ == 'uname_result'"
  category: class_qualnames
  kind: python_call_eq
  function: uname_result.__qualname__.__eq__
  args: ["uname_result"]
  expected: true
