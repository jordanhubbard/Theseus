spec: functools_extra2731
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 629 theme: __trunc__, __floor__, and __ceil__ dict-presence checks (numeric rounding protocol — used by math.trunc(), math.floor(), math.ceil())."
    - "functools.partial is a callable wrapper; it does not implement numeric rounding protocols."
    - "functools.partialmethod is a descriptor; it similarly defines none of __trunc__, __floor__, or __ceil__."
    - "functools.cached_property is a data descriptor (defines __get__, __set__, __delete__) but not __trunc__, __floor__, or __ceil__."
    - "functools.singledispatchmethod is a descriptor wrapper; it does not define __trunc__, __floor__, or __ceil__."
    - "None of the functools public classes define __trunc__, __floor__, or __ceil__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2731.trunc_protocol:
  description: "__trunc__ is absent from all functools class __dict__s — none implement numeric truncation"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2731

  columns: [id, function, args, expected]
  rows:
    - ["ft2731001", "functools.partial.__dict__.__contains__",              ["__trunc__"], false]
    - ["ft2731002", "functools.partialmethod.__dict__.__contains__",        ["__trunc__"], false]
    - ["ft2731003", "functools.cached_property.__dict__.__contains__",      ["__trunc__"], false]
    - ["ft2731004", "functools.singledispatchmethod.__dict__.__contains__",  ["__trunc__"], false]

