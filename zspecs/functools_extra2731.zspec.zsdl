  rows:
    - ["ft2731009", "functools.partial.__dict__.__contains__",              ["__ceil__"], false]
    - ["ft2731010", "functools.partialmethod.__dict__.__contains__",        ["__ceil__"], false]
    - ["ft2731011", "functools.cached_property.__dict__.__contains__",      ["__ceil__"], false]
    - ["ft2731012", "functools.singledispatchmethod.__dict__.__contains__",  ["__ceil__"], false]

# ---------------------------------------------------------------------------
# Combined view — partial and partialmethod vs. all three rounding protocols
# ---------------------------------------------------------------------------

table functools_extra2731.partial_rounding_combined:
  description: "functools.partial and functools.partialmethod define none of __trunc__, __floor__, __ceil__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2731

  columns: [id, function, args, expected]
  rows:
    - ["ft2731013", "functools.partial.__dict__.__contains__",       ["__trunc__"],  false]
    - ["ft2731014", "functools.partial.__dict__.__contains__",       ["__floor__"],  false]
    - ["ft2731015", "functools.partial.__dict__.__contains__",       ["__ceil__"],   false]
    - ["ft2731016", "functools.partialmethod.__dict__.__contains__", ["__trunc__"],  false]
    - ["ft2731017", "functools.partialmethod.__dict__.__contains__", ["__floor__"],  false]
    - ["ft2731018", "functools.partialmethod.__dict__.__contains__", ["__ceil__"],   false]
