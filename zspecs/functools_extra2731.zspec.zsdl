  rows:
    - ["ft2731005", "functools.partial.__dict__.__contains__",              ["__floor__"], false]
    - ["ft2731006", "functools.partialmethod.__dict__.__contains__",        ["__floor__"], false]
    - ["ft2731007", "functools.cached_property.__dict__.__contains__",      ["__floor__"], false]
    - ["ft2731008", "functools.singledispatchmethod.__dict__.__contains__",  ["__floor__"], false]

