spec: struct_extra1456
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "_struct.zspec.zsdl — covers Struct pack/unpack/calcsize and format string attributes"
  notes:
    - "Wave 544 theme: __contains__ and __iter__ method presence and type checks."
    - "struct.Struct is a C-level type (_struct.Struct) for compiled format strings; it is not a container."
    - "struct.error is the exception class raised on packing/unpacking failures."
    - "struct.Struct.__dict__ does not contain '__iter__' — Struct objects are not iterable."
    - "struct.Struct.__dict__ does not contain '__contains__' — Struct objects do not support membership testing."
    - "struct.error.__dict__ does not contain '__iter__' or '__contains__' — exceptions are not containers."
    - "struct.Struct.__mro__ is (_struct.Struct, object) — single-level C-extension inheritance, no container mixin."
    - "struct.error inherits from Exception > BaseException > object; no container protocol anywhere in MRO."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct — __contains__ and __iter__ absence checks
#
# struct.Struct is a compiled struct format object. It exposes pack(), unpack(),
# pack_into(), unpack_from(), iter_unpack(), size, and format — but it is not
# itself iterable or a container. The iter_unpack() METHOD returns an iterator
# over a buffer; however the Struct TYPE does not implement __iter__ or
# __contains__ in its own __dict__.
# ---------------------------------------------------------------------------

table struct_extra1456.Struct_contains_iter:
  description: "struct.Struct has no __contains__ or __iter__ — Struct is a compiled format object, not a container; neither method appears in Struct.__dict__; wave 544 __contains__/__iter__ absence theme; st1456ci anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: st1456ci

  columns: [id, function, args, expected, description]
  rows:
    - [st1456ci001, "struct.Struct.__dict__.__contains__", ["__contains__"],  false, "struct.Struct.__dict__ does not contain '__contains__' — Struct is not a membership-test container"]
    - [st1456ci002, "struct.Struct.__dict__.__contains__", ["__iter__"],      false, "struct.Struct.__dict__ does not contain '__iter__' — Struct objects are not directly iterable"]
    - [st1456ci003, "struct.Struct.__dict__.__contains__", ["pack"],          true,  "struct.Struct.__dict__ contains 'pack' — confirms __dict__ lookup works correctly on Struct"]
    - [st1456ci004, "struct.Struct.__dict__.__contains__", ["unpack"],        true,  "struct.Struct.__dict__ contains 'unpack' — confirms __dict__ lookup works correctly on Struct"]
    - [st1456ci005, "struct.Struct.__dict__.__contains__", ["size"],          true,  "struct.Struct.__dict__ contains 'size' — Struct exposes the byte size of its format"]
    - [st1456ci006, "struct.Struct.__dict__.__contains__", ["iter_unpack"],   true,  "struct.Struct.__dict__ contains 'iter_unpack' — iter_unpack method exists (returns iterator over buffer, but Struct itself is not iterable)"]

# ---------------------------------------------------------------------------
# struct.error — __contains__ and __iter__ absence checks
#
# struct.error is the exception class for struct packing/unpacking failures.
# As an Exception subclass, it has no container protocol. Neither __iter__
# nor __contains__ appears anywhere in its MRO (Exception > BaseException > object).
# ---------------------------------------------------------------------------

table struct_extra1456.error_contains_iter:
  description: "struct.error has no __contains__ or __iter__ — struct.error is an Exception subclass, not a container; neither method in error.__dict__; wave 544 theme; st1456er anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: st1456er

  columns: [id, function, args, expected, description]
  rows:
    - [st1456er001, "struct.error.__dict__.__contains__", ["__contains__"], false, "struct.error.__dict__ does not contain '__contains__' — error is an exception, not a container"]
    - [st1456er002, "struct.error.__dict__.__contains__", ["__iter__"],     false, "struct.error.__dict__ does not contain '__iter__' — struct.error is not iterable"]
    - [st1456er003, "struct.error.__name__.__eq__",       ["error"],        true,  "struct.error.__name__ == 'error' — confirms the exception class name"]
    - [st1456er004, "struct.error.__module__.__eq__",     ["struct"],       true,  "struct.error.__module__ == 'struct' — error is defined in the struct module"]
    - [st1456er005, "struct.error.__dict__.__contains__", ["__doc__"],      true,  "struct.error.__dict__ contains '__doc__' — confirms __dict__ lookup works correctly on struct.error"]
    - [st1456er006, "struct.error.__dict__.__contains__", ["__module__"],   true,  "struct.error.__dict__ contains '__module__' — confirms __dict__ lookup works on struct.error class"]

# ---------------------------------------------------------------------------
# struct.Struct vs list symmetry — Struct lacks container protocol that list has
#
# list defines __iter__ (wrapper_descriptor) and __contains__ (wrapper_descriptor).
# struct.Struct has neither. This table anchors the contrast explicitly.
# ---------------------------------------------------------------------------

table struct_extra1456.Struct_vs_list_protocol:
  description: "struct.Struct lacks __contains__/__iter__ that list provides — list.__iter__ and list.__contains__ are 'wrapper_descriptor'; Struct has neither; contrast confirms Struct is not a sequence; wave 544 st1456vs anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: st1456vs

  columns: [id, function, args, expected, description]
  rows:
    - [st1456vs001, "struct.Struct.__dict__.__contains__", ["__iter__"],          false,              "struct.Struct.__dict__ does not contain '__iter__' — contrast with list which defines __iter__"]
    - [st1456vs002, "struct.Struct.__dict__.__contains__", ["__contains__"],      false,              "struct.Struct.__dict__ does not contain '__contains__' — contrast with list which defines __contains__"]
    - [st1456vs003, "list.__iter__.__class__.__name__.__eq__",     ["wrapper_descriptor"], true,       "list.__iter__.__class__.__name__ == 'wrapper_descriptor' — reference value that Struct does NOT have"]
    - [st1456vs004, "list.__contains__.__class__.__name__.__eq__", ["wrapper_descriptor"], true,       "list.__contains__.__class__.__name__ == 'wrapper_descriptor' — reference value that Struct does NOT have"]
    - [st1456vs005, "struct.Struct.__name__.__eq__",               ["Struct"],             true,       "struct.Struct.__name__ == 'Struct' — confirms we are testing the correct C-level type"]
    - [st1456vs006, "struct.Struct.__dict__.__contains__",         ["format"],             true,       "struct.Struct.__dict__ contains 'format' — Struct exposes its format string, not container methods"]
