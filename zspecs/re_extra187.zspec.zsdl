spec: re_extra187
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "re.Pattern.match.__name__=='match' (len=5); re.Pattern.search.__name__=='search' (len=6)."
    - "re.Pattern.fullmatch.__name__=='fullmatch' (len=9); re.Pattern.findall.__name__=='findall' (len=7)."
    - "re.Pattern.finditer.__name__=='finditer' (len=8); re.Pattern.sub.__name__=='sub' (len=3)."
    - "re.Pattern.subn.__name__=='subn' (len=4); re.Pattern.split.__name__=='split' (len=5)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.Pattern search/match method name lengths
# match.__name__=='match' (len=5); search.__name__=='search' (len=6)
# fullmatch.__name__=='fullmatch' (len=9)
# ---------------------------------------------------------------------------

table re_extra187.pattern_search_methods:
  description: "re.Pattern search-related method name lengths: match (len=5), search (len=6), fullmatch (len=9)"
  kind: python_call_eq
  category: identity
  id_prefix: repatternmethods187

  columns: [id, function, args, expected, description]
  rows:
    - [match_name,       Pattern.match.__name__.__eq__,      ["match"],      true, "re.Pattern.match.__name__ == 'match' — matches at the beginning of the string; confirmed Python 3.14.3 macOS"]
    - [match_name_len,   Pattern.match.__name__.__len__,     [],             5,    "re.Pattern.match.__name__.__len__() == 5 — m(1)a(2)t(3)c(4)h(5); confirmed Python 3.14.3 macOS"]
    - [search_name,      Pattern.search.__name__.__eq__,     ["search"],     true, "re.Pattern.search.__name__ == 'search' — scans through the string for a match; confirmed Python 3.14.3 macOS"]
    - [search_name_len,  Pattern.search.__name__.__len__,    [],             6,    "re.Pattern.search.__name__.__len__() == 6 — s(1)e(2)a(3)r(4)c(5)h(6); confirmed Python 3.14.3 macOS"]
    - [fmatch_name,      Pattern.fullmatch.__name__.__eq__,  ["fullmatch"],  true, "re.Pattern.fullmatch.__name__ == 'fullmatch' — matches the whole string; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.Pattern find/iteration method name lengths
# findall.__name__=='findall' (len=7); finditer.__name__=='finditer' (len=8)
# ---------------------------------------------------------------------------

table re_extra187.pattern_find_methods:
  description: "re.Pattern find/iteration method name lengths: findall (len=7), finditer (len=8)"
  kind: python_call_eq
  category: identity
  id_prefix: repatternmethods187

  columns: [id, function, args, expected, description]
  rows:
    - [findall_name,      Pattern.findall.__name__.__eq__,   ["findall"],   true, "re.Pattern.findall.__name__ == 'findall' — returns list of all non-overlapping matches; confirmed Python 3.14.3 macOS"]
    - [findall_name_len,  Pattern.findall.__name__.__len__,  [],            7,    "re.Pattern.findall.__name__.__len__() == 7 — f(1)i(2)n(3)d(4)a(5)l(6)l(7); confirmed Python 3.14.3 macOS"]
    - [finditer_name,     Pattern.finditer.__name__.__eq__,  ["finditer"],  true, "re.Pattern.finditer.__name__ == 'finditer' — returns iterator of match objects; confirmed Python 3.14.3 macOS"]
    - [finditer_name_len, Pattern.finditer.__name__.__len__, [],            8,    "re.Pattern.finditer.__name__.__len__() == 8 — f(1)i(2)n(3)d(4)i(5)t(6)e(7)r(8); confirmed Python 3.14.3 macOS"]
    - [fmatch_name_len,   Pattern.fullmatch.__name__.__len__, [],           9,    "re.Pattern.fullmatch.__name__.__len__() == 9 — f(1)u(2)l(3)l(4)m(5)a(6)t(7)c(8)h(9); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.Pattern substitution/split method name lengths
# sub.__name__=='sub' (len=3); subn.__name__=='subn' (len=4); split.__name__=='split' (len=5)
# ---------------------------------------------------------------------------

table re_extra187.pattern_sub_split_methods:
  description: "re.Pattern substitution and split method name lengths: sub (len=3), subn (len=4), split (len=5)"
  kind: python_call_eq
  category: identity
  id_prefix: repatternmethods187

  columns: [id, function, args, expected, description]
  rows:
    - [sub_name,      Pattern.sub.__name__.__eq__,    ["sub"],    true, "re.Pattern.sub.__name__ == 'sub' — returns string with leftmost non-overlapping matches replaced; confirmed Python 3.14.3 macOS"]
    - [sub_name_len,  Pattern.sub.__name__.__len__,   [],         3,    "re.Pattern.sub.__name__.__len__() == 3 — s(1)u(2)b(3); confirmed Python 3.14.3 macOS"]
    - [subn_name,     Pattern.subn.__name__.__eq__,   ["subn"],   true, "re.Pattern.subn.__name__ == 'subn' — like sub() but also returns count of substitutions; confirmed Python 3.14.3 macOS"]
    - [subn_name_len, Pattern.subn.__name__.__len__,  [],         4,    "re.Pattern.subn.__name__.__len__() == 4 — s(1)u(2)b(3)n(4); confirmed Python 3.14.3 macOS"]
    - [split_name,    Pattern.split.__name__.__eq__,  ["split"],  true, "re.Pattern.split.__name__ == 'split' — splits string at each match; confirmed Python 3.14.3 macOS"]

