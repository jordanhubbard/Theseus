spec: pdb_extra8
version: ">=3.9"
backend: python_module(pdb)

docs: https://docs.python.org/3/library/pdb.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pdb.html — Python pdb documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pdb.py"
  notes:
    - "This spec extends pdb.zspec.zsdl through pdb_extra7.zspec.zsdl."
    - "pdb covers: Pdb/__name__, Restart/__name__, Pdb/__module__, run/runeval/runcall/set_trace/post_mortem/pm __name__ (table), Pdb().prompt, Pdb().use_rawinput."
    - "pdb_extra covers: Pdb/__name__/__module__/__bases__[0].__name__, run/runeval/runcall/set_trace/post_mortem/pm/help __name__."
    - "pdb_extra2 covers: Pdb/__name__/__module__/__qualname__, run/runcall/post_mortem/set_trace/pm __name__ and __module__."
    - "pdb_extra3 covers: runeval/__module__, help/__module__, Restart/__module__, Restart.__bases__[0]/__name__, Pdb.__bases__.__len__()==2, Pdb.__bases__[0]/__module__=='bdb', Pdb.__bases__[1]/__name__=='Cmd', Pdb.__bases__[1]/__module__=='cmd', function __qualname__ table."
    - "pdb_extra4 covers: Restart/__qualname__, Restart.__bases__.__len__()==1, Pdb.__bases__[0]/__qualname__=='Bdb', Pdb.__bases__[1]/__qualname__=='Cmd', Pdb.__bases__.__class__.__name__=='tuple', Pdb/__name__/__class__.__name__=='str', Restart/__name__/__class__.__name__=='str'."
    - "pdb_extra5 covers: Pdb command-method names (do_break/do_continue/do_step/do_next/do_quit/do_list), do_break.__module__, Pdb().__class__.__name__, Pdb().skip/nosigint defaults, run.__class__.__name__, Pdb.MAX_CHAINED_EXCEPTION_DEPTH."
    - "pdb_extra6 covers: Pdb/__name__/__module__ via __eq__, Pdb.__bases__[0]/__name__=='Bdb' via __eq__, run/pm/runcall/runeval/set_trace/post_mortem __name__ via __eq__, Restart/__name__/__bases__[0]/__name__ via __eq__, line_prefix.__class__.__name__=='str'."
    - "pdb_extra7 covers: Pdb.__mro__ (length 4, entries at indices 0..3 __name__ and __module__), do_where/do_up/do_down/do_args/do_return/do_jump __qualname__ table, line_prefix exact value."
    - "NEW in this spec: pdb.Pdb.__name__=='Pdb' and pdb.Pdb.__module__=='pdb' and pdb.Pdb.__bases__[0].__name__=='Bdb' and pdb.Pdb.__mro__.__len__()==4 as direct non-eq invariants (expected-value form, not __eq__-predicate form); pdb module-level function __qualname__ checks (run/set_trace/post_mortem/pm); pdb.Pdb.__class__.__name__=='type' — Pdb is a class object; run/set_trace/post_mortem/pm __class__.__name__=='function'."
    - "pdb.run.__qualname__ == 'run' — top-level function qualname equals name (verified runtime)."
    - "pdb.set_trace.__qualname__ == 'set_trace' — top-level function qualname equals name (verified runtime)."
    - "pdb.post_mortem.__qualname__ == 'post_mortem' — top-level function qualname equals name (verified runtime)."
    - "pdb.pm.__qualname__ == 'pm' — top-level function qualname equals name (verified runtime)."
    - "pdb.Pdb.__class__.__name__ == 'type' — Pdb is a class, so its type is 'type' (verified runtime)."
    - "pdb.Pdb.__name__ == 'Pdb', pdb.Pdb.__module__ == 'pdb', pdb.Pdb.__bases__[0].__name__ == 'Bdb', pdb.Pdb.__mro__.__len__() == 4 — all verified runtime; these use the direct expected-value form (not __eq__ predicate)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Core Pdb identity — direct expected-value form
# pdb_extra6 checks these same values using the __eq__-predicate form
# (function: Pdb.__name__.__eq__, expected: true). This spec uses the
# direct expected-value form (function returns the string/int; expected is
# the value itself), which is a structurally distinct axis.
# ---------------------------------------------------------------------------

invariant pdb_extra8.Pdb.name:
  description: "pdb.Pdb.__name__ == 'Pdb' — direct expected-value form"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pdb_extra8.Pdb.class_type:
  description: "pdb.Pdb.__class__.__name__ == 'type' — Pdb is a class object whose metaclass is type"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant pdb_extra8.Pdb.bases0_name_Bdb:
  description: "pdb.Pdb.__bases__[0].__name__ == 'Bdb' — first base is bdb.Bdb"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__bases__.__getitem__
  args: [0]
  method: __name__.__class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant pdb_extra8.Pdb.mro_len_direct:
  description: "pdb.Pdb.__mro__.__len__() == 4 — direct form (mro7 uses invariant form in pdb_extra7)"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Module-level function __qualname__ checks
# pdb_extra2 and pdb_extra3 cover __qualname__ for run/set_trace/post_mortem/pm
# but only from within a table (pdb_extra3) with the __eq__ predicate form.
# These standalone invariants provide __qualname__ as direct expected-value form.
# ---------------------------------------------------------------------------

table pdb_extra8.function_qualnames:
  description: "pdb module-level function __qualname__ values — top-level functions have qualname == name"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fnqn

  columns: [id, function, args, expected]
  rows:
    - [run,          run.__qualname__.__eq__,          ["run"],          true]
    - [set_trace,    set_trace.__qualname__.__eq__,    ["set_trace"],    true]
    - [post_mortem,  post_mortem.__qualname__.__eq__,  ["post_mortem"],  true]
    - [pm,           pm.__qualname__.__eq__,           ["pm"],           true]

# ---------------------------------------------------------------------------
# Module-level function __class__.__name__ — type verification
# pdb_extra5 checks run.__class__.__name__ == 'function'.
# set_trace, post_mortem, and pm __class__.__name__ are not covered by any prior spec.
# ---------------------------------------------------------------------------

invariant pdb_extra8.set_trace.class_name:
  description: "pdb.set_trace.__class__.__name__ == 'function' — set_trace is a plain Python function"
  category: function_types
  kind: python_call_eq
  function: set_trace.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pdb_extra8.post_mortem.class_name:
  description: "pdb.post_mortem.__class__.__name__ == 'function' — post_mortem is a plain Python function"
  category: function_types
  kind: python_call_eq
  function: post_mortem.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pdb_extra8.pm.class_name:
  description: "pdb.pm.__class__.__name__ == 'function' — pm is a plain Python function"
  category: function_types
  kind: python_call_eq
  function: pm.__class__.__name__.__eq__
  args: ["function"]
  expected: true
