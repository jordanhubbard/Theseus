spec: functools_extra1351
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "Wave 537 (_extra1351): focuses on __slots__ and __weakref__ attribute checks for functools classes."
    - "functools.partial.__dict__.__contains__('__slots__') == False — partial is a C type; C types use tp_members, not __slots__ in __dict__."
    - "functools.partial.__dict__.__contains__('__weakref__') == False — partial is a C type; weakref support is at the C level, not via __weakref__ descriptor in __dict__."
    - "functools.partial.__dict__.__contains__('__dict__') == True — partial instances have a __dict__ (the C type exposes a __dict__ descriptor in tp_getset)."
    - "functools.cached_property.__dict__.__contains__('__weakref__') == True — pure Python class; object adds __weakref__ descriptor when no __slots__ block it."
    - "functools.singledispatchmethod.__dict__.__contains__('__weakref__') == True — pure Python class; inherits weakref support via __weakref__ descriptor."
    - "functools.partialmethod.__dict__.__contains__('__weakref__') == True — pure Python class with __weakref__ descriptor present."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table functools_extra1351.partial_slot_weakref_dict_checks:
  description: "functools.partial __dict__ containment checks for __slots__, __weakref__, and __dict__ descriptors; partial is a C type with __dict__ exposed but no __slots__ or __weakref__ in class __dict__"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: fu1351pa
  columns: [id, function, args, expected]
  rows:
    - [fu1351pa001, functools.partial.__dict__.__contains__, ["__slots__"],    false]
    - [fu1351pa002, functools.partial.__dict__.__contains__, ["__weakref__"],  false]
    - [fu1351pa003, functools.partial.__dict__.__contains__, ["__dict__"],     true]
    - [fu1351pa004, functools.cached_property.__dict__.__contains__, ["__slots__"],   false]
    - [fu1351pa005, functools.cached_property.__dict__.__contains__, ["__weakref__"], true]
    - [fu1351pa006, functools.cached_property.__dict__.__contains__, ["__dict__"],    true]

table functools_extra1351.singledispatchmethod_partialmethod_slot_checks:
  description: "functools.singledispatchmethod and partialmethod __dict__ containment checks for __slots__, __weakref__, and __dict__ descriptors; both are pure Python classes"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: fu1351sm
  columns: [id, function, args, expected]
  rows:
    - [fu1351sm001, functools.singledispatchmethod.__dict__.__contains__, ["__slots__"],    false]
    - [fu1351sm002, functools.singledispatchmethod.__dict__.__contains__, ["__weakref__"],  true]
    - [fu1351sm003, functools.singledispatchmethod.__dict__.__contains__, ["__dict__"],     true]
    - [fu1351sm004, functools.partialmethod.__dict__.__contains__, ["__slots__"],    false]
    - [fu1351sm005, functools.partialmethod.__dict__.__contains__, ["__weakref__"],  true]
    - [fu1351sm006, functools.partialmethod.__dict__.__contains__, ["__dict__"],     true]

table functools_extra1351.lru_cache_slot_checks:
  description: "functools.lru_cache __dict__ containment checks; lru_cache is a C-level decorator factory that exposes no __slots__, __weakref__, or __dict__ descriptors in its class __dict__"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: fu1351lc
  columns: [id, function, args, expected]
  rows:
    - [fu1351lc001, functools.lru_cache.__dict__.__contains__, ["__slots__"],    false]
    - [fu1351lc002, functools.lru_cache.__dict__.__contains__, ["__weakref__"],  false]
    - [fu1351lc003, functools.lru_cache.__dict__.__contains__, ["__dict__"],     false]
    - [fu1351lc004, functools.partial.__dict__.__contains__,   ["__slots__"],    false]
    - [fu1351lc005, functools.partial.__dict__.__contains__,   ["__weakref__"],  false]
    - [fu1351lc006, functools.partial.__dict__.__contains__,   ["__dict__"],     true]
