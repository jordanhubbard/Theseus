spec: decimal_extra5
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic specification"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic specification"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal.zspec.zsdl, decimal_extra.zspec.zsdl, decimal_extra2.zspec.zsdl, decimal_extra3.zspec.zsdl, and decimal_extra4.zspec.zsdl."
    - "Focus: __qualname__ attributes for decimal module classes and functions; __module__ for Decimal."
    - "decimal.Decimal.__qualname__ == 'Decimal' — class qualname matches simple name at module level."
    - "decimal.Context.__qualname__ == 'Context' — Context class qualname."
    - "decimal.DecimalException.__qualname__ == 'DecimalException' — base exception qualname."
    - "decimal.Overflow.__qualname__ == 'Overflow' — subclass qualname."
    - "decimal.Underflow.__qualname__ == 'Underflow' — subclass qualname."
    - "decimal.InvalidOperation.__qualname__ == 'InvalidOperation' — subclass qualname."
    - "decimal.DivisionByZero.__qualname__ == 'DivisionByZero' — subclass qualname."
    - "decimal.Inexact.__qualname__ == 'Inexact' — subclass qualname."
    - "decimal.Rounded.__qualname__ == 'Rounded' — subclass qualname."
    - "decimal.getcontext.__qualname__ == 'getcontext' — function qualname."
    - "decimal.setcontext.__qualname__ == 'setcontext' — function qualname."
    - "decimal.localcontext.__qualname__ == 'localcontext' — function qualname."
    - "decimal.Decimal.__module__ == 'decimal' — Decimal is defined in the decimal module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for classes in the decimal module
# ---------------------------------------------------------------------------

table decimal_extra5.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Decimal,          Decimal.__qualname__.__eq__,          ["Decimal"],          true]
    - [Context,          Context.__qualname__.__eq__,          ["Context"],          true]
    - [DecimalException, DecimalException.__qualname__.__eq__, ["DecimalException"], true]
    - [Overflow,         Overflow.__qualname__.__eq__,         ["Overflow"],         true]
    - [Underflow,        Underflow.__qualname__.__eq__,        ["Underflow"],        true]
    - [InvalidOperation, InvalidOperation.__qualname__.__eq__, ["InvalidOperation"], true]
    - [DivisionByZero,   DivisionByZero.__qualname__.__eq__,   ["DivisionByZero"],   true]
    - [Inexact,          Inexact.__qualname__.__eq__,          ["Inexact"],          true]
    - [Rounded,          Rounded.__qualname__.__eq__,          ["Rounded"],          true]

# ---------------------------------------------------------------------------
# __qualname__ checks for module-level functions
# ---------------------------------------------------------------------------

table decimal_extra5.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [getcontext,   getcontext.__qualname__.__eq__,   ["getcontext"],   true]
    - [setcontext,   setcontext.__qualname__.__eq__,   ["setcontext"],   true]
    - [localcontext, localcontext.__qualname__.__eq__, ["localcontext"], true]

# ---------------------------------------------------------------------------
# __module__ check for the Decimal class
# ---------------------------------------------------------------------------

invariant decimal_extra5.Decimal.module:
  description: "decimal.Decimal.__module__ == 'decimal'"
  category: module
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true
