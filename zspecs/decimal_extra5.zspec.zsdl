spec: decimal_extra5
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic specification"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic specification"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal.zspec.zsdl, _decimal.zspec.zsdl, _decimal_extra.zspec.zsdl, decimal_extra.zspec.zsdl, decimal_extra2.zspec.zsdl, decimal_extra3.zspec.zsdl, and decimal_extra4.zspec.zsdl."
    - "decimal_extra4 covers: ROUND_HALF_UP/ROUND_HALF_EVEN/ROUND_DOWN/ROUND_UP/ROUND_CEILING/ROUND_FLOOR/ROUND_05UP/ROUND_HALF_DOWN values (table); is_nan/is_infinite/is_zero/is_finite method name checks; as_tuple method name; InvalidOperation/DivisionByZero/Overflow/Underflow class names."
    - "This spec adds: Context.__name__, Context.__module__, DefaultContext.__class__.__name__, BasicContext.__class__.__name__, ExtendedContext.__class__.__name__, ROUND_UP.__class__.__name__, ROUND_DOWN.__class__.__name__, ROUND_HALF_UP.__class__.__name__, ROUND_HALF_EVEN.__class__.__name__, ROUND_* class names table."
    - "decimal.Context.__name__ == 'Context' — the Context class identity."
    - "decimal.Context.__module__ — in CPython the C accelerator module exposes 'decimal.Context'; __module__ is 'decimal'."
    - "decimal.DefaultContext.__class__.__name__ == 'Context' — DefaultContext is a Context instance."
    - "decimal.BasicContext.__class__.__name__ == 'Context' — BasicContext is a Context instance."
    - "decimal.ExtendedContext.__class__.__name__ == 'Context' — ExtendedContext is a Context instance."
    - "decimal.ROUND_UP.__class__.__name__ == 'str' — rounding constants are str values."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Context class identity
# ---------------------------------------------------------------------------

invariant decimal_extra5.Context.class_name:
  description: "decimal.Context.__name__ == 'Context'"
  category: class_metadata
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra5.Context.module:
  description: "decimal.Context.__module__ == 'decimal'"
  category: class_metadata
  kind: python_call_eq
  function: Context.__module__.__eq__
  args: ["decimal"]
  expected: true

# ---------------------------------------------------------------------------
# Pre-built context instances — DefaultContext, BasicContext, ExtendedContext
# These are module-level Context instances; their __class__.__name__ == 'Context'.
# ---------------------------------------------------------------------------

invariant decimal_extra5.DefaultContext.class_name:
  description: "decimal.DefaultContext.__class__.__name__ == 'Context'"
  category: context_instances
  kind: python_call_eq
  function: DefaultContext.__class__.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra5.BasicContext.class_name:
  description: "decimal.BasicContext.__class__.__name__ == 'Context'"
  category: context_instances
  kind: python_call_eq
  function: BasicContext.__class__.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra5.ExtendedContext.class_name:
  description: "decimal.ExtendedContext.__class__.__name__ == 'Context'"
  category: context_instances
  kind: python_call_eq
  function: ExtendedContext.__class__.__name__.__eq__
  args: ["Context"]
  expected: true

# ---------------------------------------------------------------------------
# ROUND_* constants — __class__.__name__ == 'str'
# decimal_extra4 covers the string values (e.g. ROUND_UP == 'ROUND_UP').
# This spec adds the class-of-constant checks: each constant is a str.
# ---------------------------------------------------------------------------

table decimal_extra5.rounding_constant_types:
  kind: python_call_eq
  category: constant_types
  id_prefix: rtype

  columns: [id, function, args, expected]
  rows:
    - [ROUND_UP,        ROUND_UP.__class__.__name__.__eq__,        ["str"], true]
    - [ROUND_DOWN,      ROUND_DOWN.__class__.__name__.__eq__,      ["str"], true]
    - [ROUND_HALF_UP,   ROUND_HALF_UP.__class__.__name__.__eq__,   ["str"], true]
    - [ROUND_HALF_EVEN, ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"], true]
    - [ROUND_CEILING,   ROUND_CEILING.__class__.__name__.__eq__,   ["str"], true]
    - [ROUND_FLOOR,     ROUND_FLOOR.__class__.__name__.__eq__,     ["str"], true]

# ---------------------------------------------------------------------------
# ROUND_UP and ROUND_DOWN as standalone invariants for traceability
# decimal_extra4 covers all ROUND_* values in a table; these add individual
# invariants for the two most commonly cited constants.
# ---------------------------------------------------------------------------

invariant decimal_extra5.ROUND_UP.value:
  description: "decimal.ROUND_UP == 'ROUND_UP'"
  category: rounding_constants
  kind: python_call_eq
  function: ROUND_UP.__eq__
  args: ["ROUND_UP"]
  expected: true

invariant decimal_extra5.ROUND_DOWN.value:
  description: "decimal.ROUND_DOWN == 'ROUND_DOWN'"
  category: rounding_constants
  kind: python_call_eq
  function: ROUND_DOWN.__eq__
  args: ["ROUND_DOWN"]
  expected: true

invariant decimal_extra5.ROUND_HALF_UP.value:
  description: "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP'"
  category: rounding_constants
  kind: python_call_eq
  function: ROUND_HALF_UP.__eq__
  args: ["ROUND_HALF_UP"]
  expected: true

invariant decimal_extra5.ROUND_HALF_EVEN.value:
  description: "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN'"
  category: rounding_constants
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true
