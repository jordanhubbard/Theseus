spec: abc_extra976
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc.ABC, abc.ABCMeta, and abc.abstractmethod qualnames and class descriptor identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra976.abc_subclass_qualnames:
  description: "abc.ABC and ABCMeta subclass/hook method __qualname__ identity"
  kind: python_call_eq
  category: abc_subclass_qualnames
  id_prefix: ab976sq
  columns: [id, function, args, expected]
  rows:
    - [ab976sq001, abc.ABC.__init_subclass__.__qualname__.__eq__,        ["object.__init_subclass__"],    true]
    - [ab976sq002, abc.ABCMeta.__subclasshook__.__qualname__.__eq__,     ["ABCMeta.__subclasshook__"],    true]
    - [ab976sq003, abc.ABCMeta.__instancecheck__.__qualname__.__eq__,    ["ABCMeta.__instancecheck__"],   true]
    - [ab976sq004, abc.ABCMeta.__subclasscheck__.__qualname__.__eq__,    ["ABCMeta.__subclasscheck__"],   true]
    - [ab976sq005, abc.ABCMeta.register.__qualname__.__eq__,             ["ABCMeta.register"],            true]
    - [ab976sq006, abc.ABCMeta.__new__.__qualname__.__eq__,              ["ABCMeta.__new__"],             true]

table abc_extra976.abstractmethod_qualnames:
  description: "abc.abstractmethod callable and attribute __qualname__ identity"
  kind: python_call_eq
  category: abstractmethod_qualnames
  id_prefix: ab976am
  columns: [id, function, args, expected]
  rows:
    - [ab976am001, abc.abstractmethod.__qualname__.__eq__,            ["abstractmethod"],          true]
    - [ab976am002, abc.abstractmethod.__call__.__qualname__.__eq__,   ["abstractmethod.__call__"], true]
    - [ab976am003, abc.abstractmethod.__init__.__qualname__.__eq__,   ["abstractmethod.__init__"], true]
    - [ab976am004, abc.abstractmethod.__module__.__eq__,              ["abc"],                     true]
    - [ab976am005, abc.abstractmethod.__class__.__name__.__eq__,      ["type"],                    true]

table abc_extra976.class_identity:
  description: "abc class and descriptor identity checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: ab976ci
  columns: [id, function, args, expected]
  rows:
    - [ab976ci001, abc.ABC.__class__.__name__.__eq__,                 ["ABCMeta"],            true]
    - [ab976ci002, abc.ABCMeta.__class__.__name__.__eq__,             ["type"],               true]
    - [ab976ci003, abc.ABCMeta.__module__.__eq__,                     ["abc"],                true]
    - [ab976ci004, abc.ABC.__module__.__eq__,                         ["abc"],                true]
    - [ab976ci005, abc.abstractmethod.__isabstractmethod__.__class__.__name__.__eq__, ["getset_descriptor"], true]
