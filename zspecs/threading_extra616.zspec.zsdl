spec: threading_extra616
version: ">=3.9"
backend: python_module(threading)
docs: "Behavioral spec for threading class __doc__ type and module identity checks."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers Thread, Condition, Semaphore, Event, Barrier, Timer doc type and module identity, plus threading.local qualname and module."
  created_at: "2026-04-12T00:00:00Z"

table threading_extra616.doc_type_checks:
  description: "threading class __doc__ type identity checks"
  kind: python_call_eq
  category: threading_identity
  id_prefix: th616dc
  columns: [id, function, args, expected]
  rows:
    - [th616dc001, threading.Thread.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th616dc002, threading.Condition.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th616dc003, threading.Semaphore.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th616dc004, threading.Event.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th616dc005, threading.Barrier.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th616dc006, threading.Timer.__doc__.__class__.__name__.__eq__, ["str"], true]

table threading_extra616.module_qualname_checks:
  description: "threading class __module__ and special qualname checks"
  kind: python_call_eq
  category: threading_identity
  id_prefix: th616qn
  columns: [id, function, args, expected]
  rows:
    - [th616qn001, threading.Thread.__module__.__eq__, ["threading"], true]
    - [th616qn002, threading.Condition.__module__.__eq__, ["threading"], true]
    - [th616qn003, threading.Semaphore.__module__.__eq__, ["threading"], true]
    - [th616qn004, threading.Event.__module__.__eq__, ["threading"], true]
    - [th616qn005, threading.Barrier.__module__.__eq__, ["threading"], true]
    - [th616qn006, threading.Timer.__module__.__eq__, ["threading"], true]
    - [th616qn007, threading.local.__module__.__eq__, ["_thread"], true]
    - [th616qn008, threading.local.__qualname__.__eq__, ["_local"], true]
