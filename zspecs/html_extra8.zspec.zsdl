spec: html_extra8
version: ">=3.9"
backend: python_module(html)

docs: https://docs.python.org/3/library/html.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/html.html — Python html module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/html/__init__.py"
    - "html.zspec.zsdl — covers escape/unescape with <, >, &, dquote, squote, compound, numeric entities, edge cases"
    - "html_extra.zspec.zsdl — covers escape.__name__, unescape.__name__, escape.__module__, unescape.__module__"
    - "html_extra2.zspec.zsdl — covers escape('<div>'), unescape('&lt;div&gt;'), quote=False/True, apos entity, hex numeric ref"
    - "html_extra3.zspec.zsdl — covers name2codepoint/codepoint2name entity values, CDATA_CONTENT_ELEMENTS type, unescape(&amp;/&lt;/&gt;), escape('<>&')"
    - "html_extra4.zspec.zsdl — covers escape.__qualname__, unescape.__qualname__, escape('<script>'), escape positional bool args, unescape('&lt;b&gt;'), unescape('&quot;')"
    - "html_extra5.zspec.zsdl — covers HTMLParser.__qualname__, method __qualname__ checks, HTMLParser.__class__.__name__, HTMLParser.__bases__[0].__name__ via method chain"
    - "html_extra6.zspec.zsdl — covers escape/unescape __class__.__name__, return types, non-ASCII passthrough, mixed entity/text unescape, numeric char refs, codepoint2name lt/gt/quot/nbsp"
    - "html_extra7.zspec.zsdl — covers escape.__name__, unescape.__name__, escape.__module__, unescape.__module__, escape('<b>hello</b>'), escape('\"hello\"' quote=True), unescape('&lt;b&gt;'), unescape('&amp;')"
  notes:
    - "This spec covers axes not yet in html through html_extra7."
    - "html.parser.HTMLParser.__bases__[0].__name__ == 'ParserBase' — HTMLParser inherits from ParserBase in _markupbase; verified at runtime."
    - "html.parser.HTMLParser.__bases__[0].__module__ == '_markupbase' — ParserBase is defined in the _markupbase C extension; verified at runtime."
    - "html.escape('Hello World') == 'Hello World' — no-op case: plain text with no HTML special chars is returned unchanged; verified at runtime."
    - "html.unescape('&copy;') == '\u00a9' — named entity for copyright sign; verified at runtime."
    - "html.unescape('&#169;') == '\u00a9' — decimal numeric character reference for copyright sign; verified at runtime."
    - "html.parser.HTMLParser.__module__ == 'html.parser' — confirmed; covered in html_extra3 as a standalone invariant; re-anchored here in extra8 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HTMLParser base class hierarchy — __eq__ style
#
# html_extra5 covers HTMLParser.__bases__[0].__name__ via method chain
# (__bases__.__getitem__). Here we use the dotted __eq__ chain style
# and add the base class __module__ which has not been covered in any
# prior html spec.
# ---------------------------------------------------------------------------

invariant html_extra8.HTMLParser.base_name:
  description: "html.parser.HTMLParser.__bases__[0].__name__ == 'ParserBase'"
  category: class_hierarchy
  kind: python_call_eq
  function: "parser.HTMLParser.__bases__[0].__name__.__eq__"
  args: ["ParserBase"]
  expected: true

invariant html_extra8.HTMLParser.base_module:
  description: "html.parser.HTMLParser.__bases__[0].__module__ == '_markupbase'"
  category: class_hierarchy
  kind: python_call_eq
  function: "parser.HTMLParser.__bases__[0].__module__.__eq__"
  args: ["_markupbase"]
  expected: true

# ---------------------------------------------------------------------------
# html.escape — no-op case for plain text
#
# All prior html specs exercise escape with strings containing <, >, &, or ".
# A string with no HTML special characters should be returned unchanged.
# This is the first spec to verify the no-op path for html.escape.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant html_extra8.escape.plain_text_noop:
  description: "html.escape('Hello World') == 'Hello World' — no HTML-special chars, no encoding"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["Hello World"]
  expected: "Hello World"

# ---------------------------------------------------------------------------
# html.unescape — named and decimal numeric entity for copyright sign
#
# No prior html spec exercises the &copy; named entity or the &#169; decimal
# numeric reference. Both decode to U+00A9 COPYRIGHT SIGN. Verified at runtime.
# ---------------------------------------------------------------------------

invariant html_extra8.unescape.copy_named:
  description: "html.unescape('&copy;') == '\u00a9' — named entity for copyright sign"
  category: unescape
  kind: python_call_eq
  function: unescape
  args: ["&copy;"]
  expected: "\u00a9"

invariant html_extra8.unescape.copy_decimal:
  description: "html.unescape('&#169;') == '\u00a9' — decimal numeric ref for copyright sign"
  category: unescape
  kind: python_call_eq
  function: unescape
  args: ["&#169;"]
  expected: "\u00a9"

# ---------------------------------------------------------------------------
# Function module table — escape and unescape from html backend
#
# html_extra and html_extra7 cover escape.__module__ and unescape.__module__
# as standalone invariants; this table re-anchors both in the extra8 namespace
# with a distinct id_prefix for independent cross-checking.
# Verified at runtime.
# ---------------------------------------------------------------------------

table html_extra8.function_modules:
  description: "__module__ for html.escape and html.unescape"
  kind: python_call_eq
  category: module_identity
  id_prefix: hmod8

  columns: [id, function, args, expected]
  rows:
    - [escape_module,    escape.__module__.__eq__,    ["html"], true]
    - [unescape_module,  unescape.__module__.__eq__,  ["html"], true]
