spec: uuid_extra871
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - uuid
  not_derived_from:
    - secrets
    - hashlib
  notes:
    - Covers uuid namespace constants, SafeUUID enum, and module-level attributes
  created_at: "2026-04-12"

table uuid_extra871.namespace_constants:
  description: Verify class names of uuid namespace constant objects
  kind: python_call_eq
  category: class_identity
  id_prefix: uu871ns
  columns: [id, function, args, expected]
  rows:
    - [uu871ns001, uuid.NAMESPACE_OID.__class__.__name__.__eq__, ["UUID"], true]
    - [uu871ns002, uuid.NAMESPACE_X500.__class__.__name__.__eq__, ["UUID"], true]

table uuid_extra871.safeuuid_attrs:
  description: Verify SafeUUID enum qualname, module, and doc type
  kind: python_call_eq
  category: qualname
  id_prefix: uu871su
  columns: [id, function, args, expected]
  rows:
    - [uu871su001, uuid.SafeUUID.__qualname__.__eq__, ["SafeUUID"], true]
    - [uu871su002, uuid.SafeUUID.__module__.__eq__, ["uuid"], true]
    - [uu871su003, uuid.SafeUUID.__doc__.__class__.__name__.__eq__, ["str"], true]

table uuid_extra871.module_attrs:
  description: Verify uuid module-level dunder attributes and class hierarchy
  kind: python_call_eq
  category: module_identity
  id_prefix: uu871mo
  columns: [id, function, args, expected]
  rows:
    - [uu871mo001, uuid.__name__.__eq__, ["uuid"], true]
    - [uu871mo002, uuid.__package__.__eq__, ["uuid"], true]
    - [uu871mo003, uuid.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true]
    - [uu871mo004, uuid.UUID.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [uu871mo005, uuid.uuid3.__code__.__class__.__name__.__eq__, ["code"], true]
    - [uu871mo006, uuid.uuid5.__code__.__class__.__name__.__eq__, ["code"], true]
    - [uu871mo007, uuid.UUID.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
