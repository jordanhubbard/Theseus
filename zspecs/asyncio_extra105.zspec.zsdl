spec: asyncio_extra105
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/runners.py"
  notes:
    - "This spec extends asyncio_extra104.zspec.zsdl."
    - "This spec covers: wave 254 theme — asyncio coroutine function __code__ attributes (co_name, co_argcount) for sleep, gather, wait, create_task, ensure_future, run, and shield. NEW in extra105: asyncio.sleep.__code__.co_name=='sleep' (co_argcount=2); asyncio.gather.__code__.co_name=='gather' (co_argcount=0, uses *coros_or_futures); asyncio.wait.__code__.co_name=='wait' (co_argcount=1); asyncio.create_task.__code__.co_name=='create_task' (co_argcount=1); asyncio.ensure_future.__code__.co_name=='ensure_future' (co_argcount=1); asyncio.run.__code__.co_name=='run' (co_argcount=1); asyncio.shield.__code__.co_name=='shield' (co_argcount=1). Also: all these functions' __module__ is 'asyncio.tasks' except asyncio.run whose __module__ is 'asyncio.runners'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__code__.co_argcount == 0. gather is defined as 'async def gather(*coros_or_futures, return_exceptions=False)' — co_argcount counts only positional (non-variadic) parameters before *args; since the first parameter is *coros_or_futures (variadic), co_argcount is 0. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.run.__module__ == 'asyncio.runners'. All other functions (sleep, gather, wait, create_task, ensure_future, shield) are defined in Lib/asyncio/tasks.py (module='asyncio.tasks'); asyncio.run is defined in Lib/asyncio/runners.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__code__.co_argcount == 2. sleep is defined as 'async def sleep(delay, result=None)' — two positional parameters (delay, result), giving co_argcount=2. This is the only function in this spec with co_argcount > 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio coroutine function __code__.co_name values — extra105
#
# Wave 254 theme: asyncio coroutine function __code__ attributes.
#
# asyncio.sleep.__code__.co_name          == 'sleep'          (co_argcount=2)
# asyncio.gather.__code__.co_name         == 'gather'         (co_argcount=0)
# asyncio.wait.__code__.co_name           == 'wait'           (co_argcount=1)
# asyncio.create_task.__code__.co_name    == 'create_task'    (co_argcount=1)
# asyncio.ensure_future.__code__.co_name  == 'ensure_future'  (co_argcount=1)
# asyncio.run.__code__.co_name            == 'run'            (co_argcount=1)
# asyncio.shield.__code__.co_name         == 'shield'         (co_argcount=1)
# ---------------------------------------------------------------------------

table asyncio_extra105.asyncio_func_co_names:
  description: "asyncio coroutine function __code__.co_name equality checks in asynciocode105 namespace — wave 254 theme: asyncio top-level functions are Python coroutines with a __code__ attribute; co_name is the name of the function as defined in source; asyncio.sleep.__code__.co_name.__eq__('sleep')==True; asyncio.gather.__code__.co_name.__eq__('gather')==True; asyncio.wait.__code__.co_name.__eq__('wait')==True; asyncio.create_task.__code__.co_name.__eq__('create_task')==True; asyncio.ensure_future.__code__.co_name.__eq__('ensure_future')==True; asyncio.run.__code__.co_name.__eq__('run')==True; asyncio.shield.__code__.co_name.__eq__('shield')==True; all co_name values match the function's __qualname__ since all are module-level (not nested); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: asynciocode105

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_co_name,   asyncio.sleep.__code__.co_name.__eq__,         ["sleep"],         true, "asyncio.sleep.__code__.co_name == 'sleep'; verified with Python 3.14.3"]
    - [gather_co_name,  asyncio.gather.__code__.co_name.__eq__,        ["gather"],        true, "asyncio.gather.__code__.co_name == 'gather'; verified with Python 3.14.3"]
    - [wait_co_name,    asyncio.wait.__code__.co_name.__eq__,           ["wait"],          true, "asyncio.wait.__code__.co_name == 'wait'; verified with Python 3.14.3"]
    - [ctask_co_name,   asyncio.create_task.__code__.co_name.__eq__,   ["create_task"],   true, "asyncio.create_task.__code__.co_name == 'create_task'; verified with Python 3.14.3"]
    - [enfut_co_name,   asyncio.ensure_future.__code__.co_name.__eq__, ["ensure_future"], true, "asyncio.ensure_future.__code__.co_name == 'ensure_future'; verified with Python 3.14.3"]
    - [run_co_name,     asyncio.run.__code__.co_name.__eq__,            ["run"],           true, "asyncio.run.__code__.co_name == 'run'; verified with Python 3.14.3"]
    - [shield_co_name,  asyncio.shield.__code__.co_name.__eq__,         ["shield"],        true, "asyncio.shield.__code__.co_name == 'shield'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio coroutine function __code__.co_argcount values — extra105
#
# asyncio.sleep.__code__.co_argcount          == 2  (delay, result)
# asyncio.gather.__code__.co_argcount         == 0  (*coros_or_futures variadic)
# asyncio.wait.__code__.co_argcount           == 1  (fs)
# asyncio.create_task.__code__.co_argcount    == 1  (coro)
# asyncio.ensure_future.__code__.co_argcount  == 1  (coro_or_future)
# asyncio.run.__code__.co_argcount            == 1  (main)
# asyncio.shield.__code__.co_argcount         == 1  (arg)
# ---------------------------------------------------------------------------

table asyncio_extra105.asyncio_func_co_argcounts:
  description: "asyncio coroutine function __code__.co_argcount checks in asynciocode105 namespace — wave 254 theme: co_argcount counts positional parameters only (not *args or **kwargs); asyncio.sleep.__code__.co_argcount.__eq__(2)==True (delay, result — the only function here with argcount=2); asyncio.gather.__code__.co_argcount.__eq__(0)==True (first param is *coros_or_futures variadic, so no non-variadic positionals before it); asyncio.wait.__code__.co_argcount.__eq__(1)==True (fs); asyncio.create_task.__code__.co_argcount.__eq__(1)==True (coro); asyncio.ensure_future.__code__.co_argcount.__eq__(1)==True (coro_or_future); asyncio.run.__code__.co_argcount.__eq__(1)==True (main); asyncio.shield.__code__.co_argcount.__eq__(1)==True (arg); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: asynciocode105a

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_argcount,  asyncio.sleep.__code__.co_argcount.__eq__,         [2], true, "asyncio.sleep.__code__.co_argcount == 2 (delay, result); verified with Python 3.14.3"]
    - [gather_argcount, asyncio.gather.__code__.co_argcount.__eq__,        [0], true, "asyncio.gather.__code__.co_argcount == 0 (*coros_or_futures variadic, no positional-only params); verified with Python 3.14.3"]
    - [wait_argcount,   asyncio.wait.__code__.co_argcount.__eq__,          [1], true, "asyncio.wait.__code__.co_argcount == 1 (fs); verified with Python 3.14.3"]
    - [ctask_argcount,  asyncio.create_task.__code__.co_argcount.__eq__,   [1], true, "asyncio.create_task.__code__.co_argcount == 1 (coro); verified with Python 3.14.3"]
    - [enfut_argcount,  asyncio.ensure_future.__code__.co_argcount.__eq__, [1], true, "asyncio.ensure_future.__code__.co_argcount == 1 (coro_or_future); verified with Python 3.14.3"]
    - [run_argcount,    asyncio.run.__code__.co_argcount.__eq__,           [1], true, "asyncio.run.__code__.co_argcount == 1 (main); verified with Python 3.14.3"]
    - [shield_argcount, asyncio.shield.__code__.co_argcount.__eq__,        [1], true, "asyncio.shield.__code__.co_argcount == 1 (arg); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio coroutine function __module__ values — extra105
#
# asyncio.sleep.__module__         == 'asyncio.tasks'
# asyncio.gather.__module__        == 'asyncio.tasks'
# asyncio.wait.__module__          == 'asyncio.tasks'
# asyncio.create_task.__module__   == 'asyncio.tasks'
# asyncio.ensure_future.__module__ == 'asyncio.tasks'
# asyncio.run.__module__           == 'asyncio.runners'
# asyncio.shield.__module__        == 'asyncio.tasks'
# ---------------------------------------------------------------------------

table asyncio_extra105.asyncio_func_modules:
  description: "asyncio coroutine function __module__ checks in asynciocode105 namespace — wave 254 theme: asyncio function __module__ values show which sub-module defines each function; all functions except run have __module__=='asyncio.tasks' (Lib/asyncio/tasks.py); asyncio.run.__module__=='asyncio.runners' (Lib/asyncio/runners.py) — the sole exception; asyncio.sleep.__module__.__eq__('asyncio.tasks')==True; asyncio.gather.__module__.__eq__('asyncio.tasks')==True; asyncio.run.__module__.__eq__('asyncio.runners')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: asynciocode105b

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_module,   asyncio.sleep.__module__.__eq__,         ["asyncio.tasks"],   true, "asyncio.sleep.__module__ == 'asyncio.tasks' (Lib/asyncio/tasks.py); verified with Python 3.14.3"]
    - [gather_module,  asyncio.gather.__module__.__eq__,        ["asyncio.tasks"],   true, "asyncio.gather.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [wait_module,    asyncio.wait.__module__.__eq__,          ["asyncio.tasks"],   true, "asyncio.wait.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [run_module,     asyncio.run.__module__.__eq__,           ["asyncio.runners"], true, "asyncio.run.__module__ == 'asyncio.runners' (Lib/asyncio/runners.py — unique among this set); verified with Python 3.14.3"]
    - [shield_module,  asyncio.shield.__module__.__eq__,        ["asyncio.tasks"],   true, "asyncio.shield.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [ctask_module,   asyncio.create_task.__module__.__eq__,   ["asyncio.tasks"],   true, "asyncio.create_task.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [enfut_module,   asyncio.ensure_future.__module__.__eq__, ["asyncio.tasks"],   true, "asyncio.ensure_future.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra105
# ---------------------------------------------------------------------------

invariant asyncio_extra105.sleep_co_argcount_2:
  description: "asyncio.sleep.__code__.co_argcount == 2 — sleep is defined as 'async def sleep(delay, result=None)' in Lib/asyncio/tasks.py; co_argcount counts positional parameters (excluding *args/**kwargs) giving 2 (delay, result); this is the only asyncio top-level function in this spec with co_argcount > 1; compare: gather=0, wait=1, create_task=1, ensure_future=1, run=1, shield=1; asyncio.sleep.__code__.co_name is 'sleep'; asyncio.sleep.__module__ is 'asyncio.tasks'; sleep suspends the current coroutine for 'delay' seconds; NEW in extra105: first standalone sleep co_argcount invariant in asynciocode105 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.sleep.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant asyncio_extra105.gather_co_argcount_0:
  description: "asyncio.gather.__code__.co_argcount == 0 — gather is defined as 'async def gather(*coros_or_futures, return_exceptions=False)' in Lib/asyncio/tasks.py; co_argcount counts only non-variadic positional parameters; since the very first parameter is *coros_or_futures (a variadic positional), there are zero non-variadic positional parameters before it, giving co_argcount=0; this makes gather unique in this spec: it is the only function with co_argcount=0; asyncio.gather.__code__.co_name is 'gather'; asyncio.gather.__module__ is 'asyncio.tasks'; gather schedules multiple awaitables concurrently; NEW in extra105: first standalone gather co_argcount invariant in asynciocode105 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.gather.__code__.co_argcount.__eq__
  args: [0]
  expected: true

invariant asyncio_extra105.run_module_is_runners:
  description: "asyncio.run.__module__.__eq__('asyncio.runners') returns True — asyncio.run is defined in Lib/asyncio/runners.py (module='asyncio.runners'); it is the sole function in this spec NOT defined in Lib/asyncio/tasks.py; all other functions (sleep, gather, wait, create_task, ensure_future, shield) have __module__=='asyncio.tasks'; asyncio.run.__code__.co_name is 'run'; asyncio.run.__code__.co_argcount is 1 (main); asyncio.run() is the high-level entry point to run a coroutine (added in Python 3.7); NEW in extra105: first standalone run module runners invariant in asynciocode105 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: asyncio.run.__module__.__eq__
  args: ["asyncio.runners"]
  expected: true

invariant asyncio_extra105.ensure_future_co_name_eq:
  description: "asyncio.ensure_future.__code__.co_name.__eq__('ensure_future') returns True — ensure_future.__code__.co_name is 'ensure_future' (len=13: 'ensure_'=7 + 'future'=6); asyncio.ensure_future is defined in Lib/asyncio/tasks.py (module='asyncio.tasks'); co_argcount is 1 (coro_or_future); ensure_future wraps a coroutine or awaitable in a Future; asyncio.ensure_future.__qualname__ is 'ensure_future' matching co_name (module-level function); compare function co_name lengths: run=3, wait=4, sleep=5, gather=6, shield=6, create_task=11, ensure_future=13 (longest co_name string); NEW in extra105: first standalone ensure_future co_name invariant in asynciocode105 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.ensure_future.__code__.co_name.__eq__
  args: ["ensure_future"]
  expected: true

invariant asyncio_extra105.create_task_co_name_eq:
  description: "asyncio.create_task.__code__.co_name.__eq__('create_task') returns True — create_task.__code__.co_name is 'create_task' (len=11: 'create_'=7 + 'task'=4); asyncio.create_task is defined in Lib/asyncio/tasks.py (module='asyncio.tasks'); co_argcount is 1 (coro); create_task wraps a coroutine in a Task and schedules its execution; asyncio.create_task.__qualname__ is 'create_task' matching co_name (module-level function); co_name 'create_task' is the second-longest among the spec's functions (len=11) after 'ensure_future' (len=13); compare: run=3, wait=4, sleep=5, gather=6, shield=6, create_task=11, ensure_future=13; NEW in extra105: first standalone create_task co_name invariant in asynciocode105 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.create_task.__code__.co_name.__eq__
  args: ["create_task"]
  expected: true
