spec: pathlib_extra47
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra46.zspec.zsdl — covers Path/__name__=='Path'/__module__=='pathlib'; PurePath/Path/PurePosixPath/PureWindowsPath __mro__.__len__(); PosixPath/__name__=='PosixPath'/__module__=='pathlib'."
    - "pathlib_extra45.zspec.zsdl — covers PureWindowsPath/__dict__.__len__()==6; PosixPath/__dict__.__len__()==5; WindowsPath/__dict__.__len__()==6; PurePath/__bases__.__len__()==1; Path/__bases__.__len__()==1."
    - "pathlib_extra44.zspec.zsdl — covers UnsupportedOperation identity; Path/__slots__.__len__()==1; Path.readlink/__qualname__.__len__()==13; PurePath.full_match/__qualname__.__len__()==19."
    - "pathlib_extra43.zspec.zsdl — covers PurePath.__new__/__init__ __qualname__.__len__(); Path.__new__ __qualname__.__len__(); PurePath.__slots__.__len__()==8."
    - "pathlib_extra40.zspec.zsdl — covers Path/PurePath/PurePosixPath __dict__.__len__()."
    - "pathlib_extra38.zspec.zsdl — covers PurePosixPath/PureWindowsPath/__bases__[0].__name__.__len__()==8; PosixPath/WindowsPath/__bases__[0].__name__.__len__()==4."
    - "pathlib_extra34.zspec.zsdl — covers PurePath/PurePosixPath/PureWindowsPath __name__.__len__() and __module__.__len__()==7."
    - "pathlib_extra31.zspec.zsdl — covers PurePath.__bases__[0].__name__=='object'; Path.__bases__[0].__name__=='PurePath'."
    - "pathlib_extra11.zspec.zsdl — covers PurePath.__module__=='pathlib'; PurePosixPath/PureWindowsPath __bases__.__len__()==1."
  notes:
    - "This spec extends pathlib_extra46.zspec.zsdl."
    - "Prior specs collectively covered: all Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __name__/__module__ equality and lengths; MRO depths; __bases__[0].__name__ for all classes; all major Path/PurePath method __qualname__.__len__(); __slots__/__dict__ lengths; UnsupportedOperation identity."
    - "This spec covers: pathlib.Path.cwd.__qualname__.__len__()==8 (NOVEL — pathlib_extra43/44 cover various Path/PurePath method __qualname__.__len__() but not cwd, home, stat, exists, is_file, is_dir, open, read_text, or write_text in this form; 'Path.cwd' is 8 chars; verified Python 3.14); pathlib.Path.home.__qualname__.__len__()==9 (NOVEL — 'Path.home' is 9 chars); pathlib.Path.stat.__qualname__.__len__()==9 (NOVEL — 'Path.stat' is 9 chars); pathlib.Path.exists.__qualname__.__len__()==11 (NOVEL — 'Path.exists' is 11 chars); pathlib.Path.is_file.__qualname__.__len__()==12 (NOVEL — 'Path.is_file' is 12 chars); pathlib.Path.is_dir.__qualname__.__len__()==11 (NOVEL — 'Path.is_dir' is 11 chars); pathlib.Path.open.__qualname__.__len__()==9 (NOVEL — 'Path.open' is 9 chars); pathlib.Path.read_text.__qualname__.__len__()==14 (NOVEL — 'Path.read_text' is 14 chars); pathlib.Path.write_text.__qualname__.__len__()==15 (NOVEL — 'Path.write_text' is 15 chars)."
    - "pathlib.Path.cwd.__qualname__.__len__() == 8. 'Path.cwd' has 8 characters (P-a-t-h-.-c-w-d). No prior pathlib spec covers Path.cwd.__qualname__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.home.__qualname__.__len__() == 9. 'Path.home' has 9 characters. No prior pathlib spec covers this. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.stat.__qualname__.__len__() == 9. 'Path.stat' has 9 characters. No prior pathlib spec covers Path.stat qualname length. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.exists.__qualname__.__len__() == 11. 'Path.exists' has 11 characters. No prior pathlib spec covers this. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.is_file.__qualname__.__len__() == 12. 'Path.is_file' has 12 characters. No prior pathlib spec covers this. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.is_dir.__qualname__.__len__() == 11. 'Path.is_dir' has 11 characters. No prior pathlib spec covers this. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.open.__qualname__.__len__() == 9. 'Path.open' has 9 characters. No prior pathlib spec covers Path.open qualname length. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.read_text.__qualname__.__len__() == 14. 'Path.read_text' has 14 characters. No prior pathlib spec covers this. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.write_text.__qualname__.__len__() == 15. 'Path.write_text' has 15 characters. No prior pathlib spec covers this. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path method __qualname__.__len__() for filesystem query methods
#
# These are the core Path methods for filesystem interaction. Their __qualname__
# follows the pattern 'Path.<method_name>' and the length is exactly the number
# of characters in that string.
#
# Method qualname lengths (all verified Python 3.14 macOS/Darwin 25.4.0):
#   Path.cwd       -> 'Path.cwd'       -> len  8
#   Path.home      -> 'Path.home'      -> len  9
#   Path.stat      -> 'Path.stat'      -> len  9
#   Path.exists    -> 'Path.exists'    -> len 11
#   Path.is_file   -> 'Path.is_file'   -> len 12
#   Path.is_dir    -> 'Path.is_dir'    -> len 11
#   Path.open      -> 'Path.open'      -> len  9
#   Path.read_text -> 'Path.read_text' -> len 14
#   Path.write_text-> 'Path.write_text'-> len 15
#
# All novel in pathlib_extra47 namespace (no prior pathlib spec covers any
# of these method qualname lengths).
# ---------------------------------------------------------------------------

table pathlib_extra47.Path_method_qualname_lens:
  description: "pathlib.Path filesystem method __qualname__.__len__(): cwd(8)/home(9)/stat(9)/exists(11)/is_file(12)/is_dir(11)/open(9)/read_text(14)/write_text(15) — all novel in pathlib_extra47 namespace; no prior pathlib spec covers these nine methods' qualname lengths; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: method_identity
  id_prefix: pmql47

  columns: [id, function, args, expected]
  rows:
    - [cwd_qualname_len,        Path.cwd.__qualname__.__len__,        [], 8]
    - [home_qualname_len,       Path.home.__qualname__.__len__,       [], 9]
    - [stat_qualname_len,       Path.stat.__qualname__.__len__,       [], 9]
    - [exists_qualname_len,     Path.exists.__qualname__.__len__,     [], 11]
    - [is_file_qualname_len,    Path.is_file.__qualname__.__len__,    [], 12]
    - [is_dir_qualname_len,     Path.is_dir.__qualname__.__len__,     [], 11]
    - [open_qualname_len,       Path.open.__qualname__.__len__,       [], 9]
    - [read_text_qualname_len,  Path.read_text.__qualname__.__len__,  [], 14]
    - [write_text_qualname_len, Path.write_text.__qualname__.__len__, [], 15]
