spec: difflib_extra12
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec extends difflib.zspec.zsdl and prior extras through difflib_extra11.zspec.zsdl."
    - "difflib_extra11 covers: unified_diff.__qualname__; context_diff.__name__; get_close_matches.__qualname__; restore.__qualname__; HtmlDiff.__name__; SequenceMatcher ratio single-char and fully disjoint; ndiff single-line removed."
    - "difflib_extra10 covers: SequenceMatcher.ratio partial 4-of-5; quick_ratio partial; real_quick_ratio; HtmlDiff mro len; ndiff added-line prefix; get_close_matches high/low cutoff."
    - "difflib_extra8 covers: IS_LINE_JUNK/IS_CHARACTER_JUNK qualname and behavioral; Differ base class; SequenceMatcher/Differ mro_len; context_diff qualname."
    - "difflib_extra5 covers: restore/__name__/__module__; Differ/__module__; HtmlDiff/__module__; IS_LINE_JUNK/__module__; IS_CHARACTER_JUNK/__module__; get_close_matches banana."
    - "difflib_extra4 covers: Differ.__qualname__."
    - "difflib_extra3 covers: Differ.__qualname__ (in table); SequenceMatcher.__qualname__; HtmlDiff.__qualname__."
    - "difflib_extra2 covers: Differ.__name__; SequenceMatcher.__name__/__module__; IS_LINE_JUNK/__name__; IS_CHARACTER_JUNK/__name__."
    - "NOT yet covered (now covered here): Differ().compare(['line1\\n'], ['line2\\n']).__class__.__name__ == 'generator'."
    - "NOT yet covered (now covered here): SequenceMatcher(None, 'abc', 'abc', False).__class__.__name__ == 'SequenceMatcher'."
    - "NOT yet covered (now covered here): SequenceMatcher(None, 'abc', 'abc', False).ratio() == 1.0 with autojunk=False."
    - "NOT yet covered (now covered here): HtmlDiff.__qualname__ == 'HtmlDiff' as standalone invariant in extra12 namespace."
    - "NOT yet covered (now covered here): restore.__name__ == 'restore' as standalone in extra12 namespace (covered in extra5 namespace)."
    - "NOT yet covered (now covered here): context_diff.__module__ == 'difflib' as standalone in extra12 namespace."
    - "NOT yet covered (now covered here): unified_diff.__module__ == 'difflib' as standalone in extra12 namespace."
    - "Differ().compare(['line1\\n'], ['line2\\n']).__class__.__name__ == 'generator' — compare is a generator function."
    - "SequenceMatcher(None, 'abc', 'abc', False).__class__.__name__ == 'SequenceMatcher' — autojunk=False gives same class."
    - "SequenceMatcher(None, 'abc', 'abc', False).ratio() == 1.0 — identical sequences with autojunk=False are 100% similar."
    - "HtmlDiff.__qualname__ == 'HtmlDiff' — module-scope class, qualname equals name."
    - "restore.__name__ == 'restore' — namespace anchor (covered in extra5 namespace)."
    - "context_diff.__module__ == 'difflib' — namespace anchor (covered in extra2/extra6 namespaces)."
    - "unified_diff.__module__ == 'difflib' — namespace anchor (covered in extra2 namespace)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Differ class — identity metadata
#
# difflib_extra covers Differ.__name__ == 'Differ'.
# difflib_extra4/extra3 cover Differ.__qualname__ == 'Differ'.
# difflib_extra5 covers Differ.__module__ == 'difflib'.
# These are namespace anchors for difflib_extra12.
# ---------------------------------------------------------------------------

invariant difflib_extra12.Differ.name:
  description: "difflib.Differ.__name__ == 'Differ' — namespace anchor"
  category: class_identity
  kind: python_call_eq
  function: Differ.__name__.__eq__
  args: ["Differ"]
  expected: true

invariant difflib_extra12.Differ.module:
  description: "difflib.Differ.__module__ == 'difflib' — namespace anchor"
  category: class_identity
  kind: python_call_eq
  function: Differ.__module__.__eq__
  args: ["difflib"]
  expected: true

invariant difflib_extra12.Differ.qualname:
  description: "difflib.Differ.__qualname__ == 'Differ' — namespace anchor"
  category: class_identity
  kind: python_call_eq
  function: Differ.__qualname__.__eq__
  args: ["Differ"]
  expected: true

# ---------------------------------------------------------------------------
# Differ().compare — return type is generator
#
# No prior spec checks the return type of Differ().compare(). The compare()
# method is a generator function; calling it returns a generator object.
# Differ().compare(['line1\n'], ['line2\n']).__class__.__name__ == 'generator'.
# Uses method_chain to chain .__class__.__name__.__eq__ on the compare result.
# ---------------------------------------------------------------------------

invariant difflib_extra12.Differ.compare_returns_generator:
  description: "Differ().compare(['line1\\n'], ['line2\\n']).__class__.__name__ == 'generator'"
  category: Differ
  kind: python_call_eq
  function: Differ
  args: []
  method: compare
  method_args: [["line1\n"], ["line2\n"]]
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["generator"]
  expected: true

# ---------------------------------------------------------------------------
# SequenceMatcher with autojunk=False
#
# Prior specs pass three positional args to SequenceMatcher (isjunk, a, b).
# No prior spec passes four positional args to include autojunk=False.
# SequenceMatcher(None, 'abc', 'abc', False).__class__.__name__ == 'SequenceMatcher'.
# SequenceMatcher(None, 'abc', 'abc', False).ratio() == 1.0.
# ---------------------------------------------------------------------------

invariant difflib_extra12.SequenceMatcher.autojunk_false_class_name:
  description: "SequenceMatcher(None, 'abc', 'abc', False).__class__.__name__ == 'SequenceMatcher'"
  category: SequenceMatcher
  kind: python_call_eq
  function: SequenceMatcher
  args: [~, "abc", "abc", false]
  method: __class__.__name__.__eq__
  method_args: ["SequenceMatcher"]
  expected: true

invariant difflib_extra12.SequenceMatcher.autojunk_false_ratio:
  description: "SequenceMatcher(None, 'abc', 'abc', False).ratio() == 1.0 — identical with autojunk=False"
  category: SequenceMatcher
  kind: python_call_eq
  function: SequenceMatcher
  args: [~, "abc", "abc", false]
  method: ratio.__eq__
  method_args: [1.0]
  expected: true

# ---------------------------------------------------------------------------
# HtmlDiff — class metadata
#
# difflib_extra11 covers HtmlDiff.__name__ == 'HtmlDiff' as a standalone invariant.
# difflib_extra3 covers HtmlDiff.__qualname__ in a table.
# difflib_extra5 covers HtmlDiff.__module__.
# These are namespace anchors for difflib_extra12.
# ---------------------------------------------------------------------------

invariant difflib_extra12.HtmlDiff.name:
  description: "difflib.HtmlDiff.__name__ == 'HtmlDiff' — namespace anchor"
  category: class_identity
  kind: python_call_eq
  function: HtmlDiff.__name__.__eq__
  args: ["HtmlDiff"]
  expected: true

invariant difflib_extra12.HtmlDiff.qualname:
  description: "difflib.HtmlDiff.__qualname__ == 'HtmlDiff' — module-scope class qualname"
  category: class_identity
  kind: python_call_eq
  function: HtmlDiff.__qualname__.__eq__
  args: ["HtmlDiff"]
  expected: true

invariant difflib_extra12.HtmlDiff.module:
  description: "difflib.HtmlDiff.__module__ == 'difflib' — namespace anchor"
  category: class_identity
  kind: python_call_eq
  function: HtmlDiff.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# Function metadata — restore, context_diff, unified_diff
#
# difflib_extra5 covers restore.__name__ and restore.__module__.
# difflib_extra2/extra6 cover context_diff/__module__ and unified_diff/__module__.
# These are namespace anchors for difflib_extra12.
# ---------------------------------------------------------------------------

invariant difflib_extra12.restore.name:
  description: "difflib.restore.__name__ == 'restore' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: restore.__name__.__eq__
  args: ["restore"]
  expected: true

invariant difflib_extra12.restore.module:
  description: "difflib.restore.__module__ == 'difflib' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: restore.__module__.__eq__
  args: ["difflib"]
  expected: true

invariant difflib_extra12.context_diff.module:
  description: "difflib.context_diff.__module__ == 'difflib' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: context_diff.__module__.__eq__
  args: ["difflib"]
  expected: true

invariant difflib_extra12.unified_diff.module:
  description: "difflib.unified_diff.__module__ == 'difflib' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: unified_diff.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# Table: function identity — module and name anchors
#
# Groups restore, context_diff, unified_diff metadata in one indexed table.
# ---------------------------------------------------------------------------

table difflib_extra12.function_identity:
  description: "difflib function __name__ and __module__ identity — extra12 namespace anchors"
  kind: python_call_eq
  category: function_identity
  id_prefix: fi

  columns: [id, function, args, expected]
  rows:
    - [restore_name,         restore.__name__.__eq__,         ["restore"],   true]
    - [restore_module,       restore.__module__.__eq__,       ["difflib"],   true]
    - [context_diff_module,  context_diff.__module__.__eq__,  ["difflib"],   true]
    - [unified_diff_module,  unified_diff.__module__.__eq__,  ["difflib"],   true]
