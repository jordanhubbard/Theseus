spec: theseus_base64_cr
version: ">=3.8"
backend: python_cleanroom(theseus_base64_cr)
blocks: base64

docs: https://docs.python.org/3/library/base64.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/base64.html"
    - "RFC 4648 — Base16, Base32, Base64 Data Encodings"
  not_derived_from:
    - "CPython source: Lib/base64.py (internal implementation)"
  notes:
    - "Clean-room base64 module. Do NOT import base64."
    - "b64encode(s): encode bytes to base64 bytes."
    - "b64decode(s): decode base64 bytes to original bytes."
    - "urlsafe_b64encode(s): URL-safe base64 encoding."
    - "urlsafe_b64decode(s): URL-safe base64 decoding."
    - "b32encode(s): Base32 encode."
    - "b32decode(s): Base32 decode."

error_model: python_exceptions

invariant theseus_base64_cr.base64_2_encode:
  description: "b64encode(b'hello') returns b'aGVsbG8='"
  category: b64encode
  kind: python_call_eq
  function: base64_2_encode
  args: []
  expected: "aGVsbG8="

invariant theseus_base64_cr.base64_2_decode:
  description: "b64decode(b'aGVsbG8=') returns b'hello'"
  category: b64decode
  kind: python_call_eq
  function: base64_2_decode
  args: []
  expected: "hello"

invariant theseus_base64_cr.base64_2_round_trip:
  description: "decode(encode(data)) == data for arbitrary bytes"
  category: b64encode
  kind: python_call_eq
  function: base64_2_round_trip
  args: []
  expected: true
