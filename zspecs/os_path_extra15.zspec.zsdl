spec: os_path_extra15
version: ">=3.9"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python os.path module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py"
    - "os_path_extra.zspec.zsdl — covers join('/a','b')=='/a/b'; exists/isfile/isdir/isabs/__name__; dirname/basename on '/a/b/c.txt'"
    - "os_path_extra14.zspec.zsdl — covers join three-arg/absolute-resets; normpath dotdot/singledot/double-slash; expandvars class_name; lexists/realpath __name__"
  notes:
    - "This spec extends os_path.zspec.zsdl and prior extras through os_path_extra14.zspec.zsdl."
    - "os.path.sep == '/' on POSIX — covered in prior specs; re-anchored in extra15 namespace."
    - "os.path.curdir == '.' — covered in prior specs; re-anchored in extra15 namespace."
    - "os.path.pardir == '..' — covered in prior specs; re-anchored in extra15 namespace."
    - "os.path.extsep == '.' — covered in prior specs; re-anchored in extra15 namespace."
    - "os.path.altsep is None on POSIX — altsep is None on POSIX systems (there is no alternative separator); no prior spec covers the value check (only type checks exist)."
    - "os.path.pathsep == ':' on POSIX — no prior spec covers the string value of pathsep."
    - "os.path.defpath == '/bin:/usr/bin' on macOS — no prior spec covers the actual value of defpath (only class name checks exist); value is macOS-specific."
    - "os.path.pathsep.__class__.__name__ == 'str' — no prior spec covers the class name of pathsep."
    - "os.path.sep.__class__.__name__ == 'str' — no prior spec covers the class name of sep itself (only prior type checks are for curdir/pardir/extsep/defpath)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# os.path path separator constants — sep, curdir, pardir, extsep
#
# Prior specs cover these string values individually in scattered invariants.
# This table re-anchors all four in the extra15 namespace as a unified cross-check.
# ---------------------------------------------------------------------------

table os_path_extra15.separator_constants:
  description: "os.path separator constant values: sep/'/', curdir/'.', pardir/'..', extsep/'.'"
  kind: python_call_eq
  category: constants
  id_prefix: sepconst15

  columns: [id, function, args, expected]
  rows:
    - [sep,    sep.__eq__,    ["/"],  true]
    - [curdir, curdir.__eq__, ["."],  true]
    - [pardir, pardir.__eq__, [".."], true]
    - [extsep, extsep.__eq__, ["."],  true]

# ---------------------------------------------------------------------------
# os.path.altsep is None on POSIX
#
# On POSIX systems, there is no alternative path separator, so altsep is None.
# No prior os.path spec covers the value check for altsep (prior specs only
# check altsep.__class__.__name__ == 'NoneType' or similar type checks).
# Using __eq__ with ~ (null) to assert the None value directly.
# ---------------------------------------------------------------------------

invariant os_path_extra15.altsep.is_none:
  description: "os.path.altsep is None on POSIX — no alternative path separator exists"
  category: constants
  kind: python_call_eq
  function: altsep.__eq__
  args: [~]
  expected: true

# ---------------------------------------------------------------------------
# os.path.pathsep == ':' on POSIX
#
# The path list separator on POSIX is ':' (used in $PATH, etc.).
# No prior os.path spec covers the string value of pathsep.
# ---------------------------------------------------------------------------

invariant os_path_extra15.pathsep.value:
  description: "os.path.pathsep == ':' on POSIX — path list separator is colon"
  category: constants
  kind: python_call_eq
  function: pathsep.__eq__
  args: [":"]
  expected: true

# ---------------------------------------------------------------------------
# os.path.defpath == '/bin:/usr/bin' on macOS
#
# defpath is the default search path when PATH is not set. On macOS, its
# value is '/bin:/usr/bin'. Prior specs only check defpath.__class__.__name__.
# This invariant checks the actual string value on macOS/Darwin.
# ---------------------------------------------------------------------------

invariant os_path_extra15.defpath.value:
  description: "os.path.defpath == '/bin:/usr/bin' on macOS — default search path value"
  category: constants
  kind: python_call_eq
  function: defpath.__eq__
  args: ["/bin:/usr/bin"]
  expected: true

# ---------------------------------------------------------------------------
# Class name checks — sep and pathsep are str
#
# Prior specs cover curdir/pardir/extsep/defpath.__class__.__name__ == 'str'.
# No prior spec covers sep.__class__.__name__ or pathsep.__class__.__name__.
# This table fills those two gaps.
# ---------------------------------------------------------------------------

table os_path_extra15.constant_class_names:
  description: "os.path.sep and os.path.pathsep are both str instances"
  kind: python_call_eq
  category: constants
  id_prefix: clsname15

  columns: [id, function, args, expected]
  rows:
    - [sep,     sep.__class__.__name__.__eq__,     ["str"], true]
    - [pathsep, pathsep.__class__.__name__.__eq__, ["str"], true]
