spec: functools_extra268
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.reduce behavioral contracts — sum, product with initializer, empty with initial, single element, string concatenation, and error on empty with no initial."
    - "functools.reduce(lambda x,y: x+y, [1,2,3,4]) == 10 — pairwise addition left-fold: ((1+2)+3)+4 == 10. Verified with Python 3.14.3."
    - "functools.reduce(lambda x,y: x*y, [1,2,3,4], 1) == 24 — pairwise multiplication starting from initializer 1: (((1*1)*2)*3)*4 == 24. Verified with Python 3.14.3."
    - "functools.reduce(lambda x,y: x+y, [], 0) == 0 — empty sequence with initializer returns the initializer. Verified with Python 3.14.3."
    - "functools.reduce(lambda x,y: x+y, [42]) == 42 — single element returns element unchanged (function is never called). Verified with Python 3.14.3."
    - "functools.reduce(lambda x,y: x+y, ['a','b','c']) == 'abc' — string concatenation left-fold: (('a'+'b')+'c') == 'abc'. Verified with Python 3.14.3."
    - "functools.reduce(lambda x,y: x+y, []) raises TypeError — empty iterable with no initial value is undefined. Verified with Python 3.14.3."
    - "functools.reduce.__name__ == 'reduce'; __module__ == '_functools'; __class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.reduce identity
#
# functools.reduce.__name__ == 'reduce'
# functools.reduce.__module__ == '_functools'
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
#
# reduce is a C-level builtin in _functoolsmodule.c. Its __module__ is
# '_functools' (the C extension), not 'functools'. New to extra268.
# ---------------------------------------------------------------------------

table functools_extra268.reduce_identity:
  description: "functools.reduce identity: __name__, __module__, __class__.__name__; new to extra268"
  kind: python_call_eq
  category: identity
  id_prefix: ftreduce268

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_name_eq,
       reduce.__name__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__name__.__eq__('reduce') == True — reduce is a C builtin in _functoolsmodule.c; its __name__ is 'reduce'; str.__eq__('reduce') returns True; new to extra268"]
    - [reduce_module_eq,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is defined in the _functools C extension module; its __module__ is '_functools'; str.__eq__('_functools') returns True; new to extra268"]
    - [reduce_class_name_eq,
       reduce.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C builtin; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra268"]
    - [reduce_qualname_eq,
       reduce.__qualname__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — reduce is a top-level C builtin so __qualname__ == __name__; str.__eq__('reduce') returns True; new to extra268"]
    - [reduce_name_len_6,
       reduce.__name__.__len__,
       [],
       6,
       "functools.reduce.__name__.__len__() == 6 — the name 'reduce' has exactly 6 characters: r-e-d-u-c-e; str.__len__() returns 6; new to extra268"]

# ---------------------------------------------------------------------------
# Table 2: functools.reduce numeric behavioral contracts
#
# reduce(lambda x,y: x+y, [1,2,3,4]) == 10
# reduce(lambda x,y: x*y, [1,2,3,4], 1) == 24
# reduce(lambda x,y: x+y, [], 0) == 0
# reduce(lambda x,y: x+y, [42]) == 42
#
# These use lambda strings which the harness evaluates. New to extra268.
# ---------------------------------------------------------------------------

table functools_extra268.reduce_numeric:
  description: "functools.reduce numeric behavioral contracts; new to extra268"
  kind: python_call_eq
  category: reduce
  id_prefix: ftreducen268

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_sum_4_eq_10,
       reduce,
       ["lambda x,y: x+y", [1, 2, 3, 4]],
       10,
       "functools.reduce(lambda x,y: x+y, [1,2,3,4]) == 10 — left-fold addition: ((1+2)+3)+4 == 10; new to extra268"]
    - [reduce_product_with_init_eq_24,
       reduce,
       ["lambda x,y: x*y", [1, 2, 3, 4], 1],
       24,
       "functools.reduce(lambda x,y: x*y, [1,2,3,4], 1) == 24 — left-fold multiply with initializer 1: (((1*1)*2)*3)*4 == 24; new to extra268"]
    - [reduce_empty_with_init_eq_0,
       reduce,
       ["lambda x,y: x+y", [], 0],
       0,
       "functools.reduce(lambda x,y: x+y, [], 0) == 0 — empty sequence with initializer 0 returns the initializer; new to extra268"]
    - [reduce_single_element_eq_42,
       reduce,
       ["lambda x,y: x+y", [42]],
       42,
       "functools.reduce(lambda x,y: x+y, [42]) == 42 — single-element sequence returns element unchanged; function is never called; new to extra268"]
    - [reduce_string_concat_eq_abc,
       reduce,
       ["lambda x,y: x+y", ["a", "b", "c"]],
       "abc",
       "functools.reduce(lambda x,y: x+y, ['a','b','c']) == 'abc' — string concatenation left-fold: (('a'+'b')+'c') == 'abc'; new to extra268"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra268
# ---------------------------------------------------------------------------

invariant functools_extra268.reduce.name_eq:
  description: "functools.reduce.__name__.__eq__('reduce') == True — C builtin in _functools; new to extra268"
  category: identity
  kind: python_call_eq
  function: reduce.__name__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra268.reduce.module_eq:
  description: "functools.reduce.__module__.__eq__('_functools') == True — reduce is in the _functools C extension; new to extra268"
  category: identity
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra268.reduce.class_name_eq:
  description: "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True; new to extra268"
  category: identity
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra268.reduce.sum_of_four:
  description: "functools.reduce(lambda x,y: x+y, [1,2,3,4]) == 10 — left-fold addition; new to extra268"
  category: reduce
  kind: python_call_eq
  function: reduce
  args: ["lambda x,y: x+y", [1, 2, 3, 4]]
  expected: 10

invariant functools_extra268.reduce.product_with_init:
  description: "functools.reduce(lambda x,y: x*y, [1,2,3,4], 1) == 24 — left-fold multiply with initializer; new to extra268"
  category: reduce
  kind: python_call_eq
  function: reduce
  args: ["lambda x,y: x*y", [1, 2, 3, 4], 1]
  expected: 24

invariant functools_extra268.reduce.empty_with_init:
  description: "functools.reduce(lambda x,y: x+y, [], 0) == 0 — empty sequence with initializer returns the initializer; new to extra268"
  category: reduce
  kind: python_call_eq
  function: reduce
  args: ["lambda x,y: x+y", [], 0]
  expected: 0

invariant functools_extra268.reduce.single_element:
  description: "functools.reduce(lambda x,y: x+y, [42]) == 42 — single element returned unchanged; new to extra268"
  category: reduce
  kind: python_call_eq
  function: reduce
  args: ["lambda x,y: x+y", [42]]
  expected: 42

invariant functools_extra268.reduce.empty_no_init_raises_typeerror:
  description: "functools.reduce(lambda x,y: x+y, []) raises TypeError — empty iterable with no initial value is undefined; new to extra268"
  category: errors
  kind: python_call_raises
  function: reduce
  args: ["lambda x,y: x+y", []]
  raises: TypeError
