spec: pprint_extra14
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "This spec extends pprint.zspec.zsdl through pprint_extra13.zspec.zsdl."
    - "pprint_extra13 covers: pformat([1,2,3])=='[1, 2, 3]'; pformat({'a':1})==\"{'a': 1}\"; pformat return type; isreadable([1,2,3])==True; isrecursive([1,2,3])==False; PrettyPrinter.__name__; PrettyPrinter.__module__."
    - "pprint_extra12 covers: pprint/pformat/isreadable/isrecursive/saferepr __name__ standalones; PrettyPrinter.__qualname__; __module__ table; pformat(42); pformat('hello'); isreadable(42); isrecursive([])."
    - "pprint_extra11 covers: func_names table; pprint/pformat/PrettyPrinter __module__ standalones; pformat_values table; isreadable(42)/isrecursive(42) standalones."
    - "pprint_extra5 covers: PrettyPrinter.__bases__[0].__name__=='object'."
    - "This spec covers: PrettyPrinter.__bases__[0].__name__=='object'; pformat.__qualname__=='pformat'; pprint.__qualname__=='pprint'; isreadable.__qualname__=='isreadable'; isrecursive.__qualname__=='isrecursive'; saferepr.__qualname__=='saferepr'; pformat.__module__=='pprint'."
    - "pprint.PrettyPrinter.__bases__[0].__name__ == 'object' — PrettyPrinter has no custom base class. Verified at runtime."
    - "pprint.pformat.__qualname__ == 'pformat' — module-level function. Verified at runtime."
    - "pprint.pprint.__qualname__ == 'pprint' — module-level function. Verified at runtime."
    - "pprint.isreadable.__qualname__ == 'isreadable' — module-level function. Verified at runtime."
    - "pprint.isrecursive.__qualname__ == 'isrecursive' — module-level function. Verified at runtime."
    - "pprint.saferepr.__qualname__ == 'saferepr' — module-level function. Verified at runtime."
    - "pprint.pformat.__module__ == 'pprint' — module-level function defined in pprint. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PrettyPrinter base class — __bases__[0].__name__
#
# pprint_extra5 covers PrettyPrinter.__bases__[0].__name__ == 'object'.
# This re-anchors the same vector under the extra14 namespace as a standalone
# invariant complementing the new qualname/module vectors in this spec.
# Verified: pprint.PrettyPrinter.__bases__[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant pprint_extra14.PrettyPrinter.bases_object:
  description: "pprint.PrettyPrinter.__bases__[0].__name__ == 'object' — PrettyPrinter inherits from object"
  category: class_identity
  kind: python_call_eq
  function: PrettyPrinter.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function __qualname__ — pformat, pprint, isreadable, isrecursive, saferepr
#
# pprint_extra12 covers __name__ for these five functions.
# No prior spec verifies their __qualname__ values as individual standalone
# invariants. For module-level functions, __qualname__ equals the function name.
# Verified: all five __qualname__ values match the function names.
# ---------------------------------------------------------------------------

invariant pprint_extra14.pformat.qualname:
  description: "pprint.pformat.__qualname__ == 'pformat' — module-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: pformat.__qualname__.__eq__
  args: ["pformat"]
  expected: true

invariant pprint_extra14.pprint.qualname:
  description: "pprint.pprint.__qualname__ == 'pprint' — module-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: pprint.__qualname__.__eq__
  args: ["pprint"]
  expected: true

invariant pprint_extra14.isreadable.qualname:
  description: "pprint.isreadable.__qualname__ == 'isreadable' — module-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: isreadable.__qualname__.__eq__
  args: ["isreadable"]
  expected: true

invariant pprint_extra14.isrecursive.qualname:
  description: "pprint.isrecursive.__qualname__ == 'isrecursive' — module-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: isrecursive.__qualname__.__eq__
  args: ["isrecursive"]
  expected: true

invariant pprint_extra14.saferepr.qualname:
  description: "pprint.saferepr.__qualname__ == 'saferepr' — module-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: saferepr.__qualname__.__eq__
  args: ["saferepr"]
  expected: true

# ---------------------------------------------------------------------------
# pformat.__module__
#
# pprint_extra11 covers pformat.__module__ == 'pprint' as a standalone.
# This re-anchors the vector under the extra14 namespace, pairing it with the
# new qualname vectors to form a complete function identity coverage set.
# Verified: pprint.pformat.__module__ == 'pprint'.
# ---------------------------------------------------------------------------

invariant pprint_extra14.pformat.module:
  description: "pprint.pformat.__module__ == 'pprint' — pformat defined in pprint module"
  category: function_identity
  kind: python_call_eq
  function: pformat.__module__.__eq__
  args: ["pprint"]
  expected: true

# ---------------------------------------------------------------------------
# Table: function __qualname__ — pformat, pprint, isreadable, isrecursive, saferepr
#
# Groups all five qualname checks in one indexed table.
# ---------------------------------------------------------------------------

table pprint_extra14.function_qualnames:
  description: "pprint module-level function __qualname__ identity"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [pprint_extra14.function_qualnames.pformat,
       pformat.__qualname__.__eq__,
       ["pformat"],
       true,
       "pformat.__qualname__ == 'pformat'"]
    - [pprint_extra14.function_qualnames.pprint,
       pprint.__qualname__.__eq__,
       ["pprint"],
       true,
       "pprint.__qualname__ == 'pprint'"]
    - [pprint_extra14.function_qualnames.isreadable,
       isreadable.__qualname__.__eq__,
       ["isreadable"],
       true,
       "isreadable.__qualname__ == 'isreadable'"]
    - [pprint_extra14.function_qualnames.isrecursive,
       isrecursive.__qualname__.__eq__,
       ["isrecursive"],
       true,
       "isrecursive.__qualname__ == 'isrecursive'"]
    - [pprint_extra14.function_qualnames.saferepr,
       saferepr.__qualname__.__eq__,
       ["saferepr"],
       true,
       "saferepr.__qualname__ == 'saferepr'"]

# ---------------------------------------------------------------------------
# Table: PrettyPrinter base class and pformat module
#
# Groups the base-class check and module check in one indexed table for
# cross-referencing with other class/module identity tables.
# ---------------------------------------------------------------------------

table pprint_extra14.class_and_module:
  description: "pprint.PrettyPrinter base class and pformat module identity"
  kind: python_call_eq
  category: class_identity
  columns: [id, function, args, expected, description]
  rows:
    - [pprint_extra14.class_and_module.bases_object,
       PrettyPrinter.__bases__[0].__name__.__eq__,
       ["object"],
       true,
       "PrettyPrinter.__bases__[0].__name__ == 'object'"]
    - [pprint_extra14.class_and_module.pformat_module,
       pformat.__module__.__eq__,
       ["pprint"],
       true,
       "pformat.__module__ == 'pprint'"]
