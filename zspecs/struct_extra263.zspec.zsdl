spec: struct_extra263
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra262.zspec.zsdl — covers Struct method __name__/__class__/__qualname__ identity; Struct.size/format getset_descriptor identity."
    - "struct_extra261.zspec.zsdl — covers struct module-level function identity."
    - "struct_extra260.zspec.zsdl — covers struct module identity and Struct class identity."
  notes:
    - "struct.error.__name__ == 'error' — the exception class name is 'error' (lowercase). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.error.__module__ == 'struct' — error is defined in the struct module. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.error.__qualname__ == 'error' — qualname is 'error' (top-level class in module). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.error.__bases__[0].__name__ == 'Exception' — struct.error directly inherits from Exception. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack('!I', -1) raises struct.error — unsigned int format '!I' cannot accept negative values. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack('b', 200) raises struct.error — signed byte 'b' max is 127; 200 overflows. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.unpack('!I', b'abc') raises struct.error — '!I' requires exactly 4 bytes; 3 bytes is too short. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.error class identity — name, module, qualname, bases
# struct.error is the exception class raised by pack/unpack on invalid input.
# It is a top-level class in the struct module, inheriting from Exception.
# ---------------------------------------------------------------------------

table struct_extra263.error_class_identity:
  description: "struct.error class identity — __name__/'error', __module__/'struct', __qualname__/'error', __bases__[0].__name__/'Exception'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structerr263

  columns: [id, function, args, expected, description]
  rows:
    - [error_name,       error.__name__.__eq__,            ["error"],     true, "struct.error.__name__ == 'error' — exception class name is lowercase 'error'"]
    - [error_module,     error.__module__.__eq__,          ["struct"],    true, "struct.error.__module__ == 'struct' — defined in the struct module"]
    - [error_qualname,   error.__qualname__.__eq__,        ["error"],     true, "struct.error.__qualname__ == 'error' — top-level class; qualname equals simple name"]
    - [error_base_name,  "error.__bases__[0].__name__.__eq__", ["Exception"], true, "struct.error.__bases__[0].__name__ == 'Exception' — directly inherits from Exception"]
    - [error_class_name, error.__class__.__name__.__eq__,  ["type"],      true, "struct.error.__class__.__name__ == 'type' — struct.error is a class (metaclass is type)"]

# ---------------------------------------------------------------------------
# struct.pack raises struct.error for invalid arguments
# struct.pack('!I', -1) — unsigned int cannot hold negative values.
# struct.pack('b', 200) — signed byte max is 127; 200 overflows.
# ---------------------------------------------------------------------------

invariant struct_extra263.pack_negative_uint_raises:
  description: "struct.pack('!I', -1) raises struct.error — unsigned 32-bit integer format '!I' cannot represent negative values; struct.error is raised; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: errors
  kind: python_call_raises
  function: pack
  args: ["!I", -1]
  raises: error

invariant struct_extra263.pack_signed_byte_overflow_raises:
  description: "struct.pack('b', 200) raises struct.error — signed byte format 'b' accepts -128..127 only; value 200 overflows; struct.error is raised; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: errors
  kind: python_call_raises
  function: pack
  args: ["b", 200]
  raises: error

# ---------------------------------------------------------------------------
# struct.unpack raises struct.error for too-short buffer
# struct.unpack('!I', b'abc') — '!I' needs 4 bytes; b'abc' is only 3.
# ---------------------------------------------------------------------------

invariant struct_extra263.unpack_short_buffer_raises:
  description: "struct.unpack('!I', b'abc') raises struct.error — format '!I' requires exactly 4 bytes; b'abc' is only 3 bytes; unpack raises struct.error; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: errors
  kind: python_call_raises
  function: unpack
  args: ["!I", "b'abc'"]
  raises: error

# ---------------------------------------------------------------------------
# struct.error identity as subclass of Exception
# struct.error.__bases__[0] is Exception (C-level inheritance check).
# ---------------------------------------------------------------------------

invariant struct_extra263.error_base_module_eq:
  description: "struct.error.__bases__[0].__module__ == 'builtins' — Exception is defined in the builtins module; struct.error inherits directly from it; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: error.__bases__[0].__module__.__eq__
  args: ["builtins"]
  expected: true

invariant struct_extra263.error_name_len_eq:
  description: "struct.error.__name__.__len__() == 5 — 'error' has 5 characters; confirms the lowercase exception class name; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: error.__name__.__len__
  args: []
  expected: 5
