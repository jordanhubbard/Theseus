spec: io_extra119
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec extends io_extra118.zspec.zsdl."
    - "This spec covers: io abstract base class MRO slot names for RawIOBase, BufferedIOBase, and TextIOBase."
    - "RawIOBase.__mro__ has 5 entries: RawIOBase, _RawIOBase, IOBase, _IOBase, object."
    - "BufferedIOBase.__mro__ has 5 entries: BufferedIOBase, _BufferedIOBase, IOBase, _IOBase, object."
    - "TextIOBase.__mro__ has 5 entries: TextIOBase, _TextIOBase, IOBase, _IOBase, object."
    - "All three abstract bases share the same MRO pattern: Python ABC -> C type -> Python ABC -> C type -> object."
    - "MRO[0] is the Python ABC itself; MRO[1] is the corresponding C implementation type (prefixed with underscore)."
    - "MRO[2] is always IOBase (the root Python ABC); MRO[3] is _IOBase (the C root); MRO[4] is object."
    - "RawIOBase.__bases__[0].__name__ == '_RawIOBase' (len 10); BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' (len 15); TextIOBase.__bases__[0].__name__ == '_TextIOBase' (len 11)."
    - "All three abstract bases are of type ABCMeta (metaclass); all have __module__ == 'io'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.RawIOBase MRO slot names (5-level chain)
# RawIOBase.__mro__[0]='RawIOBase', [1]='_RawIOBase', [2]='IOBase',
# [3]='_IOBase', [4]='object'.
# The two-level Python/C alternating pattern exposes both the public ABC
# and its underlying C implementation type at each layer of the hierarchy.
# ---------------------------------------------------------------------------

table io_extra119.RawIOBase_mro_slot_names:
  description: "io.RawIOBase MRO slot names: [0]='RawIOBase', [1]='_RawIOBase', [2]='IOBase', [3]='_IOBase', [4]='object'; 5-level alternating Python-ABC and C-type chain"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: iomro119a

  columns: [id, function, args, expected, description]
  rows:
    - [raw_mro0_name,  "RawIOBase.__mro__[0].__name__.__eq__",  ["RawIOBase"],    true,  "io.RawIOBase.__mro__[0].__name__ == 'RawIOBase' (the abstract base class itself is first in its own MRO)"]
    - [raw_mro1_name,  "RawIOBase.__mro__[1].__name__.__eq__",  ["_RawIOBase"],   true,  "io.RawIOBase.__mro__[1].__name__ == '_RawIOBase' (C implementation type; underscore prefix marks it as private)"]
    - [raw_mro2_name,  "RawIOBase.__mro__[2].__name__.__eq__",  ["IOBase"],       true,  "io.RawIOBase.__mro__[2].__name__ == 'IOBase' (root Python ABC shared by all io abstract base classes)"]
    - [raw_mro3_name,  "RawIOBase.__mro__[3].__name__.__eq__",  ["_IOBase"],      true,  "io.RawIOBase.__mro__[3].__name__ == '_IOBase' (root C implementation type; the C counterpart to IOBase)"]
    - [raw_mro4_name,  "RawIOBase.__mro__[4].__name__.__eq__",  ["object"],       true,  "io.RawIOBase.__mro__[4].__name__ == 'object' (universal Python base class; all types ultimately inherit from object)"]
    - [raw_mro1_ne_0,  "RawIOBase.__mro__[1].__name__.__eq__",  ["RawIOBase"],    false, "io.RawIOBase.__mro__[1].__name__ != 'RawIOBase' (MRO[1] is the C type '_RawIOBase', not the Python ABC 'RawIOBase')"]
    - [raw_mro2_ne_io, "RawIOBase.__mro__[2].__name__.__eq__",  ["_IOBase"],      false, "io.RawIOBase.__mro__[2].__name__ != '_IOBase' (MRO[2] is the Python ABC 'IOBase'; the C type '_IOBase' is one step deeper at MRO[3])"]

# ---------------------------------------------------------------------------
# io.BufferedIOBase and io.TextIOBase MRO slot names
# Both follow the same 5-level pattern as RawIOBase.
# BufferedIOBase: [0]='BufferedIOBase', [1]='_BufferedIOBase', [2]='IOBase',
#   [3]='_IOBase', [4]='object'.
# TextIOBase: [0]='TextIOBase', [1]='_TextIOBase', [2]='IOBase',
#   [3]='_IOBase', [4]='object'.
# The MRO[2] entry ('IOBase') is shared across all three abstract bases.
# ---------------------------------------------------------------------------

table io_extra119.BufferedIOBase_TextIOBase_mro_slot_names:
  description: "io.BufferedIOBase MRO: [0]='BufferedIOBase',[1]='_BufferedIOBase',[2]='IOBase'; io.TextIOBase MRO: [0]='TextIOBase',[1]='_TextIOBase',[2]='IOBase'; both share IOBase at slot 2"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: iomro119b

  columns: [id, function, args, expected, description]
  rows:
    - [buf_mro0_name,   "BufferedIOBase.__mro__[0].__name__.__eq__",   ["BufferedIOBase"],    true,  "io.BufferedIOBase.__mro__[0].__name__ == 'BufferedIOBase' (Python ABC for buffered I/O first in its own MRO)"]
    - [buf_mro1_name,   "BufferedIOBase.__mro__[1].__name__.__eq__",   ["_BufferedIOBase"],   true,  "io.BufferedIOBase.__mro__[1].__name__ == '_BufferedIOBase' (C implementation type; private counterpart to BufferedIOBase)"]
    - [buf_mro2_name,   "BufferedIOBase.__mro__[2].__name__.__eq__",   ["IOBase"],            true,  "io.BufferedIOBase.__mro__[2].__name__ == 'IOBase' (shared root Python ABC; same at MRO[2] for all three abstract bases)"]
    - [buf_mro3_name,   "BufferedIOBase.__mro__[3].__name__.__eq__",   ["_IOBase"],           true,  "io.BufferedIOBase.__mro__[3].__name__ == '_IOBase' (shared root C type; same at MRO[3] for all three abstract bases)"]
    - [txt_mro0_name,   "TextIOBase.__mro__[0].__name__.__eq__",       ["TextIOBase"],        true,  "io.TextIOBase.__mro__[0].__name__ == 'TextIOBase' (Python ABC for text I/O first in its own MRO)"]
    - [txt_mro1_name,   "TextIOBase.__mro__[1].__name__.__eq__",       ["_TextIOBase"],       true,  "io.TextIOBase.__mro__[1].__name__ == '_TextIOBase' (C implementation type; private counterpart to TextIOBase)"]
    - [txt_mro2_name,   "TextIOBase.__mro__[2].__name__.__eq__",       ["IOBase"],            true,  "io.TextIOBase.__mro__[2].__name__ == 'IOBase' (same root Python ABC as BufferedIOBase and RawIOBase at MRO[2])"]
    - [txt_mro4_name,   "TextIOBase.__mro__[4].__name__.__eq__",       ["object"],            true,  "io.TextIOBase.__mro__[4].__name__ == 'object' (universal base at position 4 for all 5-level abstract base MROs)"]
    - [buf_raw_mro2_eq, "BufferedIOBase.__mro__[2].__name__.__eq__",   ["IOBase"],            true,  "io.BufferedIOBase.__mro__[2] is IOBase — the root Python ABC is shared at MRO slot 2 across all abstract bases"]

# ---------------------------------------------------------------------------
# io abstract base class __bases__[0].__name__ lengths
# Each abstract base has exactly one direct base: its corresponding C type.
# RawIOBase.__bases__[0].__name__ == '_RawIOBase' (len 10).
# BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' (len 15).
# TextIOBase.__bases__[0].__name__ == '_TextIOBase' (len 11).
# IOBase.__bases__[0].__name__ == '_IOBase' (len 7; shortest).
# The C type names all start with an underscore followed by the Python ABC name.
# ---------------------------------------------------------------------------

table io_extra119.abstract_base_C_type_name_lengths:
  description: "io abstract base __bases__[0].__name__ lengths: IOBase->_IOBase(7), RawIOBase->_RawIOBase(10), TextIOBase->_TextIOBase(11), BufferedIOBase->_BufferedIOBase(15)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: iomro119c

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_base_eq,   "IOBase.__bases__[0].__name__.__eq__",         ["_IOBase"],         true,  "io.IOBase.__bases__[0].__name__ == '_IOBase' (the single direct C base of the IOBase Python ABC)"]
    - [iobase_base_len,  "IOBase.__bases__[0].__name__.__len__",        [],                  7,     "io.IOBase.__bases__[0].__name__.__len__() == 7 ('_IOBase' has 7 chars; shortest C base name)"]
    - [rawbase_eq,       "RawIOBase.__bases__[0].__name__.__eq__",      ["_RawIOBase"],      true,  "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' (C implementation base for raw binary I/O)"]
    - [rawbase_len,      "RawIOBase.__bases__[0].__name__.__len__",     [],                  10,    "io.RawIOBase.__bases__[0].__name__.__len__() == 10 ('_RawIOBase' has 10 chars)"]
    - [txtbase_eq,       "TextIOBase.__bases__[0].__name__.__eq__",     ["_TextIOBase"],     true,  "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' (C implementation base for text I/O)"]
    - [txtbase_len,      "TextIOBase.__bases__[0].__name__.__len__",    [],                  11,    "io.TextIOBase.__bases__[0].__name__.__len__() == 11 ('_TextIOBase' has 11 chars)"]
    - [bufbase_eq,       "BufferedIOBase.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true,  "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' (C implementation base for buffered I/O)"]
    - [bufbase_len,      "BufferedIOBase.__bases__[0].__name__.__len__", [],                 15,    "io.BufferedIOBase.__bases__[0].__name__.__len__() == 15 ('_BufferedIOBase' has 15 chars; longest C base name)"]
    - [buf_gt_txt_base,  "BufferedIOBase.__bases__[0].__name__.__len__.__gt__", [11],        true,  "len('_BufferedIOBase') > len('_TextIOBase') (15 > 11; BufferedIOBase has the longest C type name)"]
    - [raw_gt_io_base,   "RawIOBase.__bases__[0].__name__.__len__.__gt__", [7],              true,  "len('_RawIOBase') > len('_IOBase') (10 > 7; _RawIOBase is three chars longer than _IOBase)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra119.RawIOBase.mro_slot1_is_CRawIOBase:
  description: "io.RawIOBase.__mro__[1].__name__ == '_RawIOBase' (the C implementation type sits at MRO slot 1, immediately after the Python ABC at slot 0; the underscore prefix is the CPython convention marking the type as a private C-level implementation detail; RawIOBase is the abstract base for all raw binary I/O streams that read/write without buffering; FileIO is the only concrete subclass in the standard library)"
  category: class_hierarchy
  kind: python_call_eq
  function: "RawIOBase.__mro__[1].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

invariant io_extra119.BufferedIOBase.mro_slot2_is_IOBase:
  description: "io.BufferedIOBase.__mro__[2].__name__ == 'IOBase' (the root Python abstract base class IOBase appears at MRO slot 2 for all three 5-level abstract base chains: RawIOBase, BufferedIOBase, and TextIOBase; this is because each chain is: [ABCClass, _ABCClass, IOBase, _IOBase, object]; slot 2 is always the shared root IOBase ABC)"
  category: class_hierarchy
  kind: python_call_eq
  function: "BufferedIOBase.__mro__[2].__name__.__eq__"
  args: ["IOBase"]
  expected: true

invariant io_extra119.TextIOBase.mro_slot1_is_CTextIOBase:
  description: "io.TextIOBase.__mro__[1].__name__ == '_TextIOBase' (C implementation type at slot 1; TextIOBase is the abstract base for all text-mode I/O streams; StringIO and TextIOWrapper are concrete subclasses; the C type '_TextIOBase' is defined in Modules/_io/textio.c and implements the abstract methods that TextIOBase declares)"
  category: class_hierarchy
  kind: python_call_eq
  function: "TextIOBase.__mro__[1].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra119.BufferedIOBase.bases0_len_15:
  description: "io.BufferedIOBase.__bases__[0].__name__.__len__() == 15 ('_BufferedIOBase' has 15 characters; it is the longest C implementation type name among the four io abstract bases: _IOBase(7) < _RawIOBase(10) < _TextIOBase(11) < _BufferedIOBase(15); BufferedIOBase is the abstract base for all buffered I/O streams including BytesIO, BufferedReader, BufferedWriter, BufferedRandom, and BufferedRWPair)"
  category: class_hierarchy
  kind: python_call_eq
  function: "BufferedIOBase.__bases__[0].__name__.__len__"
  args: []
  expected: 15

invariant io_extra119.IOBase.bases0_name_is_CIOBase:
  description: "io.IOBase.__bases__[0].__name__ == '_IOBase' (length 7; IOBase is a Python-level abstract base class defined in Lib/io.py that directly inherits from the C type '_IOBase' defined in Modules/_io/_iomodule.c; this dual-layer design lets IOBase declare abstract methods and register ABCs while _IOBase provides the optimized C implementations; the same layered pattern repeats for RawIOBase, BufferedIOBase, and TextIOBase)"
  category: class_hierarchy
  kind: python_call_eq
  function: "IOBase.__bases__[0].__name__.__eq__"
  args: ["_IOBase"]
  expected: true

