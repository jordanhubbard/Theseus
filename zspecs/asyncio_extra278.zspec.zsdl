spec: asyncio_extra278
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-protocol.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-protocol.html — Python asyncio protocol documentation"
    - "https://docs.python.org/3/library/asyncio-transport.html — Python asyncio transport documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/protocols.py"
    - "CPython source: Lib/asyncio/transports.py"
  notes:
    - "This spec covers: asyncio.SubprocessProtocol, asyncio.BufferedProtocol, and asyncio.WriteTransport class identity. NEW in extra278: asyncio.SubprocessProtocol.__name__=='SubprocessProtocol'; asyncio.SubprocessProtocol.__module__=='asyncio.protocols'; asyncio.SubprocessProtocol.__bases__[0].__name__=='BaseProtocol'; asyncio.SubprocessProtocol.__mro__.__len__()==3; SubprocessProtocol.pipe_data_received.__qualname__=='SubprocessProtocol.pipe_data_received' (len=37); SubprocessProtocol.pipe_connection_lost.__qualname__=='SubprocessProtocol.pipe_connection_lost' (len=39, longest); SubprocessProtocol.process_exited.__qualname__=='SubprocessProtocol.process_exited' (len=33); asyncio.BufferedProtocol.__name__=='BufferedProtocol'; asyncio.BufferedProtocol.__module__=='asyncio.protocols'; asyncio.BufferedProtocol.__bases__[0].__name__=='BaseProtocol'; asyncio.BufferedProtocol.__mro__.__len__()==3; BufferedProtocol.get_buffer.__qualname__=='BufferedProtocol.get_buffer' (len=27); BufferedProtocol.buffer_updated.__qualname__=='BufferedProtocol.buffer_updated' (len=31); asyncio.WriteTransport.__name__=='WriteTransport'; asyncio.WriteTransport.__module__=='asyncio.transports'; asyncio.WriteTransport.__bases__[0].__name__=='BaseTransport'; asyncio.WriteTransport.__mro__.__len__()==3; WriteTransport.get_write_buffer_limits.__qualname__=='WriteTransport.get_write_buffer_limits' (len=38, longest WriteTransport method qualname). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.SubprocessProtocol.__module__ == 'asyncio.protocols'. SubprocessProtocol is defined in Lib/asyncio/protocols.py alongside BaseProtocol, Protocol, DatagramProtocol, and BufferedProtocol; all five share __module__ 'asyncio.protocols'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "SubprocessProtocol.pipe_connection_lost.__qualname__ == 'SubprocessProtocol.pipe_connection_lost' (len=39). This is the longest protocol method qualname in this spec: 'SubprocessProtocol.'=19 + 'pipe_connection_lost'=20 = 39. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.WriteTransport.__module__ == 'asyncio.transports'. WriteTransport is defined in Lib/asyncio/transports.py, not protocols.py; its __module__ is 'asyncio.transports' (len=18: 'asyncio.'=8 + 'transports'=10). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.WriteTransport.__bases__[0].__name__ == 'BaseTransport'. WriteTransport inherits from BaseTransport; BaseTransport.__module__ is 'asyncio.transports' and BaseTransport.__mro__.__len__() is 2 ([BaseTransport, object]). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "WriteTransport.close.__qualname__ == 'BaseTransport.close'. close() is defined on BaseTransport and inherited by WriteTransport; its qualname reflects the defining class. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.SubprocessProtocol and asyncio.BufferedProtocol class identity — extra278
#
# asyncio.SubprocessProtocol.__name__                           == 'SubprocessProtocol'
# asyncio.SubprocessProtocol.__module__                         == 'asyncio.protocols'
# asyncio.SubprocessProtocol.__bases__[0].__name__              == 'BaseProtocol'
# asyncio.SubprocessProtocol.__mro__.__len__()                  == 3
# SubprocessProtocol.pipe_data_received.__qualname__            == 'SubprocessProtocol.pipe_data_received'  (len=37)
# SubprocessProtocol.pipe_connection_lost.__qualname__          == 'SubprocessProtocol.pipe_connection_lost' (len=39)
# SubprocessProtocol.process_exited.__qualname__                == 'SubprocessProtocol.process_exited'      (len=33)
# asyncio.BufferedProtocol.__name__                             == 'BufferedProtocol'
# asyncio.BufferedProtocol.__module__                           == 'asyncio.protocols'
# asyncio.BufferedProtocol.__bases__[0].__name__                == 'BaseProtocol'
# asyncio.BufferedProtocol.__mro__.__len__()                    == 3
# BufferedProtocol.get_buffer.__qualname__                      == 'BufferedProtocol.get_buffer'   (len=27)
# BufferedProtocol.buffer_updated.__qualname__                  == 'BufferedProtocol.buffer_updated' (len=31)
# ---------------------------------------------------------------------------

table asyncio_extra278.asyncio_subprocess_buffered_protocol_identity:
  description: "asyncio.SubprocessProtocol and asyncio.BufferedProtocol class identity checks in asyncioprotident278 namespace — SubprocessProtocol is defined in Lib/asyncio/protocols.py alongside BaseProtocol, Protocol, DatagramProtocol, and BufferedProtocol; SubprocessProtocol.__name__.__eq__('SubprocessProtocol')==True; SubprocessProtocol.__module__.__eq__('asyncio.protocols')==True; SubprocessProtocol.__bases__[0].__name__.__eq__('BaseProtocol')==True (SubprocessProtocol inherits from BaseProtocol as sole direct base); SubprocessProtocol.__mro__.__len__()==3 ([SubprocessProtocol, BaseProtocol, object]); SubprocessProtocol.pipe_data_received.__qualname__.__eq__('SubprocessProtocol.pipe_data_received')==True (len=37: 'SubprocessProtocol.'=19+'pipe_data_received'=18); SubprocessProtocol.pipe_connection_lost.__qualname__.__eq__('SubprocessProtocol.pipe_connection_lost')==True (len=39: 'SubprocessProtocol.'=19+'pipe_connection_lost'=20, longest qualname in spec); SubprocessProtocol.process_exited.__qualname__.__eq__('SubprocessProtocol.process_exited')==True (len=33: 'SubprocessProtocol.'=19+'process_exited'=14); SubprocessProtocol.connection_made is inherited from BaseProtocol; BufferedProtocol.__name__.__eq__('BufferedProtocol')==True; BufferedProtocol.__module__.__eq__('asyncio.protocols')==True (same module); BufferedProtocol.__bases__[0].__name__.__eq__('BaseProtocol')==True; BufferedProtocol.__mro__.__len__()==3; BufferedProtocol.get_buffer.__qualname__.__eq__('BufferedProtocol.get_buffer')==True (len=27); BufferedProtocol.buffer_updated.__qualname__.__eq__('BufferedProtocol.buffer_updated')==True (len=31); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioprotident278

  columns: [id, function, args, expected, description]
  rows:
    - [sp_name_eq,      asyncio.SubprocessProtocol.__name__.__eq__,                             ["SubprocessProtocol"],                       true, "asyncio.SubprocessProtocol.__name__ == 'SubprocessProtocol'; verified with Python 3.14.3"]
    - [sp_module_eq,    asyncio.SubprocessProtocol.__module__.__eq__,                           ["asyncio.protocols"],                         true, "asyncio.SubprocessProtocol.__module__ == 'asyncio.protocols'; verified with Python 3.14.3"]
    - [sp_base0_eq,     "asyncio.SubprocessProtocol.__bases__[0].__name__.__eq__",              ["BaseProtocol"],                              true, "asyncio.SubprocessProtocol.__bases__[0].__name__ == 'BaseProtocol'; verified with Python 3.14.3"]
    - [sp_mro_len,      asyncio.SubprocessProtocol.__mro__.__len__,                             [],                                            3,    "asyncio.SubprocessProtocol.__mro__.__len__() == 3 — [SubprocessProtocol, BaseProtocol, object]; verified with Python 3.14.3"]
    - [sp_pdr_qn_eq,    asyncio.SubprocessProtocol.pipe_data_received.__qualname__.__eq__,      ["SubprocessProtocol.pipe_data_received"],      true, "SubprocessProtocol.pipe_data_received.__qualname__ == 'SubprocessProtocol.pipe_data_received' (len=37); verified with Python 3.14.3"]
    - [sp_pdr_qn_len,   asyncio.SubprocessProtocol.pipe_data_received.__qualname__.__len__,     [],                                            37,   "SubprocessProtocol.pipe_data_received.__qualname__.__len__() == 37 ('SubprocessProtocol.'=19+'pipe_data_received'=18); verified with Python 3.14.3"]
    - [sp_pcl_qn_eq,    asyncio.SubprocessProtocol.pipe_connection_lost.__qualname__.__eq__,    ["SubprocessProtocol.pipe_connection_lost"],    true, "SubprocessProtocol.pipe_connection_lost.__qualname__ == 'SubprocessProtocol.pipe_connection_lost' (len=39, longest); verified with Python 3.14.3"]
    - [sp_pcl_qn_len,   asyncio.SubprocessProtocol.pipe_connection_lost.__qualname__.__len__,   [],                                            39,   "SubprocessProtocol.pipe_connection_lost.__qualname__.__len__() == 39 (longest in spec); verified with Python 3.14.3"]
    - [sp_pe_qn_eq,     asyncio.SubprocessProtocol.process_exited.__qualname__.__eq__,          ["SubprocessProtocol.process_exited"],          true, "SubprocessProtocol.process_exited.__qualname__ == 'SubprocessProtocol.process_exited' (len=33); verified with Python 3.14.3"]
    - [bp_name_eq,      asyncio.BufferedProtocol.__name__.__eq__,                               ["BufferedProtocol"],                          true, "asyncio.BufferedProtocol.__name__ == 'BufferedProtocol'; verified with Python 3.14.3"]
    - [bp_module_eq,    asyncio.BufferedProtocol.__module__.__eq__,                             ["asyncio.protocols"],                         true, "asyncio.BufferedProtocol.__module__ == 'asyncio.protocols' (same as SubprocessProtocol); verified with Python 3.14.3"]
    - [bp_base0_eq,     "asyncio.BufferedProtocol.__bases__[0].__name__.__eq__",                ["BaseProtocol"],                              true, "asyncio.BufferedProtocol.__bases__[0].__name__ == 'BaseProtocol'; verified with Python 3.14.3"]
    - [bp_mro_len,      asyncio.BufferedProtocol.__mro__.__len__,                               [],                                            3,    "asyncio.BufferedProtocol.__mro__.__len__() == 3 — [BufferedProtocol, BaseProtocol, object]; verified with Python 3.14.3"]
    - [bp_gb_qn_eq,     asyncio.BufferedProtocol.get_buffer.__qualname__.__eq__,                ["BufferedProtocol.get_buffer"],                true, "BufferedProtocol.get_buffer.__qualname__ == 'BufferedProtocol.get_buffer' (len=27); verified with Python 3.14.3"]
    - [bp_bu_qn_eq,     asyncio.BufferedProtocol.buffer_updated.__qualname__.__eq__,            ["BufferedProtocol.buffer_updated"],            true, "BufferedProtocol.buffer_updated.__qualname__ == 'BufferedProtocol.buffer_updated' (len=31); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.WriteTransport class identity — extra278
#
# asyncio.WriteTransport.__name__                               == 'WriteTransport'
# asyncio.WriteTransport.__module__                             == 'asyncio.transports'
# asyncio.WriteTransport.__bases__[0].__name__                  == 'BaseTransport'
# asyncio.WriteTransport.__mro__.__len__()                      == 3
# WriteTransport.write.__qualname__                             == 'WriteTransport.write'              (len=20)
# WriteTransport.write_eof.__qualname__                         == 'WriteTransport.write_eof'          (len=24)
# WriteTransport.can_write_eof.__qualname__                     == 'WriteTransport.can_write_eof'      (len=28)
# WriteTransport.get_write_buffer_size.__qualname__             == 'WriteTransport.get_write_buffer_size'   (len=36)
# WriteTransport.get_write_buffer_limits.__qualname__           == 'WriteTransport.get_write_buffer_limits' (len=38)
# WriteTransport.close.__qualname__                             == 'BaseTransport.close'  (inherited)
# ---------------------------------------------------------------------------

table asyncio_extra278.asyncio_write_transport_identity:
  description: "asyncio.WriteTransport class identity checks in asyncioprotident278a namespace — WriteTransport is defined in Lib/asyncio/transports.py (distinct from protocols.py); WriteTransport.__module__.__eq__('asyncio.transports')==True (len=18: 'asyncio.'=8+'transports'=10); WriteTransport.__name__.__eq__('WriteTransport')==True; WriteTransport.__bases__[0].__name__.__eq__('BaseTransport')==True (WriteTransport inherits from BaseTransport as sole direct base); WriteTransport.__mro__.__len__()==3 ([WriteTransport, BaseTransport, object]); WriteTransport.write.__qualname__.__eq__('WriteTransport.write')==True (len=20, own method); WriteTransport.write_eof.__qualname__.__eq__('WriteTransport.write_eof')==True (len=24, own method); WriteTransport.can_write_eof.__qualname__.__eq__('WriteTransport.can_write_eof')==True (len=28, own method); WriteTransport.get_write_buffer_size.__qualname__.__eq__('WriteTransport.get_write_buffer_size')==True (len=36, own method); WriteTransport.get_write_buffer_limits.__qualname__.__eq__('WriteTransport.get_write_buffer_limits')==True (len=38, longest WriteTransport method qualname in spec); WriteTransport.close.__qualname__.__eq__('BaseTransport.close')==True (inherited from BaseTransport); BaseTransport.__module__ is 'asyncio.transports'; BaseTransport.__mro__.__len__() is 2 ([BaseTransport, object]); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioprotident278a

  columns: [id, function, args, expected, description]
  rows:
    - [wt_name_eq,      asyncio.WriteTransport.__name__.__eq__,                              ["WriteTransport"],                          true, "asyncio.WriteTransport.__name__ == 'WriteTransport'; verified with Python 3.14.3"]
    - [wt_module_eq,    asyncio.WriteTransport.__module__.__eq__,                            ["asyncio.transports"],                      true, "asyncio.WriteTransport.__module__ == 'asyncio.transports' (len=18); verified with Python 3.14.3"]
    - [wt_base0_eq,     "asyncio.WriteTransport.__bases__[0].__name__.__eq__",               ["BaseTransport"],                           true, "asyncio.WriteTransport.__bases__[0].__name__ == 'BaseTransport'; verified with Python 3.14.3"]
    - [wt_mro_len,      asyncio.WriteTransport.__mro__.__len__,                              [],                                          3,    "asyncio.WriteTransport.__mro__.__len__() == 3 — [WriteTransport, BaseTransport, object]; verified with Python 3.14.3"]
    - [wt_write_qn_eq,  asyncio.WriteTransport.write.__qualname__.__eq__,                   ["WriteTransport.write"],                     true, "WriteTransport.write.__qualname__ == 'WriteTransport.write' (len=20, own method); verified with Python 3.14.3"]
    - [wt_weof_qn_eq,   asyncio.WriteTransport.write_eof.__qualname__.__eq__,               ["WriteTransport.write_eof"],                 true, "WriteTransport.write_eof.__qualname__ == 'WriteTransport.write_eof' (len=24, own method); verified with Python 3.14.3"]
    - [wt_cwe_qn_eq,    asyncio.WriteTransport.can_write_eof.__qualname__.__eq__,           ["WriteTransport.can_write_eof"],             true, "WriteTransport.can_write_eof.__qualname__ == 'WriteTransport.can_write_eof' (len=28, own method); verified with Python 3.14.3"]
    - [wt_gwbs_qn_eq,   asyncio.WriteTransport.get_write_buffer_size.__qualname__.__eq__,   ["WriteTransport.get_write_buffer_size"],     true, "WriteTransport.get_write_buffer_size.__qualname__ == 'WriteTransport.get_write_buffer_size' (len=36); verified with Python 3.14.3"]
    - [wt_gwbl_qn_eq,   asyncio.WriteTransport.get_write_buffer_limits.__qualname__.__eq__, ["WriteTransport.get_write_buffer_limits"],   true, "WriteTransport.get_write_buffer_limits.__qualname__ == 'WriteTransport.get_write_buffer_limits' (len=38, longest); verified with Python 3.14.3"]
    - [wt_gwbl_qn_len,  asyncio.WriteTransport.get_write_buffer_limits.__qualname__.__len__, [],                                          38,   "WriteTransport.get_write_buffer_limits.__qualname__.__len__() == 38 ('WriteTransport.'=15+'get_write_buffer_limits'=23); verified with Python 3.14.3"]
    - [wt_close_qn_eq,  asyncio.WriteTransport.close.__qualname__.__eq__,                   ["BaseTransport.close"],                      true, "WriteTransport.close.__qualname__ == 'BaseTransport.close' (inherited from BaseTransport, qualname reflects defining class); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra278
# ---------------------------------------------------------------------------

invariant asyncio_extra278.SubprocessProtocol_module_is_asyncio_protocols:
  description: "asyncio.SubprocessProtocol.__module__.__eq__('asyncio.protocols') returns True — asyncio.SubprocessProtocol is defined in Lib/asyncio/protocols.py alongside BaseProtocol, Protocol, DatagramProtocol, and BufferedProtocol; all five protocol classes share __module__ 'asyncio.protocols' (len=17: 'asyncio.'=8+'protocols'=9); SubprocessProtocol inherits from BaseProtocol as its sole direct base giving MRO [SubprocessProtocol, BaseProtocol, object] (length=3); SubprocessProtocol is used for subprocess communication via asyncio.create_subprocess_exec() and asyncio.create_subprocess_shell(); it adds pipe_data_received, pipe_connection_lost, and process_exited methods on top of BaseProtocol's connection_made/connection_lost; NEW in extra278: first standalone SubprocessProtocol.__module__ invariant in asyncioprotident278 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.SubprocessProtocol.__module__.__eq__
  args: ["asyncio.protocols"]
  expected: true

invariant asyncio_extra278.SubprocessProtocol_pipe_connection_lost_qualname_len_39:
  description: "asyncio.SubprocessProtocol.pipe_connection_lost.__qualname__.__len__() == 39 — SubprocessProtocol.pipe_connection_lost.__qualname__ is 'SubprocessProtocol.pipe_connection_lost' (39 chars: 'SubprocessProtocol.'=19 + 'pipe_connection_lost'=20); this is the longest protocol method qualname in this spec; compare qualname lengths in this spec: SubprocessProtocol.process_exited=33, SubprocessProtocol.pipe_data_received=37, SubprocessProtocol.pipe_connection_lost=39 (longest); the prefix 'SubprocessProtocol.'=19 chars is shared by all three own methods; connection_made is inherited from BaseProtocol so its qualname is 'BaseProtocol.connection_made' (shorter); NEW in extra278: first standalone pipe_connection_lost qualname length invariant in asyncioprotident278 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.SubprocessProtocol.pipe_connection_lost.__qualname__.__len__
  args: []
  expected: 39

invariant asyncio_extra278.BufferedProtocol_base_is_BaseProtocol:
  description: "asyncio.BufferedProtocol.__bases__[0].__name__.__eq__('BaseProtocol') returns True — asyncio.BufferedProtocol inherits from asyncio.BaseProtocol as its sole direct base, parallel to Protocol, DatagramProtocol, and SubprocessProtocol; BufferedProtocol's MRO is [BufferedProtocol, BaseProtocol, object] (length=3); BufferedProtocol is used for zero-copy receive with buffer re-use; it adds get_buffer() and buffer_updated() methods; BufferedProtocol.__module__ is 'asyncio.protocols'; BufferedProtocol.get_buffer.__qualname__ is 'BufferedProtocol.get_buffer' (len=27: 'BufferedProtocol.'=17+'get_buffer'=10); BufferedProtocol.buffer_updated.__qualname__ is 'BufferedProtocol.buffer_updated' (len=31: 'BufferedProtocol.'=17+'buffer_updated'=14); NEW in extra278: first standalone BufferedProtocol base class invariant in asyncioprotident278 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "asyncio.BufferedProtocol.__bases__[0].__name__.__eq__"
  args: ["BaseProtocol"]
  expected: true

invariant asyncio_extra278.WriteTransport_module_is_asyncio_transports:
  description: "asyncio.WriteTransport.__module__.__eq__('asyncio.transports') returns True — asyncio.WriteTransport is defined in Lib/asyncio/transports.py, a separate module from protocols.py; WriteTransport.__module__ is 'asyncio.transports' (len=18: 'asyncio.'=8+'transports'=10); WriteTransport inherits from BaseTransport (also in asyncio.transports) giving MRO [WriteTransport, BaseTransport, object] (length=3); BaseTransport.__module__ is 'asyncio.transports'; BaseTransport.__mro__.__len__() is 2 ([BaseTransport, object]); close() is inherited from BaseTransport (qualname 'BaseTransport.close'), while write, write_eof, can_write_eof, set_write_buffer_limits, get_write_buffer_size, and get_write_buffer_limits are own WriteTransport methods; NEW in extra278: first standalone WriteTransport.__module__ invariant in asyncioprotident278 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.WriteTransport.__module__.__eq__
  args: ["asyncio.transports"]
  expected: true

invariant asyncio_extra278.WriteTransport_get_write_buffer_limits_qualname_len_38:
  description: "asyncio.WriteTransport.get_write_buffer_limits.__qualname__.__len__() == 38 — WriteTransport.get_write_buffer_limits.__qualname__ is 'WriteTransport.get_write_buffer_limits' (38 chars: 'WriteTransport.'=15+'get_write_buffer_limits'=23); this is the longest WriteTransport method qualname in this spec; compare: WriteTransport.write=20, WriteTransport.write_eof=24, WriteTransport.can_write_eof=28, WriteTransport.get_write_buffer_size=36, WriteTransport.get_write_buffer_limits=38 (longest); get_write_buffer_limits returns (low, high) buffer watermarks as a 2-tuple; the 'get_write_buffer_' prefix is shared by both get_write_buffer_size (len=36) and get_write_buffer_limits (len=38); NEW in extra278: first standalone get_write_buffer_limits qualname length invariant in asyncioprotident278 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.WriteTransport.get_write_buffer_limits.__qualname__.__len__
  args: []
  expected: 38

invariant asyncio_extra278.WriteTransport_close_qualname_is_BaseTransport_close:
  description: "asyncio.WriteTransport.close.__qualname__.__eq__('BaseTransport.close') returns True — close() is defined on BaseTransport and inherited by WriteTransport (and ReadTransport, Transport); the qualname 'BaseTransport.close' reflects the defining class, not the class it is accessed from; this parallels asyncio.Protocol.connection_made.__qualname__ == 'BaseProtocol.connection_made' (also inherited); WriteTransport.close.__qualname__ is 'BaseTransport.close' (len=19: 'BaseTransport.'=14+'close'=5); WriteTransport defines its own methods write, write_eof, can_write_eof, set_write_buffer_limits, get_write_buffer_size, get_write_buffer_limits; it inherits close, set_protocol, get_protocol, is_closing, get_extra_info from BaseTransport; NEW in extra278: first standalone WriteTransport.close qualname invariant in asyncioprotident278 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.WriteTransport.close.__qualname__.__eq__
  args: ["BaseTransport.close"]
  expected: true
