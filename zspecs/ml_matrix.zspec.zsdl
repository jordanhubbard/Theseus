spec: ml_matrix
version: ">=6.0.0"
backend: node(ml-matrix)

docs: https://mljs.github.io/matrix/

provenance:
  derived_from:
    - "ml-matrix documentation — https://mljs.github.io/matrix/"
    - "Test vectors verified with ml-matrix via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "ml-matrix source"
  notes:
    - "ml-matrix is the matrix-arithmetic core of mljs (the JS machine-learning ecosystem)."
    - "Install: npm install ml-matrix"
    - "Pattern: const {Matrix} = require('ml-matrix'); new Matrix([[a,b],[c,d]]).method()"
    - "Static helpers (determinant, inverse) live as named exports off the module rather than as instance methods."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; throws on size mismatches."
  stderr: "null"
  stickiness: "N/A — Matrix instances are values."
  codes: {}

# Properties on a 2x2
invariant ml_matrix.shape_rows:
  description: "2x2 matrix has 2 rows"
  category: shape
  kind: node_chain_eq
  entry: constructor
  class: Matrix
  entry_args: [[[1, 2], [3, 4]]]
  chain:
    - {get: rows}
  expected: 2

invariant ml_matrix.shape_columns:
  description: "2x2 matrix has 2 columns"
  category: shape
  kind: node_chain_eq
  entry: constructor
  class: Matrix
  entry_args: [[[1, 2], [3, 4]]]
  chain:
    - {get: columns}
  expected: 2

invariant ml_matrix.sum:
  description: "Sum of all entries in [[1,2],[3,4]] is 10"
  category: aggregation
  kind: node_chain_eq
  entry: constructor
  class: Matrix
  entry_args: [[[1, 2], [3, 4]]]
  chain:
    - {method: sum, args: []}
  expected: 10

invariant ml_matrix.trace:
  description: "Trace of [[1,2],[3,4]] is 5 (diagonal sum)"
  category: aggregation
  kind: node_chain_eq
  entry: constructor
  class: Matrix
  entry_args: [[[1, 2], [3, 4]]]
  chain:
    - {method: trace, args: []}
  expected: 5

invariant ml_matrix.max:
  description: "Max entry of [[1,2],[3,4]] is 4"
  category: aggregation
  kind: node_chain_eq
  entry: constructor
  class: Matrix
  entry_args: [[[1, 2], [3, 4]]]
  chain:
    - {method: max, args: []}
  expected: 4

invariant ml_matrix.min:
  description: "Min entry of [[1,2],[3,4]] is 1"
  category: aggregation
  kind: node_chain_eq
  entry: constructor
  class: Matrix
  entry_args: [[[1, 2], [3, 4]]]
  chain:
    - {method: min, args: []}
  expected: 1

# Element access
invariant ml_matrix.get_element:
  description: ".get(0,1) returns the entry at row 0 column 1"
  category: access
  kind: node_chain_eq
  entry: constructor
  class: Matrix
  entry_args: [[[1, 2], [3, 4]]]
  chain:
    - {method: get, args: [0, 1]}
  expected: 2

# Determinant via static
invariant ml_matrix.determinant_2x2:
  description: "determinant([[1,2],[3,4]]) = 1*4 - 2*3 = -2"
  category: linear_algebra
  kind: node_chain_eq
  entry: named
  function: determinant
  entry_args: [[[1, 2], [3, 4]]]
  chain: []
  expected: -2

# Multiply [[1,2],[3,4]] by itself
invariant ml_matrix.mmul_self:
  description: "[[1,2],[3,4]] * [[1,2],[3,4]] = [[7,10],[15,22]]"
  category: linear_algebra
  kind: node_chain_eq
  entry: constructor
  class: Matrix
  entry_args: [[[1, 2], [3, 4]]]
  chain:
    - {method: mmul, args: [[[1, 2], [3, 4]]]}
    - {method: to2DArray, args: []}
  expected: [[7, 10], [15, 22]]

# Identity matrix
invariant ml_matrix.identity_3x3:
  description: "Matrix.eye(3) is the 3x3 identity"
  category: factories
  kind: node_chain_eq
  entry: named
  function: Matrix.eye
  entry_args: [3]
  chain:
    - {method: to2DArray, args: []}
  expected: [[1, 0, 0], [0, 1, 0], [0, 0, 1]]
