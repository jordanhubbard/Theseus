spec: socket_extra2761
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra276.zspec.zsdl — covers socket.socket I/O method __qualname__ and __name__ values; method_descriptor class identity."
    - "socket_extra275.zspec.zsdl — covers __module__ attribute for pure-Python socket functions; has_dualstack_ipv6/__name__; IPPROTO_ICMP value."
    - "socket_extra270.zspec.zsdl — covers socket.socket __init__/__repr__/__str__ method identity; socket.timeout/error identity; family/type property descriptors."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "socket.socket.__dict__.__contains__('__matmul__') == False — socket.socket is a network I/O type; it defines no matrix multiplication operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.socket.__dict__.__contains__('__truediv__') == False — socket.socket defines no true division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.socket.__dict__.__contains__('__iadd__') == False — socket.socket defines no in-place addition operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__matmul__') == False — AddressFamily is an IntEnum subclass; it does not add matrix multiplication to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__truediv__') == False — AddressFamily does not add true division to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__iadd__') == False — AddressFamily does not add in-place addition to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__matmul__') == False — SocketKind is an IntEnum subclass; it does not add matrix multiplication to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__truediv__') == False — SocketKind does not add true division to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__iadd__') == False — SocketKind does not add in-place addition to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket.socket.__dict__ — __matmul__, __truediv__, __iadd__ absence
# socket.socket is the main socket class; it wraps a file descriptor and
# provides network I/O methods (connect, bind, send, recv, etc.). It defines
# no arithmetic or matrix operators.
# ---------------------------------------------------------------------------

table socket_extra2761.socket_dict_matmul_truediv_iadd:
  description: "socket.socket.__dict__ does not contain __matmul__, __truediv__, or __iadd__ — socket.socket is a network I/O type with no arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2761

  columns: [id, function, args, expected]
  rows:
    - ["sk2761-sock-matmul",  socket.socket.__dict__.__contains__,  ["__matmul__"],  false]
    - ["sk2761-sock-truediv", socket.socket.__dict__.__contains__,  ["__truediv__"], false]
    - ["sk2761-sock-iadd",    socket.socket.__dict__.__contains__,  ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Table 2: socket.AddressFamily.__dict__ — __matmul__, __truediv__, __iadd__ absence
# AddressFamily is an IntEnum subclass (AF_INET=2, AF_INET6=10, AF_UNIX=1, etc.).
# It inherits integer arithmetic from int/IntEnum but does not add new operators
# to its own __dict__ (checked with 'in AddressFamily.__dict__', not MRO lookup).
# ---------------------------------------------------------------------------

table socket_extra2761.addressfamily_dict_matmul_truediv_iadd:
  description: "socket.AddressFamily.__dict__ does not contain __matmul__, __truediv__, or __iadd__ — AddressFamily (IntEnum subclass) adds no new arithmetic operators to its own __dict__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2761

  columns: [id, function, args, expected]
  rows:
    - ["sk2761-af-matmul",  socket.AddressFamily.__dict__.__contains__,  ["__matmul__"],  false]
    - ["sk2761-af-truediv", socket.AddressFamily.__dict__.__contains__,  ["__truediv__"], false]
    - ["sk2761-af-iadd",    socket.AddressFamily.__dict__.__contains__,  ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Table 3: socket.SocketKind.__dict__ — __matmul__, __truediv__, __iadd__ absence
# SocketKind is an IntEnum subclass (SOCK_STREAM=1, SOCK_DGRAM=2, etc.).
# Like AddressFamily, it does not add arithmetic operators to its own __dict__.
# ---------------------------------------------------------------------------

table socket_extra2761.socketkind_dict_matmul_truediv_iadd:
  description: "socket.SocketKind.__dict__ does not contain __matmul__, __truediv__, or __iadd__ — SocketKind (IntEnum subclass) adds no new arithmetic operators to its own __dict__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2761

  columns: [id, function, args, expected]
  rows:
    - ["sk2761-sk-matmul",  socket.SocketKind.__dict__.__contains__,  ["__matmul__"],  false]
    - ["sk2761-sk-truediv", socket.SocketKind.__dict__.__contains__,  ["__truediv__"], false]
    - ["sk2761-sk-iadd",    socket.SocketKind.__dict__.__contains__,  ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — socket, AddressFamily, SocketKind all absent
# ---------------------------------------------------------------------------

table socket_extra2761.all_types_all_dunders_absent:
  description: "socket.socket, socket.AddressFamily, and socket.SocketKind all lack __matmul__, __truediv__, and __iadd__ in __dict__ — no socket type defines these arithmetic or matrix operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2761

  columns: [id, function, args, expected]
  rows:
    - ["sk2761-x-sock-matmul",  socket.socket.__dict__.__contains__,       ["__matmul__"],  false]
    - ["sk2761-x-sock-truediv", socket.socket.__dict__.__contains__,       ["__truediv__"], false]
    - ["sk2761-x-sock-iadd",    socket.socket.__dict__.__contains__,       ["__iadd__"],    false]
    - ["sk2761-x-af-matmul",    socket.AddressFamily.__dict__.__contains__, ["__matmul__"],  false]
    - ["sk2761-x-af-truediv",   socket.AddressFamily.__dict__.__contains__, ["__truediv__"], false]
    - ["sk2761-x-af-iadd",      socket.AddressFamily.__dict__.__contains__, ["__iadd__"],    false]
    - ["sk2761-x-sk-matmul",    socket.SocketKind.__dict__.__contains__,   ["__matmul__"],  false]
    - ["sk2761-x-sk-truediv",   socket.SocketKind.__dict__.__contains__,   ["__truediv__"], false]
    - ["sk2761-x-sk-iadd",      socket.SocketKind.__dict__.__contains__,   ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra2761.socket_no_matmul:
  description: "socket.socket.__dict__.__contains__('__matmul__') == False — socket.socket is a network I/O object; it defines no @ operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: socket.socket.__dict__.__contains__
  args: ["__matmul__"]
  expected: false

invariant socket_extra2761.socket_no_truediv:
  description: "socket.socket.__dict__.__contains__('__truediv__') == False — socket.socket defines no / operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: socket.socket.__dict__.__contains__
  args: ["__truediv__"]
  expected: false

invariant socket_extra2761.socket_no_iadd:
  description: "socket.socket.__dict__.__contains__('__iadd__') == False — socket.socket defines no += operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: socket.socket.__dict__.__contains__
  args: ["__iadd__"]
  expected: false

