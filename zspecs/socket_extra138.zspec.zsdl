spec: socket_extra138
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra99.zspec.zsdl — covers socket.gethostname/gethostbyname/getaddrinfo/setdefaulttimeout/getdefaulttimeout __qualname__.__len__() / SocketIO class identity (ABCMeta metaclass, socket module, RawIOBase base, qualname len 8) (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout __class__.__name__=='builtin_function_or_method' / getaddrinfo/create_connection Python function."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra99."
    - "Wave 286 theme: socket.socket class __doc__ identity / socket.__spec__ and __loader__ attribute identity / socket.herror and socket.gaierror exception class identity / socket.getfqdn and socket.create_connection qualnames."
    - "socket.socket.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__doc__.__len__() == 58. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__doc__ == 'A subclass of _socket.socket adding the makefile() method.'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getdefaulttimeout.__qualname__ == 'getdefaulttimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0 (extra94 anchors this; confirmed not re-anchored here)."
    - "socket.getdefaulttimeout.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0 (extra96 anchors this)."
    - "socket.setdefaulttimeout.__qualname__ == 'setdefaulttimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0 (extra94 anchors this)."
    - "socket.setdefaulttimeout.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0 (extra96 anchors this)."
    - "socket.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__spec__.name.__eq__('socket') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__spec__.name.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__spec__.origin.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__loader__.__class__.__name__ == 'SourceFileLoader'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__name__ == 'herror'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__bases__[0].__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__name__ == 'gaierror'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__bases__[0].__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__qualname__ == 'getfqdn'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__qualname__ == 'create_connection'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket.__doc__ explicitly states it is a Python subclass of _socket.socket; this is the Python-level class in Lib/socket.py that adds makefile()."
    - "Note: socket.herror and socket.gaierror both inherit from OSError and are defined in Lib/socket.py (not in socketmodule.c); their __module__ is 'socket'."
    - "Note: socket.getfqdn and socket.create_connection are pure-Python functions (class 'function'), whereas gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout are C builtins (class 'builtin_function_or_method')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__doc__.__class__.__name__.__eq__('str')
# socket.socket.__doc__.__len__()==58
# socket.socket.__doc__.__eq__('A subclass of _socket.socket adding the makefile() method.')
#
# Wave 286 theme: socket.socket class __doc__ identity and content.
#
# socket.socket is the Python-level socket class in Lib/socket.py, which subclasses
# _socket.socket (the C-level class from socketmodule.c). Its __doc__ is a str
# of 58 chars explicitly describing its relationship to _socket.socket. No prior
# socket spec anchors socket.socket.__doc__ content under sockdoc138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra138.socket_class_doc:
  description: "socket.socket/__doc__/__class__.__name__.__eq__('str')==True / socket.socket/__doc__/__len__()==58 / socket.socket/__doc__.__eq__('A subclass of _socket.socket adding the makefile() method.')==True — socket.socket is the Python-level socket class (Lib/socket.py); its __doc__ (58 chars) explicitly describes its relation to _socket.socket; no prior socket spec anchors socket.socket __doc__ content; first sockdoc138 anchor"
  kind: python_call_eq
  category: doc_identity
  id_prefix: sockdoc138

  columns: [id, function, args, expected, description]
  rows:
    - [socket_doc_class, "socket.__doc__.__class__.__name__.__eq__", ["str"],                                                           true, "socket.socket.__doc__ is a str (Python-level class docstring from Lib/socket.py)"]
    - [socket_doc_len,   "socket.__doc__.__len__",                   [],                                                                58,   "socket.socket.__doc__.__len__() is 58 chars"]
    - [socket_doc_eq,    "socket.__doc__.__eq__",                    ["A subclass of _socket.socket adding the makefile() method."],    true, "socket.socket.__doc__ is 'A subclass of _socket.socket adding the makefile() method.' (58 chars)"]

# ---------------------------------------------------------------------------
# socket.__spec__.__class__.__name__.__eq__('ModuleSpec')
# socket.__spec__.name.__eq__('socket')
# socket.__spec__.name.__len__()==6
# socket.__spec__.origin.__class__.__name__.__eq__('str')
# socket.__loader__.__class__.__name__.__eq__('SourceFileLoader')
#
# Wave 286 theme: socket.__spec__ and __loader__ attribute identity.
#
# socket.__spec__ is a ModuleSpec. Its name is 'socket' (6 chars). Its origin
# is a str path to Lib/socket.py. The loader is SourceFileLoader because socket
# is a pure-Python module file (Lib/socket.py) — the C-level socket code lives
# in _socket (a separate C extension). No prior socket spec anchors these
# __spec__/__loader__ values under sockdoc138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra138.spec_and_loader_identity:
  description: "socket.__spec__/__class__.__name__.__eq__('ModuleSpec')==True / __spec__.name.__eq__('socket')==True / __spec__.name.__len__()==6 / __spec__.origin/__class__.__name__.__eq__('str')==True / __loader__/__class__.__name__.__eq__('SourceFileLoader')==True — socket.__spec__ is a ModuleSpec; name is 'socket' (6 chars); origin is str path to Lib/socket.py; loader is SourceFileLoader (socket.py is Python-level module); no prior socket spec anchors these; first sockdoc138 anchor for spec/loader values"
  kind: python_call_eq
  category: module_spec
  id_prefix: sockdoc138

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name,        __spec__.__class__.__name__.__eq__,        ["ModuleSpec"],        true, "socket.__spec__ is a ModuleSpec (importlib.machinery.ModuleSpec)"]
    - [spec_name_eq,           __spec__.name.__eq__,                      ["socket"],            true, "socket.__spec__.name is 'socket' (matches socket.__name__)"]
    - [spec_name_len,          __spec__.name.__len__,                     [],                    6,    "socket.__spec__.name.__len__() is 6 ('socket' = 6 chars)"]
    - [spec_origin_class_name, __spec__.origin.__class__.__name__.__eq__, ["str"],               true, "socket.__spec__.origin is a str (path to Lib/socket.py)"]
    - [loader_class_name,      __loader__.__class__.__name__.__eq__,      ["SourceFileLoader"],  true, "socket.__loader__ is a SourceFileLoader (socket.py is a Python module; C code is in _socket)"]

# ---------------------------------------------------------------------------
# socket.herror.__name__.__eq__('herror')
# socket.herror.__bases__[0].__name__.__eq__('OSError')
# socket.herror.__module__.__eq__('socket')
# socket.gaierror.__name__.__eq__('gaierror')
# socket.gaierror.__bases__[0].__name__.__eq__('OSError')
# socket.gaierror.__module__.__eq__('socket')
#
# Wave 286 theme: socket exception class identity.
#
# socket.herror and socket.gaierror are both exception classes defined in
# Lib/socket.py. Both inherit from OSError. Both have __module__ == 'socket'.
# herror is raised for address-related errors (host not found), gaierror for
# getaddrinfo/getnameinfo failures. No prior socket spec anchors herror or
# gaierror class attributes under sockdoc138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra138.exception_class_identity:
  description: "socket.herror/__name__.__eq__('herror')==True / herror/__bases__[0]/__name__.__eq__('OSError')==True / herror/__module__.__eq__('socket')==True / gaierror/__name__.__eq__('gaierror')==True / gaierror/__bases__[0]/__name__.__eq__('OSError')==True / gaierror/__module__.__eq__('socket')==True — herror and gaierror are OSError subclasses defined in Lib/socket.py; herror for host address errors; gaierror for getaddrinfo/getnameinfo failures; no prior socket spec anchors these; first sockdoc138 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockdoc138

  columns: [id, function, args, expected, description]
  rows:
    - [herror_name,       herror.__name__.__eq__,                ["herror"],   true, "socket.herror.__name__ is 'herror' (host address error)"]
    - [herror_base_name,  "herror.__bases__[0].__name__.__eq__", ["OSError"],  true, "socket.herror.__bases__[0] is OSError (herror is an OSError subclass)"]
    - [herror_module,     herror.__module__.__eq__,              ["socket"],   true, "socket.herror.__module__ is 'socket' (defined in Lib/socket.py)"]
    - [gaierror_name,     gaierror.__name__.__eq__,              ["gaierror"], true, "socket.gaierror.__name__ is 'gaierror' (getaddrinfo/getnameinfo error)"]
    - [gaierror_base,     "gaierror.__bases__[0].__name__.__eq__", ["OSError"], true, "socket.gaierror.__bases__[0] is OSError (gaierror is an OSError subclass)"]
    - [gaierror_module,   gaierror.__module__.__eq__,            ["socket"],   true, "socket.gaierror.__module__ is 'socket' (defined in Lib/socket.py)"]

# ---------------------------------------------------------------------------
# socket.socket.__doc__.__len__()==58 — standalone
#
# socket.socket.__doc__.__len__() is 58. The docstring 'A subclass of
# _socket.socket adding the makefile() method.' is terse but informative:
# it states the inheritance relationship and the key addition (makefile).
# At 58 chars it is short compared to module-level function docstrings. No prior
# socket spec anchors socket.socket.__doc__.__len__() as a standalone under
# sockdoc138. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra138.socket_doc_len_58:
  description: "socket.socket.__doc__.__len__() == 58 — the Python-level socket class docstring is 58 chars ('A subclass of _socket.socket adding the makefile() method.'); terse but describes both the inheritance and the key addition; no prior socket spec anchors this as a standalone; first standalone under sockdoc138"
  category: doc_lengths
  kind: python_call_eq
  function: "socket.__doc__.__len__"
  args: []
  expected: 58

# ---------------------------------------------------------------------------
# socket.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# socket.__spec__.__class__.__name__ is 'ModuleSpec'. socket is a Python-level
# module (Lib/socket.py) loaded by SourceFileLoader; the C-level socket
# functionality is in _socket (a separate C extension with its own ModuleSpec
# and ExtensionFileLoader). socket's ModuleSpec captures origin (Lib/socket.py),
# name ('socket'), and no submodule_search_locations. No prior socket spec
# anchors __spec__.__class__.__name__ as a standalone under sockdoc138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra138.spec_class_ModuleSpec:
  description: "socket.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — socket.py is loaded via SourceFileLoader from Lib/socket.py; C-level socket code is in _socket (separate C extension with its own spec); no prior socket spec anchors this as a standalone; first standalone for __spec__.__class__.__name__ under sockdoc138"
  category: module_spec
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# socket.herror.__name__.__eq__('herror') — standalone
#
# socket.herror.__name__ is 'herror'. socket.herror is an exception class for
# host address errors (originally raised by gethostbyname-style functions).
# It inherits from OSError and is defined in Lib/socket.py. The __name__
# attribute of a class is its simple (unqualified) name. No prior socket spec
# anchors socket.herror.__name__ as a standalone under sockdoc138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra138.herror_name_eq:
  description: "socket.herror.__name__.__eq__('herror') == True — socket.herror is the host address error exception (for gethostbyname-style failures); inherits from OSError; defined in Lib/socket.py; no prior socket spec anchors herror.__name__ as a standalone; first standalone under sockdoc138"
  category: type_identity
  kind: python_call_eq
  function: herror.__name__.__eq__
  args: ["herror"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gaierror.__name__.__eq__('gaierror') — standalone
#
# socket.gaierror.__name__ is 'gaierror'. socket.gaierror is the exception
# raised by getaddrinfo() and getnameinfo() when they fail. The name 'gaierror'
# is an abbreviation of 'getaddrinfo error'. Like herror, it inherits from OSError
# and is defined in Lib/socket.py with __module__ == 'socket'. No prior socket
# spec anchors socket.gaierror.__name__ as a standalone under sockdoc138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra138.gaierror_name_eq:
  description: "socket.gaierror.__name__.__eq__('gaierror') == True — gaierror (getaddrinfo error) is raised by getaddrinfo() and getnameinfo() failures; inherits from OSError; defined in Lib/socket.py; no prior socket spec anchors gaierror.__name__ as a standalone; first standalone under sockdoc138"
  category: type_identity
  kind: python_call_eq
  function: gaierror.__name__.__eq__
  args: ["gaierror"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# socket.__loader__.__class__.__name__ is 'SourceFileLoader'. Like struct, the
# top-level 'socket' module is a Python file (Lib/socket.py) despite having a C
# extension backend (_socket). The SourceFileLoader handles the Python-level module.
# No prior socket spec anchors __loader__.__class__.__name__.__eq__('SourceFileLoader')
# as a standalone under sockdoc138. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra138.loader_class_SourceFileLoader:
  description: "socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — the 'socket' module is Lib/socket.py loaded by SourceFileLoader; C socket code lives in _socket (ExtensionFileLoader); no prior socket spec anchors this as a standalone; first standalone under sockdoc138"
  category: module_spec
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

