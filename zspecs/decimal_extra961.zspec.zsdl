spec: decimal_extra961
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module function and context documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks decimal.getcontext, setcontext, localcontext qualnames, context singletons, and module identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra961.function_identity:
  description: "decimal module function __module__ and __qualname__ identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: dc961f
  columns: [id, function, args, expected]
  rows:
    - [dc961f001, decimal.getcontext.__module__.__eq__,     ["decimal"],          true]
    - [dc961f002, decimal.getcontext.__qualname__.__eq__,   ["getcontext"],       true]
    - [dc961f003, decimal.setcontext.__module__.__eq__,     ["decimal"],          true]
    - [dc961f004, decimal.setcontext.__qualname__.__eq__,   ["setcontext"],       true]
    - [dc961f005, decimal.localcontext.__module__.__eq__,   ["decimal"],          true]
    - [dc961f006, decimal.localcontext.__qualname__.__eq__, ["localcontext"],     true]
    - [dc961f007, decimal.getcontext.__name__.__eq__,       ["getcontext"],       true]
    - [dc961f008, decimal.setcontext.__name__.__eq__,       ["setcontext"],       true]
    - [dc961f009, decimal.localcontext.__name__.__eq__,     ["localcontext"],     true]

table decimal_extra961.context_singleton_identity:
  description: "decimal predefined context singletons are Context instances"
  kind: python_call_eq
  category: context_singleton_identity
  id_prefix: dc961s
  columns: [id, function, args, expected]
  rows:
    - [dc961s001, decimal.BasicContext.__class__.__name__.__eq__,    ["Context"], true]
    - [dc961s002, decimal.ExtendedContext.__class__.__name__.__eq__, ["Context"], true]
    - [dc961s003, decimal.DefaultContext.__class__.__name__.__eq__,  ["Context"], true]
    - [dc961s004, decimal.Context.__name__.__eq__,                   ["Context"], true]
    - [dc961s005, decimal.Context.__module__.__eq__,                 ["decimal"], true]
    - [dc961s006, decimal.Context.__qualname__.__eq__,               ["Context"], true]

table decimal_extra961.module_identity:
  description: "decimal module __name__ and __spec__.name identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: dc961m
  columns: [id, function, args, expected]
  rows:
    - [dc961m001, decimal.__name__.__eq__,      ["decimal"], true]
    - [dc961m002, decimal.__spec__.name.__eq__, ["decimal"], true]
    - [dc961m003, decimal.__package__.__eq__,   [""],        true]
