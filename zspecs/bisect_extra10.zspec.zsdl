spec: bisect_extra10
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec extends bisect.zspec.zsdl and prior extras through bisect_extra9.zspec.zsdl."
    - "bisect.zspec.zsdl covers: lo/hi args on [1,3,5,7,9] for bisect_left and bisect_right."
    - "bisect_extra through bisect_extra9: __name__/__module__/__qualname__ for all functions; behavioral on many distinct inputs."
    - "NOT yet covered: lo/hi args on a different list ([6,12,18,24,30]); bisect_right with lo only (hi defaults to len); bisect_left with hi only (lo defaults to 0); bisect on a list with duplicates and lo/hi to restrict the search range; insort_right __qualname__ as a standalone invariant in the extra10 namespace."
    - "bisect_left([6,12,18,24,30], 18, 0, 3) == 2 — search restricted to [6,12,18]; 18 at index 2."
    - "bisect_right([6,12,18,24,30], 18, 0, 3) == 3 — search restricted to [6,12,18]; 18 right point is 3."
    - "bisect_left([6,12,18,24,30], 18, 2) == 2 — lo=2, hi defaults to end; 18 at index 2."
    - "bisect_right([6,12,18,24,30], 18, 2) == 3 — lo=2, hi defaults to end; 18 right point is 3."
    - "bisect_left([6,12,18,24,30], 13, 0, 2) == 2 — search [6,12]; 13>12, insertion at end of subrange (index 2)."
    - "bisect_right([6,12,18,24,30], 11, 0, 2) == 1 — search [6,12]; 11 < 12, right insertion at index 1."
    - "bisect_left([6,12,18,18,24,30], 18, 1, 4) == 2 — subrange [12,18,18]; leftmost 18 is at index 2."
    - "bisect_right([6,12,18,18,24,30], 18, 1, 4) == 4 — subrange [12,18,18]; one past last 18 is index 4."
    - "insort_right.__qualname__ == 'insort_right' — standalone extra10 namespace invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# lo/hi subrange args — new list [6, 12, 18, 24, 30]
#
# bisect.zspec.zsdl covers lo/hi on [1,3,5,7,9] (three invariants).
# No prior spec tests lo/hi on any other list. This spec uses [6,12,18,24,30]
# (multiples of 6, distinct from all prior bisect inputs).
# The extra10 namespace provides new invariant IDs for these axes.
# ---------------------------------------------------------------------------

invariant bisect_extra10.bisect_left.sixes_lo_hi_present:
  description: "bisect_left([6,12,18,24,30], 18, 0, 3) == 2 — subrange [6,12,18]; 18 left point is 2"
  category: lo_hi
  kind: python_call_eq
  function: bisect_left
  args: [[6, 12, 18, 24, 30], 18, 0, 3]
  expected: 2

invariant bisect_extra10.bisect_right.sixes_lo_hi_present:
  description: "bisect_right([6,12,18,24,30], 18, 0, 3) == 3 — subrange [6,12,18]; 18 right point is 3"
  category: lo_hi
  kind: python_call_eq
  function: bisect_right
  args: [[6, 12, 18, 24, 30], 18, 0, 3]
  expected: 3

# ---------------------------------------------------------------------------
# lo without hi — hi defaults to len(a)
#
# No prior spec tests bisect with lo only (hi omitted). With lo=2 and no hi,
# the search covers a[2:end] = [18, 24, 30].
# bisect_left([6,12,18,24,30], 18, 2) searches [18,24,30]; 18 at index 2
# (full list index), left insertion point is 2.
# bisect_right([6,12,18,24,30], 18, 2) searches [18,24,30]; right point is 3.
# ---------------------------------------------------------------------------

invariant bisect_extra10.bisect_left.sixes_lo_only:
  description: "bisect_left([6,12,18,24,30], 18, 2) == 2 — lo=2, hi=end; 18 left point is 2"
  category: lo_hi
  kind: python_call_eq
  function: bisect_left
  args: [[6, 12, 18, 24, 30], 18, 2]
  expected: 2

invariant bisect_extra10.bisect_right.sixes_lo_only:
  description: "bisect_right([6,12,18,24,30], 18, 2) == 3 — lo=2, hi=end; 18 right point is 3"
  category: lo_hi
  kind: python_call_eq
  function: bisect_right
  args: [[6, 12, 18, 24, 30], 18, 2]
  expected: 3

# ---------------------------------------------------------------------------
# lo/hi restricts search to head of list — item absent from subrange
#
# bisect_left([6,12,18,24,30], 13, 0, 2) searches a[0:2]=[6,12]; 13>12,
# insertion at the end of the subrange, which is index 2 in the full list.
# bisect_right([6,12,18,24,30], 11, 0, 2) searches a[0:2]=[6,12]; 11<12,
# right insertion point is 1.
# ---------------------------------------------------------------------------

invariant bisect_extra10.bisect_left.sixes_lo_hi_gap_after:
  description: "bisect_left([6,12,18,24,30], 13, 0, 2) == 2 — subrange [6,12]; 13 after subrange end"
  category: lo_hi
  kind: python_call_eq
  function: bisect_left
  args: [[6, 12, 18, 24, 30], 13, 0, 2]
  expected: 2

invariant bisect_extra10.bisect_right.sixes_lo_hi_gap_before:
  description: "bisect_right([6,12,18,24,30], 11, 0, 2) == 1 — subrange [6,12]; 11 between 6 and 12"
  category: lo_hi
  kind: python_call_eq
  function: bisect_right
  args: [[6, 12, 18, 24, 30], 11, 0, 2]
  expected: 1

# ---------------------------------------------------------------------------
# lo/hi with duplicates — bisect_left vs bisect_right differ
#
# bisect.zspec.zsdl covers duplicates on [1,3,5,5,5,7] without lo/hi.
# This spec adds lo/hi on a list with duplicates: [6,12,18,18,24,30].
# Subrange a[1:4] = [12, 18, 18].
# bisect_left searches [12,18,18] for 18 → leftmost 18 is at full-list index 2.
# bisect_right searches [12,18,18] for 18 → one past last 18 is full-list index 4.
# ---------------------------------------------------------------------------

invariant bisect_extra10.bisect_left.duplicates_lo_hi_left:
  description: "bisect_left([6,12,18,18,24,30], 18, 1, 4) == 2 — subrange [12,18,18]; leftmost 18 at index 2"
  category: lo_hi_duplicates
  kind: python_call_eq
  function: bisect_left
  args: [[6, 12, 18, 18, 24, 30], 18, 1, 4]
  expected: 2

invariant bisect_extra10.bisect_right.duplicates_lo_hi_right:
  description: "bisect_right([6,12,18,18,24,30], 18, 1, 4) == 4 — subrange [12,18,18]; one past last 18 at index 4"
  category: lo_hi_duplicates
  kind: python_call_eq
  function: bisect_right
  args: [[6, 12, 18, 18, 24, 30], 18, 1, 4]
  expected: 4

# ---------------------------------------------------------------------------
# insort_right.__qualname__ — standalone extra10 namespace invariant
#
# bisect_extra5 covers insort_right.__qualname__ == 'insort_right' in a table
# (id_prefix qualname). bisect_extra7 adds a standalone invariant for
# insort_right.__qualname__ with the extra7 namespace anchor. This spec adds
# a standalone invariant in the extra10 namespace for completeness — a new
# distinct invariant ID that verifies the same invariant with an independent
# identity.
# ---------------------------------------------------------------------------

invariant bisect_extra10.insort_right.qualname:
  description: "bisect.insort_right.__qualname__ == 'insort_right' — standalone extra10 namespace"
  category: function_qualnames
  kind: python_call_eq
  function: insort_right.__qualname__.__eq__
  args: ["insort_right"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral invariants — [6, 12, 18, 24, 30] without subrange restrictions
#
# Full-list behavioral tests on the same [6,12,18,24,30] fixture used above.
# These complement the lo/hi tests and document the expected results for the
# full sorted list.
# ---------------------------------------------------------------------------

invariant bisect_extra10.bisect_left.sixes_gap:
  description: "bisect_left([6,12,18,24,30], 15) == 2 — 15 falls between 12 and 18; left point is 2"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[6, 12, 18, 24, 30], 15]
  expected: 2

invariant bisect_extra10.bisect_right.sixes_present_last:
  description: "bisect_right([6,12,18,24,30], 30) == 5 — 30 at index 4; right point is 5"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[6, 12, 18, 24, 30], 30]
  expected: 5
