spec: concurrent_futures_extra946
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes:
    - "Checks string sentinel constants and class name identity for concurrent.futures public API"
    - "FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED are str constants"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra946.string_constants:
  description: "concurrent.futures string sentinel constant __class__.__name__ identity"
  kind: python_call_eq
  category: constant_identity
  id_prefix: cf946sc
  columns: [id, function, args, expected]
  rows:
    - [cf946sc001, concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__,  ["str"], true]
    - [cf946sc002, concurrent.futures.FIRST_EXCEPTION.__class__.__name__.__eq__,  ["str"], true]
    - [cf946sc003, concurrent.futures.ALL_COMPLETED.__class__.__name__.__eq__,    ["str"], true]
    - [cf946sc004, concurrent.futures.FIRST_COMPLETED.__eq__,                     ["FIRST_COMPLETED"], true]
    - [cf946sc005, concurrent.futures.FIRST_EXCEPTION.__eq__,                     ["FIRST_EXCEPTION"], true]
    - [cf946sc006, concurrent.futures.ALL_COMPLETED.__eq__,                       ["ALL_COMPLETED"],   true]

table concurrent_futures_extra946.class_names:
  description: "concurrent.futures class __name__ identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: cf946cn
  columns: [id, function, args, expected]
  rows:
    - [cf946cn001, concurrent.futures.Future.__name__.__eq__,              ["Future"],              true]
    - [cf946cn002, concurrent.futures.ThreadPoolExecutor.__name__.__eq__,  ["ThreadPoolExecutor"],  true]
    - [cf946cn003, concurrent.futures.ProcessPoolExecutor.__name__.__eq__, ["ProcessPoolExecutor"], true]
    - [cf946cn004, concurrent.futures.Executor.__name__.__eq__,            ["Executor"],            true]
    - [cf946cn005, concurrent.futures.Future.__module__.__eq__,            ["concurrent.futures"],  true]
    - [cf946cn006, concurrent.futures.Executor.__module__.__eq__,          ["concurrent.futures"],  true]

table concurrent_futures_extra946.executor_qualnames:
  description: "concurrent.futures executor class __qualname__ identity"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: cf946qn
  columns: [id, function, args, expected]
  rows:
    - [cf946qn001, concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__,  ["ThreadPoolExecutor"],  true]
    - [cf946qn002, concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__, ["ProcessPoolExecutor"], true]
    - [cf946qn003, concurrent.futures.Executor.__qualname__.__eq__,            ["Executor"],            true]
    - [cf946qn004, concurrent.futures.Future.__qualname__.__eq__,              ["Future"],              true]
    - [cf946qn005, concurrent.futures.ThreadPoolExecutor.__class__.__name__.__eq__, ["type"],           true]
    - [cf946qn006, concurrent.futures.ProcessPoolExecutor.__class__.__name__.__eq__, ["type"],          true]
    - [cf946qn007, concurrent.futures.Future.__class__.__name__.__eq__,        ["type"],                true]
