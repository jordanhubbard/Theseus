spec: th3541
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 683 (th3541): __format__, __sizeof__, __dir__ dict-presence checks for threading types."
    - "All values false — threading types do not define __format__, __sizeof__, or __dir__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __format__ dict-presence — operator.contains(Cls.__dict__, '__format__')
# ---------------------------------------------------------------------------

table th3541.format:
  description: "threading types __format__ dict-presence checks; wave 683"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3541
  columns: [id, function, args, expected]
  rows:
    - ["th3541001", operator.contains, [threading.Thread.__dict__,           "__format__"], false]
    - ["th3541002", operator.contains, [threading.Event.__dict__,            "__format__"], false]
    - ["th3541003", operator.contains, [threading.Condition.__dict__,        "__format__"], false]
    - ["th3541004", operator.contains, [threading.Semaphore.__dict__,        "__format__"], false]
    - ["th3541005", operator.contains, [threading.BoundedSemaphore.__dict__, "__format__"], false]
    - ["th3541006", operator.contains, [threading.Timer.__dict__,            "__format__"], false]
    - ["th3541007", operator.contains, [threading.Barrier.__dict__,          "__format__"], false]
    - ["th3541008", operator.contains, [threading.local.__dict__,            "__format__"], false]
    - ["th3541009", operator.contains, [type(threading.Lock()).__dict__,     "__format__"], false]
    - ["th3541010", operator.contains, [type(threading.RLock()).__dict__,    "__format__"], false]

