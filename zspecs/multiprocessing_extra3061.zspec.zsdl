spec: mp3061
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 651 (mp3061): __aexit__, __await__, __anext__ dict-presence for multiprocessing types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: multiprocessing.Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.BaseListProxy, managers._BaseDictProxy, managers._BaseSetProxy."
    - "All eight classes return false for __aexit__, __await__, and __anext__ in their own __dict__."
    - "multiprocessing.pool.Pool defines synchronous __enter__/__exit__ (confirmed in wave 650) but has no async context manager (__aexit__) support."
    - "multiprocessing is a process-based synchronous concurrency library; it has no async protocol support in its class hierarchy."
    - "pool.AsyncResult ('async' in the name refers to non-blocking result retrieval, not asyncio) — it does not define __await__ or __anext__."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __aexit__ dict-presence — operator.contains(Cls.__dict__, '__aexit__')
#
# No multiprocessing class defines __aexit__ in its own __dict__; all false.
# pool.Pool defines synchronous __enter__/__exit__ (wave 650) but no __aexit__.
# multiprocessing has no async context manager support; all results are false.
# ---------------------------------------------------------------------------

table mp3061.aexit:
  description: "multiprocessing types __aexit__ dict-presence checks; wave 651"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3061

  columns: [id, function, args, expected]
  rows:
    - ["mp3061001", operator.contains, [multiprocessing.Process.__dict__,                 "__aexit__"], false]
    - ["mp3061002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__aexit__"], false]
    - ["mp3061003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__aexit__"], false]
    - ["mp3061004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__aexit__"], false]
    - ["mp3061005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__aexit__"], false]
    - ["mp3061006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__aexit__"], false]
    - ["mp3061007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__aexit__"], false]
    - ["mp3061008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__aexit__"], false]

# ---------------------------------------------------------------------------
# __await__ dict-presence — operator.contains(Cls.__dict__, '__await__')
#
# No multiprocessing class defines __await__ in its own __dict__; all false.
# pool.AsyncResult is named for non-blocking result polling, not asyncio awaiting —
# it does not define __await__ and is not directly awaitable.
# multiprocessing is entirely synchronous; no class implements the awaitable protocol.
# ---------------------------------------------------------------------------

table mp3061.await:
  description: "multiprocessing types __await__ dict-presence checks; wave 651"
  kind: python_call_eq
