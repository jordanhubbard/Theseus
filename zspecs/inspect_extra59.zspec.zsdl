spec: inspect_extra59
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra58.zspec.zsdl."
    - "Wave 225 theme: __loader__ identity checks + __spec__ attribute chains + module __file__ checks (None for C extensions, path strings for Python files) + __cached__ attribute presence."
    - "inspect is a pure-Python module (Lib/inspect.py). Its __loader__ is an instance of SourceFileLoader (from _frozen_importlib_external), so inspect.__loader__.__class__.__name__ == 'SourceFileLoader'. No prior inspect spec has a table row checking __loader__.__class__.__name__.__eq__('SourceFileLoader')."
    - "inspect.__spec__ is a ModuleSpec instance (from _frozen_importlib). inspect.__spec__.__class__.__name__ == 'ModuleSpec'. No prior inspect spec has a table row checking __spec__.__class__.__name__.__eq__('ModuleSpec')."
    - "inspect.__file__ is a str (the absolute filesystem path to inspect.py). For pure-Python stdlib modules, __file__ is always a str pointing to the .py source file. No prior inspect spec has a table row checking __file__.__class__.__name__.__eq__('str')."
    - "inspect.__cached__ is a str (the absolute filesystem path to the compiled .pyc bytecode file under __pycache__/). For pure-Python stdlib modules, __cached__ is always a str. No prior inspect spec has a table row checking __cached__.__class__.__name__.__eq__('str')."
    - "This spec covers: inspect.__loader__.__class__.__name__.__eq__('SourceFileLoader')==true; inspect.__spec__.__class__.__name__.__eq__('ModuleSpec')==true; inspect.__file__.__class__.__name__.__eq__('str')==true; inspect.__cached__.__class__.__name__.__eq__('str')==true."
    - "Key findings: inspect.__loader__ is a SourceFileLoader instance — the standard loader for pure-Python source files in CPython's importlib. inspect.__spec__ is a ModuleSpec instance with origin pointing to inspect.py. inspect.__file__ is a str path to inspect.py. inspect.__cached__ is a str path to inspect.cpython-<ver>.pyc in __pycache__/. All four attributes are consistent with pure-Python module identity. inspect is a large pure-Python module (107 public names in __all__, confirmed in extra57) but its loader/spec/file/cached attributes follow the same pattern as any other pure-Python stdlib module. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.__loader__ identity — extra59
#
# Wave 225 theme: __loader__ identity checks.
#
# inspect.__loader__ is an instance of SourceFileLoader from
# _frozen_importlib_external. SourceFileLoader is the standard loader that
# CPython's importlib uses for pure-Python source (.py) files. Since inspect
# is implemented as Lib/inspect.py (a .py source file), its __loader__ is a
# SourceFileLoader instance.
#
# The check: inspect.__loader__.__class__.__name__.__eq__('SourceFileLoader')
# — __loader__ is an object whose __class__ is SourceFileLoader, and
# SourceFileLoader.__name__ == 'SourceFileLoader' (17 chars).
#
# No prior inspect spec has a table row checking __loader__.__class__.__name__.__eq__('SourceFileLoader').
# New to extra59.
# ---------------------------------------------------------------------------

table inspect_extra59.loader_identity:
  description: "inspect.__loader__.__class__.__name__.__eq__('SourceFileLoader')==true — inspect is pure Python, loaded by SourceFileLoader (not BuiltinImporter or FrozenImporter); wave 225 __loader__ identity check; no prior inspect spec has table rows for __loader__; new to extra59"
  kind: python_call_eq
  category: class_identity
  id_prefix: inspload59

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_name_eq_SourceFileLoader,
       __loader__.__class__.__name__.__eq__,
       ["SourceFileLoader"],
       true,
       "inspect.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — inspect.__loader__ is an instance of _frozen_importlib_external.SourceFileLoader; SourceFileLoader is the standard CPython importlib loader for pure-Python source (.py) files; inspect is implemented in Lib/inspect.py — one of the largest stdlib modules at roughly 1700+ lines — and its __loader__ is a SourceFileLoader instance just like any other pure-Python module; __loader__.__class__.__name__ is 'SourceFileLoader' (17 chars); contrast with C built-in modules (itertools) where __loader__ is the BuiltinImporter class itself and __loader__.__class__.__name__ is 'type'; no prior inspect spec has a table row checking __loader__.__class__.__name__.__eq__('SourceFileLoader'); new to extra59"]

# ---------------------------------------------------------------------------
# inspect.__spec__ class identity — extra59
#
# Wave 225 theme: __spec__ attribute chains.
#
# inspect.__spec__ is a ModuleSpec instance from _frozen_importlib.
# Every importable Python module has a __spec__ attribute set to a ModuleSpec
# object by the import machinery (PEP 451). For inspect, __spec__.origin points
# to the inspect.py source file path on disk.
#
# The check: inspect.__spec__.__class__.__name__.__eq__('ModuleSpec')
# — __spec__ is a ModuleSpec object, and ModuleSpec.__name__ == 'ModuleSpec' (10 chars).
#
# No prior inspect spec has a table row checking __spec__.__class__.__name__.__eq__('ModuleSpec').
# New to extra59.
# ---------------------------------------------------------------------------

table inspect_extra59.spec_class_identity:
  description: "inspect.__spec__.__class__.__name__.__eq__('ModuleSpec')==true — module spec class is ModuleSpec from _frozen_importlib (PEP 451); origin points to inspect.py; wave 225 __spec__ attribute chain; no prior inspect spec has table rows for __spec__.__class__.__name__; new to extra59"
  kind: python_call_eq
  category: class_identity
  id_prefix: inspload59

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name_eq_ModuleSpec,
       __spec__.__class__.__name__.__eq__,
       ["ModuleSpec"],
       true,
       "inspect.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — inspect.__spec__ is an instance of _frozen_importlib.ModuleSpec; the ModuleSpec class was introduced in PEP 451 (Python 3.4) to provide a standardized specification object that the import machinery attaches to every imported module as its __spec__ attribute; ModuleSpec carries name, loader, origin (inspect.py filepath), submodule_search_locations, and other import metadata; for inspect, __spec__.origin is an absolute path to inspect.py; ModuleSpec.__name__ == 'ModuleSpec' (10 chars); this is consistent with functools, threading (pure-Python) and also with itertools (C builtin) — all have ModuleSpec as their __spec__ class; no prior inspect spec has a table row checking __spec__.__class__.__name__.__eq__('ModuleSpec'); new to extra59"]

# ---------------------------------------------------------------------------
# inspect.__file__ type check — extra59
#
# Wave 225 theme: module __file__ checks (path strings for Python files).
#
# inspect.__file__ is a str — the absolute filesystem path to inspect.py.
# For pure-Python stdlib modules, __file__ is always a str because the module
# is loaded from a .py source file on disk. The path is set by SourceFileLoader
# during the import process.
#
# Example: '/opt/homebrew/.../python3.14/lib/python3.14/inspect.py'
#
# Contrast with C builtin modules (like itertools): they have no __file__
# attribute at all (hasattr(itertools, '__file__') is False).
#
# The check: inspect.__file__.__class__.__name__.__eq__('str')
# — __file__ is a str object, and str.__name__ == 'str' (3 chars).
#
# No prior inspect spec has a table row checking __file__.__class__.__name__.__eq__('str').
# New to extra59.
# ---------------------------------------------------------------------------

table inspect_extra59.file_type_check:
  description: "inspect.__file__.__class__.__name__.__eq__('str')==true — inspect is pure Python so __file__ is a str path to inspect.py (not None and not missing); wave 225 __file__ check; no prior inspect spec has table rows for __file__.__class__.__name__; new to extra59"
  kind: python_call_eq
  category: class_identity
  id_prefix: inspload59

  columns: [id, function, args, expected, description]
  rows:
    - [file_class_name_eq_str,
       __file__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.__file__.__class__.__name__.__eq__('str') == True — inspect.__file__ is a Python str object containing the absolute filesystem path to the inspect.py source file (e.g., '/opt/homebrew/.../lib/python3.14/inspect.py'); for pure-Python stdlib modules, __file__ is always a str set by SourceFileLoader during import; inspect is a large stdlib module (Lib/inspect.py) that provides runtime type-checking and introspection utilities; the str type has __class__.__name__ == 'str' (3 chars); contrast with C builtin modules (itertools) which have no __file__ attribute at all; functools, inspect, and threading all have __file__ as a str; no prior inspect spec has a table row checking __file__.__class__.__name__.__eq__('str'); new to extra59"]

# ---------------------------------------------------------------------------
# inspect.__cached__ type check — extra59
#
# Wave 225 theme: __cached__ attribute presence.
#
# inspect.__cached__ is a str — the absolute filesystem path to the compiled
# bytecode cache file (.pyc) under __pycache__/. For pure-Python stdlib modules,
# __cached__ is always a str pointing to the .pyc file generated by compileall.
#
# Example: '/opt/homebrew/.../python3.14/lib/python3.14/__pycache__/inspect.cpython-314.pyc'
#
# Contrast with C builtin modules (like itertools): they have no __cached__
# attribute at all (hasattr(itertools, '__cached__') is False).
#
# The check: inspect.__cached__.__class__.__name__.__eq__('str')
# — __cached__ is a str object, and str.__name__ == 'str' (3 chars).
#
# No prior inspect spec has a table row checking __cached__.__class__.__name__.__eq__('str').
# New to extra59.
# ---------------------------------------------------------------------------

table inspect_extra59.cached_type_check:
  description: "inspect.__cached__.__class__.__name__.__eq__('str')==true — inspect is pure Python so __cached__ is a str path to the .pyc bytecode cache (not None and not missing); wave 225 __cached__ attribute check; no prior inspect spec has table rows for __cached__.__class__.__name__; new to extra59"
  kind: python_call_eq
  category: class_identity
  id_prefix: inspload59

  columns: [id, function, args, expected, description]
  rows:
    - [cached_class_name_eq_str,
       __cached__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.__cached__.__class__.__name__.__eq__('str') == True — inspect.__cached__ is a Python str object containing the absolute filesystem path to the compiled bytecode cache file for inspect (e.g., '/opt/homebrew/.../lib/python3.14/__pycache__/inspect.cpython-314.pyc'); for pure-Python stdlib modules, __cached__ is always a str set by the import machinery to the PEP 3147 bytecode cache path under __pycache__/; inspect.py is a large module that compiles to a correspondingly large .pyc file; the str type has __class__.__name__ == 'str' (3 chars); contrast with C builtin modules (itertools) which have no __cached__ attribute at all because they have no source file and hence no bytecode cache; functools, inspect, and threading all have __cached__ as a str; no prior inspect spec has a table row checking __cached__.__class__.__name__.__eq__('str'); new to extra59"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra59
# ---------------------------------------------------------------------------

invariant inspect_extra59.loader_is_SourceFileLoader:
  description: "inspect.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — inspect is pure Python, loaded by a SourceFileLoader instance; wave 225 __loader__ identity check; new to extra59"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant inspect_extra59.spec_is_ModuleSpec:
  description: "inspect.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — inspect.__spec__ is a ModuleSpec instance (PEP 451); holds for all importable stdlib modules; wave 225 __spec__ chain; new to extra59"
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant inspect_extra59.file_is_str:
  description: "inspect.__file__.__class__.__name__.__eq__('str') == True — __file__ is a str path for pure-Python modules; absent for C builtins; wave 225 __file__ check; new to extra59"
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant inspect_extra59.cached_is_str:
  description: "inspect.__cached__.__class__.__name__.__eq__('str') == True — __cached__ is a str path to .pyc bytecode for pure-Python modules; absent for C builtins; wave 225 __cached__ check; new to extra59"
  kind: python_call_eq
  function: __cached__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
