spec: functools_extra196
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.lru_cache.__name__ == 'lru_cache' (len=9); lru_cache is a Python function in the functools module; verified with Python 3.14.3."
    - "functools.lru_cache.__module__ == 'functools' (len=9); the lru_cache decorator is defined in the functools module; verified with Python 3.14.3."
    - "functools.lru_cache.__class__.__name__ == 'function'; lru_cache is a plain Python function (not a type or C builtin); verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache' (len=9); top-level function so __qualname__ equals __name__; verified with Python 3.14.3."
    - "functools.lru_cache.__doc__.__class__.__name__ == 'str'; the docstring is a plain Python str; verified with Python 3.14.3."
    - "functools._lru_cache_wrapper.__name__ == '_lru_cache_wrapper' (len=18); the underlying C extension type that wraps cached functions; verified with Python 3.14.3."
    - "functools._lru_cache_wrapper.__module__ == 'functools' (len=9); _lru_cache_wrapper is exposed via the functools module; verified with Python 3.14.3."
    - "functools._lru_cache_wrapper.__bases__[0].__name__ == 'object'; the C wrapper type inherits directly from object; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.lru_cache function identity — __name__, __module__, __class__
#
# functools.lru_cache.__name__          == 'lru_cache' (len=9)
# functools.lru_cache.__module__        == 'functools' (len=9)
# functools.lru_cache.__class__.__name__ == 'function'
#
# lru_cache is a Python-level decorator function (not a C type) defined in
# Lib/functools.py. Its __name__ and __module__ are both 9 characters.
# __class__.__name__ is 'function' distinguishing it from a builtin or type.
# New to extra196.
# ---------------------------------------------------------------------------

table functools_extra196.lru_cache_name_module_class:
  description: "functools.lru_cache identity: __name__=='lru_cache'(len=9); __module__=='functools'(len=9); __class__.__name__=='function'; new to extra196"
  kind: python_call_eq
  category: identity
  id_prefix: functlrucache196

  columns: [id, function, args, expected, description]
  rows:
    - [lrucache_name_eq,
       lru_cache.__name__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__name__.__eq__('lru_cache') == True — lru_cache is a Python-level decorator function; __name__ is 'lru_cache' (len=9: l-r-u-_-c-a-c-h-e); str.__eq__('lru_cache') returns True; verified with Python 3.14.3; new to extra196"]
    - [lrucache_name_len,
       lru_cache.__name__.__len__,
       [],
       9,
       "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters: l-r-u-_-c-a-c-h-e; str.__len__() returns 9; verified with Python 3.14.3; new to extra196"]
    - [lrucache_module_eq,
       lru_cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is defined in the functools module; __module__ is 'functools' (len=9: f-u-n-c-t-o-o-l-s); str.__eq__('functools') returns True; verified with Python 3.14.3; new to extra196"]
    - [lrucache_module_len,
       lru_cache.__module__.__len__,
       [],
       9,
       "functools.lru_cache.__module__.__len__() == 9 — 'functools' has 9 characters: f-u-n-c-t-o-o-l-s; str.__len__() returns 9; verified with Python 3.14.3; new to extra196"]
    - [lrucache_class_name_eq,
       lru_cache.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is a plain Python function (not a C builtin or type); __class__.__name__ is 'function'; str.__eq__('function') returns True; verified with Python 3.14.3; new to extra196"]

# ---------------------------------------------------------------------------
# Table 2: functools.lru_cache __qualname__ and __doc__ identity
#
# functools.lru_cache.__qualname__              == 'lru_cache' (len=9)
# functools.lru_cache.__doc__.__class__.__name__ == 'str'
#
# As a top-level function, __qualname__ equals __name__ ('lru_cache').
# The docstring is a plain Python str (not bytes or NoneType).
# New to extra196.
# ---------------------------------------------------------------------------

table functools_extra196.lru_cache_qualname_doc:
  description: "functools.lru_cache qualname and doc identity: __qualname__=='lru_cache'(len=9); __doc__.__class__.__name__=='str'; new to extra196"
  kind: python_call_eq
  category: identity
  id_prefix: functlrucache196

  columns: [id, function, args, expected, description]
  rows:
    - [lrucache_qualname_eq,
       lru_cache.__qualname__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — lru_cache is a top-level function so __qualname__ equals __name__; __qualname__ is 'lru_cache' (len=9); str.__eq__('lru_cache') returns True; verified with Python 3.14.3; new to extra196"]
    - [lrucache_qualname_len,
       lru_cache.__qualname__.__len__,
       [],
       9,
       "functools.lru_cache.__qualname__.__len__() == 9 — 'lru_cache' has 9 characters: l-r-u-_-c-a-c-h-e; __qualname__ equals __name__ for top-level functions; str.__len__() returns 9; verified with Python 3.14.3; new to extra196"]
    - [lrucache_doc_class_name,
       lru_cache.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.lru_cache.__doc__.__class__.__name__.__eq__('str') == True — the lru_cache docstring is a plain Python str object; __class__.__name__ is 'str'; str.__eq__('str') returns True; verified with Python 3.14.3; new to extra196"]

# ---------------------------------------------------------------------------
# Table 3: functools._lru_cache_wrapper C extension type identity
#
# functools._lru_cache_wrapper.__name__           == '_lru_cache_wrapper' (len=18)
# functools._lru_cache_wrapper.__module__         == 'functools' (len=9)
# functools._lru_cache_wrapper.__bases__[0].__name__ == 'object'
#
# _lru_cache_wrapper is the C extension type (from _functools.c) that wraps
# functions decorated by @lru_cache. It inherits directly from object.
# Its __name__ has 18 characters (underscore prefix + 'lru_cache_wrapper').
# New to extra196.
# ---------------------------------------------------------------------------

table functools_extra196.lru_cache_wrapper_identity:
  description: "functools._lru_cache_wrapper C extension type: __name__=='_lru_cache_wrapper'(len=18); __module__=='functools'(len=9); __bases__[0].__name__=='object'; new to extra196"
  kind: python_call_eq
  category: identity
  id_prefix: functlrucache196

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_name_eq,
       _lru_cache_wrapper.__name__.__eq__,
       ["_lru_cache_wrapper"],
       true,
       "functools._lru_cache_wrapper.__name__.__eq__('_lru_cache_wrapper') == True — _lru_cache_wrapper is the C extension type used internally by @lru_cache; __name__ is '_lru_cache_wrapper' (len=18: _+lru_cache_wrapper); str.__eq__('_lru_cache_wrapper') returns True; verified with Python 3.14.3; new to extra196"]
    - [wrapper_name_len,
       _lru_cache_wrapper.__name__.__len__,
       [],
       18,
       "functools._lru_cache_wrapper.__name__.__len__() == 18 — '_lru_cache_wrapper' has 18 characters: _-l-r-u-_-c-a-c-h-e-_-w-r-a-p-p-e-r; str.__len__() returns 18; verified with Python 3.14.3; new to extra196"]
    - [wrapper_module_eq,
       _lru_cache_wrapper.__module__.__eq__,
       ["functools"],
       true,
       "functools._lru_cache_wrapper.__module__.__eq__('functools') == True — _lru_cache_wrapper is exposed via the functools module; __module__ is 'functools' (len=9); str.__eq__('functools') returns True; verified with Python 3.14.3; new to extra196"]
    - [wrapper_bases_object,
       "_lru_cache_wrapper.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools._lru_cache_wrapper.__bases__[0].__name__.__eq__('object') == True — _lru_cache_wrapper is a C extension type that inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; verified with Python 3.14.3; new to extra196"]

