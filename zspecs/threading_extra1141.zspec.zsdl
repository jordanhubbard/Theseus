spec: threading_extra1141
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks TIMEOUT_MAX.__class__.__name__, Barrier/__doc__/__class__/__name__, Semaphore/__doc__/__class__.__name__, Timer/__doc__/__class__.__name__, Semaphore acquire/release qualnames, Thread.start/join qualnames — not covered in _extra1111/_extra1126"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1141.timeout_max_and_barrier_doc:
  description: "threading.TIMEOUT_MAX class identity and Barrier, Timer, Semaphore __doc__ class identity"
  kind: python_call_eq
  category: timeout_max_barrier_doc
  id_prefix: th1141tb
  columns: [id, function, args, expected]
  rows:
    - [th1141tb001, threading.TIMEOUT_MAX.__class__.__name__.__eq__,                 ["float"],                        true]
    - [th1141tb002, threading.Barrier.__doc__.__class__.__name__.__eq__,             ["str"],                          true]
    - [th1141tb003, threading.Semaphore.__doc__.__class__.__name__.__eq__,           ["str"],                          true]
    - [th1141tb004, threading.Timer.__doc__.__class__.__name__.__eq__,               ["str"],                          true]
    - [th1141tb005, threading.Barrier.__class__.__name__.__eq__,                     ["type"],                         true]
    - [th1141tb006, threading.Semaphore.__class__.__name__.__eq__,                   ["type"],                         true]
    - [th1141tb007, threading.Timer.__class__.__name__.__eq__,                       ["type"],                         true]
    - [th1141tb008, threading.Timer.__qualname__.__eq__,                             ["Timer"],                        true]

table threading_extra1141.semaphore_acquire_release_qualnames:
  description: "threading.Semaphore acquire and release method qualnames"
  kind: python_call_eq
  category: semaphore_acquire_release_qualnames
  id_prefix: th1141sa
  columns: [id, function, args, expected]
  rows:
    - [th1141sa001, threading.Semaphore.acquire.__qualname__.__eq__,                 ["Semaphore.acquire"],             true]
    - [th1141sa002, threading.Semaphore.release.__qualname__.__eq__,                 ["Semaphore.release"],             true]
    - [th1141sa003, threading.Semaphore.__enter__.__qualname__.__eq__,               ["Semaphore.__enter__"],           true]
    - [th1141sa004, threading.Semaphore.__exit__.__qualname__.__eq__,                ["Semaphore.__exit__"],            true]
    - [th1141sa005, threading.Semaphore.acquire.__class__.__name__.__eq__,           ["function"],                     true]
    - [th1141sa006, threading.Semaphore.release.__class__.__name__.__eq__,           ["function"],                     true]
    - [th1141sa007, threading.Semaphore.__qualname__.__eq__,                         ["Semaphore"],                    true]
    - [th1141sa008, threading.Semaphore.__module__.__eq__,                           ["threading"],                    true]

table threading_extra1141.thread_start_join_qualnames:
  description: "threading.Thread start and join method qualnames and Barrier abort qualname"
  kind: python_call_eq
  category: thread_start_join_qualnames
  id_prefix: th1141tj
  columns: [id, function, args, expected]
  rows:
    - [th1141tj001, threading.Thread.start.__qualname__.__eq__,                      ["Thread.start"],                  true]
    - [th1141tj002, threading.Thread.join.__qualname__.__eq__,                       ["Thread.join"],                   true]
    - [th1141tj003, threading.Thread.run.__qualname__.__eq__,                        ["Thread.run"],                    true]
    - [th1141tj004, threading.Thread.start.__class__.__name__.__eq__,                ["function"],                     true]
    - [th1141tj005, threading.Thread.join.__class__.__name__.__eq__,                 ["function"],                     true]
    - [th1141tj006, threading.Barrier.abort.__qualname__.__eq__,                     ["Barrier.abort"],                 true]
    - [th1141tj007, threading.Barrier.__module__.__eq__,                             ["threading"],                    true]
    - [th1141tj008, threading.Barrier.__qualname__.__eq__,                           ["Barrier"],                      true]
