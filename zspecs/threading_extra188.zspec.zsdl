       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — Event is defined in Lib/threading.py and reports __module__=='threading'; str.__eq__('threading') returns True; verified with Python 3.14.3; new to extra188"]
    - [event_qualname_eq,
       Event.__qualname__.__eq__,
       ["Event"],
       true,
       "threading.Event.__qualname__.__eq__('Event') == True — __qualname__ matches __name__ for a top-level class; str.__eq__('Event') returns True; verified with Python 3.14.3; new to extra188"]

