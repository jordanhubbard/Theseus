  notes:
    - "threading.Event.__name__ == 'Event' (len=5); __module__ == 'threading'; __qualname__ == 'Event'; __bases__[0].__name__ == 'object'; verified with Python 3.14.3."
    - "threading.BrokenBarrierError.__name__ == 'BrokenBarrierError' (len=18); __module__ == 'threading'; __qualname__ == 'BrokenBarrierError'; __bases__[0].__name__ == 'RuntimeError' (NOT 'Exception'); verified with Python 3.14.3."
    - "BrokenBarrierError inherits from RuntimeError (not Exception directly); RuntimeError itself inherits from Exception; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
