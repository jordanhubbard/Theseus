# ---------------------------------------------------------------------------
# Table 3: threading.BrokenBarrierError base class and qualname identity
#
# threading.BrokenBarrierError.__bases__[0].__name__ == 'RuntimeError'
# threading.BrokenBarrierError.__qualname__ == 'BrokenBarrierError'
#
# IMPORTANT: BrokenBarrierError inherits from RuntimeError (not Exception directly).
# RuntimeError is itself a subclass of Exception, but the immediate base is RuntimeError.
# Verified with Python 3.14.3 on macOS/Darwin 25.4.0. New to extra188.
# ---------------------------------------------------------------------------

table threading_extra188.brokenbarriererror_bases_and_qualname:
  description: "threading.BrokenBarrierError.__bases__[0].__name__=='RuntimeError' (NOT Exception); __qualname__=='BrokenBarrierError'; new to extra188"
