    - [event_name_eq,
       Event.__name__.__eq__,
       ["Event"],
       true,
       "threading.Event.__name__.__eq__('Event') == True — the class name is 'Event'; str.__eq__('Event') returns True; verified with Python 3.14.3; new to extra188"]
    - [event_name_len,
       Event.__name__.__len__,
       [],
       5,
       "threading.Event.__name__.__len__() == 5 — 'Event' has 5 characters: E-v-e-n-t; str.__len__() returns 5; verified with Python 3.14.3; new to extra188"]
    - [event_module_eq,
