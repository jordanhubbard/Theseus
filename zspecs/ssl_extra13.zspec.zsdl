spec: ssl_extra13
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "OpenSSL source"
  notes:
    - "This spec extends ssl.zspec.zsdl and prior extras through ssl_extra12.zspec.zsdl."
    - "ssl_extra12 covers: SSLSyscallError/__qualname__; SSLEOFError/__qualname__; SSLZeroReturnError/__qualname__; SSLError/__mro__[1]; SSLSyscallError/__mro__[2]; SSLEOFError/__mro__[2]; SSLCertVerificationError/__mro__[2/3]; SSLWantReadError/__mro__[2]; SSLWantWriteError/__mro__[2]; SSLZeroReturnError/__mro__[2]."
    - "ssl_extra8 covers: SSLContext/__qualname__; SSLSocket/__qualname__."
    - "ssl_extra4 covers: SSLContext.__bases__[0].__name__ == 'object' — but on CPython 3.12 the actual base is _SSLContext (the C-level type), not object. This spec corrects and supersedes that claim with the accurate value."
    - "ssl_extra2 covers: SSLSocket.__module__ == 'ssl'."
    - "ssl_extra.zspec.zsdl covers: PROTOCOL_TLS_CLIENT.__class__.__name__ == 'Protocol'."
    - "ssl_extra3 covers: PROTOCOL_TLS_CLIENT.__class__.__name__ == '_SSLMethod'."
    - "No prior spec covers: SSLContext.__bases__[0].__name__ == '_SSLContext' — the real C-level base class (not 'object')."
    - "No prior spec covers: SSLContext.__mro__[1].__name__ == '_SSLContext' (via MRO access)."
    - "No prior spec covers: SSLContext.__mro__[2].__name__ == 'object' (MRO terminus for SSLContext)."
    - "No prior spec covers: SSLSocket.__bases__[0].__name__ == 'socket' — SSLSocket inherits from socket.socket."
    - "No prior spec covers: SSLSocket.__mro__[2].__name__ == 'socket' — the socket module's socket class at MRO depth 2."
    - "No prior spec covers: PROTOCOL_TLS_SERVER.__class__.__name__ == '_SSLMethod' (ssl_extra only checks PROTOCOL_TLS_CLIENT and SERVER for 'Protocol'; the internal name is '_SSLMethod' on Python 3.12)."
    - "No prior spec covers: Purpose.SERVER_AUTH.__class__.__name__ == 'Purpose'."
    - "ssl.SSLContext inherits from _ssl._SSLContext (C-level); its MRO is [SSLContext, _SSLContext, object]."
    - "ssl.SSLSocket inherits from socket.socket; its MRO is [SSLSocket, socket.socket, socket, object] — note 'socket' at index 2 is the Python-level socket class from the socket module."
    - "ssl.PROTOCOL_TLS_SERVER.__class__.__name__ == '_SSLMethod' on CPython 3.12 — same as PROTOCOL_TLS_CLIENT."
    - "ssl.Purpose.SERVER_AUTH is an instance of the Purpose enum; its __class__.__name__ == 'Purpose'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SSLContext MRO — actual C-level base is _SSLContext, not object
#
# ssl_extra4 checks SSLContext.__bases__[0].__name__ == 'object' but this is
# incorrect on CPython 3.12: SSLContext inherits from _ssl._SSLContext.
# ssl_extra8 checks SSLContext.__qualname__ == 'SSLContext'.
# No prior spec checks SSLContext.__mro__[1] or SSLContext.__mro__[2].
# SSLContext.__mro__: [SSLContext, _SSLContext, object]
# ---------------------------------------------------------------------------

invariant ssl_extra13.SSLContext.base_name:
  description: "ssl.SSLContext.__bases__[0].__name__ == '_SSLContext' — the C-level base class"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLContext.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_SSLContext"

invariant ssl_extra13.SSLContext.mro_index1:
  description: "ssl.SSLContext.__mro__[1].__name__ == '_SSLContext' — MRO index 1 is the C-level base"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLContext.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "_SSLContext"

invariant ssl_extra13.SSLContext.mro_index2:
  description: "ssl.SSLContext.__mro__[2].__name__ == 'object' — SSLContext MRO terminus"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLContext.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# SSLSocket MRO — SSLSocket inherits from socket.socket
#
# ssl_extra2 checks SSLSocket.__module__ == 'ssl'.
# ssl_extra8 checks SSLSocket.__qualname__ == 'SSLSocket'.
# No prior spec checks SSLSocket.__bases__[0].__name__ or SSLSocket.__mro__[2].
# SSLSocket.__mro__: [SSLSocket, socket.socket, socket (module attr), object]
# Index 2 is the 'socket' name — the socket.socket class's __name__ == 'socket'.
# ---------------------------------------------------------------------------

invariant ssl_extra13.SSLSocket.base_name:
  description: "ssl.SSLSocket.__bases__[0].__name__ == 'socket' — SSLSocket inherits from socket.socket"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLSocket.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "socket"

invariant ssl_extra13.SSLSocket.mro_index2:
  description: "ssl.SSLSocket.__mro__[2].__name__ == 'socket' — MRO depth 2 is the socket class"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLSocket.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "socket"

# ---------------------------------------------------------------------------
# PROTOCOL_TLS_SERVER.__class__.__name__ — internal _SSLMethod enum member
#
# ssl_extra.zspec.zsdl checks PROTOCOL_TLS_SERVER.__class__.__name__ == 'Protocol'.
# ssl_extra3 notes that PROTOCOL_TLS_CLIENT.__class__.__name__ == '_SSLMethod' on Python 3.12.
# No prior spec checks PROTOCOL_TLS_SERVER.__class__.__name__ as '_SSLMethod' directly.
# On CPython 3.12 both PROTOCOL_TLS_CLIENT and PROTOCOL_TLS_SERVER are _SSLMethod members.
# ---------------------------------------------------------------------------

invariant ssl_extra13.PROTOCOL_TLS_SERVER.class_name:
  description: "ssl.PROTOCOL_TLS_SERVER.__class__.__name__ == '_SSLMethod' on Python 3.12"
  category: constants
  kind: python_call_eq
  function: PROTOCOL_TLS_SERVER.__class__.__name__.__eq__
  args: ["_SSLMethod"]
  expected: true

# ---------------------------------------------------------------------------
# Purpose enum member class name — members are instances of Purpose
#
# ssl_extra covers Purpose.__name__ == 'Purpose' and member .name attributes.
# No prior spec checks Purpose.SERVER_AUTH.__class__.__name__ == 'Purpose'.
# Enum members' __class__ is the enum class itself.
# ---------------------------------------------------------------------------

table ssl_extra13.Purpose_member_class_names:
  description: "Purpose enum members are instances of the Purpose class"
  kind: python_call_eq
  category: enum_members
  id_prefix: purpclass

  columns: [id, function, args, expected]
  rows:
    - [SERVER_AUTH, Purpose.SERVER_AUTH.__class__.__name__.__eq__, ["Purpose"], true]
    - [CLIENT_AUTH, Purpose.CLIENT_AUTH.__class__.__name__.__eq__, ["Purpose"], true]
