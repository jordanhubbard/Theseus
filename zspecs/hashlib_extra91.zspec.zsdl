spec: hashlib_extra91
version: ">=3.9"
extends: hashlib_extra90
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra90.zspec.zsdl — covers blake2b/blake2s class identity __name__/__module__/__bases__[0].__name__/__mro__.__len__() / blake2b/blake2s __dict__.__contains__ for copy/digest/hexdigest/update (table + invariants)."
    - "hashlib_extra89.zspec.zsdl — covers blake2b/blake2s method __qualname__.__eq__ for copy/digest/hexdigest/update / blake2b/blake2s class __qualname__.__eq__ and __qualname__.__len__() / cross-check table for mixed method __qualname__ strings (table + invariants)."
    - "hashlib_extra86.zspec.zsdl — covers blake2b/blake2s __class__.__name__/'type' / __name__ / __module__/'_blake2' / __qualname__ / __bases__[0].__name__/'object' / __mro__.__len__()==2 / SALT_SIZE.__class__.__name__/'int' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra90; it does NOT duplicate invariants present in those files."
    - "Wave 254 theme: hashlib.new function identity / algorithms_available/algorithms_guaranteed set identity / blake2b BLAKE2 constant attrs / blake2b and blake2s doc class identity."
    - "hashlib.new.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__qualname__ == '__hash_new'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__contains__.__qualname__.__eq__('set.__contains__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__.__qualname__.__eq__('set.__contains__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('MAX_DIGEST_SIZE') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('MAX_KEY_SIZE') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('SALT_SIZE') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__contains__('PERSON_SIZE') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__doc__.__class__.__name__.__eq__('str') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__doc__.__class__.__name__.__eq__('str') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.new is a Python function in hashlib.py with internal name __hash_new (not a builtin_function_or_method)."
    - "Note: BLOCK_SIZE and DIGEST_SIZE are NOT in blake2b.__dict__; the available class-level constants are MAX_KEY_SIZE, MAX_DIGEST_SIZE, SALT_SIZE, PERSON_SIZE."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new/__class__/__name__ == 'function'
# hashlib.new/__qualname__.__eq__('__hash_new')
# hashlib.new/__module__.__eq__('hashlib')
# hashlib.new/__class__/__name__.__eq__('function')
#
# Wave 254 theme: hashlib.new function identity.
#
# hashlib.new is a Python function internally named __hash_new in hashlib.py.
# Its __class__.__name__ is 'function', __qualname__ is '__hash_new', and
# __module__ is 'hashlib'. No prior hashlib spec anchors new.__class__.__name__,
# new.__qualname__.__eq__, or new.__module__.__eq__ under this id_prefix.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra91.hashlib_new_identity:
  description: "hashlib.new/__class__.__name__=='function' / new/__qualname__.__eq__('__hash_new')==True / new/__module__.__eq__('hashlib')==True / new/__class__.__name__.__eq__('function')==True — hashlib.new is a Python function in hashlib.py with internal qualname __hash_new; its __class__.__name__ is 'function' (not builtin_function_or_method); __module__ is 'hashlib'; first hashlibalgid91 anchor for hashlib.new identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibalgid91

  columns: [id, function, args, expected]
  rows:
    - [new_qualname_eq,          new.__qualname__.__eq__,                ["__hash_new"], true]
    - [new_module_eq,            new.__module__.__eq__,                  ["hashlib"],    true]
    - [new_class_name_eq,        new.__class__.__name__.__eq__,          ["function"],   true]
    - [new_qualname_len,         new.__qualname__.__len__,               [],             10]

# ---------------------------------------------------------------------------
# hashlib.algorithms_available/__class__/__name__ == 'set'
# hashlib.algorithms_guaranteed/__class__.__name__ == 'set'
# hashlib.algorithms_available/__contains__/__qualname__.__eq__('set.__contains__')
# hashlib.algorithms_guaranteed/__contains__/__qualname__.__eq__('set.__contains__')
#
# Wave 254 theme: algorithms set class identity.
#
# algorithms_available and algorithms_guaranteed are Python set objects.
# Their __class__.__name__ is 'set' and their __contains__ method's
# __qualname__ is 'set.__contains__'. No prior hashlib spec anchors these.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra91.algorithms_sets_identity:
  description: "hashlib.algorithms_available/__class__.__name__.__eq__('set')==True / algorithms_guaranteed/__class__.__name__.__eq__('set')==True / algorithms_available/__contains__/__qualname__.__eq__('set.__contains__')==True / algorithms_guaranteed/__contains__/__qualname__.__eq__('set.__contains__')==True — both algorithms_available and algorithms_guaranteed are Python set objects; their __contains__ method carries __qualname__ 'set.__contains__'; no prior hashlib spec anchors these attributes; first hashlibalgid91 anchor for algorithms set identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibalgid91

  columns: [id, function, args, expected]
  rows:
    - [algavail_class_name_eq,   algorithms_available.__class__.__name__.__eq__,              ["set"],              true]
    - [algguaranteed_class_name_eq, algorithms_guaranteed.__class__.__name__.__eq__,          ["set"],              true]
    - [algavail_contains_qual,   algorithms_available.__contains__.__qualname__.__eq__,       ["set.__contains__"], true]
    - [algguaranteed_contains_qual, algorithms_guaranteed.__contains__.__qualname__.__eq__,   ["set.__contains__"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b/__dict__/__contains__('MAX_DIGEST_SIZE') == True
# hashlib.blake2b/__dict__/__contains__('MAX_KEY_SIZE') == True
# hashlib.blake2b/__dict__/__contains__('SALT_SIZE') == True
# hashlib.blake2b/__dict__/__contains__('PERSON_SIZE') == True
#
# Wave 254 theme: blake2b BLAKE2 constant attrs in __dict__.
#
# blake2b.__dict__ contains the class-level constants MAX_DIGEST_SIZE (64),
# MAX_KEY_SIZE (64), SALT_SIZE (16), PERSON_SIZE (16). BLOCK_SIZE and
# DIGEST_SIZE are NOT present as class-level constants (they exist as
# instance descriptors named block_size/digest_size). hashlib_extra90 anchors
# copy/digest/hexdigest/update membership; this table anchors the BLAKE2
# constant attrs. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra91.blake2b_const_attrs:
  description: "hashlib.blake2b/__dict__/__contains__('MAX_DIGEST_SIZE')==True / blake2b/__dict__/__contains__('MAX_KEY_SIZE')==True / blake2b/__dict__/__contains__('SALT_SIZE')==True / blake2b/__dict__/__contains__('PERSON_SIZE')==True — blake2b.__dict__ contains the integer class constants MAX_DIGEST_SIZE/MAX_KEY_SIZE/SALT_SIZE/PERSON_SIZE; BLOCK_SIZE and DIGEST_SIZE are NOT in __dict__ (they exist as 'block_size'/'digest_size' instance attribute descriptors); hashlib_extra90 anchors copy/digest/hexdigest/update; this table anchors the BLAKE2 constant attrs; first hashlibalgid91 anchor for blake2b BLAKE2 constants"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibalgid91

  columns: [id, function, args, expected]
  rows:
    - [blake2b_dict_max_digest,  "blake2b.__dict__.__contains__", ["MAX_DIGEST_SIZE"], true]
    - [blake2b_dict_max_key,     "blake2b.__dict__.__contains__", ["MAX_KEY_SIZE"],    true]
    - [blake2b_dict_salt_size,   "blake2b.__dict__.__contains__", ["SALT_SIZE"],       true]
    - [blake2b_dict_person_size, "blake2b.__dict__.__contains__", ["PERSON_SIZE"],     true]

# ---------------------------------------------------------------------------
# hashlib.blake2b/__doc__/__class__/__name__.__eq__('str') == True
# hashlib.blake2s/__doc__/__class__/__name__.__eq__('str') == True
# hashlib.blake2b/__dict__/__contains__('MAX_DIGEST_SIZE') (cross-check)
# hashlib.algorithms_available/__class__/__name__.__eq__('set') (cross-check)
#
# Wave 254 theme: blake2b/blake2s doc class identity cross-check.
#
# blake2b and blake2s docstrings are str objects. This table anchors the
# __doc__.__class__.__name__.__eq__ call form alongside cross-checks.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra91.blake2_doc_class_cross_check:
  description: "hashlib.blake2b/__doc__/__class__/__name__.__eq__('str')==True / blake2s/__doc__/__class__/__name__.__eq__('str')==True / blake2b/__dict__.__contains__('MAX_DIGEST_SIZE')==True / algorithms_available/__class__.__name__.__eq__('set')==True — blake2b and blake2s docstrings are str objects; cross-checks anchor blake2b BLAKE2 constant dict membership and algorithms set class name alongside doc class identity; first hashlibalgid91 anchor for blake2b/blake2s __doc__.__class__.__name__.__eq__"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibalgid91

  columns: [id, function, args, expected]
  rows:
    - [blake2b_doc_class_str,    blake2b.__doc__.__class__.__name__.__eq__,                ["str"],  true]
    - [blake2s_doc_class_str,    blake2s.__doc__.__class__.__name__.__eq__,                ["str"],  true]
    - [blake2b_dict_max_digest2, "blake2b.__dict__.__contains__",                          ["MAX_DIGEST_SIZE"], true]
    - [algavail_class_name_eq2,  algorithms_available.__class__.__name__.__eq__,           ["set"],  true]

# ---------------------------------------------------------------------------
# hashlib.new.__qualname__.__eq__('__hash_new') — standalone
#
# hashlib.new.__qualname__ is '__hash_new'. hashlib.new is a Python function
# in hashlib.py that wraps the underlying hash constructors. Its internal
# name is __hash_new. No prior hashlib spec anchors new.__qualname__.__eq__.
# First __qualname__.__eq__ standalone for hashlib.new.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra91.new_qualname_eq:
  description: "hashlib.new.__qualname__.__eq__('__hash_new') == True — hashlib.new is a Python function in hashlib.py; its __qualname__ is '__hash_new' (its internal implementation name); no prior hashlib spec anchors new.__qualname__.__eq__; first __qualname__.__eq__ standalone for hashlib.new"
  category: class_attrs
  kind: python_call_eq
  function: new.__qualname__.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__contains__.__qualname__.__eq__('set.__contains__') — standalone
#
# algorithms_available.__contains__ is the standard set.__contains__ method.
# Its __qualname__ is 'set.__contains__'. No prior hashlib spec anchors this.
# First standalone for algorithms_available.__contains__.__qualname__.__eq__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra91.algavail_contains_qualname_eq:
  description: "hashlib.algorithms_available.__contains__.__qualname__.__eq__('set.__contains__') == True — algorithms_available is a Python set; its __contains__ method is the standard set.__contains__ with __qualname__ 'set.__contains__'; no prior hashlib spec anchors this; first standalone for algorithms_available __contains__ qualname"
  category: class_attrs
  kind: python_call_eq
  function: algorithms_available.__contains__.__qualname__.__eq__
  args: ["set.__contains__"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__.__qualname__.__eq__('set.__contains__') — standalone
#
# algorithms_guaranteed.__contains__ is the standard set.__contains__ method.
# Its __qualname__ is 'set.__contains__'. No prior hashlib spec anchors this.
# First standalone for algorithms_guaranteed.__contains__.__qualname__.__eq__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra91.algguaranteed_contains_qualname_eq:
  description: "hashlib.algorithms_guaranteed.__contains__.__qualname__.__eq__('set.__contains__') == True — algorithms_guaranteed is a Python set; its __contains__ method is set.__contains__ with __qualname__ 'set.__contains__'; no prior hashlib spec anchors this; first standalone for algorithms_guaranteed __contains__ qualname"
  category: class_attrs
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__.__qualname__.__eq__
  args: ["set.__contains__"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__doc__.__class__.__name__.__eq__('str') — standalone
#
# blake2b.__doc__ is a str. Its __class__.__name__.__eq__('str') is True.
# No prior hashlib spec anchors blake2b.__doc__.__class__.__name__.__eq__.
# First standalone for hashlib.blake2b doc class identity.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra91.blake2b_doc_class_str:
  description: "hashlib.blake2b.__doc__.__class__.__name__.__eq__('str') == True — blake2b is a C type with a str docstring; __doc__.__class__.__name__ is 'str'; no prior hashlib spec anchors __doc__.__class__.__name__.__eq__ for blake2b; first standalone for blake2b doc class identity"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.__doc__.__class__.__name__.__eq__('str') — standalone
#
# blake2s.__doc__ is a str. Its __class__.__name__.__eq__('str') is True.
# No prior hashlib spec anchors blake2s.__doc__.__class__.__name__.__eq__.
# First standalone for hashlib.blake2s doc class identity.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra91.blake2s_doc_class_str:
  description: "hashlib.blake2s.__doc__.__class__.__name__.__eq__('str') == True — blake2s is a C type with a str docstring; __doc__.__class__.__name__ is 'str'; no prior hashlib spec anchors __doc__.__class__.__name__.__eq__ for blake2s; first standalone for blake2s doc class identity"
  category: class_attrs
  kind: python_call_eq
  function: blake2s.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
