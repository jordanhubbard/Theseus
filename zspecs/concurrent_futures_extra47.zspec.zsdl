invariant concurrent_futures_extra47.Future_doc_class_qualname_eq:
  description: "concurrent.futures.Future.__doc__.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str'; no enclosing scope"
  category: class_names
  kind: python_call_eq
  function: Future.__doc__.__class__.__qualname__.__eq__
