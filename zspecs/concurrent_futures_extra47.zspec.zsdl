invariant concurrent_futures_extra47.BrokenExecutor_doc_class_name_eq:
  description: "concurrent.futures.BrokenExecutor.__doc__.__class__.__name__ == 'str' — custom exception class docstring is a plain Python string; __class__ is built-in str type"
  category: class_names
  kind: python_call_eq
  function: BrokenExecutor.__doc__.__class__.__name__.__eq__
