spec: concurrent_futures_extra47
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra46.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__ tables, as_completed/wait __module__.__len__(), __all__.__len__()==14, __mro__.__len__() tables, __bases__[0].__name__.__len__() for all classes, Executor context manager qualname lens, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, map/__qualname__.__len__() for both executors, Future/ThreadPoolExecutor method __name__/__qualname__.__len__() tables, InvalidStateError/__name__.__len__()==17, CancelledError/__qualname__.__len__()==14, BrokenExecutor lengths, CancelledError/__module__.__len__()==24, TimeoutError/__name__/__module__.__len__(), concurrent.futures.__package__.__len__()==18, executor __name__ equality, executor __module__ equality, Executor/__name__/__module__ equality, exception identity/MRO depths, class __qualname__ equality tables (extra41), module string equality for thread/process/builtins (extra42), Future/__module__ lengths (extra43), class __class__.__name__=='type'/'function' tables (extra44), class __class__.__qualname__ equality tables (extra45), FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED __class__.__name__=='str', __class__.__qualname__=='str', __len__() lengths, and string value equality (extra46)."
    - "This spec covers: ThreadPoolExecutor/__doc__/__class__/__name__=='str'; ProcessPoolExecutor/__doc__/__class__/__name__=='str'; Future/__doc__/__class__/__name__=='str'; Executor/__doc__/__class__/__name__=='str'; CancelledError/__doc__/__class__/__name__=='str'; BrokenExecutor/__doc__/__class__/__name__=='str'; module __doc__/__class__/__name__=='str'; ThreadPoolExecutor/__doc__/__class__/__qualname__=='str'; Future/__doc__/__class__/__qualname__=='str'; ThreadPoolExecutor/__doc__/__class__/__module__=='builtins'; Future/__doc__/__class__/__module__=='builtins'."
    - "concurrent.futures.ThreadPoolExecutor.__doc__.__class__.__name__ == 'str'. Class docstrings are compiled by Python into __doc__ attributes of type str. ThreadPoolExecutor has a descriptive docstring; its __class__ is the built-in str type with __name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__doc__.__class__.__name__ == 'str'. ProcessPoolExecutor also has a class docstring; it is a plain Python str with __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__doc__.__class__.__name__ == 'str'. The Future class docstring is a plain Python string. __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__doc__.__class__.__name__ == 'str'. The Executor abstract base class has a docstring; it is a plain Python string with __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.CancelledError.__doc__.__class__.__name__ == 'str'. CancelledError is re-exported from concurrent.futures; its docstring (inherited from the built-in BaseException hierarchy) is a plain Python string. __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__doc__.__class__.__name__ == 'str'. BrokenExecutor is a custom exception class defined in _base.py; its docstring is a plain Python string. __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__doc__.__class__.__name__ == 'str'. The concurrent.futures module has a module-level docstring. Module docstrings are plain Python strings; __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__doc__.__class__.__qualname__ == 'str'. The built-in str type has no enclosing class or function scope, so __qualname__ == __name__ == 'str'. This confirms that __class__.__qualname__ and __class__.__name__ are identical for all str instances. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__doc__.__class__.__qualname__ == 'str'. Same reasoning: Future's docstring is a str instance; str.__qualname__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__doc__.__class__.__module__ == 'builtins'. The str type is a built-in type defined in the builtins module. Every str instance therefore has __class__.__module__ == 'builtins'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__doc__.__class__.__module__ == 'builtins'. Same reasoning as ThreadPoolExecutor: Future's docstring is a str; str.__class__.__module__ == 'builtins'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures class __doc__.__class__.__name__ — extra47
#
# All concurrent.futures class and exception docstrings are instances of the
# built-in str type. Python compiles docstring literals into __doc__
# attributes whose type is always str:
#   ThreadPoolExecutor.__doc__.__class__.__name__ == 'str'
#   ProcessPoolExecutor.__doc__.__class__.__name__ == 'str'
#   Future.__doc__.__class__.__name__             == 'str'
#   Executor.__doc__.__class__.__name__           == 'str'
#   CancelledError.__doc__.__class__.__name__     == 'str'
#   BrokenExecutor.__doc__.__class__.__name__     == 'str'
# Prior specs (extra40–extra46) covered __class__.__name__ for the classes
# themselves but never traversed into the __doc__ dimension. Extra47 opens
# the __doc__ dimension for concurrent.futures for the first time.
# ---------------------------------------------------------------------------

table concurrent_futures_extra47.class_doc_class_name_eq:
  description: "concurrent.futures class __doc__.__class__.__name__ string equality in extra47 namespace — all class docstrings are str instances"
  kind: python_call_eq
  category: class_names
  id_prefix: cfdoc47clsname

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__doc__.__class__.__name__.__eq__,  ["str"], true, "ThreadPoolExecutor.__doc__.__class__.__name__ == 'str' — class docstring is a plain Python string"]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__doc__.__class__.__name__.__eq__, ["str"], true, "ProcessPoolExecutor.__doc__.__class__.__name__ == 'str' — class docstring is a plain Python string"]
    - [Future,              Future.__doc__.__class__.__name__.__eq__,              ["str"], true, "Future.__doc__.__class__.__name__ == 'str' — class docstring is a plain Python string"]
    - [Executor,            Executor.__doc__.__class__.__name__.__eq__,            ["str"], true, "Executor.__doc__.__class__.__name__ == 'str' — abstract base class docstring is a plain Python string"]
    - [CancelledError,      CancelledError.__doc__.__class__.__name__.__eq__,      ["str"], true, "CancelledError.__doc__.__class__.__name__ == 'str' — exception docstring is a plain Python string"]
    - [BrokenExecutor,      BrokenExecutor.__doc__.__class__.__name__.__eq__,      ["str"], true, "BrokenExecutor.__doc__.__class__.__name__ == 'str' — custom exception class docstring is a plain Python string"]

# ---------------------------------------------------------------------------
# concurrent.futures module __doc__.__class__.__name__ — extra47
#
# The concurrent.futures module carries a module-level docstring accessible
# via __doc__ within the backend scope. Module docstrings are plain Python
# strings; __doc__.__class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra47.module_doc_class_name_eq:
  description: "concurrent.futures.__doc__.__class__.__name__ == 'str' — module-level docstring is a plain Python string; __class__ is built-in str type"
  category: class_names
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# concurrent.futures class __doc__.__class__.__qualname__ — extra47
#
# The built-in str type has __qualname__ == __name__ == 'str' (no enclosing
# scope). Therefore every docstring (a str instance) has
# __doc__.__class__.__qualname__ == 'str'. Verified here for
# ThreadPoolExecutor and Future as representative samples:
#   ThreadPoolExecutor.__doc__.__class__.__qualname__ == 'str'
#   Future.__doc__.__class__.__qualname__             == 'str'
# ---------------------------------------------------------------------------

table concurrent_futures_extra47.doc_class_qualname_eq:
  description: "concurrent.futures __doc__.__class__.__qualname__ string equality in extra47 namespace — ThreadPoolExecutor and Future docstrings have __class__.__qualname__ == 'str'"
  kind: python_call_eq
  category: class_names
  id_prefix: cfdoc47clsqual

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor, ThreadPoolExecutor.__doc__.__class__.__qualname__.__eq__, ["str"], true, "ThreadPoolExecutor.__doc__.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str' (no enclosing scope)"]
    - [Future,             Future.__doc__.__class__.__qualname__.__eq__,             ["str"], true, "Future.__doc__.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str' (no enclosing scope)"]

# ---------------------------------------------------------------------------
# concurrent.futures class __doc__.__class__.__module__ — extra47
#
# The str type is a built-in type defined in the builtins module. Every str
# instance's __class__.__module__ == 'builtins':
#   ThreadPoolExecutor.__doc__.__class__.__module__ == 'builtins'
#   Future.__doc__.__class__.__module__             == 'builtins'
# This is consistent with abc_extra44 and all other __doc__ specs in this
# series which observe that docstring str instances always report
# __class__.__module__ == 'builtins'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra47.doc_class_module_eq:
  description: "concurrent.futures __doc__.__class__.__module__ string equality in extra47 namespace — str is a built-in type; docstrings have __class__.__module__ == 'builtins'"
  kind: python_call_eq
  category: module_identity
  id_prefix: cfdoc47clsmodule

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor, ThreadPoolExecutor.__doc__.__class__.__module__.__eq__, ["builtins"], true, "ThreadPoolExecutor.__doc__.__class__.__module__ == 'builtins' — str is a built-in type defined in builtins; __class__.__module__ == 'builtins'"]
    - [Future,             Future.__doc__.__class__.__module__.__eq__,             ["builtins"], true, "Future.__doc__.__class__.__module__ == 'builtins' — str is a built-in type defined in builtins; __class__.__module__ == 'builtins'"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra47
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra47.ThreadPoolExecutor_doc_class_name_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__doc__.__class__.__name__ == 'str' — class docstring is a plain Python string; __class__ is built-in str type"
  category: class_names
  kind: python_call_eq
  function: ThreadPoolExecutor.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra47.ProcessPoolExecutor_doc_class_name_eq:
  description: "concurrent.futures.ProcessPoolExecutor.__doc__.__class__.__name__ == 'str' — class docstring is a plain Python string; __class__ is built-in str type"
  category: class_names
  kind: python_call_eq
  function: ProcessPoolExecutor.__doc__.__class__.__name__.__eq__
  args: ["str"]
