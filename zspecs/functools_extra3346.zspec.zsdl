spec: ft3346
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 670 (ft3346): __neg__, __pos__, __abs__ dict-presence checks for functools types."
    - "Theme: __neg__/__pos__/__abs__ unary arithmetic dict-presence."
    - "Unary arithmetic operators (-x, +x, abs(x)) are defined by __neg__, __pos__, __abs__ respectively."
    - "All values False — callable/iterator/inspection/synchronization types have no unary arithmetic operators."
    - "None of the four functools types define __neg__, __pos__, or __abs__ in their own __dict__."
    - "functools.partial and functools._lru_cache_wrapper are C-level types; functools.partialmethod and functools.cached_property are Python-level classes."
    - "type(functools.lru_cache(lambda: None)) accesses the internal _lru_cache_wrapper C type at runtime."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3346.neg:
  description: "functools types __neg__ dict-presence checks; wave 670"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3346
  columns: [id, function, args, expected]
  rows:
    - ["ft3346001", operator.contains, [functools.partial.__dict__,                              "__neg__"], false]
    - ["ft3346002", operator.contains, [functools.partialmethod.__dict__,                        "__neg__"], false]
    - ["ft3346003", operator.contains, [functools.cached_property.__dict__,                      "__neg__"], false]
    - ["ft3346004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__,        "__neg__"], false]

