spec: asyncio_extra82
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec extends asyncio_extra81.zspec.zsdl."
    - "This spec covers: wave 245 theme — asyncio Queue/LifoQueue/PriorityQueue class hierarchy + QueueEmpty/QueueFull exception hierarchy. NEW in extra82: Queue.__name__=='Queue'; Queue.__module__=='asyncio.queues'; Queue.__bases__[0].__name__=='_LoopBoundMixin' (in Python 3.14, Queue inherits from _LoopBoundMixin not object directly); Queue.__mro__.__len__()==3 (Queue, _LoopBoundMixin, object); LifoQueue.__name__=='LifoQueue'; LifoQueue.__bases__[0].__name__=='Queue'; LifoQueue.__mro__.__len__()==4; PriorityQueue.__name__=='PriorityQueue'; PriorityQueue.__bases__[0].__name__=='Queue'; PriorityQueue.__mro__.__len__()==4; QueueEmpty.__name__=='QueueEmpty'; QueueEmpty.__bases__[0].__name__=='Exception'; QueueEmpty.__mro__.__len__()==4 (QueueEmpty, Exception, BaseException, object); QueueFull.__name__=='QueueFull'; QueueFull.__bases__[0].__name__=='Exception'; QueueFull.__mro__.__len__()==4. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__name__ == 'Queue'. Simple class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__module__ == 'asyncio.queues'. Queue is defined in the asyncio.queues submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin'. In Python 3.14, Queue inherits from _LoopBoundMixin rather than object directly. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__mro__.__len__() == 3. MRO is [Queue, _LoopBoundMixin, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.LifoQueue.__bases__[0].__name__ == 'Queue'. LifoQueue directly subclasses Queue. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.LifoQueue.__mro__.__len__() == 4. MRO is [LifoQueue, Queue, _LoopBoundMixin, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.PriorityQueue.__bases__[0].__name__ == 'Queue'. PriorityQueue directly subclasses Queue. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.PriorityQueue.__mro__.__len__() == 4. MRO is [PriorityQueue, Queue, _LoopBoundMixin, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.QueueEmpty.__bases__[0].__name__ == 'Exception'. QueueEmpty directly subclasses Exception. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.QueueEmpty.__mro__.__len__() == 4. MRO is [QueueEmpty, Exception, BaseException, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.QueueFull.__bases__[0].__name__ == 'Exception'. QueueFull directly subclasses Exception. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.QueueFull.__mro__.__len__() == 4. MRO is [QueueFull, Exception, BaseException, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Queue class name and module checks — extra82
#
# Wave 245 theme: asyncio Queue/LifoQueue/PriorityQueue class hierarchy.
#
# Queue.__name__ == 'Queue'
# Queue.__module__ == 'asyncio.queues'
# Queue.__bases__[0].__name__ == '_LoopBoundMixin'
# Queue.__mro__.__len__() == 3
# ---------------------------------------------------------------------------

table asyncio_extra82.Queue_class_name_and_module:
  description: "asyncio Queue class name, module, and base class checks in asyncioextra82 namespace — wave 245 theme: asyncio Queue/LifoQueue/PriorityQueue class hierarchy; Queue.__name__=='Queue'; Queue.__module__=='asyncio.queues' (defined in asyncio.queues submodule); Queue.__bases__[0].__name__=='_LoopBoundMixin' (in Python 3.14 Queue inherits _LoopBoundMixin not object); Queue.__mro__.__len__()==3 (Queue, _LoopBoundMixin, object); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra82

  columns: [id, function, args, expected, description]
  rows:
    - [queue_name,          Queue.__name__.__eq__,                   ["Queue"],          true, "Queue.__name__ == 'Queue' — simple class name; verified with Python 3.14.3"]
    - [queue_module,        Queue.__module__.__eq__,                 ["asyncio.queues"], true, "Queue.__module__ == 'asyncio.queues' — defined in asyncio.queues submodule; verified with Python 3.14.3"]
    - [queue_base_name,     "Queue.__bases__[0].__name__.__eq__",   ["_LoopBoundMixin"], true, "Queue.__bases__[0].__name__ == '_LoopBoundMixin' — in Python 3.14 Queue inherits from _LoopBoundMixin; verified with Python 3.14.3"]
    - [queue_mro_len,       "Queue.__mro__.__len__",                [],                  3,   "Queue.__mro__.__len__() == 3 — MRO is [Queue, _LoopBoundMixin, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio LifoQueue and PriorityQueue hierarchy checks — extra82
#
# LifoQueue.__name__ == 'LifoQueue'
# LifoQueue.__bases__[0].__name__ == 'Queue'
# LifoQueue.__mro__.__len__() == 4
# PriorityQueue.__name__ == 'PriorityQueue'
# PriorityQueue.__bases__[0].__name__ == 'Queue'
# PriorityQueue.__mro__.__len__() == 4
# ---------------------------------------------------------------------------

table asyncio_extra82.LifoQueue_and_PriorityQueue_hierarchy:
  description: "asyncio LifoQueue and PriorityQueue class hierarchy checks in asyncioextra82 namespace — wave 245 theme: asyncio Queue subclasses; LifoQueue.__name__=='LifoQueue'; LifoQueue.__bases__[0].__name__=='Queue' (direct subclass of Queue); LifoQueue.__mro__.__len__()==4 (LifoQueue, Queue, _LoopBoundMixin, object); PriorityQueue.__name__=='PriorityQueue'; PriorityQueue.__bases__[0].__name__=='Queue'; PriorityQueue.__mro__.__len__()==4; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra82a

  columns: [id, function, args, expected, description]
  rows:
    - [lifo_name,           LifoQueue.__name__.__eq__,               ["LifoQueue"],  true, "LifoQueue.__name__ == 'LifoQueue' — simple class name; verified with Python 3.14.3"]
    - [lifo_base_name,      "LifoQueue.__bases__[0].__name__.__eq__", ["Queue"],     true, "LifoQueue.__bases__[0].__name__ == 'Queue' — direct subclass of asyncio.Queue; verified with Python 3.14.3"]
    - [lifo_mro_len,        "LifoQueue.__mro__.__len__",             [],              4,   "LifoQueue.__mro__.__len__() == 4 — MRO is [LifoQueue, Queue, _LoopBoundMixin, object]; verified with Python 3.14.3"]
    - [pq_name,             PriorityQueue.__name__.__eq__,           ["PriorityQueue"], true, "PriorityQueue.__name__ == 'PriorityQueue' — simple class name; verified with Python 3.14.3"]
    - [pq_base_name,        "PriorityQueue.__bases__[0].__name__.__eq__", ["Queue"], true, "PriorityQueue.__bases__[0].__name__ == 'Queue' — direct subclass of asyncio.Queue; verified with Python 3.14.3"]
    - [pq_mro_len,          "PriorityQueue.__mro__.__len__",         [],              4,   "PriorityQueue.__mro__.__len__() == 4 — MRO is [PriorityQueue, Queue, _LoopBoundMixin, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio QueueEmpty hierarchy checks — extra82
#
# QueueEmpty.__name__ == 'QueueEmpty'
# QueueEmpty.__bases__[0].__name__ == 'Exception'
