# ---------------------------------------------------------------------------

table asyncio_extra82.QueueEmpty_hierarchy:
  description: "asyncio QueueEmpty exception hierarchy checks in asyncioextra82 namespace — wave 245 theme: asyncio queue exception hierarchy; QueueEmpty.__name__=='QueueEmpty'; QueueEmpty.__bases__[0].__name__=='Exception' (direct subclass of Exception, not a custom base); QueueEmpty.__mro__.__len__()==4 (QueueEmpty, Exception, BaseException, object); QueueFull.__name__=='QueueFull'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra82b

  columns: [id, function, args, expected, description]
  rows:
    - [qempty_name,         QueueEmpty.__name__.__eq__,                  ["QueueEmpty"], true, "QueueEmpty.__name__ == 'QueueEmpty' — simple class name; verified with Python 3.14.3"]
    - [qempty_base_name,    "QueueEmpty.__bases__[0].__name__.__eq__",   ["Exception"],  true, "QueueEmpty.__bases__[0].__name__ == 'Exception' — direct subclass of built-in Exception; verified with Python 3.14.3"]
    - [qempty_mro_len,      "QueueEmpty.__mro__.__len__",                [],             4,   "QueueEmpty.__mro__.__len__() == 4 — MRO is [QueueEmpty, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [qfull_name,          QueueFull.__name__.__eq__,                   ["QueueFull"],  true, "QueueFull.__name__ == 'QueueFull' — simple class name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio QueueFull hierarchy and cross-checks — extra82
#
# QueueFull.__bases__[0].__name__ == 'Exception'
# QueueFull.__mro__.__len__() == 4
# ---------------------------------------------------------------------------

table asyncio_extra82.QueueFull_hierarchy_and_cross_checks:
  description: "asyncio QueueFull exception hierarchy and cross-checks in asyncioextra82 namespace — wave 245 theme: asyncio queue exception hierarchy; QueueFull.__bases__[0].__name__=='Exception'; QueueFull.__mro__.__len__()==4 (QueueFull, Exception, BaseException, object); Queue.__mro__.__len__()==3 (cross-check); LifoQueue.__mro__.__len__()==4 (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra82c

  columns: [id, function, args, expected, description]
  rows:
    - [qfull_base_name,     "QueueFull.__bases__[0].__name__.__eq__",    ["Exception"], true, "QueueFull.__bases__[0].__name__ == 'Exception' — direct subclass of built-in Exception; verified with Python 3.14.3"]
    - [qfull_mro_len,       "QueueFull.__mro__.__len__",                 [],            4,   "QueueFull.__mro__.__len__() == 4 — MRO is [QueueFull, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [queue_mro_len_cross, "Queue.__mro__.__len__",                     [],            3,   "Queue.__mro__.__len__() == 3 — cross-check; verified with Python 3.14.3"]
    - [lifo_mro_len_cross,  "LifoQueue.__mro__.__len__",                 [],            4,   "LifoQueue.__mro__.__len__() == 4 — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra82
# ---------------------------------------------------------------------------

invariant asyncio_extra82.Queue_name:
  description: "asyncio.Queue.__name__.__eq__('Queue') returns True — simple class name for the asyncio Queue class; NEW in extra82: first standalone __name__ invariant for Queue in asyncioextra82 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

invariant asyncio_extra82.Queue_module:
  description: "asyncio.Queue.__module__.__eq__('asyncio.queues') returns True — Queue is defined in the asyncio.queues submodule, not in asyncio directly; NEW in extra82: first standalone __module__ invariant for Queue in asyncioextra82 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Queue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra82.Queue_mro_len:
  description: "asyncio.Queue.__mro__.__len__() == 3 — MRO is [Queue, _LoopBoundMixin, object]; in Python 3.14 Queue inherits from _LoopBoundMixin giving a three-element MRO; NEW in extra82: first standalone __mro__.__len__ invariant for Queue in asyncioextra82 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Queue.__mro__.__len__
  args: []
  expected: 3

invariant asyncio_extra82.QueueEmpty_mro_len:
  description: "asyncio.QueueEmpty.__mro__.__len__() == 4 — MRO is [QueueEmpty, Exception, BaseException, object]; QueueEmpty is a simple exception that subclasses Exception directly; NEW in extra82: first standalone __mro__.__len__ invariant for QueueEmpty in asyncioextra82 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: QueueEmpty.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra82.LifoQueue_base_name:
  description: "asyncio.LifoQueue.__bases__[0].__name__.__eq__('Queue') returns True — LifoQueue directly subclasses asyncio.Queue and overrides _get and _put to implement LIFO ordering; NEW in extra82: first standalone __bases__[0].__name__ invariant for LifoQueue in asyncioextra82 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: LifoQueue.__bases__[0].__name__.__eq__
  args: ["Queue"]
  expected: true
