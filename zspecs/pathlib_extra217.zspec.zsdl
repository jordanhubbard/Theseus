# mkdir, iterdir, is_symlink are concrete navigation methods on Path
# ---------------------------------------------------------------------------

table pathlib_extra217.path_dict_navigation_methods:
  description: "pathlib.Path.__dict__ contains concrete navigation and inspection method implementations"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathliblink217

  columns: [id, function, args, expected, description]
  rows:
    - [path_has_mkdir,       "pathlib.Path.__dict__.__contains__",  ["mkdir"],       true,  "pathlib.Path.__dict__.__contains__('mkdir') == True; mkdir is a concrete method on Path; confirmed Python 3.14.3 macOS"]
    - [path_has_iterdir,     "pathlib.Path.__dict__.__contains__",  ["iterdir"],     true,  "pathlib.Path.__dict__.__contains__('iterdir') == True; iterdir is a concrete method on Path; confirmed Python 3.14.3 macOS"]
    - [path_has_is_symlink,  "pathlib.Path.__dict__.__contains__",  ["is_symlink"],  true,  "pathlib.Path.__dict__.__contains__('is_symlink') == True; is_symlink is a concrete method on Path; confirmed Python 3.14.3 macOS"]
    - [path_has_rmdir,       "pathlib.Path.__dict__.__contains__",  ["rmdir"],       true,  "pathlib.Path.__dict__.__contains__('rmdir') == True; rmdir is a concrete method on Path; confirmed Python 3.14.3 macOS"]

