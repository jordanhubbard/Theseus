spec: pathlib_extra217
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra.zspec.zsdl — covers pathlib.Path class metadata, PurePath, PosixPath, WindowsPath"
    - "pathlib_extra216.zspec.zsdl — covers pathlib.Path.__dict__ destructive/query/link methods"
  notes:
    - "pathlib.Path.__dict__ contains concrete resolution and navigation method implementations."
    - "resolve, absolute, expanduser are path resolution methods present in Path.__dict__."
    - "read_bytes, write_bytes, touch are file I/O helper methods present in Path.__dict__."
    - "Path inherits from PurePath; filesystem I/O methods are implemented directly on Path."
    - "absolute was added as a public method in Python 3.11; present in __dict__ on 3.11+."
    - "All __dict__.__contains__ checks return True for these methods; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__dict__.__contains__('resolve') == True; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__dict__.__contains__('expanduser') == True; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__dict__.__contains__('read_bytes') == True; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.Path.__dict__ membership — path resolution methods
# resolve, absolute, expanduser are concrete resolution methods on Path
# ---------------------------------------------------------------------------

table pathlib_extra217.path_dict_resolution_methods:
  description: "pathlib.Path.__dict__ contains concrete path resolution method implementations"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathliblink217

  columns: [id, function, args, expected, description]
  rows:
    - [path_has_resolve,     "pathlib.Path.__dict__.__contains__",  ["resolve"],     true,  "pathlib.Path.__dict__.__contains__('resolve') == True; resolve is a concrete method on Path; confirmed Python 3.14.3 macOS"]
    - [path_has_absolute,    "pathlib.Path.__dict__.__contains__",  ["absolute"],    true,  "pathlib.Path.__dict__.__contains__('absolute') == True; absolute is a concrete method on Path; confirmed Python 3.14.3 macOS"]
    - [path_has_expanduser,  "pathlib.Path.__dict__.__contains__",  ["expanduser"],  true,  "pathlib.Path.__dict__.__contains__('expanduser') == True; expanduser is a concrete method on Path; confirmed Python 3.14.3 macOS"]
    - [path_has_is_file,     "pathlib.Path.__dict__.__contains__",  ["is_file"],     true,  "pathlib.Path.__dict__.__contains__('is_file') == True; is_file is a concrete method on Path; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.Path.__dict__ membership — binary I/O helper methods
# read_bytes, write_bytes are concrete binary file I/O methods on Path
# ---------------------------------------------------------------------------

table pathlib_extra217.path_dict_binary_io_methods:
  description: "pathlib.Path.__dict__ contains concrete binary file I/O helper method implementations"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathliblink217

  columns: [id, function, args, expected, description]
  rows:
    - [path_has_read_bytes,   "pathlib.Path.__dict__.__contains__",  ["read_bytes"],   true,  "pathlib.Path.__dict__.__contains__('read_bytes') == True; read_bytes is a concrete method on Path; confirmed Python 3.14.3 macOS"]
    - [path_has_write_bytes,  "pathlib.Path.__dict__.__contains__",  ["write_bytes"],  true,  "pathlib.Path.__dict__.__contains__('write_bytes') == True; write_bytes is a concrete method on Path; confirmed Python 3.14.3 macOS"]
    - [path_has_touch,        "pathlib.Path.__dict__.__contains__",  ["touch"],        true,  "pathlib.Path.__dict__.__contains__('touch') == True; touch is a concrete method on Path; confirmed Python 3.14.3 macOS"]
    - [path_has_is_dir,       "pathlib.Path.__dict__.__contains__",  ["is_dir"],       true,  "pathlib.Path.__dict__.__contains__('is_dir') == True; is_dir is a concrete method on Path; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
