spec: multiprocessing_extra2776
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "multiprocessing_extra.zspec.zsdl — covers Process.__module__, base class, factory __name__ checks"
    - "multiprocessing_extra2.zspec.zsdl — covers factory __module__ checks, extra primitive names"
    - "multiprocessing_extra2761.zspec.zsdl — covers __matmul__, __truediv__, __iadd__ dict-presence checks"
  notes:
    - "Wave 632 theme: __isub__, __imul__, and __itruediv__ dict-presence checks (in-place arithmetic)."
    - "None of the multiprocessing public classes define __isub__, __imul__, or __itruediv__ in their __dict__."
    - "multiprocessing.Process is a real class (Lib/multiprocessing/process.py); Pool and ApplyResult are in Lib/multiprocessing/pool.py."
    - "multiprocessing.pool.AsyncResult is an alias for multiprocessing.pool.ApplyResult; __name__ is 'ApplyResult' in Python 3.14.4."
    - "Process, Pool, and ApplyResult are process-management/coordination classes, not numeric types."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process — __isub__/__imul__/__itruediv__ dict-presence checks
#
# Process is the core class for spawning new OS processes. It manages process
# lifecycle (start, join, terminate) and does not implement in-place arithmetic dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2776.process_operator_dict:
  description: "multiprocessing.Process __isub__, __imul__, __itruediv__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2776p

  columns: [id, function, args, expected]
  rows:
    - ["mp2776p_isub",    multiprocessing.Process.__dict__.__contains__, ["__isub__"],    false]
    - ["mp2776p_imul",    multiprocessing.Process.__dict__.__contains__, ["__imul__"],    false]
    - ["mp2776p_itruediv", multiprocessing.Process.__dict__.__contains__, ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool — __isub__/__imul__/__itruediv__ dict-presence checks
#
# Pool is a process pool manager providing map/apply/starmap/imap interfaces.
# It coordinates worker processes and does not define in-place numeric operator dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2776.pool_operator_dict:
  description: "multiprocessing.pool.Pool __isub__, __imul__, __itruediv__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2776pl

  columns: [id, function, args, expected]
  rows:
    - ["mp2776pl_isub",    multiprocessing.pool.Pool.__dict__.__contains__, ["__isub__"],    false]
    - ["mp2776pl_imul",    multiprocessing.pool.Pool.__dict__.__contains__, ["__imul__"],    false]
    - ["mp2776pl_itruediv", multiprocessing.pool.Pool.__dict__.__contains__, ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# multiprocessing.pool.ApplyResult — __isub__/__imul__/__itruediv__ dict-presence checks
#
# ApplyResult (also exported as AsyncResult) is the result object returned by
# Pool.apply_async(). It wraps a pending result and provides get()/ready()/wait().
# It does not implement in-place arithmetic operator dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2776.applyresult_operator_dict:
  description: "multiprocessing.pool.ApplyResult __isub__, __imul__, __itruediv__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2776ar

  columns: [id, function, args, expected]
  rows:
    - ["mp2776ar_isub",    multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__isub__"],    false]
    - ["mp2776ar_imul",    multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__imul__"],    false]
    - ["mp2776ar_itruediv", multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Full 3×3 cross-type matrix — Process, Pool, ApplyResult × three in-place operator dunders
#
# Consolidates the complete 3×3 dict-presence check in one table.
# Every cell is False: Process, Pool, and ApplyResult do not define -=, *=, or /=
# operator dunders in their respective __dict__ attributes.
# ---------------------------------------------------------------------------

table multiprocessing_extra2776.all_types_isub_imul_itruediv_matrix:
  description: "Full 3×3 dict-presence matrix for multiprocessing types vs __isub__/__imul__/__itruediv__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2776mx

  columns: [id, function, args, expected]
  rows:
    - ["mp2776mx_p_is",   multiprocessing.Process.__dict__.__contains__,          ["__isub__"],    false]
    - ["mp2776mx_p_im",   multiprocessing.Process.__dict__.__contains__,          ["__imul__"],    false]
    - ["mp2776mx_p_it",   multiprocessing.Process.__dict__.__contains__,          ["__itruediv__"], false]
    - ["mp2776mx_pl_is",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__isub__"],    false]
    - ["mp2776mx_pl_im",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__imul__"],    false]
    - ["mp2776mx_pl_it",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__itruediv__"], false]
    - ["mp2776mx_ar_is",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__isub__"],    false]
    - ["mp2776mx_ar_im",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__imul__"],    false]
    - ["mp2776mx_ar_it",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__itruediv__"], false]
