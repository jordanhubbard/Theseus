spec: token_extra5
version: ">=3.12"
backend: python_module(token)

docs: https://docs.python.org/3/library/token.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/token.html — Python token module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/token.py"
    - "token.zspec.zsdl — covers ENDMARKER/NAME/NUMBER/STRING/NEWLINE/INDENT/DEDENT exact values, OP/TYPE_COMMENT/SOFT_KEYWORD/COMMENT/NL/ERRORTOKEN/ENCODING exact values, NT_OFFSET, tok_name lookups [0-6], ISEOF/ISTERMINAL/ISNONTERMINAL predicates"
    - "token_extra.zspec.zsdl — covers int type checks for NAME/NUMBER/STRING/OP/COMMENT/NEWLINE/ENDMARKER/INDENT/DEDENT/ERRORTOKEN, tok_name/EXACT_TOKEN_TYPES is_dict, NAME/NUMBER/STRING/NEWLINE/ENDMARKER exact values"
    - "token_extra2.zspec.zsdl — covers EXACT_TYPE/ERRORTOKEN/ENCODING/TYPE_COMMENT is_int, tok_name is_dict, tok_name min_length>=50, tok_name[0-4], ENDMARKER==0"
    - "token_extra3.zspec.zsdl — covers int type checks for NAME/NUMBER/STRING/OP/NEWLINE/ENDMARKER/INDENT/DEDENT/COMMENT/NL via tables, tok_name/EXACT_TOKEN_TYPES is_dict, NAME>0/NUMBER>0/ENDMARKER==0, tok_name[1]=='NAME', EXACT_TOKEN_TYPES nonempty, tok_name nonempty"
    - "token_extra4.zspec.zsdl — covers INDENT==5, DEDENT==6, tok_name[2-6], EXACT_TOKEN_TYPES membership for '='/'+'/':',, tok_name[4]=='NEWLINE', INDENT>NEWLINE/DEDENT>INDENT ordering"
  notes:
    - "This spec adds Python 3.12+ token constants not covered in any prior token spec."
    - "SOFT_KEYWORD (value 58) was added in Python 3.12 for context-sensitive soft keywords."
    - "FSTRING_START (value 59) and FSTRING_END (value 61) were added in Python 3.12 for f-string token support."
    - "N_TOKENS (value 69) is the total count of token types on Python 3.14; prior token specs do not check this constant."
    - "tok_name[58]=='SOFT_KEYWORD' and tok_name[59]=='FSTRING_START' — dict round-trips for Python 3.12+ constants."
    - "EXACT_TOKEN_TYPES.__len__() >= 40 — on Python 3.12+ the map has at least 48 operator entries."
    - "tok_name.__len__() >= 60 — on Python 3.12+ the dict has at least 69 entries."
    - "EXACT_TOKEN_TYPES contains '(' and ')' — parentheses are single-character exact tokens (values 7 and 8)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Python 3.12+ token constants — SOFT_KEYWORD, FSTRING_START, FSTRING_END
# None of these appear in any prior token spec.
# ---------------------------------------------------------------------------

invariant token_extra5.SOFT_KEYWORD.is_int:
  description: "token.SOFT_KEYWORD.__class__.__name__ == 'int' — SOFT_KEYWORD is a plain int"
  category: constant_types
  kind: python_call_eq
  function: SOFT_KEYWORD.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant token_extra5.SOFT_KEYWORD.value:
  description: "token.SOFT_KEYWORD == 58 (Python 3.12+)"
  category: constant_values
  kind: python_call_eq
  function: SOFT_KEYWORD.__eq__
  args: [58]
  expected: true

invariant token_extra5.FSTRING_START.is_int:
  description: "token.FSTRING_START.__class__.__name__ == 'int' — FSTRING_START is a plain int (Python 3.12+)"
  category: constant_types
  kind: python_call_eq
  function: FSTRING_START.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant token_extra5.FSTRING_START.value:
  description: "token.FSTRING_START == 59 (Python 3.12+)"
  category: constant_values
  kind: python_call_eq
  function: FSTRING_START.__eq__
  args: [59]
  expected: true

invariant token_extra5.FSTRING_END.is_int:
  description: "token.FSTRING_END.__class__.__name__ == 'int' — FSTRING_END is a plain int (Python 3.12+)"
  category: constant_types
  kind: python_call_eq
  function: FSTRING_END.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant token_extra5.FSTRING_END.value:
  description: "token.FSTRING_END == 61 (Python 3.12+)"
  category: constant_values
  kind: python_call_eq
  function: FSTRING_END.__eq__
  args: [61]
  expected: true

# ---------------------------------------------------------------------------
# tok_name dict round-trips for Python 3.12+ constants
# token_extra4 covers tok_name[2-6]; this adds tok_name[58] and tok_name[59].
# ---------------------------------------------------------------------------

table token_extra5.tok_name_new_constants:
  kind: python_call_eq
  category: tok_name
  id_prefix: tok_name_new

  columns: [id, function, args, expected]
  rows:
    - [soft_keyword,  tok_name.__getitem__, [58], "SOFT_KEYWORD"]
    - [fstring_start, tok_name.__getitem__, [59], "FSTRING_START"]

# ---------------------------------------------------------------------------
# tok_name length — Python 3.12+ adds new token types; total >= 60
# token_extra2 covers >= 50; this tightens the bound for 3.12+.
# ---------------------------------------------------------------------------

invariant token_extra5.tok_name.len_ge_60:
  description: "len(token.tok_name) >= 60 — Python 3.12+ defines at least 69 token types"
  category: tok_name
  kind: python_call_eq
  function: tok_name.__len__
  args: []
  method: __ge__
  method_args: [60]
  expected: true

# ---------------------------------------------------------------------------
# EXACT_TOKEN_TYPES length and additional membership checks
# token_extra4 covers membership for '=', '+', ':'; this adds '(' and ')'.
# ---------------------------------------------------------------------------

invariant token_extra5.EXACT_TOKEN_TYPES.len_ge_40:
  description: "len(token.EXACT_TOKEN_TYPES) >= 40 — Python 3.12+ has at least 48 entries"
  category: dict_contents
  kind: python_call_eq
  function: EXACT_TOKEN_TYPES.__len__
  args: []
  method: __ge__
  method_args: [40]
  expected: true

invariant token_extra5.EXACT_TOKEN_TYPES.has_lpar:
  description: "token.EXACT_TOKEN_TYPES.__contains__('(') == True — left paren is an exact token"
  category: dict_contents
  kind: python_call_eq
  function: EXACT_TOKEN_TYPES.__contains__
  args: ["("]
  expected: true

invariant token_extra5.EXACT_TOKEN_TYPES.has_rpar:
  description: "token.EXACT_TOKEN_TYPES.__contains__(')') == True — right paren is an exact token"
  category: dict_contents
  kind: python_call_eq
  function: EXACT_TOKEN_TYPES.__contains__
  args: [")"]
  expected: true

invariant token_extra5.EXACT_TOKEN_TYPES.has_dot:
  description: "token.EXACT_TOKEN_TYPES.__contains__('.') == True — dot is an exact token"
  category: dict_contents
  kind: python_call_eq
  function: EXACT_TOKEN_TYPES.__contains__
  args: ["."]
  expected: true
