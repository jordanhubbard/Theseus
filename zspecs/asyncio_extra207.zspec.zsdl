spec: asyncio_extra207
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py, Lib/asyncio/runners.py"
  notes:
    - "asyncio.sleep.__code__.co_flags == 67108995 — sleep is an async coroutine function; CO_COROUTINE flag (0x100) and CO_OPTIMIZED (0x1), CO_NEWLOCALS (0x2) are set; co_flags.__class__.__name__ == 'int' because co_flags is always an integer bitmask."
    - "asyncio.gather.__code__.co_flags == 67108871 — gather is an async coroutine function; CO_COROUTINE (0x100), CO_OPTIMIZED (0x1), CO_NEWLOCALS (0x2), CO_VARARGS (0x4) bits set; co_flags.__class__.__name__ == 'int'."
    - "asyncio.run.__code__.co_stacksize == 7 — run is a regular (non-async) function that sets up and runs an event loop; co_stacksize is always int."
    - "asyncio.sleep.__code__.co_filename.__class__.__name__ == 'str' — co_filename is the path string to the source file; for asyncio.sleep this is the asyncio/tasks.py path."
    - "asyncio.gather.__code__.co_stacksize == 6; asyncio.sleep.__code__.co_stacksize == 6 — both coroutines have the same stack depth."
    - "asyncio.run.__code__.co_flags == 67108867 — run is a regular function (no CO_COROUTINE); flags include CO_OPTIMIZED (0x1), CO_NEWLOCALS (0x2)."
    - "asyncio.gather co_filename and asyncio.sleep co_filename both point to asyncio/tasks.py — gather and sleep are defined together in the tasks module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio co_flags __class__.__name__ checks
#
# asyncio.sleep.__code__.co_flags.__class__.__name__  == 'int'
# asyncio.gather.__code__.co_flags.__class__.__name__ == 'int'
# asyncio.run.__code__.co_stacksize.__class__.__name__ == 'int'
# asyncio.sleep.__code__.co_filename.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table asyncio_extra207.asyncio_code_attr_types:
  description: "asyncio function __code__ attribute type name checks in asynciocoflags207 namespace — asyncio.sleep.__code__.co_flags.__class__.__name__=='int' (co_flags is always an integer bitmask; CO_COROUTINE|CO_OPTIMIZED|CO_NEWLOCALS bits give 67108995); asyncio.gather.__code__.co_flags.__class__.__name__=='int' (gather is also async, flags=67108871 including CO_VARARGS); asyncio.run.__code__.co_stacksize.__class__.__name__=='int' (co_stacksize is the required stack depth integer, value=7); asyncio.sleep.__code__.co_filename.__class__.__name__=='str' (co_filename is the source path string pointing to asyncio/tasks.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attr_types
  id_prefix: asynciocoflags207

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_coflags_type_eq,    asyncio.sleep.__code__.co_flags.__class__.__name__.__eq__,     ["int"], true, "asyncio.sleep.__code__.co_flags.__class__.__name__ == 'int' — co_flags is an integer bitmask; verified Python 3.14.3"]
    - [gather_coflags_type_eq,   asyncio.gather.__code__.co_flags.__class__.__name__.__eq__,    ["int"], true, "asyncio.gather.__code__.co_flags.__class__.__name__ == 'int' — co_flags is an integer bitmask; verified Python 3.14.3"]
    - [run_costacksize_type_eq,  asyncio.run.__code__.co_stacksize.__class__.__name__.__eq__,   ["int"], true, "asyncio.run.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is an integer; verified Python 3.14.3"]
    - [sleep_cofilename_type_eq, asyncio.sleep.__code__.co_filename.__class__.__name__.__eq__,  ["str"], true, "asyncio.sleep.__code__.co_filename.__class__.__name__ == 'str' — co_filename is a string path; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: asyncio co_flags integer values
#
# asyncio.sleep.__code__.co_flags  == 67108995
# asyncio.gather.__code__.co_flags == 67108871
# asyncio.run.__code__.co_flags    == 67108867
# asyncio.run.__code__.co_stacksize == 7
# asyncio.sleep.__code__.co_stacksize == 6
# asyncio.gather.__code__.co_stacksize == 6
# ---------------------------------------------------------------------------

table asyncio_extra207.asyncio_code_flag_values:
  description: "asyncio function __code__.co_flags and co_stacksize integer value checks in asynciocoflags207 namespace — sleep.co_flags==67108995 (async coroutine with CO_COROUTINE|CO_OPTIMIZED|CO_NEWLOCALS; higher than run's 67108867 because CO_COROUTINE is set); gather.co_flags==67108871 (async coroutine with additional CO_VARARGS bit, lower than sleep because *aws varargs replaces other flags); run.co_flags==67108867 (regular function, no CO_COROUTINE, just CO_OPTIMIZED|CO_NEWLOCALS); run.co_stacksize==7; sleep.co_stacksize==6; gather.co_stacksize==6; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_flag_values
  id_prefix: asynciocoflags207a

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_coflags_val,        asyncio.sleep.__code__.co_flags.__eq__,       [67108995], true, "asyncio.sleep.__code__.co_flags == 67108995 — async coroutine with CO_COROUTINE bit set; verified Python 3.14.3"]
    - [gather_coflags_val,       asyncio.gather.__code__.co_flags.__eq__,      [67108871], true, "asyncio.gather.__code__.co_flags == 67108871 — async coroutine with CO_VARARGS; verified Python 3.14.3"]
    - [run_coflags_val,          asyncio.run.__code__.co_flags.__eq__,         [67108867], true, "asyncio.run.__code__.co_flags == 67108867 — regular (non-async) function; verified Python 3.14.3"]
    - [run_costacksize_val,      asyncio.run.__code__.co_stacksize.__eq__,     [7],        true, "asyncio.run.__code__.co_stacksize == 7; verified Python 3.14.3"]
    - [sleep_costacksize_val,    asyncio.sleep.__code__.co_stacksize.__eq__,   [6],        true, "asyncio.sleep.__code__.co_stacksize == 6; verified Python 3.14.3"]
    - [gather_costacksize_val,   asyncio.gather.__code__.co_stacksize.__eq__,  [6],        true, "asyncio.gather.__code__.co_stacksize == 6 (same as sleep); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: asyncio co_filename __class__.__name__ and run type checks
#
# asyncio.run.__code__.co_filename.__class__.__name__   == 'str'
# asyncio.gather.__code__.co_filename.__class__.__name__ == 'str'
# asyncio.run.__code__.co_stacksize == 7 (int)
# asyncio.gather.__code__.co_flags.__class__.__name__   == 'int'
# ---------------------------------------------------------------------------

table asyncio_extra207.asyncio_run_gather_code_attrs:
  description: "asyncio.run and asyncio.gather __code__ attribute type and value checks in asynciocoflags207 namespace — run.__code__.co_filename.__class__.__name__=='str' (co_filename is always str; run is in asyncio/runners.py); gather.__code__.co_filename.__class__.__name__=='str' (gather is in asyncio/tasks.py, same file as sleep); run.__code__.co_stacksize.__class__.__name__=='int'; gather.__code__.co_flags.__class__.__name__=='int'; all __code__ integer attributes (co_flags, co_stacksize, co_argcount) are plain Python int; all __code__ filename attributes are plain Python str; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attr_types
  id_prefix: asynciocoflags207b

  columns: [id, function, args, expected, description]
  rows:
    - [run_cofilename_type_eq,    asyncio.run.__code__.co_filename.__class__.__name__.__eq__,    ["str"], true, "asyncio.run.__code__.co_filename.__class__.__name__ == 'str'; verified Python 3.14.3"]
    - [gather_cofilename_type_eq, asyncio.gather.__code__.co_filename.__class__.__name__.__eq__, ["str"], true, "asyncio.gather.__code__.co_filename.__class__.__name__ == 'str'; verified Python 3.14.3"]
    - [run_costacksize_type2_eq,  asyncio.run.__code__.co_stacksize.__class__.__name__.__eq__,   ["int"], true, "asyncio.run.__code__.co_stacksize.__class__.__name__ == 'int'; verified Python 3.14.3"]
    - [gather_coflags_type2_eq,   asyncio.gather.__code__.co_flags.__class__.__name__.__eq__,    ["int"], true, "asyncio.gather.__code__.co_flags.__class__.__name__ == 'int'; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra207
# ---------------------------------------------------------------------------

invariant asyncio_extra207.sleep_coflags_type_int:
  description: "asyncio.sleep.__code__.co_flags.__class__.__name__.__eq__('int') returns True — asyncio.sleep is an async coroutine function defined in Lib/asyncio/tasks.py; co_flags is always an integer bitmask regardless of whether the function is async or not; sleep.co_flags==67108995 (CO_COROUTINE|CO_OPTIMIZED|CO_NEWLOCALS bits set); the __class__.__name__ chain returns 'int' (len=3: i-n-t); NEW in extra207: first standalone asyncio sleep co_flags type invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attr_types
  kind: python_call_eq
  function: asyncio.sleep.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant asyncio_extra207.gather_coflags_type_int:
  description: "asyncio.gather.__code__.co_flags.__class__.__name__.__eq__('int') returns True — asyncio.gather is an async coroutine function defined in Lib/asyncio/tasks.py alongside sleep; gather.co_flags==67108871 (includes CO_VARARGS because gather takes *aws); the __class__.__name__ chain traverses: int object -> type 'int' -> name 'int'; co_flags.__class__ is the built-in int type; co_flags.__class__.__name__ is 'int' (len=3); NEW in extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attr_types
  kind: python_call_eq
  function: asyncio.gather.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant asyncio_extra207.run_costacksize_type_int:
  description: "asyncio.run.__code__.co_stacksize.__class__.__name__.__eq__('int') returns True — asyncio.run is a regular (non-async) function that launches the event loop; run.co_stacksize==7 (larger than gather/sleep co_stacksize of 6); co_stacksize is the number of stack slots required by the function's bytecode; co_stacksize.__class__.__name__ is 'int' (len=3); run.co_flags==67108867 (no CO_COROUTINE bit unlike sleep's 67108995); NEW in extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attr_types
  kind: python_call_eq
  function: asyncio.run.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant asyncio_extra207.sleep_cofilename_type_str:
  description: "asyncio.sleep.__code__.co_filename.__class__.__name__.__eq__('str') returns True — co_filename is the source file path string where the function was defined; asyncio.sleep is defined in Lib/asyncio/tasks.py; co_filename.__class__ is the built-in str type; co_filename.__class__.__name__ is 'str' (len=3: s-t-r); contrast with frozen modules where co_filename would be '<frozen xyz>'; NEW in extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attr_types
  kind: python_call_eq
  function: asyncio.sleep.__code__.co_filename.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant asyncio_extra207.sleep_coflags_value:
  description: "asyncio.sleep.__code__.co_flags.__eq__(67108995) returns True — asyncio.sleep co_flags value is 67108995; this integer encodes several compiler flags as a bitmask: CO_OPTIMIZED (0x1), CO_NEWLOCALS (0x2), CO_COROUTINE (0x100 = 256) and additional interpreter-defined high bits; sleep.co_flags (67108995) > gather.co_flags (67108871) > run.co_flags (67108867) because sleep uses more flag bits than gather and run; NEW in extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_flag_values
  kind: python_call_eq
  function: asyncio.sleep.__code__.co_flags.__eq__
  args: [67108995]
  expected: true

invariant asyncio_extra207.gather_coflags_value:
  description: "asyncio.gather.__code__.co_flags.__eq__(67108871) returns True — asyncio.gather co_flags value is 67108871; gather takes *aws (variable positional args) so CO_VARARGS (0x4) is set; gather.co_flags (67108871) < sleep.co_flags (67108995); gather is also async so CO_COROUTINE is set; gather.co_stacksize==6 (same as sleep.co_stacksize); gather.__code__.co_filename and sleep.__code__.co_filename both point to asyncio/tasks.py; NEW in extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_flag_values
  kind: python_call_eq
  function: asyncio.gather.__code__.co_flags.__eq__
  args: [67108871]
  expected: true

invariant asyncio_extra207.run_costacksize_value:
  description: "asyncio.run.__code__.co_stacksize.__eq__(7) returns True — asyncio.run co_stacksize is 7; run has the largest co_stacksize among the three functions (run=7 > sleep=6 == gather=6); co_stacksize represents the maximum depth of the Python value stack required for the function's bytecode; asyncio.run is a regular (non-async) function that creates an event loop, so its co_flags==67108867 lacks the CO_COROUTINE bit; NEW in extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_flag_values
  kind: python_call_eq
  function: asyncio.run.__code__.co_stacksize.__eq__
  args: [7]
  expected: true

invariant asyncio_extra207.run_coflags_value:
  description: "asyncio.run.__code__.co_flags.__eq__(67108867) returns True — asyncio.run co_flags is 67108867; run is a regular (synchronous) function — it does NOT have the CO_COROUTINE bit (0x100=256) that sleep (67108995) and gather (67108871) have; run.co_flags == gather.co_flags - 4 (the CO_VARARGS bit difference); run.__code__.co_stacksize is 7 while sleep and gather co_stacksize are both 6; run.__code__.co_filename points to asyncio/runners.py (different file from sleep/gather which are in tasks.py); NEW in extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_flag_values
  kind: python_call_eq
  function: asyncio.run.__code__.co_flags.__eq__
  args: [67108867]
  expected: true
