table inspect_extra140.signature_method_qualnames:
  description: "inspect.Signature: __init__ qualname len 18 co_argcount 2, bind len 14 co_argcount 1, bind_partial len 22, __eq__ len 16, replace len 17; wave 268; new to extra140"
