# ---------------------------------------------------------------------------
# Standalone invariants — extra140
# ---------------------------------------------------------------------------

invariant inspect_extra140.signature_is_type:
  description: "inspect.Signature.__class__.__name__ == 'type' — Signature is a Python class; wave 268; new to extra140"
  kind: python_call_eq
  function: Signature.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra140.signature_name_len:
  description: "len(inspect.Signature.__name__) == 9 — __name__ is 'Signature'; wave 268; new to extra140"
  kind: python_call_eq
  function: Signature.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra140.signature_mro_len:
  description: "len(inspect.Signature.__mro__) == 2 — Signature's MRO is [Signature, object]; wave 268; new to extra140"
  kind: python_call_eq
  function: Signature.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra140.signature_doc_len:
  description: "len(inspect.Signature.__doc__) == 970 — the Signature docstring has 970 characters; wave 268; new to extra140"
  kind: python_call_eq
  function: Signature.__doc__.__len__
  args: []
  expected: 970

invariant inspect_extra140.signature_init_argcount:
  description: "inspect.Signature.__init__.__code__.co_argcount == 2 — takes self, parameters; wave 268; new to extra140"
  kind: python_call_eq
  function: Signature.__init__.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra140.signature_bind_qualname_len:
  description: "len(inspect.Signature.bind.__qualname__) == 14 — __qualname__ is 'Signature.bind'; wave 268; new to extra140"
  kind: python_call_eq
