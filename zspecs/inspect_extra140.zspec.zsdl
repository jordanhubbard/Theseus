       ["Signature.__eq__"],
       true,
       "inspect.Signature.__eq__.__qualname__.__eq__('Signature.__eq__') == True — __eq__ is a Python function defined on Signature; its qualname is 'Signature.__eq__'; str.__eq__ returns True; new to extra140"]
    - [sig_eq_qualname_len_eq_16,
       "Signature.__eq__.__qualname__.__len__",
       [],
       16,
       "inspect.Signature.__eq__.__qualname__.__len__() == 16 — __qualname__ is 'Signature.__eq__' which has 16 characters; len() == 16; new to extra140"]
    - [sig_replace_qualname_eq,
