  kind: python_call_eq
  function: isfunction.__doc__.__len__
  args: []
  expected: 817

invariant inspect_extra140.isfunction_co_argcount:
  description: "inspect.isfunction.__code__.co_argcount == 1 — takes a single object argument; wave 268; new to extra140"
  kind: python_call_eq
  function: isfunction.__code__.co_argcount.__eq__
  args: [1]
  expected: true

