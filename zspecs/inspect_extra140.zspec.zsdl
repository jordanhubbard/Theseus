    - [sig_doc_class_eq_str,
       "Signature.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "inspect.Signature.__doc__.__class__.__name__.__eq__('str') == True — the Signature docstring is a plain Python str; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra140"]
    - [sig_doc_len_eq_970,
       "Signature.__doc__.__len__",
       [],
       970,
       "inspect.Signature.__doc__.__len__() == 970 — the Signature docstring has 970 characters; len(__doc__) == 970; verified with Python 3.14.3; new to extra140"]

