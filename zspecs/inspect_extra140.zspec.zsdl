    - [sig_bind_co_argcount_eq_1,
       "Signature.bind.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.Signature.bind.__code__.co_argcount.__eq__(1) == True — bind takes 1 positional-or-keyword argument (self); *args and **kwargs are varargs; co_argcount is 1; int.__eq__(1) returns True; new to extra140"]
    - [sig_bind_partial_qualname_eq,
       "Signature.bind_partial.__qualname__.__eq__",
       ["Signature.bind_partial"],
       true,
       "inspect.Signature.bind_partial.__qualname__.__eq__('Signature.bind_partial') == True — bind_partial is a Python function on Signature; its qualname is 'Signature.bind_partial'; str.__eq__ returns True; new to extra140"]
    - [sig_bind_partial_qualname_len_eq_22,
