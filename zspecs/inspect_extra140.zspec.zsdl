       [],
       10,
       "inspect.isfunction.__qualname__.__len__() == 10 — __qualname__ is 'isfunction' which has 10 characters; len('isfunction') == 10; new to extra140"]
    - [isfunction_module_eq_inspect,
       "isfunction.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isfunction.__module__.__eq__('inspect') == True — isfunction is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra140"]
    - [isfunction_module_len_eq_7,
       "isfunction.__module__.__len__",
       [],
       7,
       "inspect.isfunction.__module__.__len__() == 7 — __module__ is 'inspect' which has 7 characters; len('inspect') == 7; new to extra140"]
    - [isfunction_co_argcount_eq_1,
