spec: inspect_extra140
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Signature (Python class) and inspect.isfunction (Python function) — class identity, __name__, __module__, __bases__, MRO, __doc__, __init__/__bind/__bind_partial/__eq__/replace qualnames and co_argcount values (Wave 268)."
    - "inspect.Signature.__name__ == 'Signature' (len 9). Verified with Python 3.14.3."
    - "inspect.Signature.__module__ == 'inspect' (len 7). Verified with Python 3.14.3."
    - "inspect.Signature.__bases__[0].__name__ == 'object' — directly inherits object. Verified with Python 3.14.3."
    - "len(inspect.Signature.__mro__) == 2 — MRO is [Signature, object]. Verified with Python 3.14.3."
    - "len(inspect.Signature.__doc__) == 970 — Signature docstring has 970 characters. Verified with Python 3.14.3."
    - "inspect.Signature.__init__.__qualname__ == 'Signature.__init__' (len 18). Verified with Python 3.14.3."
    - "inspect.Signature.__init__.__code__.co_argcount == 2 (self, parameters). Verified with Python 3.14.3."
    - "inspect.Signature.bind.__qualname__ == 'Signature.bind' (len 14). Verified with Python 3.14.3."
    - "inspect.Signature.bind.__code__.co_argcount == 1 (self; args/kwargs are varargs). Verified with Python 3.14.3."
    - "inspect.Signature.bind_partial.__qualname__ == 'Signature.bind_partial' (len 22). Verified with Python 3.14.3."
    - "inspect.Signature.__eq__.__qualname__ == 'Signature.__eq__' (len 16). Verified with Python 3.14.3."
    - "inspect.Signature.replace.__qualname__ == 'Signature.replace' (len 17). Verified with Python 3.14.3."
    - "inspect.isfunction.__doc__.__class__.__name__ == 'str' (len 817). Verified with Python 3.14.3."
    - "inspect.isfunction.__qualname__ == 'isfunction' (len 10). Verified with Python 3.14.3."
    - "inspect.isfunction.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Signature — class identity and MRO
#
# Wave 268 theme: inspect.Signature — Python class identity.
#
# inspect.Signature.__class__.__name__ == 'type'
# inspect.Signature.__name__ == 'Signature' (len 9)
# inspect.Signature.__module__ == 'inspect' (len 7)
# inspect.Signature.__bases__[0].__name__ == 'object'
# len(inspect.Signature.__mro__) == 2
#
# Signature is a pure Python class defined in Lib/inspect.py that represents
# the call signature of a callable. New to extra140.
# ---------------------------------------------------------------------------

table inspect_extra140.signature_class_identity:
  description: "inspect.Signature: Python class (type), __name__ len 9, __module__ len 7, MRO len 2; wave 268; new to extra140"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectsig140

  columns: [id, function, args, expected, description]
  rows:
    - [sig_class_eq_type,
       "Signature.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Signature.__class__.__name__.__eq__('type') == True — Signature is a Python class defined in Lib/inspect.py; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra140"]
    - [sig_name_eq,
       "Signature.__name__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — the class __name__ is 'Signature'; str.__eq__('Signature') returns True; new to extra140"]
    - [sig_name_len_eq_9,
       "Signature.__name__.__len__",
       [],
       9,
       "inspect.Signature.__name__.__len__() == 9 — __name__ is 'Signature' which has 9 characters; len('Signature') == 9; new to extra140"]
    - [sig_module_eq_inspect,
       "Signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra140"]
    - [sig_module_len_eq_7,
       "Signature.__module__.__len__",
       [],
       7,
       "inspect.Signature.__module__.__len__() == 7 — __module__ is 'inspect' which has 7 characters; len('inspect') == 7; new to extra140"]
    - [sig_bases_0_eq_object,
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature directly inherits from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra140"]
    - [sig_mro_len_eq_2,
       "Signature.__mro__.__len__",
       [],
       2,
       "inspect.Signature.__mro__.__len__() == 2 — Signature's MRO is [Signature, object]; len(__mro__) is 2; new to extra140"]

