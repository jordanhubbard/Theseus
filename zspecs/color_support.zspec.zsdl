spec: color_support
version: ">=1.1.0"
backend: node(color-support)

docs: https://github.com/tapjs/color-support#readme

provenance:
  derived_from:
    - "color-support README — https://github.com/tapjs/color-support#readme"
    - "Test vectors verified with color-support via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "color-support source"
  notes:
    - "Detects terminal color capability — basic / 256 / 16m — without needing chalk."
    - "Install: npm install color-support"
    - "v1 CJS; module export IS the detector. Pass {level: N} to force a specific level."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "When forced via {level}, behaves deterministically; otherwise sniffs env vars + isTTY."
  codes: {}

invariant color_support.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant color_support.level_0_returns_false:
  description: "Forced level 0 returns boolean false (no color)"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [{"level": 0}]
  chain: []
  expected: false

invariant color_support.level_1_basic:
  description: "Forced level 1 has hasBasic=true"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [{"level": 1}]
  chain:
    - {get: hasBasic}
  expected: true

invariant color_support.level_1_no_256:
  description: "Forced level 1 does not have 256-color support"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [{"level": 1}]
  chain:
    - {get: has256}
  expected: false

invariant color_support.level_2_has_256:
  description: "Forced level 2 has has256=true"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [{"level": 2}]
  chain:
    - {get: has256}
  expected: true

invariant color_support.level_2_no_16m:
  description: "Forced level 2 does not have 16m support"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [{"level": 2}]
  chain:
    - {get: has16m}
  expected: false

invariant color_support.level_3_has_16m:
  description: "Forced level 3 has has16m=true"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [{"level": 3}]
  chain:
    - {get: has16m}
  expected: true

invariant color_support.level_3_carries_level:
  description: "Forced level 3 reports level=3"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [{"level": 3}]
  chain:
    - {get: level}
  expected: 3

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:31:23Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
