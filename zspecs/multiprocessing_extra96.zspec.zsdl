spec: multiprocessing_extra96
version: ">=3.9"
backend: python_module(multiprocessing)
extends: multiprocessing_extra95

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/connection.py"
  notes:
    - "This spec extends multiprocessing_extra95.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing Pipe/Queue/Lock/RLock/Value/Array/Pool class identity (all are bound context methods). NEW in extra96: multiprocessing.Pipe.__class__.__name__=='method'; multiprocessing.Pipe.__module__=='multiprocessing.context'; multiprocessing.Pipe.__qualname__=='BaseContext.Pipe' (len=16); multiprocessing.Queue.__class__.__name__=='method'; multiprocessing.Queue.__qualname__=='BaseContext.Queue' (len=17); multiprocessing.Lock.__class__.__name__=='method'; multiprocessing.Lock.__qualname__=='BaseContext.Lock' (len=16); multiprocessing.RLock.__class__.__name__=='method'; multiprocessing.RLock.__qualname__=='BaseContext.RLock' (len=17); multiprocessing.Value.__class__.__name__=='method'; multiprocessing.Value.__qualname__=='BaseContext.Value' (len=17); multiprocessing.Array.__class__.__name__=='method'; multiprocessing.Array.__qualname__=='BaseContext.Array' (len=17); multiprocessing.Pool.__class__.__name__=='method'; multiprocessing.Pool.__qualname__=='BaseContext.Pool' (len=16); multiprocessing.Process.__class__.__name__=='type' (Process is an actual class, unlike the others). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pipe.__class__.__name__ == 'method'. Pipe is a bound context method (like Manager, cpu_count), not a standalone function or class. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Queue.__qualname__ == 'BaseContext.Queue' (len=17). Queue is a bound context method. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__class__.__name__ == 'type'. Process is an actual class (type), unlike Pipe/Queue/Lock which are bound methods. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Pipe and Queue identity — extra96
#
# Wave 254 theme: multiprocessing Pipe/Queue/Lock/RLock/Value/Array/Pool identity.
#
# multiprocessing.Pipe.__class__.__name__ == 'method'
# multiprocessing.Pipe.__module__ == 'multiprocessing.context'
# multiprocessing.Pipe.__qualname__ == 'BaseContext.Pipe' (len=16)
# multiprocessing.Queue.__class__.__name__ == 'method'
# multiprocessing.Queue.__qualname__ == 'BaseContext.Queue' (len=17)
# ---------------------------------------------------------------------------

table multiprocessing_extra96.mp_pipe_queue_identity:
  description: "multiprocessing.Pipe and multiprocessing.Queue identity checks in mppipequeueid96 namespace — wave 254 theme: multiprocessing Pipe/Queue identity; multiprocessing.Pipe and multiprocessing.Queue are bound methods of the process context object (BaseContext), not standalone functions or classes; multiprocessing.Pipe.__class__.__name__.__eq__('method')==True; multiprocessing.Pipe.__module__.__eq__('multiprocessing.context')==True (defined in Lib/multiprocessing/context.py); multiprocessing.Pipe.__qualname__.__eq__('BaseContext.Pipe')==True (len=16, 'BaseContext.' prefix 12 chars + 'Pipe' 4 chars); multiprocessing.Queue.__class__.__name__.__eq__('method')==True; multiprocessing.Queue.__module__.__eq__('multiprocessing.context')==True; multiprocessing.Queue.__qualname__.__eq__('BaseContext.Queue')==True (len=17, one char longer than Pipe because 'Queue' is 5 chars vs 'Pipe' 4 chars); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppipequeueid96

  columns: [id, function, args, expected, description]
  rows:
    - [pipe_class_nm,  "multiprocessing.Pipe.__class__.__name__.__eq__",      ["method"],                   true, "multiprocessing.Pipe.__class__.__name__ == 'method' — bound context method; verified with Python 3.14.3"]
    - [pipe_module,    "multiprocessing.Pipe.__module__.__eq__",               ["multiprocessing.context"],  true, "multiprocessing.Pipe.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [pipe_qualname,  "multiprocessing.Pipe.__qualname__.__eq__",             ["BaseContext.Pipe"],         true, "multiprocessing.Pipe.__qualname__ == 'BaseContext.Pipe' (len=16); verified with Python 3.14.3"]
    - [pipe_qlen,      "multiprocessing.Pipe.__qualname__.__len__",            [],                           16,   "multiprocessing.Pipe.__qualname__.__len__() == 16; verified with Python 3.14.3"]
    - [queue_class_nm, "multiprocessing.Queue.__class__.__name__.__eq__",      ["method"],                   true, "multiprocessing.Queue.__class__.__name__ == 'method' — bound context method; verified with Python 3.14.3"]
    - [queue_module,   "multiprocessing.Queue.__module__.__eq__",              ["multiprocessing.context"],  true, "multiprocessing.Queue.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [queue_qualname, "multiprocessing.Queue.__qualname__.__eq__",            ["BaseContext.Queue"],        true, "multiprocessing.Queue.__qualname__ == 'BaseContext.Queue' (len=17); verified with Python 3.14.3"]
    - [queue_qlen,     "multiprocessing.Queue.__qualname__.__len__",           [],                           17,   "multiprocessing.Queue.__qualname__.__len__() == 17 (one char longer than Pipe len=16); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Lock and RLock identity — extra96
#
# multiprocessing.Lock.__class__.__name__ == 'method'
# multiprocessing.Lock.__module__ == 'multiprocessing.context'
# multiprocessing.Lock.__qualname__ == 'BaseContext.Lock' (len=16)
# multiprocessing.RLock.__class__.__name__ == 'method'
# multiprocessing.RLock.__module__ == 'multiprocessing.context'
# multiprocessing.RLock.__qualname__ == 'BaseContext.RLock' (len=17)
# ---------------------------------------------------------------------------

table multiprocessing_extra96.mp_lock_rlock_identity:
  description: "multiprocessing.Lock and multiprocessing.RLock identity checks in mppipequeueid96 namespace — wave 254 theme: multiprocessing Lock/RLock identity; multiprocessing.Lock and multiprocessing.RLock are bound methods of the process context, returning platform-specific lock objects; multiprocessing.Lock.__class__.__name__.__eq__('method')==True; multiprocessing.Lock.__module__.__eq__('multiprocessing.context')==True; multiprocessing.Lock.__qualname__.__eq__('BaseContext.Lock')==True (len=16, same as Pipe — 'Lock' is 4 chars like 'Pipe'); multiprocessing.RLock.__class__.__name__.__eq__('method')==True; multiprocessing.RLock.__module__.__eq__('multiprocessing.context')==True; multiprocessing.RLock.__qualname__.__eq__('BaseContext.RLock')==True (len=17, same as Queue — 'RLock' is 5 chars like 'Queue'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppipequeueid96a

  columns: [id, function, args, expected, description]
  rows:
    - [lock_class_nm,  "multiprocessing.Lock.__class__.__name__.__eq__",       ["method"],                   true, "multiprocessing.Lock.__class__.__name__ == 'method' — bound context method; verified with Python 3.14.3"]
    - [lock_module,    "multiprocessing.Lock.__module__.__eq__",                ["multiprocessing.context"],  true, "multiprocessing.Lock.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [lock_qualname,  "multiprocessing.Lock.__qualname__.__eq__",              ["BaseContext.Lock"],         true, "multiprocessing.Lock.__qualname__ == 'BaseContext.Lock' (len=16); verified with Python 3.14.3"]
    - [rlock_class_nm, "multiprocessing.RLock.__class__.__name__.__eq__",       ["method"],                   true, "multiprocessing.RLock.__class__.__name__ == 'method' — bound context method; verified with Python 3.14.3"]
    - [rlock_module,   "multiprocessing.RLock.__module__.__eq__",               ["multiprocessing.context"],  true, "multiprocessing.RLock.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [rlock_qualname, "multiprocessing.RLock.__qualname__.__eq__",             ["BaseContext.RLock"],        true, "multiprocessing.RLock.__qualname__ == 'BaseContext.RLock' (len=17); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Value, Array, Pool identity — extra96
#
# multiprocessing.Value.__class__.__name__ == 'method'
# multiprocessing.Value.__qualname__ == 'BaseContext.Value' (len=17)
# multiprocessing.Array.__class__.__name__ == 'method'
# multiprocessing.Array.__qualname__ == 'BaseContext.Array' (len=17)
# multiprocessing.Pool.__class__.__name__ == 'method'
# multiprocessing.Pool.__qualname__ == 'BaseContext.Pool' (len=16)
# multiprocessing.Process.__class__.__name__ == 'type'
# ---------------------------------------------------------------------------

table multiprocessing_extra96.mp_value_array_pool_identity:
  description: "multiprocessing.Value, Array, Pool, and Process identity checks in mppipequeueid96 namespace — wave 254 theme: multiprocessing shared-memory and pool factory identity; multiprocessing.Value, Array, and Pool are bound context methods (class='method') like Lock/Queue/Pipe; multiprocessing.Value.__class__.__name__.__eq__('method')==True; multiprocessing.Value.__qualname__.__eq__('BaseContext.Value')==True (len=17); multiprocessing.Array.__class__.__name__.__eq__('method')==True; multiprocessing.Array.__qualname__.__eq__('BaseContext.Array')==True (len=17, same length as Value); multiprocessing.Pool.__class__.__name__.__eq__('method')==True; multiprocessing.Pool.__qualname__.__eq__('BaseContext.Pool')==True (len=16, same as Lock and Pipe); contrast: multiprocessing.Process.__class__.__name__.__eq__('type')==True — Process is an actual class (not a bound method), making it unique among the commonly used multiprocessing names; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppipequeueid96b

  columns: [id, function, args, expected, description]
  rows:
    - [value_class_nm,   "multiprocessing.Value.__class__.__name__.__eq__",     ["method"],                   true, "multiprocessing.Value.__class__.__name__ == 'method' — bound context method; verified with Python 3.14.3"]
    - [value_qualname,   "multiprocessing.Value.__qualname__.__eq__",            ["BaseContext.Value"],        true, "multiprocessing.Value.__qualname__ == 'BaseContext.Value' (len=17); verified with Python 3.14.3"]
    - [array_class_nm,   "multiprocessing.Array.__class__.__name__.__eq__",     ["method"],                   true, "multiprocessing.Array.__class__.__name__ == 'method' — bound context method; verified with Python 3.14.3"]
    - [array_qualname,   "multiprocessing.Array.__qualname__.__eq__",            ["BaseContext.Array"],        true, "multiprocessing.Array.__qualname__ == 'BaseContext.Array' (len=17, same as Value); verified with Python 3.14.3"]
    - [pool_class_nm,    "multiprocessing.Pool.__class__.__name__.__eq__",       ["method"],                   true, "multiprocessing.Pool.__class__.__name__ == 'method' — bound context method; verified with Python 3.14.3"]
    - [pool_qualname,    "multiprocessing.Pool.__qualname__.__eq__",             ["BaseContext.Pool"],         true, "multiprocessing.Pool.__qualname__ == 'BaseContext.Pool' (len=16); verified with Python 3.14.3"]
    - [pool_module,      "multiprocessing.Pool.__module__.__eq__",               ["multiprocessing.context"],  true, "multiprocessing.Pool.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [proc_class_nm,    "multiprocessing.Process.__class__.__name__.__eq__",    ["type"],                     true, "multiprocessing.Process.__class__.__name__ == 'type' — Process is an actual class, unlike bound-method factories; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra96
# ---------------------------------------------------------------------------

invariant multiprocessing_extra96.Pipe_is_method_not_function:
  description: "multiprocessing.Pipe.__class__.__name__.__eq__('method') returns True — multiprocessing.Pipe is a bound method of the process context object (BaseContext), not a standalone function or class; this is the same pattern as multiprocessing.Manager (extra95), cpu_count, and freeze_support; Pipe.__qualname__ is 'BaseContext.Pipe' (len=16) reflecting that the underlying method is defined in BaseContext in Lib/multiprocessing/context.py; Pipe creates a pair of connected Connection objects for inter-process communication; contrast with multiprocessing.Process which has class 'type' (it is an actual class); NEW in extra96: first standalone Pipe class name invariant in mppipequeueid96 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.Pipe.__class__.__name__.__eq__"
  args: ["method"]
  expected: true

invariant multiprocessing_extra96.Queue_qualname_eq:
  description: "multiprocessing.Queue.__qualname__.__eq__('BaseContext.Queue') returns True — multiprocessing.Queue.__qualname__ is 'BaseContext.Queue' (len=17) confirming it is a bound method of BaseContext; Queue is a shared inter-process queue implementation; it should not be confused with queue.Queue (the thread-safe queue) or asyncio.Queue (the async queue) — multiprocessing.Queue is backed by pipes and has different performance characteristics; Queue's qualname length (17) is 1 more than Pipe (16) and Pool (16), while matching Lock and Pipe at different counts ('BaseContext.' prefix=12, 'Queue'=5); NEW in extra96: first standalone Queue qualname invariant in mppipequeueid96 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.Queue.__qualname__.__eq__"
  args: ["BaseContext.Queue"]
  expected: true

invariant multiprocessing_extra96.Lock_is_method:
  description: "multiprocessing.Lock.__class__.__name__.__eq__('method') returns True — multiprocessing.Lock is a bound context method returning a platform-specific mutual-exclusion lock; on macOS/Darwin it returns a Semaphore-based lock from the SemLock type; Lock.__qualname__ is 'BaseContext.Lock' (len=16, same as Pipe); multiprocessing.RLock is similarly a bound method ('BaseContext.RLock', len=17); neither Lock nor RLock is an actual class (type) — they are factory methods on the context; this contrasts with multiprocessing.Process which is a genuine class; NEW in extra96: first standalone Lock class name invariant in mppipequeueid96 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.Lock.__class__.__name__.__eq__"
  args: ["method"]
  expected: true

invariant multiprocessing_extra96.Process_is_type:
  description: "multiprocessing.Process.__class__.__name__.__eq__('type') returns True — multiprocessing.Process is an actual Python class (metaclass=type), unlike all the other commonly used multiprocessing names (Pipe, Queue, Lock, RLock, Value, Array, Pool, Manager, cpu_count) which are bound context methods with class='method'; Process.__module__ is 'multiprocessing.context'; Process.__name__ is 'Process'; Process is subclassed by users to implement process-specific logic in the run() method; its class being 'type' means it can be directly subclassed, while the bound-method factories cannot; NEW in extra96: first standalone Process class name invariant distinguishing it from bound-method factories in mppipequeueid96 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.Process.__class__.__name__.__eq__"
  args: ["type"]
  expected: true

invariant multiprocessing_extra96.Pool_qualname_eq:
  description: "multiprocessing.Pool.__qualname__.__eq__('BaseContext.Pool') returns True — multiprocessing.Pool.__qualname__ is 'BaseContext.Pool' (len=16); Pool is a bound context method that creates a process pool for parallel execution; Pool.__module__ is 'multiprocessing.context'; Pool's qualname length (16) matches Pipe (16) and Lock (16) — all three have 4-character names ('Pool', 'Pipe', 'Lock') after the 'BaseContext.' prefix (12 chars); Value (17) and Array (17) are one char longer (5-char names); RLock (17) also 5 chars; Queue (17) also 5 chars; NEW in extra96: first standalone Pool qualname invariant in mppipequeueid96 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.Pool.__qualname__.__eq__"
  args: ["BaseContext.Pool"]
  expected: true
