spec: io_extra118
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec extends io_extra117.zspec.zsdl."
    - "This spec covers: io.BytesIO and io.StringIO and io.FileIO and io.BufferedReader and io.TextIOWrapper __init__ method qualnames and types."
    - "io.BytesIO.__init__.__qualname__ == 'BytesIO.__init__' (len 16); type 'wrapper_descriptor'."
    - "io.StringIO.__init__.__qualname__ == 'StringIO.__init__' (len 17); type 'wrapper_descriptor'."
    - "io.FileIO.__init__.__qualname__ == 'FileIO.__init__' (len 15); type 'wrapper_descriptor'."
    - "io.BufferedReader.__init__.__qualname__ == 'BufferedReader.__init__' (len 23); type 'wrapper_descriptor'."
    - "io.TextIOWrapper.__init__.__qualname__ == 'TextIOWrapper.__init__' (len 22); type 'wrapper_descriptor'."
    - "All five __init__ methods are 'wrapper_descriptor' (C slot wrappers for tp_init)."
    - "io.BytesIO.__module__ == '_io'; io.StringIO.__module__ == '_io'; io.FileIO.__module__ == '_io'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO.__init__ and io.StringIO.__init__ qualnames and types
# BytesIO.__init__: 'BytesIO.__init__' (16 chars); type 'wrapper_descriptor'.
# StringIO.__init__: 'StringIO.__init__' (17 chars); type 'wrapper_descriptor'.
# Both implement the tp_init C slot for their respective in-memory stream types.
# ---------------------------------------------------------------------------

table io_extra118.BytesIO_StringIO_init_qualnames:
  description: "io.BytesIO.__init__ qualname='BytesIO.__init__'(16), io.StringIO.__init__ qualname='StringIO.__init__'(17); both type 'wrapper_descriptor'; C tp_init slot wrappers"
  kind: python_call_eq
  category: qualnames
  id_prefix: ioinit118a

  columns: [id, function, args, expected, description]
  rows:
    - [bytesio_init_type,     "BytesIO.__init__.__class__.__name__.__eq__",   ["wrapper_descriptor"],   true,  "type(io.BytesIO.__init__).__name__ == 'wrapper_descriptor' (C tp_init slot wrapper for in-memory bytes stream)"]
    - [bytesio_init_qn_eq,    "BytesIO.__init__.__qualname__.__eq__",         ["BytesIO.__init__"],     true,  "io.BytesIO.__init__.__qualname__ == 'BytesIO.__init__' (no underscore prefix; class is defined directly as BytesIO)"]
    - [bytesio_init_qn_len,   "BytesIO.__init__.__qualname__.__len__",        [],                       16,    "io.BytesIO.__init__.__qualname__.__len__() == 16 ('BytesIO.__init__' has 16 chars)"]
    - [stringio_init_type,    "StringIO.__init__.__class__.__name__.__eq__",  ["wrapper_descriptor"],   true,  "type(io.StringIO.__init__).__name__ == 'wrapper_descriptor' (C tp_init slot wrapper for in-memory text stream)"]
    - [stringio_init_qn_eq,   "StringIO.__init__.__qualname__.__eq__",        ["StringIO.__init__"],    true,  "io.StringIO.__init__.__qualname__ == 'StringIO.__init__' (StringIO wraps a text buffer in memory)"]
    - [stringio_init_qn_len,  "StringIO.__init__.__qualname__.__len__",       [],                       17,    "io.StringIO.__init__.__qualname__.__len__() == 17 ('StringIO.__init__' has 17 chars; one longer than BytesIO)"]
    - [bytes_lt_string_len,   "BytesIO.__init__.__qualname__.__len__.__lt__", [17],                     true,  "len('BytesIO.__init__') < len('StringIO.__init__') (16 < 17; StringIO is one char longer than BytesIO)"]
    - [string_ne_bytes_qn,    "StringIO.__init__.__qualname__.__eq__",        ["BytesIO.__init__"],     false, "io.StringIO.__init__.__qualname__ != 'BytesIO.__init__' (distinct qualname strings despite both being in-memory streams)"]

# ---------------------------------------------------------------------------
# io.FileIO.__init__ qualname and type
# FileIO.__init__: 'FileIO.__init__' (15 chars); type 'wrapper_descriptor'.
# FileIO is the raw file I/O implementation; shortest __init__ qualname in this group.
# Also covers: io.BytesIO.__module__, io.StringIO.__module__, io.FileIO.__module__
# all equal '_io' (the C extension module).
# ---------------------------------------------------------------------------

table io_extra118.FileIO_init_qualname_and_module:
  description: "io.FileIO.__init__ qualname='FileIO.__init__'(15); type 'wrapper_descriptor'; io.BytesIO.__module__==io.StringIO.__module__==io.FileIO.__module__=='_io'"
  kind: python_call_eq
  category: qualnames
  id_prefix: ioinit118b

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_init_type,      "FileIO.__init__.__class__.__name__.__eq__",    ["wrapper_descriptor"],  true,  "type(io.FileIO.__init__).__name__ == 'wrapper_descriptor' (C tp_init slot wrapper for raw file I/O)"]
    - [fileio_init_qn_eq,     "FileIO.__init__.__qualname__.__eq__",          ["FileIO.__init__"],     true,  "io.FileIO.__init__.__qualname__ == 'FileIO.__init__' (raw binary file I/O; wraps OS-level file descriptors)"]
    - [fileio_init_qn_len,    "FileIO.__init__.__qualname__.__len__",         [],                      15,    "io.FileIO.__init__.__qualname__.__len__() == 15 ('FileIO.__init__' has 15 chars; shortest in this group)"]
    - [bytesio_module_eq,     "BytesIO.__module__.__eq__",                    ["_io"],                 true,  "io.BytesIO.__module__ == '_io' (implemented in the C extension module _io)"]
    - [stringio_module_eq,    "StringIO.__module__.__eq__",                   ["_io"],                 true,  "io.StringIO.__module__ == '_io' (implemented in the C extension module _io)"]
    - [fileio_module_eq,      "FileIO.__module__.__eq__",                     ["_io"],                 true,  "io.FileIO.__module__ == '_io' (implemented in the C extension module _io)"]
    - [fileio_lt_bytes_len,   "FileIO.__init__.__qualname__.__len__.__lt__",  [16],                    true,  "len('FileIO.__init__') < len('BytesIO.__init__') (15 < 16; FileIO is shorter than BytesIO)"]
    - [module_ne_io,          "BytesIO.__module__.__eq__",                    ["io"],                  false, "io.BytesIO.__module__ != 'io' (the public 'io' module re-exports from '_io'; actual implementation is '_io')"]

# ---------------------------------------------------------------------------
# io.BufferedReader.__init__ and io.TextIOWrapper.__init__ qualnames
# BufferedReader.__init__: 'BufferedReader.__init__' (23 chars); type 'wrapper_descriptor'.
# TextIOWrapper.__init__: 'TextIOWrapper.__init__' (22 chars); type 'wrapper_descriptor'.
# These are the two longest __init__ qualnames in this group.
# ---------------------------------------------------------------------------

table io_extra118.BufferedReader_TextIOWrapper_init_qualnames:
  description: "io.BufferedReader.__init__ qualname='BufferedReader.__init__'(23), io.TextIOWrapper.__init__ qualname='TextIOWrapper.__init__'(22); both type 'wrapper_descriptor'"
  kind: python_call_eq
  category: qualnames
  id_prefix: ioinit118c

  columns: [id, function, args, expected, description]
  rows:
    - [bufrd_init_type,       "BufferedReader.__init__.__class__.__name__.__eq__",   ["wrapper_descriptor"],      true,  "type(io.BufferedReader.__init__).__name__ == 'wrapper_descriptor' (C tp_init slot wrapper for buffered reading)"]
    - [bufrd_init_qn_eq,      "BufferedReader.__init__.__qualname__.__eq__",         ["BufferedReader.__init__"], true,  "io.BufferedReader.__init__.__qualname__ == 'BufferedReader.__init__' (adds buffering to a RawIOBase object)"]
    - [bufrd_init_qn_len,     "BufferedReader.__init__.__qualname__.__len__",        [],                          23,    "io.BufferedReader.__init__.__qualname__.__len__() == 23 ('BufferedReader.__init__' has 23 chars; longest in this group)"]
    - [txtwrap_init_type,     "TextIOWrapper.__init__.__class__.__name__.__eq__",    ["wrapper_descriptor"],      true,  "type(io.TextIOWrapper.__init__).__name__ == 'wrapper_descriptor' (C tp_init slot wrapper for text I/O)"]
    - [txtwrap_init_qn_eq,    "TextIOWrapper.__init__.__qualname__.__eq__",          ["TextIOWrapper.__init__"],  true,  "io.TextIOWrapper.__init__.__qualname__ == 'TextIOWrapper.__init__' (wraps a BufferedIOBase for text encoding/decoding)"]
    - [txtwrap_init_qn_len,   "TextIOWrapper.__init__.__qualname__.__len__",         [],                          22,    "io.TextIOWrapper.__init__.__qualname__.__len__() == 22 ('TextIOWrapper.__init__' has 22 chars)"]
    - [bufrd_gt_txtwrap_len,  "BufferedReader.__init__.__qualname__.__len__.__gt__", [22],                        true,  "len('BufferedReader.__init__') > len('TextIOWrapper.__init__') (23 > 22; BufferedReader is one char longer)"]
    - [txtwrap_gt_fileio_len, "TextIOWrapper.__init__.__qualname__.__len__.__gt__",  [15],                        true,  "len('TextIOWrapper.__init__') > len('FileIO.__init__') (22 > 15; TextIOWrapper is much longer than FileIO)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra118.BytesIO.init_qualname:
  description: "io.BytesIO.__init__.__qualname__ == 'BytesIO.__init__' (length 16; type is 'wrapper_descriptor' — a C slot wrapper for tp_init; BytesIO is an in-memory binary stream backed by a bytes buffer; its __init__ takes an optional initial_bytes argument; 'BytesIO.' (8) + '__init__' (8) == 16)"
  category: qualnames
  kind: python_call_eq
  function: "BytesIO.__init__.__qualname__.__eq__"
  args: ["BytesIO.__init__"]
  expected: true

invariant io_extra118.StringIO.init_qualname_len:
  description: "io.StringIO.__init__.__qualname__.__len__() == 17 ('StringIO.__init__' has 17 characters; 'StringIO.' (9) + '__init__' (8) == 17; type is 'wrapper_descriptor'; StringIO is an in-memory text stream that accepts an optional initial_value string and a newline argument; it is one char longer than BytesIO.__init__ which is 16)"
  category: qualnames
  kind: python_call_eq
  function: "StringIO.__init__.__qualname__.__len__"
  args: []
  expected: 17

invariant io_extra118.FileIO.init_qualname_len:
  description: "io.FileIO.__init__.__qualname__.__len__() == 15 ('FileIO.__init__' has 15 characters; 'FileIO.' (7) + '__init__' (8) == 15; type is 'wrapper_descriptor'; FileIO is the raw OS-level file I/O class; it is the shortest __init__ qualname among the five io classes examined — FileIO(15) < BytesIO(16) < StringIO(17) < TextIOWrapper(22) < BufferedReader(23))"
  category: qualnames
  kind: python_call_eq
  function: "FileIO.__init__.__qualname__.__len__"
  args: []
  expected: 15

invariant io_extra118.BufferedReader.init_qualname_len:
  description: "io.BufferedReader.__init__.__qualname__.__len__() == 23 ('BufferedReader.__init__' has 23 characters; 'BufferedReader.' (15) + '__init__' (8) == 23; type is 'wrapper_descriptor'; BufferedReader adds a read buffer on top of a RawIOBase object; it has the longest __init__ qualname among the five io classes examined)"
  category: qualnames
  kind: python_call_eq
  function: "BufferedReader.__init__.__qualname__.__len__"
  args: []
  expected: 23

invariant io_extra118.BytesIO.module_is_io_c_ext:
  description: "io.BytesIO.__module__ == '_io' (the public 'io' module is a thin Python wrapper that re-exports types from the C extension '_io'; the actual implementation lives in _io and all three concrete stream types BytesIO, StringIO, and FileIO report '__module__ == _io'; the module name begins with an underscore indicating it is a private C implementation detail)"
  category: qualnames
  kind: python_call_eq
  function: "BytesIO.__module__.__eq__"
  args: ["_io"]
  expected: true
