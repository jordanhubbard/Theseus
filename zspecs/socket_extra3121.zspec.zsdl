spec: sk3121
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 655 (sk3121): __ge__, __repr__, __str__ dict-presence checks for socket types."
    - "socket.socket is a Python class; it defines __repr__ but not __ge__ or __str__ in its __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses (EnumType metaclass)."
    - "Neither socket.AddressFamily nor socket.SocketKind defines __ge__, __repr__, or __str__ in its own __dict__; these methods are inherited from int/IntEnum."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk3121.ge:
  description: "socket types __ge__ dict-presence checks; wave 655"
