spec: keyword_extra2
version: ">=3.9"
backend: python_module(keyword)

docs: https://docs.python.org/3/library/keyword.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/keyword.html — Python keyword module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/keyword.py"
  notes:
    - "This spec covers invariants not in keyword.zspec.zsdl or keyword_extra.zspec.zsdl."
    - "iskeyword.__module__ == 'keyword' — the function is defined in the keyword module."
    - "issoftkeyword.__name__ == 'issoftkeyword' (Python >= 3.12) — re-verified as extra2 dimension."
    - "kwlist is a plain Python list: kwlist.__class__.__name__ == 'list'."
    - "kwlist.__len__() >= 30 — a conservative lower bound valid for Python 3.9+."
    - "Python 3.12 has exactly 35 hard keywords; 3.13+ may add more, so >= 30 is stable."
    - "kwlist.__contains__ checks confirm that 'if', 'for', 'while', 'class', 'def' are present."
    - "softkwlist.__class__.__name__ == 'list' (Python >= 3.12) — softkwlist is a plain list."
    - "Python 3.12 softkwlist == ['_', 'case', 'match', 'type']; length == 4."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# iskeyword — function __name__ and __module__ affiliation
# ---------------------------------------------------------------------------

invariant keyword_extra2.iskeyword.name:
  description: "iskeyword.__name__ == 'iskeyword'"
  category: iskeyword
  kind: python_call_eq
  function: iskeyword.__name__.__eq__
  args: ["iskeyword"]
  expected: true

invariant keyword_extra2.iskeyword.module:
  description: "iskeyword.__module__ == 'keyword'"
  category: iskeyword
  kind: python_call_eq
  function: iskeyword.__module__.__eq__
  args: ["keyword"]
  expected: true

# ---------------------------------------------------------------------------
# issoftkeyword — function __name__ (Python >= 3.12)
# ---------------------------------------------------------------------------

invariant keyword_extra2.issoftkeyword.name:
  description: "issoftkeyword.__name__ == 'issoftkeyword' (Python >= 3.12)"
  category: issoftkeyword
  kind: python_call_eq
  function: issoftkeyword.__name__.__eq__
  args: ["issoftkeyword"]
  expected: true

# ---------------------------------------------------------------------------
# kwlist — type identity
# ---------------------------------------------------------------------------

invariant keyword_extra2.kwlist.type_is_list:
  description: "kwlist.__class__.__name__ == 'list' — kwlist is a plain Python list"
  category: kwlist
  kind: python_call_eq
  function: kwlist.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# kwlist — length lower bound
#
# Python 3.9+ has at least 30 hard keywords; 3.12 has exactly 35.
# Using a conservative bound so the invariant is stable across minor versions.
# ---------------------------------------------------------------------------

invariant keyword_extra2.kwlist.len_ge_30:
  description: "len(kwlist) >= 30 — Python 3.9+ has at least 30 keywords"
  category: kwlist
  kind: python_call_eq
  function: kwlist.__len__
  args: []
  method: __ge__
  method_args: [30]
  expected: true

# ---------------------------------------------------------------------------
# kwlist — contains core control-flow and definition keywords
# ---------------------------------------------------------------------------

table keyword_extra2.kwlist.core_keywords:
  kind: python_call_eq
  category: kwlist
  id_prefix: contains

  columns: [id, function, args, expected]
  rows:
    - [if,    kwlist.__contains__, ["if"],    true]
    - [for,   kwlist.__contains__, ["for"],   true]
    - [while, kwlist.__contains__, ["while"], true]
    - [class, kwlist.__contains__, ["class"], true]
    - [def,   kwlist.__contains__, ["def"],   true]

# ---------------------------------------------------------------------------
# softkwlist — type identity (Python >= 3.12)
#
# In Python 3.12, softkwlist == ['_', 'case', 'match', 'type']
# ---------------------------------------------------------------------------

invariant keyword_extra2.softkwlist.type_is_list:
  description: "softkwlist.__class__.__name__ == 'list' (Python >= 3.12)"
  category: softkwlist
  kind: python_call_eq
  function: softkwlist.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# softkwlist — length equals 4 on Python 3.12
# ---------------------------------------------------------------------------

invariant keyword_extra2.softkwlist.len_eq_4:
  description: "len(softkwlist) == 4 on Python 3.12 (['_', 'case', 'match', 'type'])"
  category: softkwlist
  kind: python_call_eq
  function: softkwlist.__len__
  args: []
  method: __eq__
  method_args: [4]
  expected: true

# ---------------------------------------------------------------------------
# softkwlist — contains all four soft keywords (Python >= 3.12)
# ---------------------------------------------------------------------------

table keyword_extra2.softkwlist.soft_keywords:
  kind: python_call_eq
  category: softkwlist
  id_prefix: soft_contains

  columns: [id, function, args, expected]
  rows:
    - [underscore, softkwlist.__contains__, ["_"],     true]
    - [case,       softkwlist.__contains__, ["case"],  true]
    - [match,      softkwlist.__contains__, ["match"], true]
    - [type,       softkwlist.__contains__, ["type"],  true]
