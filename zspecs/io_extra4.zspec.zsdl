spec: io_extra4
version: ">=3.2"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/<module>.py"
  notes:
    - "Extends io.zspec.zsdl, _io.zspec.zsdl, io_extra.zspec.zsdl, io_extra2.zspec.zsdl, io_extra3.zspec.zsdl, and io_streams.zspec.zsdl."
    - "io_extra2.zspec.zsdl covers: IOBase/__name__, IOBase/__module__=='_io', IOBase/base is object, RawIOBase/__name__, BufferedIOBase/__name__, TextIOBase/__name__, FileIO/__name__, BufferedReader/__name__, BufferedWriter/__name__, BufferedRWPair/__name__, IncrementalNewlineDecoder/__name__."
    - "io_extra3.zspec.zsdl covers: open/__name__, UnsupportedOperation bases count and names, FileIO/StringIO/BytesIO base class names, DEFAULT_BUFFER_SIZE value."
    - "io.zspec.zsdl covers: StringIO/__name__, BytesIO/__name__, StringIO/BytesIO is_type, SEEK_*/DEFAULT_BUFFER_SIZE values."
    - "io_extra.zspec.zsdl covers: DEFAULT_BUFFER_SIZE type/positive, SEEK_* type checks, TextIOWrapper/BufferedRandom class metadata and bases, UnsupportedOperation name/module/is_type."
    - "This spec adds: IOBase/__name__ and IOBase/__module__ standalone invariants, RawIOBase/BufferedIOBase/TextIOBase/StringIO/BytesIO/FileIO/BufferedReader __name__ standalone invariants (addressable individually), plus module checks and is_type checks for classes not yet verified."
    - "io.IOBase.__module__ == 'io' when accessed through the public io module — note that the underlying C class has __module__=='_io', but io re-exports it."
    - "io.RawIOBase, io.BufferedIOBase, io.TextIOBase each have __module__ == '_io' (C extension)."
    - "io.FileIO.__module__ == '_io' — implemented in C."
    - "io.BufferedReader.__module__ == '_io' — implemented in C."
    - "io.BufferedWriter.__module__ == '_io' — implemented in C."
    - "io.StringIO.__module__ == '_io' — implemented in C."
    - "io.BytesIO.__module__ == '_io' — implemented in C."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IOBase — class name and module (standalone addressable invariants)
#
# io_extra2 covers these; this spec re-exposes them under io_extra4 IDs so
# each class has a canonically addressable invariant in this spec file.
# ---------------------------------------------------------------------------

invariant io_extra4.IOBase.class_name:
  description: "io.IOBase.__name__ == 'IOBase'"
  category: class_metadata
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true

invariant io_extra4.IOBase.module:
  description: "io.IOBase.__module__ == '_io' — IOBase is implemented in the _io C extension"
  category: class_metadata
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra4.IOBase.is_type:
  description: "type(io.IOBase).__name__ == 'type' — IOBase is a class object"
  category: class_metadata
  kind: python_call_eq
  function: IOBase.__class__.__name__.__eq__
  args: ["type"]
  expected: true

