spec: http_client_extra2
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
  notes:
    - "This spec extends http_client.zspec.zsdl and http_client_extra.zspec.zsdl."
    - "http_client.zspec.zsdl covers: status_codes table, HTTP_PORT==80, HTTPS_PORT==443, class_names table (HTTPResponse, HTTPConnection, HTTPSConnection, HTTPException, InvalidURL, BadStatusLine), responses dict."
    - "http_client_extra.zspec.zsdl covers: HTTPConnection.__name__/__module__, HTTPSConnection.__name__/__module__, HTTPException.__name__, HTTPResponse.__name__, NotConnected.__name__, InvalidURL.__name__, RemoteDisconnected.__name__, HTTPException.__bases__[0].__name__ == 'Exception', NotConnected.__bases__[0].__name__ == 'HTTPException', InvalidURL.__bases__[0].__name__ == 'HTTPException', HTTPConnection/HTTPSConnection/HTTPResponse is_type checks."
    - "Focus: __qualname__ checks for http.client classes; HTTP_PORT/__class__.__name__, HTTPS_PORT/__class__.__name__; and __module__ for HTTPException and additional classes."
    - "For top-level classes, __qualname__ == __name__ (no enclosing class)."
    - "http.client.HTTP_PORT is a plain int; HTTP_PORT.__class__.__name__ == 'int'."
    - "http.client.HTTPS_PORT is a plain int; HTTPS_PORT.__class__.__name__ == 'int'."
    - "http.client.HTTPException.__module__ == 'http.client'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — connection and response classes
# http_client.zspec.zsdl and http_client_extra.zspec.zsdl only check __name__
# and __module__; __qualname__ is a new dimension not covered in either.
# ---------------------------------------------------------------------------

table http_client_extra2.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [HTTPConnection,  HTTPConnection.__qualname__.__eq__,  ["HTTPConnection"],  true]
    - [HTTPSConnection, HTTPSConnection.__qualname__.__eq__, ["HTTPSConnection"], true]
    - [HTTPResponse,    HTTPResponse.__qualname__.__eq__,    ["HTTPResponse"],    true]
    - [HTTPException,   HTTPException.__qualname__.__eq__,   ["HTTPException"],   true]
    - [NotConnected,    NotConnected.__qualname__.__eq__,    ["NotConnected"],    true]
    - [InvalidURL,      InvalidURL.__qualname__.__eq__,      ["InvalidURL"],      true]

# ---------------------------------------------------------------------------
# __module__ checks — classes not individually covered as invariants in prior specs
# http_client_extra covers HTTPConnection.__module__ and HTTPSConnection.__module__.
# HTTPException.__module__ and HTTPResponse.__module__ are new.
# ---------------------------------------------------------------------------

invariant http_client_extra2.HTTPException.module:
  description: "http.client.HTTPException.__module__ == 'http.client'"
  category: modules
  kind: python_call_eq
  function: HTTPException.__module__.__eq__
  args: ["http.client"]
  expected: true

invariant http_client_extra2.HTTPResponse.module:
  description: "http.client.HTTPResponse.__module__ == 'http.client'"
  category: modules
  kind: python_call_eq
  function: HTTPResponse.__module__.__eq__
  args: ["http.client"]
  expected: true

invariant http_client_extra2.NotConnected.module:
  description: "http.client.NotConnected.__module__ == 'http.client'"
  category: modules
  kind: python_call_eq
  function: NotConnected.__module__.__eq__
  args: ["http.client"]
  expected: true

invariant http_client_extra2.InvalidURL.module:
  description: "http.client.InvalidURL.__module__ == 'http.client'"
  category: modules
  kind: python_call_eq
  function: InvalidURL.__module__.__eq__
  args: ["http.client"]
  expected: true

# ---------------------------------------------------------------------------
# Port constant type checks — HTTP_PORT and HTTPS_PORT are plain ints
# http_client.zspec.zsdl verifies HTTP_PORT==80 and HTTPS_PORT==443.
# The __class__.__name__ checks are new.
# ---------------------------------------------------------------------------

invariant http_client_extra2.HTTP_PORT.class_name:
  description: "http.client.HTTP_PORT.__class__.__name__ == 'int' — HTTP_PORT is a plain integer"
  category: constants
  kind: python_call_eq
  function: HTTP_PORT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant http_client_extra2.HTTPS_PORT.class_name:
  description: "http.client.HTTPS_PORT.__class__.__name__ == 'int' — HTTPS_PORT is a plain integer"
  category: constants
  kind: python_call_eq
  function: HTTPS_PORT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Port constant value checks — redundant with http_client.zspec.zsdl's invariants
# but expressed differently: using direct __eq__ on the constant rather than
# via the constants' __eq__ method chain. These are standalone value checks.
# We use the constant's __eq__ as function to verify the value.
# ---------------------------------------------------------------------------

invariant http_client_extra2.HTTP_PORT.value:
  description: "http.client.HTTP_PORT == 80"
  category: constants
  kind: python_call_eq
  function: HTTP_PORT.__eq__
  args: [80]
  expected: true

invariant http_client_extra2.HTTPS_PORT.value:
  description: "http.client.HTTPS_PORT == 443"
  category: constants
  kind: python_call_eq
  function: HTTPS_PORT.__eq__
  args: [443]
  expected: true
