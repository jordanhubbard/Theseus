spec: re_extra288
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module public API: Match, Pattern, and function names/modules"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py, Modules/_sre.c"
  notes:
    - "re.Match and re.Pattern are real classes in Python 3.8+; __name__ and __module__ are reliable"
    - "re.Match.__bases__[0].__name__ == 'object' and re.Pattern.__bases__[0].__name__ == 'object'"
    - "All re module functions have __module__ == 're'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table re_extra288.function_names:
  description: "__name__ for re module classes and functions"
  kind: python_call_eq
  category: identity
  id_prefix: re288n

  columns: [id, function, args, expected, description]
  rows:
    - [re288n001, re.Match.__name__, [], "Match", "re.Match.__name__"]
    - [re288n002, re.Pattern.__name__, [], "Pattern", "re.Pattern.__name__"]
    - [re288n003, re.fullmatch.__name__, [], "fullmatch", "re.fullmatch.__name__"]
    - [re288n004, re.search.__name__, [], "search", "re.search.__name__"]
    - [re288n005, re.findall.__name__, [], "findall", "re.findall.__name__"]
    - [re288n006, re.finditer.__name__, [], "finditer", "re.finditer.__name__"]
    - [re288n007, re.split.__name__, [], "split", "re.split.__name__"]
    - [re288n008, re.sub.__name__, [], "sub", "re.sub.__name__"]
    - [re288n009, re.subn.__name__, [], "subn", "re.subn.__name__"]
    - [re288n010, re.escape.__name__, [], "escape", "re.escape.__name__"]
    - [re288n011, re.purge.__name__, [], "purge", "re.purge.__name__"]

table re_extra288.function_modules:
  description: "__module__ for re module classes and functions"
  kind: python_call_eq
  category: identity
  id_prefix: re288m

  columns: [id, function, args, expected, description]
  rows:
    - [re288m001, re.Match.__module__, [], "re", "re.Match.__module__"]
    - [re288m002, re.Pattern.__module__, [], "re", "re.Pattern.__module__"]
    - [re288m003, re.fullmatch.__module__, [], "re", "re.fullmatch.__module__"]
    - [re288m004, re.search.__module__, [], "re", "re.search.__module__"]
    - [re288m005, re.findall.__module__, [], "re", "re.findall.__module__"]
    - [re288m006, re.finditer.__module__, [], "re", "re.finditer.__module__"]
    - [re288m007, re.split.__module__, [], "re", "re.split.__module__"]
    - [re288m008, re.sub.__module__, [], "re", "re.sub.__module__"]
    - [re288m009, re.subn.__module__, [], "re", "re.subn.__module__"]
    - [re288m010, re.escape.__module__, [], "re", "re.escape.__module__"]
    - [re288m011, re.purge.__module__, [], "re", "re.purge.__module__"]

invariant re_extra288.match_base_class:
  description: "re.Match base class is object"
  category: identity
  kind: python_call_eq
  function: "re.Match.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant re_extra288.pattern_base_class:
  description: "re.Pattern base class is object"
  category: identity
  kind: python_call_eq
  function: "re.Pattern.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant re_extra288.match_is_type:
  description: "re.Match is a type (class)"
  category: identity
  kind: python_call_eq
  function: re.Match.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant re_extra288.pattern_is_type:
  description: "re.Pattern is a type (class)"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant re_extra288.compile_name:
  description: "re.compile.__name__ is 'compile'"
  category: identity
  kind: python_call_eq
  function: re.compile.__name__.__eq__
  args: ["compile"]
  expected: true

invariant re_extra288.compile_module:
  description: "re.compile.__module__ is 're'"
  category: identity
  kind: python_call_eq
  function: re.compile.__module__.__eq__
  args: ["re"]
  expected: true
