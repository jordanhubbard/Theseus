spec: itertools_extra2461
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Theme: __len__ and __length_hint__ dict-presence — which itertools types define the length protocol in their class __dict__?"
    - "itertools.repeat is the only itertools type that defines __length_hint__ in its class __dict__. All other itertools types define neither __len__ nor __length_hint__. Verified with Python 3.14.3."
    - "itertools.repeat.__dict__.__contains__('__length_hint__') == True — repeat defines __length_hint__ because finite repeats (repeat(x, n)) know exactly how many items remain; repeat(x, n).__length_hint__() returns the remaining count. Verified with Python 3.14.3."
    - "itertools.repeat.__dict__.__contains__('__len__') == False — repeat does not define __len__ because infinite repeats (repeat(x) with no count) are unbounded; __len__ would need to return an integer, which is impossible for infinite sequences. Verified with Python 3.14.3."
    - "itertools.chain.__dict__.__contains__('__len__') == False — chain lazily chains iterables of unknown sizes; it cannot know total length. Verified with Python 3.14.3."
    - "itertools.chain.__dict__.__contains__('__length_hint__') == False — chain does not define __length_hint__; the underlying iterables may not support it. Verified with Python 3.14.3."
    - "itertools.cycle.__dict__.__contains__('__len__') == False — cycle produces an infinite sequence by looping; __len__ is not defined. Verified with Python 3.14.3."
    - "itertools.count.__dict__.__contains__('__len__') == False — count produces an infinite arithmetic sequence; __len__ is not defined. Verified with Python 3.14.3."
    - "itertools.islice.__dict__.__contains__('__length_hint__') == False — islice truncates an iterable but the source may not be sized; __length_hint__ is not defined. Verified with Python 3.14.3."
    - "itertools.product.__dict__.__contains__('__len__') == False — product lazily computes Cartesian products; total size depends on inputs not known at construction. Verified with Python 3.14.3."
    - "itertools.combinations.__dict__.__contains__('__len__') == False — combinations does not define __len__ in its class dict. Verified with Python 3.14.3."
    - "itertools.permutations.__dict__.__contains__('__len__') == False — permutations does not define __len__ in its class dict. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __len__ dict-presence for itertools types
#
# Theme: which itertools types define __len__ in their class __dict__?
#
# itertools.repeat.__dict__.__contains__('__len__') == False
# itertools.chain.__dict__.__contains__('__len__') == False
# itertools.cycle.__dict__.__contains__('__len__') == False
# itertools.count.__dict__.__contains__('__len__') == False
# itertools.islice.__dict__.__contains__('__len__') == False
# itertools.product.__dict__.__contains__('__len__') == False
# itertools.combinations.__dict__.__contains__('__len__') == False
# itertools.permutations.__dict__.__contains__('__len__') == False
# itertools.accumulate.__dict__.__contains__('__len__') == False
# itertools.groupby.__dict__.__contains__('__len__') == False
#
# No itertools type defines __len__ because all itertools types are lazy
# iterators. Even types that produce a finite, bounded number of elements
# (combinations, permutations, product) do not define __len__ in their
# class dict on CPython 3.14.3.
# ---------------------------------------------------------------------------

table itertools_extra2461.len_dict_presence:
  description: "__len__ in class __dict__ for itertools types; none define it"
  kind: python_call_eq
  category: identity
  id_prefix: it2461

  columns: [id, function, args, expected]
  rows:
    - ["it2461001", repeat.__dict__.__contains__, ["__len__"], false]
    - ["it2461002", chain.__dict__.__contains__, ["__len__"], false]
    - ["it2461003", cycle.__dict__.__contains__, ["__len__"], false]
    - ["it2461004", count.__dict__.__contains__, ["__len__"], false]
    - ["it2461005", islice.__dict__.__contains__, ["__len__"], false]
    - ["it2461006", product.__dict__.__contains__, ["__len__"], false]
    - ["it2461007", combinations.__dict__.__contains__, ["__len__"], false]
    - ["it2461008", permutations.__dict__.__contains__, ["__len__"], false]
    - ["it2461009", accumulate.__dict__.__contains__, ["__len__"], false]
    - ["it2461010", groupby.__dict__.__contains__, ["__len__"], false]

# ---------------------------------------------------------------------------
# Table 2: __length_hint__ dict-presence for itertools types
#
# Theme: which itertools types define __length_hint__ in their class __dict__?
#
# itertools.repeat.__dict__.__contains__('__length_hint__') == True
# itertools.chain.__dict__.__contains__('__length_hint__') == False
# itertools.cycle.__dict__.__contains__('__length_hint__') == False
# itertools.count.__dict__.__contains__('__length_hint__') == False
# itertools.islice.__dict__.__contains__('__length_hint__') == False
# itertools.product.__dict__.__contains__('__length_hint__') == False
# itertools.combinations.__dict__.__contains__('__length_hint__') == False
# itertools.permutations.__dict__.__contains__('__length_hint__') == False
# itertools.zip_longest.__dict__.__contains__('__length_hint__') == False
# itertools.accumulate.__dict__.__contains__('__length_hint__') == False
#
# repeat is unique: it defines __length_hint__ so that consumers of finite
# repeats (repeat(x, n)) can estimate remaining items. All other itertools
# types are either infinite or depend on unsized sources, so they define
# neither __len__ nor __length_hint__.
# ---------------------------------------------------------------------------

table itertools_extra2461.length_hint_dict_presence:
  description: "__length_hint__ in class __dict__ for itertools types; only repeat defines it"
  kind: python_call_eq
  category: identity
  id_prefix: it2461

  columns: [id, function, args, expected]
  rows:
    - ["it2461011", repeat.__dict__.__contains__, ["__length_hint__"], true]
    - ["it2461012", chain.__dict__.__contains__, ["__length_hint__"], false]
    - ["it2461013", cycle.__dict__.__contains__, ["__length_hint__"], false]
    - ["it2461014", count.__dict__.__contains__, ["__length_hint__"], false]
    - ["it2461015", islice.__dict__.__contains__, ["__length_hint__"], false]
    - ["it2461016", product.__dict__.__contains__, ["__length_hint__"], false]
    - ["it2461017", combinations.__dict__.__contains__, ["__length_hint__"], false]
    - ["it2461018", permutations.__dict__.__contains__, ["__length_hint__"], false]
    - ["it2461019", zip_longest.__dict__.__contains__, ["__length_hint__"], false]
    - ["it2461020", accumulate.__dict__.__contains__, ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Table 3: repeat is unique — cross-checks for the length protocol asymmetry
#
# itertools.repeat.__dict__.__contains__('__length_hint__') == True
# itertools.repeat.__dict__.__contains__('__len__') == False
# itertools.repeat.__dict__.__contains__('__iter__') == True
# itertools.repeat.__dict__.__contains__('__next__') == True
# itertools.combinations_with_replacement.__dict__.__contains__('__length_hint__') == False
# itertools.pairwise.__dict__.__contains__('__length_hint__') == False
#
# repeat defines __length_hint__ but NOT __len__: a finite repeat knows
# how many items remain at each step (the hint decrements), but since
# repeat(x) with no count is infinite, the type cannot define __len__
# (which must return a non-negative int, impossible for unbounded sequences).
# ---------------------------------------------------------------------------

table itertools_extra2461.repeat_protocol_cross_checks:
  description: "repeat defines __length_hint__ but not __len__; iter/next present; other combinatoric types lack both"
  kind: python_call_eq
  category: identity
  id_prefix: it2461

  columns: [id, function, args, expected]
  rows:
    - ["it2461021", repeat.__dict__.__contains__, ["__length_hint__"], true]
    - ["it2461022", repeat.__dict__.__contains__, ["__len__"], false]
    - ["it2461023", repeat.__dict__.__contains__, ["__iter__"], true]
    - ["it2461024", repeat.__dict__.__contains__, ["__next__"], true]
    - ["it2461025", combinations_with_replacement.__dict__.__contains__, ["__length_hint__"], false]
    - ["it2461026", pairwise.__dict__.__contains__, ["__length_hint__"], false]
