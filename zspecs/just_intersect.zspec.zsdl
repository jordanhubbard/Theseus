spec: just_intersect
version: ">=4.3.0"
backend: node(just-intersect)

docs: https://www.npmjs.com/package/just-intersect

provenance:
  derived_from:
    - "just-intersect README — https://www.npmjs.com/package/just-intersect"
    - "Test vectors verified with just-intersect via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-intersect source"
  notes:
    - "just-intersect is an npm package. Install: npm install just-intersect"
    - "The module exports a single function that returns the intersection of two arrays."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new array containing only elements present in both inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_intersect.intersect:
  kind: node_module_call_eq
  function: ~
  category: set
  id_prefix: jisect

  columns: [id, args, expected]
  rows:
    - [overlap,  [[1, 2, 3], [2, 3, 4]], [2, 3]]
    - [disjoint, [[1, 2], [3, 4]],       []]

