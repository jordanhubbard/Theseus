spec: socket_extra1681
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 559 (_extra1681): __call__ callable protocol dict-presence checks."
    - "socket.socket is a class; socket instances are NOT callable — '__call__' in socket.socket.__dict__ → False."
    - "socket.socket defines __enter__ and __exit__ in its own __dict__ (context manager protocol)."
    - "socket.socket defines connect, bind, listen, accept, send, recv, close, fileno in its own __dict__."
    - "socket.socket.__dict__.__contains__('__call__') == False — socket objects are network endpoints, not callables."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: callable_protocol
#
# socket.socket is a class whose instances represent network endpoints.
# Instances are not callable; __call__ is not defined in the class dict.
# Context manager methods (__enter__, __exit__) are defined in own dict.
# ---------------------------------------------------------------------------

table socket_extra1681.callable_protocol:
  description: "socket.socket __call__ dict-presence checks (wave 559 _extra1681) — socket.socket.__dict__.__contains__('__call__')==False (socket.socket is a class whose instances are network-endpoint objects; they implement the I/O and context-manager protocols but are not designed to be called as functions; __call__ is not defined in the socket.socket class dict); verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1681

  columns: [id, function, args, expected]
  rows:
    - ["sk1681001", "socket.socket.__dict__.__contains__", ["__call__"],  false]
    - ["sk1681002", "socket.socket.__dict__.__contains__", ["__enter__"], true]
    - ["sk1681003", "socket.socket.__dict__.__contains__", ["__exit__"],  true]
    - ["sk1681004", "socket.socket.__dict__.__contains__", ["connect"],   true]
    - ["sk1681005", "socket.socket.__dict__.__contains__", ["bind"],      true]

# ---------------------------------------------------------------------------
# Table 2: socket_network_method_attrs
#
# Verifies the full set of core networking methods on socket.socket.
# All of these are defined in the socket.socket class dict (pure-Python
# wrapper around the C _socket.socket type, or defined directly on the
# Python-level class).
# ---------------------------------------------------------------------------

table socket_extra1681.socket_network_method_attrs:
  description: "socket.socket own-dict network method presence (wave 559 _extra1681) — socket.socket defines the full BSD socket API as methods in its own class dict: connect, bind, listen, accept, send, recv, close, fileno, and the context manager protocol (__enter__, __exit__); __call__ is absent because socket instances are network endpoints, not callables; verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1681

  columns: [id, function, args, expected]
  rows:
    - ["sk1681010", "socket.socket.__dict__.__contains__", ["__call__"],  false]
    - ["sk1681011", "socket.socket.__dict__.__contains__", ["connect"],   true]
    - ["sk1681012", "socket.socket.__dict__.__contains__", ["bind"],      true]
    - ["sk1681013", "socket.socket.__dict__.__contains__", ["listen"],    true]
    - ["sk1681014", "socket.socket.__dict__.__contains__", ["accept"],    true]
    - ["sk1681015", "socket.socket.__dict__.__contains__", ["send"],      true]
    - ["sk1681016", "socket.socket.__dict__.__contains__", ["recv"],      true]
    - ["sk1681017", "socket.socket.__dict__.__contains__", ["close"],     true]
    - ["sk1681018", "socket.socket.__dict__.__contains__", ["fileno"],    true]
    - ["sk1681019", "socket.socket.__dict__.__contains__", ["__enter__"], true]
    - ["sk1681020", "socket.socket.__dict__.__contains__", ["__exit__"],  true]

# ---------------------------------------------------------------------------
# Table 3: socket_type_identity
#
# Verifies module and metatype identity for socket.socket.
# socket.socket is defined in the public socket module (pure-Python wrapper);
# __module__ == 'socket'.  __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

table socket_extra1681.socket_type_identity:
  description: "socket.socket module and metatype identity checks (wave 559 _extra1681) — socket.socket.__module__ == 'socket' (the public Python-level socket module); socket.socket.__name__ == 'socket'; socket.socket.__class__.__name__ == 'type' (it is a regular Python type object); socket.socket does not define __call__ in its own class dict; verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1681

  columns: [id, function, args, expected]
  rows:
    - ["sk1681021", "socket.socket.__dict__.__contains__",       ["__call__"],  false]
    - ["sk1681022", "socket.socket.__name__.__eq__",             ["socket"],    true]
    - ["sk1681023", "socket.socket.__module__.__eq__",           ["socket"],    true]
    - ["sk1681024", "socket.socket.__class__.__name__.__eq__",   ["type"],      true]
