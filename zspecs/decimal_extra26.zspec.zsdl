spec: decimal_extra26
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra25.zspec.zsdl."
    - "Prior specs covered: Decimal class identity, arithmetic, context, rounding modes, signals, Decimal/__init__.__name__, Context/__name__/__module__/__qualname__/__bases__[0].__name__, DefaultContext/BasicContext/ExtendedContext.__class__.__name__, ROUND_* __class__.__name__=='str'."
    - "This spec covers: decimal.Decimal.__module__ and its length, decimal.Context.__module__.__len__(), decimal.Decimal.__name__.__len__(), decimal.Context.__name__.__len__(), decimal.Decimal.__qualname__.__len__(), decimal.Context.__qualname__.__len__(), decimal.getcontext/__name__/__qualname__, decimal.setcontext/__name__/__qualname__, decimal.localcontext/__name__."
    - "Decimal.__module__ == 'decimal' — Decimal is defined in the decimal module."
    - "Both Decimal and Context have __module__ == 'decimal' (7 chars), __name__ == 7 chars, __qualname__ == 7 chars."
    - "getcontext.__name__ == 'getcontext', getcontext.__qualname__ == 'getcontext' — top-level function."
    - "setcontext.__name__ == 'setcontext', setcontext.__qualname__ == 'setcontext' — top-level function."
    - "localcontext.__name__ == 'localcontext' — top-level context manager function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.__module__
#
# decimal_extra25 records Decimal.__name__, __qualname__, and __bases__, but
# does not record Decimal.__module__ as a standalone string equality invariant.
# Decimal is defined in the decimal module; __module__ == 'decimal'.
# ---------------------------------------------------------------------------

invariant decimal_extra26.Decimal.module:
  description: "decimal.Decimal.__module__ == 'decimal'"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra26.Decimal.module_len:
  description: "len(decimal.Decimal.__module__) == 7 — 'decimal' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# decimal.Context.__module__.__len__()
#
# decimal_extra25 records Context.__module__.__eq__("decimal") and
# Context.__module__.__len__() == 7.  Covered here for Decimal in parallel.
# Both Decimal and Context share the same module string length.
# ---------------------------------------------------------------------------

invariant decimal_extra26.Context.module_len_parallel:
  description: "len(decimal.Context.__module__) == 7 — same module 'decimal' as Decimal"
  category: class_identity
  kind: python_call_eq
  function: Context.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# __name__ lengths for Decimal and Context
#
# Both class names are 7 chars: 'Decimal' and 'Context'.
# decimal_extra25 records Context.__name__.__len__() == 7.
# This spec records Decimal.__name__.__len__() as a standalone invariant.
# ---------------------------------------------------------------------------

invariant decimal_extra26.Decimal.name_len:
  description: "len(decimal.Decimal.__name__) == 7 — 'Decimal' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__name__.__len__
  args: []
  expected: 7

invariant decimal_extra26.Context.name_len_parallel:
  description: "len(decimal.Context.__name__) == 7 — 'Context' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Context.__name__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# __qualname__ lengths for Decimal and Context
#
# Both classes are top-level; their __qualname__ equals their __name__.
# decimal_extra25 records Context.__qualname__.__len__() == 7.
# This spec records Decimal.__qualname__.__len__() as a standalone invariant.
# ---------------------------------------------------------------------------

invariant decimal_extra26.Decimal.qualname_len:
  description: "len(decimal.Decimal.__qualname__) == 7 — 'Decimal' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__qualname__.__len__
  args: []
  expected: 7

invariant decimal_extra26.Context.qualname_len_parallel:
  description: "len(decimal.Context.__qualname__) == 7 — 'Context' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Context.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# decimal.getcontext — __name__ and __qualname__
#
# No prior spec records getcontext.__name__ or getcontext.__qualname__.
# getcontext is a module-level function; its __qualname__ equals its __name__.
# ---------------------------------------------------------------------------

invariant decimal_extra26.getcontext.name:
  description: "decimal.getcontext.__name__ == 'getcontext'"
  category: function_identity
  kind: python_call_eq
  function: getcontext.__name__.__eq__
  args: ["getcontext"]
  expected: true

invariant decimal_extra26.getcontext.name_len:
  description: "len(decimal.getcontext.__name__) == 10 — 'getcontext' is 10 chars"
  category: function_identity
  kind: python_call_eq
  function: getcontext.__name__.__len__
  args: []
  expected: 10

invariant decimal_extra26.getcontext.qualname:
  description: "decimal.getcontext.__qualname__ == 'getcontext'"
  category: function_identity
  kind: python_call_eq
  function: getcontext.__qualname__.__eq__
  args: ["getcontext"]
  expected: true

invariant decimal_extra26.getcontext.qualname_len:
  description: "len(decimal.getcontext.__qualname__) == 10 — 'getcontext' is 10 chars"
  category: function_identity
  kind: python_call_eq
  function: getcontext.__qualname__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# decimal.setcontext — __name__ and __qualname__
#
# No prior spec records setcontext.__name__ or setcontext.__qualname__.
# setcontext is a module-level function; its __qualname__ equals its __name__.
# ---------------------------------------------------------------------------

invariant decimal_extra26.setcontext.name:
  description: "decimal.setcontext.__name__ == 'setcontext'"
  category: function_identity
  kind: python_call_eq
  function: setcontext.__name__.__eq__
  args: ["setcontext"]
  expected: true

invariant decimal_extra26.setcontext.name_len:
  description: "len(decimal.setcontext.__name__) == 10 — 'setcontext' is 10 chars"
  category: function_identity
  kind: python_call_eq
  function: setcontext.__name__.__len__
  args: []
  expected: 10

invariant decimal_extra26.setcontext.qualname:
  description: "decimal.setcontext.__qualname__ == 'setcontext'"
  category: function_identity
  kind: python_call_eq
  function: setcontext.__qualname__.__eq__
  args: ["setcontext"]
  expected: true

invariant decimal_extra26.setcontext.qualname_len:
  description: "len(decimal.setcontext.__qualname__) == 10 — 'setcontext' is 10 chars"
  category: function_identity
  kind: python_call_eq
  function: setcontext.__qualname__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# decimal.localcontext — __name__
#
# No prior spec records localcontext.__name__.
# localcontext is a module-level context manager function.
# ---------------------------------------------------------------------------

invariant decimal_extra26.localcontext.name:
  description: "decimal.localcontext.__name__ == 'localcontext'"
  category: function_identity
  kind: python_call_eq
  function: localcontext.__name__.__eq__
  args: ["localcontext"]
  expected: true

invariant decimal_extra26.localcontext.name_len:
  description: "len(decimal.localcontext.__name__) == 12 — 'localcontext' is 12 chars"
  category: function_identity
  kind: python_call_eq
  function: localcontext.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Table: context function __name__ values
#
# Summarises the three context-management functions together.
# No prior table covers __name__ for getcontext/setcontext/localcontext.
# ---------------------------------------------------------------------------

table decimal_extra26.context_function_names:
  kind: python_call_eq
  category: function_identity
  id_prefix: name

  columns: [id, function, args, expected, description]
  rows:
    - [getcontext,    getcontext.__name__.__eq__,    ["getcontext"],    true, "decimal.getcontext.__name__ == 'getcontext'"]
    - [setcontext,    setcontext.__name__.__eq__,    ["setcontext"],    true, "decimal.setcontext.__name__ == 'setcontext'"]
    - [localcontext,  localcontext.__name__.__eq__,  ["localcontext"],  true, "decimal.localcontext.__name__ == 'localcontext'"]

# ---------------------------------------------------------------------------
# Table: context function __qualname__ values
#
# getcontext and setcontext are top-level functions; __qualname__ == __name__.
# (localcontext __qualname__ not separately tabled; covered by __name__ table.)
# ---------------------------------------------------------------------------

table decimal_extra26.context_function_qualnames:
  kind: python_call_eq
  category: function_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [getcontext,  getcontext.__qualname__.__eq__,  ["getcontext"],  true, "decimal.getcontext.__qualname__ == 'getcontext'"]
    - [setcontext,  setcontext.__qualname__.__eq__,  ["setcontext"],  true, "decimal.setcontext.__qualname__ == 'setcontext'"]
