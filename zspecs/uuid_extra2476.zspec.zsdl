spec: uuid_extra2476
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID)"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "uuid_extra161.zspec.zsdl and uuid_extra180.zspec.zsdl and other pre-existing uuid_extra files"
  notes:
    - "Theme: __contains__ and __getitem__ dict-presence — membership test and item access protocol checks in class __dict__."
    - "uuid.UUID does NOT define __contains__ or __getitem__ in its own __dict__; UUID instances are not mappings or sequences."
    - "UUID is a value type (immutable) that exposes its 128-bit value through named attributes (int, hex, bytes, bytes_le, fields, urn) rather than via subscription or membership tests."
    - "UUID.__dict__ defines comparison operators (__eq__, __lt__, __le__, __gt__, __ge__) and other value-oriented dunder methods, but no mapping or sequence protocol."
    - "uuid.UUID.__setattr__ IS defined (to enforce immutability — it raises AttributeError to prevent mutation)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: uuid.UUID — __contains__ and __getitem__ absent
#
# uuid.UUID is an immutable value type. It does NOT define __contains__ or
# __getitem__ in its class __dict__. UUID instances are not mappings, sets,
# or sequences; membership testing ('x in uuid_obj') and subscript access
# ('uuid_obj[key]') are both unsupported.
# ---------------------------------------------------------------------------

table uuid_extra2476.uuid_contains_getitem_absent:
  description: "uuid.UUID.__dict__: __contains__ and __getitem__ absent — UUID is not a mapping or sequence; new to extra2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2476

  columns: [id, function, args, expected]
  rows:
    - ["uu2476-001", "uuid.UUID.__dict__.__contains__", ["__contains__"], false]
    - ["uu2476-002", "uuid.UUID.__dict__.__contains__", ["__getitem__"],  false]
    - ["uu2476-003", "uuid.UUID.__dict__.__contains__", ["__setitem__"],  false]
    - ["uu2476-004", "uuid.UUID.__dict__.__contains__", ["__delitem__"],  false]
    - ["uu2476-005", "uuid.UUID.__dict__.__contains__", ["__iter__"],     false]
    - ["uu2476-006", "uuid.UUID.__dict__.__contains__", ["__len__"],      false]

# ---------------------------------------------------------------------------
# Table 2: uuid.UUID — comparison and value operators present in __dict__
#
# UUID defines a rich set of value-oriented operators in its own __dict__.
# These are own attributes (not inherited), confirming UUID is a proper value
# type. Their presence contrasts with the absent container protocol above.
# ---------------------------------------------------------------------------

table uuid_extra2476.uuid_value_operators_present:
  description: "uuid.UUID.__dict__: comparison and value dunder methods present; contrasts with absent __contains__/__getitem__; new to extra2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2476

  columns: [id, function, args, expected]
  rows:
    - ["uu2476-007", "uuid.UUID.__dict__.__contains__", ["__eq__"],   true]
    - ["uu2476-008", "uuid.UUID.__dict__.__contains__", ["__lt__"],   true]
    - ["uu2476-009", "uuid.UUID.__dict__.__contains__", ["__le__"],   true]
    - ["uu2476-010", "uuid.UUID.__dict__.__contains__", ["__gt__"],   true]
    - ["uu2476-011", "uuid.UUID.__dict__.__contains__", ["__ge__"],   true]
    - ["uu2476-012", "uuid.UUID.__dict__.__contains__", ["__hash__"], true]
    - ["uu2476-013", "uuid.UUID.__dict__.__contains__", ["__int__"],  true]
    - ["uu2476-014", "uuid.UUID.__dict__.__contains__", ["__str__"],  true]

# ---------------------------------------------------------------------------
# Table 3: uuid.UUID — named value attributes present in __dict__
#
# UUID exposes the 128-bit value through named property-style attributes
# defined directly in its __dict__. These confirm UUID's access pattern is
# by named attribute (not by key or index).
# ---------------------------------------------------------------------------

table uuid_extra2476.uuid_named_attrs_present:
  description: "uuid.UUID.__dict__: named value attributes (fields, hex, int, bytes, urn) present; new to extra2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2476

  columns: [id, function, args, expected]
  rows:
    - ["uu2476-015", "uuid.UUID.__dict__.__contains__", ["fields"],   true]
    - ["uu2476-016", "uuid.UUID.__dict__.__contains__", ["hex"],      true]
    - ["uu2476-017", "uuid.UUID.__dict__.__contains__", ["int"],      true]
    - ["uu2476-018", "uuid.UUID.__dict__.__contains__", ["bytes"],    true]
    - ["uu2476-019", "uuid.UUID.__dict__.__contains__", ["urn"],      true]
    - ["uu2476-020", "uuid.UUID.__dict__.__contains__", ["version"],  true]
