spec: html_escape_rust
version: ">=3.9"
backend: rust_module(html_escape_rust)

docs: https://docs.python.org/3/library/html.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/html.html — Python html module documentation"
  not_derived_from:
    - "CPython source: Lib/html/__init__.py"
  notes:
    - "Clean-room Rust reimplementation of Python html.escape and html.unescape, exposed via PyO3."
    - "escape(s) converts special HTML characters to named character references."
    - "escape('<p>hello</p>') == '&lt;p&gt;hello&lt;/p&gt;'."
    - "escape('hello & world') == 'hello &amp; world'."
    - "escape('\"quoted\"') == '&quot;quoted&quot;' — double quotes escaped by default."
    - "escape(\"it's\") == 'it&#x27;s' — single quotes also escaped (quote=True default)."
    - "escape('safe') == 'safe' — no-op for strings with no special chars."
    - "unescape(s) converts named and numeric character references to characters."
    - "unescape('&lt;p&gt;') == '<p>'."
    - "unescape('&amp;') == '&'."
    - "unescape('&quot;') == '\"'."
    - "unescape('&#65;') == 'A' — numeric character reference."
    - "All test vectors verified against Python 3.14.3 html module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# escape — encode special HTML characters
table html_escape_rust.escape.vectors:
  kind: python_call_eq
  category: escape
  id_prefix: esc
  function: escape

  columns: [id, args, expected]
  rows:
    - [tags,     ["<p>hello</p>"],  "&lt;p&gt;hello&lt;/p&gt;"]
    - [amp,      ["hello & world"], "hello &amp; world"]
    - [dquote,   ["\"quoted\""],    "&quot;quoted&quot;"]
    - [squote,   ["it's"],         "it&#x27;s"]
    - [safe,     ["safe"],          "safe"]
    - [empty,    [""],              ""]

# unescape — decode HTML character references
table html_escape_rust.unescape.vectors:
  kind: python_call_eq
  category: unescape
  id_prefix: unesc
  function: unescape

  columns: [id, args, expected]
  rows:
    - [lt_gt,   ["&lt;p&gt;"],                         "<p>"]
    - [amp,     ["&amp;"],                              "&"]
    - [quot,    ["&quot;"],                             "\""]
    - [numeric, ["&#65;"],                              "A"]
    - [mixed,   ["&lt;p&gt;hello&lt;/p&gt;"],          "<p>hello</p>"]
    - [plain,   ["no entities"],                        "no entities"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
