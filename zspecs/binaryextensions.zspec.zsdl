spec: binaryextensions
version: ">=6.0.0"
backend: node(binaryextensions)
esm: true

docs: https://github.com/bevry/binaryextensions#readme

provenance:
  derived_from:
    - "binaryextensions README — https://github.com/bevry/binaryextensions#readme"
    - "Test vectors verified with binaryextensions via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "binaryextensions source"
  notes:
    - "Curated list of file extensions that should be treated as binary."
    - "Install: npm install binaryextensions"
    - "v6 ESM only; default export IS an array of extension strings."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Static data array; no runtime errors."
  stderr: "null"
  stickiness: "N/A — read-only data."
  codes: {}

invariant binaryextensions.default_export_is_array:
  description: "Default export is an Array"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "Array"

invariant binaryextensions.includes_png:
  description: "List includes 'png'"
  category: contains
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: includes, args: ["png"]}
  expected: true

invariant binaryextensions.includes_pdf:
  description: "List includes 'pdf'"
  category: contains
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: includes, args: ["pdf"]}
  expected: true

invariant binaryextensions.includes_gif:
  description: "List includes 'gif'"
  category: contains
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: includes, args: ["gif"]}
  expected: true

invariant binaryextensions.excludes_md:
  description: "List does not include 'md' (text)"
  category: contains
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: includes, args: ["md"]}
  expected: false

invariant binaryextensions.excludes_js:
  description: "List does not include 'js' (text)"
  category: contains
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: includes, args: ["js"]}
  expected: false

invariant binaryextensions.includes_eot:
  description: "List includes 'eot' (font binary)"
  category: contains
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: includes, args: ["eot"]}
  expected: true
