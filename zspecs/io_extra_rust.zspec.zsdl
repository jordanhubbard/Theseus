  notes:
    - "io provides I/O stream classes."
    - "io.StringIO('hello').read() == 'hello'."
    - "io.BytesIO(b'hello').read() == b'hello'."
    - "io.StringIO is a class."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant io_extra_rust.stringio_read:
  description: "io.StringIO('hello').read() == 'hello'"
  category: stringio
  kind: python_call_eq
  function: io_extra_stringio_read
  args: []
  expected: "hello"

invariant io_extra_rust.bytesio_read:
  description: "io.BytesIO(b'hello').read() == b'hello'"
  category: bytesio
  kind: python_call_eq
  function: io_extra_bytesio_read
  args: []
  expected: true

invariant io_extra_rust.has_string_io:
  description: "io.StringIO is a class"
  category: presence
  kind: python_call_eq
  function: io_extra_has_string_io
  args: []
  expected: true

