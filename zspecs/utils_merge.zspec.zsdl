spec: utils_merge
version: ">=1.0.0"
backend: node(utils-merge)

docs: https://github.com/jaredhanson/utils-merge#readme

provenance:
  derived_from:
    - "utils-merge README — https://github.com/jaredhanson/utils-merge#readme"
    - "Test vectors verified with utils-merge@1.0.1 pre-installed in theseus repo, 2026-04-24"
  not_derived_from:
    - "utils-merge source: index.js"
  notes:
    - "utils-merge exports a single function that shallowly merges src properties into dst."
    - "merge(dst, src) modifies dst in place and returns dst."
    - "This is a SHALLOW merge: nested objects are overwritten, not recursively merged."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns dst object with src properties merged in. No errors for object inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table utils_merge.merge:
  kind: node_module_call_eq
  function: ~
  category: merge
  id_prefix: um

  columns: [id, args, expected]
  rows:
    - [flat,     [{"x": 1}, {"y": 2}],                       {"x": 1, "y": 2}]
    - [overlap,  [{"a": 1}, {"a": 2, "b": 3}],               {"a": 2, "b": 3}]
    - [shallow,  [{"a": 1, "b": {"c": 2}}, {"b": {"d": 3}}], {"a": 1, "b": {"d": 3}}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:15:55Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
