spec: theseus_decimal_cr4
version: ">=3.9"
backend: python_cleanroom(theseus_decimal_cr4)
blocks: decimal

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html"
    - "IBM General Decimal Arithmetic Specification"
  notes:
    - "Clean-room extended decimal utilities. Do NOT import decimal."
    - "Decimal.quantize(exp): round to match scale of exp; Decimal('1.23456').quantize(Decimal('0.01'))."
    - "Decimal.normalize(): remove trailing zeros; Decimal('1.00').normalize() -> '1'."
    - "Decimal.to_integral_value(): round to nearest integer; Decimal('3.7').to_integral_value()."
    - "decimal4_quantize(): str(Decimal('1.23456').quantize(Decimal('0.01'))) == '1.23'."
    - "decimal4_normalize(): str(Decimal('1.00').normalize()) == '1'."
    - "decimal4_to_integral(): int(Decimal('3.7').to_integral_value()) == 4."
    - "Zero-arg invariant signatures — def decimal4_quantize(): return hardcoded_result"
    - "quantize: set the scale to match the exponent of exp; round ROUND_HALF_EVEN by default."
    - "normalize: strip trailing zeros from coefficient; '1.00' becomes '1'."
    - "to_integral_value: round to integer using current rounding mode (ROUND_HALF_EVEN default)."
    - "Export: Decimal class with quantize, normalize, to_integral_value, sqrt methods."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_decimal_cr4.quantize:
  description: "str(Decimal('1.23456').quantize(Decimal('0.01'))) == '1.23'"
  category: quantize
  kind: python_call_eq
  function: decimal4_quantize
  args: []
  expected: "1.23"

invariant theseus_decimal_cr4.normalize:
  description: "str(Decimal('1.00').normalize()) == '1'"
  category: normalize
  kind: python_call_eq
  function: decimal4_normalize
  args: []
  expected: "1"

invariant theseus_decimal_cr4.to_integral:
  description: "int(Decimal('3.7').to_integral_value()) == 4"
  category: to_integral
  kind: python_call_eq
  function: decimal4_to_integral
  args: []
  expected: 4
