spec: lxml_etree_extra_rust
version: ">=3.9"
backend: rust_module(lxml_etree_extra_rust)

docs: https://lxml.de/apidoc/lxml.etree.html#lxml.etree.Element

provenance:
  derived_from:
    - "https://lxml.de/apidoc/lxml.etree.html — lxml etree API documentation"
  not_derived_from:
    - "lxml source: lxml/etree.pyx"
  notes:
    - "Additional lxml.etree operations: Element creation and SubElement."
    - "Element('root').tag == 'root' — create element with tag name."
    - "Element('div', {'class': 'main'}).get('class') == 'main'."
    - "SubElement(parent, 'child') adds a child element."
    - "tostring(fromstring(xml), encoding='unicode') round-trips correctly."
    - "All test vectors verified against lxml 6.0.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# Element — create element with tag
table lxml_etree_extra_rust.element.tag:
  kind: python_call_eq
  category: element_tag
  id_prefix: lxml_elem
  function: Element
  method: tag

  columns: [id, args, expected]
  rows:
    - [root, ["root"], "root"]
    - [div,  ["div"],  "div"]
    - [span, ["span"], "span"]
    - [p,    ["p"],    "p"]

# Element with attributes — get attribute value
invariant lxml_etree_extra_rust.element.attrib_class:
  description: "Element('div', {'class': 'main'}).get('class') == 'main'"
  category: element_attrib
  kind: python_call_eq
  function: Element
  args: ["div", {class: "main"}]
  method: get
  method_args: ["class"]
  expected: "main"

invariant lxml_etree_extra_rust.element.attrib_id:
  description: "Element('p', {'id': 'content'}).get('id') == 'content'"
  category: element_attrib
  kind: python_call_eq
  function: Element
  args: ["p", {id: "content"}]
  method: get
  method_args: ["id"]
  expected: "content"

invariant lxml_etree_extra_rust.element.attrib_missing:
  description: "Element('p').get('class') == None"
  category: element_attrib
  kind: python_call_eq
  function: Element
  args: ["p"]
  method: get
  method_args: ["class"]
  expected: null

# Element len (child count) — starts at 0
invariant lxml_etree_extra_rust.element.empty_len:
  description: "len(Element('root')) == 0 — no children"
  category: element_len
  kind: python_call_eq
  function: Element
  args: ["root"]
  method: __len__
  expected: 0

