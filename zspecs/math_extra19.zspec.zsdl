spec: math_extra19
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl and prior extras through math_extra18.zspec.zsdl."
    - "math.zspec covers tau.__gt__(6.28) and tau.__lt__(6.29); no prior spec uses coarser bounds tau.__gt__(6) or tau.__lt__(7)."
    - "math_extra covers ceil/floor/trunc with 3.7/3.2/3.9 args; no prior spec uses 2.1/2.9 args."
    - "math_extra18 covers gcd(0,5), gcd(12,8), gcd(100,75), gcd(7,0); no prior spec covers gcd(9,6) or gcd(15,10)."
    - "math.tau.__gt__(6) == True — tau (~6.283) is greater than 6."
    - "math.tau.__lt__(7) == True — tau (~6.283) is less than 7."
    - "math.ceil(2.1) == 3 — smallest integer >= 2.1 is 3."
    - "math.floor(2.9) == 2 — largest integer <= 2.9 is 2."
    - "math.trunc(2.9) == 2 — truncation toward zero of 2.9 is 2."
    - "math.gcd(9, 6) == 3 — 9 = 3*3, 6 = 3*2, gcd = 3."
    - "math.gcd(15, 10) == 5 — 15 = 5*3, 10 = 5*2, gcd = 5."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# math.tau — coarse integer bounds
#
# math.zspec pins tau between 6.28 and 6.29. No prior spec uses the
# simpler integer bounds tau.__gt__(6) and tau.__lt__(7). These are
# broad sanity checks confirming tau is in the range (6, 7).
# ---------------------------------------------------------------------------

invariant math_extra19.tau.gt_6:
  description: "math.tau.__gt__(6) == True — tau (~6.283) is greater than 6"
  category: constants
  kind: python_call_eq
  function: tau.__gt__
  args: [6]
  expected: true

invariant math_extra19.tau.lt_7:
  description: "math.tau.__lt__(7) == True — tau (~6.283) is less than 7"
  category: constants
  kind: python_call_eq
  function: tau.__lt__
  args: [7]
  expected: true

# ---------------------------------------------------------------------------
# math.ceil, math.floor, math.trunc — positive non-integer inputs
#
# math_extra covers 3.7/3.2/3.9 args. No prior spec uses 2.1/2.9 args.
# All three return int on Python 3.
# ---------------------------------------------------------------------------

invariant math_extra19.ceil.two_point_one:
  description: "math.ceil(2.1) == 3 — smallest integer >= 2.1 is 3"
  category: rounding
  kind: python_call_eq
  function: ceil
  args: [2.1]
  expected: 3

invariant math_extra19.floor.two_point_nine:
  description: "math.floor(2.9) == 2 — largest integer <= 2.9 is 2"
  category: rounding
  kind: python_call_eq
  function: floor
  args: [2.9]
  expected: 2

invariant math_extra19.trunc.two_point_nine:
  description: "math.trunc(2.9) == 2 — truncation toward zero of 2.9 is 2"
  category: rounding
  kind: python_call_eq
  function: trunc
  args: [2.9]
  expected: 2

# ---------------------------------------------------------------------------
# math.gcd — additional argument pairs
#
# math_extra18 covers gcd(0,5), gcd(12,8), gcd(100,75), gcd(7,0).
# No prior spec covers gcd(9,6)==3 or gcd(15,10)==5.
# ---------------------------------------------------------------------------

table math_extra19.gcd:
  kind: python_call_eq
  category: number_theory
  id_prefix: gcd

  columns: [id, function, args, expected]
  rows:
    - [nine_six,     gcd, [9, 6],   3]
    - [fifteen_ten,  gcd, [15, 10], 5]
