spec: itertools_extra3
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Extends itertools.zspec.zsdl, itertools_extra.zspec.zsdl, itertools_extra2.zspec.zsdl."
    - "Previous specs cover: class names, call results, length hints, first elements for chain/compress/dropwhile/filterfalse/groupby/islice/starmap/takewhile/zip_longest/accumulate/combinations/combinations_with_replacement/permutations/product/count/cycle/repeat."
    - "This spec adds: __module__ checks for all 15 itertools iterator types — all report '__module__ == itertools'."
    - "All itertools C iterator types (__class__.__module__) report 'itertools' as their module."
    - "chain.__module__ == 'itertools'; compress.__module__ == 'itertools'; etc."
    - "These checks confirm that class objects (not instances) have __module__ == 'itertools'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ table — all 15 itertools iterator types
#
# Every public itertools C type reports __module__ == 'itertools'.
# ---------------------------------------------------------------------------

table itertools_extra3.module_checks:
  kind: python_call_eq
  category: module_checks
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [chain,                          chain.__module__.__eq__,                          ["itertools"], true]
    - [compress,                       compress.__module__.__eq__,                       ["itertools"], true]
    - [dropwhile,                      dropwhile.__module__.__eq__,                      ["itertools"], true]
    - [filterfalse,                    filterfalse.__module__.__eq__,                    ["itertools"], true]
    - [groupby,                        groupby.__module__.__eq__,                        ["itertools"], true]
    - [islice,                         islice.__module__.__eq__,                         ["itertools"], true]
    - [starmap,                        starmap.__module__.__eq__,                        ["itertools"], true]
    - [takewhile,                      takewhile.__module__.__eq__,                      ["itertools"], true]
    - [zip_longest,                    zip_longest.__module__.__eq__,                    ["itertools"], true]
    - [accumulate,                     accumulate.__module__.__eq__,                     ["itertools"], true]
    - [combinations,                   combinations.__module__.__eq__,                   ["itertools"], true]
    - [combinations_with_replacement,  combinations_with_replacement.__module__.__eq__,  ["itertools"], true]
    - [permutations,                   permutations.__module__.__eq__,                   ["itertools"], true]
    - [product,                        product.__module__.__eq__,                        ["itertools"], true]
    - [count,                          count.__module__.__eq__,                          ["itertools"], true]

# ---------------------------------------------------------------------------
# Standalone invariants — cycle and repeat __module__ (outside the table for
# cross-reference discoverability)
# ---------------------------------------------------------------------------

invariant itertools_extra3.cycle.module:
  description: "itertools.cycle.__module__ == 'itertools'"
  category: module_checks
  kind: python_call_eq
  function: cycle.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra3.repeat.module:
  description: "itertools.repeat.__module__ == 'itertools'"
  category: module_checks
  kind: python_call_eq
  function: repeat.__module__.__eq__
  args: ["itertools"]
  expected: true
