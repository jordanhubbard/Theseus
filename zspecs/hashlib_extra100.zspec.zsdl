spec: hashlib_extra100
version: ">=3.9"
backend: python_module(hashlib)
extends: hashlib_extra99

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra99.zspec.zsdl — covers hashlib.md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s class identity and __module__/__qualname__ / new.__class__.__name__=='function' / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers hashlib.sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership for sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512/sha3_224/sha3_384/blake2b/blake2s/shake_128/shake_256 / algorithms_available membership / new/__qualname__/__len__() (table + invariants)."
    - "hashlib_extra76.zspec.zsdl — covers hashlib.new/__qualname__.__eq__('__hash_new') / new/__code__.co_argcount.__eq__(1) (table + invariants)."
    - "hashlib_extra74.zspec.zsdl — covers hashlib.scrypt/__class__.__name__=='builtin_function_or_method' (table + invariants)."
    - "hashlib_extra71.zspec.zsdl — covers hashlib.pbkdf2_hmac/__class__.__name__=='builtin_function_or_method' (table + invariants)."
    - "hashlib_extra43.zspec.zsdl — covers hashlib.scrypt/__qualname__.__eq__('scrypt') / pbkdf2_hmac/__qualname__.__eq__('pbkdf2_hmac') (invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra99; it does NOT duplicate invariants present in those files."
    - "Wave 260 theme: hashlib SHAKE/pbkdf2_hmac/scrypt __name__ and __module__ identity — shake_128.__name__/__qualname__ / shake_256.__name__/__qualname__ / pbkdf2_hmac.__module__ / scrypt.__module__ / new.__name__.__eq__('__hash_new') / algorithms_available.__len__() == 19."
    - "hashlib.shake_128.__name__ == 'openssl_shake_128'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__name__ == 'openssl_shake_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__qualname__ == 'openssl_shake_128'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__qualname__ == 'openssl_shake_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__qualname__ == 'scrypt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__name__ == '__hash_new'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__len__() == 19. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: shake_128/shake_256 __name__ and __qualname__ are identical ('openssl_shake_128'/'openssl_shake_256'), as is true for all OpenSSL-backed C builtins (C builtins have __name__ == __qualname__ at top-level)."
    - "Note: pbkdf2_hmac and scrypt both live in the _hashlib C extension (__module__ == '_hashlib'). They are C-level functions, not Python-defined."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.shake_128.__name__.__eq__('openssl_shake_128')
# hashlib.shake_256.__name__.__eq__('openssl_shake_256')
# hashlib.shake_128.__qualname__.__eq__('openssl_shake_128')
# hashlib.shake_256.__qualname__.__eq__('openssl_shake_256')
# hashlib.shake_128.__module__.__eq__('_hashlib')
# hashlib.shake_256.__module__.__eq__('_hashlib')
#
# Wave 260 theme: SHAKE XOF constructor __name__, __qualname__, and __module__ identity.
#
# shake_128 and shake_256 are extendable-output functions (XOFs) from the SHA-3
# family, implemented in C via the _hashlib extension wrapping OpenSSL. Their
# __name__ and __qualname__ are identical ('openssl_shake_128' / 'openssl_shake_256')
# because C builtins at top level have __name__ == __qualname__. Their __module__
# is '_hashlib'. hashlib_extra98 anchors shake_128/__qualname__ and __module__
# in a table; this table groups all six name/qualname/module checks together as a
# complete cross-check under hashlibshake100. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra100.shake_name_qualname_module:
  description: "hashlib.shake_128/__name__.__eq__('openssl_shake_128')==True / shake_256/__name__.__eq__('openssl_shake_256')==True / shake_128/__qualname__.__eq__('openssl_shake_128')==True / shake_256/__qualname__.__eq__('openssl_shake_256')==True / shake_128/__module__.__eq__('_hashlib')==True / shake_256/__module__.__eq__('_hashlib')==True — SHAKE XOF constructors are OpenSSL-backed C builtins from _hashlib; __name__==__qualname__ for C builtins at top level; hashlib_extra98 anchors shake qualname/module in a table; this groups all six together; first hashlibshake100 anchor for shake __name__/__qualname__/__module__ cross-check"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibshake100

  columns: [id, function, args, expected]
  rows:
    - [shake128_name,     shake_128.__name__.__eq__,     ["openssl_shake_128"], true]
    - [shake256_name,     shake_256.__name__.__eq__,     ["openssl_shake_256"], true]
    - [shake128_qualname, shake_128.__qualname__.__eq__,  ["openssl_shake_128"], true]
    - [shake256_qualname, shake_256.__qualname__.__eq__,  ["openssl_shake_256"], true]
    - [shake128_module,   shake_128.__module__.__eq__,    ["_hashlib"],          true]
    - [shake256_module,   shake_256.__module__.__eq__,    ["_hashlib"],          true]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib')
# hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac')
# hashlib.scrypt.__module__.__eq__('_hashlib')
# hashlib.scrypt.__qualname__.__eq__('scrypt')
# hashlib.new.__name__.__eq__('__hash_new')
# hashlib.algorithms_available.__len__()==19
#
# Wave 260 theme: pbkdf2_hmac/scrypt module identity / new __name__ / algorithms_available length.
#
# pbkdf2_hmac and scrypt are both C-level functions in the _hashlib extension
# (__module__ == '_hashlib'). Their __qualname__ equals their __name__ ('pbkdf2_hmac'
# and 'scrypt' respectively). hashlib.new is actually exposed as __hash_new (its
# internal name); new.__name__ == '__hash_new'. algorithms_available has 19 members
# on Python 3.14.3 macOS (platform-dependent, unlike the 14-member guaranteed set).
# No prior hashlib spec anchors pbkdf2_hmac/__module__ or scrypt/__module__ as
# __eq__ calls, or new/__name__.__eq__('__hash_new') as a cross-check, or
# algorithms_available/__len__()==19 under hashlibshake100.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra100.pbkdf2_scrypt_new_algavail:
  description: "hashlib.pbkdf2_hmac/__module__.__eq__('_hashlib')==True / pbkdf2_hmac/__qualname__.__eq__('pbkdf2_hmac')==True / scrypt/__module__.__eq__('_hashlib')==True / scrypt/__qualname__.__eq__('scrypt')==True / new/__name__.__eq__('__hash_new')==True / algorithms_available/__len__()==19 — pbkdf2_hmac and scrypt are C-level _hashlib functions; new.__name__ is its internal name '__hash_new'; algorithms_available has 19 members on Python 3.14.3 macOS (platform-dependent); no prior hashlib spec anchors these six together; first hashlibshake100 anchor for pbkdf2_hmac/scrypt __module__/__qualname__ and new __name__ cross-check"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibshake100

  columns: [id, function, args, expected]
  rows:
    - [pbkdf2_module,     pbkdf2_hmac.__module__.__eq__,     ["_hashlib"],    true]
    - [pbkdf2_qualname,   pbkdf2_hmac.__qualname__.__eq__,   ["pbkdf2_hmac"], true]
    - [scrypt_module,     scrypt.__module__.__eq__,          ["_hashlib"],    true]
    - [scrypt_qualname,   scrypt.__qualname__.__eq__,        ["scrypt"],      true]
    - [new_name,          new.__name__.__eq__,               ["__hash_new"],  true]
    - [algavail_len,      algorithms_available.__len__,      [],              19]

# ---------------------------------------------------------------------------
# hashlib.shake_128.__name__.__eq__('openssl_shake_128') — standalone
#
# hashlib.shake_128.__name__ is 'openssl_shake_128'. shake_128 is an
# extendable-output function (XOF) from the SHA-3 family backed by OpenSSL via
# the _hashlib C extension. The 'openssl_' prefix in __name__ identifies the
# OpenSSL implementation (as opposed to a pure-Python fallback). For C builtins,
# __name__ equals __qualname__ at the top level. hashlib_extra98 anchors
# shake_128.__qualname__ in a table; this invariant cross-checks __name__ as a
# standalone under hashlibshake100. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra100.shake128_name_openssl:
  description: "hashlib.shake_128.__name__.__eq__('openssl_shake_128') == True — shake_128 is a SHA-3 XOF backed by OpenSSL (_hashlib); __name__ carries the 'openssl_' prefix; for C builtins __name__==__qualname__ at top level; hashlib_extra98 anchors __qualname__; this is the first standalone for shake_128 __name__ under hashlibshake100"
  category: type_identity
  kind: python_call_eq
  function: shake_128.__name__.__eq__
  args: ["openssl_shake_128"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') — standalone
#
# hashlib.pbkdf2_hmac.__module__ is '_hashlib'. pbkdf2_hmac is the PBKDF2-HMAC
# key derivation function, implemented in C within the _hashlib extension.
# This is distinct from hashlib.new (a Python function in 'hashlib' module).
# hashlib_extra43 anchors pbkdf2_hmac.__qualname__; hashlib_extra71 anchors
# pbkdf2_hmac.__class__.__name__; no prior spec anchors __module__.__eq__ for
# pbkdf2_hmac as a standalone under hashlibshake100.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra100.pbkdf2_module_hashlib:
  description: "hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') == True — pbkdf2_hmac is the PBKDF2-HMAC KDF, implemented in C within the _hashlib extension; its __module__ is '_hashlib' (not 'hashlib'); hashlib_extra43 anchors __qualname__; hashlib_extra71 anchors class name; this is the first standalone for pbkdf2_hmac __module__ under hashlibshake100"
  category: type_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.scrypt.__module__.__eq__('_hashlib') — standalone
#
# hashlib.scrypt.__module__ is '_hashlib'. scrypt is the scrypt password-based
# key derivation function (RFC 7914), implemented in C within the _hashlib
# extension using OpenSSL. Like pbkdf2_hmac, scrypt is a memory-hard KDF
# rather than a simple hash constructor. hashlib_extra43 anchors scrypt.__qualname__;
# hashlib_extra74 anchors scrypt.__class__.__name__; no prior spec anchors
# scrypt.__module__.__eq__ as a standalone under hashlibshake100.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra100.scrypt_module_hashlib:
  description: "hashlib.scrypt.__module__.__eq__('_hashlib') == True — scrypt is the RFC 7914 password-based KDF, implemented in C within the _hashlib extension via OpenSSL; its __module__ is '_hashlib'; hashlib_extra43 anchors __qualname__; hashlib_extra74 anchors class name; this is the first standalone for scrypt __module__ under hashlibshake100"
  category: type_identity
  kind: python_call_eq
  function: scrypt.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__name__.__eq__('__hash_new') — standalone
#
# hashlib.new.__name__ is '__hash_new'. Although exposed publicly as
# hashlib.new, the underlying Python function is internally named __hash_new.
# This internal name reflects that the function is a private implementation
# detail — the public API is the name 'hashlib.new', but the code object's
# co_name (and __name__, __qualname__) is '__hash_new'. hashlib_extra76 anchors
# new.__qualname__.__eq__('__hash_new') in a table; this invariant cross-checks
# new.__name__ as a standalone under hashlibshake100.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra100.new_name_hash_new:
  description: "hashlib.new.__name__.__eq__('__hash_new') == True — hashlib.new is exposed publicly as 'new' but its internal function name is '__hash_new'; __name__ is '__hash_new' (not 'new'); hashlib_extra76 anchors new.__qualname__.__eq__('__hash_new'); this cross-checks __name__ as a standalone under hashlibshake100"
  category: type_identity
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__len__()==19 — standalone
#
# hashlib.algorithms_available.__len__() is 19. Unlike algorithms_guaranteed
# (exactly 14 algorithms across all Python platforms), algorithms_available
# is platform-dependent and includes additional OpenSSL-provided hash algorithms.
# On Python 3.14.3 macOS/Darwin 25.4.0, 19 algorithms are available. The extra
# five (beyond the 14 guaranteed) are provided by the OpenSSL implementation
# on this platform. hashlib_extra34 first anchors this value; this invariant
# cross-checks it as a standalone under hashlibshake100.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra100.algorithms_available_len_19:
  description: "hashlib.algorithms_available.__len__() == 19 — algorithms_available is platform-dependent (unlike the 14-member guaranteed set); on Python 3.14.3 macOS/Darwin 25.4.0, 19 hash algorithms are available via OpenSSL; hashlib_extra34 first anchors this; cross-checked as standalone under hashlibshake100"
  category: type_identity
  kind: python_call_eq
  function: algorithms_available.__len__
  args: []
  expected: 19

