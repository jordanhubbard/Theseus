spec: signal_extra4
version: ">=3.9"
backend: python_module(signal)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "Python signal documentation — https://docs.python.org/3/library/signal.html"
    - "POSIX.1-2017 — The Open Group Base Specifications Issue 7, 2018 Edition"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
  notes:
    - "Extends signal.zspec.zsdl, signal_extra.zspec.zsdl, signal_extra2.zspec.zsdl, and signal_extra3.zspec.zsdl."
    - "signal.zspec.zsdl covers: POSIX signal integer values; Signals/Handlers class names; SIG_DFL/SIG_IGN values; strsignal strings."
    - "signal_extra.zspec.zsdl covers: getsignal/raise_signal/strsignal/valid_signals __name__ table; SIG_DFL/SIG_IGN/SIGABRT/SIGFPE/SIGILL/SIGINT/SIGSEGV/SIGTERM class names; valid_signals() return type and membership."
    - "signal_extra2.zspec.zsdl covers: function __module__ table (signal/getsignal/raise_signal/strsignal/valid_signals); signal.__name__; getsignal.__name__; SIG_DFL/SIG_IGN/SIGTERM/SIGINT class names (standalone); Signals/Handlers __name__ (standalone); Signals/Handlers __bases__[0].__name__."
    - "signal_extra3.zspec.zsdl covers: module __name__ attribute; NSIG >= 16; NSIG.__class__.__name__ == 'int'; SIGHUP/SIGKILL/SIGQUIT/SIGALRM/SIGPIPE class names; SIGHUP/SIGKILL .name; SIG_DFL/SIG_IGN .name."
    - "This spec adds: __qualname__ checks for signal/getsignal/raise_signal/strsignal/valid_signals functions; __qualname__ for Signals and Handlers classes; Signals.__module__ and Handlers.__module__."
    - "Module-level functions defined directly in the signal module have __qualname__ equal to their __name__ (no class prefix)."
    - "Signals.__module__ == 'signal' and Handlers.__module__ == 'signal' — both enum classes are defined in the signal module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ checks
# Module-level callables in the signal module have __qualname__ == __name__
# because they are not nested inside any class. None of the prior specs
# cover __qualname__ for any signal callable.
# ---------------------------------------------------------------------------

table signal_extra4.function_qualnames:
  description: "signal callables have __qualname__ equal to their unqualified name"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [signal,        signal.__qualname__.__eq__,        ["signal"],        true]
    - [getsignal,     getsignal.__qualname__.__eq__,     ["getsignal"],     true]
    - [raise_signal,  raise_signal.__qualname__.__eq__,  ["raise_signal"],  true]
    - [strsignal,     strsignal.__qualname__.__eq__,     ["strsignal"],     true]
    - [valid_signals, valid_signals.__qualname__.__eq__, ["valid_signals"], true]

# ---------------------------------------------------------------------------
# Signals and Handlers enum class __qualname__
# Enum classes defined at module scope have __qualname__ equal to __name__.
# No prior spec covers __qualname__ for either enum class.
# ---------------------------------------------------------------------------

invariant signal_extra4.Signals.qualname:
  description: "signal.Signals.__qualname__ == 'Signals' — module-level enum class"
  category: enum_qualnames
  kind: python_call_eq
  function: Signals.__qualname__.__eq__
  args: ["Signals"]
  expected: true

invariant signal_extra4.Handlers.qualname:
  description: "signal.Handlers.__qualname__ == 'Handlers' — module-level enum class"
  category: enum_qualnames
  kind: python_call_eq
  function: Handlers.__qualname__.__eq__
  args: ["Handlers"]
  expected: true

# ---------------------------------------------------------------------------
# Signals and Handlers enum class __module__
# signal_extra2 covers the *function* named 'signal' in its module-checks table.
# No prior spec checks Signals.__module__ or Handlers.__module__.
# ---------------------------------------------------------------------------

invariant signal_extra4.Signals.module:
  description: "signal.Signals.__module__ == 'signal' — Signals enum is defined in the signal module"
  category: enum_modules
  kind: python_call_eq
  function: Signals.__module__.__eq__
  args: ["signal"]
  expected: true

invariant signal_extra4.Handlers.module:
  description: "signal.Handlers.__module__ == 'signal' — Handlers enum is defined in the signal module"
  category: enum_modules
  kind: python_call_eq
  function: Handlers.__module__.__eq__
  args: ["signal"]
  expected: true
