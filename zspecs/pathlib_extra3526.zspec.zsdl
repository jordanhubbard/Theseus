# ---------------------------------------------------------------------------

table pp3526.set_name:
  description: "pathlib types __set_name__ dict-presence checks; wave 682"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3526
  columns: [id, function, args, expected]
  rows:
