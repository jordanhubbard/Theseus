spec: fast_fifo
version: ">=1.0.0"
backend: node(fast-fifo)

docs: https://github.com/mafintosh/fast-fifo#readme

provenance:
  derived_from:
    - "fast-fifo README — https://github.com/mafintosh/fast-fifo#readme"
    - "Test vectors verified with fast-fifo via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "fast-fifo source"
  notes:
    - "Tiny fast FIFO queue — used by streamx, hyperswarm, etc. for fixed-size head/tail dequeue."
    - "Install: npm install fast-fifo"
    - "v1 CJS; module export IS the queue constructor."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Methods never throw."
  stderr: "null"
  stickiness: "N/A — each queue independent."
  codes: {}

invariant fast_fifo.module_is_constructor:
  description: "Module export is a function (the FIFO class)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant fast_fifo.fresh_queue_isEmpty:
  description: "Fresh queue's isEmpty() is true"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: isEmpty, args: []}
  expected: true

invariant fast_fifo.push_then_isEmpty_false:
  description: "After push(v), isEmpty() is false"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: push, args: [1], tap: true}
    - {method: isEmpty, args: []}
  expected: false

invariant fast_fifo.push_then_shift_FIFO:
  description: "FIFO order — first pushed is first shifted"
  category: order
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: push, args: [10], tap: true}
    - {method: push, args: [20], tap: true}
    - {method: shift, args: []}
  expected: 10

invariant fast_fifo.shift_when_empty_undefined:
  description: "shift() on empty queue returns undefined"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: shift, args: []}
  expected: ~

invariant fast_fifo.peek_when_empty_undefined:
  description: "peek() on empty queue returns undefined"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: peek, args: []}
  expected: ~

invariant fast_fifo.push_three_then_shift_three_empty:
  description: "Push 3, shift 3 → isEmpty true again"
  category: order
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: push, args: [1], tap: true}
    - {method: push, args: [2], tap: true}
    - {method: push, args: [3], tap: true}
    - {method: shift, args: [], tap: true}
    - {method: shift, args: [], tap: true}
    - {method: shift, args: [], tap: true}
    - {method: isEmpty, args: []}
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:52:08Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
