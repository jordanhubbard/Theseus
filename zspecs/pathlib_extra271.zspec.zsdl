spec: pathlib_extra271
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "PurePosixPath('/a/b/c.txt').suffix == '.txt' — last suffix of a single-extension filename."
    - "PurePosixPath('/a/b/c.txt').stem == 'c' — stem is the filename without its last suffix."
    - "PurePosixPath('/a/b/c.txt').suffixes == ['.txt'] — list of all suffixes; single-extension has one element."
    - "len(PurePosixPath('/a/b/c.txt').suffixes) == 1 — single-extension file has exactly one suffix."
    - "PurePosixPath('archive.tar.gz').suffixes == ['.tar', '.gz'] — multi-extension file has two suffixes."
    - "PurePosixPath('archive.tar.gz').suffix == '.gz' — last suffix is the outermost extension."
    - "PurePosixPath('archive.tar.gz').stem == 'archive.tar' — stem drops only the last suffix."
    - "len(PurePosixPath('archive.tar.gz').suffixes) == 2 — double-extension file has two suffixes."
    - "PurePosixPath('/usr/local/bin').parents has 3 entries: /usr/local, /usr, /."
    - "str(list(PurePosixPath('/usr/local/bin').parents)[0]) == '/usr/local' — first parent."
    - "str(list(PurePosixPath('/usr/local/bin').parents)[1]) == '/usr' — second parent."
    - "str(list(PurePosixPath('/usr/local/bin').parents)[2]) == '/' — root parent."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePosixPath suffix/stem/name — single extension
# ---------------------------------------------------------------------------

invariant pathlib_extra271.purepath.suffix_single:
  description: "PurePosixPath('/a/b/c.txt').suffix == '.txt'"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c.txt"]
  method: suffix
  expected: ".txt"

invariant pathlib_extra271.purepath.stem_single:
  description: "PurePosixPath('/a/b/c.txt').stem == 'c'"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c.txt"]
  method: stem
  expected: "c"

invariant pathlib_extra271.purepath.suffixes_single:
  description: "PurePosixPath('/a/b/c.txt').suffixes == ['.txt']"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c.txt"]
  method: suffixes
  expected: [".txt"]

invariant pathlib_extra271.purepath.suffixes_single_len:
  description: "len(PurePosixPath('/a/b/c.txt').suffixes) == 1"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c.txt"]
  method: suffixes
  method_chain: __len__
  expected: 1

# ---------------------------------------------------------------------------
# PurePosixPath suffix/stem — multiple extensions
# ---------------------------------------------------------------------------

invariant pathlib_extra271.purepath.suffix_multi:
  description: "PurePosixPath('archive.tar.gz').suffix == '.gz' — last suffix only"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["archive.tar.gz"]
  method: suffix
  expected: ".gz"

invariant pathlib_extra271.purepath.stem_multi:
  description: "PurePosixPath('archive.tar.gz').stem == 'archive.tar' — stem drops only last suffix"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["archive.tar.gz"]
  method: stem
  expected: "archive.tar"

invariant pathlib_extra271.purepath.suffixes_multi:
  description: "PurePosixPath('archive.tar.gz').suffixes == ['.tar', '.gz']"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["archive.tar.gz"]
  method: suffixes
  expected: [".tar", ".gz"]

invariant pathlib_extra271.purepath.suffixes_multi_len:
  description: "len(PurePosixPath('archive.tar.gz').suffixes) == 2"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["archive.tar.gz"]
  method: suffixes
  method_chain: __len__
  expected: 2

# ---------------------------------------------------------------------------
# PurePosixPath.parents — tuple length and str values for /usr/local/bin
# ---------------------------------------------------------------------------

invariant pathlib_extra271.purepath.parents_len:
  description: "len(list(PurePosixPath('/usr/local/bin').parents)) == 3"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/local/bin"]
  method: parents
  method_chain: __len__
  expected: 3

invariant pathlib_extra271.purepath.parents_first:
  description: "str(list(PurePosixPath('/usr/local/bin').parents)[0]) == '/usr/local'"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/local/bin"]
  method: parents
  method_chain: __getitem__
  method_chain_args: [0]
  method_chain2: __str__
  expected: "/usr/local"

invariant pathlib_extra271.purepath.parents_second:
  description: "str(list(PurePosixPath('/usr/local/bin').parents)[1]) == '/usr'"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/local/bin"]
  method: parents
  method_chain: __getitem__
  method_chain_args: [1]
  method_chain2: __str__
  expected: "/usr"

invariant pathlib_extra271.purepath.parents_root:
  description: "str(list(PurePosixPath('/usr/local/bin').parents)[2]) == '/'"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/local/bin"]
  method: parents
  method_chain: __getitem__
  method_chain_args: [2]
  method_chain2: __str__
  expected: "/"

# ---------------------------------------------------------------------------
# Table: suffix/stem/name for a single-extension path (tabular form)
# ---------------------------------------------------------------------------

table pathlib_extra271.single_ext_components:
  description: "suffix, stem, and name for /a/b/c.txt via PurePosixPath"
  kind: python_call_eq
  category: components
  id_prefix: singext

  columns: [id, args, method, expected]
  rows:
    - [suffix,  ["/a/b/c.txt"],  suffix,  ".txt"]
    - [stem,    ["/a/b/c.txt"],  stem,    "c"]
    - [name,    ["/a/b/c.txt"],  name,    "c.txt"]
