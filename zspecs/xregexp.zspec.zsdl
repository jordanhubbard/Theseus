spec: xregexp
version: ">=5.0.0"
backend: node(xregexp)

docs: https://xregexp.com/

provenance:
  derived_from:
    - "XRegExp documentation — https://xregexp.com/"
    - "Test vectors verified with xregexp via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "xregexp source"
  notes:
    - "XRegExp augments JS regex with Unicode property escapes (\\\\p{Letter}), named groups, free-spacing mode, and more."
    - "Install: npm install xregexp"
    - "Module export IS a constructor: XRegExp(pattern, flags) returns a RegExp-compatible object with .test()."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure construction; throws on syntax errors only."
  stderr: "null"
  stickiness: "N/A — each XRegExp is stateless."
  codes: {}

# \\p{Letter} — Unicode letter category
invariant xregexp.unicode_letter_match_ascii:
  description: "\\\\p{Letter} matches plain ASCII letters"
  category: unicode_property
  kind: node_chain_eq
  entry: module
  entry_args: ["^\\p{Letter}+$", ""]
  chain:
    - {method: test, args: ["hello"]}
  expected: true

invariant xregexp.unicode_letter_no_match_digit:
  description: "\\\\p{Letter} does not match digit-containing strings (anchored)"
  category: unicode_property
  kind: node_chain_eq
  entry: module
  entry_args: ["^\\p{Letter}+$", ""]
  chain:
    - {method: test, args: ["hello123"]}
  expected: false

invariant xregexp.unicode_letter_matches_cyrillic:
  description: "\\\\p{Letter} matches Cyrillic"
  category: unicode_property
  kind: node_chain_eq
  entry: module
  entry_args: ["^\\p{Letter}+$", ""]
  chain:
    - {method: test, args: ["Москва"]}
  expected: true

invariant xregexp.unicode_letter_matches_chinese:
  description: "\\\\p{Letter} matches CJK ideographs"
  category: unicode_property
  kind: node_chain_eq
  entry: module
  entry_args: ["^\\p{Letter}+$", ""]
  chain:
    - {method: test, args: ["日本語"]}
  expected: true

# Decimal digit category \\p{Nd}
invariant xregexp.decimal_digit_match:
  description: "\\\\p{Nd} matches digit-only strings"
  category: unicode_property
  kind: node_chain_eq
  entry: module
  entry_args: ["^\\p{Nd}+$", ""]
  chain:
    - {method: test, args: ["12345"]}
  expected: true

invariant xregexp.decimal_digit_no_match_letter:
  description: "\\\\p{Nd} does NOT match letters"
  category: unicode_property
  kind: node_chain_eq
  entry: module
  entry_args: ["^\\p{Nd}+$", ""]
  chain:
    - {method: test, args: ["abc"]}
  expected: false

# Named groups via XRegExp(?<name>...) — exec returns groups
invariant xregexp.indexed_capture_year:
  description: "XRegExp .exec() captures via numeric indices (group 1 = year)"
  category: capture
  kind: node_chain_eq
  entry: module
  entry_args: ["(?<year>\\d{4})-(?<month>\\d{2})-(?<day>\\d{2})", ""]
  chain:
    - {method: exec, args: ["2024-06-15"]}
    - {method: at, args: [1]}
  expected: "2024"

invariant xregexp.indexed_capture_month:
  description: "XRegExp .exec() captures month at index 2"
  category: capture
  kind: node_chain_eq
  entry: module
  entry_args: ["(?<year>\\d{4})-(?<month>\\d{2})-(?<day>\\d{2})", ""]
  chain:
    - {method: exec, args: ["2024-06-15"]}
    - {method: at, args: [2]}
  expected: "06"

invariant xregexp.indexed_capture_day:
  description: "XRegExp .exec() captures day at index 3"
  category: capture
  kind: node_chain_eq
  entry: module
  entry_args: ["(?<year>\\d{4})-(?<month>\\d{2})-(?<day>\\d{2})", ""]
  chain:
    - {method: exec, args: ["2024-06-15"]}
    - {method: at, args: [3]}
  expected: "15"
