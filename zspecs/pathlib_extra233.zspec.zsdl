spec: pathlib_extra233
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec covers: pathlib.PurePosixPath component contracts — name, stem, suffix, parent, and is_absolute() behavioral output values."
    - "PurePosixPath('/usr/local/bin/python').name == 'python' — final path component; verified Python 3.14.3 macOS."
    - "PurePosixPath('/usr/local/bin/python').stem == 'python' — no suffix so stem equals name; verified Python 3.14.3 macOS."
    - "PurePosixPath('/usr/local/bin/python').suffix == '' — no extension; verified Python 3.14.3 macOS."
    - "str(PurePosixPath('/usr/local/bin/python').parent) == '/usr/local/bin' — parent directory; verified Python 3.14.3 macOS."
    - "PurePosixPath('/home/user/file.txt').name == 'file.txt' — filename with extension; verified Python 3.14.3 macOS."
    - "PurePosixPath('/home/user/file.txt').stem == 'file' — filename without extension; verified Python 3.14.3 macOS."
    - "PurePosixPath('/home/user/file.txt').suffix == '.txt' — extension including dot; verified Python 3.14.3 macOS."
    - "PurePosixPath('relative/path/file.py').name == 'file.py' — name of relative path; verified Python 3.14.3 macOS."
    - "PurePosixPath('relative/path/file.py').suffix == '.py' — suffix of relative path; verified Python 3.14.3 macOS."
    - "PurePosixPath('/usr/local').is_absolute() == True — absolute path starts with /; verified Python 3.14.3 macOS."
    - "PurePosixPath('relative/path').is_absolute() == False — relative path has no leading /; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath('/usr/local/bin/python') component contracts
# name == 'python', stem == 'python', suffix == '',
# parent.__str__() == '/usr/local/bin'.
# No extension: stem equals name.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra233.PurePosixPath.python_name:
  description: "pathlib.PurePosixPath('/usr/local/bin/python').name == 'python' — final component of the path; no extension so name == stem == 'python'; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/local/bin/python"]
  method: name
  expected: "python"

invariant pathlib_extra233.PurePosixPath.python_stem:
  description: "pathlib.PurePosixPath('/usr/local/bin/python').stem == 'python' — no suffix so stem equals the full final component; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/local/bin/python"]
  method: stem
  expected: "python"

invariant pathlib_extra233.PurePosixPath.python_suffix_empty:
  description: "pathlib.PurePosixPath('/usr/local/bin/python').suffix == '' — no file extension; suffix is empty string; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/local/bin/python"]
  method: suffix
  expected: ""

invariant pathlib_extra233.PurePosixPath.python_parent_str:
  description: "str(pathlib.PurePosixPath('/usr/local/bin/python').parent) == '/usr/local/bin' — parent of the path strips the final component; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/local/bin/python"]
  method: parent.__str__
  expected: "/usr/local/bin"

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath('/home/user/file.txt') component contracts
# name == 'file.txt', stem == 'file', suffix == '.txt'.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra233.PurePosixPath.txt_name:
  description: "pathlib.PurePosixPath('/home/user/file.txt').name == 'file.txt' — final component includes extension; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["/home/user/file.txt"]
  method: name
  expected: "file.txt"

invariant pathlib_extra233.PurePosixPath.txt_stem:
  description: "pathlib.PurePosixPath('/home/user/file.txt').stem == 'file' — stem strips the .txt suffix from 'file.txt'; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["/home/user/file.txt"]
  method: stem
  expected: "file"

invariant pathlib_extra233.PurePosixPath.txt_suffix:
  description: "pathlib.PurePosixPath('/home/user/file.txt').suffix == '.txt' — suffix includes the leading dot; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["/home/user/file.txt"]
  method: suffix
  expected: ".txt"

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath('relative/path/file.py') component contracts
# name == 'file.py', suffix == '.py'.
# Relative path — no leading slash.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra233.PurePosixPath.py_relative_name:
  description: "pathlib.PurePosixPath('relative/path/file.py').name == 'file.py' — name of a relative path is the final component; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["relative/path/file.py"]
  method: name
  expected: "file.py"

invariant pathlib_extra233.PurePosixPath.py_relative_suffix:
  description: "pathlib.PurePosixPath('relative/path/file.py').suffix == '.py' — suffix of a relative path; .py extension with leading dot; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["relative/path/file.py"]
  method: suffix
  expected: ".py"

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath is_absolute() behavioral contracts
# Absolute paths start with '/'; relative paths do not.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra233.PurePosixPath.absolute_true:
  description: "pathlib.PurePosixPath('/usr/local').is_absolute() == True — path starts with '/' so it is absolute; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/local"]
  method: is_absolute
  expected: true

invariant pathlib_extra233.PurePosixPath.relative_not_absolute:
  description: "pathlib.PurePosixPath('relative/path').is_absolute() == False — path has no leading '/' so is_absolute returns False; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["relative/path"]
  method: is_absolute
  expected: false
