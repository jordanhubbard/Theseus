spec: concurrent_futures_extra1651
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __init_subclass__, __set_name__, __class_getitem__"
    - "Covers: absence of __init_subclass__ in concurrent.futures classes (Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor); __class_getitem__ presence on concurrent.futures.Future (supports Future[T] generic alias); absence of __class_getitem__ on executor classes; module-level attr presence in concurrent.futures namespace."
    - "Python 3.14.4 on macOS/Darwin 25.4.0: concurrent.futures.Future has __class_getitem__ in its __dict__ (Future[T] syntax supported). Executor, ThreadPoolExecutor, and ProcessPoolExecutor do NOT have __class_getitem__ in their __dict__. None of the concurrent.futures classes define __init_subclass__ or __set_name__ in their own __dict__ — these hooks are inherited from object but not overridden."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __init_subclass__ absence in concurrent.futures classes
# No concurrent.futures class defines __init_subclass__ in its own __dict__.
# The hook is inherited from object but not overridden.
# Also checks __set_name__ and __class_getitem__ selectively.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1651.no_init_subclass:
  description: "concurrent.futures classes do not define __init_subclass__ or __set_name__ in their own __dict__; only concurrent.futures.Future defines __class_getitem__ (Future[T] generic alias support)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1651ni

  columns: [id, function, args, expected]
  rows:
    - ["cf1651ni001", "concurrent.futures.Future.__dict__.__contains__",              ["__init_subclass__"], false]
    - ["cf1651ni002", "concurrent.futures.Executor.__dict__.__contains__",            ["__init_subclass__"], false]
    - ["cf1651ni003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__init_subclass__"], false]
    - ["cf1651ni004", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__init_subclass__"], false]
    - ["cf1651ni005", "concurrent.futures.Future.__dict__.__contains__",              ["__set_name__"],      false]
    - ["cf1651ni006", "concurrent.futures.Executor.__dict__.__contains__",            ["__set_name__"],      false]
    - ["cf1651ni007", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__set_name__"],      false]
    - ["cf1651ni008", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__set_name__"],      false]
    - ["cf1651ni009", "concurrent.futures.Future.__dict__.__contains__",              ["__class_getitem__"], true]
    - ["cf1651ni010", "concurrent.futures.Executor.__dict__.__contains__",            ["__class_getitem__"], false]
    - ["cf1651ni011", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__class_getitem__"], false]
    - ["cf1651ni012", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__class_getitem__"], false]
    - ["cf1651ni013", "concurrent.futures.Future.__dict__.__contains__",              ["cancel"],            true]
    - ["cf1651ni014", "concurrent.futures.Future.__dict__.__contains__",              ["result"],            true]
    - ["cf1651ni015", "concurrent.futures.Future.__dict__.__contains__",              ["exception"],         true]
    - ["cf1651ni016", "concurrent.futures.Future.__dict__.__contains__",              ["done"],              true]
    - ["cf1651ni017", "concurrent.futures.Future.__dict__.__contains__",              ["running"],           true]
    - ["cf1651ni018", "concurrent.futures.Future.__dict__.__contains__",              ["cancelled"],         true]
    - ["cf1651ni019", "concurrent.futures.Executor.__dict__.__contains__",            ["submit"],            true]
    - ["cf1651ni020", "concurrent.futures.Executor.__dict__.__contains__",            ["map"],               true]
    - ["cf1651ni021", "concurrent.futures.Executor.__dict__.__contains__",            ["shutdown"],          true]
    - ["cf1651ni022", "concurrent.futures.Executor.__dict__.__contains__",            ["__enter__"],         true]
    - ["cf1651ni023", "concurrent.futures.Executor.__dict__.__contains__",            ["__exit__"],          true]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures module-level attribute presence
# Checks that key public names are present in concurrent.futures.__dict__
# covering classes, functions, constants, and exception types.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1651.module_attr_presence:
  description: "concurrent.futures module-level attribute presence — key public names must appear in concurrent.futures.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1651mp

  columns: [id, function, args, expected]
  rows:
    - ["cf1651mp001", "concurrent.futures.__dict__.__contains__", ["Future"],               true]
    - ["cf1651mp002", "concurrent.futures.__dict__.__contains__", ["Executor"],             true]
    - ["cf1651mp003", "concurrent.futures.__dict__.__contains__", ["ThreadPoolExecutor"],   true]
    - ["cf1651mp004", "concurrent.futures.__dict__.__contains__", ["ProcessPoolExecutor"],  true]
    - ["cf1651mp005", "concurrent.futures.__dict__.__contains__", ["as_completed"],         true]
    - ["cf1651mp006", "concurrent.futures.__dict__.__contains__", ["wait"],                 true]
    - ["cf1651mp007", "concurrent.futures.__dict__.__contains__", ["FIRST_COMPLETED"],      true]
    - ["cf1651mp008", "concurrent.futures.__dict__.__contains__", ["FIRST_EXCEPTION"],      true]
    - ["cf1651mp009", "concurrent.futures.__dict__.__contains__", ["ALL_COMPLETED"],        true]
    - ["cf1651mp010", "concurrent.futures.__dict__.__contains__", ["CancelledError"],       true]
    - ["cf1651mp011", "concurrent.futures.__dict__.__contains__", ["InvalidStateError"],    true]
    - ["cf1651mp012", "concurrent.futures.__dict__.__contains__", ["BrokenExecutor"],       true]
    - ["cf1651mp013", "concurrent.futures.__dict__.__contains__", ["TimeoutError"],         true]
    - ["cf1651mp014", "concurrent.futures.__dict__.__contains__", ["__version__"],          false]
    - ["cf1651mp015", "concurrent.futures.__dict__.__contains__", ["__name__"],             true]
    - ["cf1651mp016", "concurrent.futures.__dict__.__contains__", ["__package__"],          true]
    - ["cf1651mp017", "concurrent.futures.__dict__.__contains__", ["__doc__"],              true]
    - ["cf1651mp018", "concurrent.futures.__dict__.__contains__", ["__all__"],              true]
    - ["cf1651mp019", "concurrent.futures.__dict__.__contains__", ["__spec__"],             true]
    - ["cf1651mp020", "concurrent.futures.__dict__.__contains__", ["__loader__"],           true]
    - ["cf1651mp021", "concurrent.futures.__dict__.__contains__", ["__path__"],             true]
    - ["cf1651mp022", "concurrent.futures.__dict__.__contains__", ["__file__"],             true]
    - ["cf1651mp023", "concurrent.futures.__dict__.__contains__", ["__builtins__"],         true]
    - ["cf1651mp024", "concurrent.futures.__dict__.__contains__", ["thread"],               false]
    - ["cf1651mp025", "concurrent.futures.__dict__.__contains__", ["process"],              false]
