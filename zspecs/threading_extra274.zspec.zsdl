spec: threading_extra274
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.current_thread() and threading.main_thread() both return the main thread when called from the main thread."
    - "main_thread().__class__.__name__ == '_MainThread'; current_thread().__class__.__name__ == '_MainThread' in main thread."
    - "threading.Lock().__class__.__name__ == 'lock' (lowercase); threading.RLock().__class__.__name__ == 'RLock'."
    - "threading.Event, Semaphore, Barrier, Thread, Timer are all Python classes; __module__ == 'threading'."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' (Timer subclasses Thread)."
    - "threading.Event.__bases__ == (<class 'object'>,); threading.Barrier.__bases__ == (<class 'object'>,)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading class identity — Event, Semaphore, Barrier, Thread, Timer
#
# All are Python classes defined in threading; __module__ == 'threading'.
# Timer subclasses Thread; Event and Barrier both have object as sole base.
# ---------------------------------------------------------------------------

table threading_extra274.class_identity:
  description: "threading.Event, Semaphore, Barrier, Thread, Timer class identity — __name__, __module__, __qualname__; Timer.__bases__[0].__name__=='Thread'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex274ci

  columns: [id, function, args, expected, description]
  rows:
    - [ev_name_eq,   Event.__name__.__eq__,            ["Event"],     true, "threading.Event.__name__ == 'Event'; verified with Python 3.14.3"]
    - [ev_mod_eq,    Event.__module__.__eq__,           ["threading"], true, "threading.Event.__module__ == 'threading'; verified with Python 3.14.3"]
    - [ev_qn_eq,     Event.__qualname__.__eq__,         ["Event"],     true, "threading.Event.__qualname__ == 'Event'; verified with Python 3.14.3"]
    - [se_name_eq,   Semaphore.__name__.__eq__,         ["Semaphore"], true, "threading.Semaphore.__name__ == 'Semaphore'; verified with Python 3.14.3"]
    - [se_mod_eq,    Semaphore.__module__.__eq__,       ["threading"], true, "threading.Semaphore.__module__ == 'threading'; verified with Python 3.14.3"]
    - [se_qn_eq,     Semaphore.__qualname__.__eq__,     ["Semaphore"], true, "threading.Semaphore.__qualname__ == 'Semaphore'; verified with Python 3.14.3"]
    - [ba_name_eq,   Barrier.__name__.__eq__,           ["Barrier"],   true, "threading.Barrier.__name__ == 'Barrier'; verified with Python 3.14.3"]
    - [ba_mod_eq,    Barrier.__module__.__eq__,         ["threading"], true, "threading.Barrier.__module__ == 'threading'; verified with Python 3.14.3"]
    - [ba_qn_eq,     Barrier.__qualname__.__eq__,       ["Barrier"],   true, "threading.Barrier.__qualname__ == 'Barrier'; verified with Python 3.14.3"]
    - [th_name_eq,   Thread.__name__.__eq__,            ["Thread"],    true, "threading.Thread.__name__ == 'Thread'; verified with Python 3.14.3"]
    - [th_mod_eq,    Thread.__module__.__eq__,          ["threading"], true, "threading.Thread.__module__ == 'threading'; verified with Python 3.14.3"]
    - [th_qn_eq,     Thread.__qualname__.__eq__,        ["Thread"],    true, "threading.Thread.__qualname__ == 'Thread'; verified with Python 3.14.3"]
    - [ti_name_eq,   Timer.__name__.__eq__,             ["Timer"],     true, "threading.Timer.__name__ == 'Timer'; verified with Python 3.14.3"]
    - [ti_mod_eq,    Timer.__module__.__eq__,           ["threading"], true, "threading.Timer.__module__ == 'threading'; verified with Python 3.14.3"]
    - [ti_base_eq,   Timer.__bases__.__getitem__,       [0],           "<class 'threading.Thread'>", "threading.Timer.__bases__[0] is threading.Thread — Timer subclasses Thread; verified with Python 3.14.3"]
    - [ti_base_name, Timer.__bases__.__getitem__(0).__name__.__eq__, ["Thread"], true, "threading.Timer.__bases__[0].__name__ == 'Thread'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# threading main/current thread — class names and identity
#
# In the main thread: current_thread() is main_thread() → True.
# Both have __class__.__name__ == '_MainThread'.
# threading.Lock().__class__.__name__ == 'lock' (lowercase, C-level type).
# threading.RLock().__class__.__name__ == 'RLock'.
# ---------------------------------------------------------------------------

table threading_extra274.thread_and_lock_identity:
  description: "threading.main_thread, current_thread class names; Lock/RLock instance class names; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex274tl

  columns: [id, function, args, expected, description]
  rows:
    - [mt_cls_eq,   main_thread().__class__.__name__.__eq__,    ["_MainThread"], true, "threading.main_thread().__class__.__name__ == '_MainThread'; verified with Python 3.14.3"]
    - [ct_cls_eq,   current_thread().__class__.__name__.__eq__, ["_MainThread"], true, "threading.current_thread().__class__.__name__ == '_MainThread' (in main thread); verified with Python 3.14.3"]
    - [lk_cls_eq,   Lock().__class__.__name__.__eq__,           ["lock"],        true, "threading.Lock().__class__.__name__ == 'lock' (lowercase — C-level lock type); verified with Python 3.14.3"]
    - [rl_cls_eq,   RLock().__class__.__name__.__eq__,          ["RLock"],       true, "threading.RLock().__class__.__name__ == 'RLock'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra274
# ---------------------------------------------------------------------------

invariant threading_extra274.main_thread_class_is_MainThread:
  description: "threading.main_thread().__class__.__name__ == '_MainThread' — the main thread is an instance of the private _MainThread class"
  category: identity
  kind: python_call_eq
  function: main_thread().__class__.__name__.__eq__
  args: ["_MainThread"]
  expected: true

invariant threading_extra274.current_thread_is_main_thread_in_main:
  description: "threading.current_thread() is threading.main_thread() when called from the main thread — they return the same object"
  category: behavior
  kind: python_call_eq
  function: current_thread().__eq__
  args: ["<threading.main_thread()>"]
  expected: true

invariant threading_extra274.lock_class_name_is_lowercase_lock:
  description: "threading.Lock().__class__.__name__ == 'lock' — the C-level lock type name is lowercase, distinguishing it from the factory function Lock"
  category: identity
  kind: python_call_eq
  function: Lock().__class__.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra274.event_module_is_threading:
  description: "threading.Event.__module__ == 'threading' — Event class is defined in the pure-Python threading module"
  category: identity
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra274.timer_base_is_thread:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer subclasses Thread, making it a specialized Thread that runs a function after a delay"
  category: identity
  kind: python_call_eq
  function: Timer.__bases__.__getitem__(0).__name__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra274.barrier_module_is_threading:
  description: "threading.Barrier.__module__ == 'threading' — Barrier class is defined in the pure-Python threading module"
  category: identity
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra274.semaphore_name_is_Semaphore:
  description: "threading.Semaphore.__name__ == 'Semaphore' — class name matches its export symbol"
  category: identity
  kind: python_call_eq
  function: Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra274.thread_qualname_is_Thread:
  description: "threading.Thread.__qualname__ == 'Thread' — module-level class has qualname equal to its simple name"
  category: identity
  kind: python_call_eq
  function: Thread.__qualname__.__eq__
  args: ["Thread"]
  expected: true
