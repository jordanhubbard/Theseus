spec: asyncio_extra227
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
  notes:
    - "asyncio.Queue.__name__.__lt__('Semaphore') == True — 'Queue' < 'Semaphore' alphabetically ('Q' < 'S'); verified with Python 3.14.3."
    - "asyncio.Semaphore.__name__.__gt__('Lock') == True — 'Semaphore' > 'Lock' alphabetically ('S' > 'L'); verified with Python 3.14.3."
    - "asyncio.Queue.__module__ == 'asyncio.queues' — Queue is defined in asyncio.queues submodule; startswith('asyncio') is True; verified with Python 3.14.3."
    - "asyncio.Lock.__module__ == 'asyncio.locks' — Lock is defined in asyncio.locks submodule; startswith('asyncio') is True; verified with Python 3.14.3."
    - "asyncio.Task.__module__ == '_asyncio' — Task is defined in the C accelerator module _asyncio; startswith('_asyncio') is True; verified with Python 3.14.3."
    - "asyncio.Future.__module__ == '_asyncio' — Future is defined in the C accelerator module _asyncio; startswith('_asyncio') is True; verified with Python 3.14.3."
    - "asyncio.LifoQueue.__name__ == 'LifoQueue' — startswith('Lifo') is True; verified with Python 3.14.3."
    - "asyncio.PriorityQueue.__name__ == 'PriorityQueue' — startswith('Priority') is True; verified with Python 3.14.3."
    - "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore' — startswith('Bounded') and endswith('Semaphore') both True; verified with Python 3.14.3."
    - "asyncio.CancelledError.__name__ == 'CancelledError' — endswith('Error') is True; verified with Python 3.14.3."
    - "asyncio.TimeoutError.__name__ == 'TimeoutError' — endswith('Error') is True; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio class name string comparison contracts — extra227 namespace
#
# Alphabetic ordering: Queue < Semaphore, Semaphore > Lock; verified Python 3.14.3.
# ---------------------------------------------------------------------------

table asyncio_extra227.name_comparisons:
  description: "asyncio class __name__ string comparison contracts in aio227nc namespace"
  kind: python_call_eq
  category: string_comparison
  id_prefix: aio227nc

  columns: [id, function, args, expected, description]
  rows:
    - [Queue_lt_Semaphore,      Queue.__name__.__lt__,       ["Semaphore"],  true, "asyncio.Queue.__name__.__lt__('Semaphore') == True — 'Queue' < 'Semaphore' alphabetically; verified with Python 3.14.3"]
    - [Semaphore_gt_Lock,       Semaphore.__name__.__gt__,   ["Lock"],       true, "asyncio.Semaphore.__name__.__gt__('Lock') == True — 'Semaphore' > 'Lock' alphabetically; verified with Python 3.14.3"]
    - [LifoQueue_sw_Lifo,       LifoQueue.__name__.__startswith__, ["Lifo"],      true, "asyncio.LifoQueue.__name__.__startswith__('Lifo') == True — verified with Python 3.14.3"]
    - [PriorityQueue_sw_Priority, PriorityQueue.__name__.__startswith__, ["Priority"], true, "asyncio.PriorityQueue.__name__.__startswith__('Priority') == True — verified with Python 3.14.3"]
    - [BoundedSemaphore_sw_Bounded, BoundedSemaphore.__name__.__startswith__, ["Bounded"],   true, "asyncio.BoundedSemaphore.__name__.__startswith__('Bounded') == True — verified with Python 3.14.3"]
    - [BoundedSemaphore_ew_Semaphore, BoundedSemaphore.__name__.__endswith__, ["Semaphore"], true, "asyncio.BoundedSemaphore.__name__.__endswith__('Semaphore') == True — verified with Python 3.14.3"]
    - [CancelledError_ew_Error,  CancelledError.__name__.__endswith__, ["Error"], true, "asyncio.CancelledError.__name__.__endswith__('Error') == True — verified with Python 3.14.3"]
    - [TimeoutError_ew_Error,    TimeoutError.__name__.__endswith__,   ["Error"], true, "asyncio.TimeoutError.__name__.__endswith__('Error') == True — verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio class __module__ startswith contracts — extra227 namespace
#
# Queue and Lock live in asyncio.* submodules; Task and Future are in _asyncio (C accelerator).
# ---------------------------------------------------------------------------

table asyncio_extra227.module_checks:
  description: "asyncio class __module__ startswith contracts in aio227mc namespace"
  kind: python_call_eq
  category: module_identity
  id_prefix: aio227mc

  columns: [id, function, args, expected, description]
  rows:
    - [Queue_module_sw_asyncio,   Queue.__module__.__startswith__,   ["asyncio"],  true, "asyncio.Queue.__module__.__startswith__('asyncio') == True — Queue.__module__ is 'asyncio.queues'; verified with Python 3.14.3"]
    - [Lock_module_sw_asyncio,    Lock.__module__.__startswith__,    ["asyncio"],  true, "asyncio.Lock.__module__.__startswith__('asyncio') == True — Lock.__module__ is 'asyncio.locks'; verified with Python 3.14.3"]
    - [Task_module_sw_asyncio,    Task.__module__.__startswith__,    ["_asyncio"], true, "asyncio.Task.__module__.__startswith__('_asyncio') == True — Task.__module__ is '_asyncio' (C accelerator); verified with Python 3.14.3"]
    - [Future_module_sw_asyncio,  Future.__module__.__startswith__,  ["_asyncio"], true, "asyncio.Future.__module__.__startswith__('_asyncio') == True — Future.__module__ is '_asyncio' (C accelerator); verified with Python 3.14.3"]
