spec: pathlib_extra263
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath component access, parent, parts, predicates, manipulation, joining, string representations"
    - "pathlib_extra.zspec.zsdl — covers Path/PurePosixPath class name/module, PurePosixPath component access variants, parent, truediv, parts, is_absolute"
  notes:
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath' and __module__ == 'pathlib'."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — immediate base class."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' and __module__ == 'pathlib'."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — same immediate base."
    - "Path.rename/replace/symlink_to/hardlink_to have __qualname__ 'Path.<method>' and __class__.__name__ 'function'."
    - "hardlink_to was added in Python 3.10; all verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePosixPath — class identity: name, module, base
# ---------------------------------------------------------------------------

invariant pathlib_extra263.PurePosixPath.class_name:
  description: "pathlib.PurePosixPath.__name__ == 'PurePosixPath'"
  category: identity
  kind: python_call_eq
  function: PurePosixPath.__name__.__eq__
  args: ["PurePosixPath"]
  expected: true

invariant pathlib_extra263.PurePosixPath.module:
  description: "pathlib.PurePosixPath.__module__ == 'pathlib'"
  category: identity
  kind: python_call_eq
  function: PurePosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra263.PurePosixPath.base_name:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath'"
  category: identity
  kind: python_call_eq
  function: PurePosixPath.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "PurePath"

# ---------------------------------------------------------------------------
# PureWindowsPath — class identity: name, module, base
# ---------------------------------------------------------------------------

invariant pathlib_extra263.PureWindowsPath.class_name:
  description: "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath'"
  category: identity
  kind: python_call_eq
  function: PureWindowsPath.__name__.__eq__
  args: ["PureWindowsPath"]
  expected: true

invariant pathlib_extra263.PureWindowsPath.module:
  description: "pathlib.PureWindowsPath.__module__ == 'pathlib'"
  category: identity
  kind: python_call_eq
  function: PureWindowsPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra263.PureWindowsPath.base_name:
  description: "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath'"
  category: identity
  kind: python_call_eq
  function: PureWindowsPath.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "PurePath"

# ---------------------------------------------------------------------------
# Path — method qualnames: rename, replace, symlink_to, hardlink_to
# ---------------------------------------------------------------------------

table pathlib_extra263.Path.method_qualnames:
  description: "rename/replace/symlink_to/hardlink_to qualnames are 'Path.<method>'"
  kind: python_call_eq
  category: identity
  id_prefix: method_qualname

  columns: [id, function, args, expected, description]
  rows:
    - [rename_qualname,      Path.rename.__qualname__.__eq__,      ["Path.rename"],      true, "rename qualname"]
    - [replace_qualname,     Path.replace.__qualname__.__eq__,     ["Path.replace"],     true, "replace qualname"]
    - [symlink_to_qualname,  Path.symlink_to.__qualname__.__eq__,  ["Path.symlink_to"],  true, "symlink_to qualname"]
    - [hardlink_to_qualname, Path.hardlink_to.__qualname__.__eq__, ["Path.hardlink_to"], true, "hardlink_to qualname"]

# ---------------------------------------------------------------------------
# Path — method class names: rename, replace, symlink_to, hardlink_to
# These are plain Python functions (defined in Lib/pathlib/_local.py)
# ---------------------------------------------------------------------------

table pathlib_extra263.Path.method_class_names:
  description: "rename/replace/symlink_to/hardlink_to are 'function' objects"
  kind: python_call_eq
  category: identity
  id_prefix: method_class

  columns: [id, function, args, expected, description]
  rows:
    - [rename_class,      Path.rename.__class__.__name__.__eq__,      ["function"], true, "rename is function"]
    - [replace_class,     Path.replace.__class__.__name__.__eq__,     ["function"], true, "replace is function"]
    - [symlink_to_class,  Path.symlink_to.__class__.__name__.__eq__,  ["function"], true, "symlink_to is function"]
    - [hardlink_to_class, Path.hardlink_to.__class__.__name__.__eq__, ["function"], true, "hardlink_to is function"]
