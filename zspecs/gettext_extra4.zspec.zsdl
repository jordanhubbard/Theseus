spec: gettext_extra4
version: ">=3.9"
backend: python_module(gettext)

docs: https://docs.python.org/3/library/gettext.html

provenance:
  derived_from:
    - "Python gettext documentation — https://docs.python.org/3/library/gettext.html"
    - "GNU gettext manual — https://www.gnu.org/software/gettext/manual/gettext.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gettext.py"
  notes:
    - "This spec extends gettext.zspec.zsdl, gettext_extra.zspec.zsdl, gettext_extra2.zspec.zsdl, and gettext_extra3.zspec.zsdl."
    - "gettext.zspec.zsdl covers: func_names table (gettext/ngettext/dgettext/dngettext/bindtextdomain/textdomain/find/translation/install __name__); NullTranslations/__name__; GNUTranslations/__name__/__bases__; Catalog/__name__; gettext/ngettext passthrough (args: 'apple'/'apples')."
    - "gettext_extra.zspec.zsdl covers: NullTranslations/__name__/__module__; GNUTranslations/__name__/__bases__; pgettext/npgettext names."
    - "gettext_extra2.zspec.zsdl covers: NullTranslations base is object; GNUTranslations single_base len; dgettext/dngettext/pgettext/npgettext passthroughs."
    - "gettext_extra3.zspec.zsdl covers: GNUTranslations/__module__; Catalog/__module__; dpgettext __name__/__module__; func_modules table (gettext/ngettext/dgettext/dngettext __module__); pgettext/__module__; GNUTranslations/NullTranslations __mro__ len; dpgettext passthrough."
    - "This spec adds: __qualname__ checks for gettext/ngettext/bindtextdomain/textdomain/dgettext module-level functions; __qualname__ for GNUTranslations/NullTranslations/Catalog classes; ngettext behavioral test with 'item'/'items' args (distinct from 'apple'/'apples' in gettext.zspec)."
    - "Module-level functions have __qualname__ equal to their simple name (no dot in qualname)."
    - "Classes defined at module level have __qualname__ equal to their class name."
    - "gettext.Catalog.__qualname__ == 'GNUTranslations' because Catalog is an alias bound to GNUTranslations."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for module-level functions
# Not covered in any prior gettext spec.
# ---------------------------------------------------------------------------

table gettext_extra4.func_qualnames:
  kind: python_call_eq
  category: functions
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [gettext,        "gettext.__qualname__.__eq__",        ["gettext"],        true]
    - [ngettext,       "ngettext.__qualname__.__eq__",       ["ngettext"],       true]
    - [bindtextdomain, "bindtextdomain.__qualname__.__eq__", ["bindtextdomain"], true]
    - [textdomain,     "textdomain.__qualname__.__eq__",     ["textdomain"],     true]
    - [dgettext,       "dgettext.__qualname__.__eq__",       ["dgettext"],       true]

# ---------------------------------------------------------------------------
# __qualname__ checks for classes
# GNUTranslations and NullTranslations are defined at module level — their
# __qualname__ equals their simple class name.
# Catalog is an alias; its __qualname__ == 'GNUTranslations'.
# Not covered in any prior gettext spec.
# ---------------------------------------------------------------------------

invariant gettext_extra4.GNUTranslations.qualname:
  description: "gettext.GNUTranslations.__qualname__ == 'GNUTranslations' — class defined at module level"
  category: classnames
  kind: python_call_eq
  function: GNUTranslations.__qualname__.__eq__
  args: ["GNUTranslations"]
  expected: true

invariant gettext_extra4.NullTranslations.qualname:
  description: "gettext.NullTranslations.__qualname__ == 'NullTranslations' — class defined at module level"
  category: classnames
  kind: python_call_eq
  function: NullTranslations.__qualname__.__eq__
  args: ["NullTranslations"]
  expected: true

invariant gettext_extra4.Catalog.qualname:
  description: "gettext.Catalog.__qualname__ == 'GNUTranslations' — Catalog alias carries GNUTranslations qualname"
  category: classnames
  kind: python_call_eq
  function: Catalog.__qualname__.__eq__
  args: ["GNUTranslations"]
  expected: true

# ---------------------------------------------------------------------------
# ngettext behavioral test — 'item'/'items' args
# gettext.zspec.zsdl covers ngettext('apple', 'apples', 1) and ('apple', 'apples', 2).
# New distinct args: 'item'/'items' (not previously used in any spec).
# ---------------------------------------------------------------------------

invariant gettext_extra4.ngettext.item_singular:
  description: "gettext.ngettext('item', 'items', 1) == 'item' — singular form when n == 1"
  category: behavior
  kind: python_call_eq
  function: ngettext
  args: ["item", "items", 1]
  expected: "item"

invariant gettext_extra4.ngettext.item_plural:
  description: "gettext.ngettext('item', 'items', 2) == 'items' — plural form when n != 1"
  category: behavior
  kind: python_call_eq
  function: ngettext
  args: ["item", "items", 2]
  expected: "items"
