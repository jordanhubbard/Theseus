spec: linecache_extra2
version: ">=3.2"
backend: python_module(linecache)

docs: https://docs.python.org/3/library/linecache.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/linecache.html — Python linecache module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/linecache.py (internal implementation)"
  notes:
    - "This spec covers invariants not in linecache.zspec.zsdl or linecache_extra.zspec.zsdl."
    - "All public functions are verified by __name__ and __module__ attributes."
    - "getline.__module__ == 'linecache' — function is defined in this module."
    - "clearcache.__name__ == 'clearcache' — re-verified as extra2 dimension alongside __module__."
    - "checkcache.__name__ == 'checkcache' and getlines.__name__ == 'getlines'."
    - "lazycache.__name__ == 'lazycache' — function added in Python 3.5 for PEP 451 loaders."
    - "updatecache.__name__ == 'updatecache' — internal helper exposed as public API."
    - "cache.__class__.__name__ == 'dict' — the module-level cache is a plain dict."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# getline — __name__ and __module__ affiliation
# ---------------------------------------------------------------------------

invariant linecache_extra2.getline.name:
  description: "getline.__name__ == 'getline'"
  category: functions
  kind: python_call_eq
  function: getline.__name__.__eq__
  args: ["getline"]
  expected: true

invariant linecache_extra2.getline.module:
  description: "getline.__module__ == 'linecache'"
  category: functions
  kind: python_call_eq
  function: getline.__module__.__eq__
  args: ["linecache"]
  expected: true

