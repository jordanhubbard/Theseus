# ---------------------------------------------------------------------------
# cache — module-level dict affiliation
# ---------------------------------------------------------------------------

invariant linecache_extra2.cache.is_dict:
  description: "cache.__class__.__name__ == 'dict' — linecache.cache is a plain dict"
  category: cache
  kind: python_call_eq
  function: cache.__class__.__name__.__eq__
  args: ["dict"]
  expected: true
