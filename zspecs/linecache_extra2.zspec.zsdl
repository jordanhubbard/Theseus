  function: clearcache.__name__.__eq__
  args: ["clearcache"]
  expected: true

invariant linecache_extra2.clearcache.module:
  description: "clearcache.__module__ == 'linecache'"
  category: functions
  kind: python_call_eq
  function: clearcache.__module__.__eq__
  args: ["linecache"]
  expected: true

