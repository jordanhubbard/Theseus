spec: decimal_extra262
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "decimal.Context.__name__ == 'Context', __module__ == 'decimal', __qualname__ == 'Context'."
    - "decimal.Context.__bases__[0].__name__ == 'object' — Context inherits directly from object."
    - "decimal.getcontext, decimal.setcontext, decimal.localcontext are C-extension builtin functions."
    - "All three context functions have __module__ == '_decimal' (C extension) and __class__.__name__ == 'builtin_function_or_method'."
    - "decimal.getcontext().__qualname__ values: getcontext.__qualname__ == 'getcontext', etc."
    - "decimal.getcontext().prec == 28 — default precision is 28 significant digits."
    - "decimal.getcontext().rounding == 'ROUND_HALF_EVEN' — default rounding mode."
    - "type(decimal.getcontext().prec).__name__ == 'int' — prec is a plain Python int."
    - "type(decimal.getcontext().rounding).__name__ == 'str' — rounding is a plain Python str."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: Context class identity — name, module, qualname, base
# ---------------------------------------------------------------------------

table decimal_extra262.context_class_identity:
  description: "decimal.Context __name__, __module__, __qualname__, and __bases__[0].__name__"
  kind: python_call_eq
  category: identity
  id_prefix: ctx

  columns: [id, function, args, expected, description]
  rows:
    - [name,      Context.__name__.__eq__,     ["Context"],  true, "decimal.Context.__name__ == 'Context'"]
    - [module,    Context.__module__.__eq__,   ["decimal"],  true, "decimal.Context.__module__ == 'decimal'"]
    - [qualname,  Context.__qualname__.__eq__, ["Context"],  true, "decimal.Context.__qualname__ == 'Context'"]
    - [is_type,   Context.__class__.__name__.__eq__, ["type"], true, "decimal.Context.__class__.__name__ == 'type' — Context is a class"]

# ---------------------------------------------------------------------------
# Table: context function identity — name, module, class
# ---------------------------------------------------------------------------

table decimal_extra262.function_identity:
  description: "decimal.getcontext, setcontext, localcontext __name__, __module__, __class__.__name__"
  kind: python_call_eq
  category: identity
  id_prefix: fn

  columns: [id, function, args, expected, description]
  rows:
    - [getcontext_name,    getcontext.__name__.__eq__,            ["getcontext"],                  true, "decimal.getcontext.__name__ == 'getcontext'"]
    - [getcontext_module,  getcontext.__module__.__eq__,          ["_decimal"],                    true, "decimal.getcontext.__module__ == '_decimal' (C extension)"]
    - [getcontext_class,   getcontext.__class__.__name__.__eq__,  ["builtin_function_or_method"],  true, "decimal.getcontext is a C builtin function"]
    - [setcontext_name,    setcontext.__name__.__eq__,            ["setcontext"],                  true, "decimal.setcontext.__name__ == 'setcontext'"]
    - [setcontext_module,  setcontext.__module__.__eq__,          ["_decimal"],                    true, "decimal.setcontext.__module__ == '_decimal' (C extension)"]
    - [setcontext_class,   setcontext.__class__.__name__.__eq__,  ["builtin_function_or_method"],  true, "decimal.setcontext is a C builtin function"]
    - [localcontext_name,  localcontext.__name__.__eq__,          ["localcontext"],                true, "decimal.localcontext.__name__ == 'localcontext'"]
    - [localcontext_mod,   localcontext.__module__.__eq__,        ["_decimal"],                    true, "decimal.localcontext.__module__ == '_decimal' (C extension)"]
    - [localcontext_class, localcontext.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "decimal.localcontext is a C builtin function"]

# ---------------------------------------------------------------------------
# Standalone invariants: Context base class and context defaults
# ---------------------------------------------------------------------------

invariant decimal_extra262.Context.base_name:
  description: "decimal.Context.__bases__[0].__name__ == 'object' — Context inherits directly from object"
  category: identity
  kind: python_call_eq
  function: "Context.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant decimal_extra262.getcontext.qualname:
  description: "decimal.getcontext.__qualname__ == 'getcontext' — top-level C builtin function"
  category: identity
  kind: python_call_eq
  function: getcontext.__qualname__.__eq__
  args: ["getcontext"]
  expected: true

invariant decimal_extra262.setcontext.qualname:
  description: "decimal.setcontext.__qualname__ == 'setcontext' — top-level C builtin function"
  category: identity
  kind: python_call_eq
  function: setcontext.__qualname__.__eq__
  args: ["setcontext"]
  expected: true

invariant decimal_extra262.localcontext.qualname:
  description: "decimal.localcontext.__qualname__ == 'localcontext' — top-level C builtin function"
  category: identity
  kind: python_call_eq
  function: localcontext.__qualname__.__eq__
  args: ["localcontext"]
  expected: true

invariant decimal_extra262.getcontext.prec_default:
  description: "decimal.getcontext().prec == 28 — default context precision is 28 significant digits"
  category: context_defaults
  kind: python_call_eq
  function: getcontext
  args: []
  method: prec
  method_chain: __eq__
  method_chain_args: [28]
  expected: true

invariant decimal_extra262.getcontext.rounding_default:
  description: "decimal.getcontext().rounding == 'ROUND_HALF_EVEN' — default rounding mode"
  category: context_defaults
  kind: python_call_eq
  function: getcontext
  args: []
  method: rounding
  method_chain: __eq__
  method_chain_args: ["ROUND_HALF_EVEN"]
  expected: true

invariant decimal_extra262.getcontext.prec_is_int:
  description: "type(decimal.getcontext().prec).__name__ == 'int' — prec is a plain Python int"
  category: context_defaults
  kind: python_call_eq
  function: getcontext
  args: []
  method: prec
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["int"]
  expected: true

invariant decimal_extra262.getcontext.rounding_is_str:
  description: "type(decimal.getcontext().rounding).__name__ == 'str' — rounding is a plain Python str"
  category: context_defaults
  kind: python_call_eq
  function: getcontext
  args: []
  method: rounding
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["str"]
  expected: true
