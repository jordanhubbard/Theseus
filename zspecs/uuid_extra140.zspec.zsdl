spec: uuid_extra140
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra139.zspec.zsdl — covers uuid.UUID.__dict__.__contains__('urn'/'bytes_le'/'node'/'fields'/'__str__'/'__repr__'/'__hash__'/'variant') / UUID.__dict__.__len__()==37 / UUID.__doc__.__len__()==2787 / SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy') / uuid.__package__.__eq__('') (table + invariants)."
    - "uuid_extra138.zspec.zsdl — covers uuid.NAMESPACE_DNS/__class__.__name__.__eq__('UUID') (all four namespace constants) / NAMESPACE_DNS.version==1 / NAMESPACE_DNS.hex.__len__()==32 / uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') / uuid.UUID.__name__.__eq__('UUID') (table + invariants)."
    - "uuid_extra137.zspec.zsdl — covers uuid.UUID.__dict__.__contains__('hex'/'int'/'bytes'/'version'/__slots__/__init__) / UUID.__dict__.__class__.__name__.__eq__('mappingproxy') / uuid.__spec__.name.__eq__('uuid') / uuid.__doc__.__len__()==1948 (table + invariants)."
    - "uuid_extra136.zspec.zsdl — covers uuid.UUID.__lt__/__gt__/__le__/__ge__ comparison operator __qualname__ string equality (all 'UUID.<method>', len 11) / UUID.__int__ __qualname__.__eq__('UUID.__int__') and __len__()==12 / UUID dunder __class__.__name__ values (table + invariants)."
    - "uuid_extra135.zspec.zsdl — covers uuid.UUID property descriptor __class__.__name__ == 'property' for hex/urn/variant/version/bytes/fields / UUID.int/__class__.__name__ == 'member_descriptor' (table + invariants)."
    - "uuid_extra134.zspec.zsdl — covers uuid.UUID.__init__/__str__/__repr__/__hash__/__eq__/__lt__ __qualname__ lengths and equality strings / UUID.__bases__[0].__name__=='object' (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/qualname / UUID method qualname equality and length."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants __class__.__name__, hex values, str() values, version attributes."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality / UUID.__module__.__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__.__eq__ / SafeUUID.__bases__[0].__name__=='Enum'."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra139."
    - "Wave 321 theme: uuid.UUID dunder method __qualname__ equality strings NOT previously covered — UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__') (len 16) / UUID.__getstate__.__qualname__.__eq__('UUID.__getstate__') (len 17) / UUID.__setstate__.__qualname__.__eq__('UUID.__setstate__') (len 17) / UUID.__setattr__/__class__.__name__.__eq__('function') / UUID.__getstate__/__class__.__name__.__eq__('function') / UUID.__setstate__/__class__.__name__.__eq__('function')."
    - "uuid.UUID.__setattr__.__qualname__ == 'UUID.__setattr__' (len 16). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__getstate__.__qualname__ == 'UUID.__getstate__' (len 17). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setstate__.__qualname__ == 'UUID.__setstate__' (len 17). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__class__.__name__ == 'function' (Python-level). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__getstate__.__class__.__name__ == 'function' (Python-level). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setstate__.__class__.__name__ == 'function' (Python-level). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.__setattr__ has qualname 'UUID.__setattr__' (16 chars = 5-char 'UUID.' + 11-char '__setattr__'). UUID defines its own __setattr__ to make UUID objects immutable (raising TypeError on any attribute assignment after initialization). This is a Python-level function ('function' class) rather than a C-level wrapper_descriptor. Prior covered qualname lengths: __lt__/__gt__/__le__/__ge__/__eq__ (11), __int__/__str__ (12), __repr__/__hash__ (13). __setattr__ (16) is longer than all these."
    - "Note: uuid.UUID.__getstate__ and uuid.UUID.__setstate__ have qualnames 'UUID.__getstate__' and 'UUID.__setstate__' (both 17 chars = 5-char 'UUID.' + 12-char method name). These are Python-level functions supporting Python object pickling/copying. __getstate__ returns a dict of the UUID's state; __setstate__ restores it. At 17 chars these are the longest UUID method qualnames examined in the spec series."
    - "Note: Length ordering across UUID method qualnames: __eq__/__lt__/__gt__/__le__/__ge__ (11) < __int__/__str__ (12) < __repr__/__hash__ (13) < __setattr__ (16) < __getstate__/__setstate__ (17). The progression from comparison operators (11) through output methods (12-13) to attribute control (16) and pickling (17) reflects increasing method name length."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__')
# uuid.UUID.__setattr__.__qualname__.__len__()==16
# uuid.UUID.__setattr__.__class__.__name__.__eq__('function')
#
# Wave 321 theme: UUID.__setattr__ qualname and class.
#
# UUID.__setattr__ is a Python-level function that raises TypeError on any attribute
# assignment, enforcing UUID immutability. Its qualname is 'UUID.__setattr__' (16 chars).
# extra134 covers __init__/__str__/__repr__/__hash__/__eq__/__lt__ qualname equality
# strings; extra136 covers __lt__/__gt__/__le__/__ge__/__int__ qualname equality strings;
# no prior uuid spec anchors UUID.__setattr__ qualname equality string or class name
# as a table under uuidmeth140. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra140.UUID_setattr_qualname_and_class:
  description: "uuid.UUID.__setattr__/__qualname__.__eq__('UUID.__setattr__')==True / __qualname__.__len__()==16 / __setattr__/__class__.__name__.__eq__('function')==True — 'UUID.__setattr__' (16 chars = 5-char 'UUID.' + 11-char '__setattr__'); UUID defines __setattr__ to enforce immutability (raises TypeError on assignment); Python-level function; longer than __repr__/__hash__ (13) and shorter than __getstate__/__setstate__ (17); extra134/extra136 cover earlier dunders; first uuidmeth140 anchor for __setattr__ qualname and class"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: uuidmeth140

  columns: [id, function, args, expected, description]
  rows:
    - [setattr_qualname_eq,   UUID.__setattr__.__qualname__.__eq__,        ["UUID.__setattr__"], true, "uuid.UUID.__setattr__.__qualname__ == 'UUID.__setattr__' (16 chars = 5 + 11; enforces UUID immutability)"]
    - [setattr_qualname_len,  UUID.__setattr__.__qualname__.__len__,        [],                  16,   "uuid.UUID.__setattr__.__qualname__.__len__() is 16 (longer than __repr__/__hash__ at 13; shorter than __getstate__ at 17)"]
    - [setattr_class_function, UUID.__setattr__.__class__.__name__.__eq__, ["function"],         true, "uuid.UUID.__setattr__.__class__.__name__ == 'function' (Python-level, not a C-level wrapper_descriptor)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__getstate__.__qualname__.__eq__('UUID.__getstate__')
# uuid.UUID.__getstate__.__qualname__.__len__()==17
# uuid.UUID.__getstate__.__class__.__name__.__eq__('function')
# uuid.UUID.__setstate__.__qualname__.__eq__('UUID.__setstate__')
#
# Wave 321 theme: UUID.__getstate__ and __setstate__ qualnames.
#
# __getstate__ and __setstate__ are Python-level functions supporting pickling and
# copying. Both have 17-char qualnames ('UUID.' + 12-char method name). At 17 chars
# these are the longest UUID method qualnames in the spec series. No prior uuid spec
# anchors UUID.__getstate__ or UUID.__setstate__ qualname equality strings or class
# names as a table under uuidmeth140. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra140.UUID_getstate_setstate_qualnames:
  description: "uuid.UUID.__getstate__/__qualname__.__eq__('UUID.__getstate__')==True / __qualname__.__len__()==17 / __getstate__/__class__.__name__.__eq__('function')==True / UUID.__setstate__/__qualname__.__eq__('UUID.__setstate__')==True — both 'UUID.'+12-char name = 17 chars; __getstate__ returns dict for pickling; __setstate__ restores UUID from dict; both Python-level functions; longest UUID method qualnames in the series (17 > __setattr__=16 > __repr__/__hash__=13); first uuidmeth140 anchor for getstate/setstate qualname equality strings"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: uuidmeth140

  columns: [id, function, args, expected, description]
  rows:
    - [getstate_qualname_eq,    UUID.__getstate__.__qualname__.__eq__,        ["UUID.__getstate__"], true, "uuid.UUID.__getstate__.__qualname__ == 'UUID.__getstate__' (17 chars = 5-char 'UUID.' + 12-char '__getstate__')"]
    - [getstate_qualname_len,   UUID.__getstate__.__qualname__.__len__,        [],                   17,   "uuid.UUID.__getstate__.__qualname__.__len__() is 17 (longest UUID method qualname in the series)"]
    - [getstate_class_function, UUID.__getstate__.__class__.__name__.__eq__,  ["function"],          true, "uuid.UUID.__getstate__.__class__.__name__ == 'function' (Python-level; used for pickling/copying)"]
    - [setstate_qualname_eq,    UUID.__setstate__.__qualname__.__eq__,        ["UUID.__setstate__"], true, "uuid.UUID.__setstate__.__qualname__ == 'UUID.__setstate__' (17 chars = 5-char 'UUID.' + 12-char '__setstate__')"]

# ---------------------------------------------------------------------------
# uuid.UUID.__setstate__.__qualname__.__len__()==17
# uuid.UUID.__setstate__.__class__.__name__.__eq__('function')
# uuid.UUID.__getstate__.__qualname__.__len__()==17 (complement standalone)
#
# Wave 321 theme: setstate qualname length and class, and length ordering summary.
#
# __setstate__ length is 17 (same as __getstate__). Both are 'function' class.
# The full length ordering for UUID method qualnames is:
# __eq__/comparison (11) < __int__/__str__ (12) < __repr__/__hash__ (13) <
# __setattr__ (16) < __getstate__/__setstate__ (17).
# No prior uuid spec anchors these lengths or the comparison as a table under uuidmeth140.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra140.UUID_setstate_qualname_len_and_ordering:
  description: "uuid.UUID.__setstate__/__qualname__.__len__()==17 / __setstate__/__class__.__name__.__eq__('function')==True / __setattr__.__qualname__.__len__()==16 / __repr__.__qualname__.__len__()==13 — full ordering: eq/comparison(11) < int/str(12) < repr/hash(13) < setattr(16) < getstate/setstate(17); __setstate__ is 'function' (Python-level); no prior uuid spec anchors __setstate__ length or the ordering as a table under uuidmeth140"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: uuidmeth140

  columns: [id, function, args, expected, description]
  rows:
    - [setstate_qualname_len,    UUID.__setstate__.__qualname__.__len__,        [],          17,   "uuid.UUID.__setstate__.__qualname__.__len__() is 17 (ties with __getstate__; longest UUID method qualname)"]
    - [setstate_class_function,  UUID.__setstate__.__class__.__name__.__eq__,   ["function"], true, "uuid.UUID.__setstate__.__class__.__name__ == 'function' (Python-level; restores UUID state from pickle dict)"]
    - [setattr_qualname_len_16,  UUID.__setattr__.__qualname__.__len__,         [],          16,   "uuid.UUID.__setattr__.__qualname__.__len__() is 16 (between __repr__/__hash__ at 13 and getstate/setstate at 17)"]
    - [repr_qualname_len_13,     UUID.__repr__.__qualname__.__len__,            [],          13,   "uuid.UUID.__repr__.__qualname__.__len__() is 13 ('UUID.__repr__'; covered by extra134 for equality string)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__') — standalone
#
# uuid.UUID.__setattr__.__qualname__ is 'UUID.__setattr__' (16 chars). UUID defines
# its own __setattr__ as a Python function to raise TypeError on any attempt to set
# an attribute after construction. This makes UUID instances effectively immutable.
# The __setattr__ override is part of UUID's design (along with __slots__) to prevent
# accidental modification. The 16-char qualname places __setattr__ between __repr__/
# __hash__ (13 chars, covered by extra134) and __getstate__/__setstate__ (17 chars).
# No prior uuid spec anchors UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__')
# as a standalone under uuidmeth140. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra140.UUID_setattr_qualname_eq:
  description: "uuid.UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__') == True — 'UUID.__setattr__' (16 chars = 5-char 'UUID.' + 11-char '__setattr__'); raises TypeError on attribute assignment (UUID immutability enforcement); between __repr__/__hash__ (13) and __getstate__/__setstate__ (17) in length; no prior uuid spec anchors this as a standalone; first standalone under uuidmeth140"
  category: qualname_identity
  kind: python_call_eq
  function: UUID.__setattr__.__qualname__.__eq__
  args: ["UUID.__setattr__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__getstate__.__qualname__.__eq__('UUID.__getstate__') — standalone
#
# uuid.UUID.__getstate__.__qualname__ is 'UUID.__getstate__' (17 chars). The __getstate__
# method supports Python's pickle/copy protocol by returning a dict {'int': self.int,
# 'is_safe': self.is_safe} that captures the UUID's complete state. Together with
# __setstate__, this allows UUID objects to be pickled and unpickled correctly,
# preserving both the integer value and the is_safe attribute. At 17 chars,
# 'UUID.__getstate__' is the longest UUID method qualname examined in the spec series.
# No prior uuid spec anchors UUID.__getstate__.__qualname__.__eq__('UUID.__getstate__')
# as a standalone under uuidmeth140. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra140.UUID_getstate_qualname_eq:
  description: "uuid.UUID.__getstate__.__qualname__.__eq__('UUID.__getstate__') == True — 'UUID.__getstate__' (17 chars = 5-char 'UUID.' + 12-char '__getstate__'); returns {'int': self.int, 'is_safe': self.is_safe} for pickling; longest UUID method qualname in the series (17); no prior uuid spec anchors this as a standalone; first standalone under uuidmeth140"
  category: qualname_identity
  kind: python_call_eq
  function: UUID.__getstate__.__qualname__.__eq__
  args: ["UUID.__getstate__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__setstate__.__qualname__.__eq__('UUID.__setstate__') — standalone
#
# uuid.UUID.__setstate__.__qualname__ is 'UUID.__setstate__' (17 chars). The __setstate__
# method restores a UUID from a pickled state dict, setting self.int and self.is_safe
# from the dict produced by __getstate__. Together with __getstate__, this implements
# the pickle protocol for UUID objects. Both __getstate__ and __setstate__ have 17-char
# qualnames because both have 12-char method names ('__getstate__' and '__setstate__'),
# tied with each other and both longer than any other UUID method qualname.
# No prior uuid spec anchors UUID.__setstate__.__qualname__.__eq__('UUID.__setstate__')
# as a standalone under uuidmeth140. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra140.UUID_setstate_qualname_eq:
  description: "uuid.UUID.__setstate__.__qualname__.__eq__('UUID.__setstate__') == True — 'UUID.__setstate__' (17 chars = 5-char 'UUID.' + 12-char '__setstate__'); restores UUID from pickle state dict (int + is_safe); ties with __getstate__ at 17 chars (both longest UUID method qualnames); no prior uuid spec anchors this as a standalone; first standalone under uuidmeth140"
  category: qualname_identity
  kind: python_call_eq
  function: UUID.__setstate__.__qualname__.__eq__
  args: ["UUID.__setstate__"]
  expected: true
