spec: linecache_extra8
version: ">=3.9"
backend: python_module(linecache)

docs: https://docs.python.org/3/library/linecache.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/linecache.html — Python linecache module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/linecache.py"
  notes:
    - "This spec extends linecache.zspec.zsdl and all prior linecache_extra specs."
    - "linecache.zspec.zsdl covers: function_names table; getline_module; getline for /nonexistent_path_xyz/file.py lineno 0/1/2/-1; getlines nonexistent; clearcache/checkcache return None."
    - "linecache_extra through linecache_extra7 cover: __name__/__module__/__qualname__/__class__.__name__ for all six public functions; cache dict; getline/getlines return values for /dev/null, '', and nonexistent filenames; checkcache(None); getline/getlines return types."
    - "This spec adds genuinely new axes: __name__ length checks for the six public linecache functions; __name__ is-str checks; first-character checks for selected function names."
    - "linecache.getline.__name__ has length 7 ('getline')."
    - "linecache.getlines.__name__ has length 8 ('getlines')."
    - "linecache.clearcache.__name__ has length 10 ('clearcache')."
    - "linecache.checkcache.__name__ has length 10 ('checkcache')."
    - "linecache.updatecache.__name__ has length 11 ('updatecache')."
    - "linecache.lazycache.__name__ has length 9 ('lazycache')."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ length checks — all six public linecache functions
# All prior specs verify __name__ via equality (__name__.__eq__(str) == True).
# This spec adds the length of each __name__ string — a new uncovered axis.
# ---------------------------------------------------------------------------

table linecache_extra8.name_lengths:
  description: "__name__ attribute lengths for all six public linecache functions"
  kind: python_call_eq
  category: name_lengths
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [getline,    getline.__name__.__len__,    [], 7]
    - [getlines,   getlines.__name__.__len__,   [], 8]
    - [clearcache, clearcache.__name__.__len__, [], 10]
    - [checkcache, checkcache.__name__.__len__, [], 10]
    - [updatecache, updatecache.__name__.__len__, [], 11]
    - [lazycache,  lazycache.__name__.__len__,  [], 9]

# ---------------------------------------------------------------------------
# __name__ is-str checks — all six public linecache functions
# No prior linecache spec verifies that __name__ is itself a str object.
# ---------------------------------------------------------------------------

table linecache_extra8.name_is_str:
  description: "__name__ attributes are str objects for all six public linecache functions"
  kind: python_call_eq
  category: name_types
  id_prefix: namestr

  columns: [id, function, args, expected]
  rows:
    - [getline,    getline.__name__.__class__.__name__.__eq__,    ["str"], true]
    - [getlines,   getlines.__name__.__class__.__name__.__eq__,   ["str"], true]
    - [clearcache, clearcache.__name__.__class__.__name__.__eq__, ["str"], true]
    - [checkcache, checkcache.__name__.__class__.__name__.__eq__, ["str"], true]
    - [updatecache, updatecache.__name__.__class__.__name__.__eq__, ["str"], true]
    - [lazycache,  lazycache.__name__.__class__.__name__.__eq__,  ["str"], true]

# ---------------------------------------------------------------------------
# __name__ first-character checks — 'g', 'c', 'u', 'l' prefixes
# getline/getlines -> 'g'; clearcache/checkcache -> 'c'; updatecache -> 'u';
# lazycache -> 'l'. Not covered in any prior linecache spec.
# ---------------------------------------------------------------------------

invariant linecache_extra8.getline.name_starts_g:
  description: "linecache.getline.__name__[0] == 'g' — 'getline' begins with 'g'"
  category: name_prefix
  kind: python_call_eq
  function: getline.__name__.__getitem__
  args: [0]
  expected: "g"

invariant linecache_extra8.getlines.name_starts_g:
  description: "linecache.getlines.__name__[0] == 'g' — 'getlines' begins with 'g'"
  category: name_prefix
  kind: python_call_eq
  function: getlines.__name__.__getitem__
  args: [0]
  expected: "g"

invariant linecache_extra8.clearcache.name_starts_c:
  description: "linecache.clearcache.__name__[0] == 'c' — 'clearcache' begins with 'c'"
  category: name_prefix
  kind: python_call_eq
  function: clearcache.__name__.__getitem__
  args: [0]
  expected: "c"

invariant linecache_extra8.updatecache.name_starts_u:
  description: "linecache.updatecache.__name__[0] == 'u' — 'updatecache' begins with 'u'"
  category: name_prefix
  kind: python_call_eq
  function: updatecache.__name__.__getitem__
  args: [0]
  expected: "u"

invariant linecache_extra8.lazycache.name_starts_l:
  description: "linecache.lazycache.__name__[0] == 'l' — 'lazycache' begins with 'l'"
  category: name_prefix
  kind: python_call_eq
  function: lazycache.__name__.__getitem__
  args: [0]
  expected: "l"
