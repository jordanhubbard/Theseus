spec: re_extra57
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra56.zspec.zsdl — covers Pattern/Match/error/RegexFlag __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy'); re module __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy'); search/compile/sub/findall __qualname__.__eq__()."
    - "re_extra55.zspec.zsdl — covers subn __module__.__len__()==2; Pattern/Match/RegexFlag __module__ equality/length namespace anchors."
    - "re_extra54.zspec.zsdl — covers re function __module__.__eq__('re') for all 9 functions + error."
    - "re_extra51.zspec.zsdl — covers RegexFlag member __class__.__module__.__eq__('re') for MULTILINE/DOTALL/VERBOSE/ASCII/UNICODE."
    - "re_extra43.zspec.zsdl — covers search/__module__=='re'; findall/__module__=='re'; IGNORECASE/__class__.__module__=='re'."
    - "re_extra41.zspec.zsdl — covers DOTALL/VERBOSE __class__.__module__.__eq__('re')."
    - "re_extra27.zspec.zsdl — covers IGNORECASE/__class__.__module__.__eq__('re'); RegexFlag.__module__.__eq__('re')."
    - "re_extra33.zspec.zsdl — covers error/Pattern/Match/RegexFlag __dict__.__class__.__name__.__len__()==12."
  notes:
    - "This spec extends re_extra56.zspec.zsdl."
    - "Prior specs collectively covered: IGNORECASE/MULTILINE/DOTALL/VERBOSE/ASCII/UNICODE RegexFlag member __class__.__module__=='re' (re_extra27/41/43/51); re function __module__.__eq__('re') for all 9 functions (re_extra54); Pattern/Match/RegexFlag __module__ equality (re_extra55). NOT YET COVERED: Pattern.__class__.__module__.__eq__('builtins') — Pattern is a C-extension type with metaclass 'type' from builtins; NO prior re spec checks Pattern.__class__.__module__; novel; Match.__class__.__module__.__eq__('builtins') — same reasoning; novel; error.__class__.__module__.__eq__('builtins') — error is an Exception subclass with metaclass 'type' from builtins; novel; search.__class__.__module__.__eq__('builtins') — search is a Python function; the 'function' type is from builtins; no prior re spec checks function-level __class__.__module__; novel; compile/__class__.__module__.__eq__('builtins') (novel); sub/__class__.__module__.__eq__('builtins') (novel); findall/__class__.__module__.__eq__('builtins') (novel); RegexFlag.__class__.__module__.__eq__('enum') — RegexFlag's metaclass is EnumType from the 'enum' module; NO prior re spec checks RegexFlag.__class__.__module__ (earlier specs check RegexFlag member __class__.__module__=='re', but NOT the class object itself); novel."
    - "This spec covers: re.Pattern.__class__.__module__.__eq__('builtins') (NOVEL — Pattern is a C-extension type; its metaclass is 'type' from builtins; no prior re spec checks Pattern.__class__.__module__; novel in remod57 namespace); re.Match.__class__.__module__.__eq__('builtins') (NOVEL); re.error.__class__.__module__.__eq__('builtins') (NOVEL — error is an Exception subclass; metaclass is 'type' from builtins; novel); re.search.__class__.__module__.__eq__('builtins') (NOVEL — search is a Python function; the builtin 'function' type has __module__=='builtins'; no prior re spec checks search.__class__.__module__; novel); re.compile.__class__.__module__.__eq__('builtins') (NOVEL); re.sub.__class__.__module__.__eq__('builtins') (NOVEL); re.findall.__class__.__module__.__eq__('builtins') (NOVEL); re.RegexFlag.__class__.__module__.__eq__('enum') (NOVEL — RegexFlag's metaclass is EnumType from the 'enum' module; __class__.__module__=='enum'; no prior re spec checks the RegexFlag class object's __class__.__module__; novel — distinct from RegexFlag member __class__.__module__=='re')."
    - "re.Pattern.__class__.__module__ == 'builtins'. re.Pattern is the compiled pattern type, implemented as a C extension (_sre.SRE_Pattern). Its metaclass is the standard 'type' builtin. 'type'.__module__ == 'builtins'. No prior re spec checks Pattern.__class__.__module__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Match.__class__.__module__ == 'builtins'. re.Match is the match object type, also a C extension. Its metaclass is 'type' from builtins. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.error.__class__.__module__ == 'builtins'. re.error is a pure-Python Exception subclass. Exception subclasses use the standard 'type' metaclass from builtins. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.search.__class__.__module__ == 'builtins'. re.search is a module-level Python function. The 'function' type is a C-level builtin with __module__=='builtins'. This is distinct from re.search.__module__=='re' (covered in re_extra54/43), which reflects the module the function belongs to. No prior re spec checks search.__class__.__module__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.compile.__class__.__module__ == 'builtins'. Same reasoning as search. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.sub.__class__.__module__ == 'builtins'. Same reasoning. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.findall.__class__.__module__ == 'builtins'. Same reasoning. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.RegexFlag.__class__.__module__ == 'enum'. RegexFlag is an IntFlag enum. Its metaclass is EnumType (the enum metaclass), which is defined in the 'enum' module. Therefore RegexFlag.__class__.__module__ == 'enum'. This is distinct from RegexFlag member __class__.__module__=='re' (covered by re_extra27/41/43/51), which is the module of the RegexFlag type itself (not the metaclass). No prior re spec checks the RegexFlag class object's __class__.__module__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re type __class__.__module__ == 'builtins'
#
# Pattern, Match, and error are all types whose metaclass is the standard
# 'type' builtin (Pattern and Match are C extensions; error is a pure-Python
# Exception subclass). The 'type' metaclass has __module__ == 'builtins'.
#
#   Pattern.__class__.__module__ == 'builtins'
#   Match.__class__.__module__   == 'builtins'
#   error.__class__.__module__   == 'builtins'
#
# No prior re spec checks __class__.__module__ for any of these re types.
# All three anchors are novel in the remod57 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra57.type_class_module_eq:
  description: "re type __class__.__module__.__eq__('builtins') for Pattern/Match/error — C-extension types and Exception subclasses have metaclass 'type' from builtins; no prior re spec checks Pattern/Match/error __class__.__module__; all three novel anchors in remod57 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: remod57type

  columns: [id, function, args, expected]
  rows:
    - [Pattern_class_module, "Pattern.__class__.__module__.__eq__", ["builtins"], true]
    - [Match_class_module,   "Match.__class__.__module__.__eq__",   ["builtins"], true]
    - [error_class_module,   "error.__class__.__module__.__eq__",   ["builtins"], true]

# ---------------------------------------------------------------------------
# re module-level function __class__.__module__ == 'builtins'
#
# Module-level functions (search, compile, sub, findall) are instances of the
# builtin 'function' type. The 'function' type has __module__ == 'builtins'.
# This is distinct from the function's own __module__ attribute (which is 're',
# covered by re_extra54). __class__.__module__ is the module of the type itself.
#
#   search.__class__.__module__  == 'builtins'
#   compile.__class__.__module__ == 'builtins'
#   sub.__class__.__module__     == 'builtins'
#   findall.__class__.__module__ == 'builtins'
#
# No prior re spec checks __class__.__module__ for any re module-level function.
# All four anchors are novel in the remod57 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra57.function_class_module_eq:
  description: "re module-level function __class__.__module__.__eq__('builtins') for search/compile/sub/findall — Python functions are instances of the builtin 'function' type; 'function'.__module__=='builtins'; distinct from re.search.__module__=='re' (own module); no prior re spec checks re function __class__.__module__; all four novel anchors in remod57 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: remod57func

  columns: [id, function, args, expected]
  rows:
    - [search_class_module,  "search.__class__.__module__.__eq__",  ["builtins"], true]
    - [compile_class_module, "compile.__class__.__module__.__eq__", ["builtins"], true]
    - [sub_class_module,     "sub.__class__.__module__.__eq__",     ["builtins"], true]
    - [findall_class_module, "findall.__class__.__module__.__eq__", ["builtins"], true]

# ---------------------------------------------------------------------------
# re.RegexFlag __class__.__module__ == 'enum'
#
# RegexFlag is an IntFlag enumeration. Its metaclass is EnumType, defined in
# the 'enum' module. Therefore RegexFlag.__class__.__module__ == 'enum'.
# This is distinct from RegexFlag member (e.g. IGNORECASE).__class__.__module__
# which is 're' (the module where RegexFlag is defined), covered by earlier
# re specs. No prior re spec checks the RegexFlag class object's own
# __class__.__module__ (the metaclass's module).
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra57.RegexFlag_class_module_eq:
  description: "re.RegexFlag.__class__.__module__ == 'enum' — RegexFlag is an IntFlag enum whose metaclass is EnumType from the 'enum' module; __class__.__module__=='enum' refers to the metaclass's module; distinct from RegexFlag member __class__.__module__=='re' (covered by re_extra27/41/51); no prior re spec checks the RegexFlag class object's __class__.__module__; novel anchor in remod57 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__class__.__module__.__eq__
  args: ["enum"]
  expected: true

invariant re_extra57.Pattern_class_module_eq:
  description: "re.Pattern.__class__.__module__ == 'builtins' — Pattern is a C-extension type; its metaclass is the standard 'type' builtin with __module__=='builtins'; no prior re spec checks Pattern.__class__.__module__; novel anchor in remod57 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant re_extra57.search_class_module_eq:
  description: "re.search.__class__.__module__ == 'builtins' — search is a Python function; the builtin 'function' type has __module__=='builtins'; distinct from search.__module__=='re' (the function's own module, covered in re_extra43/54); no prior re spec checks search.__class__.__module__; novel anchor in remod57 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: search.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true
