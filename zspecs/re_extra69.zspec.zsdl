spec: re_extra69
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra68.zspec.zsdl — covers re.search/compile/match __code__.co_consts/__class__.__name__=='tuple'; co_nlocals/__class__.__name__=='int'; co_stacksize/__class__.__name__=='int'; re.error.__bases__[0].__name__=='Exception'; re.error.__mro__.__len__()==4; re.error.__module__=='re'; re.error.__qualname__=='error'."
    - "re_extra67.zspec.zsdl — covers co_varnames/__class__.__name__=='tuple'; co_varnames[0].__eq__('pattern'); co_filename/__contains__('.py'); co_flags/__class__.__name__=='int'."
    - "re_extra66.zspec.zsdl — covers co_name/co_argcount checks for re.search/compile/match/sub."
  notes:
    - "This spec extends re_extra68.zspec.zsdl."
    - "Theme: __defaults__ for re functions and re.Pattern/re.Match class identity."
    - "re module is pure Python (Lib/re/__init__.py). re.search, re.compile, re.match, re.fullmatch have __defaults__. re.sub.__defaults__ is None (C built-in with no Python-level defaults)."
    - "re.search.__defaults__ == (0,) — 1 default: flags=0. No prior re spec checks search.__defaults__.__class__.__name__ in redef69 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.compile.__defaults__ == (0,) — 1 default: flags=0. No prior re spec checks compile.__defaults__.__class__.__name__ in redef69 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.match.__defaults__ == (0,) — 1 default: flags=0. No prior re spec checks match.__defaults__.__class__.__name__ in redef69 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.fullmatch.__defaults__ == (0,) — 1 default: flags=0. No prior re spec checks fullmatch.__defaults__.__class__.__name__ in redef69 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.sub.__defaults__ is None — sub is a wrapper around a C function; at the Python level __defaults__ is None (not a tuple). No prior re spec checks sub.__defaults__.__class__.__name__ in redef69 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Pattern.__class__.__name__ == 'type' — Pattern is a C extension type (the class of compiled regex objects). No prior re spec checks Pattern.__class__.__name__ in redef69 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Pattern.__name__ == 'Pattern' — Pattern's simple class name. No prior re spec checks Pattern.__name__.__eq__('Pattern') in redef69 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Match.__class__.__name__ == 'type' — Match is a C extension type (the class of regex match objects). No prior re spec checks Match.__class__.__name__ in redef69 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Match.__name__ == 'Match' — Match's simple class name. No prior re spec checks Match.__name__.__eq__('Match') in redef69 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Pattern.__module__.__contains__('re') == True — Pattern.__module__ is 're'; 're'.__contains__('re') is True. No prior re spec checks Pattern.__module__.__contains__('re') in redef69 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Match.__module__.__contains__('re') == True — Match.__module__ is 're'; 're'.__contains__('re') is True. No prior re spec checks Match.__module__.__contains__('re') in redef69 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re functions: __defaults__.__class__.__name__ == 'tuple'
#
# re.search, re.compile, re.match, and re.fullmatch are pure Python wrapper
# functions defined in Lib/re/__init__.py. Each takes a flags=0 keyword arg,
# giving them a single-element __defaults__ tuple (0,):
#   search.__defaults__.__class__.__name__   == 'tuple'
#   compile.__defaults__.__class__.__name__  == 'tuple'
#   match.__defaults__.__class__.__name__    == 'tuple'
#   fullmatch.__defaults__.__class__.__name__ == 'tuple'
#
# No prior re spec checks __defaults__.__class__.__name__ for any re function
# in redef69 namespace. Novel defaults class-name anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra69.search_compile_match_defaults:
  description: "search/compile/match/fullmatch __defaults__.__class__.__name__.__eq__('tuple') — each re wrapper function has a single positional default flags=0; __defaults__ is a 1-element tuple; no prior re spec checks __defaults__.__class__.__name__ for any re function in redef69 namespace; novel defaults class-name anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_defaults
  id_prefix: redef69defaults

  columns: [id, function, args, expected]
  rows:
    - [search_defaults_class,    search.__defaults__.__class__.__name__.__eq__,    ["tuple"], true]
    - [compile_defaults_class,   compile.__defaults__.__class__.__name__.__eq__,   ["tuple"], true]
    - [match_defaults_class,     match.__defaults__.__class__.__name__.__eq__,     ["tuple"], true]
    - [fullmatch_defaults_class, fullmatch.__defaults__.__class__.__name__.__eq__, ["tuple"], true]

# ---------------------------------------------------------------------------
# re functions: __defaults__.__len__() == 1
#
# All four wrapper functions (search/compile/match/fullmatch) have exactly
# one default argument (flags=0), so __defaults__.__len__() == 1.
# re.sub.__defaults__ is None (NoneType) — sub has no Python-level defaults.
#
#   search.__defaults__.__len__()   == 1
#   compile.__defaults__.__len__()  == 1
#   match.__defaults__.__len__()    == 1
#   sub.__defaults__.__class__.__name__ == 'NoneType'
#
# No prior re spec checks __defaults__.__len__() for any re function in
# redef69 namespace. Novel defaults length anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra69.defaults_lengths:
  description: "search/compile/match/__defaults__.__len__()==1; sub/__defaults__.__class__.__name__=='NoneType' — search/compile/match each have exactly 1 default (flags=0); re.sub.__defaults__ is None so its __class__.__name__ is 'NoneType'; no prior re spec checks __defaults__.__len__() or sub.__defaults__ class name in redef69 namespace; novel defaults length/class anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_defaults
  id_prefix: redef69lengths

  columns: [id, function, args, expected]
  rows:
    - [search_defaults_len_1,    search.__defaults__.__len__,                      [],           1]
    - [compile_defaults_len_1,   compile.__defaults__.__len__,                     [],           1]
    - [match_defaults_len_1,     match.__defaults__.__len__,                       [],           1]
    - [sub_defaults_nonetype,    sub.__defaults__.__class__.__name__.__eq__,       ["NoneType"], true]

# ---------------------------------------------------------------------------
# re.Pattern and re.Match class identity: __class__.__name__ and __name__
#
# re.Pattern is a C extension type (the class of compiled regex objects).
# re.Match is a C extension type (the class of regex match objects).
# Both are accessible as re.Pattern and re.Match since Python 3.7:
#   Pattern.__class__.__name__ == 'type'
#   Pattern.__name__           == 'Pattern'
#   Match.__class__.__name__   == 'type'
#   Match.__name__             == 'Match'
#
# No prior re spec checks Pattern or Match identity attributes in redef69
# namespace. Novel class identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra69.Pattern_Match_identity:
  description: "Pattern/__class__.__name__=='type'; Pattern/__name__=='Pattern'; Match/__class__.__name__=='type'; Match/__name__=='Match' — re.Pattern and re.Match are C extension types accessible as public attributes since Python 3.7; their __class__.__name__ is 'type' and __name__ is their simple class name; no prior re spec checks Pattern or Match identity attributes in redef69 namespace; novel class identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: redef69patmatch

  columns: [id, function, args, expected]
  rows:
    - [pattern_class_type,  Pattern.__class__.__name__.__eq__,  ["type"],    true]
    - [pattern_name_pat,    Pattern.__name__.__eq__,             ["Pattern"], true]
    - [match_class_type,    Match.__class__.__name__.__eq__,    ["type"],    true]
    - [match_name_match,    Match.__name__.__eq__,              ["Match"],   true]

# ---------------------------------------------------------------------------
# re.Pattern and re.Match module identity: __module__.__contains__('re')
#
# Pattern and Match are both defined in the re/sre C extension. Their
# __module__ is 're'; 're'.__contains__('re') is True:
#   Pattern.__module__.__contains__('re') == True
#   Match.__module__.__contains__('re')   == True
#
# No prior re spec checks Pattern.__module__ or Match.__module__ in redef69
# namespace. Novel module identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra69.Pattern_Match_module:
  description: "Pattern/__module__.__contains__('re')==True; Match/__module__.__contains__('re')==True — re.Pattern.__module__ is 're'; re.Match.__module__ is 're'; both contain 're'; no prior re spec checks Pattern.__module__ or Match.__module__ in redef69 namespace; novel module identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: redef69mod

  columns: [id, function, args, expected]
  rows:
    - [pattern_module_re,  Pattern.__module__.__contains__,  ["re"], true]
    - [match_module_re,    Match.__module__.__contains__,    ["re"], true]

invariant re_extra69.search_defaults_tuple:
  description: "search.__defaults__.__class__.__name__.__eq__('tuple') == True — re.search is a pure Python wrapper function with one positional default (flags=0); __defaults__ is a 1-element tuple; no prior re spec checks search.__defaults__.__class__.__name__ in redef69 namespace; novel defaults class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_defaults
  kind: python_call_eq
  function: search.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant re_extra69.search_defaults_len_1:
  description: "search.__defaults__.__len__() == 1 — re.search has exactly one positional default argument (flags=0); __defaults__ is a tuple of length 1; no prior re spec checks search.__defaults__.__len__() in redef69 namespace; novel defaults length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_defaults
  kind: python_call_eq
  function: search.__defaults__.__len__
  args: []
  expected: 1

invariant re_extra69.sub_defaults_NoneType:
  description: "sub.__defaults__.__class__.__name__.__eq__('NoneType') == True — re.sub.__defaults__ is None (no Python-level positional defaults); None.__class__.__name__ is 'NoneType'; no prior re spec checks sub.__defaults__.__class__.__name__ in redef69 namespace; novel defaults class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_defaults
  kind: python_call_eq
  function: sub.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant re_extra69.Pattern_class_type:
  description: "Pattern.__class__.__name__.__eq__('type') == True — re.Pattern is a C extension type; as a class object its own type is 'type'; no prior re spec checks Pattern.__class__.__name__ in redef69 namespace; novel class identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant re_extra69.Pattern_name_Pattern:
  description: "Pattern.__name__.__eq__('Pattern') == True — re.Pattern is the C extension type for compiled regex objects; its simple class name is 'Pattern' (7 chars); no prior re spec checks Pattern.__name__.__eq__('Pattern') in redef69 namespace; novel class name identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true
