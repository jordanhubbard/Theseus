spec: theseus_importlib_resources_cr
version: ">=3.0"
backend: python_cleanroom(theseus_importlib_resources_cr)
blocks: importlib.resources

docs: https://docs.python.org/3/library/importlib.resources.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/importlib.resources.html"
  not_derived_from:
    - "CPython source: Lib/importlib/resources/__init__.py"
  notes:
    - "Clean-room importlib.resources module. Do NOT import importlib.resources."

error_model: python_exceptions

invariant theseus_importlib_resources_cr.impres2_files:
  description: "files() function exists and accepts a package name"
  category: behavior
  kind: python_call_eq
  function: impres2_files
  args: []
  expected: true

invariant theseus_importlib_resources_cr.impres2_path:
  description: "as_file context manager wraps a Traversable resource"
  category: behavior
  kind: python_call_eq
  function: impres2_path
  args: []
  expected: true

invariant theseus_importlib_resources_cr.impres2_is_resource:
  description: "is_resource() function exists"
  category: behavior
  kind: python_call_eq
  function: impres2_is_resource
  args: []
  expected: true
