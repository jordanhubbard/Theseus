spec: re_extra246
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra245.zspec.zsdl — covers re.A/ASCII, re.I/IGNORECASE, re.M/MULTILINE, re.S/DOTALL alias identity"
    - "re_extra221.zspec.zsdl — covers re.compile() Pattern class metadata and pattern/groups attributes"
  notes:
    - "This spec covers: re.compile() behavioral contracts — compiled pattern object attributes."
    - "re.compile(r'\\d+').pattern == '\\\\d+' — the source pattern string is preserved verbatim; len=3; verified Python 3.14.3 macOS."
    - "re.compile(r'\\d+').flags.__class__.__name__ == 'int' — flags attribute is a plain int in Python 3.14 (not RegexFlag); verified Python 3.14.3 macOS."
    - "re.compile(r'\\d+', re.IGNORECASE).flags.__class__.__name__ == 'int' — flags with IGNORECASE is also a plain int; value 34 (32|2); verified Python 3.14.3 macOS."
    - "re.compile(r'abc').groups == 0 — pattern with no capturing groups reports groups == 0; verified Python 3.14.3 macOS."
    - "re.compile(r'(abc)').groups == 1 — pattern with one capturing group reports groups == 1; verified Python 3.14.3 macOS."
    - "re.compile(r'(abc)(def)').groups == 2 — pattern with two capturing groups reports groups == 2; verified Python 3.14.3 macOS."
    - "re.compile(r'\\d+').flags == 32 — default flags include re.UNICODE (32) only; verified Python 3.14.3 macOS."
    - "re.compile(r'\\d+', re.IGNORECASE).flags == 34 — IGNORECASE adds 2 to the default 32; verified Python 3.14.3 macOS."
    - "type(re.compile('abc')).__name__ == 'Pattern' — compiled result is a Pattern instance; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile() Pattern .pattern attribute
# pattern stores the source regex string verbatim.
# compile(r'\d+').pattern == '\\d+'; len == 3.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra246.compiled_pattern_attr:
  description: "re.compile() .pattern attribute value and length; verified Python 3.14.3"
  kind: python_call_eq
  category: pattern_attrs
  id_prefix: recompattr246

  columns: [id, function, args, expected]
  rows:
    - [pattern_eq,     "compile('\\\\d+').pattern.__eq__",     ["\\d+"], true]
    - [pattern_not,    "compile('\\\\d+').pattern.__eq__",     ["abc"],  false]
    - [pattern_len,    "compile('\\\\d+').pattern.__len__",    [],       3]
    - [abc_pattern_eq, "compile('abc').pattern.__eq__",        ["abc"],  true]
    - [abc_pattern_len,"compile('abc').pattern.__len__",       [],       3]

# ---------------------------------------------------------------------------
# re.compile() Pattern .flags attribute class name
# In Python 3.14, compiled pattern .flags is a plain int (not RegexFlag).
# Default flags = 32 (re.UNICODE). With IGNORECASE: 34 (32|2).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra246.compiled_flags_class:
  description: "re.compile() Pattern .flags.__class__.__name__ == 'int'; verified Python 3.14.3"
  kind: python_call_eq
  category: pattern_attrs
  id_prefix: recompattr246

  columns: [id, function, args, expected]
  rows:
    - [flags_cls_eq,      "compile('\\\\d+').flags.__class__.__name__.__eq__",            ["int"],      true]
    - [flags_cls_not,     "compile('\\\\d+').flags.__class__.__name__.__eq__",            ["RegexFlag"],false]
    - [flags_i_cls_eq,    "compile('\\\\d+', IGNORECASE).flags.__class__.__name__.__eq__",["int"],      true]
    - [flags_val_eq,      "compile('\\\\d+').flags.__eq__",                               [32],         true]
    - [flags_i_val_eq,    "compile('\\\\d+', IGNORECASE).flags.__eq__",                  [34],         true]

# ---------------------------------------------------------------------------
# re.compile() Pattern .groups attribute
# groups counts the number of capturing groups in the pattern.
# No groups: 0; one group: 1; two groups: 2.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra246.compiled_groups_count:
  description: "re.compile() Pattern .groups attribute: 0 groups, 1 group, 2 groups; verified Python 3.14.3"
  kind: python_call_eq
  category: pattern_attrs
  id_prefix: recompattr246

  columns: [id, function, args, expected]
  rows:
    - [groups_zero,     "compile('abc').groups.__eq__",       [0], true]
    - [groups_zero_not, "compile('abc').groups.__eq__",       [1], false]
    - [groups_one,      "compile('(abc)').groups.__eq__",     [1], true]
    - [groups_two,      "compile('(abc)(def)').groups.__eq__", [2], true]
    - [groups_zero_cls, "compile('abc').groups.__class__.__name__.__eq__", ["int"], true]

# ---------------------------------------------------------------------------
# re.compile() Pattern type name
# type(re.compile('abc')).__name__ == 'Pattern'.
# __class__.__module__ == 're'.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra246.compiled_type_name:
  description: "re.compile() Pattern __class__.__name__ and __class__.__module__; verified Python 3.14.3"
  kind: python_call_eq
  category: pattern_attrs
  id_prefix: recompattr246

  columns: [id, function, args, expected]
  rows:
    - [cls_name_eq,    "compile('abc').__class__.__name__.__eq__",    ["Pattern"], true]
    - [cls_name_not,   "compile('abc').__class__.__name__.__eq__",    ["Match"],   false]
    - [cls_module_eq,  "compile('abc').__class__.__module__.__eq__",  ["re"],      true]
    - [cls_module_not, "compile('abc').__class__.__module__.__eq__",  ["sre"],     false]
    - [cls_name_len,   "compile('abc').__class__.__name__.__len__",   [],          7]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra246.compile.pattern_preserved:
  description: "re.compile(r'\\d+').pattern == '\\\\d+' — the source regex string is stored verbatim on the compiled Pattern object; verified Python 3.14.3 macOS"
  category: pattern_attrs
  kind: python_call_eq
  function: "compile('\\\\d+').pattern.__eq__"
  args: ["\\d+"]
  expected: true

invariant re_extra246.compile.pattern_len:
  description: "len(re.compile(r'\\d+').pattern) == 3 — the pattern string '\\\\d+' has 3 characters; verified Python 3.14.3 macOS"
  category: pattern_attrs
  kind: python_call_eq
  function: "compile('\\\\d+').pattern.__len__"
  args: []
  expected: 3

invariant re_extra246.compile.flags_class_is_int:
  description: "re.compile(r'\\d+').flags.__class__.__name__ == 'int' — in Python 3.14 the compiled pattern flags attribute is a plain int, not a RegexFlag; verified Python 3.14.3 macOS"
  category: pattern_attrs
  kind: python_call_eq
  function: "compile('\\\\d+').flags.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

invariant re_extra246.compile.flags_with_ignorecase_class_is_int:
  description: "re.compile(r'\\d+', re.IGNORECASE).flags.__class__.__name__ == 'int' — flags remains a plain int even when IGNORECASE is specified; verified Python 3.14.3 macOS"
  category: pattern_attrs
  kind: python_call_eq
  function: "compile('\\\\d+', IGNORECASE).flags.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

invariant re_extra246.compile.groups_zero:
  description: "re.compile(r'abc').groups == 0 — a pattern with no capturing groups reports groups == 0; verified Python 3.14.3 macOS"
  category: pattern_attrs
  kind: python_call_eq
  function: "compile('abc').groups.__eq__"
  args: [0]
  expected: true

invariant re_extra246.compile.groups_one:
  description: "re.compile(r'(abc)').groups == 1 — a pattern with one capturing group reports groups == 1; verified Python 3.14.3 macOS"
  category: pattern_attrs
  kind: python_call_eq
  function: "compile('(abc)').groups.__eq__"
  args: [1]
  expected: true

invariant re_extra246.compile.default_flags_value:
  description: "re.compile(r'\\d+').flags == 32 — the default flags value is re.UNICODE (32) when no flags are specified; verified Python 3.14.3 macOS"
  category: pattern_attrs
  kind: python_call_eq
  function: "compile('\\\\d+').flags.__eq__"
  args: [32]
  expected: true

invariant re_extra246.compile.ignorecase_flags_value:
  description: "re.compile(r'\\d+', re.IGNORECASE).flags == 34 — IGNORECASE (2) combined with UNICODE (32) gives 34; verified Python 3.14.3 macOS"
  category: pattern_attrs
  kind: python_call_eq
  function: "compile('\\\\d+', IGNORECASE).flags.__eq__"
  args: [34]
  expected: true

invariant re_extra246.compile.class_name_pattern:
  description: "re.compile('abc').__class__.__name__ == 'Pattern' — compiled patterns are instances of re.Pattern; verified Python 3.14.3 macOS"
  category: pattern_attrs
  kind: python_call_eq
  function: "compile('abc').__class__.__name__.__eq__"
  args: ["Pattern"]
  expected: true

invariant re_extra246.compile.class_module_re:
  description: "re.compile('abc').__class__.__module__ == 're' — the Pattern class reports its module as 're'; verified Python 3.14.3 macOS"
  category: pattern_attrs
  kind: python_call_eq
  function: "compile('abc').__class__.__module__.__eq__"
  args: ["re"]
  expected: true
