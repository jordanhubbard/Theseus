spec: functools_extra42
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra41.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps(5)/partial(7)/lru_cache(9)/total_ordering(14)/singledispatch(14)/cached_property(15)/reduce(6)/cmp_to_key(10)/partialmethod(13)/singledispatchmethod(20)/update_wrapper(14); __qualname__.__len__() for update_wrapper(14)/partialmethod(13)/singledispatchmethod(20)/cache(5)/total_ordering(14)/singledispatch(14)/cmp_to_key(10)/cached_property(15)/lru_cache(9)/wraps(5)/reduce(6)/partial(7); WRAPPER_ASSIGNMENTS lengths and class name; WRAPPER_UPDATES lengths and class name; __all__.__len__()==15; __all__.__class__.__name__.__len__()==4; __all__[0].__len__()==14 ('update_wrapper'); __all__[1].__len__()==5 ('wraps'); __all__[2].__len__()==19 ('WRAPPER_ASSIGNMENTS'); __all__[3].__len__()==15 ('WRAPPER_UPDATES'); __all__[4].__len__()==14 ('total_ordering'); __all__[-1].__len__()==11 ('Placeholder'); __all__[-2].__len__()==15 ('cached_property'); partial.__class__.__name__.__len__()==4 ('type'); lru_cache.__class__.__name__.__len__()==8 ('function'); reduce.__class__.__name__.__len__()==26 ('builtin_function_or_method'); partial.__new__.__qualname__.__len__()==15; cached_property.__get__.__qualname__.__len__()==23; class __dict__.__class__.__name__.__len__() for partial/partialmethod/singledispatchmethod/cached_property (all 12)."
    - "This spec covers: functools.__all__[5].__len__() (5 — 'cache'); functools.__all__[6].__len__() (10 — 'cmp_to_key'); functools.__all__[7].__len__() (9 — 'lru_cache'); functools.__all__[8].__len__() (6 — 'reduce'); functools.__all__[9].__len__() (7 — 'partial'); wraps.__class__.__name__.__len__() (8 — 'function', wraps is a plain Python function); functools.__cached__.__class__.__name__.__len__() (3 — 'str', the __cached__ attribute is a path string); cached_property.__set_name__.__qualname__.__len__() (28 — 'cached_property.__set_name__'); total_ordering.__dict__.__class__.__name__.__len__() (4 — 'dict', not 'mappingproxy', because total_ordering is a function, not a class)."
    - "Key findings: functools.__all__[5] through __all__[9] are 'cache'(5)/'cmp_to_key'(10)/'lru_cache'(9)/'reduce'(6)/'partial'(7) — completing coverage of __all__ indices 0-9. functools.wraps.__class__.__name__ is 'function' (8 chars) — wraps is implemented as a plain Python function returning a partial object. functools.__cached__ is the .pyc cache path string — its __class__.__name__ is 'str' (3 chars). functools.cached_property.__set_name__.__qualname__ is 'cached_property.__set_name__' (28 chars) — the longest qualname of any cached_property method, because the class prefix 'cached_property.' is 16 chars and '__set_name__' is 12 chars. functools.total_ordering.__dict__.__class__.__name__ is 'dict' (4 chars), not 'mappingproxy' (12) — because total_ordering is a function, not a class; function __dict__ is a plain mutable dict."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.__all__[5-9] element lengths — extra42 namespace
#
# functools.__all__[5] is 'cache' (5 chars) — the shorter alias for
# lru_cache(maxsize=None). functools.__all__[6] is 'cmp_to_key' (10 chars).
# functools.__all__[7] is 'lru_cache' (9 chars). functools.__all__[8] is
# 'reduce' (6 chars). functools.__all__[9] is 'partial' (7 chars). Prior
# specs recorded indices 0-4 and -1/-2; this table completes indices 5-9.
# No prior functools spec records these five values together in a combined
# table in the extra42 namespace.
# ---------------------------------------------------------------------------

table functools_extra42.all_indices_5_to_9_lengths:
  description: "functools.__all__[5-9] element lengths: cache(5), cmp_to_key(10), lru_cache(9), reduce(6), partial(7)"
  kind: python_call_eq
  category: module_metadata
  id_prefix: allidx5942

  columns: [id, function, args, expected, description]
  rows:
    - [all_idx5,
       "__all__[5].__len__",
       [],
       5,
       "len(functools.__all__[5]) == 5 — '__all__[5]' is 'cache' (short alias for lru_cache with maxsize=None)"]
    - [all_idx6,
       "__all__[6].__len__",
       [],
       10,
       "len(functools.__all__[6]) == 10 — '__all__[6]' is 'cmp_to_key' (converts comparison function to sort key)"]
    - [all_idx7,
       "__all__[7].__len__",
       [],
       9,
       "len(functools.__all__[7]) == 9 — '__all__[7]' is 'lru_cache' (least-recently-used memoizing decorator)"]
    - [all_idx8,
       "__all__[8].__len__",
       [],
       6,
       "len(functools.__all__[8]) == 6 — '__all__[8]' is 'reduce' (C-extension left-fold over iterable)"]
    - [all_idx9,
       "__all__[9].__len__",
       [],
       7,
       "len(functools.__all__[9]) == 7 — '__all__[9]' is 'partial' (C-extension partial application class)"]

# ---------------------------------------------------------------------------
# Runtime class name lengths for module-level callables — extra42 namespace
#
# functools.wraps.__class__.__name__ is 'function' (8 chars) — wraps is a
# plain Python function (not a class), so its metatype is 'function'. This
# contrasts with functools.partial.__class__.__name__ == 'type' (4 chars,
# since partial is a class) and functools.reduce.__class__.__name__ ==
# 'builtin_function_or_method' (26 chars, C extension). functools.__cached__
# is the path to the compiled .pyc bytecode file; its __class__.__name__ is
# 'str' (3 chars). cached_property.__set_name__.__qualname__ is
# 'cached_property.__set_name__' (28 chars) — the longest qualname of any
# cached_property method, 4 chars longer than __get__ (23 chars). No prior
# functools spec records these three values together in the extra42 namespace.
# ---------------------------------------------------------------------------

table functools_extra42.callable_class_names_and_qualnames:
  description: "functools callable metatype/qualname lengths: wraps.__class__.__name__(8), __cached__.__class__.__name__(3), cached_property.__set_name__.__qualname__(28)"
  kind: python_call_eq
  category: string_properties
  id_prefix: callablemeta42

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_class_name_len,
       wraps.__class__.__name__.__len__,
       [],
       8,
       "len(functools.wraps.__class__.__name__) == 8 — 'function' (wraps is a plain Python function, not a class; cf. partial==4, reduce==26)"]
    - [cached_classname_len,
       functools.__cached__.__class__.__name__.__len__,
       [],
       3,
       "len(functools.__cached__.__class__.__name__) == 3 — 'str' (functools.__cached__ is the .pyc bytecode path, a plain string)"]
    - [cached_prop_set_name_qualname_len,
       cached_property.__set_name__.__qualname__.__len__,
       [],
       28,
       "len(functools.cached_property.__set_name__.__qualname__) == 28 — 'cached_property.__set_name__' (16-char class prefix + 12-char method; longest cached_property method qualname)"]

# ---------------------------------------------------------------------------
# total_ordering.__dict__.__class__.__name__.__len__() — extra42 standalone invariant
#
# functools.total_ordering is a decorator function, not a class. Its __dict__
# is a plain Python dict (not a mappingproxy), so __dict__.__class__.__name__
# is 'dict' (4 chars). This contrasts with functools.partial.__dict__.__class__
# .__name__ == 'mappingproxy' (12 chars), because partial is a class. The
# distinction captures a key structural difference: class __dict__ is a
# mappingproxy (read-only view), while function __dict__ is a mutable dict.
# No prior functools spec records total_ordering.__dict__.__class__.__name__
# .__len__() == 4 in the extra42 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra42.total_ordering_dict_class_name_len:
  description: "len(functools.total_ordering.__dict__.__class__.__name__) == 4 — 'dict' (total_ordering is a function; function __dict__ is mutable dict, not mappingproxy)"
  category: string_properties
  kind: python_call_eq
  function: total_ordering.__dict__.__class__.__name__.__len__
  args: []
  expected: 4
