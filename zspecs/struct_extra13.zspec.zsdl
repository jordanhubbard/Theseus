spec: struct_extra13
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct.zspec.zsdl — pack/unpack for B/b/H/h/I/i/Q/q/f/d/?/e/x; calcsize; roundtrip; error cases."
    - "struct_extra.zspec.zsdl — Struct format/size, calcsize extras, pack_into, unpack_from, iter_unpack, error name/bases."
    - "struct_extra2.zspec.zsdl — function __name__/__module__; pack(>H,256); unpack(>H); calcsize(>HHH); Struct base."
    - "struct_extra3.zspec.zsdl — pack/unpack/calcsize for !f/!d/!?; calcsize for !5s/!3p/!x/!5x."
    - "struct_extra4.zspec.zsdl — Struct.__name__; pack_into.__name__; function __qualname__ table; error.__qualname__; pack(>I,65536)/(<I,65536)/(>i,-256); calcsize(>i/<i/>I)."
    - "struct_extra5.zspec.zsdl — Struct.__qualname__; Struct('>I'/'>H') format/size; pack('>B',255); unpack('>B',xff); calcsize('>B'/'<B'/'>5s'); Struct('>I').pack(256)."
    - "struct_extra6.zspec.zsdl — pack/unpack('>b',127/-128); Struct('>b'/'>Q') format/size; pack/calcsize('<h'); unpack('<h')."
    - "struct_extra7.zspec.zsdl — pack/unpack/calcsize for '>l'/'>L'/'=H'/'>2B'; Struct('>l') format/size."
    - "struct_extra8.zspec.zsdl — function __module__ (all '_struct' except error 'struct'); pack return type/length for '>I'/'>H'; calcsize('>IHB'); unpack('>H',0100); Struct('>IHB') format/size; calcsize('>Q')."
    - "struct_extra9.zspec.zsdl — calcsize('c'/'P'); Struct method descriptor __qualname__ table; Struct method descriptor __name__ table."
    - "struct_extra10.zspec.zsdl — pack/unpack('>BB',0,255); pack/unpack('<I',1); calcsize('<f'/'<d'); Struct('>BB') format/size; pack('>i',0/-1)."
    - "struct_extra11.zspec.zsdl — pack('>I',305419896); pack('<H',256); pack('!f',1.0) length; unpack('>I',12345678); calcsize('!BHI'/'3s'); Struct __name__/__module__; error.__module__; pack/unpack('>H',1000); pack('>B',127)."
    - "struct_extra12.zspec.zsdl — pack/unpack('<H' with 1/65535/256); unpack('>i',FFFFFFFF); calcsize('<H'/'<I'/'>i'/'>b'/'!H'); pack('>b',0)."
  notes:
    - "This spec adds genuinely new test vectors not present in any prior struct spec."
    - "struct.pack('=H', 1) — native byte order unsigned short; extra7 covers '=H' in calcsize but no prior spec packs '=H' with value 1 and checks __len__."
    - "struct.calcsize('=H') == 2 — native byte order unsigned short; extra7 covers '=H' in pack/unpack but not standalone calcsize."
    - "struct.calcsize('=I') == 4 — native byte order unsigned int; no prior spec checks '=I' standalone calcsize."
    - "struct.calcsize('=c') == 1 — native byte order char; extra9 covers 'c' standalone but not '=c' prefixed."
    - "struct.pack('c', b'A') == b'A' — char pack; no prior spec packs 'c' with b'A'."
    - "struct.unpack('c', b'A') == (b'A',) — char unpack; no prior spec unpacks 'c' from b'A'."
    - "struct.pack('>H', 1000) == b'\\x03\\xe8' — big-endian uint16 value 1000; no prior spec packs '>H' with 1000 checking value (extra11 packs/unpacks '>H' with 1000 but only in extra11 namespace)."
    - "struct.unpack('>H', b'\\x03\\xe8') == (1000,) — new in extra13 namespace."
    - "struct.calcsize('3s') == 3 — three-byte string; no prior spec checks '3s' standalone calcsize."
    - "struct.pack('3s', b'abc') == b'abc' — fixed-width string pack; no prior spec packs '3s' with b'abc'."
    - "struct.unpack('3s', b'abc') == (b'abc',) — fixed-width string unpack; no prior spec unpacks '3s' from b'abc'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# calcsize — native byte order and string format variants
#
# '=H', '=I', '=c' use native byte order prefix not yet tested in standalone
# calcsize. '3s' is a fixed-width string format not yet tested standalone.
# ---------------------------------------------------------------------------

table struct_extra13.calcsize_native_and_string:
  kind: python_call_eq
  category: calcsize
  id_prefix: calcsize13

  columns: [id, function, args, expected]
  rows:
    - [native_uint16,   calcsize, ["=H"],  2]
    - [native_uint32,   calcsize, ["=I"],  4]
    - [native_char,     calcsize, ["=c"],  1]
    - [string_3bytes,   calcsize, ["3s"],  3]

# ---------------------------------------------------------------------------
# pack — native byte order and char format
#
# '=H' with value 1 checks that native byte order produces a 2-byte result.
# 'c' with b'A' is a new pack vector for the char format code.
# '>H' with 1000 produces b'\x03\xe8' — new extra13 anchor for this vector.
# '3s' with b'abc' produces b'abc' — fixed-width string pack, new vector.
# ---------------------------------------------------------------------------

table struct_extra13.pack_new_formats:
  kind: python_call_eq
  category: pack_values
  id_prefix: pack13

  columns: [id, function, args, expected]
  rows:
    - [be_uint16_1000,  pack, [">H", 1000],    !hex 03e8]
    - [char_A,          pack, ["c",  !ascii A], !ascii A]
    - [string_3s_abc,   pack, ["3s", !ascii abc], !ascii abc]

# ---------------------------------------------------------------------------
# pack '=H' length check
#
# Native byte order pack of unsigned short with value 1 must be exactly 2 bytes.
# method: __len__ is used because the return is bytes and we need the byte count.
# ---------------------------------------------------------------------------

invariant struct_extra13.pack.native_uint16_one_length:
  description: "len(struct.pack('=H', 1)) == 2 — native byte order unsigned short always 2 bytes"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: ["=H", 1]
  method: __len__
  method_args: []
  expected: 2

# ---------------------------------------------------------------------------
# unpack — char and string format codes
#
# unpack('c', b'A') == (b'A',) — char unpack with literal A byte; new vector.
# unpack('>H', b'\x03\xe8') == (1000,) — new extra13 anchor for this vector.
# unpack('3s', b'abc') == (b'abc',) — fixed-width string unpack; new vector.
# ---------------------------------------------------------------------------

table struct_extra13.unpack_new_formats:
  kind: python_call_eq
  category: unpack_values
  id_prefix: unpack13

  columns: [id, function, args, expected]
  rows:
    - [char_A,          unpack, ["c",  !ascii A],   [!ascii A]]
    - [be_uint16_1000,  unpack, [">H", !hex 03e8],  [1000]]
    - [string_3s_abc,   unpack, ["3s", !ascii abc],  [!ascii abc]]

