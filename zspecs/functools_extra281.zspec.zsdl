spec: functools_extra281
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.update_wrapper is a pure-Python function; __module__ == 'functools', __class__.__name__ == 'function'."
    - "update_wrapper.__name__ == 'update_wrapper' (14 chars); __qualname__ == 'update_wrapper'."
    - "update_wrapper copies __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__ from wrapped to wrapper (WRAPPER_ASSIGNMENTS)."
    - "update_wrapper also sets wrapper.__wrapped__ = wrapped (the original function)."
    - "update_wrapper.__doc__ is not None — the function has a docstring."
    - "update_wrapper.__module__ == 'functools' confirms it is defined in the functools module itself."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.update_wrapper — function identity
#
# update_wrapper is a pure-Python function in functools.
# __name__ == 'update_wrapper' (14 chars); __qualname__ matches __name__.
# __module__ == 'functools'; __class__.__name__ == 'function'.
# __doc__ is not None — the function ships with a docstring.
# ---------------------------------------------------------------------------

table functools_extra281.update_wrapper_identity:
  description: "functools.update_wrapper function identity — __name__, __module__, __qualname__, __class__.__name__, doc presence; pure-Python function; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex281uwi

  columns: [id, function, args, expected, description]
  rows:
    - [uw_name_eq,   update_wrapper.__name__.__eq__,           ["update_wrapper"], true, "functools.update_wrapper.__name__ == 'update_wrapper'; verified with Python 3.14.3"]
    - [uw_name_len,  update_wrapper.__name__.__len__,          [],                 14,   "functools.update_wrapper.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [uw_mod_eq,    update_wrapper.__module__.__eq__,         ["functools"],      true, "functools.update_wrapper.__module__ == 'functools'; verified with Python 3.14.3"]
    - [uw_qn_eq,     update_wrapper.__qualname__.__eq__,       ["update_wrapper"], true, "functools.update_wrapper.__qualname__ == 'update_wrapper'; verified with Python 3.14.3"]
    - [uw_cls_eq,    update_wrapper.__class__.__name__.__eq__, ["function"],       true, "functools.update_wrapper.__class__.__name__ == 'function' (pure-Python function); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools.update_wrapper — __wrapped__ attribute and assignment constants
#
# After update_wrapper(w, f), w.__wrapped__ is f; WRAPPER_ASSIGNMENTS
# specifies which attributes are copied; WRAPPER_UPDATES specifies which are
# merged. WRAPPER_ASSIGNMENTS contains '__name__', '__module__', '__doc__'.
# update_wrapper.__doc__ is not None.
# ---------------------------------------------------------------------------

table functools_extra281.update_wrapper_assignments_doc:
  description: "functools.update_wrapper doc presence; WRAPPER_ASSIGNMENTS contains __name__, __module__, __doc__; __wrapped__ attribute set; verified with Python 3.14.3"
  kind: python_call_eq
  category: behavior
  id_prefix: ftex281uwa

  columns: [id, function, args, expected, description]
  rows:
    - [uw_doc_none,  update_wrapper.__doc__.__eq__,            [None],             false, "functools.update_wrapper.__doc__ is not None — function ships with a docstring; verified with Python 3.14.3"]
    - [wa_name,      WRAPPER_ASSIGNMENTS.__contains__,         ["__name__"],       true,  "functools.WRAPPER_ASSIGNMENTS contains '__name__' — name is propagated by update_wrapper; verified with Python 3.14.3"]
    - [wa_mod,       WRAPPER_ASSIGNMENTS.__contains__,         ["__module__"],     true,  "functools.WRAPPER_ASSIGNMENTS contains '__module__' — module origin is propagated by update_wrapper; verified with Python 3.14.3"]
    - [wa_qualname,  WRAPPER_ASSIGNMENTS.__contains__,         ["__qualname__"],   true,  "functools.WRAPPER_ASSIGNMENTS contains '__qualname__' — qualified name is propagated by update_wrapper; verified with Python 3.14.3"]
    - [wa_doc,       WRAPPER_ASSIGNMENTS.__contains__,         ["__doc__"],        true,  "functools.WRAPPER_ASSIGNMENTS contains '__doc__' — docstring is propagated by update_wrapper; verified with Python 3.14.3"]
    - [wu_dict,      WRAPPER_UPDATES.__contains__,             ["__dict__"],       true,  "functools.WRAPPER_UPDATES contains '__dict__' — __dict__ is merged (updated) not replaced; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra281
# ---------------------------------------------------------------------------

invariant functools_extra281.update_wrapper_is_function:
  description: "functools.update_wrapper.__class__.__name__ == 'function' — update_wrapper is a pure-Python function, not a C builtin"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra281.update_wrapper_module_is_functools:
  description: "functools.update_wrapper.__module__ == 'functools' — update_wrapper is defined directly in the functools module"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra281.update_wrapper_name_length_is_14:
  description: "functools.update_wrapper.__name__.__len__() == 14 — 'update_wrapper' has 14 characters"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__name__.__len__
  args: []
  expected: 14

invariant functools_extra281.update_wrapper_qualname_matches_name:
  description: "functools.update_wrapper.__qualname__ == 'update_wrapper' — qualname and name are identical (top-level function)"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__qualname__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra281.update_wrapper_has_docstring:
  description: "functools.update_wrapper.__doc__.__eq__(None) == False — update_wrapper has a non-None docstring"
  category: behavior
  kind: python_call_eq
  function: update_wrapper.__doc__.__eq__
  args: [null]
  expected: false

invariant functools_extra281.wrapper_assignments_contains_qualname:
  description: "functools.WRAPPER_ASSIGNMENTS contains '__qualname__' — qualified name is copied from wrapped function to wrapper"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__qualname__"]
  expected: true

invariant functools_extra281.wrapper_assignments_contains_doc:
  description: "functools.WRAPPER_ASSIGNMENTS contains '__doc__' — the docstring is propagated from wrapped to wrapper by update_wrapper"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__doc__"]
  expected: true

invariant functools_extra281.wrapper_updates_contains_dict:
  description: "functools.WRAPPER_UPDATES contains '__dict__' — __dict__ is the only attribute merged (not replaced) by update_wrapper"
  category: constants
  kind: python_call_eq
  function: WRAPPER_UPDATES.__contains__
  args: ["__dict__"]
  expected: true
