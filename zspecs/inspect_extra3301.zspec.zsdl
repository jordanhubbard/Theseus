spec: in3301
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 667 (in3301): __itruediv__, __ifloordiv__, __imod__ dict-presence checks for inspect types."
    - "Theme: __itruediv__/__ifloordiv__/__imod__ in-place division/modulo dict-presence."
    - "In-place augmented assignment operators (/=, //=, %=) fall back to __truediv__/__floordiv__/__mod__ if not defined."
    - "All values False — callable/iterator/inspection/synchronization types have no in-place division/modulo operators."
    - "No inspect type defines __itruediv__, __ifloordiv__, or __imod__ in its own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "None of these types implement in-place division/modulo protocols directly."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3301.itruediv:
  description: "inspect types __itruediv__ dict-presence checks; wave 667"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3301
  columns: [id, function, args, expected]
  rows:
    - ["in3301001", operator.contains, [inspect.Parameter.__dict__,           "__itruediv__"], false]
    - ["in3301002", operator.contains, [inspect.Signature.__dict__,           "__itruediv__"], false]
    - ["in3301003", operator.contains, [inspect.BoundArguments.__dict__,      "__itruediv__"], false]
    - ["in3301004", operator.contains, [inspect.FrameInfo.__dict__,           "__itruediv__"], false]
    - ["in3301005", operator.contains, [inspect.ArgInfo.__dict__,             "__itruediv__"], false]
    - ["in3301006", operator.contains, [inspect.FullArgSpec.__dict__,         "__itruediv__"], false]
    - ["in3301007", operator.contains, [inspect.Attribute.__dict__,           "__itruediv__"], false]
    - ["in3301008", operator.contains, [inspect.ClassFoundException.__dict__, "__itruediv__"], false]
    - ["in3301009", operator.contains, [inspect.EndOfBlock.__dict__,          "__itruediv__"], false]

