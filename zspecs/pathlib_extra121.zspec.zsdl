spec: pathlib_extra121
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec extends pathlib_extra120.zspec.zsdl."
    - "This spec covers: pathlib.PurePosixPath and pathlib.PureWindowsPath MRO slot names via double-quoted bracket-path notation."
    - "PurePosixPath.__mro__ has 3 entries: (PurePosixPath, PurePath, object)."
    - "PureWindowsPath.__mro__ has 3 entries: (PureWindowsPath, PurePath, object)."
    - "Both classes inherit directly from PurePath; their MRO slot 1 is the same PurePath object."
    - "pathlib_extra112 covered __name__, __module__, __bases__[0].__name__, __mro__.__len__() for PurePosixPath and PureWindowsPath."
    - "pathlib_extra108/109 covered __qualname__ lengths and __module__ lengths for both classes."
    - "This spec is the first to index into individual MRO slots for PurePosixPath and PureWindowsPath."
    - "PurePosixPath.__name__ has length 13; PureWindowsPath.__name__ has length 15 (2 chars longer)."
    - "Both have metaclass 'type' (plain Python class, not ABCMeta)."
    - "MRO slot 1 for both is 'PurePath' (length 8); MRO slot 2 for both is 'object' (length 6)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath MRO slot names
# PurePosixPath.__mro__ == (PurePosixPath, PurePath, object) — 3 entries.
# PurePosixPath is a pure path class for POSIX (Unix/Linux/macOS) path semantics.
# It inherits directly from PurePath, which is the abstract base for all pathlib
# pure path types.  PurePosixPath has no abstract base layer — its MRO is a
# simple 3-entry chain.
# pathlib_extra112 covered __mro__.__len__()==3 and __bases__[0].__name__=='PurePath';
# no spec has previously indexed into individual MRO slots by bracket notation.
# ---------------------------------------------------------------------------

table pathlib_extra121.PurePosixPath_mro_slot_names:
  description: "pathlib.PurePosixPath.__mro__ slot names: [0]='PurePosixPath',[1]='PurePath',[2]='object'; 3-entry MRO; PurePath is the abstract base for all pure paths; POSIX-flavour semantics (case-sensitive, forward-slash separator)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: pathlibppp121a

  columns: [id, function, args, expected, description]
  rows:
    - [ppp_mro0_name,  "PurePosixPath.__mro__[0].__name__.__eq__",  ["PurePosixPath"],  true,  "pathlib.PurePosixPath.__mro__[0].__name__ == 'PurePosixPath' (class is first in its own MRO; POSIX-flavour pure path type)"]
    - [ppp_mro1_name,  "PurePosixPath.__mro__[1].__name__.__eq__",  ["PurePath"],       true,  "pathlib.PurePosixPath.__mro__[1].__name__ == 'PurePath' (direct parent; abstract base for all pure path types)"]
    - [ppp_mro2_name,  "PurePosixPath.__mro__[2].__name__.__eq__",  ["object"],         true,  "pathlib.PurePosixPath.__mro__[2].__name__ == 'object' (universal Python base class terminates the 3-entry MRO)"]
    - [ppp_mro1_ne_0,  "PurePosixPath.__mro__[1].__name__.__eq__",  ["PurePosixPath"],  false, "pathlib.PurePosixPath.__mro__[1].__name__ != 'PurePosixPath' (slot 1 is the parent 'PurePath', not the class itself)"]
    - [ppp_mro2_ne_1,  "PurePosixPath.__mro__[2].__name__.__eq__",  ["PurePath"],       false, "pathlib.PurePosixPath.__mro__[2].__name__ != 'PurePath' (slot 2 is 'object', not 'PurePath')"]
    - [ppp_type_name,  "PurePosixPath.__class__.__name__.__eq__",   ["type"],           true,  "type(pathlib.PurePosixPath).__name__ == 'type' (plain Python class; no ABCMeta or custom metaclass)"]
    - [ppp_mro1_len,   "PurePosixPath.__mro__[1].__name__.__len__", [],                 8,     "pathlib.PurePosixPath.__mro__[1].__name__.__len__() == 8 ('PurePath' has 8 characters)"]

# ---------------------------------------------------------------------------
# pathlib.PureWindowsPath MRO slot names
# PureWindowsPath.__mro__ == (PureWindowsPath, PurePath, object) — 3 entries.
# PureWindowsPath is a pure path class for Windows path semantics (case-insensitive,
# backslash separator).  Its MRO slot 1 is the same PurePath object as
# PurePosixPath.__mro__[1] — both concrete pure path classes share PurePath.
# No prior spec has indexed into individual MRO slots for PureWindowsPath.
# ---------------------------------------------------------------------------

table pathlib_extra121.PureWindowsPath_mro_slot_names:
  description: "pathlib.PureWindowsPath.__mro__ slot names: [0]='PureWindowsPath',[1]='PurePath',[2]='object'; 3-entry MRO; same PurePath base as PurePosixPath at slot 1; Windows-flavour semantics (case-insensitive, backslash separator)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: pathlibpwp121b

  columns: [id, function, args, expected, description]
  rows:
    - [pwp_mro0_name,  "PureWindowsPath.__mro__[0].__name__.__eq__",  ["PureWindowsPath"],  true,  "pathlib.PureWindowsPath.__mro__[0].__name__ == 'PureWindowsPath' (class is first in its own MRO; Windows-flavour pure path type)"]
    - [pwp_mro1_name,  "PureWindowsPath.__mro__[1].__name__.__eq__",  ["PurePath"],         true,  "pathlib.PureWindowsPath.__mro__[1].__name__ == 'PurePath' (direct parent; same PurePath object as PurePosixPath.__mro__[1])"]
    - [pwp_mro2_name,  "PureWindowsPath.__mro__[2].__name__.__eq__",  ["object"],           true,  "pathlib.PureWindowsPath.__mro__[2].__name__ == 'object' (universal Python base class terminates the 3-entry MRO)"]
    - [pwp_mro1_ne_0,  "PureWindowsPath.__mro__[1].__name__.__eq__",  ["PureWindowsPath"],  false, "pathlib.PureWindowsPath.__mro__[1].__name__ != 'PureWindowsPath' (slot 1 is the parent 'PurePath', not the class itself)"]
    - [pwp_type_name,  "PureWindowsPath.__class__.__name__.__eq__",   ["type"],             true,  "type(pathlib.PureWindowsPath).__name__ == 'type' (plain Python class; no ABCMeta or custom metaclass)"]
    - [pwp_mro1_len,   "PureWindowsPath.__mro__[1].__name__.__len__", [],                   8,     "pathlib.PureWindowsPath.__mro__[1].__name__.__len__() == 8 ('PurePath' has 8 chars; same as PurePosixPath.__mro__[1].__name__.__len__())"]
    - [pwp_mro1_eq_ppp, "PureWindowsPath.__mro__[1].__name__.__eq__", ["PurePath"],         true,  "pathlib.PureWindowsPath.__mro__[1].__name__ == 'PurePath' == pathlib.PurePosixPath.__mro__[1].__name__ (both share the same PurePath base)"]

# ---------------------------------------------------------------------------
# PurePosixPath and PureWindowsPath name lengths and cross-comparisons
# PurePosixPath.__name__ has 13 chars; PureWindowsPath.__name__ has 15 chars.
# Both have MRO slot 1 == 'PurePath' (8 chars) and slot 2 == 'object' (6 chars).
# Both have metaclass 'type' and __module__ == 'pathlib'.
# The two classes differ only at MRO slot 0 (their own names).
# ---------------------------------------------------------------------------

table pathlib_extra121.PurePosixPath_PureWindowsPath_name_lengths_and_metaclass:
  description: "pathlib.PurePosixPath.__name__ len=13; PureWindowsPath.__name__ len=15; both MRO slot 1 is 'PurePath'(8); both metaclass 'type'; PureWindowsPath is 2 chars longer than PurePosixPath"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: pathlibpure121c

  columns: [id, function, args, expected, description]
  rows:
    - [ppp_name_len,   "PurePosixPath.__name__.__len__",                         [],     13,    "pathlib.PurePosixPath.__name__.__len__() == 13 ('PurePosixPath' has 13 characters: 'Pure'(4)+'Posix'(5)+'Path'(4)==13)"]
    - [pwp_name_len,   "PureWindowsPath.__name__.__len__",                       [],     15,    "pathlib.PureWindowsPath.__name__.__len__() == 15 ('PureWindowsPath' has 15 characters: 'Pure'(4)+'Windows'(7)+'Path'(4)==15)"]
    - [pwp_gt_ppp,     "PureWindowsPath.__name__.__len__.__gt__",                [13],   true,  "len('PureWindowsPath') > len('PurePosixPath') (15 > 13; PureWindowsPath is 2 chars longer due to 'Windows' vs 'Posix')"]
    - [ppp_ne_pwp,     "PurePosixPath.__name__.__eq__",                          ["PureWindowsPath"], false, "pathlib.PurePosixPath.__name__ != 'PureWindowsPath' (distinct names; Posix vs Windows path semantics)"]
    - [ppp_mro1_8,     "PurePosixPath.__mro__[1].__name__.__len__.__eq__",       [8],    true,  "len(pathlib.PurePosixPath.__mro__[1].__name__) == 8 ('PurePath' is 8 chars; slot 1 for both PurePosixPath and PureWindowsPath)"]
    - [pwp_mro1_8,     "PureWindowsPath.__mro__[1].__name__.__len__.__eq__",     [8],    true,  "len(pathlib.PureWindowsPath.__mro__[1].__name__) == 8 ('PurePath' is 8 chars; PurePosixPath and PureWindowsPath share the same PurePath base)"]
    - [ppp_class_type, "PurePosixPath.__class__.__name__.__eq__",                ["type"], true, "type(pathlib.PurePosixPath).__name__ == 'type' (plain Python class created with ordinary 'type' metaclass)"]
    - [pwp_class_type, "PureWindowsPath.__class__.__name__.__eq__",              ["type"], true, "type(pathlib.PureWindowsPath).__name__ == 'type' (plain Python class created with ordinary 'type' metaclass like PurePosixPath)"]
    - [ppp_mro1_eq_pwp_mro1, "PurePosixPath.__mro__[1].__name__.__eq__",        ["PurePath"], true, "pathlib.PurePosixPath.__mro__[1].__name__ == pathlib.PureWindowsPath.__mro__[1].__name__ == 'PurePath' (both concrete pure paths share PurePath as their sole direct parent)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra121.PurePosixPath.mro_slot1_is_PurePath:
  description: "pathlib.PurePosixPath.__mro__[1].__name__ == 'PurePath' (length 8; PurePosixPath is a concrete pure path class for POSIX path semantics: case-sensitive comparisons and forward-slash separator; its MRO is (PurePosixPath, PurePath, object) — a simple 3-entry chain with no intermediate abstract base; pathlib_extra112 covered __mro__.__len__()==3 and __bases__[0].__name__=='PurePath'; this spec is the first to index into individual MRO slots via double-quoted bracket-path notation for PurePosixPath)"
  category: class_hierarchy
  kind: python_call_eq
  function: "PurePosixPath.__mro__[1].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra121.PureWindowsPath.mro_slot1_is_PurePath:
  description: "pathlib.PureWindowsPath.__mro__[1].__name__ == 'PurePath' (length 8; PureWindowsPath is a concrete pure path class for Windows path semantics: case-insensitive comparisons and backslash separator; its MRO is (PureWindowsPath, PurePath, object) — a 3-entry chain identical in structure to PurePosixPath.__mro__ except for slot 0; both PurePosixPath and PureWindowsPath share the same PurePath object at MRO slot 1; pathlib_extra112 covered __mro__.__len__()==3 for PureWindowsPath but not the individual slot names)"
  category: class_hierarchy
  kind: python_call_eq
  function: "PureWindowsPath.__mro__[1].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra121.PurePosixPath.mro_slot2_is_object:
  description: "pathlib.PurePosixPath.__mro__[2].__name__ == 'object' (length 6; the universal Python base class terminates the 3-entry PurePosixPath MRO; all pathlib pure path types ultimately trace back to object at the end of their MRO; PurePosixPath has the shortest MRO of any pathlib class (3 entries) because it is a leaf class in the pure path hierarchy: PurePosixPath -> PurePath -> object; concrete path types like PosixPath have longer MROs — 5 entries)"
  category: class_hierarchy
  kind: python_call_eq
  function: "PurePosixPath.__mro__[2].__name__.__eq__"
  args: ["object"]
  expected: true

invariant pathlib_extra121.PureWindowsPath.mro_slot2_is_object:
  description: "pathlib.PureWindowsPath.__mro__[2].__name__ == 'object' (length 6; same terminal base as PurePosixPath.__mro__[2]; PureWindowsPath has the same 3-entry MRO structure as PurePosixPath; both share identical MRO slots 1 and 2 — only slot 0 differs between them; PureWindowsPath inherits all pure path operations from PurePath and applies Windows-flavour parsing rules when parsing path strings)"
  category: class_hierarchy
  kind: python_call_eq
  function: "PureWindowsPath.__mro__[2].__name__.__eq__"
  args: ["object"]
  expected: true

invariant pathlib_extra121.PureWindowsPath.name_longer_than_PurePosixPath:
  description: "pathlib.PureWindowsPath.__name__.__len__() == 15 > 13 == pathlib.PurePosixPath.__name__.__len__() (PureWindowsPath is 2 characters longer than PurePosixPath because 'Windows' is 7 chars while 'Posix' is 5 chars; both share the 'Pure'(4) prefix and 'Path'(4) suffix; pathlib_extra109 covered these lengths individually; this spec cross-compares them via the __gt__ inequality in a table row and as a standalone invariant)"
  category: class_hierarchy
  kind: python_call_eq
  function: "PureWindowsPath.__name__.__len__.__gt__"
  args: [13]
  expected: true
