spec: decimal_extra223
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal additional arithmetic behavioral contracts — __add__, __sub__, __mul__, __truediv__, __mod__, __pow__, copy_abs, copy_negate, to_integral_value."
    - "Integer operands are used for method_args since Decimal constructors cannot be serialised as JSON; Decimal accepts int operands for all arithmetic operators."
    - "Decimal('1').__add__(2) == '3' — str(Decimal(1) + 2); verified Python 3.14.3 macOS."
    - "Decimal('10').__sub__(3) == '7' — str(Decimal(10) - 3); verified Python 3.14.3 macOS."
    - "Decimal('4').__mul__(3) == '12' — str(Decimal(4) * 3); verified Python 3.14.3 macOS."
    - "Decimal('10').__truediv__(4) == '2.5' — str(Decimal(10) / 4); verified Python 3.14.3 macOS."
    - "Decimal('7').__mod__(3) == '1' — str(Decimal(7) % 3); verified Python 3.14.3 macOS."
    - "Decimal('2').__pow__(10) == '1024' — str(Decimal(2) ** 10); verified Python 3.14.3 macOS."
    - "Decimal('-5').copy_abs() == '5' — absolute value copy; sign is positive; verified Python 3.14.3 macOS."
    - "Decimal('5').copy_negate() == '-5' — negated copy; sign is flipped; verified Python 3.14.3 macOS."
    - "Decimal('3.7').to_integral_value() == '4' — rounds 3.7 to nearest integer; ROUND_HALF_EVEN default rounds up since 0.7 > 0.5; verified Python 3.14.3 macOS."
    - "Decimal('3.5').to_integral_value() == '4' — banker's rounding: 3.5 rounds to 4 (nearest even integer); verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal binary arithmetic behavioral contracts
# Integer operands used (Decimal accepts int for all arithmetic).
# All results verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra223.Decimal.add_1_plus_2:
  description: "decimal.Decimal('1').__add__(2) == Decimal('3') — str result '3'; integer operand 2 used; Decimal accepts int for __add__; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: __add__
  method_args: [2]
  method_chain: __str__
  expected: "3"

invariant decimal_extra223.Decimal.sub_10_minus_3:
  description: "decimal.Decimal('10').__sub__(3) == Decimal('7') — str result '7'; integer operand 3 used; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["10"]
  method: __sub__
  method_args: [3]
  method_chain: __str__
  expected: "7"

invariant decimal_extra223.Decimal.mul_4_times_3:
  description: "decimal.Decimal('4').__mul__(3) == Decimal('12') — str result '12'; integer operand 3 used; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["4"]
  method: __mul__
  method_args: [3]
  method_chain: __str__
  expected: "12"

invariant decimal_extra223.Decimal.truediv_10_div_4:
  description: "decimal.Decimal('10').__truediv__(4) == Decimal('2.5') — str result '2.5'; integer operand 4 used; exact division with decimal result; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["10"]
  method: __truediv__
  method_args: [4]
  method_chain: __str__
  expected: "2.5"

invariant decimal_extra223.Decimal.mod_7_rem_3:
  description: "decimal.Decimal('7').__mod__(3) == Decimal('1') — str result '1'; 7 = 2*3 + 1 so 7 mod 3 == 1; integer operand 3 used; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["7"]
  method: __mod__
  method_args: [3]
  method_chain: __str__
  expected: "1"

invariant decimal_extra223.Decimal.pow_2_exp_10:
  description: "decimal.Decimal('2').__pow__(10) == Decimal('1024') — str result '1024'; 2**10 == 1024; integer operand 10 used; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["2"]
  method: __pow__
  method_args: [10]
  method_chain: __str__
  expected: "1024"

# ---------------------------------------------------------------------------
# decimal.Decimal unary method behavioral contracts: copy_abs, copy_negate
# copy_abs() returns a copy with positive sign.
# copy_negate() returns a copy with flipped sign.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra223.Decimal.copy_abs_neg5:
  description: "decimal.Decimal('-5').copy_abs() == Decimal('5') — copy_abs returns a copy with the absolute value (positive sign); str result '5'; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["-5"]
  method: copy_abs
  method_args: []
  method_chain: __str__
  expected: "5"

invariant decimal_extra223.Decimal.copy_negate_5:
  description: "decimal.Decimal('5').copy_negate() == Decimal('-5') — copy_negate returns a copy with the sign flipped; str result '-5'; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["5"]
  method: copy_negate
  method_args: []
  method_chain: __str__
  expected: "-5"

# ---------------------------------------------------------------------------
# decimal.Decimal.to_integral_value() behavioral contracts
# Default rounding mode is ROUND_HALF_EVEN (banker's rounding).
# 3.7 -> 4 (rounds up since 0.7 > 0.5).
# 3.5 -> 4 (banker's rounding: 3.5 rounds to nearest even, which is 4).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra223.Decimal.to_integral_3_7:
  description: "decimal.Decimal('3.7').to_integral_value() == Decimal('4') — str result '4'; 3.7 rounds up to 4 since 0.7 > 0.5 under ROUND_HALF_EVEN; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["3.7"]
  method: to_integral_value
  method_args: []
  method_chain: __str__
  expected: "4"

invariant decimal_extra223.Decimal.to_integral_3_5:
  description: "decimal.Decimal('3.5').to_integral_value() == Decimal('4') — str result '4'; banker's rounding ROUND_HALF_EVEN: 3.5 is exactly halfway between 3 and 4; nearest even integer is 4; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["3.5"]
  method: to_integral_value
  method_args: []
  method_chain: __str__
  expected: "4"
