# ---------------------------------------------------------------------------
# Table 3: multiprocessing.pool.Pool.imap and imap_unordered __name__ identity
#
# multiprocessing.pool.Pool.imap.__name__ == 'imap' (len=4)
# multiprocessing.pool.Pool.imap_unordered.__name__ == 'imap_unordered' (len=14)
#
# imap() is a lazy version of map() — returns an iterator rather than a list.
# imap_unordered() is similar but results may be in any order (faster for
# heterogeneous workloads). NAME LENGTHS: imap=4 < imap_unordered=14.
# New to extra176.
# ---------------------------------------------------------------------------

