spec: unicodedata_extra19
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends unicodedata.zspec.zsdl through unicodedata_extra18.zspec.zsdl."
    - "unicodedata_extra16 covers: module-level lookup/name/decimal/digit/numeric/category/normalize/bidirectional __qualname__ attributes (all flat, e.g. 'lookup')."
    - "unicodedata_extra17 covers: combining/east_asian_width/mirrored/decomposition/is_normalized __qualname__ attributes."
    - "unicodedata_extra18 covers: UCD.__qualname__=='UCD'; unidata_version.__len__()==6; ucd_3_2_0.unidata_version=='3.2.0'."
    - "No prior spec verifies ucd_3_2_0.__class__.__module__ as a standalone invariant."
    - "No prior spec verifies ucd_3_2_0 method __qualname__ attributes (which carry the 'UCD.' prefix, unlike module-level function qualnames)."
    - "The module-level unicodedata functions are C builtins whose __qualname__ equals their simple name (e.g. 'lookup'). The ucd_3_2_0 instance methods are bound methods of the UCD class; their __qualname__ takes the form 'UCD.<name>'."
    - "unicodedata.ucd_3_2_0.__class__.__module__ == 'unicodedata' — the UCD class is defined in the unicodedata C extension. Verified at runtime."
    - "unicodedata.ucd_3_2_0.lookup.__qualname__ == 'UCD.lookup' — bound method qualname includes owning class. Verified at runtime."
    - "unicodedata.ucd_3_2_0.name.__qualname__ == 'UCD.name' — bound method qualname includes owning class. Verified at runtime."
    - "unicodedata.ucd_3_2_0.category.__qualname__ == 'UCD.category' — bound method qualname includes owning class. Verified at runtime."
    - "unicodedata.ucd_3_2_0.normalize.__qualname__ == 'UCD.normalize' — bound method qualname includes owning class. Verified at runtime."
    - "unicodedata.ucd_3_2_0.bidirectional.__qualname__ == 'UCD.bidirectional' — bound method qualname includes owning class. Verified at runtime."
    - "unicodedata.ucd_3_2_0.combining.__qualname__ == 'UCD.combining' — bound method qualname includes owning class. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ucd_3_2_0.__class__.__module__
#
# unicodedata_extra3 covers ucd_3_2_0.__class__.__name__ == 'UCD'.
# unicodedata_extra18 covers UCD.__qualname__ == 'UCD'.
# No prior spec verifies ucd_3_2_0.__class__.__module__ as a standalone invariant.
# The UCD class is defined in the unicodedata C extension module.
# Verified: ucd_3_2_0.__class__.__module__ == 'unicodedata'.
# ---------------------------------------------------------------------------

invariant unicodedata_extra19.ucd_3_2_0.class_module:
  description: "unicodedata.ucd_3_2_0.__class__.__module__ == 'unicodedata' — UCD class defined in unicodedata module"
  category: function_identity
  kind: python_call_eq
  function: ucd_3_2_0.__class__.__module__.__eq__
  args: ["unicodedata"]
  expected: true

# ---------------------------------------------------------------------------
# ucd_3_2_0 method __qualname__ attributes
#
# unicodedata_extra16 covers module-level function __qualname__ values (e.g.
# lookup.__qualname__ == 'lookup'). The ucd_3_2_0 instance methods are bound
# methods of the UCD class; their __qualname__ includes the 'UCD.' prefix.
# No prior spec verifies any ucd_3_2_0 method __qualname__ as a standalone.
# All verified at runtime.
# ---------------------------------------------------------------------------

invariant unicodedata_extra19.ucd_3_2_0.lookup_qualname:
  description: "unicodedata.ucd_3_2_0.lookup.__qualname__ == 'UCD.lookup' — UCD bound method qualname includes class prefix"
  category: function_identity
  kind: python_call_eq
  function: ucd_3_2_0.lookup.__qualname__.__eq__
  args: ["UCD.lookup"]
  expected: true

invariant unicodedata_extra19.ucd_3_2_0.name_qualname:
  description: "unicodedata.ucd_3_2_0.name.__qualname__ == 'UCD.name' — UCD bound method qualname includes class prefix"
  category: function_identity
  kind: python_call_eq
  function: ucd_3_2_0.name.__qualname__.__eq__
  args: ["UCD.name"]
  expected: true

invariant unicodedata_extra19.ucd_3_2_0.category_qualname:
  description: "unicodedata.ucd_3_2_0.category.__qualname__ == 'UCD.category' — UCD bound method qualname includes class prefix"
  category: function_identity
  kind: python_call_eq
  function: ucd_3_2_0.category.__qualname__.__eq__
  args: ["UCD.category"]
  expected: true

invariant unicodedata_extra19.ucd_3_2_0.normalize_qualname:
  description: "unicodedata.ucd_3_2_0.normalize.__qualname__ == 'UCD.normalize' — UCD bound method qualname includes class prefix"
  category: function_identity
  kind: python_call_eq
  function: ucd_3_2_0.normalize.__qualname__.__eq__
  args: ["UCD.normalize"]
  expected: true

invariant unicodedata_extra19.ucd_3_2_0.bidirectional_qualname:
  description: "unicodedata.ucd_3_2_0.bidirectional.__qualname__ == 'UCD.bidirectional' — UCD bound method qualname includes class prefix"
  category: function_identity
  kind: python_call_eq
  function: ucd_3_2_0.bidirectional.__qualname__.__eq__
  args: ["UCD.bidirectional"]
  expected: true

invariant unicodedata_extra19.ucd_3_2_0.combining_qualname:
  description: "unicodedata.ucd_3_2_0.combining.__qualname__ == 'UCD.combining' — UCD bound method qualname includes class prefix"
  category: function_identity
  kind: python_call_eq
  function: ucd_3_2_0.combining.__qualname__.__eq__
  args: ["UCD.combining"]
  expected: true

# ---------------------------------------------------------------------------
# Table: ucd_3_2_0 method __qualname__ attributes
#
# Groups the six ucd_3_2_0 method qualname checks in one indexed table.
# No prior table covers ucd_3_2_0 method qualnames. The 'UCD.' prefix
# distinguishes these from the flat module-level function qualnames covered
# in unicodedata_extra16.
# All verified at runtime.
# ---------------------------------------------------------------------------

table unicodedata_extra19.ucd_3_2_0_method_qualnames:
  description: "unicodedata.ucd_3_2_0 UCD bound-method __qualname__ attributes — all carry 'UCD.' class prefix"
  kind: python_call_eq
  category: function_identity
  id_prefix: ud19mq

  columns: [id, function, args, expected]
  rows:
    - [lookup,       ucd_3_2_0.lookup.__qualname__.__eq__,       ["UCD.lookup"],       true]
    - [name,         ucd_3_2_0.name.__qualname__.__eq__,         ["UCD.name"],         true]
    - [category,     ucd_3_2_0.category.__qualname__.__eq__,     ["UCD.category"],     true]
    - [normalize,    ucd_3_2_0.normalize.__qualname__.__eq__,    ["UCD.normalize"],    true]
    - [bidirectional, ucd_3_2_0.bidirectional.__qualname__.__eq__, ["UCD.bidirectional"], true]
    - [combining,    ucd_3_2_0.combining.__qualname__.__eq__,    ["UCD.combining"],    true]
