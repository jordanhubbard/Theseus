spec: pathlib_extra1036
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module PurePath, PurePosixPath, PureWindowsPath documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks pathlib.PurePath and related class attribute descriptor class names"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1036.purepath_attr_descriptors:
  description: "pathlib.PurePath attribute descriptor class name checks"
  kind: python_call_eq
  category: purepath_attr_descriptors
  id_prefix: pl1036pp
  columns: [id, function, args, expected]
  rows:
    - [pl1036pp001, pathlib.PurePath.drive.__class__.__name__.__eq__,    ["property"], true]
    - [pl1036pp002, pathlib.PurePath.root.__class__.__name__.__eq__,     ["property"], true]
    - [pl1036pp003, pathlib.PurePath.anchor.__class__.__name__.__eq__,   ["property"], true]
    - [pl1036pp004, pathlib.PurePath.name.__class__.__name__.__eq__,     ["property"], true]
    - [pl1036pp005, pathlib.PurePath.suffix.__class__.__name__.__eq__,   ["property"], true]
    - [pl1036pp006, pathlib.PurePath.suffixes.__class__.__name__.__eq__, ["property"], true]
    - [pl1036pp007, pathlib.PurePath.stem.__class__.__name__.__eq__,     ["property"], true]
    - [pl1036pp008, pathlib.PurePath.parent.__class__.__name__.__eq__,   ["property"], true]
    - [pl1036pp009, pathlib.PurePath.parents.__class__.__name__.__eq__,  ["property"], true]

table pathlib_extra1036.purepath_class_identity:
  description: "pathlib.PurePath and subclass identity checks"
  kind: python_call_eq
  category: purepath_class_identity
  id_prefix: pl1036ci
  columns: [id, function, args, expected]
  rows:
    - [pl1036ci001, pathlib.PurePath.__name__.__eq__,             ["PurePath"],            true]
    - [pl1036ci002, pathlib.PurePosixPath.__name__.__eq__,        ["PurePosixPath"],       true]
    - [pl1036ci003, pathlib.PureWindowsPath.__name__.__eq__,      ["PureWindowsPath"],     true]
    - [pl1036ci004, pathlib.PurePath.__module__.__eq__,           ["pathlib"],             true]
    - [pl1036ci005, pathlib.PurePosixPath.__module__.__eq__,      ["pathlib"],             true]
    - [pl1036ci006, pathlib.PureWindowsPath.__module__.__eq__,    ["pathlib"],             true]
    - [pl1036ci007, pathlib.PurePath.__doc__.__class__.__name__.__eq__, ["str"],           true]

table pathlib_extra1036.purepath_parts_descriptor:
  description: "pathlib.PurePath parts property and method descriptor checks"
  kind: python_call_eq
  category: purepath_parts_descriptor
  id_prefix: pl1036pd
  columns: [id, function, args, expected]
  rows:
    - [pl1036pd001, pathlib.PurePath.parts.__class__.__name__.__eq__,     ["property"], true]
    - [pl1036pd002, pathlib.PurePath.__class__.__name__.__eq__,           ["type"],     true]
    - [pl1036pd003, pathlib.PurePosixPath.drive.__class__.__name__.__eq__,  ["property"], true]
    - [pl1036pd004, pathlib.PurePosixPath.root.__class__.__name__.__eq__,   ["property"], true]
    - [pl1036pd005, pathlib.PurePosixPath.name.__class__.__name__.__eq__,   ["property"], true]
    - [pl1036pd006, pathlib.PureWindowsPath.drive.__class__.__name__.__eq__, ["property"], true]
    - [pl1036pd007, pathlib.PureWindowsPath.name.__class__.__name__.__eq__,  ["property"], true]
