spec: pathlib_extra2101
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2101 (pathlib_extra2101): __class_getitem__, __init_subclass__, __subclasshook__, __mro_entries__ dict-presence checks."
    - "pathlib.PurePath is the base for all path classes; pathlib.Path is the concrete cross-platform class."
    - "pathlib.PurePosixPath and pathlib.PureWindowsPath are pure (non-I/O) posix and windows variants."
    - "None of the pathlib path classes define __class_getitem__ in their own __dict__ — subscript generic alias syntax is not supported."
    - "None define __init_subclass__ in their own __dict__ — the hook is inherited from object."
    - "None define __subclasshook__ in their own __dict__ — no ABC virtual subclass customization."
    - "None define __mro_entries__ in their own __dict__ — MRO resolution protocol is absent."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table pathlib_extra2101.class_getitem_protocol:
  description: "pathlib path classes __class_getitem__ dict-presence checks — generic alias protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2101

  columns: [id, function, args, expected]
  rows:
    - ["pl2101001", "pathlib.PurePath.__dict__.__contains__", ["__class_getitem__"], false]
    - ["pl2101002", "pathlib.PurePosixPath.__dict__.__contains__", ["__class_getitem__"], false]
    - ["pl2101003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__class_getitem__"], false]
    - ["pl2101004", "pathlib.Path.__dict__.__contains__", ["__class_getitem__"], false]

