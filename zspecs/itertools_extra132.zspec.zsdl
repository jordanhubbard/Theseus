    - "itertools.takewhile.__iter__.__qualname__ == 'takewhile.__iter__' (len 18) — slot method on C type. Verified with Python 3.14.3."
    - "itertools.takewhile.__next__.__qualname__ == 'takewhile.__next__' (len 18) — slot method on C type. Verified with Python 3.14.3."
    - "itertools.takewhile.__new__.__qualname__ == 'takewhile.__new__' (len 17) — slot method on C type. Verified with Python 3.14.3."
    - "itertools.filterfalse.__name__ == 'filterfalse' — C extension type defined in Modules/itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.filterfalse.__iter__.__qualname__ == 'filterfalse.__iter__' (len 20) — slot method on C type. Verified with Python 3.14.3."
    - "itertools.filterfalse.__next__.__qualname__ == 'filterfalse.__next__' (len 20) — slot method on C type. Verified with Python 3.14.3."
    - "itertools.filterfalse.__new__.__qualname__ == 'filterfalse.__new__' (len 19) — slot method on C type. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.takewhile __name__ and slot qualnames
#
# Wave 257 theme: itertools.takewhile C-type slot method qualnames.
#
# itertools.takewhile.__name__ == 'takewhile'
# itertools.takewhile.__iter__.__qualname__ == 'takewhile.__iter__' (len 18)
# itertools.takewhile.__next__.__qualname__ == 'takewhile.__next__' (len 18)
# itertools.takewhile.__new__.__qualname__ == 'takewhile.__new__' (len 17)
#
# takewhile is a C extension type; its slot methods (__iter__, __next__, __new__)
# have qualnames prefixed with the type name. New to extra132.
# ---------------------------------------------------------------------------

table itertools_extra132.takewhile_slot_qualnames:
  description: "itertools.takewhile __name__ and slot qualnames: __iter__/'takewhile.__iter__' len 18, __next__/'takewhile.__next__' len 18, __new__/'takewhile.__new__' len 17; wave 257; new to extra132"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolstakewhile132

  columns: [id, function, args, expected, description]
  rows:
    - [takewhile_name_eq,
       "takewhile.__name__.__eq__",
       ["takewhile"],
       true,
       "itertools.takewhile.__name__.__eq__('takewhile') == True — takewhile is a C extension type defined in Modules/itertoolsmodule.c; the __name__ attribute is set from the PyTypeObject tp_name field; str.__eq__('takewhile') returns True; new to extra132"]
    - [takewhile_iter_qualname_eq,
       "takewhile.__iter__.__qualname__.__eq__",
       ["takewhile.__iter__"],
       true,
       "itertools.takewhile.__iter__.__qualname__.__eq__('takewhile.__iter__') == True — the __iter__ slot method on C extension types is exposed with a qualname that includes the type name; str.__eq__('takewhile.__iter__') returns True; new to extra132"]
    - [takewhile_iter_qualname_len_eq_18,
       "takewhile.__iter__.__qualname__.__len__",
       [],
       18,
       "itertools.takewhile.__iter__.__qualname__.__len__() == 18 — qualname is 'takewhile.__iter__' which is 18 characters; len('takewhile.__iter__') == 18; new to extra132"]
    - [takewhile_next_qualname_eq,
       "takewhile.__next__.__qualname__.__eq__",
       ["takewhile.__next__"],
       true,
       "itertools.takewhile.__next__.__qualname__.__eq__('takewhile.__next__') == True — the __next__ slot method on the C takewhile type has qualname 'takewhile.__next__'; str.__eq__('takewhile.__next__') returns True; new to extra132"]
    - [takewhile_next_qualname_len_eq_18,
       "takewhile.__next__.__qualname__.__len__",
       [],
       18,
       "itertools.takewhile.__next__.__qualname__.__len__() == 18 — qualname is 'takewhile.__next__' which is 18 characters; len('takewhile.__next__') == 18; new to extra132"]
    - [takewhile_new_qualname_eq,
       "takewhile.__new__.__qualname__.__eq__",
       ["takewhile.__new__"],
       true,
       "itertools.takewhile.__new__.__qualname__.__eq__('takewhile.__new__') == True — the __new__ slot method on the C takewhile type has qualname 'takewhile.__new__'; str.__eq__('takewhile.__new__') returns True; new to extra132"]
    - [takewhile_new_qualname_len_eq_17,
       "takewhile.__new__.__qualname__.__len__",
       [],
       17,
       "itertools.takewhile.__next__.__qualname__.__len__() == 17 — qualname is 'takewhile.__new__' which is 17 characters; len('takewhile.__new__') == 17; new to extra132"]

