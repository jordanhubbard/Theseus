# ---------------------------------------------------------------------------
# Table 3: itertools.takewhile and filterfalse __module__ and __class__.__name__
#
# Wave 257 theme: C-type module identity for takewhile and filterfalse.
#
# itertools.takewhile.__module__ == 'itertools'
# itertools.filterfalse.__module__ == 'itertools'
# itertools.takewhile.__class__.__name__ == 'type'
# itertools.filterfalse.__class__.__name__ == 'type'
#
# Both types are C extension types in Modules/itertoolsmodule.c;
# their __module__ is 'itertools'; their metaclass is 'type'. New to extra132.
# ---------------------------------------------------------------------------

table itertools_extra132.takewhile_filterfalse_module_identity:
  description: "itertools.takewhile and filterfalse __module__=='itertools' and __class__.__name__=='type'; C extension types in itertoolsmodule.c; wave 257; new to extra132"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolstakefalse132

  columns: [id, function, args, expected, description]
  rows:
    - [takewhile_module_eq_itertools,
       "takewhile.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.takewhile.__module__.__eq__('itertools') == True — takewhile is a C extension type defined in Modules/itertoolsmodule.c; its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra132"]
    - [takewhile_class_name_eq_type,
       "takewhile.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.takewhile.__class__.__name__.__eq__('type') == True — takewhile is a C extension type; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra132"]
    - [filterfalse_module_eq_itertools,
       "filterfalse.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.filterfalse.__module__.__eq__('itertools') == True — filterfalse is a C extension type defined in Modules/itertoolsmodule.c; its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra132"]
    - [filterfalse_class_name_eq_type,
       "filterfalse.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.filterfalse.__class__.__name__.__eq__('type') == True — filterfalse is a C extension type; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra132"]

