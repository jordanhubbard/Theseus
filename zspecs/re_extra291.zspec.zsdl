spec: re_extra291
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module reference and RegexFlag enum"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py, Lib/re/_constants.py"
  notes:
    - "re has __all__ (True); re.__package__ is 're' (package, not empty string)"
    - "re.__loader__.__class__.__name__ is 'SourceFileLoader'"
    - "re.RegexFlag.__class__.__name__ is 'EnumType' (Python 3.11+)"
    - "re.RegexFlag.__bases__[0].__name__ is 'IntFlag'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table re_extra291.module_identity:
  description: "re module identity attribute checks"
  kind: python_call_eq
  category: identity
  id_prefix: ree291

  columns: [id, function, args, expected, description]
  rows:
    - [ree291001, re.__name__,                    [], "re",               "module __name__"]
    - [ree291002, re.__package__,                 [], "re",               "module __package__"]
    - [ree291003, re.__spec__.__class__.__name__,   [], "ModuleSpec",       "__spec__ class"]
    - [ree291004, re.__loader__.__class__.__name__, [], "SourceFileLoader", "__loader__ class"]

table re_extra291.all_membership:
  description: "re.__all__ membership checks for key public names"
  kind: python_call_eq
  category: identity
  id_prefix: ree291a

  columns: [id, function, args, expected, description]
  rows:
    - [ree291a001, re.__all__.__class__.__name__, [], "list",     "__all__ is a list"]
    - [ree291a002, re.RegexFlag.__name__,         [], "RegexFlag", "RegexFlag __name__"]
    - [ree291a003, re.RegexFlag.__module__,       [], "re",        "RegexFlag __module__"]

invariant re_extra291.regexflag_bases:
  description: "RegexFlag base class is IntFlag"
  category: identity
  kind: python_call_eq
  function: re.RegexFlag.__bases__[0].__name__
  args: []
  expected: "IntFlag"

invariant re_extra291.regexflag_metaclass:
  description: "RegexFlag metaclass is EnumType"
  category: identity
  kind: python_call_eq
  function: re.RegexFlag.__class__.__name__
  args: []
  expected: "EnumType"

invariant re_extra291.all_has_compile:
  description: "'compile' is in re.__all__"
  category: identity
  kind: python_call_eq
  function: re.__all__.__contains__
  args: ["compile"]
  expected: true

invariant re_extra291.all_has_match:
  description: "'match' is in re.__all__"
  category: identity
  kind: python_call_eq
  function: re.__all__.__contains__
  args: ["match"]
  expected: true

invariant re_extra291.all_has_search:
  description: "'search' is in re.__all__"
  category: identity
  kind: python_call_eq
  function: re.__all__.__contains__
  args: ["search"]
  expected: true

invariant re_extra291.all_has_findall:
  description: "'findall' is in re.__all__"
  category: identity
  kind: python_call_eq
  function: re.__all__.__contains__
  args: ["findall"]
  expected: true

invariant re_extra291.all_has_regexflag:
  description: "'RegexFlag' is in re.__all__"
  category: identity
  kind: python_call_eq
  function: re.__all__.__contains__
  args: ["RegexFlag"]
  expected: true
