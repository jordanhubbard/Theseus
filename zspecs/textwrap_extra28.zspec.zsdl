spec: textwrap_extra28
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap_extra27.zspec.zsdl."
    - "Prior specs covered: TextWrapper __module__/__name__/__qualname__ __len__()==8/11/11, wrap/fill/shorten/dedent/indent __module__.__len__()==8, wrap/fill/shorten/dedent __name__.__len__()==4/4/7/6, TextWrapper.wrap.__qualname__.__len__()==16."
    - "This spec covers: indent.__name__.__len__()==6, wrap/__qualname__.__len__()==4, fill/__qualname__.__len__()==4, dedent/__qualname__.__len__()==6, shorten/__qualname__.__len__()==7, indent/__qualname__.__len__()==6, TextWrapper.fill.__qualname__.__len__()==16, TextWrapper._split.__qualname__.__len__()==18, TextWrapper._wrap_chunks.__qualname__.__len__()==24, TextWrapper._handle_long_word.__qualname__.__len__()==29, TextWrapper._munge_whitespace.__qualname__.__len__()==29."
    - "textwrap.indent.__name__ == 'indent' (len 6). extra27 covers dedent (6) but not indent as standalone; verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "textwrap.wrap.__qualname__ == 'wrap' (len 4). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "textwrap.fill.__qualname__ == 'fill' (len 4). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "textwrap.dedent.__qualname__ == 'dedent' (len 6). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "textwrap.shorten.__qualname__ == 'shorten' (len 7). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "textwrap.indent.__qualname__ == 'indent' (len 6). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "textwrap.TextWrapper.fill.__qualname__ == 'TextWrapper.fill' (len 16). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "textwrap.TextWrapper._split.__qualname__ == 'TextWrapper._split' (len 18). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "textwrap.TextWrapper._wrap_chunks.__qualname__ == 'TextWrapper._wrap_chunks' (len 24). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "textwrap.TextWrapper._handle_long_word.__qualname__ == 'TextWrapper._handle_long_word' (len 29). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "textwrap.TextWrapper._munge_whitespace.__qualname__ == 'TextWrapper._munge_whitespace' (len 29). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# textwrap.indent.__name__.__len__()
#
# indent.__name__ == 'indent', which has length 6.
# extra27 covers dedent.__name__.__len__()==6 as a standalone, but does not
# cover indent.__name__.__len__() explicitly. This is the complementary check.
# ---------------------------------------------------------------------------

invariant textwrap_extra28.indent.name_len:
  description: "len(textwrap.indent.__name__) == 6 — 'indent' has 6 characters"
  category: function_identity
  kind: python_call_eq
  function: indent.__name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Module-level function __qualname__.__len__() checks
#
# For module-level functions __qualname__ == __name__, so these lengths equal
# the function name lengths. No prior spec records __qualname__.__len__() for
# wrap/fill/dedent/shorten/indent as standalones.
# ---------------------------------------------------------------------------

invariant textwrap_extra28.wrap.qualname_len:
  description: "len(textwrap.wrap.__qualname__) == 4 — 'wrap' has 4 characters"
  category: function_identity
  kind: python_call_eq
  function: wrap.__qualname__.__len__
  args: []
  expected: 4

invariant textwrap_extra28.fill.qualname_len:
  description: "len(textwrap.fill.__qualname__) == 4 — 'fill' has 4 characters"
  category: function_identity
  kind: python_call_eq
  function: fill.__qualname__.__len__
  args: []
  expected: 4

invariant textwrap_extra28.dedent.qualname_len:
  description: "len(textwrap.dedent.__qualname__) == 6 — 'dedent' has 6 characters"
  category: function_identity
  kind: python_call_eq
  function: dedent.__qualname__.__len__
  args: []
  expected: 6

invariant textwrap_extra28.shorten.qualname_len:
  description: "len(textwrap.shorten.__qualname__) == 7 — 'shorten' has 7 characters"
  category: function_identity
  kind: python_call_eq
  function: shorten.__qualname__.__len__
  args: []
  expected: 7

invariant textwrap_extra28.indent.qualname_len:
  description: "len(textwrap.indent.__qualname__) == 6 — 'indent' has 6 characters"
  category: function_identity
  kind: python_call_eq
  function: indent.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# TextWrapper method __qualname__.__len__() checks
#
# extra27 covers TextWrapper.wrap.__qualname__.__len__()==16 as a standalone.
# This spec adds fill (16), _split (18), _wrap_chunks (24),
# _handle_long_word (29), and _munge_whitespace (29).
# The format is 'TextWrapper.' (12 chars) + method name.
# ---------------------------------------------------------------------------

invariant textwrap_extra28.TextWrapper.fill.qualname_len:
  description: "len(textwrap.TextWrapper.fill.__qualname__) == 16 — 'TextWrapper.fill' has 16 characters"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.fill.__qualname__.__len__
  args: []
  expected: 16

invariant textwrap_extra28.TextWrapper._split.qualname_len:
  description: "len(textwrap.TextWrapper._split.__qualname__) == 18 — 'TextWrapper._split' has 18 characters"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper._split.__qualname__.__len__
  args: []
  expected: 18

invariant textwrap_extra28.TextWrapper._wrap_chunks.qualname_len:
  description: "len(textwrap.TextWrapper._wrap_chunks.__qualname__) == 24 — 'TextWrapper._wrap_chunks' has 24 characters"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper._wrap_chunks.__qualname__.__len__
  args: []
  expected: 24

invariant textwrap_extra28.TextWrapper._handle_long_word.qualname_len:
  description: "len(textwrap.TextWrapper._handle_long_word.__qualname__) == 29 — 'TextWrapper._handle_long_word' has 29 characters"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper._handle_long_word.__qualname__.__len__
  args: []
  expected: 29

invariant textwrap_extra28.TextWrapper._munge_whitespace.qualname_len:
  description: "len(textwrap.TextWrapper._munge_whitespace.__qualname__) == 29 — 'TextWrapper._munge_whitespace' has 29 characters"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper._munge_whitespace.__qualname__.__len__
  args: []
  expected: 29

# ---------------------------------------------------------------------------
# Table: module-level function __qualname__.__len__() values
#
# No prior spec groups wrap/fill/dedent/shorten/indent __qualname__.__len__()
# into a single table. For module-level functions __qualname__ == __name__.
# ---------------------------------------------------------------------------

table textwrap_extra28.module_function_qualname_lengths:
  description: "textwrap module-level function __qualname__ string lengths — wrap, fill, dedent, shorten, indent"
  kind: python_call_eq
  category: function_identity

  columns: [id, function, args, expected, description]
  rows:
    - [wrap_qualname_len,
       wrap.__qualname__.__len__,
       [],
       4,
       "len('wrap') == 4"]
    - [fill_qualname_len,
       fill.__qualname__.__len__,
       [],
       4,
       "len('fill') == 4"]
    - [dedent_qualname_len,
       dedent.__qualname__.__len__,
       [],
       6,
       "len('dedent') == 6"]
    - [shorten_qualname_len,
       shorten.__qualname__.__len__,
       [],
       7,
       "len('shorten') == 7"]
    - [indent_qualname_len,
       indent.__qualname__.__len__,
       [],
       6,
       "len('indent') == 6"]
    - [indent_name_len,
       indent.__name__.__len__,
       [],
       6,
       "len('indent') == 6"]

# ---------------------------------------------------------------------------
# Table: TextWrapper method __qualname__.__len__() values
#
# No prior spec groups TextWrapper method qualname length checks into a single
# table (extra27 had only wrap as a standalone). All qualnames follow the
# pattern 'TextWrapper.' (12 chars) + method name.
# ---------------------------------------------------------------------------

table textwrap_extra28.TextWrapper_method_qualname_lengths:
  description: "textwrap.TextWrapper method __qualname__ string lengths"
  kind: python_call_eq
  category: class_identity

  columns: [id, function, args, expected, description]
  rows:
    - [wrap_qualname_len,
       TextWrapper.wrap.__qualname__.__len__,
       [],
       16,
       "len('TextWrapper.wrap') == 16"]
    - [fill_qualname_len,
       TextWrapper.fill.__qualname__.__len__,
       [],
       16,
       "len('TextWrapper.fill') == 16"]
    - [_split_qualname_len,
       TextWrapper._split.__qualname__.__len__,
       [],
       18,
       "len('TextWrapper._split') == 18"]
    - [_wrap_chunks_qualname_len,
       TextWrapper._wrap_chunks.__qualname__.__len__,
       [],
       24,
       "len('TextWrapper._wrap_chunks') == 24"]
    - [_handle_long_word_qualname_len,
       TextWrapper._handle_long_word.__qualname__.__len__,
       [],
       29,
       "len('TextWrapper._handle_long_word') == 29"]
    - [_munge_whitespace_qualname_len,
       TextWrapper._munge_whitespace.__qualname__.__len__,
       [],
       29,
       "len('TextWrapper._munge_whitespace') == 29"]
