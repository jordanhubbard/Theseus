spec: struct_extra1531
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra1516.zspec.zsdl — covers arithmetic operator absence (__add__ through __pow__) on Struct; packing/meta attribute presence."
    - "struct_extra1501.zspec.zsdl — covers bitwise operator absence on Struct and struct.error."
    - "struct_extra991.zspec.zsdl — covers method __qualname__ attributes and descriptor class names for Struct and error."
    - "struct_extra15.zspec.zsdl — covers calcsize/pack/unpack test vectors for various format strings."
  notes:
    - "This spec is wave 549 / suffix _extra1531. Theme: comparison operator dict-presence checks on struct.Struct and struct.error."
    - "struct.Struct is a compiled binary layout descriptor. It holds no value — only a format string and derived size. Comparison between two Struct objects is undefined and no comparison dunders appear in Struct.__dict__."
    - "struct.error is a subclass of Exception. Exceptions do not define comparison operators in their own __dict__."
    - "Verified: struct.Struct.__dict__.__contains__('__lt__') == False."
    - "Verified: struct.Struct.__dict__.__contains__('__le__') == False."
    - "Verified: struct.Struct.__dict__.__contains__('__gt__') == False."
    - "Verified: struct.Struct.__dict__.__contains__('__ge__') == False."
    - "Verified: struct.Struct.__dict__.__contains__('__eq__') == False."
    - "Verified: struct.Struct.__dict__.__contains__('__hash__') == False."
    - "Verified: struct.Struct.__dict__.__contains__('__ne__') == False."
    - "Verified True for Struct: pack, unpack, __new__, __repr__, size, format, __doc__, __module__, __sizeof__, __getattribute__, __setattr__, __delattr__."
    - "Verified: struct.error.__dict__.__contains__('__lt__') == False (through __ne__) == False."
    - "Verified True for struct.error: __doc__, __module__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct — comparison operator absence checks
#
# struct.Struct is a C-extension type describing a binary data layout. A Struct
# object stores a format string and the computed byte size; it provides no
# value that would make comparison between two Struct instances meaningful.
# Consequently none of the standard comparison dunders (__lt__, __le__,
# __gt__, __ge__, __eq__, __hash__, __ne__) appear in Struct.__dict__.
# The True entries (pack, unpack, __new__, __repr__, format, size) confirm
# that the dict-presence mechanism works correctly.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table struct_extra1531.Struct_cmp_absent:
  description: "Comparison operator dunders absent from struct.Struct.__dict__ — Struct holds layout, not a value"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st1531ca

  columns: [id, function, args, expected]
  rows:
    - ["st1531ca001", "Struct.__dict__.__contains__", ["__lt__"],   false]
    - ["st1531ca002", "Struct.__dict__.__contains__", ["__le__"],   false]
    - ["st1531ca003", "Struct.__dict__.__contains__", ["__gt__"],   false]
    - ["st1531ca004", "Struct.__dict__.__contains__", ["__ge__"],   false]
    - ["st1531ca005", "Struct.__dict__.__contains__", ["__eq__"],   false]
    - ["st1531ca006", "Struct.__dict__.__contains__", ["__hash__"], false]
    - ["st1531ca007", "Struct.__dict__.__contains__", ["__ne__"],   false]
    - ["st1531ca008", "Struct.__dict__.__contains__", ["pack"],     true]
    - ["st1531ca009", "Struct.__dict__.__contains__", ["unpack"],   true]
    - ["st1531ca010", "Struct.__dict__.__contains__", ["__new__"],  true]

# ---------------------------------------------------------------------------
# struct.Struct — attribute and meta-dunder presence checks
#
# Beyond the packing/unpacking API, struct.Struct defines attribute access
# overrides (__getattribute__, __setattr__, __delattr__), the memory-size
# helper (__sizeof__), documentation (__doc__), and module provenance
# (__module__). The format and size descriptors expose the layout information
# stored in the Struct. All of these are present in Struct.__dict__ and
# contrast cleanly with the absent comparison operators.
# ---------------------------------------------------------------------------

table struct_extra1531.Struct_attrs_present:
  description: "Attribute descriptors and meta-dunders present in struct.Struct.__dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st1531ap

  columns: [id, function, args, expected]
  rows:
    - ["st1531ap001", "Struct.__dict__.__contains__", ["format"],          true]
    - ["st1531ap002", "Struct.__dict__.__contains__", ["size"],            true]
    - ["st1531ap003", "Struct.__dict__.__contains__", ["__repr__"],        true]
    - ["st1531ap004", "Struct.__dict__.__contains__", ["__sizeof__"],      true]
    - ["st1531ap005", "Struct.__dict__.__contains__", ["__module__"],      true]
    - ["st1531ap006", "Struct.__dict__.__contains__", ["__doc__"],         true]
    - ["st1531ap007", "Struct.__dict__.__contains__", ["__getattribute__"],true]
    - ["st1531ap008", "Struct.__dict__.__contains__", ["__setattr__"],     true]
    - ["st1531ap009", "Struct.__dict__.__contains__", ["__delattr__"],     true]
    - ["st1531ap010", "Struct.__dict__.__contains__", ["pack_into"],       true]
    - ["st1531ap011", "Struct.__dict__.__contains__", ["unpack_from"],     true]
    - ["st1531ap012", "Struct.__dict__.__contains__", ["iter_unpack"],     true]

# ---------------------------------------------------------------------------
# struct.error — comparison operator absence checks
#
# struct.error is the exception type raised by struct on bad format strings,
# insufficient data, etc. It inherits from Exception -> BaseException ->
# object. None of __lt__, __le__, __gt__, __ge__, __eq__, __hash__, __ne__
# are overridden in struct.error's own __dict__. The True entries (__doc__,
# __module__) confirm that lookups work and the False results are genuine.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table struct_extra1531.error_cmp_absent:
  description: "Comparison operator dunders absent from struct.error.__dict__ — exception, not a value type"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st1531ec

  columns: [id, function, args, expected]
  rows:
    - ["st1531ec001", "error.__dict__.__contains__", ["__lt__"],    false]
    - ["st1531ec002", "error.__dict__.__contains__", ["__le__"],    false]
    - ["st1531ec003", "error.__dict__.__contains__", ["__gt__"],    false]
    - ["st1531ec004", "error.__dict__.__contains__", ["__ge__"],    false]
    - ["st1531ec005", "error.__dict__.__contains__", ["__eq__"],    false]
    - ["st1531ec006", "error.__dict__.__contains__", ["__hash__"],  false]
    - ["st1531ec007", "error.__dict__.__contains__", ["__ne__"],    false]
    - ["st1531ec008", "error.__dict__.__contains__", ["__doc__"],   true]
    - ["st1531ec009", "error.__dict__.__contains__", ["__module__"], true]
