spec: delaunator
version: ">=5.0.0"
backend: node(delaunator)

docs: https://github.com/mapbox/delaunator#readme

provenance:
  derived_from:
    - "Delaunator README — https://github.com/mapbox/delaunator#readme"
    - "Mapbox 'Algorithms for Computing Delaunay Triangulations'"
    - "Test vectors verified with delaunator via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "delaunator source"
  notes:
    - "Mapbox's fast Delaunay-triangulation library."
    - "Install: npm install delaunator"
    - "Pattern: Delaunator.from(points).triangles → Uint32Array of vertex-index triples."
    - "v5 is ESM with a CJS shim; the class is exposed as default."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure construction; throws on degenerate (collinear) inputs only."
  stderr: "null"
  stickiness: "N/A — Delaunator instances are values."
  codes: {}

# Square with 2 triangles
invariant delaunator.unit_square_triangles_length:
  description: "4-corner unit square triangulates into 2 triangles (6 indices)"
  category: triangulation
  kind: node_chain_eq
  entry: named
  function: default.from
  entry_args: [[[0,0],[1,0],[0,1],[1,1]]]
  chain:
    - {get: triangles}
    - {get: length}
  expected: 6

invariant delaunator.unit_square_first_triangle_vertex:
  description: "First triangle of unit-square Delaunay starts with vertex 0"
  category: triangulation
  kind: node_chain_eq
  entry: named
  function: default.from
  entry_args: [[[0,0],[1,0],[0,1],[1,1]]]
  chain:
    - {get: triangles}
    - {method: at, args: [0]}
  expected: 0

invariant delaunator.unit_square_halfedges_length:
  description: "halfedges array has same length as triangles array (one per directed edge)"
  category: triangulation
  kind: node_chain_eq
  entry: named
  function: default.from
  entry_args: [[[0,0],[1,0],[0,1],[1,1]]]
  chain:
    - {get: halfedges}
    - {get: length}
  expected: 6

# Triangle (3 points) — single triangle, 3 indices
invariant delaunator.triangle_3_points:
  description: "3 input points → 1 triangle (3 indices)"
  category: triangulation
  kind: node_chain_eq
  entry: named
  function: default.from
  entry_args: [[[0,0],[1,0],[0,1]]]
  chain:
    - {get: triangles}
    - {get: length}
  expected: 3

# Hull — boundary of the convex hull
invariant delaunator.hull_4_points_length:
  description: "Convex hull of 4-corner square has 4 vertices"
  category: hull
  kind: node_chain_eq
  entry: named
  function: default.from
  entry_args: [[[0,0],[1,0],[0,1],[1,1]]]
  chain:
    - {get: hull}
    - {get: length}
  expected: 4

# coords — flat array, 2 entries per point
invariant delaunator.coords_double_input_length:
  description: "coords array has 2*N entries for N input points"
  category: coords
  kind: node_chain_eq
  entry: named
  function: default.from
  entry_args: [[[0,0],[1,0],[0,1],[1,1]]]
  chain:
    - {get: coords}
    - {get: length}
  expected: 8

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:09:38Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
