spec: struct_extra196
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "struct.pack, unpack, calcsize, pack_into, unpack_from, iter_unpack are all C-level built-in functions: __class__.__name__ == 'builtin_function_or_method'."
    - "struct.Struct is a type object (a C extension type): __class__.__name__ == 'type'."
    - "struct.error is a type object (exception class): __class__.__name__ == 'type'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __class__.__name__ for struct module-level functions — builtin group
#
# pack, unpack, calcsize, pack_into, unpack_from, iter_unpack are all C-level.
# ---------------------------------------------------------------------------

table struct_extra196.functions_builtin:
  kind: python_call_eq
  category: types
  id_prefix: structclasses196builtin

  columns: [id, function, args, expected, description]
  rows:
    - [pack_class,        pack.__class__.__name__.__eq__,        ["builtin_function_or_method"], true, "struct.pack.__class__.__name__ == 'builtin_function_or_method'"]
    - [unpack_class,      unpack.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "struct.unpack.__class__.__name__ == 'builtin_function_or_method'"]
    - [calcsize_class,    calcsize.__class__.__name__.__eq__,    ["builtin_function_or_method"], true, "struct.calcsize.__class__.__name__ == 'builtin_function_or_method'"]
    - [pack_into_class,   pack_into.__class__.__name__.__eq__,   ["builtin_function_or_method"], true, "struct.pack_into.__class__.__name__ == 'builtin_function_or_method'"]
    - [unpack_from_class, unpack_from.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "struct.unpack_from.__class__.__name__ == 'builtin_function_or_method'"]
    - [iter_unpack_class, iter_unpack.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "struct.iter_unpack.__class__.__name__ == 'builtin_function_or_method'"]

# ---------------------------------------------------------------------------
# __class__.__name__ for struct.Struct and struct.error — 'type' group
# ---------------------------------------------------------------------------

table struct_extra196.types_type:
  kind: python_call_eq
  category: types
  id_prefix: structclasses196type

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_class, Struct.__class__.__name__.__eq__, ["type"], true, "struct.Struct.__class__.__name__ == 'type' — Struct is a C extension type"]
    - [error_class,  error.__class__.__name__.__eq__,  ["type"], true, "struct.error.__class__.__name__ == 'type' — error is an exception class"]

# ---------------------------------------------------------------------------
# Combined table — both groups together for cross-cutting coverage
# ---------------------------------------------------------------------------

table struct_extra196.all_names:
  kind: python_call_eq
  category: types
  id_prefix: structclasses196all

  columns: [id, function, args, expected, description]
  rows:
    - [pack_eq,    pack.__class__.__name__.__eq__,    ["builtin_function_or_method"], true, "struct.pack is builtin_function_or_method"]
    - [Struct_eq,  Struct.__class__.__name__.__eq__,  ["type"],                       true, "struct.Struct is a type"]

