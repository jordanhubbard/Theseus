spec: abc_extra109
version: ">=3.11"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra108.zspec.zsdl."
    - "This spec covers: wave 255 theme — abc module co_qualname attributes (Python 3.11+) not covered in extra103-extra108. extra101 covered abstractmethod.__code__.co_qualname and extra102 covered ABCMeta.register qualname/co_name/co_argcount; but no prior spec (extra103-extra108) covered co_qualname for ABCMeta.register, ABCMeta.__subclasscheck__, ABCMeta.__new__, ABCMeta.__instancecheck__. NEW in extra109: ABCMeta.register.__code__.co_qualname=='ABCMeta.register' (len=16); ABCMeta.__subclasscheck__.__code__.co_qualname=='ABCMeta.__subclasscheck__' (len=25, tied longest); ABCMeta.__new__.__code__.co_qualname=='ABCMeta.__new__' (len=15); ABCMeta.__instancecheck__.__code__.co_qualname=='ABCMeta.__instancecheck__' (len=25, tied longest); update_abstractmethods.__code__.co_qualname=='update_abstractmethods' (len=22); ABCMeta.__init__.__qualname__=='type.__init__' (len=13, inherited from type as wrapper_descriptor); type(ABCMeta.__init__).__name__=='wrapper_descriptor'; type(abc.ABC).__name__=='ABCMeta' (ABC is an instance of ABCMeta). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "ABCMeta method co_qualname values equal their __qualname__ values (as expected for module-level class methods in Python 3.11+): register co_qualname='ABCMeta.register' (len=16), __new__ co_qualname='ABCMeta.__new__' (len=15), __instancecheck__ co_qualname='ABCMeta.__instancecheck__' (len=25), __subclasscheck__ co_qualname='ABCMeta.__subclasscheck__' (len=25). update_abstractmethods co_qualname='update_abstractmethods' (len=22, module-level function so qualname is just the function name). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "ABCMeta.__init__ is inherited from type as a wrapper_descriptor (not a Python function — has no __code__ attribute). ABCMeta.__init__.__qualname__ == 'type.__init__' (len=13) — the qualname shows the source class 'type', not 'ABCMeta'. type(abc.ABC).__name__ == 'ABCMeta' — ABC is an instance of ABCMeta (ABC's metaclass is ABCMeta). ABCMeta.__new__.__code__.co_argcount == 4 (mcls, name, bases, namespace). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta method co_qualname values — extra109
#
# Wave 255 theme: ABCMeta Python-defined method co_qualname (Python 3.11+).
#
# abc.ABCMeta.register.__code__.co_qualname          == 'ABCMeta.register'          (len=16)
# abc.ABCMeta.__new__.__code__.co_qualname           == 'ABCMeta.__new__'           (len=15)
# abc.ABCMeta.__instancecheck__.__code__.co_qualname == 'ABCMeta.__instancecheck__' (len=25, longest tied)
# abc.ABCMeta.__subclasscheck__.__code__.co_qualname == 'ABCMeta.__subclasscheck__' (len=25, longest tied)
# ---------------------------------------------------------------------------

table abc_extra109.abc_abcmeta_coqualname:
  description: "abc.ABCMeta method co_qualname checks in abccoq109 namespace — wave 255 theme: co_qualname is a Python 3.11+ code object attribute (spec requires version >=3.11); for methods on module-level classes, co_qualname equals __qualname__; abc.ABCMeta.register.__code__.co_qualname.__eq__('ABCMeta.register')==True (len=16: 'ABCMeta.'=8+'register'=8=16; co_qualname matches ABCMeta.register.__qualname__ from extra102); abc.ABCMeta.register.__code__.co_qualname.__len__()==16; abc.ABCMeta.__new__.__code__.co_qualname.__eq__('ABCMeta.__new__')==True (len=15: 'ABCMeta.'=8+'__new__'=7=15; co_qualname matches ABCMeta.__new__.__qualname__ from extra108); abc.ABCMeta.__new__.__code__.co_qualname.__len__()==15; abc.ABCMeta.__instancecheck__.__code__.co_qualname.__eq__('ABCMeta.__instancecheck__')==True (len=25: 'ABCMeta.'=8+'__instancecheck__'=17=25; co_qualname matches ABCMeta.__instancecheck__.__qualname__ from extra108; tied longest in spec); abc.ABCMeta.__instancecheck__.__code__.co_qualname.__len__()==25; abc.ABCMeta.__subclasscheck__.__code__.co_qualname.__eq__('ABCMeta.__subclasscheck__')==True (len=25: 'ABCMeta.'=8+'__subclasscheck__'=17=25; tied longest in spec with __instancecheck__; co_qualname matches ABCMeta.__subclasscheck__.__qualname__ from extra102); abc.ABCMeta.__subclasscheck__.__code__.co_qualname.__len__()==25; compare co_qualname lengths: __new__=15 < register=16 < __instancecheck__=__subclasscheck__=25 (tied longest); ABCMeta.__init__ is NOT a Python function (it is inherited from type as a wrapper_descriptor and has no __code__ attribute); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abccoq109

  columns: [id, function, args, expected, description]
  rows:
    - [reg_coq_eq,         abc.ABCMeta.register.__code__.co_qualname.__eq__,              ["ABCMeta.register"],          true, "ABCMeta.register.__code__.co_qualname == 'ABCMeta.register' (len=16); verified with Python 3.14.3"]
    - [reg_coq_len,        abc.ABCMeta.register.__code__.co_qualname.__len__,             [],                            16,   "ABCMeta.register co_qualname.__len__() == 16 ('ABCMeta.register'=16); verified with Python 3.14.3"]
    - [new_coq_eq,         abc.ABCMeta.__new__.__code__.co_qualname.__eq__,               ["ABCMeta.__new__"],            true, "ABCMeta.__new__.__code__.co_qualname == 'ABCMeta.__new__' (len=15); verified with Python 3.14.3"]
    - [new_coq_len,        abc.ABCMeta.__new__.__code__.co_qualname.__len__,              [],                            15,   "ABCMeta.__new__ co_qualname.__len__() == 15 ('ABCMeta.__new__'=15); verified with Python 3.14.3"]
    - [icheck_coq_eq,      abc.ABCMeta.__instancecheck__.__code__.co_qualname.__eq__,     ["ABCMeta.__instancecheck__"], true, "ABCMeta.__instancecheck__.__code__.co_qualname == 'ABCMeta.__instancecheck__' (len=25, longest tied); verified with Python 3.14.3"]
    - [icheck_coq_len,     abc.ABCMeta.__instancecheck__.__code__.co_qualname.__len__,    [],                            25,   "ABCMeta.__instancecheck__ co_qualname.__len__() == 25 (tied longest in spec); verified with Python 3.14.3"]
    - [sc_coq_eq,          abc.ABCMeta.__subclasscheck__.__code__.co_qualname.__eq__,     ["ABCMeta.__subclasscheck__"], true, "ABCMeta.__subclasscheck__.__code__.co_qualname == 'ABCMeta.__subclasscheck__' (len=25, tied longest); verified with Python 3.14.3"]
    - [sc_coq_len,         abc.ABCMeta.__subclasscheck__.__code__.co_qualname.__len__,    [],                            25,   "ABCMeta.__subclasscheck__ co_qualname.__len__() == 25 (tied longest with __instancecheck__); verified with Python 3.14.3"]
    - [new_lt_reg,         abc.ABCMeta.__new__.__code__.co_qualname.__len__,              [],                            15,   "ABCMeta.__new__ co_qualname len=15 < register co_qualname len=16 < __instancecheck__=25; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__init__ qualname (inherited from type) and ABC type — extra109
#
# Wave 255 theme: ABCMeta.__init__ is a C-level wrapper_descriptor from type.
#
# type(abc.ABCMeta.__init__).__name__   == 'wrapper_descriptor'
# abc.ABCMeta.__init__.__qualname__     == 'type.__init__'       (len=13)
# type(abc.ABC).__name__                == 'ABCMeta'
# type(abc.ABC).__qualname__            == 'ABCMeta'             (len=7)
# ---------------------------------------------------------------------------

table abc_extra109.abc_abcmeta_init_and_abc_type:
  description: "abc.ABCMeta.__init__ (inherited from type) and abc.ABC metaclass checks in abccoq109 namespace — wave 255 theme: type(abc.ABCMeta.__init__).__name__.__eq__('wrapper_descriptor')==True (ABCMeta.__init__ is NOT a Python function — it is inherited from type as a C-level wrapper_descriptor; unlike ABCMeta.__new__ which IS Python-defined with type=='function'; this contrast is a key distinguishing fact); abc.ABCMeta.__init__.__qualname__.__eq__('type.__init__')==True (len=13: 'type.'=5+'__init__'=8=13; the qualname shows 'type.__init__' not 'ABCMeta.__init__' — confirming the method is inherited from type, not defined in ABCMeta); abc.ABCMeta.__init__.__qualname__.__len__()==13; type(abc.ABC).__name__.__eq__('ABCMeta')==True (abc.ABC is an instance of ABCMeta — its type/metaclass is ABCMeta; this is the fundamental relationship: ABC is a helper class whose metaclass is ABCMeta, enabling classes that inherit from ABC to automatically use ABCMeta); type(abc.ABC).__qualname__.__eq__('ABCMeta')==True (len=7; the type qualname equals ABCMeta.__qualname__); abc.ABCMeta.__new__.__code__.co_argcount.__eq__(4)==True (ABCMeta.__new__ takes 4 args: mcls, name, bases, namespace — the standard metaclass __new__ signature); compare: ABCMeta.__new__ is Python-defined (type=='function', co_argcount=4) while ABCMeta.__init__ is C-inherited (type=='wrapper_descriptor', no __code__); abc.ABCMeta.__init__.__qualname__.__len__()==13 vs abc.ABCMeta.__new__.__qualname__.__len__()==15 (from extra108); abc.ABCMeta.__name__=='ABCMeta' (len=7); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abccoq109a

  columns: [id, function, args, expected, description]
  rows:
    - [init_type_eq,       type(abc.ABCMeta.__init__).__name__.__eq__,                    ["wrapper_descriptor"],    true, "type(ABCMeta.__init__).__name__ == 'wrapper_descriptor' (inherited from type, not Python-defined); verified with Python 3.14.3"]
    - [init_qn_eq,         abc.ABCMeta.__init__.__qualname__.__eq__,                      ["type.__init__"],         true, "ABCMeta.__init__.__qualname__ == 'type.__init__' (len=13, shows inheritance from type); verified with Python 3.14.3"]
    - [init_qn_len,        abc.ABCMeta.__init__.__qualname__.__len__,                     [],                        13,   "ABCMeta.__init__.__qualname__.__len__() == 13 ('type.__init__'=13); verified with Python 3.14.3"]
    - [abc_type_name_eq,   type(abc.ABC).__name__.__eq__,                                 ["ABCMeta"],               true, "type(abc.ABC).__name__ == 'ABCMeta' (ABC's metaclass is ABCMeta); verified with Python 3.14.3"]
    - [abc_type_qn_eq,     type(abc.ABC).__qualname__.__eq__,                             ["ABCMeta"],               true, "type(abc.ABC).__qualname__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]
    - [abc_type_qn_len,    type(abc.ABC).__qualname__.__len__,                            [],                        7,    "type(abc.ABC).__qualname__.__len__() == 7 ('ABCMeta'=7); verified with Python 3.14.3"]
    - [new_argc,           abc.ABCMeta.__new__.__code__.co_argcount.__eq__,               [4],                       true, "ABCMeta.__new__.__code__.co_argcount == 4 (mcls, name, bases, namespace — metaclass __new__ signature); verified with Python 3.14.3"]
    - [new_type_eq,        type(abc.ABCMeta.__new__).__name__.__eq__,                     ["function"],              true, "type(ABCMeta.__new__).__name__ == 'function' (Python-defined — contrast with ABCMeta.__init__ which is wrapper_descriptor); verified with Python 3.14.3"]
    - [init_qn_lt_reg,     abc.ABCMeta.__init__.__qualname__.__len__,                     [],                        13,   "ABCMeta.__init__ qualname len=13 < ABCMeta.register qualname len=16 < ABCMeta.__instancecheck__ len=25; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.update_abstractmethods co_qualname and ABC identity — extra109
#
# Wave 255 theme: update_abstractmethods co_qualname and ABC class attributes.
#
# abc.update_abstractmethods.__code__.co_qualname  == 'update_abstractmethods' (len=22)
# abc.ABC.__name__                                 == 'ABC'     (len=3)
# abc.ABC.__module__                               == 'abc'     (len=3)
# abc.ABC.__mro__.__len__()                        == 2
# abc.ABC.__bases__[0].__name__                    == 'object'
# ---------------------------------------------------------------------------

table abc_extra109.abc_uam_coqualname_and_abc_identity:
  description: "abc.update_abstractmethods co_qualname and abc.ABC class identity checks in abccoq109 namespace — wave 255 theme: abc.update_abstractmethods.__code__.co_qualname.__eq__('update_abstractmethods')==True (len=22: 'update_abstractmethods'=22; for module-level functions, co_qualname equals the function name — no class prefix; this matches update_abstractmethods.__qualname__ from extra108); abc.update_abstractmethods.__code__.co_qualname.__len__()==22; abc.ABC.__name__.__eq__('ABC')==True (len=3: 'ABC'=3; ABC is the convenience base class for abstract classes — inheriting from ABC is equivalent to metaclass=ABCMeta); abc.ABC.__name__.__len__()==3; abc.ABC.__qualname__.__eq__('ABC')==True (len=3; qualname equals name for a top-level class); abc.ABC.__module__.__eq__('abc')==True (len=3: 'abc'=3; same module as ABCMeta and all other abc public names); abc.ABC.__module__.__len__()==3; abc.ABC.__mro__.__len__()==2 (MRO=[ABC, object]; minimal 2-level chain — ABC inherits directly from object; compare: ABCMeta.__mro__.__len__()==3 ([ABCMeta, type, object]) — ABCMeta has a deeper MRO because it inherits from type); abc.ABC.__bases__[0].__name__.__eq__('object')==True (ABC inherits directly from object — no intermediate classes); compare: ABC.__mro__.__len__()==2 vs abstractproperty.__mro__.__len__()==3 (from extra108) — ABC has shorter MRO; compare string lengths: ABC.__name__==ABC.__module__==ABC.__qualname__=='abc' or 'ABC' all have len=3 (all tie at 3); abc.update_abstractmethods co_qualname len=22 is the longest co_qualname in this spec; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abccoq109b

  columns: [id, function, args, expected, description]
  rows:
    - [uam_coq_eq,         abc.update_abstractmethods.__code__.co_qualname.__eq__,        ["update_abstractmethods"], true, "update_abstractmethods.__code__.co_qualname == 'update_abstractmethods' (len=22, module-level function); verified with Python 3.14.3"]
    - [uam_coq_len,        abc.update_abstractmethods.__code__.co_qualname.__len__,       [],                         22,   "update_abstractmethods co_qualname.__len__() == 22 ('update_abstractmethods'=22, longest in spec); verified with Python 3.14.3"]
    - [abc_name_eq,        abc.ABC.__name__.__eq__,                                       ["ABC"],                    true, "abc.ABC.__name__ == 'ABC' (len=3); verified with Python 3.14.3"]
    - [abc_name_len,       abc.ABC.__name__.__len__,                                      [],                         3,    "abc.ABC.__name__.__len__() == 3 ('ABC'=3); verified with Python 3.14.3"]
    - [abc_qn_eq,          abc.ABC.__qualname__.__eq__,                                   ["ABC"],                    true, "abc.ABC.__qualname__ == 'ABC' (len=3, qualname equals name); verified with Python 3.14.3"]
    - [abc_mod_eq,         abc.ABC.__module__.__eq__,                                     ["abc"],                    true, "abc.ABC.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [abc_mod_len,        abc.ABC.__module__.__len__,                                    [],                         3,    "abc.ABC.__module__.__len__() == 3 ('abc'=3); verified with Python 3.14.3"]
    - [abc_mro_len,        abc.ABC.__mro__.__len__,                                       [],                         2,    "abc.ABC.__mro__.__len__() == 2 ([ABC, object]); verified with Python 3.14.3"]
    - [abc_base_eq,        "abc.ABC.__bases__[0].__name__.__eq__",                        ["object"],                 true, "abc.ABC.__bases__[0].__name__ == 'object' (ABC inherits directly from object); verified with Python 3.14.3"]
    - [uam_coq_longest,    abc.update_abstractmethods.__code__.co_qualname.__len__,       [],                         22,   "update_abstractmethods co_qualname len=22 is longest in spec (ABCMeta.__instancecheck__=25 is per-method qualname, uam=22 is module-level); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra109
# ---------------------------------------------------------------------------

invariant abc_extra109.ABCMeta_register_coqualname_len_16:
  description: "abc.ABCMeta.register.__code__.co_qualname.__len__() == 16 — 'ABCMeta.register' = 'ABCMeta.'=8 + 'register'=8 = 16; co_qualname is a Python 3.11+ code object attribute (spec requires version >=3.11); abc.ABCMeta.register.__code__.co_qualname.__eq__('ABCMeta.register')==True; co_qualname matches __qualname__ for module-level class methods; abc.ABCMeta.register.__code__.co_argcount==2 (self and subclass — register() makes subclass a virtual subclass of the ABC); abc.ABCMeta.register.__code__.co_name=='register' (len=8); compare co_qualname lengths in spec: ABCMeta.__new__=15 < ABCMeta.register=16 < ABCMeta.__instancecheck__=ABCMeta.__subclasscheck__=25 (tied longest); NOTE: extra102 covered ABCMeta.register.__qualname__ and co_name; this invariant is the first to test ABCMeta.register co_qualname specifically; abc.ABCMeta.__name__=='ABCMeta' (len=7); abc.ABCMeta.__mro__.__len__()==3 ([ABCMeta, type, object]); NEW in extra109: first standalone ABCMeta.register co_qualname length invariant; wave 255; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: abc.ABCMeta.register.__code__.co_qualname.__len__
  args: []
  expected: 16

invariant abc_extra109.ABCMeta_instancecheck_coqualname_len_25:
  description: "abc.ABCMeta.__instancecheck__.__code__.co_qualname.__len__() == 25 — 'ABCMeta.__instancecheck__' = 'ABCMeta.'=8 + '__instancecheck__'=17 = 25; tied longest co_qualname in this spec (tied with ABCMeta.__subclasscheck__=25); abc.ABCMeta.__instancecheck__.__code__.co_qualname.__eq__('ABCMeta.__instancecheck__')==True; co_qualname matches ABCMeta.__instancecheck__.__qualname__ from extra108; abc.ABCMeta.__instancecheck__.__code__.co_argcount==2 (self and instance); abc.ABCMeta.__instancecheck__.__code__.co_name=='__instancecheck__' (len=17); compare co_qualname length for all ABCMeta methods: __new__=15 < register=16 < __instancecheck__=__subclasscheck__=25 (tied longest); '__instancecheck__'=17 chars (the method name alone) is the longest dunder name in the ABCMeta Python-defined methods; abc.ABCMeta.__mro__.__len__()==3 ([ABCMeta, type, object]); NEW in extra109: first standalone ABCMeta.__instancecheck__ co_qualname length invariant; wave 255; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__code__.co_qualname.__len__
  args: []
  expected: 25

invariant abc_extra109.ABCMeta_init_qualname_type_init:
  description: "abc.ABCMeta.__init__.__qualname__.__eq__('type.__init__') returns True — ABCMeta.__init__.__qualname__ == 'type.__init__' (len=13); this qualname reveals that ABCMeta.__init__ is INHERITED from type (the standard metaclass), not defined in ABCMeta itself; type(abc.ABCMeta.__init__).__name__=='wrapper_descriptor' (C-level, no __code__ attribute — compare: ABCMeta.__new__ is Python-defined with type=='function'); 'type.__init__' (len=13: 'type.'=5+'__init__'=8=13) differs from what you might expect ('ABCMeta.__init__'); this is the inheritance indicator in qualname — the prefix 'type.' shows the defining class; compare: ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15, from extra108) — __new__ is defined IN ABCMeta, so it uses 'ABCMeta.' prefix; abc.ABCMeta.__name__=='ABCMeta' (len=7); abc.ABCMeta.__mro__.__len__()==3; NEW in extra109: first standalone ABCMeta.__init__ qualname string invariant; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__init__.__qualname__.__eq__
  args: ["type.__init__"]
  expected: true

invariant abc_extra109.ABC_mro_len_2:
  description: "abc.ABC.__mro__.__len__() == 2 — ABC's MRO is [ABC, object] (length=2); the simplest possible MRO — ABC inherits directly from object with no intermediate bases; abc.ABC.__bases__[0].__name__=='object'; abc.ABC.__name__=='ABC' (len=3); abc.ABC.__module__=='abc' (len=3); abc.ABC.__qualname__=='ABC' (len=3); type(abc.ABC).__name__=='ABCMeta' (ABC is an instance of ABCMeta — its metaclass is ABCMeta); compare MRO lengths: ABC.__mro__.__len__()==2 (shortest — only [ABC, object]) < abstractproperty.__mro__.__len__()==3 (from extra108, adds property) < ABCMeta.__mro__.__len__()==3 (adds type) = abstractproperty=3; abc.ABC.__mro__.__len__()==2 is shorter than all other abc module classes in prior specs; the ABC helper class exists purely to enable 'class Foo(ABC):' syntax as an alternative to 'class Foo(metaclass=ABCMeta):'; NEW in extra109: first standalone ABC MRO length invariant in abccoq109 namespace; wave 255; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: abc.ABC.__mro__.__len__
  args: []
  expected: 2

invariant abc_extra109.type_of_ABC_is_ABCMeta:
  description: "type(abc.ABC).__name__.__eq__('ABCMeta') returns True — type(abc.ABC).__name__ == 'ABCMeta'; abc.ABC is an instance of ABCMeta (ABC's metaclass is ABCMeta); type(abc.ABC).__qualname__=='ABCMeta' (len=7); this is the fundamental relationship: ABC is a convenience class — by inheriting from ABC, user classes automatically use ABCMeta as their metaclass without explicitly specifying metaclass=ABCMeta; compare: type(abc.ABCMeta).__name__=='type' (ABCMeta is itself a class whose type is type — the standard metaclass of metaclasses); contrast: type(abc.abstractproperty).__name__=='type' (abstractproperty is a plain class with metaclass type); type(abc.abstractmethod).__name__=='function' (abstractmethod is a function, not a class); abc.ABC.__name__=='ABC' (len=3); abc.ABC.__mro__.__len__()==2 ([ABC, object]); abc.ABC.__module__=='abc' (len=3); abc.ABC.__bases__[0].__name__=='object'; NEW in extra109: first standalone 'type(abc.ABC).__name__==ABCMeta' invariant in abccoq109 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: type(abc.ABC).__name__.__eq__
  args: ["ABCMeta"]
  expected: true
