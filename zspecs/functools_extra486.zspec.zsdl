spec: functools_extra486
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools.partial class attributes and method names"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.partial is a C-extension type; descriptor attributes return getset_descriptor at class level"
    - "Method name identity checked via __name__ attribute of each method"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra486.method_names:
  description: "functools.partial built-in method __name__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [mname001, functools.partial.__new__.__name__.__eq__, ["__new__"], true]
    - [mname002, functools.partial.__call__.__name__.__eq__, ["__call__"], true]
    - [mname003, functools.partial.__repr__.__name__.__eq__, ["__repr__"], true]
    - [mname004, functools.partial.__reduce__.__name__.__eq__, ["__reduce__"], true]
    - [mname005, functools.partial.__setstate__.__name__.__eq__, ["__setstate__"], true]

table functools_extra486.descriptor_types:
  description: "functools.partial data descriptor __class__.__name__ checks at class level"
  kind: python_call_eq
  category: identity
  id_prefix: desc

  columns: [id, function, args, expected]
  rows:
    - [desc001, functools.partial.func.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [desc002, functools.partial.args.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [desc003, functools.partial.keywords.__class__.__name__.__eq__, ["getset_descriptor"], true]

table functools_extra486.doc_type:
  description: "functools.partial __doc__ type check"
  kind: python_call_eq
  category: identity
  id_prefix: doc

  columns: [id, function, args, expected]
  rows:
    - [doc001, functools.partial.__doc__.__class__.__name__.__eq__, ["str"], true]
