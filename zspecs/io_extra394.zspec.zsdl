spec: io_extra394
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "io.StringIO methods write, getvalue, seek, tell, truncate each report __name__ matching their Python-level name"
    - "io.BytesIO methods write, getvalue, getbuffer each report __name__ matching their Python-level name"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.StringIO method __name__ identity
# ---------------------------------------------------------------------------

table io_extra394.stringio_method_names:
  description: "io.StringIO method __name__ identity — write, getvalue, seek, tell, truncate; each method's __name__ matches its Python-level name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iostrio394

  columns: [id, function, args, expected]
  rows:
    - [write_name,    io.StringIO.write.__name__.__eq__,    ["write"],    true]
    - [getvalue_name, io.StringIO.getvalue.__name__.__eq__, ["getvalue"], true]
    - [seek_name,     io.StringIO.seek.__name__.__eq__,     ["seek"],     true]
    - [tell_name,     io.StringIO.tell.__name__.__eq__,     ["tell"],     true]
    - [truncate_name, io.StringIO.truncate.__name__.__eq__, ["truncate"], true]

# ---------------------------------------------------------------------------
# io.BytesIO method __name__ identity
# ---------------------------------------------------------------------------

table io_extra394.bytesio_method_names:
  description: "io.BytesIO method __name__ identity — write, getvalue, getbuffer; each method's __name__ matches its Python-level name; getbuffer returns a memoryview of the internal buffer without copying; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iobytio394

  columns: [id, function, args, expected]
  rows:
    - [write_name,     io.BytesIO.write.__name__.__eq__,     ["write"],     true]
    - [getvalue_name,  io.BytesIO.getvalue.__name__.__eq__,  ["getvalue"],  true]
    - [getbuffer_name, io.BytesIO.getbuffer.__name__.__eq__, ["getbuffer"], true]
