spec: json_extra15
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json.zspec.zsdl and prior extras through json_extra14.zspec.zsdl."
    - "json_extra14 covers: JSONDecodeError __name__/__bases__[0].__name__; JSONEncoder/__name__; JSONDecoder/__name__; loads/__qualname__; dumps/__qualname__; loads/__module__; dumps/__module__ (table)."
    - "json_extra12 covers: JSONEncoder/__module__; JSONDecoder/__module__; JSONDecodeError __bases__[0].__name__; dump/load __module__."
    - "json_extra13 covers: JSONEncoder/JSONDecoder instance __class__.__name__; JSONEncoder().encode() table; JSONDecoder().decode() invariants."
    - "Focus: new axes — JSONDecodeError/__module__; JSONEncoder/__module__ standalone extra15 namespace; JSONDecoder/__module__ standalone extra15 namespace; JSONEncoder/__bases__[0].__name__; JSONDecoder/__bases__[0].__name__; load/__qualname__; dump/__qualname__."
    - "json.JSONDecodeError.__module__ == 'json.decoder' — class defined in json.decoder submodule; no prior spec checks JSONDecodeError.__module__ as a standalone invariant in this namespace."
    - "json.JSONEncoder.__module__ == 'json.encoder' — class defined in json.encoder submodule; json_extra12 checks JSONEncoder.__module__ in a table; standalone invariant in json_extra15 is new."
    - "json.JSONDecoder.__module__ == 'json.decoder' — class defined in json.decoder submodule; json_extra12 checks JSONDecoder.__module__ in a table; standalone invariant in json_extra15 is new."
    - "json.JSONEncoder.__bases__[0].__name__ == 'object' — JSONEncoder inherits directly from object; no prior spec checks JSONEncoder.__bases__[0].__name__."
    - "json.JSONDecoder.__bases__[0].__name__ == 'object' — JSONDecoder inherits directly from object; no prior spec checks JSONDecoder.__bases__[0].__name__."
    - "json.load.__qualname__ == 'load' — no prior spec checks load.__qualname__ as a standalone invariant."
    - "json.dump.__qualname__ == 'dump' — no prior spec checks dump.__qualname__ as a standalone invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# JSONDecodeError, JSONEncoder, JSONDecoder — __module__ standalone invariants
#
# json_extra12 checks JSONEncoder/__module__ and JSONDecoder/__module__ in a
# table. No prior spec checks JSONDecodeError.__module__ as a standalone
# invariant. All three are re-anchored in the json_extra15 namespace.
# ---------------------------------------------------------------------------

invariant json_extra15.JSONDecodeError.module:
  description: "json.JSONDecodeError.__module__ == 'json.decoder' — defined in json.decoder submodule"
  category: class_attrs
  kind: python_call_eq
  function: JSONDecodeError.__module__.__eq__
  args: ["json.decoder"]
  expected: true

invariant json_extra15.JSONEncoder.module:
  description: "json.JSONEncoder.__module__ == 'json.encoder' — defined in json.encoder submodule"
  category: class_attrs
  kind: python_call_eq
  function: JSONEncoder.__module__.__eq__
  args: ["json.encoder"]
  expected: true

invariant json_extra15.JSONDecoder.module:
  description: "json.JSONDecoder.__module__ == 'json.decoder' — defined in json.decoder submodule"
  category: class_attrs
  kind: python_call_eq
  function: JSONDecoder.__module__.__eq__
  args: ["json.decoder"]
  expected: true

# ---------------------------------------------------------------------------
# JSONEncoder and JSONDecoder — __bases__[0].__name__
#
# Both classes inherit directly from object. No prior json spec checks
# __bases__[0].__name__ for JSONEncoder or JSONDecoder.
# ---------------------------------------------------------------------------

invariant json_extra15.JSONEncoder.bases_0_name:
  description: "json.JSONEncoder.__bases__[0].__name__ == 'object' — inherits directly from object"
  category: class_attrs
  kind: python_call_eq
  function: "JSONEncoder.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant json_extra15.JSONDecoder.bases_0_name:
  description: "json.JSONDecoder.__bases__[0].__name__ == 'object' — inherits directly from object"
  category: class_attrs
  kind: python_call_eq
  function: "JSONDecoder.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# load and dump — __qualname__ and __module__ table
#
# json_extra12 checks load/dump __module__ in a table. No prior json spec
# checks load.__qualname__ or dump.__qualname__ as standalone invariants.
# This table covers all four axes for load and dump under json_extra15.
# ---------------------------------------------------------------------------

table json_extra15.load_dump_attrs:
  description: "json.load and json.dump — __qualname__ and __module__"
  kind: python_call_eq
  category: function_attrs
  id_prefix: jld15

  columns: [id, function, args, expected]
  rows:
    - [load_qualname,  load.__qualname__.__eq__,  ["load"],  true]
    - [dump_qualname,  dump.__qualname__.__eq__,  ["dump"],  true]
    - [load_module,    load.__module__.__eq__,    ["json"],  true]
    - [dump_module,    dump.__module__.__eq__,    ["json"],  true]
