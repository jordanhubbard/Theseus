spec: sha1
version: ">=1.1.1"
backend: node(sha1)

docs: https://www.npmjs.com/package/sha1

provenance:
  derived_from:
    - "sha1 README — https://www.npmjs.com/package/sha1"
    - "Test vectors verified with sha1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "sha1 source"
  notes:
    - "sha1 is an npm package. Install: npm install sha1"
    - "Returns the SHA-1 hash of a string as a hex string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a 40-character hex string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table sha1.hash:
  kind: node_module_call_eq
  function: ~
  category: crypto
  id_prefix: sha1

  columns: [id, args, expected]
  rows:
    - [hello,  ["hello"],  "aaf4c61ddcc5e8a2dabede0f3b482cd9aea9434d"]
    - [world,  ["world"],  "7c211433f02071597741e6ff5a8ea34789abbf43"]
    - [empty,  [""],       "da39a3ee5e6b4b0d3255bfef95601890afd80709"]
