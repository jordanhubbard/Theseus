spec: decimal_extra64
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra63.zspec.zsdl — covers InvalidOperation/Clamped/Rounded/Inexact __mro__.__len__()==6; DivisionByZero/__mro__.__len__()==7; Inexact/__bases__[0].__name__=='DecimalException'; InvalidOperation/DivisionByZero/Clamped/Rounded __name__.__eq__; InvalidOperation/DivisionByZero/Clamped __module__.__contains__('decimal')."
    - "decimal_extra62.zspec.zsdl — covers Decimal/__name__.__eq__('Decimal'); Decimal/__qualname__/__module__.__contains__('decimal'); Decimal/__bases__[0].__name__=='object'; Decimal/__mro__.__len__()==2; DecimalException/__bases__[0].__name__=='ArithmeticError'; DecimalException/__mro__.__len__()==5; InvalidOperation/DivisionByZero/Overflow/__bases__[0].__name__=='DecimalException'."
    - "decimal_extra61.zspec.zsdl — covers ROUND_* constant __class__/__len__ checks; getcontext/__class__.__name__ check."
  notes:
    - "This spec extends decimal_extra63.zspec.zsdl."
    - "Theme: decimal.Context class identity and hierarchy, plus extended decimal exception base chains."
    - "decimal.Context is a C extension type used to hold arithmetic context settings. Context.__class__.__name__ == 'type'. No prior decimal spec checks Context.__class__.__name__ in decimalctx64 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Context.__name__ == 'Context' — simple class name. No prior decimal spec checks Context.__name__.__eq__('Context') in decimalctx64 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Context.__module__.__contains__('decimal') == True — module is 'decimal' or '_decimal'; both contain 'decimal'. No prior decimal spec checks Context.__module__.__contains__('decimal') in decimalctx64 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Context.__qualname__ == 'Context' — top-level class, qualname equals simple name. No prior decimal spec checks Context.__qualname__ in decimalctx64 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Context.__bases__[0].__name__ == 'object' — Context is a C extension type that inherits directly from object. No prior decimal spec checks Context.__bases__[0].__name__ in decimalctx64 namespace. Function value contains '[' so it is double-quoted. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Context.__mro__.__len__() == 2 — MRO is [Context, object]; 2 entries. No prior decimal spec checks Context.__mro__.__len__() in decimalctx64 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Overflow.__bases__[0].__name__ == 'Inexact' — decimal.Overflow inherits from Inexact (not directly from DecimalException). No prior decimal spec checks Overflow.__bases__[0].__name__ in decimalctx64 namespace. Function value contains '[' so it is double-quoted. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Inexact.__bases__[0].__name__ == 'DecimalException' — already in decimal_extra63. Use Rounded and Subnormal as novel anchors."
    - "Rounded.__bases__[0].__name__ == 'DecimalException' — Rounded inherits directly from DecimalException. No prior decimal spec checks Rounded.__bases__[0].__name__ in decimalctx64 namespace. Function value contains '[' so it is double-quoted. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Subnormal.__bases__[0].__name__ == 'DecimalException' — Subnormal inherits directly from DecimalException. No prior decimal spec checks Subnormal.__bases__[0].__name__ in decimalctx64 namespace. Function value contains '[' so it is double-quoted. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Overflow.__mro__.__len__() == 7 — MRO is [Overflow, Inexact, DecimalException, ArithmeticError, Exception, BaseException, object]; 7 entries. Overflow inherits from Inexact which inherits from DecimalException. No prior decimal spec checks Overflow.__mro__.__len__() in decimalctx64 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Table row function values containing '[' must be double-quoted per ZSDL rules."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context class identity: __class__.__name__, __name__, __module__, __qualname__
#
# decimal.Context is the C extension class for arithmetic context objects.
# As a class object its type is 'type'. It is top-level in the decimal module:
#   Context.__class__.__name__             == 'type'
#   Context.__name__                       == 'Context'
#   Context.__module__.__contains__('decimal') == True
#   Context.__qualname__                   == 'Context'
#
# No prior decimal spec checks any of these Context attributes in the
# decimalctx64 namespace. Novel Context identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra64.Context_identity:
  description: "Context/__class__.__name__=='type'; Context/__name__.__eq__('Context')==True; Context/__module__.__contains__('decimal')==True; Context/__qualname__.__eq__('Context')==True — decimal.Context is the arithmetic context C extension class; it is a type object; defined in the decimal module (or _decimal); top-level so qualname equals simple name; no prior decimal spec checks these in decimalctx64 namespace; novel Context identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalctx64ident

  columns: [id, function, args, expected]
  rows:
    - [context_class_type,       Context.__class__.__name__.__eq__,    ["type"],    true]
    - [context_name_context,     Context.__name__.__eq__,              ["Context"], true]
    - [context_module_decimal,   Context.__module__.__contains__,      ["decimal"], true]
    - [context_qualname_context, Context.__qualname__.__eq__,          ["Context"], true]

# ---------------------------------------------------------------------------
# decimal.Context class hierarchy: __bases__[0].__name__ and __mro__.__len__()
#
# decimal.Context is a C extension type that inherits directly from object:
#   Context.__bases__[0].__name__ == 'object'
#   Context.__mro__.__len__()     == 2   ([Context, object])
#
# Function value for __bases__[0].__name__ contains '[' — must be double-quoted.
# No prior decimal spec checks Context.__bases__[0].__name__ or
# Context.__mro__.__len__() in decimalctx64 namespace.
# Novel hierarchy anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra64.Context_hierarchy:
  description: "Context/__bases__[0].__name__=='object'; Context/__mro__.__len__()==2 — decimal.Context inherits directly from object; MRO is [Context, object] with 2 entries; no prior decimal spec checks Context.__bases__[0].__name__ or Context.__mro__.__len__() in decimalctx64 namespace; function value with '[' is double-quoted; novel hierarchy anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: decimalctx64hier

  columns: [id, function, args, expected]
  rows:
    - [context_bases_object,  "Context.__bases__[0].__name__.__eq__",  ["object"], true]
    - [context_mro_len_2,     Context.__mro__.__len__,                 [],         2]

# ---------------------------------------------------------------------------
# decimal exception extended base chains: Overflow, Rounded, Subnormal
#
# Overflow inherits from Inexact (not directly from DecimalException):
#   Overflow.__bases__[0].__name__  == 'Inexact'
#
# Rounded and Subnormal both inherit directly from DecimalException:
#   Rounded.__bases__[0].__name__   == 'DecimalException'
#   Subnormal.__bases__[0].__name__ == 'DecimalException'
#
# All function values containing '[' must be double-quoted.
# No prior decimal spec checks Overflow/__bases__[0].__name__ (only
# Overflow/__bases__[0].__name__=='DecimalException' was checked in
# decimal_extra62, but that is wrong — Overflow inherits from Inexact).
# Novel hierarchy anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra64.decimal_exception_bases_extended:
  description: "Overflow/__bases__[0].__name__=='Inexact'; Rounded/__bases__[0].__name__=='DecimalException'; Subnormal/__bases__[0].__name__=='DecimalException' — Overflow inherits from Inexact (not directly from DecimalException); Rounded and Subnormal both inherit directly from DecimalException; all function values with '[' are double-quoted; no prior decimal spec checks these in decimalctx64 namespace; novel exception base chain anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: decimalctx64bases

  columns: [id, function, args, expected]
  rows:
    - [overflow_bases_inexact,       "Overflow.__bases__[0].__name__.__eq__",   ["Inexact"],           true]
    - [rounded_bases_decimalexc,     "Rounded.__bases__[0].__name__.__eq__",    ["DecimalException"],  true]
    - [subnormal_bases_decimalexc,   "Subnormal.__bases__[0].__name__.__eq__",  ["DecimalException"],  true]

# ---------------------------------------------------------------------------
# decimal.Overflow MRO length
#
# Overflow inherits from Inexact which inherits from DecimalException. The
# full MRO is:
#   [Overflow, Inexact, DecimalException, ArithmeticError, Exception, BaseException, object]
# That is 7 entries. This is one more than the 6-entry MRO of other direct
# DecimalException subclasses (InvalidOperation, Clamped, Rounded, Inexact).
#
# No prior decimal spec checks Overflow.__mro__.__len__() in decimalctx64
# namespace. Novel MRO length anchor for Overflow.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra64.overflow_mro:
  description: "Overflow/__mro__.__len__()==7 — decimal.Overflow inherits from Inexact which inherits from DecimalException; full MRO is [Overflow, Inexact, DecimalException, ArithmeticError, Exception, BaseException, object] with 7 entries; one more entry than direct DecimalException subclasses; no prior decimal spec checks Overflow.__mro__.__len__() in decimalctx64 namespace; novel MRO length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: decimalctx64mro

  columns: [id, function, args, expected]
  rows:
    - [overflow_mro_len_7,  Overflow.__mro__.__len__,  [], 7]

invariant decimal_extra64.Context_class_type:
  description: "Context.__class__.__name__.__eq__('type') == True — decimal.Context is the C extension class for arithmetic context objects; as a class object its own type is 'type'; no prior decimal spec checks Context.__class__.__name__ in decimalctx64 namespace; novel class identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Context.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant decimal_extra64.Context_module_decimal:
  description: "Context.__module__.__contains__('decimal') == True — decimal.Context.__module__ is 'decimal' (or '_decimal' in C extension builds); both strings contain 'decimal'; no prior decimal spec checks Context.__module__.__contains__('decimal') in decimalctx64 namespace; novel module identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Context.__module__.__contains__
  args: ["decimal"]
  expected: true

invariant decimal_extra64.Context_bases_object:
  description: "Context.__bases__[0].__name__.__eq__('object') == True — decimal.Context is a C extension type that inherits directly from object; __bases__[0] is object; object.__name__ is 'object'; no prior decimal spec checks Context.__bases__[0].__name__ in decimalctx64 namespace; novel hierarchy anchor; function value contains '[' so it is double-quoted; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_hierarchy
  kind: python_call_eq
  function: "Context.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant decimal_extra64.Context_mro_2:
  description: "Context.__mro__.__len__() == 2 — decimal.Context inherits directly from object; its MRO is [Context, object] with exactly 2 entries; no prior decimal spec checks Context.__mro__.__len__() in decimalctx64 namespace; novel MRO length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_hierarchy
  kind: python_call_eq
  function: Context.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra64.Overflow_mro_7:
  description: "Overflow.__mro__.__len__() == 7 — decimal.Overflow inherits from Inexact which in turn inherits from DecimalException; MRO is [Overflow, Inexact, DecimalException, ArithmeticError, Exception, BaseException, object] with 7 entries; one more than direct DecimalException subclasses; no prior decimal spec checks Overflow.__mro__.__len__() in decimalctx64 namespace; novel MRO length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: exception_hierarchy
  kind: python_call_eq
  function: Overflow.__mro__.__len__
  args: []
  expected: 7
