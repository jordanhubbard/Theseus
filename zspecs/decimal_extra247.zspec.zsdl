spec: decimal_extra247
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers decimal.Decimal method identity: quantize, normalize, sqrt, exp, ln, log10, compare, max, min, to_eng_string."
    - "All decimal.Decimal methods are C-level method_descriptor objects; their __class__.__name__ is 'method_descriptor'."
    - "All methods are defined directly on Decimal, so their __qualname__ values use the 'Decimal.' prefix."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal arithmetic method __name__ identity
#
# quantize, normalize, sqrt, exp, ln, log10 are the primary arithmetic
# methods for rounding and transcendental operations. All are method_descriptor
# objects defined in the _decimal C extension.
# ---------------------------------------------------------------------------

table decimal_extra247.decimal_arithmetic_method_names:
  description: "decimal.Decimal arithmetic method __name__ identity — quantize, normalize, sqrt, exp, ln, log10; new to extra247"
  kind: python_call_eq
  category: identity
  id_prefix: decxamn247

  columns: [id, function, args, expected, description]
  rows:
    - [quantize_name,
       "Decimal.quantize.__name__.__eq__",
       ["quantize"],
       true,
       "decimal.Decimal.quantize.__name__.__eq__('quantize') == True — Decimal.quantize returns a value equal to the first operand after rounding and having the exponent of the second operand; its __name__ is 'quantize'; str.__eq__('quantize') returns True; new to extra247"]
    - [normalize_name,
       "Decimal.normalize.__name__.__eq__",
       ["normalize"],
       true,
       "decimal.Decimal.normalize.__name__.__eq__('normalize') == True — Decimal.normalize reduces the number to its simplest form by removing trailing zeros; its __name__ is 'normalize'; str.__eq__('normalize') returns True; new to extra247"]
    - [sqrt_name,
       "Decimal.sqrt.__name__.__eq__",
       ["sqrt"],
       true,
       "decimal.Decimal.sqrt.__name__.__eq__('sqrt') == True — Decimal.sqrt returns the square root of the argument to full precision; its __name__ is 'sqrt'; str.__eq__('sqrt') returns True; new to extra247"]
    - [exp_name,
       "Decimal.exp.__name__.__eq__",
       ["exp"],
       true,
       "decimal.Decimal.exp.__name__.__eq__('exp') == True — Decimal.exp returns the value of e raised to the power of the operand; its __name__ is 'exp'; str.__eq__('exp') returns True; new to extra247"]
    - [ln_name,
       "Decimal.ln.__name__.__eq__",
       ["ln"],
       true,
       "decimal.Decimal.ln.__name__.__eq__('ln') == True — Decimal.ln returns the natural (base e) logarithm of the operand; its __name__ is 'ln'; str.__eq__('ln') returns True; new to extra247"]
    - [log10_name,
       "Decimal.log10.__name__.__eq__",
       ["log10"],
       true,
       "decimal.Decimal.log10.__name__.__eq__('log10') == True — Decimal.log10 returns the base-10 logarithm of the operand; its __name__ is 'log10'; str.__eq__('log10') returns True; new to extra247"]

# ---------------------------------------------------------------------------
# Table 2: decimal.Decimal comparison and utility method __name__ identity
#
# compare, max, min, to_eng_string are comparison and formatting methods.
# All are method_descriptor objects defined in the _decimal C extension.
# ---------------------------------------------------------------------------

table decimal_extra247.decimal_comparison_method_names:
  description: "decimal.Decimal comparison and utility method __name__ identity — compare, max, min, to_eng_string; new to extra247"
  kind: python_call_eq
  category: identity
  id_prefix: decxcmn247

  columns: [id, function, args, expected, description]
  rows:
    - [compare_name,
       "Decimal.compare.__name__.__eq__",
       ["compare"],
       true,
       "decimal.Decimal.compare.__name__.__eq__('compare') == True — Decimal.compare compares two Decimal instances numerically and returns Decimal('-1'), Decimal('0'), or Decimal('1'); its __name__ is 'compare'; str.__eq__('compare') returns True; new to extra247"]
    - [max_name,
       "Decimal.max.__name__.__eq__",
       ["max"],
       true,
       "decimal.Decimal.max.__name__.__eq__('max') == True — Decimal.max returns the larger of two Decimal values (following IEEE 754 semantics); its __name__ is 'max'; str.__eq__('max') returns True; new to extra247"]
    - [min_name,
       "Decimal.min.__name__.__eq__",
       ["min"],
       true,
       "decimal.Decimal.min.__name__.__eq__('min') == True — Decimal.min returns the smaller of two Decimal values (following IEEE 754 semantics); its __name__ is 'min'; str.__eq__('min') returns True; new to extra247"]
    - [to_eng_string_name,
       "Decimal.to_eng_string.__name__.__eq__",
       ["to_eng_string"],
       true,
       "decimal.Decimal.to_eng_string.__name__.__eq__('to_eng_string') == True — Decimal.to_eng_string converts to a string using engineering notation (exponents that are multiples of 3); its __name__ is 'to_eng_string'; str.__eq__('to_eng_string') returns True; new to extra247"]
    - [compare_class,
       "Decimal.compare.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.compare.__class__.__name__.__eq__('method_descriptor') == True — Decimal.compare is a C-level method_descriptor; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra247"]
    - [to_eng_string_class,
       "Decimal.to_eng_string.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.to_eng_string.__class__.__name__.__eq__('method_descriptor') == True — Decimal.to_eng_string is a C-level method_descriptor; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra247"]

# ---------------------------------------------------------------------------
# Table 3: decimal.Decimal method __qualname__ identity
#
# All Decimal methods are defined directly on Decimal, so their __qualname__
# values carry the 'Decimal.' prefix.
# ---------------------------------------------------------------------------

table decimal_extra247.decimal_method_qualnames:
  description: "decimal.Decimal method __qualname__ identity — all use 'Decimal.' prefix; new to extra247"
  kind: python_call_eq
  category: identity
  id_prefix: decxmq247

  columns: [id, function, args, expected, description]
  rows:
    - [quantize_qualname,
       "Decimal.quantize.__qualname__.__eq__",
       ["Decimal.quantize"],
       true,
       "decimal.Decimal.quantize.__qualname__.__eq__('Decimal.quantize') == True — quantize is defined directly on Decimal; its __qualname__ is 'Decimal.quantize'; str.__eq__('Decimal.quantize') returns True; new to extra247"]
    - [normalize_qualname,
       "Decimal.normalize.__qualname__.__eq__",
       ["Decimal.normalize"],
       true,
       "decimal.Decimal.normalize.__qualname__.__eq__('Decimal.normalize') == True — normalize is defined directly on Decimal; its __qualname__ is 'Decimal.normalize'; str.__eq__('Decimal.normalize') returns True; new to extra247"]
    - [sqrt_qualname,
       "Decimal.sqrt.__qualname__.__eq__",
       ["Decimal.sqrt"],
       true,
       "decimal.Decimal.sqrt.__qualname__.__eq__('Decimal.sqrt') == True — sqrt is defined directly on Decimal; its __qualname__ is 'Decimal.sqrt'; str.__eq__('Decimal.sqrt') returns True; new to extra247"]
    - [exp_qualname,
       "Decimal.exp.__qualname__.__eq__",
       ["Decimal.exp"],
       true,
       "decimal.Decimal.exp.__qualname__.__eq__('Decimal.exp') == True — exp is defined directly on Decimal; its __qualname__ is 'Decimal.exp'; str.__eq__('Decimal.exp') returns True; new to extra247"]
    - [ln_qualname,
       "Decimal.ln.__qualname__.__eq__",
       ["Decimal.ln"],
       true,
       "decimal.Decimal.ln.__qualname__.__eq__('Decimal.ln') == True — ln is defined directly on Decimal; its __qualname__ is 'Decimal.ln'; str.__eq__('Decimal.ln') returns True; new to extra247"]
    - [log10_qualname,
       "Decimal.log10.__qualname__.__eq__",
       ["Decimal.log10"],
       true,
       "decimal.Decimal.log10.__qualname__.__eq__('Decimal.log10') == True — log10 is defined directly on Decimal; its __qualname__ is 'Decimal.log10'; str.__eq__('Decimal.log10') returns True; new to extra247"]
    - [compare_qualname,
       "Decimal.compare.__qualname__.__eq__",
       ["Decimal.compare"],
       true,
       "decimal.Decimal.compare.__qualname__.__eq__('Decimal.compare') == True — compare is defined directly on Decimal; its __qualname__ is 'Decimal.compare'; str.__eq__('Decimal.compare') returns True; new to extra247"]
    - [max_qualname,
       "Decimal.max.__qualname__.__eq__",
       ["Decimal.max"],
       true,
       "decimal.Decimal.max.__qualname__.__eq__('Decimal.max') == True — max is defined directly on Decimal; its __qualname__ is 'Decimal.max'; str.__eq__('Decimal.max') returns True; new to extra247"]
    - [min_qualname,
       "Decimal.min.__qualname__.__eq__",
       ["Decimal.min"],
       true,
       "decimal.Decimal.min.__qualname__.__eq__('Decimal.min') == True — min is defined directly on Decimal; its __qualname__ is 'Decimal.min'; str.__eq__('Decimal.min') returns True; new to extra247"]
    - [to_eng_string_qualname,
       "Decimal.to_eng_string.__qualname__.__eq__",
       ["Decimal.to_eng_string"],
       true,
       "decimal.Decimal.to_eng_string.__qualname__.__eq__('Decimal.to_eng_string') == True — to_eng_string is defined directly on Decimal; its __qualname__ is 'Decimal.to_eng_string'; str.__eq__('Decimal.to_eng_string') returns True; new to extra247"]

# ---------------------------------------------------------------------------
# Table 4: decimal.Decimal arithmetic method __class__.__name__
# — all are method_descriptor
# ---------------------------------------------------------------------------

table decimal_extra247.decimal_method_class_names:
  description: "decimal.Decimal method __class__.__name__ — all are 'method_descriptor'; new to extra247"
  kind: python_call_eq
  category: identity
  id_prefix: decxmcn247

  columns: [id, function, args, expected, description]
  rows:
    - [quantize_class,
       "Decimal.quantize.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.quantize.__class__.__name__.__eq__('method_descriptor') == True — Decimal.quantize is a C-level method_descriptor, not a Python function; str.__eq__('method_descriptor') returns True; new to extra247"]
    - [normalize_class,
       "Decimal.normalize.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.normalize.__class__.__name__.__eq__('method_descriptor') == True — Decimal.normalize is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra247"]
    - [sqrt_class,
       "Decimal.sqrt.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.sqrt.__class__.__name__.__eq__('method_descriptor') == True — Decimal.sqrt is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra247"]
    - [exp_class,
       "Decimal.exp.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.exp.__class__.__name__.__eq__('method_descriptor') == True — Decimal.exp is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra247"]
    - [ln_class,
       "Decimal.ln.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.ln.__class__.__name__.__eq__('method_descriptor') == True — Decimal.ln is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra247"]
    - [log10_class,
       "Decimal.log10.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.log10.__class__.__name__.__eq__('method_descriptor') == True — Decimal.log10 is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra247"]

# ---------------------------------------------------------------------------
# Standalone invariants — decimal_extra247
# ---------------------------------------------------------------------------

invariant decimal_extra247.decimal_quantize_name:
  description: "decimal.Decimal.quantize.__name__ == 'quantize' — quantize rounds to the exponent of the second operand; new to extra247"
  kind: python_call_eq
  function: Decimal.quantize.__name__.__eq__
  args: ["quantize"]
  expected: true

invariant decimal_extra247.decimal_sqrt_name:
  description: "decimal.Decimal.sqrt.__name__ == 'sqrt' — Decimal.sqrt returns square root to full precision; new to extra247"
  kind: python_call_eq
  function: Decimal.sqrt.__name__.__eq__
  args: ["sqrt"]
  expected: true

invariant decimal_extra247.decimal_quantize_qualname:
  description: "decimal.Decimal.quantize.__qualname__ == 'Decimal.quantize' — quantize is defined directly on Decimal; new to extra247"
  kind: python_call_eq
  function: Decimal.quantize.__qualname__.__eq__
  args: ["Decimal.quantize"]
  expected: true

invariant decimal_extra247.decimal_quantize_is_method_descriptor:
  description: "decimal.Decimal.quantize.__class__.__name__ == 'method_descriptor' — all Decimal methods are C-level method_descriptors; new to extra247"
  kind: python_call_eq
  function: Decimal.quantize.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra247.decimal_ln_name:
  description: "decimal.Decimal.ln.__name__ == 'ln' — Decimal.ln returns natural (base e) logarithm; new to extra247"
  kind: python_call_eq
  function: Decimal.ln.__name__.__eq__
  args: ["ln"]
  expected: true

invariant decimal_extra247.decimal_log10_name:
  description: "decimal.Decimal.log10.__name__ == 'log10' — Decimal.log10 returns base-10 logarithm; new to extra247"
  kind: python_call_eq
  function: Decimal.log10.__name__.__eq__
  args: ["log10"]
  expected: true

invariant decimal_extra247.decimal_to_eng_string_name:
  description: "decimal.Decimal.to_eng_string.__name__ == 'to_eng_string' — to_eng_string uses engineering notation with exponents as multiples of 3; new to extra247"
  kind: python_call_eq
  function: Decimal.to_eng_string.__name__.__eq__
  args: ["to_eng_string"]
  expected: true

invariant decimal_extra247.decimal_compare_qualname:
  description: "decimal.Decimal.compare.__qualname__ == 'Decimal.compare' — compare is defined directly on Decimal; new to extra247"
  kind: python_call_eq
  function: Decimal.compare.__qualname__.__eq__
  args: ["Decimal.compare"]
  expected: true
