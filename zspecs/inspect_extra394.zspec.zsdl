spec: inspect_extra394
version: ">=3.11"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "inspect.getattr_static.__name__ == 'getattr_static' — Python function in Lib/inspect.py; __name__ is 'getattr_static'. Verified with Python 3.14.4."
    - "inspect.getattr_static.__module__ == 'inspect' — defined in Lib/inspect.py; __module__ is 'inspect'. Verified with Python 3.14.4."
    - "inspect.getmembers_static.__name__ == 'getmembers_static' — added in Python 3.11; Python function in Lib/inspect.py. Verified with Python 3.14.4."
    - "inspect.getmembers_static.__module__ == 'inspect' — defined in Lib/inspect.py; __module__ is 'inspect'. Verified with Python 3.14.4."
    - "inspect.getmro.__name__ == 'getmro' — Python function in Lib/inspect.py. Verified with Python 3.14.4."
    - "inspect.getmro.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.4."
    - "inspect.formatargvalues.__name__ == 'formatargvalues' — Python function in Lib/inspect.py. Verified with Python 3.14.4."
    - "inspect.formatargvalues.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.4."
    - "inspect.formatargspec was removed in Python 3.11 — it is no longer present in the inspect module as of 3.11. Verified with Python 3.14.4."
    - "version: >=3.11 required for getmembers_static (added in 3.11) and absence of formatargspec (removed in 3.11)."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect function __name__ identity
#
# getattr_static, getmembers_static, getmro, and formatargvalues are all
# Python functions defined in Lib/inspect.py. Their __name__ equals the
# bare function name with no qualifying prefix.
# ---------------------------------------------------------------------------

table inspect_extra394.function_name:
  description: "inspect function __name__ values — plain Python functions in Lib/inspect.py; new to extra394"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectfn394

  columns: [id, function, args, expected, description]
  rows:
    - [getattr_static_name_eq,
       "getattr_static.__name__.__eq__",
       ["getattr_static"],
       true,
       "inspect.getattr_static.__name__.__eq__('getattr_static') == True — getattr_static is a Python function in Lib/inspect.py; __name__ is 'getattr_static'; str.__eq__('getattr_static') returns True; new to extra394"]
    - [getmembers_static_name_eq,
       "getmembers_static.__name__.__eq__",
       ["getmembers_static"],
       true,
       "inspect.getmembers_static.__name__.__eq__('getmembers_static') == True — getmembers_static was added in Python 3.11 in Lib/inspect.py; __name__ is 'getmembers_static'; str.__eq__('getmembers_static') returns True; new to extra394"]
    - [getmro_name_eq,
       "getmro.__name__.__eq__",
       ["getmro"],
       true,
       "inspect.getmro.__name__.__eq__('getmro') == True — getmro is a Python function in Lib/inspect.py; __name__ is 'getmro'; str.__eq__('getmro') returns True; new to extra394"]
    - [formatargvalues_name_eq,
       "formatargvalues.__name__.__eq__",
       ["formatargvalues"],
       true,
       "inspect.formatargvalues.__name__.__eq__('formatargvalues') == True — formatargvalues is a Python function in Lib/inspect.py; __name__ is 'formatargvalues'; str.__eq__('formatargvalues') returns True; new to extra394"]

# ---------------------------------------------------------------------------
# Table 2: inspect function __module__ identity
#
# All four functions are defined in Lib/inspect.py and thus carry
# __module__ == 'inspect'.
# ---------------------------------------------------------------------------

table inspect_extra394.function_module:
  description: "inspect function __module__ values — all defined in Lib/inspect.py; new to extra394"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectfm394

  columns: [id, function, args, expected, description]
  rows:
    - [getattr_static_module_eq,
       "getattr_static.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getattr_static.__module__.__eq__('inspect') == True — getattr_static is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra394"]
    - [getmembers_static_module_eq,
       "getmembers_static.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getmembers_static.__module__.__eq__('inspect') == True — getmembers_static is defined in Lib/inspect.py (added 3.11); __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra394"]
    - [getmro_module_eq,
       "getmro.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getmro.__module__.__eq__('inspect') == True — getmro is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra394"]
    - [formatargvalues_module_eq,
       "formatargvalues.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.formatargvalues.__module__.__eq__('inspect') == True — formatargvalues is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra394"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra394
# ---------------------------------------------------------------------------

invariant inspect_extra394.getattr_static_name:
  description: "inspect.getattr_static.__name__ == 'getattr_static' — Python function in Lib/inspect.py; new to extra394"
  kind: python_call_eq
  function: getattr_static.__name__.__eq__
  args: ["getattr_static"]
  expected: true

invariant inspect_extra394.getattr_static_module:
  description: "inspect.getattr_static.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra394"
  kind: python_call_eq
  function: getattr_static.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra394.getmembers_static_name:
  description: "inspect.getmembers_static.__name__ == 'getmembers_static' — Python function added in 3.11; new to extra394"
  kind: python_call_eq
  function: getmembers_static.__name__.__eq__
  args: ["getmembers_static"]
  expected: true

invariant inspect_extra394.getmembers_static_module:
  description: "inspect.getmembers_static.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra394"
  kind: python_call_eq
  function: getmembers_static.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra394.getmro_name:
  description: "inspect.getmro.__name__ == 'getmro' — Python function in Lib/inspect.py; new to extra394"
  kind: python_call_eq
  function: getmro.__name__.__eq__
  args: ["getmro"]
  expected: true

invariant inspect_extra394.getmro_module:
  description: "inspect.getmro.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra394"
  kind: python_call_eq
  function: getmro.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra394.formatargvalues_name:
  description: "inspect.formatargvalues.__name__ == 'formatargvalues' — Python function in Lib/inspect.py; new to extra394"
  kind: python_call_eq
  function: formatargvalues.__name__.__eq__
  args: ["formatargvalues"]
  expected: true

invariant inspect_extra394.formatargvalues_module:
  description: "inspect.formatargvalues.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra394"
  kind: python_call_eq
  function: formatargvalues.__module__.__eq__
  args: ["inspect"]
  expected: true
