spec: asyncio_extra78
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "This spec extends asyncio_extra77.zspec.zsdl."
    - "This spec covers: wave 244 theme — asyncio BoundedSemaphore.__dict__ content + create_task/sleep code attributes. NEW in extra78: BoundedSemaphore.__dict__.__class__.__name__=='mappingproxy'; BoundedSemaphore.__dict__.__contains__('acquire')==False (BoundedSemaphore does NOT override acquire — only release is overridden to enforce the bound); BoundedSemaphore.__dict__.__contains__('release')==True; asyncio.create_task.__class__.__name__=='function'; asyncio.create_task.__code__.co_name=='create_task'; asyncio.create_task.__code__.co_argcount==1 (coro; name and context are keyword-only); asyncio.sleep.__class__.__name__=='function'; asyncio.sleep.__code__.co_name=='sleep'; asyncio.sleep.__code__.co_argcount==2 (delay and result are both positional; loop was removed in Python 3.10). NOTE: BoundedSemaphore does NOT override acquire — verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.__dict__.__class__.__name__ == 'mappingproxy'. BoundedSemaphore is a Python class in asyncio/locks.py; its __dict__ is a read-only mappingproxy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.__dict__.__contains__('acquire') == False. BoundedSemaphore does NOT override acquire; it inherits acquire from Semaphore. Only release is overridden to enforce the upper bound. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.__dict__.__contains__('release') == True. BoundedSemaphore defines its own release() to enforce the bound (raises ValueError if count exceeds initial value). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.create_task.__class__.__name__ == 'function'. create_task is a plain Python function in asyncio/tasks.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.create_task.__code__.co_name == 'create_task'. The code object co_name matches the function name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.create_task.__code__.co_argcount == 1. Only coro is a positional parameter; name and context are keyword-only (co_kwonlyargcount). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__class__.__name__ == 'function'. sleep is a coroutine function (still has __class__.__name__ == 'function') in asyncio/tasks.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__code__.co_name == 'sleep'. The code object co_name matches the function name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__code__.co_argcount == 2. Both delay and result are positional parameters (sleep(delay, result=None)); the loop parameter was removed in Python 3.10. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio BoundedSemaphore.__dict__ class name and release method — extra78
#
# Wave 244 theme: BoundedSemaphore.__dict__ content.
#
# BoundedSemaphore.__dict__.__class__.__name__ == 'mappingproxy'
# BoundedSemaphore.__dict__.__contains__('release') == True
# BoundedSemaphore.__dict__.__contains__('acquire') == False
# ---------------------------------------------------------------------------

table asyncio_extra78.BoundedSemaphore_dict_content:
  description: "asyncio BoundedSemaphore.__dict__ class name and method content checks in asynciomore78 namespace — wave 244 theme: BoundedSemaphore.__dict__ content; BoundedSemaphore.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is read-only mappingproxy in CPython); BoundedSemaphore.__dict__.__contains__('release')==True (BoundedSemaphore overrides release to enforce upper bound); BoundedSemaphore.__dict__.__contains__('acquire')==False (acquire is NOT overridden — inherited from Semaphore); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: asynciomore78

  columns: [id, function, args, expected, description]
  rows:
    - [bs_dict_class_name,    BoundedSemaphore.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true,  "BoundedSemaphore.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy in CPython; verified with Python 3.14.3"]
    - [bs_dict_has_release,   BoundedSemaphore.__dict__.__contains__,              ["release"],      true,  "BoundedSemaphore.__dict__.__contains__('release') == True — BoundedSemaphore overrides release to enforce upper bound; verified with Python 3.14.3"]
    - [bs_dict_has_acquire,   BoundedSemaphore.__dict__.__contains__,              ["acquire"],      false, "BoundedSemaphore.__dict__.__contains__('acquire') == False — BoundedSemaphore does NOT override acquire; inherits from Semaphore; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio create_task class name and code attributes — extra78
#
# asyncio.create_task.__class__.__name__ == 'function'
# asyncio.create_task.__code__.co_name == 'create_task'
# asyncio.create_task.__code__.co_argcount == 1
# ---------------------------------------------------------------------------

table asyncio_extra78.create_task_code_attrs:
  description: "asyncio create_task class name and code attribute checks in asynciomore78 namespace — wave 244 theme: create_task/sleep code attributes; create_task.__class__.__name__=='function' (plain Python function in asyncio/tasks.py); create_task.__code__.co_name=='create_task' (code object co_name matches function name); create_task.__code__.co_argcount==1 (only coro is positional; name and context are keyword-only); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asynciomore78a

  columns: [id, function, args, expected, description]
  rows:
    - [create_task_class_name,  create_task.__class__.__name__.__eq__,  ["function"],    true, "create_task.__class__.__name__ == 'function' — create_task is a plain Python function in asyncio/tasks.py; verified with Python 3.14.3"]
    - [create_task_co_name,     create_task.__code__.co_name.__eq__,    ["create_task"], true, "create_task.__code__.co_name == 'create_task' — code object co_name matches the function name; verified with Python 3.14.3"]
    - [create_task_co_argcount, create_task.__code__.co_argcount.__eq__, [1],             true, "create_task.__code__.co_argcount == 1 — only coro is positional; name and context are keyword-only parameters; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
