# ---------------------------------------------------------------------------

table asyncio_extra78.sleep_code_attrs:
  description: "asyncio sleep class name and code attribute checks in asynciomore78 namespace — wave 244 theme: sleep code attributes; sleep.__class__.__name__=='function'; sleep.__code__.co_name=='sleep'; sleep.__code__.co_argcount==2 (both delay and result are positional; loop was removed in Python 3.10); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asynciomore78b

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_class_name,  sleep.__class__.__name__.__eq__,  ["function"], true, "sleep.__class__.__name__ == 'function' — sleep is a coroutine function in asyncio/tasks.py; verified with Python 3.14.3"]
    - [sleep_co_name,     sleep.__code__.co_name.__eq__,    ["sleep"],    true, "sleep.__code__.co_name == 'sleep' — code object co_name matches the function name; verified with Python 3.14.3"]
    - [sleep_co_argcount, sleep.__code__.co_argcount.__eq__, [2],          true, "sleep.__code__.co_argcount == 2 — delay and result are both positional; loop was removed in Python 3.10; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio BoundedSemaphore dict + create_task/sleep cross-check — extra78
# ---------------------------------------------------------------------------

table asyncio_extra78.BoundedSemaphore_and_task_sleep_cross_check:
  description: "asyncio BoundedSemaphore.__dict__ and create_task/sleep code attribute cross-check in asynciomore78 namespace — wave 244 theme: cross-check of BoundedSemaphore dict content with create_task/sleep code attributes; BoundedSemaphore.__dict__.__class__.__name__=='mappingproxy'; BoundedSemaphore.__dict__.__contains__('release')==True; create_task.__code__.co_name=='create_task'; sleep.__code__.co_name=='sleep'; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: asynciomore78c

  columns: [id, function, args, expected, description]
  rows:
    - [bs_dict_cls_cross,       BoundedSemaphore.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "BoundedSemaphore.__dict__.__class__.__name__ == 'mappingproxy' — cross-check; verified with Python 3.14.3"]
    - [bs_dict_release_cross,   BoundedSemaphore.__dict__.__contains__,              ["release"],      true, "BoundedSemaphore.__dict__.__contains__('release') == True — cross-check; verified with Python 3.14.3"]
    - [create_task_name_cross,  create_task.__code__.co_name.__eq__,                 ["create_task"],  true, "create_task.__code__.co_name == 'create_task' — cross-check; verified with Python 3.14.3"]
    - [sleep_name_cross,        sleep.__code__.co_name.__eq__,                       ["sleep"],        true, "sleep.__code__.co_name == 'sleep' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra78
# ---------------------------------------------------------------------------

invariant asyncio_extra78.BoundedSemaphore_dict_class_name:
  description: "asyncio.BoundedSemaphore.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — BoundedSemaphore is a Python class in asyncio/locks.py; class __dict__ objects are always mappingproxy in CPython; NEW in extra78: first standalone __dict__.__class__.__name__ invariant for BoundedSemaphore in asynciomore78 namespace; wave 244; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: BoundedSemaphore.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant asyncio_extra78.BoundedSemaphore_dict_has_release:
  description: "asyncio.BoundedSemaphore.__dict__.__contains__('release') returns True — BoundedSemaphore defines its own release() to enforce the upper bound (raises ValueError if count exceeds initial value); NEW in extra78: first standalone __contains__('release') invariant for BoundedSemaphore.__dict__ in asynciomore78 namespace; wave 244; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: BoundedSemaphore.__dict__.__contains__
  args: ["release"]
  expected: true

invariant asyncio_extra78.BoundedSemaphore_dict_no_acquire:
  description: "asyncio.BoundedSemaphore.__dict__.__contains__('acquire') returns False — BoundedSemaphore does NOT override acquire; it inherits acquire from Semaphore; only release is overridden to enforce the upper bound; NEW in extra78: first standalone __contains__('acquire')==False invariant for BoundedSemaphore.__dict__ in asynciomore78 namespace; wave 244; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: BoundedSemaphore.__dict__.__contains__
  args: ["acquire"]
  expected: false

invariant asyncio_extra78.create_task_co_argcount:
  description: "asyncio.create_task.__code__.co_argcount.__eq__(1) returns True — only coro is a positional parameter; name and context are keyword-only (counted in co_kwonlyargcount not co_argcount); NEW in extra78: first standalone co_argcount invariant for create_task in asynciomore78 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: create_task.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant asyncio_extra78.sleep_co_argcount:
  description: "asyncio.sleep.__code__.co_argcount.__eq__(2) returns True — both delay and result are positional parameters; sleep(delay, result=None); the loop parameter was removed in Python 3.10; NEW in extra78: first standalone co_argcount invariant for sleep in asynciomore78 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: sleep.__code__.co_argcount.__eq__
  args: [2]
  expected: true
