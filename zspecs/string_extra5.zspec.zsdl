spec: string_extra5
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl, string_extra.zspec.zsdl, string_extra2.zspec.zsdl, and string_extra4.zspec.zsdl."
    - "string.zspec.zsdl: constant lengths, constant __contains__ checks, capwords basic/sep tables."
    - "string_extra.zspec.zsdl: Formatter.__name__/__module__, Template.__name__/__module__, capwords.__name__, constant type-is-str table, digits/ascii_lowercase lengths."
    - "string_extra2.zspec.zsdl: Formatter __name__/__module__/__bases__, Template __name__/__module__/__bases__, capwords.__module__, ascii_letters length, whitespace contains newline, printable/punctuation lengths, octdigits/hexdigits values."
    - "string_extra4.zspec.zsdl: Formatter.__name__/Template.__name__ table, Formatter.__module__/Template.__module__ table, digits/hexdigits/octdigits values, ascii_lowercase/ascii_uppercase/ascii_letters/digits/punctuation lengths, Formatter().format method name, Template.__name__ invariant."
    - "Focus: Template.__qualname__; Formatter.__qualname__; capwords.__qualname__; exact values for ascii_uppercase and ascii_lowercase; membership checks for digits and ascii_uppercase; capwords with internal double-space."
    - "string.Template.__qualname__ == 'Template' — module-level class has a flat qualname."
    - "string.Formatter.__qualname__ == 'Formatter' — module-level class has a flat qualname."
    - "string.capwords.__qualname__ == 'capwords' — module-level function has a flat qualname."
    - "string.ascii_uppercase == 'ABCDEFGHIJKLMNOPQRSTUVWXYZ' — exact value (length covered in prior specs)."
    - "string.ascii_lowercase == 'abcdefghijklmnopqrstuvwxyz' — exact value (length covered in prior specs)."
    - "string.digits.__contains__('5') == True — '5' is in the digits string."
    - "string.ascii_uppercase.__contains__('Z') == True — 'Z' is the last uppercase letter."
    - "string.ascii_uppercase.__contains__('a') == False — lowercase not in uppercase set."
    - "string.capwords('hello  world') == 'Hello World' — double internal space collapses to single space."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Template and Formatter — __qualname__
# ---------------------------------------------------------------------------

invariant string_extra5.Template.qualname:
  description: "string.Template.__qualname__ == 'Template' — flat qualname for module-level class"
  category: class_identity
  kind: python_call_eq
  function: Template.__qualname__.__eq__
  args: ["Template"]
  expected: true

invariant string_extra5.Formatter.qualname:
  description: "string.Formatter.__qualname__ == 'Formatter' — flat qualname for module-level class"
  category: class_identity
  kind: python_call_eq
  function: Formatter.__qualname__.__eq__
  args: ["Formatter"]
  expected: true

# ---------------------------------------------------------------------------
# capwords — __qualname__
# ---------------------------------------------------------------------------

invariant string_extra5.capwords.qualname:
  description: "string.capwords.__qualname__ == 'capwords' — flat qualname for module-level function"
  category: function_identity
  kind: python_call_eq
  function: capwords.__qualname__.__eq__
  args: ["capwords"]
  expected: true

# ---------------------------------------------------------------------------
# ascii_uppercase — exact value
#
# string_extra4 covers ascii_uppercase.__len__ == 26.
# We add the exact string value comparison.
# ---------------------------------------------------------------------------

invariant string_extra5.ascii_uppercase.exact_value:
  description: "string.ascii_uppercase == 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'"
  category: constants
  kind: python_call_eq
  function: ascii_uppercase.__eq__
  args: ["ABCDEFGHIJKLMNOPQRSTUVWXYZ"]
  expected: true

# ---------------------------------------------------------------------------
# ascii_lowercase — exact value
#
# string.zspec.zsdl and string_extra cover only length (26) and __contains__.
# We add the exact string value comparison.
# ---------------------------------------------------------------------------

invariant string_extra5.ascii_lowercase.exact_value:
  description: "string.ascii_lowercase == 'abcdefghijklmnopqrstuvwxyz'"
  category: constants
  kind: python_call_eq
  function: ascii_lowercase.__eq__
  args: ["abcdefghijklmnopqrstuvwxyz"]
  expected: true

# ---------------------------------------------------------------------------
# Membership checks — digits and ascii_uppercase
#
# string.zspec.zsdl covers contains for lowercase/digits/hexdigits/octdigits.
# We add new membership vectors for digits and ascii_uppercase.
# ---------------------------------------------------------------------------

table string_extra5.constants.extra_contains:
  kind: python_call_eq
  category: constants
  id_prefix: contains

  columns: [id, function, args, expected]
  rows:
    - [digits_has_5,          digits.__contains__,          ["5"],  true]
    - [digits_has_1,          digits.__contains__,          ["1"],  true]
    - [ascii_uppercase_has_Z, ascii_uppercase.__contains__,  ["Z"],  true]
    - [ascii_uppercase_not_a, ascii_uppercase.__contains__,  ["a"],  false]
    - [ascii_uppercase_has_A, ascii_uppercase.__contains__,  ["A"],  true]

# ---------------------------------------------------------------------------
# capwords — internal double-space collapses to single space
#
# string.zspec.zsdl covers: extra_spaces = '  hello  world  ' → 'Hello World'.
# We add 'hello  world' (double space in the middle, no leading/trailing) as a
# distinct input that confirms the same collapsing behaviour.
# ---------------------------------------------------------------------------

invariant string_extra5.capwords.double_internal_space:
  description: "string.capwords('hello  world') == 'Hello World' — double internal space collapses"
  category: capwords
  kind: python_call_eq
  function: capwords
  args: ["hello  world"]
  expected: "Hello World"

# ---------------------------------------------------------------------------
# capwords — single-word input
#
# string.zspec.zsdl covers single_word = ['hello'] → 'Hello'.
# We add an uppercase single word to confirm case normalisation on one word.
# ---------------------------------------------------------------------------

invariant string_extra5.capwords.uppercase_single_word:
  description: "string.capwords('PYTHON') == 'Python' — single uppercase word is title-cased"
  category: capwords
  kind: python_call_eq
  function: capwords
  args: ["PYTHON"]
  expected: "Python"

# ---------------------------------------------------------------------------
# Formatter — class type check
# ---------------------------------------------------------------------------

invariant string_extra5.Formatter.is_type:
  description: "string.Formatter.__class__.__name__ == 'type' — Formatter is a plain Python class"
  category: class_identity
  kind: python_call_eq
  function: Formatter.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Template — class type check
# ---------------------------------------------------------------------------

invariant string_extra5.Template.is_type:
  description: "string.Template.__class__.__name__ == 'type' — Template is a plain Python class"
  category: class_identity
  kind: python_call_eq
  function: Template.__class__.__name__.__eq__
  args: ["type"]
  expected: true
