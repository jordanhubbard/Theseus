spec: re_extra76
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra75."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; Pattern/Match method qualnames; re.error.__name__ == 'PatternError'; re.error.__bases__[0].__name__ == 'Exception'."
    - "re_extra75 covers Pattern/Match method __qualname__ values; Pattern/Match __dict__.__class__.__name__; re.error __name__ and base."
    - "This spec covers: re module-level function __code__ attributes — co_name and co_argcount for compile/match/search/sub/split/findall/finditer/subn/fullmatch."
    - "re.compile.__code__.co_name == 'compile' — re functions are Python wrappers in Lib/re/__init__.py."
    - "re.compile.__code__.co_argcount == 2 — compile(pattern, flags=0): both are positional-or-keyword."
    - "re.match.__code__.co_name == 'match' — wrapper function name confirmed by code object."
    - "re.match.__code__.co_argcount == 3 — match(pattern, string, flags=0): three positional-or-keyword."
    - "re.search.__code__.co_argcount == 3 — search(pattern, string, flags=0): three positional-or-keyword."
    - "re.sub.__code__.co_argcount == 3 — sub(pattern, repl, string, count=0, flags=0): co_argcount counts only positional-or-keyword (not kw-only): 3 here (count/flags have defaults)."
    - "re.split.__code__.co_argcount == 2 — split(pattern, string, maxsplit=0, flags=0): 2 positional without defaults."
    - "re.findall.__code__.co_argcount == 3 — findall(pattern, string, flags=0)."
    - "re.finditer.__code__.co_argcount == 3 — finditer(pattern, string, flags=0)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile and re.match __code__ attributes
# Both are Python wrapper functions in Lib/re/__init__.py and carry __code__.
# compile(pattern, flags=0): co_argcount == 2.
# match(pattern, string, flags=0): co_argcount == 3.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra76.compile_match_code:
  description: "re.compile and re.match __code__ co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: remore76

  columns: [id, function, args, expected]
  rows:
    - [compile_co_name,  compile.__code__.co_name.__eq__,     ["compile"], true]
    - [compile_co_argc,  compile.__code__.co_argcount.__eq__,  [2],        true]
    - [match_co_name,    match.__code__.co_name.__eq__,        ["match"],  true]
    - [match_co_argc,    match.__code__.co_argcount.__eq__,    [3],        true]

# ---------------------------------------------------------------------------
# re.search and re.fullmatch __code__ attributes
# search(pattern, string, flags=0): co_argcount == 3.
# fullmatch(pattern, string, flags=0): co_argcount == 3.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra76.search_fullmatch_code:
  description: "re.search and re.fullmatch __code__ co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: remore76

  columns: [id, function, args, expected]
  rows:
    - [search_co_name,    search.__code__.co_name.__eq__,        ["search"],    true]
    - [search_co_argc,    search.__code__.co_argcount.__eq__,    [3],           true]
    - [fullmatch_co_name, fullmatch.__code__.co_name.__eq__,     ["fullmatch"], true]
    - [fullmatch_co_argc, fullmatch.__code__.co_argcount.__eq__, [3],           true]

# ---------------------------------------------------------------------------
# re.findall and re.finditer __code__ attributes
# findall(pattern, string, flags=0): co_argcount == 3.
# finditer(pattern, string, flags=0): co_argcount == 3.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra76.findall_finditer_code:
  description: "re.findall and re.finditer __code__ co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: remore76

  columns: [id, function, args, expected]
  rows:
    - [findall_co_name,  findall.__code__.co_name.__eq__,    ["findall"],  true]
    - [findall_co_argc,  findall.__code__.co_argcount.__eq__, [3],         true]
    - [finditer_co_name, finditer.__code__.co_name.__eq__,   ["finditer"], true]
    - [finditer_co_argc, finditer.__code__.co_argcount.__eq__, [3],        true]

# ---------------------------------------------------------------------------
# re.sub, re.subn, and re.split __code__ attributes
# sub(pattern, repl, string, count=0, flags=0): co_argcount == 3 (count/flags
#   have defaults but are still positional-or-keyword, not keyword-only).
# subn has the same signature as sub: co_argcount == 3.
# split(pattern, string, maxsplit=0, flags=0): co_argcount == 2 (first two
#   have no default; maxsplit/flags are positional-or-keyword with defaults).
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra76.sub_subn_split_code:
  description: "re.sub, re.subn, and re.split __code__ co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: remore76

  columns: [id, function, args, expected]
  rows:
    - [sub_co_name,    sub.__code__.co_name.__eq__,     ["sub"],   true]
    - [sub_co_argc,    sub.__code__.co_argcount.__eq__,  [3],      true]
    - [subn_co_name,   subn.__code__.co_name.__eq__,    ["subn"],  true]
    - [subn_co_argc,   subn.__code__.co_argcount.__eq__, [3],      true]
    - [split_co_name,  split.__code__.co_name.__eq__,   ["split"], true]
    - [split_co_argc,  split.__code__.co_argcount.__eq__, [2],     true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra76.compile_code.co_name:
  description: "re.compile.__code__.co_name == 'compile'"
  category: code_attrs
  kind: python_call_eq
  function: compile.__code__.co_name.__eq__
  args: ["compile"]
  expected: true

invariant re_extra76.compile_code.co_argcount:
  description: "re.compile.__code__.co_argcount == 2 (pattern, flags=0)"
  category: code_attrs
  kind: python_call_eq
  function: compile.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant re_extra76.match_code.co_argcount:
  description: "re.match.__code__.co_argcount == 3 (pattern, string, flags=0)"
  category: code_attrs
  kind: python_call_eq
  function: match.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant re_extra76.sub_code.co_name:
  description: "re.sub.__code__.co_name == 'sub'"
  category: code_attrs
  kind: python_call_eq
  function: sub.__code__.co_name.__eq__
  args: ["sub"]
  expected: true

invariant re_extra76.split_code.co_argcount:
  description: "re.split.__code__.co_argcount == 2 (pattern, string; maxsplit/flags have defaults)"
  category: code_attrs
  kind: python_call_eq
  function: split.__code__.co_argcount.__eq__
  args: [2]
  expected: true
