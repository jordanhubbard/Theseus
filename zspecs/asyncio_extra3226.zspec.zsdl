spec: as3226
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 662 (as3226): __radd__, __rsub__, __rmul__ dict-presence (reflected arithmetic) for asyncio types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: asyncio.Task, asyncio.Future, asyncio.Event, asyncio.Lock, asyncio.Semaphore, asyncio.BoundedSemaphore, asyncio.Condition, asyncio.Queue, asyncio.PriorityQueue, asyncio.LifoQueue."
    - "Key finding (__radd__): all 10 asyncio classes return false for __radd__. The reflected addition operator __radd__ is invoked when the left operand does not support addition with the right operand. asyncio types are coroutine-based concurrency primitives — not numeric or sequence types. None define __add__ (confirmed in wave 658), so there is no reflected counterpart to define either. asyncio.Event/Lock/Condition are boolean-state synchronization objects; n + event is not a defined operation. asyncio.Semaphore/BoundedSemaphore manage a permit counter, but that counter is fully encapsulated; reflected addition is not exposed. asyncio.Task/Future are pending coroutine result handles; reflected addition is undefined. asyncio.Queue/PriorityQueue/LifoQueue are ordered item stores; n + queue is not defined."
    - "Key finding (__rsub__): all 10 asyncio classes return false for __rsub__. Reflected subtraction (__rsub__) is invoked when the left operand's __sub__ returns NotImplemented. asyncio types define neither __sub__ (confirmed false in wave 658) nor __rsub__. There is no arithmetic data model for asyncio concurrency primitives — neither left-side nor right-side subtraction is defined."
    - "Key finding (__rmul__): all 10 asyncio classes return false for __rmul__. Reflected multiplication (__rmul__) is invoked when the left operand does not support multiplication. asyncio types define no __mul__ (confirmed false in wave 658), so __rmul__ is equally absent. No asyncio type implements sequence repetition (n * container) or numeric multiplication. asyncio.Queue is an ordered store but does not support * repetition the way list does."
    - "Continues the all-false pattern from wave 661 (__and__/__or__/__xor__). asyncio is a pure coroutine concurrency library; its types interact exclusively through await, async with, async for, and explicit method calls — never through Python's arithmetic data model, including reflected arithmetic."
    - "Cross-wave summary for asyncio subjects:"
    - "  Wave 652 (as3076): __get__ — Task/Future/Queue/Handle true; others false."
    - "  Wave 653 (as3091): __hash__/__eq__/__bool__ — selected true."
    - "  Wave 654 (as3106): __lt__/__le__/__gt__ — TimerHandle true; others false."
    - "  Wave 655 (as3121): __ge__ — TimerHandle true; __repr__ — 12 classes true."
    - "  Wave 656 (as3136): __call__/__len__/__getitem__ — all false for all 14."
    - "  Wave 657 (as3151): __setitem__/__delitem__/__contains__ — all false for all 14."
    - "  Wave 658 (as3166): __add__/__sub__/__mul__ — all false for all 14."
    - "  Wave 659 (as3181): __truediv__/__floordiv__/__mod__ — all false for all 14."
    - "  Wave 660 (as3196): __pow__/__lshift__/__rshift__ — all false for all 10."
    - "  Wave 661 (as3211): __and__/__or__/__xor__ — all false for all 10."
    - "  Wave 662 (as3226): __radd__/__rsub__/__rmul__ — all false for all 10."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __radd__ dict-presence — operator.contains(Cls.__dict__, '__radd__')
#
# All 10 asyncio classes return false for __radd__.
# asyncio types are coroutine-based concurrency primitives, not numeric
#   or sequence types. None define __add__ (wave 658), so there is no
#   reflected counterpart either.
# asyncio.Event/Lock/Condition: boolean-state synchronization objects;
#   n + event is not a defined operation.
# asyncio.Semaphore/BoundedSemaphore: permit-counter objects; reflected
#   addition is not exposed through any part of their API.
# asyncio.Task/Future: pending coroutine result handles; arithmetic is
#   entirely absent.
# asyncio.Queue/PriorityQueue/LifoQueue: ordered item stores with no
#   sequence-repetition or numeric protocol of any kind.
# ---------------------------------------------------------------------------

table as3226.radd:
  description: "asyncio types __radd__ dict-presence checks; wave 662"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: as3226

  columns: [id, function, args, expected]
  rows:
    - ["as3226001", operator.contains, [asyncio.Task.__dict__,             "__radd__"], false]
    - ["as3226002", operator.contains, [asyncio.Future.__dict__,           "__radd__"], false]
    - ["as3226003", operator.contains, [asyncio.Event.__dict__,            "__radd__"], false]
    - ["as3226004", operator.contains, [asyncio.Lock.__dict__,             "__radd__"], false]
    - ["as3226005", operator.contains, [asyncio.Semaphore.__dict__,        "__radd__"], false]
    - ["as3226006", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__radd__"], false]
    - ["as3226007", operator.contains, [asyncio.Condition.__dict__,        "__radd__"], false]
    - ["as3226008", operator.contains, [asyncio.Queue.__dict__,            "__radd__"], false]
    - ["as3226009", operator.contains, [asyncio.PriorityQueue.__dict__,    "__radd__"], false]
    - ["as3226010", operator.contains, [asyncio.LifoQueue.__dict__,        "__radd__"], false]

# ---------------------------------------------------------------------------
# __rsub__ dict-presence — operator.contains(Cls.__dict__, '__rsub__')
#
# All 10 asyncio classes return false for __rsub__.
# Reflected subtraction (__rsub__) is the mirror of __sub__; it is invoked
#   when the left operand's __sub__ returns NotImplemented. asyncio types
#   define neither __sub__ (confirmed false in wave 658) nor __rsub__.
# asyncio.Event/Lock/Condition: boolean-state synchronization guards;
#   n - event is not a defined Python expression.
# asyncio.Semaphore/BoundedSemaphore: permit-counter types; the counter is
#   entirely encapsulated behind acquire()/release() coroutines.
# asyncio.Task/Future: pending coroutine results; subtraction is undefined
#   from either side of the operator.
# asyncio.Queue/PriorityQueue/LifoQueue: FIFO/priority/LIFO data structures
#   with no arithmetic semantics of any kind.
# ---------------------------------------------------------------------------

table as3226.rsub:
  description: "asyncio types __rsub__ dict-presence checks; wave 662"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: as3226

  columns: [id, function, args, expected]
  rows:
    - ["as3226011", operator.contains, [asyncio.Task.__dict__,             "__rsub__"], false]
    - ["as3226012", operator.contains, [asyncio.Future.__dict__,           "__rsub__"], false]
    - ["as3226013", operator.contains, [asyncio.Event.__dict__,            "__rsub__"], false]
    - ["as3226014", operator.contains, [asyncio.Lock.__dict__,             "__rsub__"], false]
    - ["as3226015", operator.contains, [asyncio.Semaphore.__dict__,        "__rsub__"], false]
    - ["as3226016", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__rsub__"], false]
    - ["as3226017", operator.contains, [asyncio.Condition.__dict__,        "__rsub__"], false]
    - ["as3226018", operator.contains, [asyncio.Queue.__dict__,            "__rsub__"], false]
    - ["as3226019", operator.contains, [asyncio.PriorityQueue.__dict__,    "__rsub__"], false]
    - ["as3226020", operator.contains, [asyncio.LifoQueue.__dict__,        "__rsub__"], false]

# ---------------------------------------------------------------------------
# __rmul__ dict-presence — operator.contains(Cls.__dict__, '__rmul__')
#
# All 10 asyncio classes return false for __rmul__.
# Reflected multiplication (__rmul__) is invoked when the left operand does
#   not support * with the right operand — e.g., n * obj triggers obj.__rmul__(n).
# asyncio types define no __mul__ (confirmed false in wave 658), so __rmul__
#   is equally absent. No asyncio type implements sequence repetition or
#   numeric multiplication.
# asyncio.Queue/PriorityQueue/LifoQueue: ordered stores, but they do not
#   support n * queue repetition the way list supports n * list.
# asyncio.Event/Lock/Condition/Semaphore/BoundedSemaphore: synchronization
#   primitives with no multiplication semantics.
# asyncio.Task/Future: pending result handles; n * future is undefined.
# ---------------------------------------------------------------------------

table as3226.rmul:
  description: "asyncio types __rmul__ dict-presence checks; wave 662"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: as3226

  columns: [id, function, args, expected]
  rows:
    - ["as3226021", operator.contains, [asyncio.Task.__dict__,             "__rmul__"], false]
    - ["as3226022", operator.contains, [asyncio.Future.__dict__,           "__rmul__"], false]
    - ["as3226023", operator.contains, [asyncio.Event.__dict__,            "__rmul__"], false]
    - ["as3226024", operator.contains, [asyncio.Lock.__dict__,             "__rmul__"], false]
    - ["as3226025", operator.contains, [asyncio.Semaphore.__dict__,        "__rmul__"], false]
    - ["as3226026", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__rmul__"], false]
    - ["as3226027", operator.contains, [asyncio.Condition.__dict__,        "__rmul__"], false]
    - ["as3226028", operator.contains, [asyncio.Queue.__dict__,            "__rmul__"], false]
    - ["as3226029", operator.contains, [asyncio.PriorityQueue.__dict__,    "__rmul__"], false]
    - ["as3226030", operator.contains, [asyncio.LifoQueue.__dict__,        "__rmul__"], false]

# ---------------------------------------------------------------------------
# combined — __radd__, __rsub__, __rmul__ across all 10 asyncio subjects
#
# Covers the full matrix: 10 classes x 3 methods = 30 rows.
# __radd__: false for all 10 — reflected addition is not defined.
# __rsub__: false for all 10 — reflected subtraction is not defined.
# __rmul__: false for all 10 — reflected multiplication is not defined.
# All 30 values are false.
# asyncio types are designed for coroutine-based concurrency — their entire
#   API surface is expressed through await, async with, async for, and
#   explicit method calls. Neither forward nor reflected arithmetic operators
#   appear anywhere in the asyncio type hierarchy.
# asyncio.Queue note: Queue is an ordered item store, but it does not
#   support sequence-repetition (n * queue). Neither __mul__ (wave 658) nor
#   __rmul__ (this wave) are defined. PriorityQueue and LifoQueue are the same.
# asyncio.Semaphore note: the permit counter is a positive integer, but
#   it is fully encapsulated. Reflected arithmetic on the semaphore itself
#   is not exposed.
# This wave continues the unbroken all-false run from wave 656 (__call__/
#   __len__/__getitem__) through wave 662 (__radd__/__rsub__/__rmul__) —
#   seven consecutive waves of 100% false results for asyncio types.
# ---------------------------------------------------------------------------

