  rows:
    - ["ab2191012", "abc.ABC.__dict__.__contains__", ["__enter__"], false]
    - ["ab2191013", "abc.ABC.__dict__.__contains__", ["__exit__"], false]
    - ["ab2191014", "abc.ABC.__dict__.__contains__", ["__aenter__"], false]
    - ["ab2191015", "abc.ABC.__dict__.__contains__", ["__aexit__"], false]
    - ["ab2191016", "abc.ABC.__dict__.__contains__", ["acquire"], false]
    - ["ab2191017", "abc.ABC.__dict__.__contains__", ["release"], false]
    - ["ab2191018", "abc.ABC.__dict__.__contains__", ["__wrapped__"], false]
    - ["ab2191019", "abc.ABC.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["ab2191020", "abc.ABC.__dict__.__contains__", ["_abc_impl"], true]

table abc_extra2191.abstract_decorators_protocol:
  description: "abc.abstractclassmethod, abstractstaticmethod, abstractproperty dict-presence — no context manager or lock protocol; only __isabstractmethod__"
