spec: abc_extra2191
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2191: context manager protocol dict-presence checks — __enter__, __exit__, __aenter__, __aexit__, acquire, release, __wrapped__, __closure__."
    - "abc.ABCMeta does NOT define __enter__, __exit__, __aenter__, __aexit__, acquire, release, __wrapped__, or __closure__ in its own __dict__."
    - "abc.ABC does NOT define any context manager or lock protocol in its own __dict__."
    - "abc.abstractclassmethod, abstractstaticmethod, abstractproperty do NOT define context manager or lock protocol in their own __dict__."
    - "abc.ABCMeta does define register, __new__, __instancecheck__, __subclasscheck__, _dump_registry, _abc_registry_clear, _abc_caches_clear in its own __dict__."
    - "abc.ABC does define __abstractmethods__, __slots__, and _abc_impl in its own __dict__."
    - "abc.abstractclassmethod, abstractstaticmethod, and abstractproperty each define __isabstractmethod__ in their own __dict__."
    - "The abc module is entirely absent of async context manager support — none of its classes define __aenter__ or __aexit__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra2191.abcmeta_context_protocol:
  description: "abc.ABCMeta dict-presence — no context manager or lock protocol defined; metaclass protocol only"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2191

  columns: [id, function, args, expected]
  rows:
    - ["ab2191001", "abc.ABCMeta.__dict__.__contains__", ["__enter__"], false]
    - ["ab2191002", "abc.ABCMeta.__dict__.__contains__", ["__exit__"], false]
    - ["ab2191003", "abc.ABCMeta.__dict__.__contains__", ["__aenter__"], false]
    - ["ab2191004", "abc.ABCMeta.__dict__.__contains__", ["__aexit__"], false]
    - ["ab2191005", "abc.ABCMeta.__dict__.__contains__", ["acquire"], false]
    - ["ab2191006", "abc.ABCMeta.__dict__.__contains__", ["release"], false]
    - ["ab2191007", "abc.ABCMeta.__dict__.__contains__", ["__wrapped__"], false]
    - ["ab2191008", "abc.ABCMeta.__dict__.__contains__", ["register"], true]
    - ["ab2191009", "abc.ABCMeta.__dict__.__contains__", ["__new__"], true]
    - ["ab2191010", "abc.ABCMeta.__dict__.__contains__", ["__instancecheck__"], true]
    - ["ab2191011", "abc.ABCMeta.__dict__.__contains__", ["__subclasscheck__"], true]

table abc_extra2191.abc_class_protocol:
  description: "abc.ABC dict-presence — no context manager or lock protocol; defines __abstractmethods__ and _abc_impl"
  kind: python_call_eq
  category: dict_contains
