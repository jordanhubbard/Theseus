spec: bytes_methods_rust
version: ">=3.9"
backend: rust_module(bytes_methods_rust)

docs: https://docs.python.org/3/library/stdtypes.html#bytes

provenance:
  derived_from:
    - "https://docs.python.org/3/library/stdtypes.html#bytes — Python bytes type documentation"
  not_derived_from:
    - "CPython source: Objects/bytesobject.c"
  notes:
    - "Clean-room Rust reimplementation of Python bytes.hex() and bytes.fromhex(), exposed via PyO3."
    - "hex(b) returns hexadecimal string representation of bytes."
    - "fromhex(s) constructs bytes from hexadecimal string."
    - "hex and fromhex are inverses: fromhex(hex(b)) == b."
    - "b'hello' encodes as base64 aGVsbG8=; hex as '68656c6c6f'."
    - "b'\\xff\\x00' encodes as base64 /wA=; hex as 'ff00'."
    - "b'\\x00' encodes as base64 AA==; hex as '00'."
    - "fromhex('') == b'' — empty hex string gives empty bytes."
    - "All test vectors verified against Python 3.14.3 bytes type."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# hex — bytes to hexadecimal string
table bytes_methods_rust.hex.vectors:
  kind: python_call_eq
  category: hex
  id_prefix: bx_hex
  function: hex

  columns: [id, args, expected]
  rows:
    - [hello,   [!b64 aGVsbG8=], "68656c6c6f"]
    - [ff00,    [!b64 /wA=],     "ff00"]
    - [zero,    [!b64 AA==],     "00"]
    - [abcd,    [!b64 AQID],     "010203"]

# fromhex — hexadecimal string to bytes
table bytes_methods_rust.fromhex.vectors:
  kind: python_call_eq
  category: fromhex
  id_prefix: bx_fromhex
  function: fromhex

  columns: [id, args, expected]
  rows:
    - [hello,   ["68656c6c6f"], !b64 aGVsbG8=]
    - [ff00,    ["ff00"],       !b64 /wA=]
    - [zero,    ["00"],         !b64 AA==]
    - [abcd,    ["010203"],     !b64 AQID]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T21:44:11Z
