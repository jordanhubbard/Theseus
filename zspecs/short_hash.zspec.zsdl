spec: short_hash
version: ">=1.0.0"
backend: node(short-hash)

docs: https://www.npmjs.com/package/short-hash

provenance:
  derived_from:
    - "short-hash README — https://www.npmjs.com/package/short-hash"
    - "Test vectors verified with short-hash via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "short-hash source"
  notes:
    - "short-hash is an npm package. Install: npm install short-hash"
    - "Generates a short deterministic hash string from an input string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table short_hash.hash:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: shash

  columns: [id, args, expected]
  rows:
    - [hello,  ["hello"], "acfa3a7"]
    - [world,  ["world"], "9cc7527"]
    - [test,   ["test"],  "7c7354f3"]
    - [empty,  [""],      "1505"]

