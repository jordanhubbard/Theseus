spec: uu2866
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 638 (_extra2866): __rand__, __ror__, __rxor__ dict-presence checks for uuid types."
    - "uuid.UUID is the primary type; uuid.SafeUUID is an Enum (not IntEnum) subclass."
    - "uuid.RFC_4122, uuid.RESERVED_NCS, uuid.RESERVED_MICROSOFT, uuid.RESERVED_FUTURE are plain str constants, not types."
    - "None of uuid.UUID, uuid.SafeUUID define reflected bitwise AND, OR, or XOR operators in their own __dict__."
    - "uuid.SafeUUID inherits from Enum (not int), so it does not pick up int's bitwise operators."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table uu2866.rand:
  description: "uuid types __rand__ dict-presence checks; wave 638"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2866
  columns: [id, function, args, expected]
  rows:
    - ["uu2866001", "uuid.UUID.__dict__.__contains__",     ["__rand__"], false]
    - ["uu2866002", "uuid.SafeUUID.__dict__.__contains__", ["__rand__"], false]
    - ["uu2866003", "type(uuid.uuid4()).__dict__.__contains__", ["__rand__"], false]
    - ["uu2866004", "type(uuid.uuid1()).__dict__.__contains__", ["__rand__"], false]
    - ["uu2866005", "type(uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org')).__dict__.__contains__", ["__rand__"], false]
    - ["uu2866006", "type(uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org')).__dict__.__contains__", ["__rand__"], false]

