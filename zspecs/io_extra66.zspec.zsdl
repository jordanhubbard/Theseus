spec: io_extra66
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/"
    - "io_extra65.zspec.zsdl — covers io.__loader__.__class__.__name__.__eq__('type'); io.__loader__.__name__.__eq__('FrozenImporter'); io.__loader__.__name__.__len__()==14; io.__spec__.origin.__eq__('frozen'); io.__spec__.origin.__class__.__name__.__eq__('str'); io.__file__.__class__.__name__.__eq__('str')."
    - "io_extra64.zspec.zsdl — covers io.__all__.__contains__ membership; io.__package__.__eq__(''); BytesIO/IOBase __doc__.__class__.__name__.__len__()==3."
    - "io_extra62.zspec.zsdl — covers BytesIO/StringIO/TextIOWrapper/IOBase/RawIOBase __repr__/__hash__ class name chains; io.__spec__.__class__.__name__.__eq__('ModuleSpec'); io.__spec__.name.__class__.__name__.__eq__('str')."
    - "io_extra61.zspec.zsdl — covers io.__spec__.name.__eq__('io') and __len__()==2."
    - "io_extra44.zspec.zsdl — covers io.__name__.__len__()==2; io.__file__.__class__.__name__.__len__()==3."
  notes:
    - "This spec extends io_extra65.zspec.zsdl."
    - "Wave 226 theme: __spec__.origin values + __spec__.submodule_search_locations + __loader__.__name__ length checks."
    - "io.__loader__.__name__.__eq__('FrozenImporter') and __len__()==14 — io.__loader__ is the FrozenImporter class object itself (not an instance). As a class, it has a __name__ attribute equal to 'FrozenImporter' (14 characters). io_extra65 covers both the equality and the length in table rows; this wave 226 spec uses standalone invariant blocks to re-anchor the length in the iospec66 namespace as a complementary anchor. No prior io spec uses iospec66 as id_prefix."
    - "io.__spec__.origin.__eq__('frozen') — io is loaded by FrozenImporter so its spec origin is the string 'frozen'. io_extra65 covers this in table and invariant form; this wave 226 spec re-anchors it in the iospec66 namespace via an invariant for cross-wave traceability."
    - "io.__spec__.submodule_search_locations is None — io is not a package; it is a single-file frozen module. Therefore __spec__.submodule_search_locations is None, and its __class__.__name__ is 'NoneType'. No prior io spec checks __spec__.submodule_search_locations directly. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.__spec__.has_location is False — io is loaded by FrozenImporter which does not associate a filesystem location. Therefore has_location is False. This contrasts with SourceFileLoader modules (pathlib, re, decimal) where has_location is True. No prior io spec checks __spec__.has_location. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.__loader__.__name__ length and equality
#
# io.__loader__ is the FrozenImporter class object itself (not an instance).
# As a class, it has a __name__ attribute: 'FrozenImporter' (14 characters).
#
#   io.__loader__.__name__.__eq__('FrozenImporter') == True
#   io.__loader__.__name__.__len__()                == 14
#
# io_extra65 covers both anchors in the ioload65 id_prefix namespace.
# This wave 226 spec re-anchors __len__()==14 in the iospec66 namespace as a
# complementary cross-wave traceability anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra66.loader_name_length:
  description: "io.__loader__.__name__ eq and len — io.__loader__ is the FrozenImporter class object; as a class it has __name__=='FrozenImporter' (14 chars); io_extra65 covers both equality and length in ioload65 namespace; this wave 226 spec re-anchors them in iospec66 namespace for cross-wave traceability; io's __loader__.__name__ is accessible because __loader__ IS the class (not an instance); contrasts with pathlib/re/decimal where __loader__ is a SourceFileLoader instance with no __name__; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: iospec66ldr

  columns: [id, function, args, expected]
  rows:
    - [loader_name_eq_FrozenImporter, __loader__.__name__.__eq__,  ["FrozenImporter"], true]
    - [loader_name_len_14,            __loader__.__name__.__len__, [],                 14  ]

# ---------------------------------------------------------------------------
# io.__spec__.origin.__eq__('frozen')
#
# io is loaded by the frozen bootstrap importer, so its spec origin is 'frozen'.
# This contrasts with pure Python modules (origin is a .py file path) and
# C extensions (origin is a .so path).
#
#   io.__spec__.origin.__eq__('frozen') == True
#
# io_extra65 covers this in the ioload65 namespace.
# This wave 226 spec re-anchors it in iospec66 for cross-wave traceability.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra66.spec_origin:
  description: "io.__spec__.origin.__eq__('frozen') — io is loaded by FrozenImporter; its spec origin is the string 'frozen'; contrasts with pure Python (.py path) and C extension (.so path) origins; io_extra65 covers this in ioload65 namespace; re-anchored in iospec66 namespace for cross-wave traceability; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: iospec66orig

  columns: [id, function, args, expected]
  rows:
    - [spec_origin_eq_frozen, __spec__.origin.__eq__, ["frozen"], true]

# ---------------------------------------------------------------------------
# io.__spec__.submodule_search_locations — None for non-packages
#
# io is not a package; it is a single-file frozen module. Therefore its
# __spec__.submodule_search_locations is None (not a list). The class name
# of None is 'NoneType'.
#
#   io.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True
#
# This contrasts with pathlib and re which ARE packages and have a list here.
# No prior io spec checks __spec__.submodule_search_locations. Novel.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra66.spec_submodule_search_locations:
  description: "io.__spec__.submodule_search_locations is None — io is not a package (single-file frozen module); therefore submodule_search_locations is None and its __class__.__name__ is 'NoneType'; contrasts with pathlib and re which are packages (submodule_search_locations is a list); no prior io spec checks submodule_search_locations; novel anchor in iospec66 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: iospec66ssl

  columns: [id, function, args, expected]
  rows:
    - [ssl_class_name_NoneType, __spec__.submodule_search_locations.__class__.__name__.__eq__, ["NoneType"], true]

# ---------------------------------------------------------------------------
# io.__spec__.has_location — False for frozen modules
#
# io is loaded by FrozenImporter which does not associate a filesystem
# location. Therefore io.__spec__.has_location is False.
#
# This contrasts with SourceFileLoader modules (pathlib, re, decimal) where
# has_location is True because they are loaded from filesystem paths.
#
# No prior io spec checks __spec__.has_location. Novel anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra66.spec_has_location:
  description: "io.__spec__.has_location is False — io is loaded by FrozenImporter which does not associate a filesystem location; has_location==False for frozen modules; contrasts with pathlib/re/decimal (SourceFileLoader, has_location==True); no prior io spec checks __spec__.has_location; novel anchor in iospec66 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: iospec66hasloc

  columns: [id, function, args, expected]
  rows:
    - [has_location_false, __spec__.has_location.__eq__, [false], true]

invariant io_extra66.loader_name_eq_FrozenImporter:
  description: "io.__loader__.__name__.__eq__('FrozenImporter') == True — io.__loader__ is the FrozenImporter class object; as a class it has __name__=='FrozenImporter'; re-anchored in iospec66 namespace for cross-wave 226 traceability; io_extra65 covers this in ioload65 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__name__.__eq__
  args: ["FrozenImporter"]
  expected: true

invariant io_extra66.loader_name_len_14:
  description: "io.__loader__.__name__.__len__() == 14 — 'FrozenImporter' has 14 characters; io_extra65 covers this in ioload65 namespace; re-anchored in iospec66 namespace for cross-wave 226 traceability; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__name__.__len__
  args: []
  expected: 14

invariant io_extra66.spec_origin_frozen:
  description: "io.__spec__.origin.__eq__('frozen') == True — io is loaded by FrozenImporter; its spec origin is 'frozen'; re-anchored in iospec66 namespace for cross-wave 226 traceability; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.origin.__eq__
  args: ["frozen"]
  expected: true

invariant io_extra66.spec_ssl_none_class_name:
  description: "io.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — io is not a package so submodule_search_locations is None; __class__.__name__ of None is 'NoneType'; no prior io spec checks submodule_search_locations; novel anchor in iospec66 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant io_extra66.spec_has_location_false:
  description: "io.__spec__.has_location.__eq__(False) == True — io is loaded by FrozenImporter which does not set a filesystem location; has_location is False for frozen modules; contrasts with SourceFileLoader modules where has_location is True; no prior io spec checks __spec__.has_location; novel anchor in iospec66 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [false]
  expected: true
