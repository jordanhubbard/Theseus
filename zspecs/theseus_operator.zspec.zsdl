spec: theseus_operator
version: ">=3.9"
backend: python_cleanroom(theseus_operator)
blocks: operator

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html"
  notes:
    - "Clean-room operator function wrappers. Do NOT import operator."
    - "add(a, b) == a + b; add(3, 4) == 7."
    - "itemgetter(key)(obj) returns obj[key]; itemgetter(1)([10,20,30]) == 20."
    - "attrgetter(name)(obj) returns getattr(obj, name)."
    - "Export: add, sub, mul, truediv, itemgetter, attrgetter, methodcaller."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_operator.add:
  description: "add(3, 4) == 7"
  category: arithmetic
  kind: python_call_eq
  function: operator_add
  args: []
  expected: 7

invariant theseus_operator.itemgetter:
  description: "itemgetter(1)([10,20,30]) == 20"
  category: functional
  kind: python_call_eq
  function: operator_itemgetter
  args: []
  expected: 20

invariant theseus_operator.lt:
  description: "lt(1, 2) == True"
  category: comparison
  kind: python_call_eq
  function: operator_lt
  args: []
  expected: true
