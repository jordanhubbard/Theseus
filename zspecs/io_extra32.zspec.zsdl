spec: io_extra32
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra9.zspec.zsdl — covers __qualname__ for BytesIO/StringIO class objects; IOBase.__module__"
    - "io_extra26.zspec.zsdl — covers __qualname__ for BytesIO/StringIO/FileIO/BufferedRandom class objects"
    - "io_extra29.zspec.zsdl — covers __qualname__ for BytesIO/StringIO/IOBase instance methods"
    - "io_extra30.zspec.zsdl — covers __qualname__ for BytesIO/StringIO extra methods; BufferedReader/BufferedWriter/TextIOWrapper class qualnames"
    - "io_extra31.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __qualname__/__module__; UnsupportedOperation bases; DEFAULT_BUFFER_SIZE"
  notes:
    - "This spec extends io_extra31.zspec.zsdl."
    - "NEW in extra32 — Axis 1: FileIO.__qualname__/__module__ and FileIO.__bases__[0].__name__ — concrete raw I/O class identity and base class."
    - "NEW in extra32 — Axis 2: BytesIO.__qualname__/__module__ and BytesIO.__bases__[0].__name__ — in-memory bytes stream identity and base class."
    - "NEW in extra32 — Axis 3: StringIO.__qualname__/__module__ and StringIO.__bases__[0].__name__ — in-memory text stream identity and base class."
    - "NEW in extra32 — Axis 4: BufferedReader/__qualname__/__module__/__bases__[0].__name__ and BufferedWriter/__qualname__/__module__/__bases__[0].__name__."
    - "NEW in extra32 — Axis 5: TextIOWrapper.__qualname__/__module__/__bases__[0].__name__ — the concrete text-mode wrapper class."
    - "io.FileIO.__qualname__ == 'FileIO' — verified Python 3.12."
    - "io.FileIO.__module__ == '_io' — C-extension class registered under the private '_io' module."
    - "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — inherits from the C-level _RawIOBase."
    - "io.BytesIO.__qualname__ == 'BytesIO' — verified Python 3.12."
    - "io.BytesIO.__module__ == '_io' — C-extension class registered under '_io'."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — inherits from C-level _BufferedIOBase."
    - "io.StringIO.__qualname__ == 'StringIO' — verified Python 3.12."
    - "io.StringIO.__module__ == '_io' — C-extension class registered under '_io'."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — inherits from C-level _TextIOBase."
    - "io.BufferedReader.__qualname__ == 'BufferedReader' — verified Python 3.12."
    - "io.BufferedReader.__module__ == '_io' — C-extension class registered under '_io'."
    - "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — inherits from C-level _BufferedIOBase."
    - "io.BufferedWriter.__qualname__ == 'BufferedWriter' — verified Python 3.12."
    - "io.BufferedWriter.__module__ == '_io' — C-extension class registered under '_io'."
    - "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — inherits from C-level _BufferedIOBase."
    - "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — verified Python 3.12."
    - "io.TextIOWrapper.__module__ == '_io' — C-extension class registered under '_io'."
    - "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — inherits from C-level _TextIOBase."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# FileIO — class identity and base class
#
# io.FileIO is the concrete raw file I/O class. It is implemented in C and
# registered under the private '_io' module (not the public 'io' module).
# Its sole base class is the C-level _RawIOBase (with underscore prefix).
# io_extra26 covers FileIO.__qualname__ in a table row; no prior spec anchors
# FileIO.__module__ or FileIO.__bases__[0].__name__ as standalone invariants.
# ---------------------------------------------------------------------------

invariant io_extra32.FileIO.qualname:
  description: "io.FileIO.__qualname__ == 'FileIO' — flat qualname for the concrete raw file I/O class"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__qualname__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra32.FileIO.module:
  description: "io.FileIO.__module__ == '_io' — C-extension class; registered under private '_io', not public 'io'"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra32.FileIO.base:
  description: "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — FileIO inherits from the C-level _RawIOBase"
  category: class_identity
  kind: python_call_eq
  function: "FileIO.__bases__[0].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

# ---------------------------------------------------------------------------
# BytesIO — class identity and base class
#
# io.BytesIO is an in-memory bytes buffer implementing the buffered I/O API.
# Like FileIO, it is a C-extension registered under '_io'. Its base class is
# the C-level _BufferedIOBase. io_extra9 and io_extra26 cover BytesIO.__qualname__
# in table rows; no prior spec anchors __module__ or __bases__[0].__name__.
# ---------------------------------------------------------------------------

invariant io_extra32.BytesIO.qualname:
  description: "io.BytesIO.__qualname__ == 'BytesIO' — flat qualname for the in-memory bytes buffer class"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__qualname__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra32.BytesIO.module:
  description: "io.BytesIO.__module__ == '_io' — C-extension class registered under private '_io' module"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra32.BytesIO.base:
  description: "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — BytesIO inherits from C-level _BufferedIOBase"
  category: class_identity
  kind: python_call_eq
  function: "BytesIO.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

# ---------------------------------------------------------------------------
# StringIO — class identity and base class
#
# io.StringIO is an in-memory text stream implementing the text I/O API.
# Its base class is the C-level _TextIOBase. No prior spec anchors __module__
# or __bases__[0].__name__ as standalone extra32-namespace invariants.
# ---------------------------------------------------------------------------

invariant io_extra32.StringIO.qualname:
  description: "io.StringIO.__qualname__ == 'StringIO' — flat qualname for the in-memory text buffer class"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__qualname__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra32.StringIO.module:
  description: "io.StringIO.__module__ == '_io' — C-extension class registered under private '_io' module"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra32.StringIO.base:
  description: "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — StringIO inherits from C-level _TextIOBase"
  category: class_identity
  kind: python_call_eq
  function: "StringIO.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

# ---------------------------------------------------------------------------
# BufferedReader and BufferedWriter — class identity and base class
#
# These two classes wrap raw I/O streams with buffering. Both are C-extensions
# under '_io' and inherit from _BufferedIOBase. io_extra30 covers their
# __qualname__ in table rows; no prior spec anchors __module__ or
# __bases__[0].__name__ as standalone invariants in the extra32 namespace.
# ---------------------------------------------------------------------------

table io_extra32.buffered_rw_identity:
  description: "__qualname__, __module__, and __bases__[0].__name__ for BufferedReader and BufferedWriter"
  kind: python_call_eq
  category: class_identity
  id_prefix: bri32

  columns: [id, function, args, expected]
  rows:
    - [BufferedReader_qualname, BufferedReader.__qualname__.__eq__, ["BufferedReader"],  true]
    - [BufferedReader_module,   BufferedReader.__module__.__eq__,   ["_io"],             true]
    - [BufferedReader_base,     "BufferedReader.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true]
    - [BufferedWriter_qualname, BufferedWriter.__qualname__.__eq__, ["BufferedWriter"],  true]
    - [BufferedWriter_module,   BufferedWriter.__module__.__eq__,   ["_io"],             true]
    - [BufferedWriter_base,     "BufferedWriter.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true]

# ---------------------------------------------------------------------------
# TextIOWrapper — class identity and base class
#
# io.TextIOWrapper is the concrete text-mode wrapper around a BufferedIOBase
# object (the default stream type returned by open() in text mode). It is a
# C-extension registered under '_io' and inherits from _TextIOBase. io_extra30
# covers TextIOWrapper.__qualname__ in a table row; no prior spec anchors
# __module__ or __bases__[0].__name__ as standalone extra32-namespace invariants.
# ---------------------------------------------------------------------------

invariant io_extra32.TextIOWrapper.qualname:
  description: "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — flat qualname for the concrete text-mode wrapper class"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__qualname__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra32.TextIOWrapper.module:
  description: "io.TextIOWrapper.__module__ == '_io' — C-extension class registered under private '_io' module"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra32.TextIOWrapper.base:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — TextIOWrapper inherits from C-level _TextIOBase"
  category: class_identity
  kind: python_call_eq
  function: "TextIOWrapper.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true
