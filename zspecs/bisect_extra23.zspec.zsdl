spec: bisect_extra23
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec extends bisect_extra22.zspec.zsdl."
    - "Prior specs covered: bisect.__name__/__package__, bisect_left/bisect_right/insort_left/insort_right/__name__/__module__, bisect.__name__=='bisect_right' (alias), insort.__name__=='insort_right' (alias), name length table, bisect.__doc__.__class__.__name__, various __qualname__ checks."
    - "This spec covers: __qualname__.__eq__ for all 6 bisect callables in extra23 namespace (aliases bisect/insort resolve to bisect_right/insort_right qualnames); __module__.__len__() for bisect_left, bisect_right, insort_left; bisect_left.__module__ and bisect_right.__module__ standalone equality checks."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "bisect.bisect_left.__qualname__ == 'bisect_left'. Verified."
    - "bisect.bisect_right.__qualname__ == 'bisect_right'. Verified."
    - "bisect.insort_left.__qualname__ == 'insort_left'. Verified."
    - "bisect.insort_right.__qualname__ == 'insort_right'. Verified."
    - "bisect.bisect.__qualname__ == 'bisect_right' (alias; resolves to underlying function). Verified."
    - "bisect.insort.__qualname__ == 'insort_right' (alias; resolves to underlying function). Verified."
    - "bisect.bisect_left.__module__ == '_bisect'; len == 7. Verified."
    - "bisect.bisect_right.__module__ == '_bisect'; len == 7. Verified."
    - "bisect.insort_left.__module__ == '_bisect'; len == 7. Verified."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ for all 6 bisect callables — extra23 namespace
#
# bisect_extra18 covers __qualname__.__eq__ in that namespace. This table
# re-anchors __qualname__.__eq__ in the extra23 namespace. The aliases
# bisect.bisect and bisect.insort point to bisect_right and insort_right
# respectively; their __qualname__ reflects the underlying function's qualname,
# not the alias name. id_prefix bsqn23 is novel.
# ---------------------------------------------------------------------------

table bisect_extra23.qualnames:
  description: "__qualname__.__eq__ for all 6 bisect callables — aliases bisect/insort resolve to bisect_right/insort_right"
  kind: python_call_eq
  category: function_qualname
  id_prefix: bsqn23

  columns: [id, function, args, expected]
  rows:
    - [bisect_left,  bisect_left.__qualname__.__eq__,  ["bisect_left"],  true]
    - [bisect_right, bisect_right.__qualname__.__eq__, ["bisect_right"], true]
    - [insort_left,  insort_left.__qualname__.__eq__,  ["insort_left"],  true]
    - [insort_right, insort_right.__qualname__.__eq__, ["insort_right"], true]
    - [bisect_alias, bisect.__qualname__.__eq__,       ["bisect_right"], true]
    - [insort_alias, insort.__qualname__.__eq__,       ["insort_right"], true]

# ---------------------------------------------------------------------------
# bisect.bisect_left.__module__.__len__() — length of '_bisect' (7 chars)
#
# bisect_left is a C builtin imported from _bisect. Its __module__ == '_bisect'
# (7 characters, including the leading underscore). No prior bisect spec checks
# __module__.__len__() in the extra23 namespace for bisect_left specifically.
# bisect_extra20 checks __module__.__len__ for all callables in that namespace.
# ---------------------------------------------------------------------------

invariant bisect_extra23.bisect_left.module_len:
  description: "bisect.bisect_left.__module__.__len__() == 7 — len('_bisect') == 7"
  category: function_module
  kind: python_call_eq
  function: bisect_left.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# bisect.bisect_right.__module__.__len__() — length of '_bisect' (7 chars)
#
# bisect_right is also a C builtin from _bisect. Its __module__ == '_bisect'
# with length 7. Separate invariant for bisect_right to confirm same C origin.
# ---------------------------------------------------------------------------

invariant bisect_extra23.bisect_right.module_len:
  description: "bisect.bisect_right.__module__.__len__() == 7 — len('_bisect') == 7"
  category: function_module
  kind: python_call_eq
  function: bisect_right.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# bisect.insort_left.__module__.__len__() — length of '_bisect' (7 chars)
#
# insort_left is a C builtin from _bisect. Its __module__ == '_bisect' with
# length 7. All 4 core bisect callables share the same C extension module.
# ---------------------------------------------------------------------------

invariant bisect_extra23.insort_left.module_len:
  description: "bisect.insort_left.__module__.__len__() == 7 — len('_bisect') == 7"
  category: function_module
  kind: python_call_eq
  function: insort_left.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# bisect.bisect_left.__module__ — module string identity check
#
# Standalone __module__.__eq__ for bisect_left in the extra23 namespace.
# Confirms the C extension origin string '_bisect' directly, complementing the
# __len__ check above. bisect_extra21 covers __module__.__eq__ for all callables
# in that namespace; extra23 re-anchors for bisect_left specifically.
# ---------------------------------------------------------------------------

invariant bisect_extra23.bisect_left.module_eq:
  description: "bisect.bisect_left.__module__ == '_bisect' — C builtin from _bisect extension"
  category: function_module
  kind: python_call_eq
  function: bisect_left.__module__.__eq__
  args: ["_bisect"]
  expected: true

# ---------------------------------------------------------------------------
# bisect.bisect_right.__module__ — module string identity check
#
# Standalone __module__.__eq__ for bisect_right in the extra23 namespace.
# bisect_right is the same C extension as bisect_left; __module__ == '_bisect'.
# ---------------------------------------------------------------------------

invariant bisect_extra23.bisect_right.module_eq:
  description: "bisect.bisect_right.__module__ == '_bisect' — C builtin from _bisect extension"
  category: function_module
  kind: python_call_eq
  function: bisect_right.__module__.__eq__
  args: ["_bisect"]
  expected: true
