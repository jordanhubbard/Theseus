spec: functools_extra126
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra125.zspec.zsdl."
    - "This spec covers: functools.lru_cache and functools.wraps __code__.co_varnames elements not previously covered — lru_cache co_varnames[1]='typed'(5), co_varnames[2]='user_function'(13), co_varnames[3]='wrapper'(7), co_varnames[4]='decorating_function'(19), co_varnames tuple len=5; wraps co_varnames[1]='assigned'(8), co_varnames[2]='updated'(7), co_varnames tuple len=3; wave 272."
    - "Prior spec extra70 covered: lru_cache co_varnames[0]='maxsize' and wraps co_varnames[0]='wrapped' (both the first parameter). New here: all remaining co_varnames indices for both functions."
    - "functools.lru_cache.__code__.co_varnames[1] == 'typed' (len 5). Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_varnames[2] == 'user_function' (len 13). Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_varnames[3] == 'wrapper' (len 7). Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_varnames[4] == 'decorating_function' (len 19). Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_varnames.__len__() == 5. Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_varnames[1] == 'assigned' (len 8). Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_varnames[2] == 'updated' (len 7). Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_varnames.__len__() == 3. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.lru_cache __code__.co_varnames[1] through [4]
#
# Wave 272 theme: functools.lru_cache is a pure-Python function with signature
# lru_cache(maxsize=128, typed=False). Prior spec extra70 covered co_varnames[0]
# == 'maxsize'. New here: the remaining four entries in co_varnames.
# co_varnames[1] == 'typed' (5 chars) — the second parameter, controls whether
# arguments of different types are cached separately. co_varnames[2] ==
# 'user_function' (13 chars) — an inner local used when lru_cache is called
# without arguments directly on a function. co_varnames[3] == 'wrapper' (7 chars)
# — the decorated function wrapper created internally. co_varnames[4] ==
# 'decorating_function' (19 chars) — the closure returned when lru_cache is
# used with arguments. co_varnames has exactly 5 entries total.
#
# lru_cache.__code__.co_varnames[1] == 'typed'              (len 5)
# lru_cache.__code__.co_varnames[2] == 'user_function'      (len 13)
# lru_cache.__code__.co_varnames[3] == 'wrapper'            (len 7)
# lru_cache.__code__.co_varnames[4] == 'decorating_function' (len 19)
# lru_cache.__code__.co_varnames.__len__() == 5
#
# New to extra126.
# ---------------------------------------------------------------------------

table functools_extra126.lru_cache_co_varnames_1_to_4:
  description: "functools.lru_cache co_varnames[1]='typed'(5), [2]='user_function'(13), [3]='wrapper'(7), [4]='decorating_function'(19); tuple len=5; prior extra70 covered [0]='maxsize'; wave 272; new to extra126"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolslcv126

  columns: [id, function, args, expected, description]
  rows:
    - [lc_co_varnames1_eq,
       "lru_cache.__code__.co_varnames.__getitem__",
       [1],
       "typed",
       "functools.lru_cache.__code__.co_varnames[1] == 'typed' — the second parameter; controls type-sensitive caching; lru_cache(maxsize=128, typed=False): typed is False by default; tuple.__getitem__(1) returns 'typed'; new to extra126"]
    - [lc_co_varnames1_len,
       "lru_cache.__code__.co_varnames.__getitem__(1).__len__",
       [],
       5,
       "functools.lru_cache.__code__.co_varnames[1].__len__() == 5 — 'typed' has 5 chars: t-y-p-e-d; same length as 'cache' in functools.__all__[5]; str.__len__() returns 5; new to extra126"]
    - [lc_co_varnames2_eq,
       "lru_cache.__code__.co_varnames.__getitem__",
       [2],
       "user_function",
       "functools.lru_cache.__code__.co_varnames[2] == 'user_function' — an inner local variable used when lru_cache is applied directly to a callable (no-argument decorator form); tuple.__getitem__(2) returns 'user_function'; new to extra126"]
    - [lc_co_varnames2_len,
       "lru_cache.__code__.co_varnames.__getitem__(2).__len__",
       [],
       13,
       "functools.lru_cache.__code__.co_varnames[2].__len__() == 13 — 'user_function' has 13 chars: u-s-e-r-_-f-u-n-c-t-i-o-n; str.__len__() returns 13; new to extra126"]
    - [lc_co_varnames3_eq,
       "lru_cache.__code__.co_varnames.__getitem__",
       [3],
       "wrapper",
       "functools.lru_cache.__code__.co_varnames[3] == 'wrapper' — the lru_wrapper object created around the user function; tuple.__getitem__(3) returns 'wrapper'; new to extra126"]
    - [lc_co_varnames4_eq,
       "lru_cache.__code__.co_varnames.__getitem__",
       [4],
       "decorating_function",
       "functools.lru_cache.__code__.co_varnames[4] == 'decorating_function' — the closure returned when lru_cache is called with arguments; accepts the actual function to decorate; tuple.__getitem__(4) returns 'decorating_function'; new to extra126"]
    - [lc_co_varnames4_len,
       "lru_cache.__code__.co_varnames.__getitem__(4).__len__",
       [],
       19,
       "functools.lru_cache.__code__.co_varnames[4].__len__() == 19 — 'decorating_function' has 19 chars: the longest of the 5 co_varnames entries; d-e-c-o-r-a-t-i-n-g-_-f-u-n-c-t-i-o-n; str.__len__() returns 19; new to extra126"]

# ---------------------------------------------------------------------------
# Table 2: functools.lru_cache __code__.co_varnames tuple length
#
# Wave 272 theme: lru_cache.__code__.co_varnames is a 5-element tuple. The five
# entries are: 'maxsize'(7), 'typed'(5), 'user_function'(13), 'wrapper'(7),
# 'decorating_function'(19). The total length 5 reflects two declared parameters
# (maxsize, typed) plus three internal locals used in the implementation.
# Comparing with functools.wraps (co_varnames len == 3): wraps has three entries
# ('wrapped', 'assigned', 'updated') all being declared parameters — it has no
# additional internal locals captured in co_varnames.
#
# lru_cache.__code__.co_varnames.__len__() == 5
# wraps.__code__.co_varnames.__len__() == 3
#
# New to extra126.
# ---------------------------------------------------------------------------

table functools_extra126.co_varnames_tuple_lengths:
  description: "functools lru_cache co_varnames tuple len=5, wraps co_varnames tuple len=3; lru_cache has 2 params + 3 internal locals; wraps has 3 params only; wave 272; new to extra126"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolscvtl126

  columns: [id, function, args, expected, description]
  rows:
    - [lc_co_varnames_len,
       "lru_cache.__code__.co_varnames.__len__",
       [],
       5,
       "functools.lru_cache.__code__.co_varnames.__len__() == 5 — lru_cache has 5 local variable names in its code object: 2 declared parameters (maxsize, typed) + 3 internal locals (user_function, wrapper, decorating_function); tuple.__len__() returns 5; new to extra126"]
    - [wraps_co_varnames_len,
       "wraps.__code__.co_varnames.__len__",
       [],
       3,
       "functools.wraps.__code__.co_varnames.__len__() == 3 — wraps has 3 local variable names: all 3 are declared parameters (wrapped, assigned, updated); no additional internal locals; tuple.__len__() returns 3; new to extra126"]
    - [lc_co_varnames_class_is_tuple,
       "lru_cache.__code__.co_varnames.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.lru_cache.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is always a tuple in CPython code objects; confirms the type; str.__eq__('tuple') returns True; new to extra126"]
    - [wraps_co_varnames_class_is_tuple,
       "wraps.__code__.co_varnames.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.wraps.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames for wraps is also a tuple; consistent with CPython code object structure; str.__eq__('tuple') returns True; new to extra126"]
    - [lc_co_varnames_len_gt_wraps,
       "lru_cache.__code__.co_varnames.__len__",
       [],
       5,
       "functools.lru_cache.__code__.co_varnames.__len__() == 5 — confirming that lru_cache (5 locals) has more entries than wraps (3 locals); lru_cache implementation uses internal closures requiring more named locals; tuple.__len__() returns 5; new to extra126"]

# ---------------------------------------------------------------------------
# Table 3: functools.wraps __code__.co_varnames[1] and [2]
#
# Wave 272 theme: functools.wraps is a convenience decorator with signature
# wraps(wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES). Prior
# spec extra70 covered co_varnames[0] == 'wrapped'. New here: co_varnames[1]
# == 'assigned' (8 chars) and co_varnames[2] == 'updated' (7 chars). The
# 'assigned' parameter lists attributes to copy from the wrapped function
# (defaults to WRAPPER_ASSIGNMENTS = ('__module__', '__name__', etc.)).
# The 'updated' parameter lists attributes to update on the wrapper (defaults
# to WRAPPER_UPDATES = ('__dict__',)). Both are keyword arguments with defaults.
# 'assigned' (8 chars) is one character longer than 'updated' (7 chars) and
# 'wrapped' (7 chars) — these two share the same length.
#
# wraps.__code__.co_varnames[1] == 'assigned'   (len 8)
# wraps.__code__.co_varnames[2] == 'updated'    (len 7)
#
# New to extra126.
# ---------------------------------------------------------------------------

table functools_extra126.wraps_co_varnames_1_and_2:
  description: "functools.wraps co_varnames[1]='assigned'(8), co_varnames[2]='updated'(7); prior extra70 covered [0]='wrapped'(7); 'assigned' is longest; 'updated' and 'wrapped' share len=7; wave 272; new to extra126"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswcv126

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_co_varnames1_eq,
       "wraps.__code__.co_varnames.__getitem__",
       [1],
       "assigned",
       "functools.wraps.__code__.co_varnames[1] == 'assigned' — the second parameter; lists which attributes to copy from the wrapped function to the wrapper; defaults to WRAPPER_ASSIGNMENTS; tuple.__getitem__(1) returns 'assigned'; new to extra126"]
    - [wraps_co_varnames1_len,
       "wraps.__code__.co_varnames.__getitem__(1).__len__",
       [],
       8,
       "functools.wraps.__code__.co_varnames[1].__len__() == 8 — 'assigned' has 8 chars: a-s-s-i-g-n-e-d; one more than 'wrapped' and 'updated' (both 7 chars); longest of the three wraps parameters; str.__len__() returns 8; new to extra126"]
    - [wraps_co_varnames2_eq,
       "wraps.__code__.co_varnames.__getitem__",
       [2],
       "updated",
       "functools.wraps.__code__.co_varnames[2] == 'updated' — the third parameter; lists which attributes on the wrapper to update from the wrapped function; defaults to WRAPPER_UPDATES = ('__dict__',); tuple.__getitem__(2) returns 'updated'; new to extra126"]
    - [wraps_co_varnames2_len,
       "wraps.__code__.co_varnames.__getitem__(2).__len__",
       [],
       7,
       "functools.wraps.__code__.co_varnames[2].__len__() == 7 — 'updated' has 7 chars: u-p-d-a-t-e-d; same length as co_varnames[0] 'wrapped' (7 chars); the two non-assigned parameters share this length; str.__len__() returns 7; new to extra126"]
    - [wraps_co_varnames0_len,
       "wraps.__code__.co_varnames.__getitem__(0).__len__",
       [],
       7,
       "functools.wraps.__code__.co_varnames[0].__len__() == 7 — 'wrapped' has 7 chars; confirming equal length with co_varnames[2] 'updated' (also 7); shorter than co_varnames[1] 'assigned' (8); str.__len__() returns 7; new to extra126"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra126
# ---------------------------------------------------------------------------

invariant functools_extra126.lc_co_varnames1_typed:
  description: "functools.lru_cache.__code__.co_varnames[1] == 'typed' — second parameter; controls type-sensitive caching; prior extra70 covered [0]='maxsize'; wave 272; new to extra126"
  kind: python_call_eq
  function: "lru_cache.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "typed"

invariant functools_extra126.lc_co_varnames2_user_function:
  description: "functools.lru_cache.__code__.co_varnames[2] == 'user_function' — internal local for no-argument decorator form; 13 chars; wave 272; new to extra126"
  kind: python_call_eq
  function: "lru_cache.__code__.co_varnames.__getitem__"
  args: [2]
  expected: "user_function"

invariant functools_extra126.lc_co_varnames4_decorating_function:
  description: "functools.lru_cache.__code__.co_varnames[4] == 'decorating_function' — closure for argument-form decorator; 19 chars; longest co_varnames entry; wave 272; new to extra126"
  kind: python_call_eq
  function: "lru_cache.__code__.co_varnames.__getitem__"
  args: [4]
  expected: "decorating_function"

invariant functools_extra126.wraps_co_varnames1_assigned:
  description: "functools.wraps.__code__.co_varnames[1] == 'assigned' — second parameter; 8 chars; longest of the 3 wraps params; wave 272; new to extra126"
  kind: python_call_eq
  function: "wraps.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "assigned"

invariant functools_extra126.wraps_co_varnames2_updated:
  description: "functools.wraps.__code__.co_varnames[2] == 'updated' — third parameter; 7 chars; same length as 'wrapped' (co_varnames[0]); wave 272; new to extra126"
  kind: python_call_eq
  function: "wraps.__code__.co_varnames.__getitem__"
  args: [2]
  expected: "updated"
