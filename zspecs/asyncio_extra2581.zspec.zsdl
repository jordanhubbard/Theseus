    - ["as2581008", "asyncio.Task.__dict__.__contains__", ["cancel"],            true]
    - ["as2581009", "asyncio.Task.__dict__.__contains__", ["done"],              true]
    - ["as2581010", "asyncio.Task.__dict__.__contains__", ["add_done_callback"], true]

