spec: asyncio_extra2581
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/asyncio.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
  notes:
    - "Wave 2581 theme: __call__ dict-presence — checking whether asyncio classes define __call__ in their own __dict__."
    - "None of the asyncio concurrency primitives (Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier, TaskGroup) define __call__ in their own class __dict__."
    - "These classes are not callable objects/functors; they expose explicit methods (put, get, acquire, release, etc.) instead of operator() equivalents."
    - "asyncio.Queue.__dict__ contains put, get, qsize, empty, full, put_nowait, get_nowait, task_done, join — confirming the positive presence checks."
    - "asyncio.Task.__dict__ contains result, cancel, done, cancelled, exception, add_done_callback — confirming positive presence checks."
    - "asyncio.Future.__dict__ contains result, cancel, done, set_result, set_exception — confirming positive presence checks."
    - "asyncio.Lock.__dict__ contains acquire, release, locked — confirming positive presence checks."
    - "asyncio.Event.__dict__ contains is_set, set, clear, wait — confirming positive presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# asyncio.Queue — no __call__; method presence confirmed
# ---------------------------------------------------------------------------

table asyncio_extra2581.queue_call_dict:
  description: "asyncio.Queue does not define __call__ in its class __dict__; standard queue methods are present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2581

  columns: [id, function, args, expected]
  rows:
    - ["as2581001", "asyncio.Queue.__dict__.__contains__", ["__call__"],    false]
    - ["as2581002", "asyncio.Queue.__dict__.__contains__", ["put"],         true]
    - ["as2581003", "asyncio.Queue.__dict__.__contains__", ["get"],         true]
    - ["as2581004", "asyncio.Queue.__dict__.__contains__", ["qsize"],       true]
    - ["as2581005", "asyncio.Queue.__dict__.__contains__", ["empty"],       true]

