spec: theseus_email_charset_cr
version: ">=3.0"
backend: python_cleanroom(theseus_email_charset_cr)
blocks: email.charset

docs: https://docs.python.org/3/library/email.charset.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/email.charset.html"
  not_derived_from:
    - "CPython source: Lib/email/charset.py"
  notes:
    - "Clean-room email.charset module. Do NOT import email.charset."

error_model: python_exceptions

invariant theseus_email_charset_cr.emailcs2_charset:
  description: "Charset class can be instantiated for common charsets"
  category: behavior
  kind: python_call_eq
  function: emailcs2_charset
  args: []
  expected: true

invariant theseus_email_charset_cr.emailcs2_aliases:
  description: "ALIASES dict maps charset aliases to canonical names"
  category: behavior
  kind: python_call_eq
  function: emailcs2_aliases
  args: []
  expected: true

invariant theseus_email_charset_cr.emailcs2_encode:
  description: "Charset can encode/decode strings"
  category: behavior
  kind: python_call_eq
  function: emailcs2_encode
  args: []
  expected: true
