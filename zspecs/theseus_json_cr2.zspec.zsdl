spec: theseus_json_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_json_cr2)
blocks: json

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html"
  notes:
    - "Clean-room extended JSON utilities. Do NOT import json."
    - "JSONDecoder: customizable decoder with object_hook."
    - "JSONEncoder: customizable encoder with default method."
    - "json_cr2_object_hook(): decode with object_hook converts dicts to objects."
    - "json_cr2_indent(): dumps({'a':1}, indent=2) produces multi-line output."
    - "json_cr2_sort_keys(): dumps({'b':2,'a':1}, sort_keys=True) has 'a' before 'b'."
    - "Export: JSONDecoder, JSONEncoder (both with override hooks)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_json_cr2.object_hook:
  description: "loads with object_hook transforms dict to custom object"
  category: decoder
  kind: python_call_eq
  function: json_cr2_object_hook
  args: []
  expected: 42

invariant theseus_json_cr2.indent:
  description: "dumps with indent=2 produces multi-line output (contains newline)"
  category: encoder
  kind: python_call_eq
  function: json_cr2_indent
  args: []
  expected: true

invariant theseus_json_cr2.sort_keys:
  description: "dumps with sort_keys=True produces 'a' before 'b'"
  category: encoder
  kind: python_call_eq
  function: json_cr2_sort_keys
  args: []
  expected: true
