spec: socket_extra2626
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 socket documentation — https://docs.python.org/3/library/socket.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra26.zspec.zsdl — covers socket module and socket.socket class identity"
    - "socket_extra269.zspec.zsdl — covers socket.socket and address family/socket kind identity"
  notes:
    - "Wave 622 (socket_extra2626) theme: __length_hint__, __missing__, and __reversed__ dict-presence checks."
    - "None of socket.socket, socket.AddressFamily, or socket.SocketKind define __length_hint__, __missing__, or __reversed__ in their own __dict__."
    - "__length_hint__ is a protocol method for sized iterators; socket objects are network I/O objects, not iterators."
    - "__missing__ is a dict subclass hook; none of these three classes is a dict subclass."
    - "__reversed__ is an iterator protocol method; socket objects do not support reverse iteration."
    - "socket.socket DOES define accept/close/makefile/__init__/__repr__ in its __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses and define __new__/_generate_next_value_/_member_names_/__doc__ in their __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — socket.socket, AddressFamily, SocketKind
# ---------------------------------------------------------------------------

table socket_extra2626.no_length_hint_in_socket_classes:
  description: "__length_hint__ is absent from socket.socket/AddressFamily/SocketKind __dict__s — socket objects are network I/O objects, not sized iterators"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2626

  columns: [id, function, args, expected]
  rows:
    - ["sk2626001", "socket.socket.__dict__.__contains__",        ["__length_hint__"], false]
    - ["sk2626002", "socket.AddressFamily.__dict__.__contains__", ["__length_hint__"], false]
    - ["sk2626003", "socket.SocketKind.__dict__.__contains__",    ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# __missing__ dict-presence — socket.socket, AddressFamily, SocketKind
# ---------------------------------------------------------------------------

table socket_extra2626.no_missing_in_socket_classes:
  description: "__missing__ is absent from socket.socket/AddressFamily/SocketKind __dict__s — none of these classes is a dict subclass implementing missing-key lookup"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2626

  columns: [id, function, args, expected]
  rows:
    - ["sk2626004", "socket.socket.__dict__.__contains__",        ["__missing__"], false]
    - ["sk2626005", "socket.AddressFamily.__dict__.__contains__", ["__missing__"], false]
    - ["sk2626006", "socket.SocketKind.__dict__.__contains__",    ["__missing__"], false]

# ---------------------------------------------------------------------------
# __reversed__ dict-presence — socket.socket, AddressFamily, SocketKind
# ---------------------------------------------------------------------------

table socket_extra2626.no_reversed_in_socket_classes:
  description: "__reversed__ is absent from socket.socket/AddressFamily/SocketKind __dict__s — socket classes do not support reverse iteration"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2626

  columns: [id, function, args, expected]
  rows:
    - ["sk2626007", "socket.socket.__dict__.__contains__",        ["__reversed__"], false]
    - ["sk2626008", "socket.AddressFamily.__dict__.__contains__", ["__reversed__"], false]
    - ["sk2626009", "socket.SocketKind.__dict__.__contains__",    ["__reversed__"], false]

# ---------------------------------------------------------------------------
# Complementary: socket.socket defines its core networking methods;
# AddressFamily/SocketKind define their IntEnum infrastructure — confirming
# the classes are well-populated even though the three protocol methods are absent.
# ---------------------------------------------------------------------------

table socket_extra2626.socket_classes_have_core_attrs:
  description: "socket.socket defines accept/close/makefile/__init__/__repr__ in __dict__; AddressFamily/SocketKind define __new__/_generate_next_value_/_member_names_ — but none defines __length_hint__/__missing__/__reversed__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2626

  columns: [id, function, args, expected]
  rows:
    - ["sk2626010", "socket.socket.__dict__.__contains__",        ["accept"],                true]
    - ["sk2626011", "socket.socket.__dict__.__contains__",        ["close"],                 true]
    - ["sk2626012", "socket.socket.__dict__.__contains__",        ["makefile"],              true]
    - ["sk2626013", "socket.socket.__dict__.__contains__",        ["__init__"],              true]
    - ["sk2626014", "socket.socket.__dict__.__contains__",        ["__repr__"],              true]
    - ["sk2626015", "socket.socket.__dict__.__contains__",        ["__length_hint__"],       false]
    - ["sk2626016", "socket.socket.__dict__.__contains__",        ["__missing__"],           false]
    - ["sk2626017", "socket.socket.__dict__.__contains__",        ["__reversed__"],          false]
    - ["sk2626018", "socket.AddressFamily.__dict__.__contains__", ["__new__"],               true]
    - ["sk2626019", "socket.AddressFamily.__dict__.__contains__", ["_generate_next_value_"], true]
    - ["sk2626020", "socket.AddressFamily.__dict__.__contains__", ["_member_names_"],        true]
    - ["sk2626021", "socket.AddressFamily.__dict__.__contains__", ["__length_hint__"],       false]
    - ["sk2626022", "socket.AddressFamily.__dict__.__contains__", ["__missing__"],           false]
    - ["sk2626023", "socket.AddressFamily.__dict__.__contains__", ["__reversed__"],          false]
    - ["sk2626024", "socket.SocketKind.__dict__.__contains__",    ["__new__"],               true]
    - ["sk2626025", "socket.SocketKind.__dict__.__contains__",    ["_generate_next_value_"], true]
    - ["sk2626026", "socket.SocketKind.__dict__.__contains__",    ["_member_names_"],        true]
    - ["sk2626027", "socket.SocketKind.__dict__.__contains__",    ["__length_hint__"],       false]
    - ["sk2626028", "socket.SocketKind.__dict__.__contains__",    ["__missing__"],           false]
    - ["sk2626029", "socket.SocketKind.__dict__.__contains__",    ["__reversed__"],          false]
