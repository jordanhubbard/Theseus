spec: inspect_extra2536
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: __format__, __bytes__, and __fspath__ dict-presence checks for inspect module classes."
    - "Theme: custom formatting, bytes conversion, and filesystem path protocol dict-presence — checking whether classes define __format__, __bytes__, or __fspath__ in their class __dict__."
    - "inspect.Parameter, inspect.Signature, inspect.BoundArguments, inspect.FrameInfo, inspect.FullArgSpec, and inspect.Attribute — none define __format__, __bytes__, or __fspath__."
    - "inspect.Parameter represents a single parameter in a callable's signature; its identity is based on name, kind, default, and annotation. It defines __eq__, __hash__, and __repr__ but not __format__, __bytes__, or __fspath__. Verified with Python 3.14."
    - "inspect.Signature represents the full call signature of a callable, holding an ordered mapping of Parameter objects and an optional return annotation; it exposes bind(), bind_partial(), and replace() but carries no formatting, bytes, or path protocol. Verified with Python 3.14."
    - "inspect.BoundArguments is returned by Signature.bind() and maps concrete argument values to their corresponding Parameter objects; it provides apply_defaults() and .args/.kwargs views but defines no __format__, __bytes__, or __fspath__. Verified with Python 3.14."
    - "inspect.FrameInfo is a named-tuple-like class holding frame, filename, lineno, function, code_context, and index; it is an introspection record with no custom formatting, bytes conversion, or path protocol. Verified with Python 3.14."
    - "inspect.FullArgSpec is a named tuple holding args, varargs, varkw, defaults, kwonlyargs, kwonlydefaults, and annotations; it is a pure data-holder for signature decomposition with no formatting, bytes, or path protocol. Verified with Python 3.14."
    - "inspect.Attribute is a named tuple returned by getmembers_static; it holds name, kind, defining_class, and object fields — a data-carrier with no format, bytes, or fspath protocol. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter — format/bytes/fspath protocol absence
#
# Theme: __format__, __bytes__, __fspath__ absent from inspect.Parameter.__dict__.
# Parameter is a frozen data-carrier describing a single parameter in a callable
# signature. It defines __eq__, __hash__, and __repr__ but has no custom
# string formatting, bytes conversion, or filesystem path protocol — it is
# a metadata object describing a signature slot, not a string or path type.
# ---------------------------------------------------------------------------

table inspect_extra2536.parameter_format_bytes_fspath:
  description: "__format__, __bytes__, __fspath__ absent from inspect.Parameter.__dict__; wave 2536"
  kind: python_call_eq
  category: format_bytes_fspath
  id_prefix: in2536

  columns: [id, function, args, expected]
  rows:
    - ["in2536-001", "Parameter.__dict__.__contains__", ["__format__"], false]
    - ["in2536-002", "Parameter.__dict__.__contains__", ["__bytes__"], false]
    - ["in2536-003", "Parameter.__dict__.__contains__", ["__fspath__"], false]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature — format/bytes/fspath protocol absence
#
# Theme: __format__, __bytes__, __fspath__ absent from inspect.Signature.__dict__.
# Signature holds an ordered mapping of Parameter objects plus an optional
# return annotation. It exposes bind(), bind_partial(), and replace() but
# carries no custom string formatting, bytes conversion, or filesystem path role.
# ---------------------------------------------------------------------------

table inspect_extra2536.signature_format_bytes_fspath:
  description: "__format__, __bytes__, __fspath__ absent from inspect.Signature.__dict__; wave 2536"
  kind: python_call_eq
  category: format_bytes_fspath
  id_prefix: in2536

  columns: [id, function, args, expected]
  rows:
    - ["in2536-004", "Signature.__dict__.__contains__", ["__format__"], false]
    - ["in2536-005", "Signature.__dict__.__contains__", ["__bytes__"], false]
    - ["in2536-006", "Signature.__dict__.__contains__", ["__fspath__"], false]

# ---------------------------------------------------------------------------
# Table 3: inspect.BoundArguments — format/bytes/fspath protocol absence
#
# Theme: __format__, __bytes__, __fspath__ absent from inspect.BoundArguments.__dict__.
# BoundArguments is returned by Signature.bind() and maps concrete argument
# values to their corresponding Parameter objects. It provides apply_defaults()
# and exposes .args and .kwargs views, but defines no custom formatting,
# bytes conversion, or filesystem path protocol.
# ---------------------------------------------------------------------------

table inspect_extra2536.bound_arguments_format_bytes_fspath:
  description: "__format__, __bytes__, __fspath__ absent from inspect.BoundArguments.__dict__; wave 2536"
  kind: python_call_eq
  category: format_bytes_fspath
  id_prefix: in2536

  columns: [id, function, args, expected]
  rows:
    - ["in2536-007", "BoundArguments.__dict__.__contains__", ["__format__"], false]
    - ["in2536-008", "BoundArguments.__dict__.__contains__", ["__bytes__"], false]
    - ["in2536-009", "BoundArguments.__dict__.__contains__", ["__fspath__"], false]

# ---------------------------------------------------------------------------
# Table 4: inspect.FrameInfo and inspect.FullArgSpec
#
# Theme: __format__, __bytes__, __fspath__ absent from FrameInfo and
# FullArgSpec.__dict__.
# FrameInfo is an introspection record grouping frame, filename, lineno,
# function, code_context, and index. FullArgSpec is a named tuple holding the
# full argument decomposition of a function signature. Both are data-carriers
# with no custom formatting, bytes, or path protocol.
# ---------------------------------------------------------------------------

table inspect_extra2536.frameinfo_fullargspec_format_bytes_fspath:
  description: "__format__, __bytes__, __fspath__ absent from inspect.FrameInfo and FullArgSpec __dict__; wave 2536"
  kind: python_call_eq
  category: format_bytes_fspath
  id_prefix: in2536

  columns: [id, function, args, expected]
  rows:
    - ["in2536-010", "FrameInfo.__dict__.__contains__", ["__format__"], false]
    - ["in2536-011", "FrameInfo.__dict__.__contains__", ["__bytes__"], false]
    - ["in2536-012", "FrameInfo.__dict__.__contains__", ["__fspath__"], false]
    - ["in2536-013", "FullArgSpec.__dict__.__contains__", ["__format__"], false]
    - ["in2536-014", "FullArgSpec.__dict__.__contains__", ["__bytes__"], false]
    - ["in2536-015", "FullArgSpec.__dict__.__contains__", ["__fspath__"], false]

