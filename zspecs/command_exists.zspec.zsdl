spec: command_exists
version: ">=1.0.0"
backend: node(command-exists)

docs: https://github.com/mathisonian/command-exists#readme

provenance:
  derived_from:
    - "command-exists README — https://github.com/mathisonian/command-exists#readme"
    - "Test vectors verified with command-exists via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "command-exists source"
  notes:
    - "Check if a binary is on PATH — sync version returns boolean."
    - "Install: npm install command-exists"
    - "v1 CJS; module export IS the async function; .sync attached."
    - "Tests assume Unix-like environment with 'ls' and 'node' on PATH."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Sync variant returns boolean; async throws if command not found."
  stderr: "null"
  stickiness: "N/A — pure PATH lookup."
  codes: {}

invariant command_exists.sync_ls_exists:
  description: "sync('ls') is true (POSIX baseline)"
  category: sync
  kind: node_chain_eq
  entry: named
  function: sync
  entry_args: ["ls"]
  chain: []
  expected: true

invariant command_exists.sync_node_exists:
  description: "sync('node') is true (we're running under Node)"
  category: sync
  kind: node_chain_eq
  entry: named
  function: sync
  entry_args: ["node"]
  chain: []
  expected: true

invariant command_exists.sync_made_up_command_false:
  description: "sync on a randomly named command returns false"
  category: sync
  kind: node_chain_eq
  entry: named
  function: sync
  entry_args: ["xyzcommand-zzzz-this-does-not-exist-99-anywhere"]
  chain: []
  expected: false

invariant command_exists.sync_takes_one_arg:
  description: "sync function arity is 1 (the command name)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "sync.length"}
  expected: 1

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:33:05Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
