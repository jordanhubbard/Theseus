spec: asyncio_extra2776
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronisation primitives documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio task and future documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "asyncio_extra.zspec.zsdl — covers __name__ and __module__ checks for Queue, Task, Future, Lock, Event, Semaphore, Condition"
    - "asyncio_extra2.zspec.zsdl — covers module checks for event loop classes and exception classes"
    - "asyncio_extra2761.zspec.zsdl — covers __matmul__, __truediv__, __iadd__ dict-presence checks"
  notes:
    - "Wave 632 theme: __isub__, __imul__, and __itruediv__ dict-presence checks (in-place arithmetic)."
    - "None of the asyncio synchronisation or task primitives define __isub__, __imul__, or __itruediv__ in their __dict__."
    - "Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier are async coordination primitives, not numeric types."
    - "asyncio.Barrier was added in Python 3.11; version constraint >=3.9 applies to all other types."
    - "All eight types checked: Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue, asyncio.Task, asyncio.Future — __isub__/__imul__/__itruediv__
# dict-presence checks
#
# Queue is an async FIFO queue; Task wraps a coroutine; Future is a low-level
# awaitable. None of them define in-place arithmetic operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2776.queue_task_future_operator_dict:
  description: "asyncio.Queue, Task, Future __isub__, __imul__, __itruediv__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2776qtf

  columns: [id, function, args, expected]
  rows:
    - ["as2776qtf_q_isub",    Queue.__dict__.__contains__,  ["__isub__"],    false]
    - ["as2776qtf_q_imul",    Queue.__dict__.__contains__,  ["__imul__"],    false]
    - ["as2776qtf_q_itruediv", Queue.__dict__.__contains__, ["__itruediv__"], false]
    - ["as2776qtf_t_isub",    Task.__dict__.__contains__,   ["__isub__"],    false]
    - ["as2776qtf_t_imul",    Task.__dict__.__contains__,   ["__imul__"],    false]
    - ["as2776qtf_t_itruediv", Task.__dict__.__contains__,  ["__itruediv__"], false]
    - ["as2776qtf_f_isub",    Future.__dict__.__contains__, ["__isub__"],    false]
    - ["as2776qtf_f_imul",    Future.__dict__.__contains__, ["__imul__"],    false]
    - ["as2776qtf_f_itruediv", Future.__dict__.__contains__, ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# asyncio.Lock, asyncio.Event, asyncio.Semaphore — __isub__/__imul__/__itruediv__
# dict-presence checks
#
# Lock, Event, and Semaphore are async synchronisation primitives defined in
# asyncio.locks. They do not implement in-place arithmetic dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2776.lock_event_semaphore_operator_dict:
  description: "asyncio.Lock, Event, Semaphore __isub__, __imul__, __itruediv__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2776les

  columns: [id, function, args, expected]
  rows:
    - ["as2776les_l_isub",    Lock.__dict__.__contains__,      ["__isub__"],    false]
    - ["as2776les_l_imul",    Lock.__dict__.__contains__,      ["__imul__"],    false]
    - ["as2776les_l_itruediv", Lock.__dict__.__contains__,     ["__itruediv__"], false]
    - ["as2776les_e_isub",    Event.__dict__.__contains__,     ["__isub__"],    false]
    - ["as2776les_e_imul",    Event.__dict__.__contains__,     ["__imul__"],    false]
    - ["as2776les_e_itruediv", Event.__dict__.__contains__,    ["__itruediv__"], false]
    - ["as2776les_s_isub",    Semaphore.__dict__.__contains__, ["__isub__"],    false]
    - ["as2776les_s_imul",    Semaphore.__dict__.__contains__, ["__imul__"],    false]
    - ["as2776les_s_itruediv", Semaphore.__dict__.__contains__, ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# asyncio.Condition and asyncio.Barrier — __isub__/__imul__/__itruediv__
# dict-presence checks
#
# Condition is a combination lock/condition variable. Barrier (added in 3.11)
# is a synchronisation barrier. Neither defines in-place numeric operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2776.condition_barrier_operator_dict:
  description: "asyncio.Condition and Barrier __isub__, __imul__, __itruediv__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2776cb

  columns: [id, function, args, expected]
  rows:
    - ["as2776cb_c_isub",    Condition.__dict__.__contains__, ["__isub__"],    false]
    - ["as2776cb_c_imul",    Condition.__dict__.__contains__, ["__imul__"],    false]
    - ["as2776cb_c_itruediv", Condition.__dict__.__contains__, ["__itruediv__"], false]
    - ["as2776cb_b_isub",    Barrier.__dict__.__contains__,   ["__isub__"],    false]
    - ["as2776cb_b_imul",    Barrier.__dict__.__contains__,   ["__imul__"],    false]
    - ["as2776cb_b_itruediv", Barrier.__dict__.__contains__,  ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Full 8×3 cross-type matrix — all asyncio types, all three in-place operator dunders
#
# Consolidates the full 8×3 dict-presence check in one table.
# Every cell is False: Queue, Task, Future, Lock, Event, Semaphore, Condition,
# and Barrier do not define -=, *=, or /= operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2776.all_types_isub_imul_itruediv_matrix:
  description: "Full 8×3 dict-presence matrix for asyncio types vs __isub__/__imul__/__itruediv__ — all 24 results are False; verified with Python 3.14.4"
