    - ["as2776mx_t_it",  Task.__dict__.__contains__,       ["__itruediv__"], false]
    - ["as2776mx_f_is",  Future.__dict__.__contains__,     ["__isub__"],    false]
    - ["as2776mx_f_im",  Future.__dict__.__contains__,     ["__imul__"],    false]
    - ["as2776mx_f_it",  Future.__dict__.__contains__,     ["__itruediv__"], false]
    - ["as2776mx_l_is",  Lock.__dict__.__contains__,       ["__isub__"],    false]
    - ["as2776mx_l_im",  Lock.__dict__.__contains__,       ["__imul__"],    false]
    - ["as2776mx_l_it",  Lock.__dict__.__contains__,       ["__itruediv__"], false]
    - ["as2776mx_e_is",  Event.__dict__.__contains__,      ["__isub__"],    false]
    - ["as2776mx_e_im",  Event.__dict__.__contains__,      ["__imul__"],    false]
    - ["as2776mx_e_it",  Event.__dict__.__contains__,      ["__itruediv__"], false]
    - ["as2776mx_s_is",  Semaphore.__dict__.__contains__,  ["__isub__"],    false]
    - ["as2776mx_s_im",  Semaphore.__dict__.__contains__,  ["__imul__"],    false]
    - ["as2776mx_s_it",  Semaphore.__dict__.__contains__,  ["__itruediv__"], false]
    - ["as2776mx_c_is",  Condition.__dict__.__contains__,  ["__isub__"],    false]
    - ["as2776mx_c_im",  Condition.__dict__.__contains__,  ["__imul__"],    false]
    - ["as2776mx_c_it",  Condition.__dict__.__contains__,  ["__itruediv__"], false]
