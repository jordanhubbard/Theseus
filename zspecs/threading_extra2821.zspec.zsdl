spec: threading_extra2821
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "any proprietary source"
  notes:
    - "Wave 635 (_extra2821): __radd__, __rsub__, and __rmul__ dict-presence checks (reflected/right-hand addition, subtraction, multiplication)."
    - "threading.Thread does NOT define __radd__, __rsub__, or __rmul__ — thread lifecycle management has no numeric arithmetic semantics."
    - "threading.Lock (alias for _thread.lock) does NOT define these operators — it is a mutex primitive with acquire/release only."
    - "threading.Event does NOT define these operators — it is a flag-based synchronization primitive."
    - "threading.Condition does NOT define these operators — it is a monitor-style synchronization primitive."
    - "threading.Semaphore does NOT define these operators — it is a counting semaphore, not a numeric type."
    - "threading.BoundedSemaphore does NOT define these operators — same rationale as Semaphore."
    - "threading.Timer does NOT define these operators — it is a Thread subclass for delayed execution."
    - "threading.Barrier does NOT define these operators — it is a phase synchronization barrier."
    - "threading.local does NOT define these operators — it provides thread-local storage, not numeric values."
    - "Reflected operators (__radd__, __rsub__, __rmul__) are invoked when the left operand does not support the operation; synchronization primitives have no arithmetic role."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __radd__ dict-presence (reflected addition)
#
# threading.Thread, Lock, Event, Condition, Semaphore — none define __radd__.
# Synchronization primitives have no numeric addition semantics.
# ---------------------------------------------------------------------------

table threading_extra2821.radd_protocol:
  description: "threading types __radd__ dict-presence checks — all False (no reflected addition protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2821
  columns: [id, function, args, expected]
  rows:
    - ["th2821001", "threading.Thread.__dict__.__contains__",           ["__radd__"], false]
    - ["th2821002", "threading.Lock.__dict__.__contains__",             ["__radd__"], false]
    - ["th2821003", "threading.Event.__dict__.__contains__",            ["__radd__"], false]
    - ["th2821004", "threading.Condition.__dict__.__contains__",        ["__radd__"], false]
    - ["th2821005", "threading.Semaphore.__dict__.__contains__",        ["__radd__"], false]
    - ["th2821006", "threading.BoundedSemaphore.__dict__.__contains__", ["__radd__"], false]
    - ["th2821007", "threading.Timer.__dict__.__contains__",            ["__radd__"], false]
    - ["th2821008", "threading.Barrier.__dict__.__contains__",          ["__radd__"], false]
    - ["th2821009", "threading.local.__dict__.__contains__",            ["__radd__"], false]

# ---------------------------------------------------------------------------
# Table 2: __rsub__ dict-presence (reflected subtraction)
#
# None of the threading types define __rsub__ — they are synchronization
# and concurrency primitives, not numeric types that support subtraction.
# ---------------------------------------------------------------------------

table threading_extra2821.rsub_protocol:
  description: "threading types __rsub__ dict-presence checks — all False (no reflected subtraction protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2821
