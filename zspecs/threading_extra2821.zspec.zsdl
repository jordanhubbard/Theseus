  rows:
    - ["th2821010", "threading.Thread.__dict__.__contains__",           ["__rsub__"], false]
    - ["th2821011", "threading.Lock.__dict__.__contains__",             ["__rsub__"], false]
    - ["th2821012", "threading.Event.__dict__.__contains__",            ["__rsub__"], false]
    - ["th2821013", "threading.Condition.__dict__.__contains__",        ["__rsub__"], false]
    - ["th2821014", "threading.Semaphore.__dict__.__contains__",        ["__rsub__"], false]
    - ["th2821015", "threading.BoundedSemaphore.__dict__.__contains__", ["__rsub__"], false]
    - ["th2821016", "threading.Timer.__dict__.__contains__",            ["__rsub__"], false]
    - ["th2821017", "threading.Barrier.__dict__.__contains__",          ["__rsub__"], false]
    - ["th2821018", "threading.local.__dict__.__contains__",            ["__rsub__"], false]

# ---------------------------------------------------------------------------
# Table 3: __rmul__ dict-presence (reflected multiplication)
#
# None of the threading types define __rmul__ — multiplication has no
# meaning for thread synchronization or thread-local storage objects.
# ---------------------------------------------------------------------------

table threading_extra2821.rmul_protocol:
  description: "threading types __rmul__ dict-presence checks — all False (no reflected multiplication protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2821
  columns: [id, function, args, expected]
  rows:
    - ["th2821019", "threading.Thread.__dict__.__contains__",           ["__rmul__"], false]
    - ["th2821020", "threading.Lock.__dict__.__contains__",             ["__rmul__"], false]
    - ["th2821021", "threading.Event.__dict__.__contains__",            ["__rmul__"], false]
    - ["th2821022", "threading.Condition.__dict__.__contains__",        ["__rmul__"], false]
    - ["th2821023", "threading.Semaphore.__dict__.__contains__",        ["__rmul__"], false]
    - ["th2821024", "threading.BoundedSemaphore.__dict__.__contains__", ["__rmul__"], false]
    - ["th2821025", "threading.Timer.__dict__.__contains__",            ["__rmul__"], false]
    - ["th2821026", "threading.Barrier.__dict__.__contains__",          ["__rmul__"], false]
    - ["th2821027", "threading.local.__dict__.__contains__",            ["__rmul__"], false]

# ---------------------------------------------------------------------------
# Table 4: combined reflected arithmetic operator absence — all types, all ops
#
# Cross-check: each threading type lacks all three reflected arithmetic operators.
# Confirms that the threading API is a synchronization surface only — mutual
# exclusion, signaling, and phase barriers have no numeric arithmetic protocol.
# ---------------------------------------------------------------------------

table threading_extra2821.reflected_arith_absent:
  description: "threading types full __radd__/__rsub__/__rmul__ absence cross-check — all False"
