spec: abc_extra164
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.ABCMeta.__dict__.__contains__ checks for 'register', '__new__', '__instancecheck__', '__subclasscheck__' (all previously covered individually in extra163; here collected in comparison tables); abc.ABCMeta.__dict__.__len__()==11; abc.ABC.__dict__.__class__.__name__=='mappingproxy'; abc.ABC.__dict__.__len__()==7. KEY FINDINGS: ABCMeta.__dict__.__len__()==11 (11 entries: '__module__', '__firstlineno__', '__doc__', '__new__', 'register', '__instancecheck__', '__subclasscheck__', '_dump_registry', '_abc_registry_clear', '_abc_caches_clear', '__static_attributes__'); ABC.__dict__.__len__()==7 (7 entries: '__module__', '__firstlineno__', '__doc__', '__slots__', '__static_attributes__', '__abstractmethods__', '_abc_impl'); ABC.__dict__.__class__.__name__=='mappingproxy' (read-only class namespace view). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__dict__.__contains__('register')==True; abc.ABCMeta.__dict__.__contains__('__new__')==True; abc.ABCMeta.__dict__.__contains__('__instancecheck__')==True; abc.ABCMeta.__dict__.__contains__('__subclasscheck__')==True — all four confirmed (register and __instancecheck__/__subclasscheck__ were established in extra163; __new__ was established in extra163; here used in new cross-check tables focused on dict size). Verified with Python 3.14.3."
    - "abc.ABCMeta.__dict__.__len__()==11: ABCMeta.__dict__ keys are: '__module__', '__firstlineno__', '__doc__', '__new__', 'register', '__instancecheck__', '__subclasscheck__', '_dump_registry', '_abc_registry_clear', '_abc_caches_clear', '__static_attributes__'. compare: abc.ABC.__dict__.__len__()==7 (7 entries; 4 fewer than ABCMeta's 11). abc.ABC.__dict__.__class__.__name__=='mappingproxy' (same as any class dict). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta.__dict__.__contains__ and __len__ — extra164
#
# abc.ABCMeta.__dict__.__contains__('register')         == True
# abc.ABCMeta.__dict__.__contains__('__new__')          == True
# abc.ABCMeta.__dict__.__len__()                        == 11
# ---------------------------------------------------------------------------

table abc_extra164.abc_ABCMeta_dict_len_and_register:
  description: "abc.ABCMeta.__dict__ length and register/new membership cross-checks in abcmetadictlen164 namespace — abc.ABCMeta.__dict__.__len__()==11 (ABCMeta's class dict has exactly 11 entries in Python 3.14.3: '__module__', '__firstlineno__', '__doc__', '__new__', 'register', '__instancecheck__', '__subclasscheck__', '_dump_registry', '_abc_registry_clear', '_abc_caches_clear', '__static_attributes__'; no other entries); abc.ABCMeta.__dict__.__contains__('register')==True ('register' is one of the 11 entries in ABCMeta.__dict__; established in extra163; cross-checked here in the context of the total dict size of 11); abc.ABCMeta.__dict__.__contains__('__new__')==True ('__new__' is one of the 11 entries; established in extra163; cross-checked here); compare: abc.ABC.__dict__.__len__()==7 (ABC's dict has only 7 entries — 4 fewer than ABCMeta's 11; ABC is a thin wrapper while ABCMeta is the fully featured metaclass); KEY: ABCMeta dict len(11) > ABC dict len(7) by 4 — ABCMeta owns 4 more direct class-namespace entries than ABC; ABCMeta.__dict__.__len__()==11 == ABCMeta.__mro__.__len__()==3... NO, 11 != 3; the dict len (11) does NOT equal the MRO len (3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetadictlen164

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_dict_len,       abc.ABCMeta.__dict__.__len__,          [],              11,    "ABCMeta.__dict__.__len__() == 11 (11 entries in ABCMeta class dict; Python 3.14.3); verified with Python 3.14.3"]
    - [abcmeta_dict_register,  abc.ABCMeta.__dict__.__contains__,     ["register"],    true,  "ABCMeta.__dict__.__contains__('register') == True (register is 1 of 11 entries); verified with Python 3.14.3"]
    - [abcmeta_dict_new,       abc.ABCMeta.__dict__.__contains__,     ["__new__"],     true,  "ABCMeta.__dict__.__contains__('__new__') == True (__new__ is 1 of 11; computes __abstractmethods__); verified with Python 3.14.3"]
    - [abcmeta_dict_len2,      abc.ABCMeta.__dict__.__len__,          [],              11,    "ABCMeta.__dict__.__len__() == 11 (cross-check; 4 more than ABC.__dict__.__len__()==7); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__dict__.__contains__ — __instancecheck__ and __subclasscheck__ — extra164
#
# abc.ABCMeta.__dict__.__contains__('__instancecheck__')  == True
# abc.ABCMeta.__dict__.__contains__('__subclasscheck__')  == True
# abc.ABCMeta.__dict__.__len__()                          == 11
# ---------------------------------------------------------------------------

table abc_extra164.abc_ABCMeta_dict_check_methods_and_len:
  description: "abc.ABCMeta.__dict__.__contains__ checks for __instancecheck__ and __subclasscheck__ with dict length context in abcmetacheck164 namespace — abc.ABCMeta.__dict__.__contains__('__instancecheck__')==True ('__instancecheck__' is directly in ABCMeta.__dict__ — it is one of ABCMeta's 11 class dict entries; established in extra163; cross-checked here with dict-length context); abc.ABCMeta.__dict__.__contains__('__subclasscheck__')==True ('__subclasscheck__' is also directly in ABCMeta.__dict__ — also one of the 11 entries; established in extra163; cross-checked here); abc.ABCMeta.__dict__.__len__()==11 (cross-check; confirming the total count remains 11 — both '__instancecheck__' and '__subclasscheck__' are counted among the 11 entries, along with 'register', '__new__', '_dump_registry', '_abc_registry_clear', '_abc_caches_clear', '__module__', '__firstlineno__', '__doc__', '__static_attributes__'); the four target methods ('register', '__new__', '__instancecheck__', '__subclasscheck__') together account for 4 of the 11 ABCMeta dict entries; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetacheck164

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_dict_instancecheck,  abc.ABCMeta.__dict__.__contains__,  ["__instancecheck__"],  true,  "ABCMeta.__dict__.__contains__('__instancecheck__') == True (1 of 11 dict entries; overrides isinstance()); verified with Python 3.14.3"]
    - [abcmeta_dict_subclasscheck,  abc.ABCMeta.__dict__.__contains__,  ["__subclasscheck__"],  true,  "ABCMeta.__dict__.__contains__('__subclasscheck__') == True (1 of 11 dict entries; overrides issubclass()); verified with Python 3.14.3"]
    - [abcmeta_dict_len3,           abc.ABCMeta.__dict__.__len__,       [],                     11,    "ABCMeta.__dict__.__len__() == 11 (cross-check; total entries including both check methods); verified with Python 3.14.3"]
    - [abcmeta_dict_register2,      abc.ABCMeta.__dict__.__contains__,  ["register"],           true,  "ABCMeta.__dict__.__contains__('register') == True (cross-check; 4 target methods confirmed among 11); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC.__dict__.__class__.__name__ and __len__ — extra164
#
# abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy') == True
# abc.ABC.__dict__.__class__.__name__.__len__()               == 12
# abc.ABC.__dict__.__len__()                                  == 7
# ---------------------------------------------------------------------------

table abc_extra164.abc_ABC_dict_class_and_len:
  description: "abc.ABC.__dict__.__class__.__name__ identity and abc.ABC.__dict__.__len__ checks in abcabcdictcls164 namespace — abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy')==True (ABC.__dict__.__class__.__name__=='mappingproxy' (len=12: 'mapping'=7+'proxy'=5=12); ABC's class dict is a mappingproxy, the standard read-only wrapper for class namespaces in Python; every Python class's __dict__ attribute returns a mappingproxy; compare: concurrent.futures.Future.__dict__.__class__.__name__=='mappingproxy' (from extra166) — all class dicts are mappingproxies regardless of class size); abc.ABC.__dict__.__class__.__name__.__len__()==12 ('mappingproxy'=12; same as Future.__dict__.__class__.__name__.__len__()==12 from extra166); abc.ABC.__dict__.__len__()==7 (ABC's class dict has exactly 7 entries in Python 3.14.3: '__module__', '__firstlineno__', '__doc__', '__slots__', '__static_attributes__', '__abstractmethods__', '_abc_impl'; compare: ABCMeta.__dict__.__len__()==11 (4 more entries than ABC=7); concurrent.futures.Future.__dict__.__len__()==21 (from extra166: 14 more than ABC=7)); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcdictcls164

  columns: [id, function, args, expected, description]
  rows:
    - [abc_dict_cls_name_eq,  abc.ABC.__dict__.__class__.__name__.__eq__,  ["mappingproxy"],  true,  "ABC.__dict__.__class__.__name__ == 'mappingproxy' (all class dicts are mappingproxy; len=12); verified with Python 3.14.3"]
    - [abc_dict_cls_name_len, abc.ABC.__dict__.__class__.__name__.__len__, [],                12,    "ABC.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy'=12; same as Future dict class name len=12); verified with Python 3.14.3"]
    - [abc_dict_len,          abc.ABC.__dict__.__len__,                    [],                7,     "ABC.__dict__.__len__() == 7 (7 entries in ABC class dict; 4 fewer than ABCMeta=11); verified with Python 3.14.3"]
    - [abc_dict_len2,         abc.ABC.__dict__.__len__,                    [],                7,     "ABC.__dict__.__len__() == 7 (cross-check; ABC is a thin wrapper — only 7 class dict entries); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta and abc.ABC dict size comparison — extra164
#
# abc.ABCMeta.__dict__.__len__() == 11
# abc.ABC.__dict__.__len__()     == 7
# ABCMeta dict has 4 more entries than ABC dict
# ---------------------------------------------------------------------------

table abc_extra164.abc_dict_size_comparison:
  description: "abc.ABCMeta.__dict__.__len__ vs abc.ABC.__dict__.__len__ size comparison in abcdictcomp164 namespace — abc.ABCMeta.__dict__.__len__()==11 vs abc.ABC.__dict__.__len__()==7 (ABCMeta has 4 more entries than ABC: 11 - 7 = 4; the 4 extra ABCMeta-specific entries relative to ABC's dict reflect that ABCMeta owns the functional heart of the abc machinery: 'register', '__instancecheck__', '__subclasscheck__', '__new__' — while ABC's dict contains the minimalistic class setup: '__slots__', '__abstractmethods__', '_abc_impl' and common entries); abc.ABCMeta.__dict__.__len__()==11 (11 entries: the complete ABCMeta class namespace including all abc-specific methods); abc.ABC.__dict__.__len__()==7 (7 entries: the lean ABC helper class namespace; ABC.__slots__==() is empty — ABC defines __slots__ to prevent instance __dict__ creation, confirmed by '__slots__' appearing in ABC.__dict__); abc.ABCMeta.__dict__.__contains__('register')==True (cross-check; 'register' is among ABCMeta's 11 entries); abc.ABC.__dict__.__class__.__name__.__len__()==12 (cross-check; 'mappingproxy'=12); KEY: dict size ordering: ABC(7) < ABCMeta(11) < Future(21) across the specs; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdictcomp164

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_dict_len4,  abc.ABCMeta.__dict__.__len__,           [],             11,    "ABCMeta.__dict__.__len__() == 11 (11 entries; 4 more than ABC=7); verified with Python 3.14.3"]
    - [abc_dict_len3,      abc.ABC.__dict__.__len__,               [],             7,     "ABC.__dict__.__len__() == 7 (7 entries; 4 fewer than ABCMeta=11); verified with Python 3.14.3"]
    - [abcmeta_has_reg3,   abc.ABCMeta.__dict__.__contains__,     ["register"],   true,  "ABCMeta.__dict__.__contains__('register') == True (cross-check; among 11 entries); verified with Python 3.14.3"]
    - [abc_mp_len2,        abc.ABC.__dict__.__class__.__name__.__len__, [],        12,    "ABC.__dict__.__class__.__name__.__len__() == 12 (cross-check; 'mappingproxy'=12); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra164
# ---------------------------------------------------------------------------

invariant abc_extra164.abc_ABCMeta_dict_len:
  description: "abc.ABCMeta.__dict__.__len__() returns 11 — abc.ABCMeta.__dict__.__len__()==11 (11 entries in ABCMeta's class dict as of Python 3.14.3 on macOS/Darwin 25.4.0); the 11 entries are: '__module__', '__firstlineno__', '__doc__', '__new__', 'register', '__instancecheck__', '__subclasscheck__', '_dump_registry', '_abc_registry_clear', '_abc_caches_clear', '__static_attributes__'; this is the complete class namespace for ABCMeta — it contains both public API ('register', '__new__', '__instancecheck__', '__subclasscheck__') and internal utilities ('_dump_registry', '_abc_registry_clear', '_abc_caches_clear'); the leading underscores on the 'caches' and 'registry' methods mark them as semi-private; compare: abc.ABC.__dict__.__len__()==7 (4 fewer than ABCMeta; ABC is a thin wrapper while ABCMeta is the full metaclass implementation); compare: concurrent.futures.Future.__dict__.__len__()==21 (from extra166; 10 more than ABCMeta=11; Future defines many more public methods than ABCMeta); KEY: ABCMeta dict size(11) > ABC dict size(7) by 4; NEW in extra164: first standalone ABCMeta.__dict__.__len__ invariant in abcmetadictlen164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__len__
  args: []
  expected: 11

invariant abc_extra164.abc_ABCMeta_dict_has_register_xcheck:
  description: "abc.ABCMeta.__dict__.__contains__('register') returns True — cross-check from extra163 in the new abc_extra164 namespace with dict-size context; abc.ABCMeta.__dict__.__contains__('register')==True; 'register' is one of 11 entries in ABCMeta.__dict__; ABCMeta.register(subclass) adds virtual subclasses to an ABC: after registration, isinstance(subclass(), SomeABC) and issubclass(subclass, SomeABC) return True without actual inheritance; 'register' is directly defined in ABCMeta's own __dict__ — it is NOT inherited from type or object; the presence of 'register' among exactly 11 entries in ABCMeta.__dict__ means it accounts for 1/11 ≈ 9% of ABCMeta's class namespace; compare: 'register' is NOT in abc.ABC.__dict__ (abc.ABC.__dict__.__len__()==7 and 'register' is not among those 7 entries — register() is accessed via the metaclass ABCMeta, not via the ABC class itself); NEW in extra164: cross-check of ABCMeta.__dict__.__contains__('register') in abcmetadictlen164 namespace with dict-size context (extra163 covered it in abcmetadict163p); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["register"]
  expected: true

invariant abc_extra164.abc_ABCMeta_dict_has_instancecheck_xcheck:
  description: "abc.ABCMeta.__dict__.__contains__('__instancecheck__') returns True — cross-check from extra163 in the new abc_extra164 namespace with dict-size context; abc.ABCMeta.__dict__.__contains__('__instancecheck__')==True; '__instancecheck__' is one of ABCMeta's 11 class dict entries; ABCMeta.__instancecheck__(cls, instance) is called when isinstance(instance, SomeABC) is evaluated with SomeABC having ABCMeta as its metaclass; '__instancecheck__' is directly in ABCMeta.__dict__ — NOT inherited from type (type also has __instancecheck__ but ABCMeta overrides it); together with '__subclasscheck__', '__instancecheck__' forms the pair of protocol methods that ABCMeta uses to support virtual subclassing via the ABC registration mechanism; compare: abc.ABC.__dict__.__len__()==7 and '__instancecheck__' is NOT in ABC.__dict__ — ABCMeta controls isinstance() behavior, not ABC itself; the 'check' methods (__instancecheck__, __subclasscheck__) together with 'register' and '__new__' form the 4-method functional core of ABCMeta; NEW in extra164: cross-check in abcmetacheck164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__instancecheck__"]
  expected: true

invariant abc_extra164.abc_ABCMeta_dict_has_subclasscheck_xcheck:
  description: "abc.ABCMeta.__dict__.__contains__('__subclasscheck__') returns True — cross-check from extra163 in the new abc_extra164 namespace; abc.ABCMeta.__dict__.__contains__('__subclasscheck__')==True; '__subclasscheck__' is one of ABCMeta's 11 class dict entries; ABCMeta.__subclasscheck__(cls, subclass) is called when issubclass(subclass, SomeABC) is evaluated; it checks: (1) calls cls.__subclasshook__(subclass) (found in object.__dict__, NOT ABCMeta.__dict__ — KEY FINDING from extra163); (2) checks the ABC's virtual subclass registry; (3) falls back to standard MRO-based subclass check; compare: ABCMeta.__dict__ CONTAINS '__subclasscheck__' (True) but does NOT contain '__subclasshook__' (False — established in extra163); CONTRAST: the methods that CALL __subclasshook__ (__instancecheck__, __subclasscheck__) ARE in ABCMeta.__dict__; the hook itself (__subclasshook__) is NOT; ABCMeta.__dict__.__len__()==11 — '__subclasscheck__' is 1 of 11; NEW in extra164: cross-check in abcmetacheck164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__subclasscheck__"]
  expected: true

invariant abc_extra164.abc_ABC_dict_class_name_eq:
  description: "abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — abc.ABC.__dict__.__class__.__name__=='mappingproxy' (len=12: 'mapping'=7+'proxy'=5=12); ABC's class dict is a mappingproxy, the same read-only type wrapper used for all Python class dicts; mappingproxy prevents direct external mutation of the class namespace: ABC.__dict__['x'] = y would raise TypeError (does not support item assignment); to add attributes to ABC, one uses setattr(abc.ABC, 'x', y) or subclassing; compare: concurrent.futures.Future.__dict__.__class__.__name__=='mappingproxy' (from extra166) — both ABC and Future class dicts are mappingproxies; compare: abc.ABCMeta.__dict__.__class__.__name__ is also 'mappingproxy' (all Python class dicts are mappingproxies regardless of whether the class is a metaclass or regular class); 'mappingproxy'=12 chars: 'mapping'=7+'proxy'=5=12; the type is types.MappingProxyType in Python's types module; NEW in extra164: first standalone ABC.__dict__.__class__.__name__ invariant in abcabcdictcls164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra164.abc_ABC_dict_len:
  description: "abc.ABC.__dict__.__len__() returns 7 — abc.ABC.__dict__.__len__()==7 (7 entries in ABC's class dict as of Python 3.14.3 on macOS/Darwin 25.4.0); the 7 entries are: '__module__', '__firstlineno__', '__doc__', '__slots__', '__static_attributes__', '__abstractmethods__', '_abc_impl'; ABC's dict is lean — only 7 entries compared to ABCMeta's 11; NOTABLE ENTRIES: '__slots__' (ABC defines __slots__=() to prevent instance __dict__ creation — ABC instances have no __dict__ by default); '__abstractmethods__' (the frozenset of abstract method names — for ABC itself it is empty: frozenset()); '_abc_impl' (the C-level ABCMeta implementation object from _abc module — this is the C-accelerated backend for the ABC machinery); compare: abc.ABCMeta.__dict__.__len__()==11 (4 more entries than ABC=7; ABCMeta is the feature-rich metaclass while ABC is just a thin helper class); compare: concurrent.futures.Future.__dict__.__len__()==21 (from extra166; 14 more than ABC=7; Future defines many more public methods); KEY dict size ordering: ABC(7) < ABCMeta(11) < Future(21); NEW in extra164: first standalone ABC.__dict__.__len__ invariant in abcabcdictcls164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__len__
  args: []
  expected: 7

invariant abc_extra164.abc_ABCMeta_dict_has_new_xcheck:
  description: "abc.ABCMeta.__dict__.__contains__('__new__') returns True — cross-check from extra163 in the new abc_extra164 namespace with dict-size context; abc.ABCMeta.__dict__.__contains__('__new__')==True; '__new__' is one of ABCMeta's 11 class dict entries; ABCMeta.__new__(mcls, name, bases, namespace, **kwargs) is ABCMeta's class creation hook: it scans the namespace and base classes for abstract method markers (__isabstractmethod__==True) and stores the union in the new class's __abstractmethods__ frozenset; '__new__' is defined directly in ABCMeta.__dict__ — ABCMeta overrides type.__new__ with its own implementation; this is why declaring an abstract class via ABCMeta (or class MyABC(abc.ABC)) automatically sets __abstractmethods__ at class creation time (not at instantiation time); compare: 'register', '__instancecheck__', '__subclasscheck__' are also directly in ABCMeta.__dict__ (all confirmed True); these four methods plus the utility methods (_dump_registry, _abc_registry_clear, _abc_caches_clear) and dunder infrastructure (__module__, __firstlineno__, __doc__, __static_attributes__) make up the 11 entries; NEW in extra164: cross-check in abcmetadictlen164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__new__"]
  expected: true
