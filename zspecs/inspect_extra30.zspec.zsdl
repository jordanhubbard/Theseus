spec: inspect_extra30
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra29.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/__name__, getmembers/signature/Parameter/Signature/BoundArguments identity, Parameter kind class names, empty sentinel class names, class __bases__[0].__name__ for Parameter/Signature/BoundArguments (all 'object'), various __qualname__ and __module__ checks, __qualname__ equality table for 8 predicates, __module__.__len__() and __name__.__len__() for many predicates and classes."
    - "This spec covers: __qualname__.__len__() for key methods on Parameter (replace, __init__), Signature (bind, bind_partial, replace), and BoundArguments (apply_defaults, __init__, __repr__); __mro__.__len__() for Parameter, Signature, and BoundArguments (all 2); Parameter.empty.__qualname__.__len__(); __bases__[0].__name__ confirmation for all three classes."
    - "Key findings: Parameter.replace qualname len=17, Parameter.__init__ qualname len=18, Signature.bind qualname len=14, Signature.bind_partial qualname len=22, Signature.replace qualname len=17, BoundArguments.apply_defaults qualname len=29, BoundArguments.__init__ qualname len=23, BoundArguments.__repr__ qualname len=23."
    - "All three classes have __mro__ of length 2: [ClassName, object]. Parameter.empty.__qualname__ is '_empty' (len 6)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — Parameter and Signature method qualname lengths
#
# inspect.Parameter.replace has qualname 'Parameter.replace' (17 chars).
# inspect.Parameter.__init__ has qualname 'Parameter.__init__' (18 chars).
# inspect.Signature.bind has qualname 'Signature.bind' (14 chars), the
# shortest of the Signature methods recorded here. inspect.Signature.bind_partial
# has qualname 'Signature.bind_partial' (22 chars), and inspect.Signature.replace
# has qualname 'Signature.replace' (17 chars). No prior inspect spec records
# these five method __qualname__.__len__() values together in a combined table
# in the extra30 namespace.
# ---------------------------------------------------------------------------

table inspect_extra30.parameter_signature_method_qualname_lengths:
  description: "__qualname__.__len__() for Parameter and Signature methods"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_replace,
       Parameter.replace.__qualname__.__len__,
       [],
       17,
       "len(inspect.Parameter.replace.__qualname__) == 17 — 'Parameter.replace'"]
    - [Parameter__init__,
       Parameter.__init__.__qualname__.__len__,
       [],
       18,
       "len(inspect.Parameter.__init__.__qualname__) == 18 — 'Parameter.__init__'"]
    - [Signature_bind,
       Signature.bind.__qualname__.__len__,
       [],
       14,
       "len(inspect.Signature.bind.__qualname__) == 14 — 'Signature.bind'"]
    - [Signature_bind_partial,
       Signature.bind_partial.__qualname__.__len__,
       [],
       22,
       "len(inspect.Signature.bind_partial.__qualname__) == 22 — 'Signature.bind_partial'"]
    - [Signature_replace,
       Signature.replace.__qualname__.__len__,
       [],
       17,
       "len(inspect.Signature.replace.__qualname__) == 17 — 'Signature.replace'"]

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — BoundArguments method qualname lengths
#
# inspect.BoundArguments.apply_defaults has qualname 'BoundArguments.apply_defaults'
# (29 chars), the longest method qualname among the three primary inspect classes.
# inspect.BoundArguments.__init__ and BoundArguments.__repr__ both have qualname
# length 23. No prior inspect spec records these three BoundArguments method
# __qualname__.__len__() values together in a combined table in the extra30 namespace.
# ---------------------------------------------------------------------------

table inspect_extra30.boundarguments_method_qualname_lengths:
  description: "__qualname__.__len__() for BoundArguments methods"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [apply_defaults,
       BoundArguments.apply_defaults.__qualname__.__len__,
       [],
       29,
       "len(inspect.BoundArguments.apply_defaults.__qualname__) == 29 — 'BoundArguments.apply_defaults'"]
    - [__init__,
       BoundArguments.__init__.__qualname__.__len__,
       [],
       23,
       "len(inspect.BoundArguments.__init__.__qualname__) == 23 — 'BoundArguments.__init__'"]
    - [__repr__,
       BoundArguments.__repr__.__qualname__.__len__,
       [],
       23,
       "len(inspect.BoundArguments.__repr__.__qualname__) == 23 — 'BoundArguments.__repr__'"]

# ---------------------------------------------------------------------------
# __mro__.__len__() table — hierarchy depth for Parameter, Signature, BoundArguments
#
# All three primary inspect classes have an __mro__ of length 2: [ClassName, object].
# None inherits from any intermediate class — each is a direct subclass of object.
# This confirms the flat class hierarchy used by the inspect module for these
# data-carrier types. No prior inspect spec records __mro__.__len__() for these
# three classes together in a combined table in the extra30 namespace.
# ---------------------------------------------------------------------------

table inspect_extra30.primary_class_mro_lengths:
  description: "__mro__.__len__() for Parameter, Signature, and BoundArguments — all 2"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mro_len

  columns: [id, function, method, method_args, expected, description]
  rows:
    - [Parameter,
       Parameter.__mro__,
       __len__,
       [],
       2,
       "len(inspect.Parameter.__mro__) == 2 — [Parameter, object]"]
    - [Signature,
       Signature.__mro__,
       __len__,
       [],
       2,
       "len(inspect.Signature.__mro__) == 2 — [Signature, object]"]
    - [BoundArguments,
       BoundArguments.__mro__,
       __len__,
       [],
       2,
       "len(inspect.BoundArguments.__mro__) == 2 — [BoundArguments, object]"]

# ---------------------------------------------------------------------------
# BoundArguments.apply_defaults.__qualname__.__len__() — standalone invariant
#
# inspect.BoundArguments.apply_defaults.__qualname__ is 'BoundArguments.apply_defaults',
# a 29-character string. This is the longest method qualname among the three primary
# inspect classes. apply_defaults fills in default values for missing arguments in a
# BoundArguments instance; its long qualname reflects the compound descriptor path.
# No prior inspect spec records this standalone in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra30.BoundArguments.apply_defaults_qualname_len:
  description: "len(inspect.BoundArguments.apply_defaults.__qualname__) == 29 — 'BoundArguments.apply_defaults'"
  category: method_qualnames
  kind: python_call_eq
  function: BoundArguments.apply_defaults.__qualname__.__len__
  args: []
  expected: 29

# ---------------------------------------------------------------------------
# Parameter.empty.__qualname__.__len__() — standalone invariant
#
# inspect.Parameter.empty is the sentinel class <class 'inspect._empty'> used
# to indicate that a parameter has no annotation or default value. Its __qualname__
# is '_empty' (6 chars). The leading underscore marks it as a private implementation
# detail. No prior inspect spec records Parameter.empty.__qualname__.__len__()
# as a standalone in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra30.Parameter_empty_qualname_len:
  description: "len(inspect.Parameter.empty.__qualname__) == 6 — '_empty' is 6 chars"
  category: method_qualnames
  kind: python_call_eq
  function: Parameter.empty.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Signature.bind_partial.__qualname__.__len__() — standalone invariant
#
# inspect.Signature.bind_partial.__qualname__ is 'Signature.bind_partial' (22 chars),
# the longest method qualname on Signature. bind_partial is like bind but allows
# partial binding — missing arguments do not raise an error. Its compound name
# with the '_partial' suffix accounts for the extra length over Signature.bind (14).
# No prior inspect spec records this standalone in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra30.Signature_bind_partial_qualname_len:
  description: "len(inspect.Signature.bind_partial.__qualname__) == 22 — 'Signature.bind_partial'"
  category: method_qualnames
  kind: python_call_eq
  function: Signature.bind_partial.__qualname__.__len__
  args: []
  expected: 22
