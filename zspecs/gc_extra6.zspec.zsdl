spec: gc_extra6
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "This spec extends gc.zspec.zsdl, gc_extra.zspec.zsdl, gc_extra2.zspec.zsdl, gc_extra3.zspec.zsdl, gc_extra4.zspec.zsdl, and gc_extra5.zspec.zsdl."
    - "gc.zspec.zsdl covers: __name__ table for all gc functions; isenabled()==True; get_threshold/get_count tuple length and type; collect nonneg/int; is_tracked list/dict/int; DEBUG_* constants."
    - "gc_extra4.zspec.zsdl covers: __name__ table for enable/disable/isenabled/collect/get_count/get_threshold/set_threshold/get_objects/get_referrers/get_referents; isenabled returns bool; get_threshold/get_count return tuple of len 3; collect returns int."
    - "gc_extra5.zspec.zsdl covers: __module__ for collect/set_threshold/get_referrers/get_referents/is_tracked/is_finalized/freeze/unfreeze/get_freeze_count; garbage/callbacks length checks."
    - "This spec adds __qualname__ checks for all gc functions."
    - "For C-level builtin functions, __qualname__ == __name__ (no enclosing scope)."
    - "gc.collect.__qualname__ == 'collect'."
    - "gc.disable.__qualname__ == 'disable'."
    - "gc.enable.__qualname__ == 'enable'."
    - "gc.isenabled.__qualname__ == 'isenabled'."
    - "gc.get_count.__qualname__ == 'get_count'."
    - "gc.get_threshold.__qualname__ == 'get_threshold'."
    - "gc.set_threshold.__qualname__ == 'set_threshold'."
    - "gc.get_objects.__qualname__ == 'get_objects'."
    - "gc.get_referrers.__qualname__ == 'get_referrers'."
    - "gc.get_referents.__qualname__ == 'get_referents'."
    - "gc.is_tracked.__qualname__ == 'is_tracked'."
    - "gc.freeze.__qualname__ == 'freeze'."
    - "gc.unfreeze.__qualname__ == 'unfreeze'."
    - "gc.get_freeze_count.__qualname__ == 'get_freeze_count'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ checks
# C-level builtin functions expose __qualname__ == __name__.
# Prior specs cover __name__ (gc.zspec + gc_extra4) and __module__ (gc_extra3 + gc_extra5).
# ---------------------------------------------------------------------------

table gc_extra6.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [collect,          collect.__qualname__.__eq__,          ["collect"],          true]
    - [disable,          disable.__qualname__.__eq__,          ["disable"],          true]
    - [enable,           enable.__qualname__.__eq__,           ["enable"],           true]
    - [isenabled,        isenabled.__qualname__.__eq__,        ["isenabled"],        true]
    - [get_count,        get_count.__qualname__.__eq__,        ["get_count"],        true]
    - [get_threshold,    get_threshold.__qualname__.__eq__,    ["get_threshold"],    true]
    - [set_threshold,    set_threshold.__qualname__.__eq__,    ["set_threshold"],    true]
    - [get_objects,      get_objects.__qualname__.__eq__,      ["get_objects"],      true]
    - [get_referrers,    get_referrers.__qualname__.__eq__,    ["get_referrers"],    true]
    - [get_referents,    get_referents.__qualname__.__eq__,    ["get_referents"],    true]
    - [is_tracked,       is_tracked.__qualname__.__eq__,       ["is_tracked"],       true]
    - [freeze,           freeze.__qualname__.__eq__,           ["freeze"],           true]
    - [unfreeze,         unfreeze.__qualname__.__eq__,         ["unfreeze"],         true]
    - [get_freeze_count, get_freeze_count.__qualname__.__eq__, ["get_freeze_count"], true]
