spec: threading_extra156
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.local.__init__.__qualname__ 'object.__init__' (local's __init__ is inherited from object); threading._DummyThread.__name__ '_DummyThread', __module__ 'threading', __bases__[0].__name__ 'Thread'; threading._MainThread.__name__ '_MainThread', __bases__[0].__name__ 'Thread'; threading.Thread.__init__.__qualname__ 'Thread.__init__'; threading.Thread.start.__qualname__ 'Thread.start' (Wave 284)."
    - "threading.local.__init__.__qualname__ == 'object.__init__' — threading.local is a C extension type from _threadmodule.c; it does not define its own __init__ so the descriptor is inherited from object; __qualname__ is 'object.__init__'. Verified with Python 3.14.3."
    - "threading._DummyThread.__name__ == '_DummyThread' — _DummyThread is an internal Thread subclass representing non-Python threads; __name__ is '_DummyThread'. Verified with Python 3.14.3."
    - "threading._DummyThread.__module__ == 'threading' — _DummyThread is defined in Lib/threading.py; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading._DummyThread.__bases__[0].__name__ == 'Thread' — _DummyThread inherits from Thread; __bases__[0].__name__ is 'Thread'. Verified with Python 3.14.3."
    - "threading._MainThread.__name__ == '_MainThread' — _MainThread is an internal Thread subclass representing the main thread; __name__ is '_MainThread'. Verified with Python 3.14.3."
    - "threading._MainThread.__bases__[0].__name__ == 'Thread' — _MainThread inherits from Thread; __bases__[0].__name__ is 'Thread'. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__qualname__ == 'Thread.__init__' — Thread defines its own __init__; the qualname is 'Thread.__init__'. Verified with Python 3.14.3."
    - "threading.Thread.start.__qualname__ == 'Thread.start' — Thread defines its own start method; the qualname is 'Thread.start'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.local.__init__ qualname and threading._DummyThread identity
#
# Wave 284 theme: threading.local method qualname and _DummyThread class identity.
#
# threading.local.__init__.__qualname__ == 'object.__init__'
# threading._DummyThread.__name__ == '_DummyThread'
# threading._DummyThread.__module__ == 'threading'
# threading._DummyThread.__bases__[0].__name__ == 'Thread'
#
# threading.local is a C extension type defined in _threadmodule.c that provides
# thread-local storage. It does not define its own __init__, so the slot is
# inherited from object; __qualname__ is 'object.__init__'. _DummyThread is an
# internal Thread subclass that wraps non-Python-created threads.
# New to extra156.
# ---------------------------------------------------------------------------

table threading_extra156.local_init_qualname_and_dummy_thread_identity:
  description: "threading.local.__init__.__qualname__ 'object.__init__'; threading._DummyThread: __name__ '_DummyThread', __module__ 'threading', __bases__[0] 'Thread'; wave 284; new to extra156"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingliqdt156

  columns: [id, function, args, expected, description]
  rows:
    - [local_init_qualname_eq,
       "local.__init__.__qualname__.__eq__",
       ["object.__init__"],
       true,
       "threading.local.__init__.__qualname__.__eq__('object.__init__') == True — threading.local is a C extension type; it does not define its own __init__ so the slot is inherited from object; __qualname__ is 'object.__init__'; str.__eq__('object.__init__') returns True; new to extra156"]
    - [dummy_thread_name_eq,
       "_DummyThread.__name__.__eq__",
       ["_DummyThread"],
       true,
       "threading._DummyThread.__name__.__eq__('_DummyThread') == True — _DummyThread is an internal Thread subclass in Lib/threading.py representing threads not created by the Python threading module; its __name__ is '_DummyThread'; str.__eq__('_DummyThread') returns True; new to extra156"]
    - [dummy_thread_module_eq_threading,
       "_DummyThread.__module__.__eq__",
       ["threading"],
       true,
       "threading._DummyThread.__module__.__eq__('threading') == True — _DummyThread is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra156"]
    - ["dummy_thread_bases_0_name_eq_Thread",
       "_DummyThread.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading._DummyThread.__bases__[0].__name__.__eq__('Thread') == True — _DummyThread inherits from Thread (not object); it is a Thread subclass wrapping externally-created threads; __bases__[0].__name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra156"]

# ---------------------------------------------------------------------------
# Table 2: threading._MainThread identity and threading.Thread method qualnames
#
# Wave 284 theme: threading._MainThread class identity and Thread method qualnames.
#
# threading._MainThread.__name__ == '_MainThread'
# threading._MainThread.__bases__[0].__name__ == 'Thread'
# threading.Thread.__init__.__qualname__ == 'Thread.__init__'
# threading.Thread.start.__qualname__ == 'Thread.start'
#
# _MainThread is the singleton Thread subclass representing the process main
# thread. Thread.__init__ and Thread.start are Python methods defined in
# Lib/threading.py; their __qualname__ values reflect their enclosing class.
# New to extra156.
# ---------------------------------------------------------------------------

table threading_extra156.main_thread_identity_and_thread_method_qualnames:
  description: "threading._MainThread: __name__ '_MainThread', __bases__[0] 'Thread'; threading.Thread.__init__.__qualname__ 'Thread.__init__'; Thread.start.__qualname__ 'Thread.start'; wave 284; new to extra156"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingmtidtmq156

  columns: [id, function, args, expected, description]
  rows:
    - [main_thread_name_eq,
       "_MainThread.__name__.__eq__",
       ["_MainThread"],
       true,
       "threading._MainThread.__name__.__eq__('_MainThread') == True — _MainThread is the internal Thread subclass representing the main thread of the Python process; its __name__ is '_MainThread'; str.__eq__('_MainThread') returns True; new to extra156"]
    - ["main_thread_bases_0_name_eq_Thread",
       "_MainThread.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading._MainThread.__bases__[0].__name__.__eq__('Thread') == True — _MainThread inherits from Thread (not object); it is a Thread subclass for the process main thread; __bases__[0].__name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra156"]
    - [thread_init_qualname_eq,
       "Thread.__init__.__qualname__.__eq__",
       ["Thread.__init__"],
       true,
       "threading.Thread.__init__.__qualname__.__eq__('Thread.__init__') == True — Thread defines its own __init__ in Lib/threading.py; the method's __qualname__ is 'Thread.__init__' reflecting the class scope; str.__eq__('Thread.__init__') returns True; new to extra156"]
    - [thread_start_qualname_eq,
       "Thread.start.__qualname__.__eq__",
       ["Thread.start"],
       true,
       "threading.Thread.start.__qualname__.__eq__('Thread.start') == True — Thread defines its own start method in Lib/threading.py; the method's __qualname__ is 'Thread.start' reflecting the class scope; str.__eq__('Thread.start') returns True; new to extra156"]

