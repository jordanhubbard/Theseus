spec: inspect_extra2026
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 582 (_extra2026): __truediv__/__rtruediv__/__itruediv__, __floordiv__/__rfloordiv__/__ifloordiv__, __mod__/__rmod__/__imod__, __pow__/__rpow__, __divmod__/__rdivmod__ dict-presence checks."
    - "inspect classes are introspection utilities — none define division, modulo, exponentiation, or divmod operators."
    - "inspect.Parameter: Python class representing a callable parameter — division/modulo/pow/divmod dunders absent from __dict__."
    - "inspect.Signature: Python class representing a callable signature — division/modulo/pow/divmod dunders absent from __dict__."
    - "inspect.BoundArguments: Python class representing bound arguments — division/modulo/pow/divmod dunders absent from __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __truediv__ / __rtruediv__ / __itruediv__ dict-presence
#
# inspect.Parameter, inspect.Signature, and inspect.BoundArguments are
# introspection utility types. They carry no numeric semantics and define
# no true-division operators in their __dict__.
# All checks expected False.
# ---------------------------------------------------------------------------

table inspect_extra2026.truediv_protocol:
  description: "inspect classes __truediv__/__rtruediv__/__itruediv__ dict-presence checks — all False — wave 582 _extra2026"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2026

  columns: [id, function, args, expected]
  rows:
    - ["in2026001", "inspect.Parameter.__dict__.__contains__", ["__truediv__"], false]
    - ["in2026002", "inspect.Parameter.__dict__.__contains__", ["__rtruediv__"], false]
    - ["in2026003", "inspect.Parameter.__dict__.__contains__", ["__itruediv__"], false]
    - ["in2026004", "inspect.Signature.__dict__.__contains__", ["__truediv__"], false]
    - ["in2026005", "inspect.Signature.__dict__.__contains__", ["__rtruediv__"], false]
    - ["in2026006", "inspect.Signature.__dict__.__contains__", ["__itruediv__"], false]
    - ["in2026007", "inspect.BoundArguments.__dict__.__contains__", ["__truediv__"], false]
    - ["in2026008", "inspect.BoundArguments.__dict__.__contains__", ["__rtruediv__"], false]
    - ["in2026009", "inspect.BoundArguments.__dict__.__contains__", ["__itruediv__"], false]

