spec: concurrent_futures_extra1711
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 561 (_extra1711): __init__ protocol dict-presence checks."
    - "concurrent.futures.Future is a pure Python class defined in concurrent/futures/_base.py; it defines __init__ in its own __dict__ -> True."
    - "concurrent.futures.ThreadPoolExecutor is a pure Python class defined in concurrent/futures/thread.py; it defines __init__ in its own __dict__ -> True."
    - "concurrent.futures.ProcessPoolExecutor is a pure Python class defined in concurrent/futures/process.py; it defines __init__ in its own __dict__ -> True."
    - "concurrent.futures.Executor is an abstract base class defined in concurrent/futures/_base.py; it does NOT define __init__ in its own __dict__ (relies on object.__init__) -> False."
    - "Cross-check: none of the executor/future classes define __new__ in their own __dict__ (all pure Python, inheriting __new__ from object) -> False."
    - "__init_subclass__ is inherited from object; none of the concurrent.futures classes add it to their own __dict__ -> False."
    - "__class_getitem__ is not defined by concurrent.futures types (no generic syntax support) -> False for Executor and Future."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __init__ dict-presence checks
#
# Wave 561 theme: which concurrent.futures types define __init__ in their own
# __dict__. All three concrete classes (Future, ThreadPoolExecutor,
# ProcessPoolExecutor) are pure Python and each defines a non-trivial __init__
# to initialize instance state such as locks, condition variables, thread pools,
# and process pools. Executor, the abstract base class, does NOT define __init__
# because it has no instance state to initialize; all initialization is
# delegated to the concrete subclasses.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1711.init_protocol:
  description: "concurrent.futures types: __init__ dict-presence via __dict__.__contains__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1711

  columns: [id, function, args, expected]
  rows:
    - ["cf1711001", "concurrent.futures.Future.__dict__.__contains__",              ["__init__"], true]
    - ["cf1711002", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__init__"], true]
    - ["cf1711003", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__init__"], true]
    - ["cf1711004", "concurrent.futures.Executor.__dict__.__contains__",            ["__init__"], false]

# ---------------------------------------------------------------------------
# Table 2: __new__ dict-presence cross-checks
#
# Wave 561 cross-check: all concurrent.futures classes are pure Python and
# inherit __new__ from object. None define __new__ in their own __dict__.
# This distinguishes them from C extension types (like functools.partial) that
# define __new__ in their own __dict__ to handle C-level construction.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1711.new_protocol:
  description: "concurrent.futures types: __new__ dict-presence cross-check (all pure Python — none define __new__ in own __dict__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1711

  columns: [id, function, args, expected]
  rows:
    - ["cf1711005", "concurrent.futures.Future.__dict__.__contains__",              ["__new__"], false]
    - ["cf1711006", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__new__"], false]
    - ["cf1711007", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__new__"], false]
    - ["cf1711008", "concurrent.futures.Executor.__dict__.__contains__",            ["__new__"], false]

# ---------------------------------------------------------------------------
# Table 3: __init_subclass__ and __class_getitem__ dict-presence cross-checks
#
# Wave 561 extension: __init_subclass__ is defined on object and inherited;
# none of the concurrent.futures classes override it in their own __dict__.
# __class_getitem__ supports generic syntax (PEP 560); concurrent.futures
# types do not support generic syntax and do not define __class_getitem__
# in their own __dict__. These checks confirm the protocol absence across
# the four public types of the module.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1711.related_dunder_protocol:
  description: "concurrent.futures types: __init_subclass__ and __class_getitem__ dict-presence (both inherited/absent, not in own __dict__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1711

  columns: [id, function, args, expected]
  rows:
    - ["cf1711009",  "concurrent.futures.Future.__dict__.__contains__",              ["__init_subclass__"], false]
    - ["cf1711010",  "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__init_subclass__"], false]
    - ["cf1711011",  "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__init_subclass__"], false]
    - ["cf1711012",  "concurrent.futures.Executor.__dict__.__contains__",            ["__init_subclass__"], false]
    - ["cf1711013",  "concurrent.futures.Future.__dict__.__contains__",              ["__class_getitem__"], false]
    - ["cf1711014",  "concurrent.futures.Executor.__dict__.__contains__",            ["__class_getitem__"], false]
    - ["cf1711015",  "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__class_getitem__"], false]
    - ["cf1711016",  "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__class_getitem__"], false]
