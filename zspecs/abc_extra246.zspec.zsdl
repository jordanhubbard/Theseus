spec: abc_extra246
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/library/abc.html#abc.update_abstractmethods — update_abstractmethods (added 3.10)"
    - "https://docs.python.org/3/library/abc.html#abc.get_cache_token — get_cache_token"
    - "https://docs.python.org/3/library/abc.html#abc.abstractproperty — abstractproperty (deprecated)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py (internal implementation)"
    - "CPython source: Modules/_abc.c (C-level accelerators)"
  notes:
    - "abc module has no __all__ attribute in Python 3.14.3 — hasattr(abc, '__all__') == False."
    - "Public names (via dir): ABC, ABCMeta, abstractclassmethod, abstractmethod, abstractproperty, abstractstaticmethod, get_cache_token, update_abstractmethods — 8 names total."
    - "abc.abstractmethod.__name__ == 'abstractmethod' (len=14); type is 'function' (pure Python), unlike ABCMeta (type='ABCMeta') and ABC (type='ABCMeta')."
    - "abc.abstractproperty.__bases__[0].__name__ == 'property' (len=8); abc.abstractclassmethod.__bases__[0].__name__ == 'classmethod' (len=11)."
    - "abc.abstractstaticmethod.__bases__[0].__name__ == 'staticmethod' (len=12); abc.ABCMeta.__bases__[0].__name__ == 'type' (len=4)."
    - "abc.get_cache_token.__module__ == '_abc' (len=4); implemented in C extension, re-exported by abc module."
    - "abc.update_abstractmethods.__name__ == 'update_abstractmethods' (len=22; longest name among public abc names)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc public name identity — class names and base classes
#
# ABC.__name__ == 'ABC' (len=3); __bases__[0].__name__ == 'object'
# ABCMeta.__name__ == 'ABCMeta' (len=7); __bases__[0].__name__ == 'type'
# abstractproperty.__name__ == 'abstractproperty' (len=16); __bases__[0].__name__ == 'property'
# abstractclassmethod.__name__ == 'abstractclassmethod' (len=19); __bases__[0].__name__ == 'classmethod'
# abstractstaticmethod.__name__ == 'abstractstaticmethod' (len=20); __bases__[0].__name__ == 'staticmethod'
# ---------------------------------------------------------------------------

table abc_extra246.abc_class_identity:
  description: "abc module class identity — ABC(len=3) subclasses object(len=6); ABCMeta(len=7) subclasses type(len=4) making it a metaclass; abstractproperty(len=16) subclasses property(len=8); abstractclassmethod(len=19) subclasses classmethod(len=11); abstractstaticmethod(len=20) subclasses staticmethod(len=12); all have __module__=='abc'(len=3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc246ci

  columns: [id, function, args, expected, description]
  rows:
    - [ci_abc_name_eq,   ABC.__name__.__eq__,                          ["ABC"],                   true, "abc.ABC.__name__ == 'ABC'; verified with Python 3.14.3"]
    - [ci_abc_name_len,  ABC.__name__.__len__,                         [],                        3,    "abc.ABC.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [ci_abc_mod_eq,    ABC.__module__.__eq__,                        ["abc"],                   true, "abc.ABC.__module__ == 'abc'; verified with Python 3.14.3"]
    - [ci_abc_base_eq,   "ABC.__bases__[0].__name__.__eq__",           ["object"],                true, "abc.ABC.__bases__[0].__name__ == 'object'; verified with Python 3.14.3"]
    - [ci_am_name_eq,    ABCMeta.__name__.__eq__,                      ["ABCMeta"],               true, "abc.ABCMeta.__name__ == 'ABCMeta'; verified with Python 3.14.3"]
    - [ci_am_name_len,   ABCMeta.__name__.__len__,                     [],                        7,    "abc.ABCMeta.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [ci_am_mod_eq,     ABCMeta.__module__.__eq__,                    ["abc"],                   true, "abc.ABCMeta.__module__ == 'abc'; verified with Python 3.14.3"]
    - [ci_am_base_eq,    "ABCMeta.__bases__[0].__name__.__eq__",       ["type"],                  true, "abc.ABCMeta.__bases__[0].__name__ == 'type' (ABCMeta is a metaclass); verified with Python 3.14.3"]
    - [ci_ap_name_eq,    abstractproperty.__name__.__eq__,             ["abstractproperty"],      true, "abc.abstractproperty.__name__ == 'abstractproperty'; verified with Python 3.14.3"]
    - [ci_ap_name_len,   abstractproperty.__name__.__len__,            [],                        16,   "abc.abstractproperty.__name__.__len__() == 16; verified with Python 3.14.3"]
    - [ci_ap_mod_eq,     abstractproperty.__module__.__eq__,           ["abc"],                   true, "abc.abstractproperty.__module__ == 'abc'; verified with Python 3.14.3"]
    - [ci_ap_base_eq,    "abstractproperty.__bases__[0].__name__.__eq__", ["property"],           true, "abc.abstractproperty.__bases__[0].__name__ == 'property'; verified with Python 3.14.3"]
    - [ci_ap_base_len,   "abstractproperty.__bases__[0].__name__.__len__", [],                    8,    "abc.abstractproperty.__bases__[0].__name__.__len__() == 8; verified with Python 3.14.3"]
    - [ci_acm_name_eq,   abstractclassmethod.__name__.__eq__,          ["abstractclassmethod"],   true, "abc.abstractclassmethod.__name__ == 'abstractclassmethod'; verified with Python 3.14.3"]
    - [ci_acm_name_len,  abstractclassmethod.__name__.__len__,         [],                        19,   "abc.abstractclassmethod.__name__.__len__() == 19; verified with Python 3.14.3"]
    - [ci_acm_mod_eq,    abstractclassmethod.__module__.__eq__,        ["abc"],                   true, "abc.abstractclassmethod.__module__ == 'abc'; verified with Python 3.14.3"]
    - [ci_acm_base_eq,   "abstractclassmethod.__bases__[0].__name__.__eq__", ["classmethod"],     true, "abc.abstractclassmethod.__bases__[0].__name__ == 'classmethod'; verified with Python 3.14.3"]
    - [ci_acm_base_len,  "abstractclassmethod.__bases__[0].__name__.__len__", [],                 11,   "abc.abstractclassmethod.__bases__[0].__name__.__len__() == 11; verified with Python 3.14.3"]
    - [ci_asm_name_eq,   abstractstaticmethod.__name__.__eq__,         ["abstractstaticmethod"],  true, "abc.abstractstaticmethod.__name__ == 'abstractstaticmethod'; verified with Python 3.14.3"]
    - [ci_asm_name_len,  abstractstaticmethod.__name__.__len__,        [],                        20,   "abc.abstractstaticmethod.__name__.__len__() == 20; verified with Python 3.14.3"]
    - [ci_asm_mod_eq,    abstractstaticmethod.__module__.__eq__,       ["abc"],                   true, "abc.abstractstaticmethod.__module__ == 'abc'; verified with Python 3.14.3"]
    - [ci_asm_base_eq,   "abstractstaticmethod.__bases__[0].__name__.__eq__", ["staticmethod"],   true, "abc.abstractstaticmethod.__bases__[0].__name__ == 'staticmethod'; verified with Python 3.14.3"]
    - [ci_asm_base_len,  "abstractstaticmethod.__bases__[0].__name__.__len__", [],                12,   "abc.abstractstaticmethod.__bases__[0].__name__.__len__() == 12; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc function identity — abstractmethod, get_cache_token, update_abstractmethods
#
# abstractmethod.__name__ == 'abstractmethod' (len=14); __module__ == 'abc'; type == 'function'
# get_cache_token.__name__ == 'get_cache_token' (len=15); __module__ == '_abc'; type == 'builtin_function_or_method'
# update_abstractmethods.__name__ == 'update_abstractmethods' (len=22); __module__ == 'abc'; type == 'function'
# ---------------------------------------------------------------------------

table abc_extra246.abc_function_identity:
  description: "abc module function identity — abstractmethod(len=14) and update_abstractmethods(len=22) are pure Python functions (__class__.__name__=='function'); get_cache_token(len=15) is a C builtin from _abc extension (__class__.__name__=='builtin_function_or_method'); update_abstractmethods(len=22) is the longest name among all abc public names; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc246fi

  columns: [id, function, args, expected, description]
  rows:
    - [fi_am_name_eq,    abstractmethod.__name__.__eq__,               ["abstractmethod"],              true, "abc.abstractmethod.__name__ == 'abstractmethod'; verified with Python 3.14.3"]
    - [fi_am_name_len,   abstractmethod.__name__.__len__,              [],                              14,   "abc.abstractmethod.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [fi_am_mod_eq,     abstractmethod.__module__.__eq__,             ["abc"],                         true, "abc.abstractmethod.__module__ == 'abc'; verified with Python 3.14.3"]
    - [fi_am_cls_eq,     abstractmethod.__class__.__name__.__eq__,     ["function"],                    true, "abc.abstractmethod.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]
    - [fi_gct_name_eq,   get_cache_token.__name__.__eq__,              ["get_cache_token"],             true, "abc.get_cache_token.__name__ == 'get_cache_token'; verified with Python 3.14.3"]
    - [fi_gct_name_len,  get_cache_token.__name__.__len__,             [],                              15,   "abc.get_cache_token.__name__.__len__() == 15; verified with Python 3.14.3"]
    - [fi_gct_mod_eq,    get_cache_token.__module__.__eq__,            ["_abc"],                        true, "abc.get_cache_token.__module__ == '_abc' (C extension); verified with Python 3.14.3"]
    - [fi_gct_mod_len,   get_cache_token.__module__.__len__,           [],                              4,    "abc.get_cache_token.__module__.__len__() == 4; verified with Python 3.14.3"]
    - [fi_gct_cls_eq,    get_cache_token.__class__.__name__.__eq__,    ["builtin_function_or_method"],  true, "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' (C builtin); verified with Python 3.14.3"]
    - [fi_uam_name_eq,   update_abstractmethods.__name__.__eq__,       ["update_abstractmethods"],      true, "abc.update_abstractmethods.__name__ == 'update_abstractmethods'; verified with Python 3.14.3"]
    - [fi_uam_name_len,  update_abstractmethods.__name__.__len__,      [],                              22,   "abc.update_abstractmethods.__name__.__len__() == 22 (longest among abc public names); verified with Python 3.14.3"]
    - [fi_uam_mod_eq,    update_abstractmethods.__module__.__eq__,     ["abc"],                         true, "abc.update_abstractmethods.__module__ == 'abc'; verified with Python 3.14.3"]
    - [fi_uam_mod_len,   update_abstractmethods.__module__.__len__,    [],                              3,    "abc.update_abstractmethods.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [fi_uam_qual_eq,   update_abstractmethods.__qualname__.__eq__,   ["update_abstractmethods"],      true, "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods'; verified with Python 3.14.3"]
    - [fi_uam_cls_eq,    update_abstractmethods.__class__.__name__.__eq__, ["function"],                true, "abc.update_abstractmethods.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra246
# ---------------------------------------------------------------------------

invariant abc_extra246.abc_has_no_all:
  description: "abc.ABC.__name__.__eq__('ABC') returns True — additionally: abc module has no __all__ attribute in Python 3.14.3 (hasattr(abc, '__all__') == False); the public API is discoverable via dir() which yields 8 names: ABC, ABCMeta, abstractclassmethod, abstractmethod, abstractproperty, abstractstaticmethod, get_cache_token, update_abstractmethods; abc.ABC.__name__ == 'ABC' (len=3); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABC.__name__.__eq__
  args: ["ABC"]
  expected: true

invariant abc_extra246.abcmeta_base_is_type:
  description: "abc.ABCMeta.__bases__[0].__name__.__eq__('type') returns True — ABCMeta is a metaclass: it subclasses type(len=4), not object(len=6); contrast with abc.ABC.__bases__[0].__name__ == 'object' (ABC is a regular helper class, not a metaclass); ABCMeta.__name__ == 'ABCMeta' (len=7); ABCMeta.__module__ == 'abc' (len=3); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra246.get_cache_token_module_is_c_ext:
  description: "abc.get_cache_token.__module__.__eq__('_abc') returns True — get_cache_token is the only public abc name whose __module__ is '_abc' (len=4, the C extension) rather than 'abc' (len=3); it is also the only builtin_function_or_method among the public names; __name__ == 'get_cache_token' (len=15); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra246.update_abstractmethods_longest_name:
  description: "abc.update_abstractmethods.__name__.__len__() == 22 — update_abstractmethods has the longest __name__ (len=22) among all 8 public abc names; next longest is abstractstaticmethod(len=20), then abstractclassmethod(len=19); shortest is ABC(len=3); update_abstractmethods.__module__ == 'abc' (len=3); __class__.__name__ == 'function'; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: update_abstractmethods.__name__.__len__
  args: []
  expected: 22
