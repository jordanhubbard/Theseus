spec: concurrent_futures_extra2131
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "Wave (_extra2131): exception protocol dict-presence — checking __cause__, __context__, __traceback__, __suppress_context__, __notes__, args, with_traceback in class __dict__."
    - "concurrent.futures exception classes (CancelledError, TimeoutError, BrokenExecutor, InvalidStateError) are genuine exception subclasses."
    - "Exception protocol attributes are instance-level, set by the interpreter at raise time; they never appear in the class __dict__."
    - "args and with_traceback are inherited from BaseException and are not redefined in concurrent.futures exception class __dict__ entries."
    - "Non-exception types (Future, Executor, ThreadPoolExecutor) likewise contain no exception protocol attrs in their class dicts."
    - "concurrent.futures.CancelledError is an alias for the builtins CancelledError since Python 3.8."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra2131.cancelledError_exception_protocol:
  description: "concurrent.futures.CancelledError.__dict__ exception protocol dict-presence — exception type, all attrs absent from class dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2131

  columns: [id, function, args, expected]
  rows:
    - ["cf2131001", "concurrent.futures.CancelledError.__dict__.__contains__", ["__cause__"], false]
    - ["cf2131002", "concurrent.futures.CancelledError.__dict__.__contains__", ["__context__"], false]
    - ["cf2131003", "concurrent.futures.CancelledError.__dict__.__contains__", ["__traceback__"], false]
    - ["cf2131004", "concurrent.futures.CancelledError.__dict__.__contains__", ["__suppress_context__"], false]
    - ["cf2131005", "concurrent.futures.CancelledError.__dict__.__contains__", ["__notes__"], false]
    - ["cf2131006", "concurrent.futures.CancelledError.__dict__.__contains__", ["args"], false]
    - ["cf2131007", "concurrent.futures.CancelledError.__dict__.__contains__", ["with_traceback"], false]

