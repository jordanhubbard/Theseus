spec: threading_extra91
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra90

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra90.zspec.zsdl."
    - "This spec covers: threading method __qualname__ string lengths for Thread, Semaphore, Condition, Event, and Barrier (Wave 250)."
    - "threading.Thread.start.__qualname__.__len__() == 12 — 'Thread.start' has 12 characters. Verified with Python 3.14.3."
    - "threading.Thread.run.__qualname__.__len__() == 10 — 'Thread.run' has 10 characters. Verified with Python 3.14.3."
    - "threading.Thread.join.__qualname__.__len__() == 11 — 'Thread.join' has 11 characters. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__qualname__.__len__() == 15 — 'Thread.is_alive' has 15 characters. Verified with Python 3.14.3."
    - "threading.Semaphore.acquire.__qualname__.__len__() == 17 — 'Semaphore.acquire' has 17 characters (S-e-m-a-p-h-o-r-e=9, dot=1, a-c-q-u-i-r-e=7). Verified with Python 3.14.3."
    - "threading.Semaphore.release.__qualname__.__len__() == 17 — 'Semaphore.release' has 17 characters (S-e-m-a-p-h-o-r-e=9, dot=1, r-e-l-e-a-s-e=7). Verified with Python 3.14.3."
    - "threading.Condition.wait.__qualname__.__len__() == 14 — 'Condition.wait' has 14 characters (C-o-n-d-i-t-i-o-n=9, dot=1, w-a-i-t=4). Verified with Python 3.14.3."
    - "threading.Condition.notify.__qualname__.__len__() == 16 — 'Condition.notify' has 16 characters (C-o-n-d-i-t-i-o-n=9, dot=1, n-o-t-i-f-y=6). Verified with Python 3.14.3."
    - "threading.Condition.notify_all.__qualname__.__len__() == 20 — 'Condition.notify_all' has 20 characters (C-o-n-d-i-t-i-o-n=9, dot=1, n-o-t-i-f-y-_-a-l-l=10). Verified with Python 3.14.3."
    - "threading.Event.wait.__qualname__.__len__() == 10 — 'Event.wait' has 10 characters (E-v-e-n-t=5, dot=1, w-a-i-t=4). Verified with Python 3.14.3."
    - "threading.Event.set.__qualname__.__len__() == 9 — 'Event.set' has 9 characters (E-v-e-n-t=5, dot=1, s-e-t=3). Verified with Python 3.14.3."
    - "threading.Barrier.wait.__qualname__.__len__() == 12 — 'Barrier.wait' has 12 characters (B-a-r-r-i-e-r=7, dot=1, w-a-i-t=4). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread method __qualname__ string lengths
#
# Wave 250 theme: threading class method __qualname__ string lengths — Thread methods.
#
# threading.Thread.start.__qualname__.__len__()    == 12  ('Thread.start')
# threading.Thread.run.__qualname__.__len__()      == 10  ('Thread.run')
# threading.Thread.join.__qualname__.__len__()     == 11  ('Thread.join')
# threading.Thread.is_alive.__qualname__.__len__() == 15  ('Thread.is_alive')
#
# Prior spec extra90 checked Thread method __qualname__ string equality. This spec (extra91) checks lengths. New to extra91.
# ---------------------------------------------------------------------------

table threading_extra91.thread_method_qualname_lengths:
  description: "Thread.start/run/join/is_alive method __qualname__ string lengths; pure-Python methods in Lib/threading.py; wave 250; new to extra91"
  kind: python_call_eq
  category: string_length
  id_prefix: threadingmqlens91

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_start_qualname_len_eq_12,
       Thread.start.__qualname__.__len__,
       [],
       12,
       "threading.Thread.start.__qualname__.__len__() == 12 — Thread.start is a pure-Python method in Lib/threading.py; __qualname__ is 'Thread.start' which has 12 characters (T-h-r-e-a-d=6, dot=1, s-t-a-r-t=5, total=12); str.__len__() returns 12; prior spec extra90 checked Thread.start.__qualname__ string equality; this spec (extra91) checks lengths; new to extra91"]
    - [Thread_run_qualname_len_eq_10,
       Thread.run.__qualname__.__len__,
       [],
       10,
       "threading.Thread.run.__qualname__.__len__() == 10 — Thread.run is a pure-Python method in Lib/threading.py; __qualname__ is 'Thread.run' which has 10 characters (T-h-r-e-a-d=6, dot=1, r-u-n=3, total=10); str.__len__() returns 10; new to extra91"]
    - [Thread_join_qualname_len_eq_11,
       Thread.join.__qualname__.__len__,
       [],
       11,
       "threading.Thread.join.__qualname__.__len__() == 11 — Thread.join is a pure-Python method in Lib/threading.py; __qualname__ is 'Thread.join' which has 11 characters (T-h-r-e-a-d=6, dot=1, j-o-i-n=4, total=11); str.__len__() returns 11; new to extra91"]
    - [Thread_is_alive_qualname_len_eq_15,
       Thread.is_alive.__qualname__.__len__,
       [],
       15,
       "threading.Thread.is_alive.__qualname__.__len__() == 15 — Thread.is_alive is a pure-Python method in Lib/threading.py; __qualname__ is 'Thread.is_alive' which has 15 characters (T-h-r-e-a-d=6, dot=1, i-s-_-a-l-i-v-e=8, total=15); str.__len__() returns 15; new to extra91"]

# ---------------------------------------------------------------------------
# Semaphore method __qualname__ string lengths
#
# Wave 250 theme: threading class method __qualname__ string lengths — Semaphore methods.
#
# threading.Semaphore.acquire.__qualname__.__len__() == 17  ('Semaphore.acquire')
# threading.Semaphore.release.__qualname__.__len__() == 17  ('Semaphore.release')
# threading.Semaphore.acquire.__qualname__.__len__() == threading.Semaphore.release.__qualname__.__len__() (same length, different strings)
# threading.Thread.start.__qualname__.__len__()      == 12  (shorter than Semaphore methods — re-confirm)
#
# No prior threading spec checks Semaphore method __qualname__ lengths via threadingmqlens91. New to extra91.
# ---------------------------------------------------------------------------

table threading_extra91.semaphore_method_qualname_lengths:
  description: "Semaphore.acquire/release method __qualname__ string lengths == 17; pure-Python methods; wave 250; new to extra91"
  kind: python_call_eq
  category: string_length
  id_prefix: threadingmqlens91

  columns: [id, function, args, expected, description]
  rows:
    - [Semaphore_acquire_qualname_len_eq_17,
       Semaphore.acquire.__qualname__.__len__,
       [],
       17,
       "threading.Semaphore.acquire.__qualname__.__len__() == 17 — Semaphore.acquire is a pure-Python method in Lib/threading.py; __qualname__ is 'Semaphore.acquire' which has 17 characters (S-e-m-a-p-h-o-r-e=9, dot=1, a-c-q-u-i-r-e=7, total=17); str.__len__() returns 17; no prior threading spec checks Semaphore method __qualname__ lengths via threadingmqlens91; new to extra91"]
    - [Semaphore_release_qualname_len_eq_17,
       Semaphore.release.__qualname__.__len__,
       [],
       17,
       "threading.Semaphore.release.__qualname__.__len__() == 17 — Semaphore.release is a pure-Python method in Lib/threading.py; __qualname__ is 'Semaphore.release' which has 17 characters (S-e-m-a-p-h-o-r-e=9, dot=1, r-e-l-e-a-s-e=7, total=17); str.__len__() returns 17; both acquire and release have the same __qualname__ length 17 even though their strings differ; new to extra91"]
    - [Thread_start_qualname_len_eq_12_reconfirm,
       Thread.start.__qualname__.__len__,
       [],
       12,
       "threading.Thread.start.__qualname__.__len__() == 12 — re-confirms Thread.start qualname length for comparison with Semaphore methods; 'Thread.start' has 12 chars, shorter than 'Semaphore.acquire' with 17 chars; str.__len__() returns 12; new to extra91"]
    - [Semaphore_acquire_qualname_len_ne_12,
       Semaphore.acquire.__qualname__.__len__,
       [],
       17,
       "threading.Semaphore.acquire.__qualname__.__len__() == 17 (not 12) — Semaphore.acquire __qualname__ length is 17, confirming it is longer than Thread.start (12); the longer class name 'Semaphore' (9 chars) compared to 'Thread' (6 chars) accounts for the difference; str.__len__() returns 17; new to extra91"]

# ---------------------------------------------------------------------------
# Condition method __qualname__ string lengths
#
# Wave 250 theme: threading class method __qualname__ string lengths — Condition methods.
#
# threading.Condition.wait.__qualname__.__len__()       == 14  ('Condition.wait')
# threading.Condition.notify.__qualname__.__len__()     == 16  ('Condition.notify')
# threading.Condition.notify_all.__qualname__.__len__() == 20  ('Condition.notify_all')
# threading.Event.wait.__qualname__.__len__()           == 10  ('Event.wait') — for comparison
#
# No prior threading spec checks Condition method __qualname__ lengths via threadingmqlens91. New to extra91.
# ---------------------------------------------------------------------------

table threading_extra91.condition_method_qualname_lengths:
  description: "Condition.wait/notify/notify_all method __qualname__ string lengths; pure-Python methods in Lib/threading.py; wave 250; new to extra91"
  kind: python_call_eq
  category: string_length
  id_prefix: threadingmqlens91

  columns: [id, function, args, expected, description]
  rows:
    - [Condition_wait_qualname_len_eq_14,
       Condition.wait.__qualname__.__len__,
       [],
       14,
       "threading.Condition.wait.__qualname__.__len__() == 14 — Condition.wait is a pure-Python method in Lib/threading.py; __qualname__ is 'Condition.wait' which has 14 characters (C-o-n-d-i-t-i-o-n=9, dot=1, w-a-i-t=4, total=14); str.__len__() returns 14; no prior threading spec checks Condition method __qualname__ lengths via threadingmqlens91; new to extra91"]
    - [Condition_notify_qualname_len_eq_16,
       Condition.notify.__qualname__.__len__,
       [],
       16,
       "threading.Condition.notify.__qualname__.__len__() == 16 — Condition.notify is a pure-Python method in Lib/threading.py; __qualname__ is 'Condition.notify' which has 16 characters (C-o-n-d-i-t-i-o-n=9, dot=1, n-o-t-i-f-y=6, total=16); str.__len__() returns 16; new to extra91"]
    - [Condition_notify_all_qualname_len_eq_20,
       Condition.notify_all.__qualname__.__len__,
       [],
       20,
       "threading.Condition.notify_all.__qualname__.__len__() == 20 — Condition.notify_all is a pure-Python method in Lib/threading.py; __qualname__ is 'Condition.notify_all' which has 20 characters (C-o-n-d-i-t-i-o-n=9, dot=1, n-o-t-i-f-y-_-a-l-l=10, total=20); str.__len__() returns 20; new to extra91"]
    - [Event_wait_qualname_len_eq_10,
       Event.wait.__qualname__.__len__,
       [],
       10,
       "threading.Event.wait.__qualname__.__len__() == 10 — Event.wait is a pure-Python method in Lib/threading.py; __qualname__ is 'Event.wait' which has 10 characters (E-v-e-n-t=5, dot=1, w-a-i-t=4, total=10); str.__len__() returns 10; included for cross-class length comparison with Condition methods; new to extra91"]

# ---------------------------------------------------------------------------
# Event and Barrier method __qualname__ string lengths
#
# Wave 250 theme: threading class method __qualname__ string lengths — Event and Barrier methods.
#
# threading.Event.wait.__qualname__.__len__()    == 10  ('Event.wait')
# threading.Event.set.__qualname__.__len__()     == 9   ('Event.set')
# threading.Barrier.wait.__qualname__.__len__()  == 12  ('Barrier.wait')
# threading.Condition.wait.__qualname__.__len__() == 14  (longer — for comparison)
#
# No prior threading spec checks Event/Barrier method __qualname__ lengths via threadingmqlens91. New to extra91.
# ---------------------------------------------------------------------------

table threading_extra91.event_barrier_method_qualname_lengths:
  description: "Event.wait/set and Barrier.wait method __qualname__ string lengths; pure-Python methods in Lib/threading.py; wave 250; new to extra91"
  kind: python_call_eq
  category: string_length
  id_prefix: threadingmqlens91

  columns: [id, function, args, expected, description]
  rows:
    - [Event_wait_qualname_len_eq_10,
       Event.wait.__qualname__.__len__,
       [],
       10,
       "threading.Event.wait.__qualname__.__len__() == 10 — Event.wait is a pure-Python method in Lib/threading.py; __qualname__ is 'Event.wait' which has 10 characters (E-v-e-n-t=5, dot=1, w-a-i-t=4, total=10); str.__len__() returns 10; no prior threading spec checks Event method __qualname__ lengths via threadingmqlens91; new to extra91"]
    - [Event_set_qualname_len_eq_9,
       Event.set.__qualname__.__len__,
       [],
       9,
       "threading.Event.set.__qualname__.__len__() == 9 — Event.set is a pure-Python method in Lib/threading.py; __qualname__ is 'Event.set' which has 9 characters (E-v-e-n-t=5, dot=1, s-e-t=3, total=9); str.__len__() returns 9; new to extra91"]
    - [Barrier_wait_qualname_len_eq_12,
       Barrier.wait.__qualname__.__len__,
       [],
       12,
       "threading.Barrier.wait.__qualname__.__len__() == 12 — Barrier.wait is a pure-Python method in Lib/threading.py; __qualname__ is 'Barrier.wait' which has 12 characters (B-a-r-r-i-e-r=7, dot=1, w-a-i-t=4, total=12); str.__len__() returns 12; no prior threading spec checks Barrier method __qualname__ lengths via threadingmqlens91; new to extra91"]
    - [Condition_wait_qualname_len_eq_14_reconfirm,
       Condition.wait.__qualname__.__len__,
       [],
       14,
       "threading.Condition.wait.__qualname__.__len__() == 14 — re-confirms Condition.wait qualname length for cross-class comparison; 'Condition.wait' has 14 chars, longer than 'Barrier.wait' (12) and 'Event.wait' (10) due to the longer class name 'Condition' (9 chars) vs 'Barrier' (7) vs 'Event' (5); str.__len__() returns 14; new to extra91"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra91
# ---------------------------------------------------------------------------

invariant threading_extra91.Thread_start_qualname_len_eq_12:
  description: "threading.Thread.start.__qualname__.__len__() == 12 — 'Thread.start' has 12 characters; wave 250; new to extra91"
  kind: python_call_eq
  function: Thread.start.__qualname__.__len__
  args: []
  expected: 12

invariant threading_extra91.Semaphore_acquire_qualname_len_eq_17:
  description: "threading.Semaphore.acquire.__qualname__.__len__() == 17 — 'Semaphore.acquire' has 17 characters; wave 250; new to extra91"
  kind: python_call_eq
  function: Semaphore.acquire.__qualname__.__len__
  args: []
  expected: 17

invariant threading_extra91.Condition_notify_all_qualname_len_eq_20:
  description: "threading.Condition.notify_all.__qualname__.__len__() == 20 — 'Condition.notify_all' has 20 characters; wave 250; new to extra91"
  kind: python_call_eq
  function: Condition.notify_all.__qualname__.__len__
  args: []
  expected: 20

invariant threading_extra91.Event_set_qualname_len_eq_9:
  description: "threading.Event.set.__qualname__.__len__() == 9 — 'Event.set' has 9 characters; wave 250; new to extra91"
  kind: python_call_eq
  function: Event.set.__qualname__.__len__
  args: []
  expected: 9

invariant threading_extra91.Barrier_wait_qualname_len_eq_12:
