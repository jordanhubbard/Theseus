spec: inspect_extra12
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect.zspec.zsdl and prior extras through inspect_extra11.zspec.zsdl."
    - "inspect.zspec covers Parameter.__name__=='Parameter' and Signature.__name__=='Signature' as standalone invariants."
    - "inspect_extra3/extra5/extra6 each cover Parameter.__name__ and Signature.__name__ as standalone invariants."
    - "inspect_signature covers BoundArguments.__name__=='BoundArguments'."
    - "inspect_extra9 covers FullArgSpec.__name__, FullArgSpec.__qualname__, FullArgSpec.__module__."
    - "inspect_extra7 covers Parameter.__qualname__, Signature.__qualname__, BoundArguments.__qualname__, BoundArguments.__module__."
    - "inspect_extra5 covers Parameter.__module__ and Signature.__module__."
    - "New axis: __bases__[0].__name__ for Parameter, Signature, FullArgSpec, and BoundArguments."
    - "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter inherits directly from object."
    - "inspect.Signature.__bases__[0].__name__ == 'object' — Signature inherits directly from object."
    - "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a namedtuple subclass."
    - "inspect.BoundArguments.__bases__[0].__name__ == 'object' — BoundArguments inherits directly from object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __bases__[0].__name__ checks — Parameter, Signature, FullArgSpec, BoundArguments
#
# Prior inspect specs cover __name__, __qualname__, and __module__ for these
# four classes. This spec adds the first __bases__ axis: the direct base class
# name for each. Parameter, Signature, and BoundArguments inherit from object;
# FullArgSpec is a namedtuple and inherits from tuple.
# ---------------------------------------------------------------------------

invariant inspect_extra12.Parameter.bases_name:
  description: "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Parameter.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant inspect_extra12.Signature.bases_name:
  description: "inspect.Signature.__bases__[0].__name__ == 'object' — Signature inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Signature.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant inspect_extra12.FullArgSpec.bases_name:
  description: "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a namedtuple (tuple subclass)"
  category: class_hierarchy
  kind: python_call_eq
  function: FullArgSpec.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "tuple"

invariant inspect_extra12.BoundArguments.bases_name:
  description: "inspect.BoundArguments.__bases__[0].__name__ == 'object' — BoundArguments inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: BoundArguments.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
