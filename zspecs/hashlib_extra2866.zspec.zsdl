    - ["hl2866009", "type(hashlib.sha3_256()).__dict__.__contains__",  ["__ror__"], false]
    - ["hl2866010", "hashlib.blake2b.__dict__.__contains__",           ["__ror__"], false]
    - ["hl2866011", "hashlib.blake2s.__dict__.__contains__",           ["__ror__"], false]
    - ["hl2866012", "type(hashlib.new('sha512')).__dict__.__contains__", ["__ror__"], false]

