spec: hl2866
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 638 (_extra2866): __rand__, __ror__, __rxor__ dict-presence checks for hashlib types."
    - "hashlib exposes two HASH-family types: _hashlib.HASH (used by md5, sha1, sha256, sha512, etc.) and _hashlib.HASHXOF (used by shake_128, shake_256)."
    - "hashlib also exposes hashlib.blake2b and hashlib.blake2s as first-class C-level types."
    - "None of these types define reflected bitwise AND, OR, or XOR operators in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl2866.rand:
  description: "hashlib types __rand__ dict-presence checks; wave 638"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2866
  columns: [id, function, args, expected]
  rows:
    - ["hl2866001", "type(hashlib.md5()).__dict__.__contains__",       ["__rand__"], false]
    - ["hl2866002", "type(hashlib.sha256()).__dict__.__contains__",    ["__rand__"], false]
    - ["hl2866003", "type(hashlib.sha3_256()).__dict__.__contains__",  ["__rand__"], false]
    - ["hl2866004", "hashlib.blake2b.__dict__.__contains__",           ["__rand__"], false]
    - ["hl2866005", "hashlib.blake2s.__dict__.__contains__",           ["__rand__"], false]
    - ["hl2866006", "type(hashlib.new('md5')).__dict__.__contains__",  ["__rand__"], false]

