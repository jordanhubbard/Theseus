spec: inspect_extra886
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "Python standard library inspect module"
    - "CPython source: Lib/inspect.py"
  not_derived_from:
    - "any third-party introspection library"
    - "objinspect or similar packages"
  notes:
    - "Covers qualname and module attribute checks for inspect frame and argument inspection functions"
    - "All covered functions are pure Python callables defined in Lib/inspect.py"
    - "getargs and getargvalues operate on code/frame objects respectively"
  created_at: "2026-04-12"

table inspect_extra886.qualname_checks:
  description: "Verify __qualname__ for inspect frame and argument inspection functions"
  kind: python_call_eq
  category: attribute_introspection
  id_prefix: in886qn
  columns: [id, function, args, expected]
  rows:
    - [in886qn001, inspect.getargs.__qualname__.__eq__, ["getargs"], true]
    - [in886qn002, inspect.getargvalues.__qualname__.__eq__, ["getargvalues"], true]
    - [in886qn003, inspect.formatargvalues.__qualname__.__eq__, ["formatargvalues"], true]
    - [in886qn004, inspect.getouterframes.__qualname__.__eq__, ["getouterframes"], true]
    - [in886qn005, inspect.getinnerframes.__qualname__.__eq__, ["getinnerframes"], true]
    - [in886qn006, inspect.currentframe.__qualname__.__eq__, ["currentframe"], true]

table inspect_extra886.module_checks:
  description: "Verify __module__ for inspect frame and argument inspection functions"
  kind: python_call_eq
  category: attribute_introspection
  id_prefix: in886mo
  columns: [id, function, args, expected]
  rows:
    - [in886mo001, inspect.getargs.__module__.__eq__, ["inspect"], true]
    - [in886mo002, inspect.getargvalues.__module__.__eq__, ["inspect"], true]
    - [in886mo003, inspect.formatargvalues.__module__.__eq__, ["inspect"], true]
    - [in886mo004, inspect.getouterframes.__module__.__eq__, ["inspect"], true]
    - [in886mo005, inspect.getinnerframes.__module__.__eq__, ["inspect"], true]
    - [in886mo006, inspect.currentframe.__module__.__eq__, ["inspect"], true]
