spec: re_extra2071
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 585 (_extra2071): __pos__/__neg__, __getattribute__, __reduce__/__reduce_ex__, __copy__/__deepcopy__ dict-presence checks."
    - "re.Pattern and re.Match both define __copy__ and __deepcopy__ (True) — compiled patterns and match objects support shallow and deep copy."
    - "re.error (alias re.PatternError in Python 3.13+) defines neither __copy__ nor __deepcopy__ (False) — exception class, inherits from Exception."
    - "re.RegexFlag (IntFlag subclass) defines none of the seven operators (all False)."
    - "None of the re types define __pos__ or __neg__; they are not numeric types."
    - "None of the re types define __getattribute__ in their own __dict__."
    - "None of the re types define __reduce__ or __reduce_ex__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table re_extra2071.unary_sign_protocol:
  description: "re types __pos__/__neg__ dict-presence checks — all False; re types are not numeric"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2071

  columns: [id, function, args, expected]
  rows:
    - ["re2071001", "re.Pattern.__dict__.__contains__",  ["__pos__"], false]
    - ["re2071002", "re.Pattern.__dict__.__contains__",  ["__neg__"], false]
    - ["re2071003", "re.Match.__dict__.__contains__",    ["__pos__"], false]
    - ["re2071004", "re.Match.__dict__.__contains__",    ["__neg__"], false]
    - ["re2071005", "re.error.__dict__.__contains__",    ["__pos__"], false]
    - ["re2071006", "re.error.__dict__.__contains__",    ["__neg__"], false]
    - ["re2071007", "re.RegexFlag.__dict__.__contains__", ["__pos__"], false]
    - ["re2071008", "re.RegexFlag.__dict__.__contains__", ["__neg__"], false]

table re_extra2071.getattribute_protocol:
  description: "re types __getattribute__ dict-presence checks — all False; attribute lookup inherits from object"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2071

  columns: [id, function, args, expected]
  rows:
    - ["re2071009", "re.Pattern.__dict__.__contains__",  ["__getattribute__"], false]
    - ["re2071010", "re.Match.__dict__.__contains__",    ["__getattribute__"], false]
    - ["re2071011", "re.error.__dict__.__contains__",    ["__getattribute__"], false]
    - ["re2071012", "re.RegexFlag.__dict__.__contains__", ["__getattribute__"], false]

table re_extra2071.reduce_protocol:
  description: "re types __reduce__/__reduce_ex__ dict-presence checks — all False; pickle protocol not customized in re class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2071

  columns: [id, function, args, expected]
  rows:
    - ["re2071013", "re.Pattern.__dict__.__contains__",  ["__reduce__"],    false]
    - ["re2071014", "re.Pattern.__dict__.__contains__",  ["__reduce_ex__"], false]
    - ["re2071015", "re.Match.__dict__.__contains__",    ["__reduce__"],    false]
    - ["re2071016", "re.Match.__dict__.__contains__",    ["__reduce_ex__"], false]
    - ["re2071017", "re.error.__dict__.__contains__",    ["__reduce__"],    false]
    - ["re2071018", "re.error.__dict__.__contains__",    ["__reduce_ex__"], false]
    - ["re2071019", "re.RegexFlag.__dict__.__contains__", ["__reduce__"],    false]
    - ["re2071020", "re.RegexFlag.__dict__.__contains__", ["__reduce_ex__"], false]

table re_extra2071.copy_protocol:
  description: "re types __copy__/__deepcopy__ dict-presence — Pattern and Match define both (True); error and RegexFlag define neither (False)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2071

  columns: [id, function, args, expected]
  rows:
    - ["re2071021", "re.Pattern.__dict__.__contains__",  ["__copy__"],     true]
    - ["re2071022", "re.Pattern.__dict__.__contains__",  ["__deepcopy__"], true]
    - ["re2071023", "re.Match.__dict__.__contains__",    ["__copy__"],     true]
    - ["re2071024", "re.Match.__dict__.__contains__",    ["__deepcopy__"], true]
    - ["re2071025", "re.error.__dict__.__contains__",    ["__copy__"],     false]
    - ["re2071026", "re.error.__dict__.__contains__",    ["__deepcopy__"], false]
    - ["re2071027", "re.RegexFlag.__dict__.__contains__", ["__copy__"],     false]
    - ["re2071028", "re.RegexFlag.__dict__.__contains__", ["__deepcopy__"], false]
    - ["re2071029", "re.Pattern.__dict__.__contains__",  ["__neg__"],      false]
    - ["re2071030", "re.Match.__dict__.__contains__",    ["__reduce__"],   false]
