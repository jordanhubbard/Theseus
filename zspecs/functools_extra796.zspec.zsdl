    - [ft796xx002, functools.lru_cache.__module__.__eq__, ["functools"], true]
    - [ft796xx003, functools.cache.__qualname__.__eq__, ["cache"], true]
    - [ft796xx004, functools.cache.__module__.__eq__, ["functools"], true]
    - [ft796xx005, functools.reduce.__qualname__.__eq__, ["reduce"], true]
    - [ft796xx006, functools.reduce.__module__.__eq__, ["functools"], true]
    - [ft796xx007, functools.cmp_to_key.__qualname__.__eq__, ["cmp_to_key"], true]
    - [ft796xx008, functools.cmp_to_key.__module__.__eq__, ["functools"], true]
    - [ft796xx009, functools.total_ordering.__qualname__.__eq__, ["total_ordering"], true]
    - [ft796xx010, functools.total_ordering.__module__.__eq__, ["functools"], true]
    - [ft796xx011, functools.wraps.__qualname__.__eq__, ["wraps"], true]
    - [ft796xx012, functools.update_wrapper.__qualname__.__eq__, ["update_wrapper"], true]
