# ---------------------------------------------------------------------------
# Standalone invariants — extra85
# ---------------------------------------------------------------------------

invariant multiprocessing_extra85.Process_name:
  description: "multiprocessing.Process.__name__.__eq__('Process') returns True — Process is a top-level class with a simple class name; NEW in extra85: first standalone __name__ equality invariant for Process in mpclsid85 namespace; wave 247; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__name__.__eq__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra85.Process_module:
  description: "multiprocessing.Process.__module__.__eq__('multiprocessing.context') returns True — the Process class is defined in multiprocessing.context (not multiprocessing.process); NEW in extra85: first standalone __module__ identity invariant for Process in mpclsid85 namespace; wave 247; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra85.Pool_name:
  description: "multiprocessing.pool.Pool.__name__.__eq__('Pool') returns True — Pool is a top-level class in multiprocessing.pool with a simple class name; accessed via pool submodule; NEW in extra85: first standalone __name__ equality invariant for pool.Pool in mpclsid85 namespace; wave 247; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pool.Pool.__name__.__eq__
  args: ["Pool"]
  expected: true

invariant multiprocessing_extra85.Pool_module:
  description: "multiprocessing.pool.Pool.__module__.__eq__('multiprocessing.pool') returns True — Pool class is defined in the multiprocessing.pool submodule; NEW in extra85: first standalone __module__ equality invariant for pool.Pool in mpclsid85 namespace; wave 247; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pool.Pool.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra85.BaseProxy_name:
  description: "multiprocessing.managers.BaseProxy.__name__.__eq__('BaseProxy') returns True — BaseProxy is the base class for all proxy objects in the multiprocessing.managers module; NEW in extra85: first standalone __name__ equality invariant for BaseProxy in mpclsid85 namespace; wave 247; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: managers.BaseProxy.__name__.__eq__
  args: ["BaseProxy"]
  expected: true
