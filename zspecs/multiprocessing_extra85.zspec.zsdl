spec: multiprocessing_extra85
version: ">=3.9"
backend: python_module(multiprocessing)
extends: multiprocessing_extra84

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "This spec extends multiprocessing_extra84.zspec.zsdl."
    - "This spec covers: wave 247 theme — multiprocessing Process and Pool class identity (__name__, __qualname__, __module__, __dict__.__class__.__name__) and managers class identity. NEW in extra85: Process.__name__=='Process'; Process.__qualname__=='Process'; Process.__module__=='multiprocessing.context' (class is defined in multiprocessing.context); Process.__dict__.__class__.__name__=='mappingproxy'; pool.Pool.__name__=='Pool'; pool.Pool.__qualname__=='Pool'; pool.Pool.__module__=='multiprocessing.pool'; pool.Pool.__dict__.__class__.__name__=='mappingproxy'; managers.BaseManager.__name__=='BaseManager'; managers.BaseManager.__module__=='multiprocessing.managers'; managers.SyncManager.__name__=='SyncManager'; managers.SyncManager.__module__=='multiprocessing.managers'; managers.BaseProxy.__name__=='BaseProxy'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__name__ == 'Process'. Process is a top-level class. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__qualname__ == 'Process'. Process has a simple top-level qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__module__ == 'multiprocessing.context'. Process class is defined in multiprocessing.context (not multiprocessing.process). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__.__class__.__name__ == 'mappingproxy'. Class __dict__ is always a mappingproxy in CPython. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.__name__ == 'Pool'. Pool is accessed via the pool submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.__qualname__ == 'Pool'. Pool has a simple top-level qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool'. Pool class is defined in multiprocessing.pool. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.__dict__.__class__.__name__ == 'mappingproxy'. Class __dict__ is always a mappingproxy in CPython. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.BaseManager.__name__ == 'BaseManager'. BaseManager is a top-level class in multiprocessing.managers. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.SyncManager.__name__ == 'SyncManager'. SyncManager is a top-level class in multiprocessing.managers. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.SyncManager.__module__ == 'multiprocessing.managers'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.BaseProxy.__name__ == 'BaseProxy'. BaseProxy is a top-level class in multiprocessing.managers. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Process class identity — extra85
#
# Wave 247 theme: multiprocessing Process and Pool class identity.
#
# Process.__name__ == 'Process'
# Process.__qualname__ == 'Process'
# Process.__module__ == 'multiprocessing.context'
# Process.__dict__.__class__.__name__ == 'mappingproxy'
# ---------------------------------------------------------------------------

table multiprocessing_extra85.Process_identity:
  description: "multiprocessing Process class identity checks in mpclsid85 namespace — wave 247 theme: multiprocessing Process and Pool class identity; Process.__name__=='Process'; Process.__qualname__=='Process'; Process.__module__=='multiprocessing.context' (Process class is defined in multiprocessing.context); Process.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is always a mappingproxy in CPython); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpclsid85

  columns: [id, function, args, expected, description]
  rows:
    - [proc_name,          Process.__name__.__eq__,                          ["Process"],               true, "Process.__name__ == 'Process' — simple top-level class name; verified with Python 3.14.3"]
    - [proc_qualname,      Process.__qualname__.__eq__,                      ["Process"],               true, "Process.__qualname__ == 'Process' — simple top-level qualname; verified with Python 3.14.3"]
    - [proc_module,        Process.__module__.__eq__,                        ["multiprocessing.context"], true, "Process.__module__ == 'multiprocessing.context' — Process class is defined in multiprocessing.context; verified with Python 3.14.3"]
    - [proc_dict_cls_name, "Process.__dict__.__class__.__name__.__eq__",     ["mappingproxy"],           true, "Process.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy in CPython; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing pool.Pool class identity — extra85
#
# pool.Pool.__name__ == 'Pool'
# pool.Pool.__qualname__ == 'Pool'
# pool.Pool.__module__ == 'multiprocessing.pool'
# pool.Pool.__dict__.__class__.__name__ == 'mappingproxy'
# ---------------------------------------------------------------------------

table multiprocessing_extra85.Pool_identity:
  description: "multiprocessing pool.Pool class identity checks in mpclsid85 namespace — wave 247 theme: multiprocessing Process and Pool class identity; pool.Pool.__name__=='Pool'; pool.Pool.__qualname__=='Pool'; pool.Pool.__module__=='multiprocessing.pool' (Pool class is defined in multiprocessing.pool); pool.Pool.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is always a mappingproxy in CPython); accessed via pool submodule since multiprocessing.Pool is a factory bound method; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpclsid85a

  columns: [id, function, args, expected, description]
  rows:
    - [pool_name,          pool.Pool.__name__.__eq__,                        ["Pool"],                  true, "pool.Pool.__name__ == 'Pool' — simple top-level class name; verified with Python 3.14.3"]
    - [pool_qualname,      pool.Pool.__qualname__.__eq__,                    ["Pool"],                  true, "pool.Pool.__qualname__ == 'Pool' — simple top-level qualname; verified with Python 3.14.3"]
    - [pool_module,        pool.Pool.__module__.__eq__,                      ["multiprocessing.pool"],  true, "pool.Pool.__module__ == 'multiprocessing.pool' — Pool class is defined in multiprocessing.pool; verified with Python 3.14.3"]
    - [pool_dict_cls_name, "pool.Pool.__dict__.__class__.__name__.__eq__",   ["mappingproxy"],          true, "pool.Pool.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy in CPython; verified with Python 3.14.3"]

