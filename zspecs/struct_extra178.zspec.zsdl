spec: struct_extra178
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "struct.error.__name__ == 'error' — len=5; Python-level exception class defined in the struct module."
    - "struct.error.__module__ == 'struct' — error is exposed from the struct namespace."
    - "struct.error.__qualname__ == 'error' — top-level class in struct, qualname equals name."
    - "struct.error.__bases__[0].__name__ == 'Exception' — struct.error inherits directly from Exception."
    - "struct.Struct.__name__ == 'Struct' — len=6; C extension type from _struct module."
    - "struct.Struct.__qualname__ == 'Struct' — top-level type, qualname matches name."
    - "struct.Struct.__bases__[0].__name__ == 'object' — Struct is a direct C extension type."
    - "struct.Struct.__module__ == '_struct' — Struct is implemented in the _struct C extension."
    - "struct.error.__class__.__name__ == 'type' — error is a plain Python class (metaclass=type)."
    - "struct.Struct.__class__.__name__ == 'type' — Struct is a plain C type (metaclass=type)."
    - "len('error')=5 < len('Struct')=6 — error name is shorter than Struct name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.error class name and module identity
#
# struct.error.__name__     == 'error'     (len=5)
# struct.error.__module__   == 'struct'
# struct.error.__qualname__ == 'error'
#
# struct.error is the exception raised for any packing/unpacking errors.
# New to extra178.
# ---------------------------------------------------------------------------

table struct_extra178.error_name_identity:
  description: "struct.error __name__, __module__, __qualname__ identity; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: structerror178

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_eq,
       error.__name__.__eq__,
       ["error"],
       true,
       "struct.error.__name__.__eq__('error') == True — struct exception class is named 'error'; len=5; new to extra178"]
    - [error_name_len,
       error.__name__.__len__,
       [],
       5,
       "struct.error.__name__.__len__() == 5 — 'error' has 5 characters; new to extra178"]
    - [error_module_eq,
       error.__module__.__eq__,
       ["struct"],
       true,
       "struct.error.__module__.__eq__('struct') == True — error is in the struct module namespace; new to extra178"]
    - [error_qualname_eq,
       error.__qualname__.__eq__,
       ["error"],
       true,
       "struct.error.__qualname__.__eq__('error') == True — top-level class, qualname equals name; new to extra178"]

# ---------------------------------------------------------------------------
# Table 2: struct.Struct class name and base class identity
#
# struct.Struct.__name__           == 'Struct'   (len=6)
# struct.Struct.__qualname__       == 'Struct'
# struct.Struct.__bases__[0].__name__ == 'object'
#
# struct.Struct is the compiled-format type from the _struct C extension.
# New to extra178.
# ---------------------------------------------------------------------------

table struct_extra178.Struct_name_identity:
  description: "struct.Struct __name__, __qualname__, and base class identity; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: structerror178

  columns: [id, function, args, expected, description]
  rows:
    - [struct_name_eq,
       Struct.__name__.__eq__,
       ["Struct"],
       true,
       "struct.Struct.__name__.__eq__('Struct') == True — compiled-format type is named 'Struct'; len=6; new to extra178"]
    - [struct_name_len,
       Struct.__name__.__len__,
       [],
       6,
       "struct.Struct.__name__.__len__() == 6 — 'Struct' has 6 characters; new to extra178"]
    - [struct_qualname_eq,
       Struct.__qualname__.__eq__,
       ["Struct"],
       true,
       "struct.Struct.__qualname__.__eq__('Struct') == True — top-level type, qualname equals name; new to extra178"]
    - [struct_base_name_eq,
       "Struct.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "struct.Struct.__bases__[0].__name__.__eq__('object') == True — Struct is a direct C extension type with object as base; new to extra178"]

# ---------------------------------------------------------------------------
# Table 3: struct.error and struct.Struct metaclass and hierarchy comparison
#
# struct.error.__bases__[0].__name__ == 'Exception'
# struct.error.__class__.__name__    == 'type'
# struct.Struct.__class__.__name__   == 'type'
# struct.error.__name__.__len__() < struct.Struct.__name__.__len__()  (5 < 6)
#
# New to extra178.
# ---------------------------------------------------------------------------

table struct_extra178.error_struct_hierarchy:
  description: "struct.error base class, metaclass identity, and len ordering vs Struct; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: structerror178

  columns: [id, function, args, expected, description]
  rows:
    - [error_base_name_eq,
       "error.__bases__[0].__name__.__eq__",
       ["Exception"],
       true,
       "struct.error.__bases__[0].__name__.__eq__('Exception') == True — struct.error inherits from Exception; new to extra178"]
    - [error_class_name_eq,
       error.__class__.__name__.__eq__,
       ["type"],
       true,
       "struct.error.__class__.__name__.__eq__('type') == True — struct.error metaclass is type (plain Python class); new to extra178"]
    - [struct_class_name_eq,
       Struct.__class__.__name__.__eq__,
       ["type"],
       true,
       "struct.Struct.__class__.__name__.__eq__('type') == True — struct.Struct metaclass is type (C extension type); new to extra178"]
    - [error_len_lt_struct_len,
       error.__name__.__len__.__lt__,
       [6],
       true,
       "struct.error.__name__.__len__().__lt__(6) == True — len('error')=5 < len('Struct')=6; new to extra178"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra178
# ---------------------------------------------------------------------------

invariant struct_extra178.error_name_is_error:
  description: "struct.error.__name__ == 'error' — len=5; raised for packing/unpacking failures; new to extra178"
  category: identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant struct_extra178.error_module_is_struct:
  description: "struct.error.__module__ == 'struct' — error is in the struct module namespace; new to extra178"
  category: identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra178.error_qualname_is_error:
  description: "struct.error.__qualname__ == 'error' — top-level class, qualname matches name; new to extra178"
  category: identity
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true

invariant struct_extra178.error_base_is_Exception:
  description: "struct.error.__bases__[0].__name__ == 'Exception' — struct.error inherits from Exception; new to extra178"
  category: identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant struct_extra178.Struct_base_is_object:
  description: "struct.Struct.__bases__[0].__name__ == 'object' — Struct is a direct C extension type; new to extra178"
  category: identity
  kind: python_call_eq
  function: "Struct.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant struct_extra178.Struct_qualname_is_Struct:
  description: "struct.Struct.__qualname__ == 'Struct' — top-level C extension type, qualname equals name; new to extra178"
  category: identity
  kind: python_call_eq
  function: Struct.__qualname__.__eq__
  args: ["Struct"]
  expected: true

invariant struct_extra178.error_class_is_type:
  description: "struct.error.__class__.__name__ == 'type' — struct.error is a plain Python class with metaclass type; new to extra178"
  category: identity
  kind: python_call_eq
  function: error.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant struct_extra178.error_name_len_is_5:
  description: "struct.error.__name__.__len__() == 5 — 'error' has 5 characters, shorter than 'Struct' (6); new to extra178"
  category: identity
  kind: python_call_eq
  function: error.__name__.__len__
  args: []
  expected: 5
