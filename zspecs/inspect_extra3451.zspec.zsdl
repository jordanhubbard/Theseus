spec: in3451
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 677 (in3451): __getitem__, __setitem__, __delitem__ dict-presence checks for inspect types."
    - "Theme: __getitem__/__setitem__/__delitem__ dict-presence (obj[key], obj[key]=val, del obj[key])."
    - "All values False — inspect introspection types have no custom getitem/setitem/delitem in their own __dict__."
    - "None of the inspect types define __getitem__, __setitem__, or __delitem__ in their own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "None of these types implement container/mapping protocols directly in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3451.getitem:
  description: "inspect types __getitem__ dict-presence checks; wave 677"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3451
  columns: [id, function, args, expected]
  rows:
    - ["in3451001", operator.contains, [inspect.Parameter.__dict__,           "__getitem__"], false]
    - ["in3451002", operator.contains, [inspect.Signature.__dict__,           "__getitem__"], false]
    - ["in3451003", operator.contains, [inspect.BoundArguments.__dict__,      "__getitem__"], false]
    - ["in3451004", operator.contains, [inspect.FrameInfo.__dict__,           "__getitem__"], false]
