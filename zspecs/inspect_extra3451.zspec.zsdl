    - ["in3451006", operator.contains, [inspect.FullArgSpec.__dict__,         "__getitem__"], false]
    - ["in3451007", operator.contains, [inspect.Attribute.__dict__,           "__getitem__"], false]
    - ["in3451008", operator.contains, [inspect.ClassFoundException.__dict__, "__getitem__"], false]
    - ["in3451009", operator.contains, [inspect.EndOfBlock.__dict__,          "__getitem__"], false]

