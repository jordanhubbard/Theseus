spec: inspect_extra706
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers Parameter, Signature, BoundArguments, FrameInfo, FullArgSpec, ArgInfo, and ArgSpec identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra706.signature_identity:
  description: "Identity checks for inspect.Parameter, Signature, BoundArguments, FrameInfo, FullArgSpec, ArgInfo, and ArgSpec"
  kind: python_call_eq
  category: class_identity
  id_prefix: in706si
  columns: [id, function, args, expected]
  rows:
    - [in706si001, inspect.Parameter.__qualname__.__eq__, ["Parameter"], true]
    - [in706si002, inspect.Parameter.__module__.__eq__, ["inspect"], true]
    - [in706si003, inspect.Parameter.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [in706si004, inspect.Signature.__qualname__.__eq__, ["Signature"], true]
    - [in706si005, inspect.Signature.__module__.__eq__, ["inspect"], true]
    - [in706si006, inspect.Signature.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [in706si007, inspect.BoundArguments.__qualname__.__eq__, ["BoundArguments"], true]
    - [in706si008, inspect.BoundArguments.__module__.__eq__, ["inspect"], true]
    - [in706si009, inspect.FrameInfo.__qualname__.__eq__, ["FrameInfo"], true]
    - [in706si010, inspect.FullArgSpec.__qualname__.__eq__, ["FullArgSpec"], true]
    - [in706si011, inspect.ArgInfo.__qualname__.__eq__, ["ArgInfo"], true]
    - [in706si012, inspect.ArgSpec.__qualname__.__eq__, ["ArgSpec"], true]
