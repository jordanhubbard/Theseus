spec: pynput_rust
version: ">=3.9"
backend: rust_module(pynput_rust)

docs: https://pynput.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "https://pynput.readthedocs.io/en/latest/ — pynput documentation"
  not_derived_from:
    - "pynput source: pynput/__init__.py"
  notes:
    - "pynput provides control and monitoring of input devices."
    - "pynput.keyboard.Key is an enum with keyboard key constants."
    - "pynput.keyboard.Key.space.name == 'space'."
    - "pynput.keyboard.Key.enter.name == 'enter'."
    - "pynput.keyboard.Key.tab.name == 'tab'."
    - "Expose pynput_key_space_name() -> str: pynput.keyboard.Key.space.name."
    - "Expose pynput_key_enter_name() -> str: pynput.keyboard.Key.enter.name."
    - "Expose pynput_has_keyboard() -> bool: hasattr(pynput, 'keyboard')."
    - "All test vectors verified against pynput 1.7.7."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# pynput_key_space_name — Key.space name
invariant pynput_rust.keyboard.space_name:
  description: "pynput.keyboard.Key.space.name == 'space'"
  category: keyboard
  kind: python_call_eq
  function: pynput_key_space_name
  args: []
  expected: "space"

# pynput_key_enter_name — Key.enter name
invariant pynput_rust.keyboard.enter_name:
  description: "pynput.keyboard.Key.enter.name == 'enter'"
  category: keyboard
  kind: python_call_eq
  function: pynput_key_enter_name
  args: []
  expected: "enter"

# pynput_has_keyboard — keyboard module present
invariant pynput_rust.module.has_keyboard:
  description: "pynput.keyboard is available"
  category: module
  kind: python_call_eq
  function: pynput_has_keyboard
  args: []
  expected: true

