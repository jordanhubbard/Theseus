spec: to_camel_case
version: ">=1.0.0"
backend: node(to-camel-case)

docs: https://www.npmjs.com/package/to-camel-case

provenance:
  derived_from:
    - "to-camel-case README — https://www.npmjs.com/package/to-camel-case"
    - "Test vectors verified with to-camel-case via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "to-camel-case source"
  notes:
    - "to-camel-case is an npm package. Install: npm install to-camel-case"
    - "Converts a string to camelCase."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table to_camel_case.toCamelCase:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: camelcase

  columns: [id, args, expected]
  rows:
    - [spaces,  ["hello world"],  "helloWorld"]
    - [hyphen,  ["foo-bar"],      "fooBar"]
    - [snake,   ["foo_bar"],      "fooBar"]
