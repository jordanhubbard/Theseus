spec: theseus_select_cr
version: ">=3.8"
backend: python_cleanroom(theseus_select_cr)
blocks: select

docs: https://docs.python.org/3/library/select.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/select.html"
  not_derived_from:
    - "CPython source: Modules/selectmodule.c"
  notes:
    - "Clean-room select module. Do NOT import select."

error_model: python_exceptions

invariant theseus_select_cr.select2_select_empty:
  description: "select() with empty lists and timeout=0 returns immediately"
  category: behavior
  kind: python_call_eq
  function: select2_select_empty
  args: []
  expected: true

invariant theseus_select_cr.select2_pipe_ready:
  description: "select() detects data available on a pipe"
  category: behavior
  kind: python_call_eq
  function: select2_pipe_ready
  args: []
  expected: true

invariant theseus_select_cr.select2_error_class:
  description: "error exception class exists"
  category: behavior
  kind: python_call_eq
  function: select2_error_class
  args: []
  expected: true
