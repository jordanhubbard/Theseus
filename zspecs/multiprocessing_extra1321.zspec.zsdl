spec: multiprocessing_extra1321
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 535 (_extra1321): focuses on __repr__ and __str__ method class checks for multiprocessing classes."
    - "multiprocessing.Queue and multiprocessing.Lock are factory functions, not classes — not tested here."
    - "multiprocessing.Process.__repr__.__qualname__ == 'BaseProcess.__repr__' — inherited from BaseProcess."
    - "multiprocessing.Process.__repr__.__class__.__name__ == 'function' — Python function."
    - "multiprocessing.pool.Pool.__repr__.__qualname__ == 'Pool.__repr__' — defines its own __repr__."
    - "multiprocessing.pool.Pool.__repr__.__class__.__name__ == 'function' — Python function."
    - "Both Process and Pool inherit __str__ from object — wrapper_descriptor."
    - "repr() of class objects is always str."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra1321.repr_qualnames:
  description: "multiprocessing.Process and pool.Pool __repr__ qualname checks"
  kind: python_call_eq
  category: identity
  id_prefix: mp1321rq
  columns: [id, function, args, expected]
  rows:
    - [mp1321rq001, multiprocessing.Process.__repr__.__qualname__.__eq__,        ["BaseProcess.__repr__"], true]
    - [mp1321rq002, multiprocessing.pool.Pool.__repr__.__qualname__.__eq__,      ["Pool.__repr__"],        true]
    - [mp1321rq003, multiprocessing.Process.__str__.__qualname__.__eq__,         ["object.__str__"],       true]
    - [mp1321rq004, multiprocessing.pool.Pool.__str__.__qualname__.__eq__,       ["object.__str__"],       true]
    - [mp1321rq005, multiprocessing.Process.__repr__.__qualname__.__class__.__name__.__eq__, ["str"],       true]
    - [mp1321rq006, multiprocessing.pool.Pool.__repr__.__qualname__.__class__.__name__.__eq__, ["str"],     true]

table multiprocessing_extra1321.repr_class_names:
  description: "multiprocessing.Process and pool.Pool __repr__ and __str__ method class checks"
  kind: python_call_eq
  category: identity
  id_prefix: mp1321rc
  columns: [id, function, args, expected]
  rows:
    - [mp1321rc001, multiprocessing.Process.__repr__.__class__.__name__.__eq__,        ["function"],           true]
    - [mp1321rc002, multiprocessing.pool.Pool.__repr__.__class__.__name__.__eq__,      ["function"],           true]
    - [mp1321rc003, multiprocessing.Process.__str__.__class__.__name__.__eq__,         ["wrapper_descriptor"], true]
    - [mp1321rc004, multiprocessing.pool.Pool.__str__.__class__.__name__.__eq__,       ["wrapper_descriptor"], true]
    - [mp1321rc005, multiprocessing.Process.__repr__.__class__.__name__.__class__.__name__.__eq__, ["str"],    true]
    - [mp1321rc006, multiprocessing.pool.Pool.__repr__.__class__.__name__.__class__.__name__.__eq__, ["str"],  true]

table multiprocessing_extra1321.str_inherited_from_object:
  description: "multiprocessing classes inherit __str__ from object — qualname is object.__str__ and class is wrapper_descriptor"
  kind: python_call_eq
  category: identity
  id_prefix: mp1321si
  columns: [id, function, args, expected]
  rows:
    - [mp1321si001, multiprocessing.Process.__str__.__qualname__.__eq__,                    ["object.__str__"],    true]
    - [mp1321si002, multiprocessing.pool.Pool.__str__.__qualname__.__eq__,                  ["object.__str__"],    true]
    - [mp1321si003, multiprocessing.Process.__str__.__class__.__name__.__eq__,              ["wrapper_descriptor"], true]
    - [mp1321si004, multiprocessing.pool.Pool.__str__.__class__.__name__.__eq__,            ["wrapper_descriptor"], true]
    - [mp1321si005, multiprocessing.Process.__str__.__qualname__.__class__.__name__.__eq__, ["str"],               true]
    - [mp1321si006, multiprocessing.pool.Pool.__str__.__qualname__.__class__.__name__.__eq__, ["str"],             true]
