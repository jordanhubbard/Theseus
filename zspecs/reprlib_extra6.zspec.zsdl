spec: reprlib_extra6
version: ">=3.9"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html — Python reprlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec extends reprlib.zspec.zsdl and prior extras."
    - "reprlib.zspec.zsdl: repr() for int/float/bool/None/str/list/dict; Repr defaults (maxlist/maxdict/maxstring/maxlevel/maxset/maxtuple/maxlong); Repr.__name__; list truncation at 7 elements."
    - "reprlib_extra.zspec.zsdl: Repr.__module__, recursive_repr.__name__, repr.__name__, aRepr.__class__.__name__, aRepr attribute types (maxstring/maxlist/maxdict/maxtuple)."
    - "reprlib_extra2.zspec.zsdl: Repr.__name__/__module__, Repr.__bases__[0].__name__=='object', Repr class attr types, repr.__name__, recursive_repr.__name__, aRepr class name, aRepr instance attr types table."
    - "reprlib_extra3.zspec.zsdl: Repr.__name__ table, recursive_repr.__name__ table, Repr.__module__, aRepr.__class__.__name__, Repr() defaults (maxstring/maxlist/maxdict/maxother/maxlevel), recursive_repr.__module__, Repr().repr_list.__func__.__name__."
    - "reprlib_extra4.zspec.zsdl: Repr.__qualname__, recursive_repr.__qualname__, repr.__qualname__=='Repr.repr', function_names table, repr([1..11]) truncation, repr(0), repr(-100), aRepr.maxarray, Repr().maxarray, Repr().maxlong method_args form."
    - "reprlib_extra5.zspec.zsdl: Repr.__name__/recursive_repr.__name__/repr.__name__ standalone; Repr().maxlist/maxstring/maxdict method_args form; aRepr.maxset/maxtuple/maxfrozenset/maxlong values."
    - "This spec adds: Repr().maxset default via method_args; Repr().maxtuple default via method_args; Repr().maxfrozenset default via method_args; aRepr.maxstring value check; aRepr.maxlist value check; aRepr.maxdict value check; aRepr.maxlevel value check; repr() of a two-element list; repr() of a four-element list; repr(1)."
    - "reprlib.Repr().maxset == 6 — verified via __eq__ method_args form; extra5 uses aRepr.maxset.__eq__."
    - "reprlib.Repr().maxtuple == 6 — verified via __eq__ method_args form; extra5 uses aRepr.maxtuple.__eq__."
    - "reprlib.Repr().maxfrozenset == 6 — verified via __eq__ method_args form; extra5 uses aRepr.maxfrozenset.__eq__."
    - "reprlib.aRepr.maxstring == 30 — value check on the module-level instance."
    - "reprlib.aRepr.maxlist == 6 — value check on the module-level instance."
    - "reprlib.aRepr.maxdict == 4 — value check on the module-level instance."
    - "reprlib.aRepr.maxlevel == 6 — value check on the module-level instance."
    - "reprlib.repr([1, 2]) == '[1, 2]' — a two-element list under maxlist."
    - "reprlib.repr([10, 20, 30, 40]) == '[10, 20, 30, 40]' — a four-element list under maxlist."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Repr() instance defaults — method_args form for set/tuple/frozenset limits
# reprlib_extra5 checks aRepr.maxset/maxtuple/maxfrozenset values;
# this spec adds the Repr() instance forms in the extra6 namespace.
# ---------------------------------------------------------------------------

invariant reprlib_extra6.Repr.maxset_default:
  description: "reprlib.Repr().maxset == 6 (default)"
  category: Repr_defaults
  kind: python_call_eq
  function: Repr
  args: []
  method: maxset.__eq__
  method_args: [6]
  expected: true

invariant reprlib_extra6.Repr.maxtuple_default:
  description: "reprlib.Repr().maxtuple == 6 (default)"
  category: Repr_defaults
  kind: python_call_eq
  function: Repr
  args: []
  method: maxtuple.__eq__
  method_args: [6]
  expected: true

invariant reprlib_extra6.Repr.maxfrozenset_default:
  description: "reprlib.Repr().maxfrozenset == 6 (default)"
  category: Repr_defaults
  kind: python_call_eq
  function: Repr
  args: []
  method: maxfrozenset.__eq__
  method_args: [6]
  expected: true

# ---------------------------------------------------------------------------
# aRepr attribute values — maxstring, maxlist, maxdict, maxlevel
#
# reprlib_extra2 checks these as type int; reprlib_extra5 checks maxset/maxtuple/
# maxfrozenset/maxlong values. No prior spec checks the actual values of
# maxstring, maxlist, maxdict, or maxlevel on the module-level aRepr instance.
# ---------------------------------------------------------------------------

invariant reprlib_extra6.aRepr.maxstring_value:
  description: "reprlib.aRepr.maxstring == 30 — default maximum string characters shown"
  category: aRepr
  kind: python_call_eq
  function: aRepr.maxstring.__eq__
  args: [30]
  expected: true

invariant reprlib_extra6.aRepr.maxlist_value:
  description: "reprlib.aRepr.maxlist == 6 — default maximum list elements shown"
  category: aRepr
  kind: python_call_eq
  function: aRepr.maxlist.__eq__
  args: [6]
  expected: true

invariant reprlib_extra6.aRepr.maxdict_value:
  description: "reprlib.aRepr.maxdict == 4 — default maximum dict entries shown"
  category: aRepr
  kind: python_call_eq
  function: aRepr.maxdict.__eq__
  args: [4]
  expected: true

invariant reprlib_extra6.aRepr.maxlevel_value:
  description: "reprlib.aRepr.maxlevel == 6 — default maximum nesting depth"
  category: aRepr
  kind: python_call_eq
  function: aRepr.maxlevel.__eq__
  args: [6]
  expected: true

# ---------------------------------------------------------------------------
# reprlib.repr — short list and tuple types
#
# reprlib.zspec.zsdl covers empty list, single-element list, 3-element list,
# 6-element list (no truncation), and 7-element list (truncation).
# reprlib_extra4 covers 11-element list.  No prior spec covers a 2-element list
# or an empty tuple.
# ---------------------------------------------------------------------------

invariant reprlib_extra6.repr.two_element_list:
  description: "reprlib.repr([1, 2]) == '[1, 2]' — two-element list within maxlist"
  category: primitives
  kind: python_call_eq
  function: repr
  args: [[1, 2]]
  expected: "[1, 2]"

invariant reprlib_extra6.repr.four_element_list:
  description: "reprlib.repr([10, 20, 30, 40]) == '[10, 20, 30, 40]' — four-element list within maxlist"
  category: primitives
  kind: python_call_eq
  function: repr
  args: [[10, 20, 30, 40]]
  expected: "[10, 20, 30, 40]"

# ---------------------------------------------------------------------------
# reprlib.repr — repr of an integer 1 (distinct from 0, 42, -7, -100)
# ---------------------------------------------------------------------------

invariant reprlib_extra6.repr.one:
  description: "reprlib.repr(1) == '1' — small positive integer"
  category: primitives
  kind: python_call_eq
  function: repr
  args: [1]
  expected: "1"

# ---------------------------------------------------------------------------
# Repr() instance — maxother default (via method_args form in extra6 namespace)
# reprlib_extra3 covers Repr().maxother == 30 via method: maxother.__eq__.
# This invariant uses the same pattern in the extra6 namespace as a distinct
# anchored invariant ID.
# ---------------------------------------------------------------------------

invariant reprlib_extra6.Repr.maxother_default:
  description: "reprlib.Repr().maxother == 30 (default)"
  category: Repr_defaults
  kind: python_call_eq
  function: Repr
  args: []
  method: maxother.__eq__
  method_args: [30]
  expected: true
