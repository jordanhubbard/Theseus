spec: itertools_extra2746
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 630 theme: __round__, __divmod__, and __pow__ dict-presence checks (numeric arithmetic protocol — used by round(), divmod(), and the ** operator)."
    - "All itertools iterator classes (chain, count, repeat, cycle, islice, compress, dropwhile, takewhile, starmap, groupby, filterfalse, accumulate, zip_longest, pairwise, product, permutations, combinations, combinations_with_replacement) are lazy iterators."
    - "Lazy iterators do not support numeric arithmetic protocols such as __round__, __divmod__, or __pow__."
    - "itertools.count yields integers/floats indefinitely but the iterator class itself defines none of __round__, __divmod__, or __pow__ in its __dict__."
    - "None of the itertools classes define __round__, __divmod__, or __pow__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __round__ dict-presence — absent from all itertools classes
# ---------------------------------------------------------------------------

table itertools_extra2746.round_protocol:
  description: "__round__ is absent from all itertools iterator class __dict__s — lazy iterators do not support the round() numeric protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2746

  columns: [id, function, args, expected]
  rows:
    - ["it2746001", "itertools.chain.__dict__.__contains__",                         ["__round__"], false]
    - ["it2746002", "itertools.count.__dict__.__contains__",                         ["__round__"], false]
    - ["it2746003", "itertools.repeat.__dict__.__contains__",                        ["__round__"], false]
    - ["it2746004", "itertools.cycle.__dict__.__contains__",                         ["__round__"], false]
    - ["it2746005", "itertools.islice.__dict__.__contains__",                        ["__round__"], false]
    - ["it2746006", "itertools.compress.__dict__.__contains__",                      ["__round__"], false]
    - ["it2746007", "itertools.dropwhile.__dict__.__contains__",                     ["__round__"], false]
    - ["it2746008", "itertools.takewhile.__dict__.__contains__",                     ["__round__"], false]
    - ["it2746009", "itertools.starmap.__dict__.__contains__",                       ["__round__"], false]
    - ["it2746010", "itertools.groupby.__dict__.__contains__",                       ["__round__"], false]
    - ["it2746011", "itertools.filterfalse.__dict__.__contains__",                   ["__round__"], false]
    - ["it2746012", "itertools.accumulate.__dict__.__contains__",                    ["__round__"], false]
    - ["it2746013", "itertools.zip_longest.__dict__.__contains__",                   ["__round__"], false]
    - ["it2746014", "itertools.pairwise.__dict__.__contains__",                      ["__round__"], false]
    - ["it2746015", "itertools.product.__dict__.__contains__",                       ["__round__"], false]
    - ["it2746016", "itertools.permutations.__dict__.__contains__",                  ["__round__"], false]
    - ["it2746017", "itertools.combinations.__dict__.__contains__",                  ["__round__"], false]
    - ["it2746018", "itertools.combinations_with_replacement.__dict__.__contains__",  ["__round__"], false]

