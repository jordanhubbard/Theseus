spec: struct_extra2266
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Wave 598 (_extra2266): pickling/serialization protocol dict-presence checks."
    - "Checks __reduce__, __reduce_ex__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__, __copy__, __deepcopy__, __sizeof__, __class_getitem__, __init_subclass__ presence in __dict__ of struct types."
    - "struct.Struct is a C extension type (_struct.Struct); it defines __sizeof__ (True); all other pickling/copy protocol keys absent from __dict__."
    - "struct.error is a Python exception class subclassing Exception; all pickling/copy/sizeof protocol keys absent from __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2266.struct_pickle:
  description: "struct.Struct pickle/copy protocol dict-presence — __sizeof__ present; all other protocol keys absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2266

  columns: [id, function, args, expected]
  rows:
    - ["st2266001", "struct.Struct.__dict__.__contains__", ["__reduce__"], false]
    - ["st2266002", "struct.Struct.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["st2266003", "struct.Struct.__dict__.__contains__", ["__getstate__"], false]
    - ["st2266004", "struct.Struct.__dict__.__contains__", ["__setstate__"], false]
    - ["st2266005", "struct.Struct.__dict__.__contains__", ["__getnewargs__"], false]
    - ["st2266006", "struct.Struct.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["st2266007", "struct.Struct.__dict__.__contains__", ["__copy__"], false]
    - ["st2266008", "struct.Struct.__dict__.__contains__", ["__deepcopy__"], false]
    - ["st2266009", "struct.Struct.__dict__.__contains__", ["__sizeof__"], true]
    - ["st2266010", "struct.Struct.__dict__.__contains__", ["__class_getitem__"], false]
    - ["st2266011", "struct.Struct.__dict__.__contains__", ["__init_subclass__"], false]

table struct_extra2266.error_pickle:
  description: "struct.error pickle/copy protocol dict-presence — all pickling and copy protocol keys absent from __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2266

  columns: [id, function, args, expected]
  rows:
    - ["st2266012", "struct.error.__dict__.__contains__", ["__reduce__"], false]
    - ["st2266013", "struct.error.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["st2266014", "struct.error.__dict__.__contains__", ["__getstate__"], false]
    - ["st2266015", "struct.error.__dict__.__contains__", ["__setstate__"], false]
    - ["st2266016", "struct.error.__dict__.__contains__", ["__getnewargs__"], false]
    - ["st2266017", "struct.error.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["st2266018", "struct.error.__dict__.__contains__", ["__copy__"], false]
    - ["st2266019", "struct.error.__dict__.__contains__", ["__deepcopy__"], false]
    - ["st2266020", "struct.error.__dict__.__contains__", ["__sizeof__"], false]
    - ["st2266021", "struct.error.__dict__.__contains__", ["__class_getitem__"], false]
    - ["st2266022", "struct.error.__dict__.__contains__", ["__init_subclass__"], false]
