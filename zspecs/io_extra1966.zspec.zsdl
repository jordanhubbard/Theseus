spec: io_extra1966
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "_io_extra.zspec.zsdl — covers _io C-module class metadata"
    - "io_extra4.zspec.zsdl — covers io.IOBase/__name__/__module__/is_type and class metadata for RawIOBase/BufferedIOBase/TextIOBase"
  notes:
    - "Wave 578 (_extra1966): __enter__/__exit__, __aenter__/__aexit__, __del__ dict-presence checks."
    - "io.IOBase is a Python-level class (module='io') that inherits from _io._IOBase (module='_io')."
    - "__enter__, __exit__, and __del__ live in _io._IOBase.__dict__, NOT in io.IOBase.__dict__."
    - "Therefore all io.X.__dict__.__contains__ checks for __enter__/__exit__/__del__ return False."
    - "None of the io public classes define __aenter__ or __aexit__ — io streams are sync-only."
    - "io.BufferedReader, io.BufferedWriter, io.BufferedRWPair, io.BufferedRandom are also covered."
    - "io.TextIOWrapper is the C-accelerated text wrapper; none of these define __enter__ in their own __dict__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __enter__ dict-presence — io public classes
# io.IOBase, RawIOBase, BufferedIOBase, TextIOBase each have module='io' and
# do NOT define __enter__ in their own __dict__ (it resides in _io._IOBase).
# ---------------------------------------------------------------------------

table io_extra1966.enter_protocol:
  description: "io public class __dict__.__contains__('__enter__') — all False (inherited from _io._IOBase)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1966

  columns: [id, function, args, expected]
  rows:
    - ["io1966001", "io.IOBase.__dict__.__contains__",         ["__enter__"], false]
    - ["io1966002", "io.RawIOBase.__dict__.__contains__",      ["__enter__"], false]
    - ["io1966003", "io.BufferedIOBase.__dict__.__contains__", ["__enter__"], false]
    - ["io1966004", "io.TextIOBase.__dict__.__contains__",     ["__enter__"], false]
    - ["io1966005", "io.BytesIO.__dict__.__contains__",        ["__enter__"], false]
    - ["io1966006", "io.StringIO.__dict__.__contains__",       ["__enter__"], false]
    - ["io1966007", "io.FileIO.__dict__.__contains__",         ["__enter__"], false]
    - ["io1966008", "io.BufferedReader.__dict__.__contains__", ["__enter__"], false]
    - ["io1966009", "io.BufferedWriter.__dict__.__contains__", ["__enter__"], false]
    - ["io1966010", "io.BufferedRandom.__dict__.__contains__", ["__enter__"], false]

