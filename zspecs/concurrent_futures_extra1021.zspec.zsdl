spec: concurrent_futures_extra1021
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks concurrent.futures Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor weakref descriptors and module attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra1021.weakref_descriptors:
  description: "concurrent.futures core classes __weakref__ class name identity"
  kind: python_call_eq
  category: weakref_descriptors
  id_prefix: cf1021x
  columns: [id, function, args, expected]
  rows:
    - [cf1021x001, concurrent.futures.Future.__weakref__.__class__.__name__.__eq__,             ["getset_descriptor"], true]
    - [cf1021x002, concurrent.futures.ThreadPoolExecutor.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [cf1021x003, concurrent.futures.ProcessPoolExecutor.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [cf1021x004, concurrent.futures.Executor.__weakref__.__class__.__name__.__eq__,           ["getset_descriptor"], true]
    - [cf1021x005, concurrent.futures.Future.__class__.__name__.__eq__,                         ["type"],              true]
    - [cf1021x006, concurrent.futures.Executor.__class__.__name__.__eq__,                       ["type"],              true]
    - [cf1021x007, concurrent.futures.ThreadPoolExecutor.__class__.__name__.__eq__,             ["type"],              true]

table concurrent_futures_extra1021.module_attributes:
  description: "concurrent.futures module-level attribute class identity"
  kind: python_call_eq
  category: module_attributes
  id_prefix: cf1021m
  columns: [id, function, args, expected]
  rows:
    - [cf1021m001, concurrent.futures.__all__.__class__.__name__.__eq__, ["list"],               true]
    - [cf1021m002, concurrent.futures.__name__.__eq__,                   ["concurrent.futures"], true]
    - [cf1021m003, concurrent.futures.__package__.__eq__,                ["concurrent.futures"], true]
    - [cf1021m004, concurrent.futures.__file__.__class__.__name__.__eq__, ["str"],               true]
    - [cf1021m005, concurrent.futures.__spec__.__class__.__name__.__eq__, ["ModuleSpec"],        true]

table concurrent_futures_extra1021.exception_classes:
  description: "concurrent.futures exception class identity"
  kind: python_call_eq
  category: exception_classes
  id_prefix: cf1021e
  columns: [id, function, args, expected]
  rows:
    - [cf1021e001, concurrent.futures.CancelledError.__module__.__eq__,        ["concurrent.futures"], true]
    - [cf1021e002, concurrent.futures.TimeoutError.__module__.__eq__,          ["concurrent.futures"], true]
    - [cf1021e003, concurrent.futures.BrokenExecutor.__module__.__eq__,        ["concurrent.futures"], true]
    - [cf1021e004, concurrent.futures.CancelledError.__class__.__name__.__eq__, ["type"],               true]
    - [cf1021e005, concurrent.futures.TimeoutError.__class__.__name__.__eq__,  ["type"],               true]
