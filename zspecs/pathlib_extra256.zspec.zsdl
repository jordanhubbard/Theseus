spec: pathlib_extra256
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers pathlib.Path error cases (FileNotFoundError on stat, read_text, iterdir for nonexistent paths) and pathlib.Path method identity (__class__.__name__ for stat, read_text, is_absolute, iterdir)."
    - "pathlib.Path('/nonexistent/path/xyz').stat() raises FileNotFoundError — verified on macOS/Darwin 25.4.0."
    - "pathlib.Path('/nonexistent/path/xyz').read_text() raises FileNotFoundError — verified on macOS/Darwin 25.4.0."
    - "list(pathlib.Path('/nonexistent/path/xyz').iterdir()) raises FileNotFoundError — calling iterdir() on a nonexistent path raises FileNotFoundError when the iterator is consumed (list() forces iteration); verified on macOS/Darwin 25.4.0."
    - "pathlib.Path.stat, Path.read_text, Path.is_absolute, Path.iterdir are all Python function objects; their __class__.__name__ is 'function'."
    - "pathlib.Path.name is a property descriptor; its __class__.__name__ is 'property'."
    - "pathlib.Path('').name == '' — the empty path has an empty name component."
    - "pathlib.Path('.').name == '' — the current-directory path '.' has an empty name (the dot is not a filename component in pathlib semantics)."
    - "pathlib.Path('/').name == '' — the root path has an empty name component."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.Path method identity — __class__.__name__
#
# Path.stat, Path.read_text, Path.is_absolute, Path.iterdir are unbound
# Python function objects (defined in Lib/pathlib/__init__.py); their
# __class__.__name__ is 'function'. Path.name is a property descriptor.
# ---------------------------------------------------------------------------

table pathlib_extra256.path_method_identity:
  description: "pathlib.Path method identity — stat, read_text, is_absolute, iterdir are 'function'; name is 'property'; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibxmi256

  columns: [id, function, args, expected, description]
  rows:
    - [stat_class,
       "Path.stat.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.Path.stat.__class__.__name__.__eq__('function') == True — Path.stat is an unbound Python function defined in Lib/pathlib/__init__.py; it calls os.stat() on the path's filesystem entry; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra256"]
    - [read_text_class,
       "Path.read_text.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.Path.read_text.__class__.__name__.__eq__('function') == True — Path.read_text is an unbound Python function that opens the file and returns its text contents; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra256"]
    - [is_absolute_class,
       "Path.is_absolute.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.Path.is_absolute.__class__.__name__.__eq__('function') == True — Path.is_absolute is an unbound Python function that returns True if the path is absolute (has a root); its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra256"]
    - [iterdir_class,
       "Path.iterdir.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.Path.iterdir.__class__.__name__.__eq__('function') == True — Path.iterdir is an unbound Python function that yields directory entries; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra256"]
    - [name_class,
       "Path.name.__class__.__name__.__eq__",
       ["property"],
       true,
       "pathlib.Path.name.__class__.__name__.__eq__('property') == True — Path.name is a property descriptor (not a plain function); it returns the final path component as a string; its __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra256"]
    - [stat_name,
       "Path.stat.__name__.__eq__",
       ["stat"],
       true,
       "pathlib.Path.stat.__name__.__eq__('stat') == True — Path.stat's function __name__ is 'stat'; str.__eq__('stat') returns True; new to extra256"]
    - [read_text_name,
       "Path.read_text.__name__.__eq__",
       ["read_text"],
       true,
       "pathlib.Path.read_text.__name__.__eq__('read_text') == True — Path.read_text's function __name__ is 'read_text'; str.__eq__('read_text') returns True; new to extra256"]
    - [is_absolute_name,
       "Path.is_absolute.__name__.__eq__",
       ["is_absolute"],
       true,
       "pathlib.Path.is_absolute.__name__.__eq__('is_absolute') == True — Path.is_absolute's function __name__ is 'is_absolute'; str.__eq__('is_absolute') returns True; new to extra256"]
    - [iterdir_name,
       "Path.iterdir.__name__.__eq__",
       ["iterdir"],
       true,
       "pathlib.Path.iterdir.__name__.__eq__('iterdir') == True — Path.iterdir's function __name__ is 'iterdir'; str.__eq__('iterdir') returns True; new to extra256"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.Path method __module__ values
#
# All Path methods (stat, read_text, is_absolute, iterdir) are defined in
# the pathlib module; their __module__ is 'pathlib'.
# ---------------------------------------------------------------------------

table pathlib_extra256.path_method_modules:
  description: "pathlib.Path method __module__ values — stat, read_text, is_absolute, iterdir are all 'pathlib'; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibxmm256

  columns: [id, function, args, expected, description]
  rows:
    - [stat_module,
       "Path.stat.__module__.__eq__",
       ["pathlib"],
       true,
       "pathlib.Path.stat.__module__.__eq__('pathlib') == True — Path.stat is defined in the pathlib module (Lib/pathlib/__init__.py); its __module__ is 'pathlib'; str.__eq__('pathlib') returns True; new to extra256"]
    - [read_text_module,
       "Path.read_text.__module__.__eq__",
       ["pathlib"],
       true,
       "pathlib.Path.read_text.__module__.__eq__('pathlib') == True — Path.read_text is defined in the pathlib module; its __module__ is 'pathlib'; str.__eq__('pathlib') returns True; new to extra256"]
    - [is_absolute_module,
       "Path.is_absolute.__module__.__eq__",
       ["pathlib"],
       true,
       "pathlib.Path.is_absolute.__module__.__eq__('pathlib') == True — Path.is_absolute is defined in the pathlib module; its __module__ is 'pathlib'; str.__eq__('pathlib') returns True; new to extra256"]
    - [iterdir_module,
       "Path.iterdir.__module__.__eq__",
       ["pathlib"],
       true,
       "pathlib.Path.iterdir.__module__.__eq__('pathlib') == True — Path.iterdir is defined in the pathlib module; its __module__ is 'pathlib'; str.__eq__('pathlib') returns True; new to extra256"]

# ---------------------------------------------------------------------------
# Standalone invariants — pathlib_extra256: error cases
#
# Path.stat(), Path.read_text(), and list(Path.iterdir()) on a nonexistent
# path all raise FileNotFoundError. These are the canonical Python errors for
# missing filesystem entries.
# ---------------------------------------------------------------------------

invariant pathlib_extra256.stat_nonexistent_raises:
  description: "pathlib.Path('/nonexistent/path/xyz').stat() raises FileNotFoundError — new to extra256"
  category: errors
  kind: python_call_raises
  function: Path
  args: ["/nonexistent/path/that/does/not/exist/xyz"]
  raises: FileNotFoundError

invariant pathlib_extra256.stat_method_is_function:
  description: "pathlib.Path.stat.__class__.__name__ == 'function' — Path.stat is an unbound Python function; new to extra256"
  kind: python_call_eq
  function: Path.stat.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra256.read_text_is_function:
  description: "pathlib.Path.read_text.__class__.__name__ == 'function' — Path.read_text is an unbound Python function; new to extra256"
  kind: python_call_eq
  function: Path.read_text.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra256.name_descriptor_is_property:
  description: "pathlib.Path.name.__class__.__name__ == 'property' — Path.name is a property descriptor, not a plain function; new to extra256"
  kind: python_call_eq
  function: Path.name.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra256.is_absolute_name:
  description: "pathlib.Path.is_absolute.__name__ == 'is_absolute' — function identity of Path.is_absolute; new to extra256"
  kind: python_call_eq
  function: Path.is_absolute.__name__.__eq__
  args: ["is_absolute"]
  expected: true

invariant pathlib_extra256.iterdir_module:
  description: "pathlib.Path.iterdir.__module__ == 'pathlib' — iterdir is defined in the pathlib module; new to extra256"
  kind: python_call_eq
  function: Path.iterdir.__module__.__eq__
  args: ["pathlib"]
  expected: true
