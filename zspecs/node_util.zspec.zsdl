spec: node_util
version: ">=0.12.5"
backend: node(util)

docs: https://nodejs.org/api/util.html

provenance:
  derived_from:
    - "Node.js util module documentation — https://nodejs.org/api/util.html"
    - "Test vectors verified with Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "Node.js source"
  notes:
    - "util is a Node.js built-in module. No npm install required."
    - "util.format(format, ...args) formats a string using printf-style placeholders."
    - "util.inspect(value) returns a string representation of value for debugging."
    - "%s is string, %d is number, %i is integer, %j is JSON."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns formatted string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table node_util.format:
  kind: node_module_call_eq
  function: format
  category: format
  id_prefix: utfmt

  columns: [id, args, expected]
  rows:
    - [string,    ["%s world", "hello"],    "hello world"]
    - [number,    ["%d + %d = %d", 1, 2, 3], "1 + 2 = 3"]
    - [json,      ["%j", {"a": 1}],         '{"a":1}']
    - [no_fmt,    ["hello"],                 "hello"]
    - [mixed,     ["%s is %d", "answer", 42], "answer is 42"]
