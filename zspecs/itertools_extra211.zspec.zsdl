spec: itertools_extra211
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools.zspec.zsdl — covers classnames and first-element tests for chain, islice, count, cycle, repeat, accumulate, compress, product, combinations, zip_longest"
    - "itertools_extra.zspec.zsdl — covers filterfalse classname, chain/repeat/islice length_hint and first-element checks"
  notes:
    - "itertools.islice.__dict__.__contains__('__doc__') == True — islice is a C-level type; its class dict contains '__doc__'. Verified with Python 3.14.3."
    - "itertools.islice.__dict__.__len__() == 6 — the class dict for islice has exactly 6 entries: __new__, __getattribute__, __iter__, __next__, __doc__, __module__. Verified with Python 3.14.3."
    - "itertools.islice.__dict__.__contains__('__iter__') == True — islice implements the iterator protocol; __iter__ is in its class dict. Verified with Python 3.14.3."
    - "itertools.islice.__dict__.__contains__('__next__') == True — islice implements __next__ in its class dict. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__doc__.__len__() == 234 — the docstring has exactly 234 characters. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__doc__.__contains__('replacement') == True — the docstring mentions 'replacement' in its description. Verified with Python 3.14.3."
    - "itertools.zip_longest.__doc__.__contains__('None') == True — the docstring mentions 'None' as the default fillvalue. Verified with Python 3.14.3."
    - "itertools.zip_longest.__doc__.__contains__('fillvalue') == True — the docstring documents the fillvalue parameter. Verified with Python 3.14.3."
    - "itertools.product.__doc__.__contains__('product') == True — the docstring mentions 'product' (the function name). Verified with Python 3.14.3."
    - "itertools.product.__doc__.__contains__('Cartesian') == True — the docstring describes the Cartesian product. Verified with Python 3.14.3."
    - "itertools.chain.__dict__.__len__() == 8 — chain's class dict has 8 entries: __new__, __getattribute__, __iter__, __next__, from_iterable, __class_getitem__, __doc__, __module__. Verified with Python 3.14.3."
    - "itertools.chain.__dict__.__contains__('from_iterable') == True — chain.from_iterable is a class method in the chain class dict. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.islice.__dict__ membership and length checks
#
# islice.__dict__.__contains__('__doc__')           == True
# islice.__dict__.__contains__('__iter__')          == True
# islice.__dict__.__contains__('__next__')          == True
# islice.__dict__.__len__()                         == 6
# ---------------------------------------------------------------------------

table itertools_extra211.islice_dict:
  description: "itertools.islice.__dict__ membership checks in iterchain211isl namespace — the class dict for islice (a C-level type) contains '__doc__', '__iter__', '__next__', and '__new__'; the dict length is exactly 6 (__new__, __getattribute__, __iter__, __next__, __doc__, __module__); all checks verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iterchain211isl

  columns: [id, function, args, expected, description]
  rows:
    - [islice_dict_has_doc,
       islice.__dict__.__contains__,
       ["__doc__"],
       true,
       "itertools.islice.__dict__.__contains__('__doc__') == True — islice is a C-level type with a docstring stored in its class dict under '__doc__'; __contains__('__doc__') returns True; verified with Python 3.14.3"]
    - [islice_dict_has_iter,
       islice.__dict__.__contains__,
       ["__iter__"],
       true,
       "itertools.islice.__dict__.__contains__('__iter__') == True — islice implements the iterator protocol; __iter__ is defined in its class dict to return self; __contains__('__iter__') returns True; verified with Python 3.14.3"]
    - [islice_dict_has_next,
       islice.__dict__.__contains__,
       ["__next__"],
       true,
       "itertools.islice.__dict__.__contains__('__next__') == True — islice implements __next__ in its class dict to advance the iterator; __contains__('__next__') returns True; verified with Python 3.14.3"]
    - [islice_dict_len,
       islice.__dict__.__len__,
       [],
       6,
       "itertools.islice.__dict__.__len__() == 6 — the class dict for islice has exactly 6 entries: __new__, __getattribute__, __iter__, __next__, __doc__, __module__; __len__() returns 6; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: itertools.combinations_with_replacement.__doc__ checks
#
# __doc__.__len__()                       == 234
# __doc__.__contains__('replacement')     == True
# __doc__.__contains__('successive')      == True
# __doc__.__contains__('iterable')        == True
# ---------------------------------------------------------------------------

table itertools_extra211.combinations_with_replacement_doc:
  description: "itertools.combinations_with_replacement.__doc__ checks in iterchain211cwr namespace — the docstring has 234 characters and describes successive r-length combinations allowing individual elements to have successive repeats; checks confirm length is 234, 'replacement' is present, 'successive' is present, 'iterable' is present; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc_checks
  id_prefix: iterchain211cwr

  columns: [id, function, args, expected, description]
  rows:
    - [cwr_doc_len,
       combinations_with_replacement.__doc__.__len__,
       [],
       234,
       "itertools.combinations_with_replacement.__doc__.__len__() == 234 — the docstring 'Return successive r-length combinations of elements in the iterable allowing individual elements to have successive repeats...' has exactly 234 characters; verified with Python 3.14.3"]
    - [cwr_doc_has_replacement,
       combinations_with_replacement.__doc__.__contains__,
       ["replacement"],
       true,
       "itertools.combinations_with_replacement.__doc__.__contains__('replacement') == True — the docstring mentions 'replacement' in describing successive repeats; __contains__('replacement') returns True; verified with Python 3.14.3"]
    - [cwr_doc_has_successive,
       combinations_with_replacement.__doc__.__contains__,
       ["successive"],
       true,
       "itertools.combinations_with_replacement.__doc__.__contains__('successive') == True — the docstring says 'Return successive r-length combinations'; 'successive' is present; __contains__('successive') returns True; verified with Python 3.14.3"]
    - [cwr_doc_has_iterable,
       combinations_with_replacement.__doc__.__contains__,
       ["iterable"],
       true,
       "itertools.combinations_with_replacement.__doc__.__contains__('iterable') == True — the docstring refers to 'elements in the iterable'; 'iterable' is present; __contains__('iterable') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: zip_longest and product __doc__ checks
#
# zip_longest.__doc__.__contains__('None')      == True
# zip_longest.__doc__.__contains__('fillvalue') == True
# product.__doc__.__contains__('product')       == True
# product.__doc__.__contains__('Cartesian')     == True
# ---------------------------------------------------------------------------

table itertools_extra211.zip_longest_and_product_doc:
  description: "itertools zip_longest and product __doc__ checks in iterchain211zp namespace — zip_longest docstring mentions 'None' (the default fillvalue when iterables are exhausted) and 'fillvalue' (the parameter name); product docstring mentions 'product' and 'Cartesian' (describing Cartesian product); all four __contains__ checks return True; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc_checks
  id_prefix: iterchain211zp

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_doc_has_none,
       zip_longest.__doc__.__contains__,
       ["None"],
       true,
       "itertools.zip_longest.__doc__.__contains__('None') == True — the zip_longest docstring mentions 'None' as the default fillvalue when iterables of different lengths are zipped; __contains__('None') returns True; verified with Python 3.14.3"]
    - [zip_longest_doc_has_fillvalue,
       zip_longest.__doc__.__contains__,
       ["fillvalue"],
       true,
       "itertools.zip_longest.__doc__.__contains__('fillvalue') == True — the zip_longest docstring documents the 'fillvalue' parameter used to pad shorter iterables; __contains__('fillvalue') returns True; verified with Python 3.14.3"]
    - [product_doc_has_product,
       product.__doc__.__contains__,
       ["product"],
       true,
       "itertools.product.__doc__.__contains__('product') == True — the product docstring mentions 'product' in describing Cartesian product computation; __contains__('product') returns True; verified with Python 3.14.3"]
    - [product_doc_has_cartesian,
       product.__doc__.__contains__,
       ["Cartesian"],
       true,
       "itertools.product.__doc__.__contains__('Cartesian') == True — the product docstring describes computing the Cartesian product of input iterables; 'Cartesian' is present; __contains__('Cartesian') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra211
# ---------------------------------------------------------------------------

invariant itertools_extra211.islice_dict_has_doc:
  description: "itertools.islice.__dict__.__contains__('__doc__') == True — islice is a C-level type with a docstring in its class dict; new to extra211; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: islice.__dict__.__contains__
  args: ["__doc__"]
  expected: true

invariant itertools_extra211.islice_dict_len:
  description: "itertools.islice.__dict__.__len__() == 6 — the islice class dict has exactly 6 entries: __new__, __getattribute__, __iter__, __next__, __doc__, __module__; new to extra211; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: islice.__dict__.__len__
  args: []
  expected: 6

invariant itertools_extra211.combinations_with_replacement_doc_len:
  description: "itertools.combinations_with_replacement.__doc__.__len__() == 234 — the docstring has exactly 234 characters; new to extra211; verified with Python 3.14.3"
  category: doc_checks
  kind: python_call_eq
  function: combinations_with_replacement.__doc__.__len__
  args: []
  expected: 234

invariant itertools_extra211.zip_longest_doc_has_none:
  description: "itertools.zip_longest.__doc__.__contains__('None') == True — the docstring mentions 'None' as the default fillvalue; new to extra211; verified with Python 3.14.3"
  category: doc_checks
  kind: python_call_eq
  function: zip_longest.__doc__.__contains__
  args: ["None"]
  expected: true

invariant itertools_extra211.product_doc_has_product:
  description: "itertools.product.__doc__.__contains__('product') == True — the product docstring mentions 'product' in describing the Cartesian product operation; new to extra211; verified with Python 3.14.3"
  category: doc_checks
  kind: python_call_eq
  function: product.__doc__.__contains__
  args: ["product"]
  expected: true

invariant itertools_extra211.chain_dict_has_from_iterable:
  description: "itertools.chain.__dict__.__contains__('from_iterable') == True — chain.from_iterable is a class method defined in chain's class dict; new to extra211; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["from_iterable"]
  expected: true

invariant itertools_extra211.chain_dict_len:
  description: "itertools.chain.__dict__.__len__() == 8 — the chain class dict has exactly 8 entries: __new__, __getattribute__, __iter__, __next__, from_iterable, __class_getitem__, __doc__, __module__; new to extra211; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: chain.__dict__.__len__
  args: []
  expected: 8

invariant itertools_extra211.zip_longest_doc_has_fillvalue:
  description: "itertools.zip_longest.__doc__.__contains__('fillvalue') == True — the docstring documents the fillvalue parameter; new to extra211; verified with Python 3.14.3"
  category: doc_checks
  kind: python_call_eq
  function: zip_longest.__doc__.__contains__
  args: ["fillvalue"]
  expected: true
