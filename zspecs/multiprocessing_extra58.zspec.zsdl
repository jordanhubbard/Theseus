spec: multiprocessing_extra58
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/importlib.html#importlib.machinery.SourceFileLoader — SourceFileLoader documentation"
    - "https://docs.python.org/3/reference/import.html#module-spec — ModuleSpec documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/_bootstrap_external.py"
    - "CPython source: Lib/importlib/_bootstrap_external.py"
  notes:
    - "This spec extends multiprocessing_extra57.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__.__class__.__name__/__qualname__ tables (extra52), Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__name__=='function', ProcessError/AuthenticationError/__class__.__name__=='type' (extra45), Process/__class__.__module__=='builtins', current_process/__class__.__module__=='builtins', cpu_count/__class__.__module__=='builtins' (extra46), Pool/__doc__/__class__/__module__=='builtins' (extra50), Pool/__class__.__name__=='type' (multiprocessing_extra), Pool/active_children/ProcessError/AuthenticationError __class__.__module__.__eq__('builtins') (extra53), Process/__init__.__class__.__name__.__eq__('function') (extra53), Process/Pool __repr__.__class__.__name__ (extra54), Process __weakref__.__class__.__name__ (extra54), ProcessError/AuthenticationError exception __repr__.__class__.__name__ (extra54), mp.__all__.__class__.__name__.__eq__('list') (extra55), mp.__all__.__len__()==37 (extra55), Process/ProcessError/AuthenticationError __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra55), mp.__all__.__contains__ membership checks (extra56), mp.__package__.__eq__('multiprocessing') (extra56), Queue/Pool __doc__.__class__.__name__.__eq__('str') (extra56), __loader__.__class__.__name__.__eq__('SourceFileLoader') (extra57), __spec__.__class__.__name__.__eq__('ModuleSpec') (extra57), __file__.__class__.__name__.__eq__('str') (extra57), __cached__.__class__.__name__.__eq__('str') (extra57)."
    - "This spec covers (mpspec58 namespace): wave 226 theme — __spec__.origin values + __spec__.submodule_search_locations checks + __loader__.__name__ length checks. multiprocessing.__loader__.__class__.__name__.__len__() == 16 — len('SourceFileLoader') == 16. multiprocessing.__spec__.origin.__class__.__name__.__eq__('str') — the origin is the file path to multiprocessing/__init__.py; it is a plain str. multiprocessing.__spec__.submodule_search_locations.__class__.__name__.__eq__('list') — multiprocessing IS a package; submodule_search_locations is NOT None; __class__.__name__ == 'list' in Python 3.14.3. multiprocessing.__spec__.has_location == True — True for file-based packages. No prior multiprocessing spec has captured these checks."
    - "multiprocessing.__loader__.__class__.__name__.__len__() == 16. 'SourceFileLoader' has 16 characters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__spec__.origin.__class__.__name__ == 'str'. The spec origin is the absolute path to multiprocessing/__init__.py, which is a plain Python str. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__spec__.submodule_search_locations.__class__.__name__ == 'list'. multiprocessing is a package; its submodule_search_locations is a list containing the multiprocessing package directory path. __class__.__name__ == 'list'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__spec__.has_location == True. multiprocessing is a file-based package (Lib/multiprocessing/__init__.py exists on disk); has_location is True for all SourceFileLoader-loaded modules. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing __spec__.origin + submodule_search_locations + loader
# name len — extra58
#
# Wave 226 theme: __spec__.origin values + __spec__.submodule_search_locations
# checks + __loader__.__name__ length checks.
#
# multiprocessing is a package (Lib/multiprocessing/__init__.py), so:
#   mp.__spec__.origin.__class__.__name__ == 'str'   (file path)
#   mp.__spec__.submodule_search_locations is NOT None
#   mp.__spec__.submodule_search_locations.__class__.__name__ == 'list'
#   mp.__spec__.has_location == True
#   mp.__loader__.__class__.__name__.__len__() == 16  (len of 'SourceFileLoader')
#
# No prior multiprocessing spec has captured these checks. Extra58 introduces
# the wave 226 theme in the mpspec58 namespace.
# ---------------------------------------------------------------------------

table multiprocessing_extra58.spec_origin_locations:
  description: "multiprocessing __spec__.origin + submodule_search_locations + loader name length checks in mpspec58 namespace — mp is a package (Lib/multiprocessing/__init__.py); __spec__.origin is a str (file path); submodule_search_locations is NOT None and has __class__.__name__ == 'list'; has_location is True; __loader__.__class__.__name__.__len__() == 16 for 'SourceFileLoader'; wave 226 theme: __spec__.origin values + submodule_search_locations + loader name length; first origin/locations/has_location checks in any multiprocessing spec"
  kind: python_call_eq
  category: spec_origin
  id_prefix: mpspec58

  columns: [id, function, args, expected, description]
  rows:
    - [loader_name_len,    __loader__.__class__.__name__.__len__,                   [],               16,   "mp.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters; cross-checks the __loader__.__class__.__name__.__eq__('SourceFileLoader') assertion in extra57; wave 226 first __loader__.__class__.__name__.__len__ check in any multiprocessing spec"]
    - [origin_class_name,  __spec__.origin.__class__.__name__.__eq__,               ["str"],          true, "mp.__spec__.origin.__class__.__name__ == 'str' — the spec origin is the absolute file path to multiprocessing/__init__.py; it is a plain Python str; __spec__.origin.__class__.__name__.__eq__('str') returns True; wave 226 first __spec__.origin type check in any multiprocessing spec"]
    - [locations_cls_name, __spec__.submodule_search_locations.__class__.__name__.__eq__, ["list"],   true, "mp.__spec__.submodule_search_locations.__class__.__name__ == 'list' — multiprocessing IS a package; submodule_search_locations is a list containing the multiprocessing package directory path (NOT None); __class__.__name__ == 'list' in Python 3.14.3; wave 226 first submodule_search_locations class name check in any multiprocessing spec"]
    - [has_location,       __spec__.has_location.__eq__,                            [true],           true, "mp.__spec__.has_location == True — multiprocessing is a file-based package (Lib/multiprocessing/__init__.py); SourceFileLoader sets has_location to True for all disk-backed modules; __spec__.has_location.__eq__(True) returns True; wave 226 first has_location check in any multiprocessing spec"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra58
# ---------------------------------------------------------------------------

invariant multiprocessing_extra58.loader_name_len:
  description: "mp.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters; cross-checks the string equality assertion established in extra57; wave 226 first __loader__.__class__.__name__.__len__ invariant in any multiprocessing spec"
  category: spec_origin
  kind: python_call_eq
  function: __loader__.__class__.__name__.__len__
  args: []
  expected: 16

invariant multiprocessing_extra58.origin_class_name_eq:
  description: "mp.__spec__.origin.__class__.__name__.__eq__('str') returns True — the spec origin is the absolute file path to multiprocessing/__init__.py; it is a plain Python str; wave 226 first __spec__.origin type invariant in any multiprocessing spec"
  category: spec_origin
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant multiprocessing_extra58.locations_class_name_eq:
  description: "mp.__spec__.submodule_search_locations.__class__.__name__.__eq__('list') returns True — multiprocessing IS a package; submodule_search_locations is a list (NOT None); __class__.__name__ == 'list' in Python 3.14.3; wave 226 first submodule_search_locations class name invariant in any multiprocessing spec"
  category: spec_origin
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant multiprocessing_extra58.has_location_eq:
  description: "mp.__spec__.has_location.__eq__(True) returns True — multiprocessing is a file-based package loaded by SourceFileLoader; has_location is True for all disk-backed modules; wave 226 first has_location invariant in any multiprocessing spec"
  category: spec_origin
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true
