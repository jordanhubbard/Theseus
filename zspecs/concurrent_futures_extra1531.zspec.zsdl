spec: concurrent_futures_extra1531
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "Wave 549 theme: comparison operator dict-presence checks — __lt__, __le__, __gt__, __ge__, __ne__, __eq__, __hash__ in class __dict__."
    - "concurrent.futures classes are thread/process pool primitives — not ordered or value-equality types. None of Future, Executor, ThreadPoolExecutor, or ProcessPoolExecutor define any comparison operator protocol methods in their own __dict__."
    - "concurrent.futures.Future does not define __eq__ or __hash__ — identity equality and default hashing fall through to object; two distinct Future objects with the same result are not considered equal by the Future class itself."
    - "concurrent.futures.Executor is an abstract base class with submit(), map(), shutdown() — no comparison operators."
    - "concurrent.futures.ThreadPoolExecutor inherits from Executor and adds thread pool management; no comparison operators in its own __dict__."
    - "concurrent.futures.ProcessPoolExecutor inherits from Executor and manages worker processes; no comparison operators in its own __dict__."
    - "Anchor 'true' rows confirm that domain methods ARE present: Future.result, Future.done, Executor.submit, ThreadPoolExecutor.submit, ProcessPoolExecutor.submit."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.Future comparison operator __dict__ absence
#
# concurrent.futures.Future.__dict__.__contains__('__lt__')   == False
# concurrent.futures.Future.__dict__.__contains__('__le__')   == False
# concurrent.futures.Future.__dict__.__contains__('__gt__')   == False
# concurrent.futures.Future.__dict__.__contains__('__ge__')   == False
# concurrent.futures.Future.__dict__.__contains__('__ne__')   == False
# concurrent.futures.Future.__dict__.__contains__('__eq__')   == False
# concurrent.futures.Future.__dict__.__contains__('__hash__') == False
# concurrent.futures.Future.__dict__.__contains__('result')   == True
# concurrent.futures.Future.__dict__.__contains__('done')     == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra1531.future_no_cmp_ops:
  description: "concurrent.futures.Future has no comparison operator methods in its own __dict__ — cf1531fu namespace. concurrent.futures.Future.__dict__.__contains__('__lt__')==False (Future is a thread/process result container — ordering between futures is not defined by the class; no __lt__ in __dict__); concurrent.futures.Future.__dict__.__contains__('__le__')==False (no less-than-or-equal on Future); concurrent.futures.Future.__dict__.__contains__('__gt__')==False (no greater-than on Future); concurrent.futures.Future.__dict__.__contains__('__ge__')==False (no greater-than-or-equal on Future); concurrent.futures.Future.__dict__.__contains__('__ne__')==False (Future does not override __ne__); concurrent.futures.Future.__dict__.__contains__('__eq__')==False (Future does not override __eq__ — identity equality uses object's default); concurrent.futures.Future.__dict__.__contains__('__hash__')==False (Future does not override __hash__); concurrent.futures.Future.__dict__.__contains__('result')==True (Future.result() IS defined in Future.__dict__ — blocks until the result is available and returns it); concurrent.futures.Future.__dict__.__contains__('done')==True (Future.done() IS defined in Future.__dict__ — returns True if the future completed); verified with Python 3.14.4"
  kind: python_call_eq
  category: comparison_protocol
  id_prefix: cf1531fu

  columns: [id, function, args, expected, description]
  rows:
    - [cf1531fu001, concurrent.futures.Future.__dict__.__contains__, ["__lt__"],   false, "concurrent.futures.Future.__dict__.__contains__('__lt__')==False — Future is a result container, not an ordered type; no __lt__ in __dict__; verified with Python 3.14.4"]
    - [cf1531fu002, concurrent.futures.Future.__dict__.__contains__, ["__le__"],   false, "concurrent.futures.Future.__dict__.__contains__('__le__')==False — no less-than-or-equal on Future; verified with Python 3.14.4"]
    - [cf1531fu003, concurrent.futures.Future.__dict__.__contains__, ["__gt__"],   false, "concurrent.futures.Future.__dict__.__contains__('__gt__')==False — no greater-than on Future; verified with Python 3.14.4"]
    - [cf1531fu004, concurrent.futures.Future.__dict__.__contains__, ["__ge__"],   false, "concurrent.futures.Future.__dict__.__contains__('__ge__')==False — no greater-than-or-equal on Future; verified with Python 3.14.4"]
    - [cf1531fu005, concurrent.futures.Future.__dict__.__contains__, ["__ne__"],   false, "concurrent.futures.Future.__dict__.__contains__('__ne__')==False — Future does not override __ne__; verified with Python 3.14.4"]
    - [cf1531fu006, concurrent.futures.Future.__dict__.__contains__, ["__eq__"],   false, "concurrent.futures.Future.__dict__.__contains__('__eq__')==False — Future does not override __eq__; identity equality uses object default; verified with Python 3.14.4"]
    - [cf1531fu007, concurrent.futures.Future.__dict__.__contains__, ["__hash__"], false, "concurrent.futures.Future.__dict__.__contains__('__hash__')==False — Future does not override __hash__; verified with Python 3.14.4"]
    - [cf1531fu008, concurrent.futures.Future.__dict__.__contains__, ["result"],   true,  "concurrent.futures.Future.__dict__.__contains__('result')==True — Future.result() IS defined in Future.__dict__; blocks until result is available; verified with Python 3.14.4"]
    - [cf1531fu009, concurrent.futures.Future.__dict__.__contains__, ["done"],     true,  "concurrent.futures.Future.__dict__.__contains__('done')==True — Future.done() IS defined in Future.__dict__; returns True if the future completed; verified with Python 3.14.4"]

