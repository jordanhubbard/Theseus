table concurrent_futures_extra1531.pool_executors_no_cmp_ops:
  description: "ThreadPoolExecutor and ProcessPoolExecutor have no comparison operator methods in their own __dict__ — cf1531pe namespace. ThreadPoolExecutor.__dict__.__contains__('__lt__')==False (ThreadPoolExecutor manages a pool of threads for executing callables asynchronously; no comparison operators); ThreadPoolExecutor.__dict__.__contains__('__eq__')==False (ThreadPoolExecutor does not override __eq__); ThreadPoolExecutor.__dict__.__contains__('__hash__')==False (ThreadPoolExecutor does not override __hash__); ThreadPoolExecutor.__dict__.__contains__('submit')==True (ThreadPoolExecutor.submit() IS defined in ThreadPoolExecutor.__dict__ — submits a callable to the thread pool); ProcessPoolExecutor.__dict__.__contains__('__lt__')==False (ProcessPoolExecutor manages a pool of worker processes; no ordering operators); ProcessPoolExecutor.__dict__.__contains__('__le__')==False (no less-than-or-equal on ProcessPoolExecutor); ProcessPoolExecutor.__dict__.__contains__('__gt__')==False (no greater-than on ProcessPoolExecutor); ProcessPoolExecutor.__dict__.__contains__('__ge__')==False (no greater-than-or-equal on ProcessPoolExecutor); ProcessPoolExecutor.__dict__.__contains__('__eq__')==False (ProcessPoolExecutor does not override __eq__); ProcessPoolExecutor.__dict__.__contains__('__hash__')==False (ProcessPoolExecutor does not override __hash__); ProcessPoolExecutor.__dict__.__contains__('submit')==True (ProcessPoolExecutor.submit() IS defined in ProcessPoolExecutor.__dict__ — submits work to the process pool); verified with Python 3.14.4"
  kind: python_call_eq
  category: comparison_protocol
  id_prefix: cf1531pe

  columns: [id, function, args, expected, description]
  rows:
    - [cf1531pe001, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["__lt__"],   false, "ThreadPoolExecutor.__dict__.__contains__('__lt__')==False — ThreadPoolExecutor manages thread workers; no ordering operators; verified with Python 3.14.4"]
    - [cf1531pe002, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["__eq__"],   false, "ThreadPoolExecutor.__dict__.__contains__('__eq__')==False — ThreadPoolExecutor does not override __eq__; verified with Python 3.14.4"]
    - [cf1531pe003, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["__hash__"], false, "ThreadPoolExecutor.__dict__.__contains__('__hash__')==False — ThreadPoolExecutor does not override __hash__; verified with Python 3.14.4"]
    - [cf1531pe004, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["submit"],   true,  "ThreadPoolExecutor.__dict__.__contains__('submit')==True — ThreadPoolExecutor.submit() IS defined in ThreadPoolExecutor.__dict__; submits callable to thread pool; verified with Python 3.14.4"]
    - [cf1531pe005, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__lt__"],   false, "ProcessPoolExecutor.__dict__.__contains__('__lt__')==False — ProcessPoolExecutor manages worker processes; no ordering operators; verified with Python 3.14.4"]
    - [cf1531pe006, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__le__"],   false, "ProcessPoolExecutor.__dict__.__contains__('__le__')==False — no less-than-or-equal on ProcessPoolExecutor; verified with Python 3.14.4"]
    - [cf1531pe007, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__gt__"],   false, "ProcessPoolExecutor.__dict__.__contains__('__gt__')==False — no greater-than on ProcessPoolExecutor; verified with Python 3.14.4"]
    - [cf1531pe008, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__ge__"],   false, "ProcessPoolExecutor.__dict__.__contains__('__ge__')==False — no greater-than-or-equal on ProcessPoolExecutor; verified with Python 3.14.4"]
    - [cf1531pe009, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__eq__"],   false, "ProcessPoolExecutor.__dict__.__contains__('__eq__')==False — ProcessPoolExecutor does not override __eq__; verified with Python 3.14.4"]
    - [cf1531pe010, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__hash__"], false, "ProcessPoolExecutor.__dict__.__contains__('__hash__')==False — ProcessPoolExecutor does not override __hash__; verified with Python 3.14.4"]
    - [cf1531pe011, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["submit"],   true,  "ProcessPoolExecutor.__dict__.__contains__('submit')==True — ProcessPoolExecutor.submit() IS defined in ProcessPoolExecutor.__dict__; submits callable to process pool; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1531
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra1531.future_no_lt:
  description: "concurrent.futures.Future.__dict__.__contains__('__lt__') returns False — concurrent.futures.Future does not define __lt__ in its own __dict__; Future is a thread/process pool result container whose interface consists of result(), done(), cancel(), cancelled(), running(), add_done_callback() — all result-state inspection and callback methods; no comparison operator protocol methods exist in Future.__dict__; ordering between futures is not meaningful — two futures with the same result are distinct objects and Future deliberately does not define ordering; wave 549 theme: comparison operator dict-presence checks; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: comparison_protocol
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["__lt__"]
  expected: false

invariant concurrent_futures_extra1531.executor_no_hash:
  description: "concurrent.futures.Executor.__dict__.__contains__('__hash__') returns False — concurrent.futures.Executor does not define __hash__ in its own __dict__; Executor is an abstract base class defining the pool executor protocol (submit, map, shutdown); hashing is not part of the executor interface and Executor does not override the default object.__hash__; wave 549 theme: comparison operator dict-presence checks; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: comparison_protocol
  kind: python_call_eq
  function: concurrent.futures.Executor.__dict__.__contains__
  args: ["__hash__"]
  expected: false

invariant concurrent_futures_extra1531.thread_pool_no_ne:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__ne__') returns False — ThreadPoolExecutor does not define __ne__ in its own __dict__; ThreadPoolExecutor manages a pool of worker threads via a bounded thread queue; its __dict__ contains submit() (submit callable to pool), shutdown() (wait for workers and free resources), and internal initializer helpers — no comparison operators; wave 549 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: comparison_protocol
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__dict__.__contains__
  args: ["__ne__"]
  expected: false

invariant concurrent_futures_extra1531.process_pool_no_gt:
  description: "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__gt__') returns False — ProcessPoolExecutor does not define __gt__ in its own __dict__; ProcessPoolExecutor manages a pool of worker processes for CPU-bound parallelism; its __dict__ contains submit() (dispatch work to process pool), shutdown() (clean up workers), and process management internals — no comparison operators; wave 549 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: comparison_protocol
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__dict__.__contains__
  args: ["__gt__"]
  expected: false
