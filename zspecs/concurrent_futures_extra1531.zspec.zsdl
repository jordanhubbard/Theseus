table concurrent_futures_extra1531.executor_no_cmp_ops:
  description: "concurrent.futures.Executor has no comparison operator methods in its own __dict__ — cf1531ex namespace. concurrent.futures.Executor.__dict__.__contains__('__lt__')==False (Executor is an abstract base class defining the executor interface — submit(), map(), shutdown(); no comparison operators are part of the executor protocol); concurrent.futures.Executor.__dict__.__contains__('__le__')==False (no less-than-or-equal on Executor); concurrent.futures.Executor.__dict__.__contains__('__gt__')==False (no greater-than on Executor); concurrent.futures.Executor.__dict__.__contains__('__ge__')==False (no greater-than-or-equal on Executor); concurrent.futures.Executor.__dict__.__contains__('__ne__')==False (Executor does not override __ne__); concurrent.futures.Executor.__dict__.__contains__('__eq__')==False (Executor does not override __eq__); concurrent.futures.Executor.__dict__.__contains__('__hash__')==False (Executor does not override __hash__); concurrent.futures.Executor.__dict__.__contains__('submit')==True (Executor.submit() IS defined in Executor.__dict__ — the core method for submitting work); concurrent.futures.Executor.__dict__.__contains__('map')==True (Executor.map() IS defined in Executor.__dict__ — maps a function over an iterable using the executor); verified with Python 3.14.4"
  kind: python_call_eq
  category: comparison_protocol
  id_prefix: cf1531ex

  columns: [id, function, args, expected, description]
  rows:
    - [cf1531ex001, concurrent.futures.Executor.__dict__.__contains__, ["__lt__"],   false, "concurrent.futures.Executor.__dict__.__contains__('__lt__')==False — Executor is an abstract base; no ordering operators; verified with Python 3.14.4"]
    - [cf1531ex002, concurrent.futures.Executor.__dict__.__contains__, ["__le__"],   false, "concurrent.futures.Executor.__dict__.__contains__('__le__')==False — no less-than-or-equal on Executor; verified with Python 3.14.4"]
    - [cf1531ex003, concurrent.futures.Executor.__dict__.__contains__, ["__gt__"],   false, "concurrent.futures.Executor.__dict__.__contains__('__gt__')==False — no greater-than on Executor; verified with Python 3.14.4"]
    - [cf1531ex004, concurrent.futures.Executor.__dict__.__contains__, ["__ge__"],   false, "concurrent.futures.Executor.__dict__.__contains__('__ge__')==False — no greater-than-or-equal on Executor; verified with Python 3.14.4"]
    - [cf1531ex005, concurrent.futures.Executor.__dict__.__contains__, ["__ne__"],   false, "concurrent.futures.Executor.__dict__.__contains__('__ne__')==False — Executor does not override __ne__; verified with Python 3.14.4"]
    - [cf1531ex006, concurrent.futures.Executor.__dict__.__contains__, ["__eq__"],   false, "concurrent.futures.Executor.__dict__.__contains__('__eq__')==False — Executor does not override __eq__; verified with Python 3.14.4"]
    - [cf1531ex007, concurrent.futures.Executor.__dict__.__contains__, ["__hash__"], false, "concurrent.futures.Executor.__dict__.__contains__('__hash__')==False — Executor does not override __hash__; verified with Python 3.14.4"]
    - [cf1531ex008, concurrent.futures.Executor.__dict__.__contains__, ["submit"],   true,  "concurrent.futures.Executor.__dict__.__contains__('submit')==True — Executor.submit() IS defined in Executor.__dict__; the core work-submission interface; verified with Python 3.14.4"]
    - [cf1531ex009, concurrent.futures.Executor.__dict__.__contains__, ["map"],      true,  "concurrent.futures.Executor.__dict__.__contains__('map')==True — Executor.map() IS defined in Executor.__dict__; maps a callable over an iterable via the pool; verified with Python 3.14.4"]

