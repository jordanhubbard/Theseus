spec: re_extra109
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec extends re_extra108.zspec.zsdl."
    - "This spec covers: re module flag constants (re.A/re.ASCII, re.I/re.IGNORECASE, re.M/re.MULTILINE, re.S/re.DOTALL, re.L/re.LOCALE, re.U/re.UNICODE, re.X/re.VERBOSE) class names and integer values."
    - "type(re.A).__name__ == 'RegexFlag' (all flag constants are instances of re.RegexFlag)."
    - "re.A.__class__.__module__ == 're'; re.A.__class__.__name__ == 'RegexFlag'."
    - "int(re.A) == 256; int(re.I) == 2; int(re.M) == 8; int(re.S) == 16; int(re.X) == 64."
    - "int(re.L) == 4; int(re.U) == 32."
    - "re.A == re.ASCII == True; re.I == re.IGNORECASE == True; re.M == re.MULTILINE == True; re.S == re.DOTALL == True."
    - "re.A is re.ASCII (the short alias and long name are the same object)."
    - "re.RegexFlag.__name__ == 'RegexFlag'; re.RegexFlag.__bases__[0].__name__ == 'IntFlag'."
    - "re.RegexFlag.__mro__.__len__() == 7 (RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object)."
    - "re.RegexFlag.__module__ == 're'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re flag constant class names
# re.A, re.I, re.M, re.S, re.L, re.U, re.X are all instances of re.RegexFlag.
# type(re.A).__name__ == 'RegexFlag'; re.A.__class__.__module__ == 're'.
# The long-form aliases (re.ASCII etc.) are the same objects as the short forms.
# ---------------------------------------------------------------------------

table re_extra109.flag_class_names:
  description: "re flag constants type names: re.A/re.I/re.M/re.S are RegexFlag instances; re.A.__class__.__module__='re'; re.A is re.ASCII (same object)"
  kind: python_call_eq
  category: class_names
  id_prefix: reflags109a

  columns: [id, function, args, expected, description]
  rows:
    - [flag_A_type,     "A.__class__.__name__.__eq__",         ["RegexFlag"], true,  "type(re.A).__name__ == 'RegexFlag' (re.A is an instance of re.RegexFlag)"]
    - [flag_I_type,     "I.__class__.__name__.__eq__",         ["RegexFlag"], true,  "type(re.I).__name__ == 'RegexFlag'"]
    - [flag_M_type,     "M.__class__.__name__.__eq__",         ["RegexFlag"], true,  "type(re.M).__name__ == 'RegexFlag'"]
    - [flag_S_type,     "S.__class__.__name__.__eq__",         ["RegexFlag"], true,  "type(re.S).__name__ == 'RegexFlag'"]
    - [flag_A_module,   "A.__class__.__module__.__eq__",       ["re"],        true,  "re.A.__class__.__module__ == 're' (RegexFlag is defined in the re module)"]
    - [flag_A_classname,"A.__class__.__name__.__eq__",         ["RegexFlag"], true,  "re.A.__class__.__name__ == 'RegexFlag'"]
    - [flag_A_eq_ASCII, "A.__eq__",                            ["ASCII"],     true,  "re.A == re.ASCII (the short alias and long-form name are equal RegexFlag members)"]
    - [flag_I_eq_IGNS,  "I.__eq__",                            ["IGNORECASE"],true,  "re.I == re.IGNORECASE"]
    - [flag_M_eq_MULTI, "M.__eq__",                            ["MULTILINE"], true,  "re.M == re.MULTILINE"]
    - [flag_S_eq_DOTALL,"S.__eq__",                            ["DOTALL"],    true,  "re.S == re.DOTALL"]

# ---------------------------------------------------------------------------
# re flag constant integer values
# int(re.A)==256, int(re.I)==2, int(re.M)==8, int(re.S)==16, int(re.X)==64.
# int(re.L)==4, int(re.U)==32.
# RegexFlag is an IntFlag subclass so flags can be combined with bitwise OR.
# ---------------------------------------------------------------------------

table re_extra109.flag_integer_values:
  description: "re flag integer values: A=256, I=2, M=8, S=16, X=64, L=4, U=32"
  kind: python_call_eq
  category: flag_values
  id_prefix: reflags109b

  columns: [id, function, args, expected, description]
  rows:
    - [flag_A_int,  "A.__int__",   [], 256, "int(re.A) == 256 (re.ASCII flag; large value avoids collision with single-letter flag codes)"]
    - [flag_I_int,  "I.__int__",   [], 2,   "int(re.I) == 2 (re.IGNORECASE flag)"]
    - [flag_M_int,  "M.__int__",   [], 8,   "int(re.M) == 8 (re.MULTILINE flag)"]
    - [flag_S_int,  "S.__int__",   [], 16,  "int(re.S) == 16 (re.DOTALL flag)"]
    - [flag_X_int,  "X.__int__",   [], 64,  "int(re.X) == 64 (re.VERBOSE flag)"]
    - [flag_L_int,  "L.__int__",   [], 4,   "int(re.L) == 4 (re.LOCALE flag)"]
    - [flag_U_int,  "U.__int__",   [], 32,  "int(re.U) == 32 (re.UNICODE flag)"]
    - [flag_A_ne_I, "A.__eq__",    ["I"], false, "re.A != re.I (256 != 2; ASCII and IGNORECASE are distinct flags)"]

# ---------------------------------------------------------------------------
# re.RegexFlag class identity
# RegexFlag inherits from IntFlag; mro len == 7.
# MRO: RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object.
# RegexFlag.__module__ == 're'.
# ---------------------------------------------------------------------------

table re_extra109.RegexFlag_class_identity:
  description: "re.RegexFlag class identity: __name__='RegexFlag', __module__='re', __bases__[0]='IntFlag', __mro__ len=7"
  kind: python_call_eq
  category: class_names
  id_prefix: reflags109c

  columns: [id, function, args, expected, description]
  rows:
    - [rflag_name_eq,  RegexFlag.__name__.__eq__,               ["RegexFlag"], true,  "re.RegexFlag.__name__ == 'RegexFlag'"]
    - [rflag_module_eq,RegexFlag.__module__.__eq__,              ["re"],        true,  "re.RegexFlag.__module__ == 're'"]
    - [rflag_base_eq,  "RegexFlag.__bases__[0].__name__.__eq__", ["IntFlag"],   true,  "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (RegexFlag is an IntFlag subclass, enabling bitwise flag combination)"]
    - [rflag_mro_len,  "RegexFlag.__mro__.__len__",              [],            7,     "re.RegexFlag.__mro__.__len__() == 7 (RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object)"]
    - [rflag_name_len, RegexFlag.__name__.__len__,               [],            9,     "re.RegexFlag.__name__.__len__() == 9 ('RegexFlag' has 9 characters)"]
    - [rflag_mod_not_enum, RegexFlag.__module__.__eq__,          ["enum"],      false, "re.RegexFlag.__module__ != 'enum' (RegexFlag is defined in the 're' module, though it inherits from IntFlag/Enum defined in 'enum')"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra109.A.type_is_RegexFlag:
  description: "type(re.A).__name__ == 'RegexFlag' (re.A is an instance of re.RegexFlag, an IntFlag subclass; all re flag constants — re.A/re.I/re.M/re.S/re.L/re.U/re.X — share this type)"
  category: class_names
  kind: python_call_eq
  function: "A.__class__.__name__.__eq__"
  args: ["RegexFlag"]
  expected: true

invariant re_extra109.A.int_value_256:
  description: "int(re.A) == 256 (re.ASCII/re.A has the largest integer value among the single-letter flag constants; the value 256 == 0x100 avoids bit-collision with re.I=2, re.L=4, re.M=8, re.S=16, re.U=32, re.X=64)"
  category: flag_values
  kind: python_call_eq
  function: "A.__int__"
  args: []
  expected: 256

invariant re_extra109.RegexFlag.bases_is_IntFlag:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (RegexFlag directly subclasses IntFlag from the enum module; this makes flag constants behave as integers and enables bitwise OR combination like re.I | re.M)"
  category: class_names
  kind: python_call_eq
  function: "RegexFlag.__bases__[0].__name__.__eq__"
  args: ["IntFlag"]
  expected: true

invariant re_extra109.RegexFlag.mro_len_7:
  description: "re.RegexFlag.__mro__.__len__() == 7 (RegexFlag's MRO is (RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object); the 7-entry MRO reflects RegexFlag's position as an IntFlag subclass with the full enum machinery in the hierarchy)"
  category: class_names
  kind: python_call_eq
  function: "RegexFlag.__mro__.__len__"
  args: []
  expected: 7

invariant re_extra109.A_equals_ASCII:
  description: "re.A == re.ASCII (the short flag alias re.A and the long-form re.ASCII are the same RegexFlag member with integer value 256; equality holds because they are literally the same object in the RegexFlag enumeration)"
  category: flag_values
  kind: python_call_eq
  function: "A.__eq__"
  args: ["ASCII"]
  expected: true
