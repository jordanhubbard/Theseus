spec: concurrent_futures_extra706
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor, and exception class identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra706.executor_identity:
  description: "Identity checks for concurrent.futures Future and Executor class qualnames and modules"
  kind: python_call_eq
  category: class_identity
  id_prefix: cf706ei
  columns: [id, function, args, expected]
  rows:
    - [cf706ei001, concurrent.futures.Future.__qualname__.__eq__, ["Future"], true]
    - [cf706ei002, concurrent.futures.Future.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf706ei003, concurrent.futures.Executor.__qualname__.__eq__, ["Executor"], true]
    - [cf706ei004, concurrent.futures.Executor.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf706ei005, concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__, ["ThreadPoolExecutor"], true]
    - [cf706ei006, concurrent.futures.ThreadPoolExecutor.__module__.__eq__, ["concurrent.futures.thread"], true]
    - [cf706ei007, concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__, ["ProcessPoolExecutor"], true]
    - [cf706ei008, concurrent.futures.ProcessPoolExecutor.__module__.__eq__, ["concurrent.futures.process"], true]

table concurrent_futures_extra706.exception_identity:
  description: "Identity checks for concurrent.futures exception class qualnames"
  kind: python_call_eq
  category: class_identity
  id_prefix: cf706ex
  columns: [id, function, args, expected]
  rows:
    - [cf706ex001, concurrent.futures.CancelledError.__qualname__.__eq__, ["CancelledError"], true]
    - [cf706ex002, concurrent.futures.TimeoutError.__qualname__.__eq__, ["TimeoutError"], true]
    - [cf706ex003, concurrent.futures.BrokenExecutor.__qualname__.__eq__, ["BrokenExecutor"], true]
    - [cf706ex004, concurrent.futures.InvalidStateError.__qualname__.__eq__, ["InvalidStateError"], true]
