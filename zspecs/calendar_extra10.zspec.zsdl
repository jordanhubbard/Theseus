spec: calendar_extra10
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
  notes:
    - "This spec extends calendar.zspec.zsdl and calendar_extra through calendar_extra9.zspec.zsdl."
    - "calendar_extra7 covers: Calendar.__qualname__; TextCalendar/__name__/__bases__; HTMLCalendar/__name__/__bases__; isleap; leapdays; monthrange; firstweekday; isleap/__module__; timegm/__module__."
    - "calendar_extra9 covers: TextCalendar/__module__/__qualname__; HTMLCalendar/__module__/__qualname__; setfirstweekday/__name__; firstweekday/__name__; TextCalendar/HTMLCalendar MRO lengths."
    - "NEW in extra10 — Axis 1: Calendar.__qualname__, TextCalendar.__qualname__, HTMLCalendar.__qualname__ as standalone extra10-namespace invariants."
    - "NEW in extra10 — Axis 2: Calendar.__module__ as standalone extra10-namespace invariant."
    - "NEW in extra10 — Axis 3: TextCalendar.__bases__.__getitem__(0).__name__ and HTMLCalendar.__bases__.__getitem__(0).__name__ both == 'Calendar'."
    - "NEW in extra10 — Axis 4: isleap truth-table for 2000/1900/2024/2023 — canonical leap year rule vectors not gathered together in a table in any prior spec."
    - "calendar.Calendar.__qualname__ == 'Calendar' — verified Python 3.12."
    - "calendar.TextCalendar.__qualname__ == 'TextCalendar' — verified Python 3.12."
    - "calendar.HTMLCalendar.__qualname__ == 'HTMLCalendar' — verified Python 3.12."
    - "calendar.Calendar.__module__ == 'calendar' — verified Python 3.12."
    - "calendar.TextCalendar.__bases__.__getitem__(0).__name__ == 'Calendar' — verified Python 3.12."
    - "calendar.HTMLCalendar.__bases__.__getitem__(0).__name__ == 'Calendar' — verified Python 3.12."
    - "calendar.isleap(2000) == True (divisible by 400), isleap(1900) == False (divisible by 100 not 400)."
    - "calendar.isleap(2024) == True (divisible by 4, not by 100), isleap(2023) == False (not divisible by 4)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __qualname__ — Calendar, TextCalendar, HTMLCalendar
#
# calendar_extra7 covers Calendar.__qualname__. calendar_extra9 covers
# TextCalendar.__qualname__ and HTMLCalendar.__qualname__. This spec anchors
# all three together as standalone invariants in the extra10 namespace.
# ---------------------------------------------------------------------------

invariant calendar_extra10.Calendar.qualname:
  description: "calendar.Calendar.__qualname__ == 'Calendar' — flat qualname for module-level class"
  category: class_qualnames
  kind: python_call_eq
  function: Calendar.__qualname__.__eq__
  args: ["Calendar"]
  expected: true

invariant calendar_extra10.TextCalendar.qualname:
  description: "calendar.TextCalendar.__qualname__ == 'TextCalendar' — flat qualname for module-level class"
  category: class_qualnames
  kind: python_call_eq
  function: TextCalendar.__qualname__.__eq__
  args: ["TextCalendar"]
  expected: true

invariant calendar_extra10.HTMLCalendar.qualname:
  description: "calendar.HTMLCalendar.__qualname__ == 'HTMLCalendar' — flat qualname for module-level class"
  category: class_qualnames
  kind: python_call_eq
  function: HTMLCalendar.__qualname__.__eq__
  args: ["HTMLCalendar"]
  expected: true

# ---------------------------------------------------------------------------
# Calendar.__module__
#
# calendar_extra7 covers Calendar.__module__ == 'calendar' as part of a broader
# check. This spec anchors it as a standalone extra10-namespace invariant.
# ---------------------------------------------------------------------------

invariant calendar_extra10.Calendar.module:
  description: "calendar.Calendar.__module__ == 'calendar'"
  category: class_modules
  kind: python_call_eq
  function: Calendar.__module__.__eq__
  args: ["calendar"]
  expected: true

# ---------------------------------------------------------------------------
# TextCalendar and HTMLCalendar inherit from Calendar
#
# Both TextCalendar and HTMLCalendar have Calendar as their first (and only
# direct) base class. Verified via __bases__.__getitem__(0).__name__.
# calendar_extra7 checks __bases__[0].__name__ for TextCalendar and HTMLCalendar
# implicitly via __name__ coverage; this provides an explicit table.
# ---------------------------------------------------------------------------

table calendar_extra10.bases_parent:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [TextCalendar,  TextCalendar.__bases__.__getitem__,  [0], __name__.__eq__, ["Calendar"], true]
    - [HTMLCalendar,  HTMLCalendar.__bases__.__getitem__,  [0], __name__.__eq__, ["Calendar"], true]

# ---------------------------------------------------------------------------
# isleap truth-table — 2000, 1900, 2024, 2023
#
# The four canonical leap-year rule test cases:
#   2000: divisible by 400 → True
#   1900: divisible by 100 but not 400 → False
#   2024: divisible by 4, not by 100 → True
#   2023: not divisible by 4 → False
# Prior specs verify individual isleap calls scattered across specs.
# This table gathers all four canonical cases in one extra10-namespace block.
# ---------------------------------------------------------------------------

table calendar_extra10.isleap_vectors:
  kind: python_call_eq
  category: behavioral
  id_prefix: isleap

  columns: [id, function, args, expected]
  rows:
    - [year_2000, isleap, [2000], true]
    - [year_1900, isleap, [1900], false]
    - [year_2024, isleap, [2024], true]
    - [year_2023, isleap, [2023], false]
