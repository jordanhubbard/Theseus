spec: math_extra22
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl and prior extras through math_extra21.zspec.zsdl."
    - "math_extra20 covers __qualname__ for floor/ceil/sqrt as standalone invariants; __module__ table for floor/ceil/sqrt/log/gcd/isfinite/isinf/isnan/factorial/fabs."
    - "math_extra21 covers __qualname__ for log/gcd/lcm/isnan/isinf in a table."
    - "No prior spec covers __qualname__ for sin/cos/tan/atan2/hypot/degrees/radians."
    - "math.sin.__qualname__ == 'sin' — top-level C builtin qualname equals __name__."
    - "math.cos.__qualname__ == 'cos' — top-level C builtin qualname equals __name__."
    - "math.tan.__qualname__ == 'tan' — top-level C builtin qualname equals __name__."
    - "math.atan2.__qualname__ == 'atan2' — top-level C builtin qualname equals __name__."
    - "math.hypot.__qualname__ == 'hypot' — top-level C builtin qualname equals __name__."
    - "math.degrees.__qualname__ == 'degrees' — top-level C builtin qualname equals __name__."
    - "math.radians.__qualname__ == 'radians' — top-level C builtin qualname equals __name__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# math trig and angle-conversion function __qualname__ table
#
# math_extra20 confirmed __qualname__ for floor/ceil/sqrt (standalone invariants).
# math_extra21 confirmed __qualname__ for log/gcd/lcm/isnan/isinf in a table.
# No prior spec covers __qualname__ for the trigonometric functions sin/cos/tan/
# atan2/hypot or the angle-conversion functions degrees/radians. For C builtins
# at module level, __qualname__ always equals __name__. This table anchors that
# invariant for the remaining representative set of math functions.
# ---------------------------------------------------------------------------

table math_extra22.trig_qualnames:
  description: "__qualname__ == function name for math trig and angle-conversion builtins"
  kind: python_call_eq
  category: function_identity
  id_prefix: mqn22

  columns: [id, function, args, expected]
  rows:
    - [sin,     sin.__qualname__.__eq__,     ["sin"],     true]
    - [cos,     cos.__qualname__.__eq__,     ["cos"],     true]
    - [tan,     tan.__qualname__.__eq__,     ["tan"],     true]
    - [atan2,   atan2.__qualname__.__eq__,   ["atan2"],   true]
    - [hypot,   hypot.__qualname__.__eq__,   ["hypot"],   true]
    - [degrees, degrees.__qualname__.__eq__, ["degrees"], true]
    - [radians, radians.__qualname__.__eq__, ["radians"], true]
