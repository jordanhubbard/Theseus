spec: uuid_extra1231
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid.__dict__.__contains__ for top-level module attributes: UUID, uuid1, uuid3, uuid4, uuid5, NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500, RFC_4122, SafeUUID, RESERVED_NCS; also __dict__ class identity and module name attrs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1231.module_dict_contains_classes_and_functions:
  description: "uuid.__dict__.__contains__ checks for UUID class and uuid generation function names"
  kind: python_call_eq
  category: module_dict_contains_classes_and_functions
  id_prefix: uu1231cf
  columns: [id, function, args, expected]
  rows:
    - [uu1231cf001, uuid.__dict__.__contains__,                    ["UUID"],                      true]
    - [uu1231cf002, uuid.__dict__.__contains__,                    ["uuid1"],                     true]
    - [uu1231cf003, uuid.__dict__.__contains__,                    ["uuid3"],                     true]
    - [uu1231cf004, uuid.__dict__.__contains__,                    ["uuid4"],                     true]
    - [uu1231cf005, uuid.__dict__.__contains__,                    ["uuid5"],                     true]
    - [uu1231cf006, uuid.__dict__.__class__.__name__.__eq__,       ["dict"],                      true]
    - [uu1231cf007, uuid.__dict__.__class__.__qualname__.__eq__,   ["dict"],                      true]
    - [uu1231cf008, uuid.__dict__.__class__.__module__.__eq__,     ["builtins"],                  true]
    - [uu1231cf009, uuid.__dict__.__class__.__name__.__class__.__name__.__eq__, ["str"],          true]

table uuid_extra1231.module_dict_contains_namespaces_and_constants:
  description: "uuid.__dict__.__contains__ checks for NAMESPACE_* constants, RFC_4122, SafeUUID, and RESERVED_NCS"
  kind: python_call_eq
  category: module_dict_contains_namespaces_and_constants
  id_prefix: uu1231nc
  columns: [id, function, args, expected]
  rows:
    - [uu1231nc001, uuid.__dict__.__contains__,                    ["NAMESPACE_DNS"],              true]
    - [uu1231nc002, uuid.__dict__.__contains__,                    ["NAMESPACE_URL"],              true]
    - [uu1231nc003, uuid.__dict__.__contains__,                    ["NAMESPACE_OID"],              true]
    - [uu1231nc004, uuid.__dict__.__contains__,                    ["NAMESPACE_X500"],             true]
    - [uu1231nc005, uuid.__dict__.__contains__,                    ["RFC_4122"],                   true]
    - [uu1231nc006, uuid.__dict__.__contains__,                    ["SafeUUID"],                   true]
    - [uu1231nc007, uuid.__dict__.__contains__,                    ["RESERVED_NCS"],               true]
    - [uu1231nc008, uuid.__dict__.__class__.__module__.__class__.__name__.__eq__, ["str"],         true]
    - [uu1231nc009, uuid.__dict__.__class__.__qualname__.__class__.__name__.__eq__, ["str"],       true]

table uuid_extra1231.module_name_and_package_attrs:
  description: "uuid module __name__, __package__, and standard dunder attrs via __dict__.__contains__ and direct attribute access"
  kind: python_call_eq
  category: module_name_and_package_attrs
  id_prefix: uu1231np
  columns: [id, function, args, expected]
  rows:
    - [uu1231np001, uuid.__dict__.__contains__,                    ["__name__"],                   true]
    - [uu1231np002, uuid.__dict__.__contains__,                    ["__doc__"],                    true]
    - [uu1231np003, uuid.__dict__.__contains__,                    ["__package__"],                true]
    - [uu1231np004, uuid.__dict__.__contains__,                    ["__spec__"],                   true]
    - [uu1231np005, uuid.__name__.__eq__,                          ["uuid"],                       true]
    - [uu1231np006, uuid.__name__.__class__.__name__.__eq__,       ["str"],                        true]
    - [uu1231np007, uuid.__package__.__eq__,                       [""],                           true]
    - [uu1231np008, uuid.__package__.__class__.__name__.__eq__,    ["str"],                        true]
    - [uu1231np009, uuid.__dict__.__contains__,                    ["__builtins__"],               true]
