spec: gensim_rust
version: ">=3.9"
backend: rust_module(gensim_rust)

docs: https://radimrehurek.com/gensim/apiref.html

provenance:
  derived_from:
    - "https://radimrehurek.com/gensim/apiref.html — Gensim API"
  not_derived_from:
    - "gensim source: gensim/corpora/dictionary.py"
  notes:
    - "Gensim provides topic modeling and NLP utilities."
    - "Dictionary([['hello','world'],['hello','python']]).num_docs == 2."
    - "Dictionary([['a','b'],['c']]).num_pos == 3 — total tokens."
    - "len(Dictionary([['a','b'],['c']])) == 3 — unique tokens."
    - "Dictionary([['a','b'],['a']]).token2id['a'] is an int."
    - "Expose gensim_num_docs(docs) -> int: Dictionary(docs).num_docs."
    - "Expose gensim_num_unique(docs) -> int: len(Dictionary(docs))."
    - "All test vectors verified against gensim 4.3.3."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# gensim_num_docs — number of documents in dictionary
table gensim_rust.dictionary.num_docs:
  kind: python_call_eq
  category: num_docs
  id_prefix: gsm_nd
  function: gensim_num_docs

  columns: [id, args, expected]
  rows:
    - [two,   [[["hello", "world"], ["hello", "python"]]], 2]
    - [three, [[["a"], ["b"], ["c"]]],                     3]
    - [one,   [[["x", "y", "z"]]],                         1]

# gensim_num_unique — unique token count
table gensim_rust.dictionary.num_unique:
  kind: python_call_eq
  category: num_unique
  id_prefix: gsm_nu
  function: gensim_num_unique

  columns: [id, args, expected]
  rows:
    - [three,  [[["a", "b"], ["c"]]],         3]
    - [two,    [[["a", "b"], ["a", "b"]]],    2]
    - [one,    [[["x"], ["x"], ["x"]]],       1]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:13:47Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
