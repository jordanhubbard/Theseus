spec: math_extra_rust
version: ">=3.9"
backend: rust_module(math_extra_rust)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math documentation"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "Clean-room Rust reimplementation of Python math module extra functions, exposed via PyO3."
    - "math.gcd(a, b) returns the greatest common divisor."
    - "math.lcm(a, b) returns the least common multiple (Python 3.9+)."
    - "math.prod(iterable) returns product of all elements (Python 3.8+)."
    - "math.comb(n, k) returns number of ways to choose k from n (n choose k)."
    - "math.perm(n, k) returns number of k-permutations of n items."
    - "math.isfinite(x) returns True if x is finite (not inf or nan)."
    - "math.isinf(x) returns True if x is positive or negative infinity."
    - "math.isnan(x) returns True if x is Not a Number (NaN)."
    - "gcd(48, 64) == 16; gcd(7, 13) == 1; gcd(0, 5) == 5."
    - "lcm(4, 6) == 12; lcm(3, 5) == 15."
    - "prod([1,2,3,4,5]) == 120; prod([]) == 1."
    - "comb(5, 2) == 10; perm(5, 2) == 20."
    - "isfinite(1.0) == True; isinf(1.0) == False; isnan(0.0) == False."
    - "All test vectors verified against Python 3.14.3 math module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# gcd — greatest common divisor
table math_extra_rust.gcd.vectors:
  kind: python_call_eq
  category: gcd
  id_prefix: gcd
  function: gcd

  columns: [id, args, expected]
  rows:
    - [basic,  [48, 64], 16]
    - [primes, [7, 13],   1]
    - [zero,   [0, 5],    5]
    - [same,   [6, 6],    6]

# lcm — least common multiple (Python 3.9+)
table math_extra_rust.lcm.vectors:
  kind: python_call_eq
  category: lcm
  id_prefix: lcm
  function: lcm

  columns: [id, args, expected]
  rows:
    - [basic,  [4, 6],  12]
    - [primes, [3, 5],  15]
    - [same,   [6, 6],   6]
    - [one,    [1, 7],   7]

# prod — product of iterable (Python 3.8+)
table math_extra_rust.prod.vectors:
  kind: python_call_eq
  category: prod
  id_prefix: prod
  function: prod

  columns: [id, args, expected]
  rows:
    - [five_fact, [[1, 2, 3, 4, 5]], 120]
    - [single,    [[7]],               7]
    - [empty,     [[]],                1]
    - [squares,   [[1, 4, 9]],        36]

# comb — binomial coefficient (n choose k)
table math_extra_rust.comb.vectors:
  kind: python_call_eq
  category: comb
  id_prefix: comb
  function: comb

  columns: [id, args, expected]
  rows:
    - [five_two, [5, 2],  10]
    - [ten_zero, [10, 0],  1]
    - [five_all, [5, 5],   1]
    - [four_two, [4, 2],   6]

# perm — k-permutations of n items
table math_extra_rust.perm.vectors:
  kind: python_call_eq
  category: perm
  id_prefix: perm
  function: perm

  columns: [id, args, expected]
  rows:
    - [five_two,  [5, 2], 20]
    - [five_zero, [5, 0],  1]
    - [four_one,  [4, 1],  4]

# isfinite, isinf, isnan — float classification
table math_extra_rust.isfinite.vectors:
  kind: python_call_eq
  category: isfinite
  id_prefix: isfinite
  function: isfinite

  columns: [id, args, expected]
  rows:
    - [one,  [1.0], true]
    - [zero, [0.0], true]
    - [neg,  [-3.14], true]

table math_extra_rust.isinf.vectors:
  kind: python_call_eq
  category: isinf
  id_prefix: isinf
  function: isinf

  columns: [id, args, expected]
  rows:
    - [one,  [1.0], false]
    - [zero, [0.0], false]

table math_extra_rust.isnan.vectors:
  kind: python_call_eq
  category: isnan
  id_prefix: isnan
  function: isnan

  columns: [id, args, expected]
  rows:
    - [zero, [0.0],  false]
    - [one,  [1.5],  false]
    - [neg,  [-1.0], false]

