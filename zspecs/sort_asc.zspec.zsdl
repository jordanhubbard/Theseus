spec: sort_asc
version: ">=0.2.0"
backend: node(sort-asc)

docs: https://www.npmjs.com/package/sort-asc

provenance:
  derived_from:
    - "sort-asc README — https://www.npmjs.com/package/sort-asc"
    - "Test vectors verified with sort-asc via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "sort-asc source"
  notes:
    - "sort-asc is an npm package. Install: npm install sort-asc"
    - "String comparator function for ascending sort. Returns -1, 0, or 1."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns -1, 0, or 1."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table sort_asc.compare:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: sortasc

  columns: [id, args, expected]
  rows:
    - [less,   ["apple", "banana"],  -1]
    - [greater, ["banana", "apple"],  1]
    - [equal,  ["a", "a"],           0]
