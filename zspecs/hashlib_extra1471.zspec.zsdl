spec: hashlib_extra1471
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "https://docs.python.org/3/library/_hashlib.html — CPython _hashlib C extension documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra1456.zspec.zsdl — covers __contains__ and __iter__ for HASH and HASHXOF"
    - "hashlib_extra1441.zspec.zsdl — covers __subclasshook__/__instancecheck__ for HASH and HASHXOF"
    - "hashlib_extra1426.zspec.zsdl — covers __init_subclass__ and __subclasses__ for HASH and HASHXOF"
  notes:
    - "Wave 545 theme: __len__ and __getitem__ method presence and type checks."
    - "_hashlib.HASH is the C-level type for standard hash objects (md5, sha256, etc.)."
    - "_hashlib.HASHXOF is the C-level type for extendable-output functions (shake_128, shake_256)."
    - "_hashlib.HASH does not define __len__ or __getitem__ in its own __dict__ — hash objects are not sequences."
    - "_hashlib.HASHXOF does not define __len__ or __getitem__ in its own __dict__ — XOF objects are not sequences."
    - "hasattr(_hashlib.HASH, '__len__') == False — no length protocol anywhere in the MRO."
    - "hasattr(_hashlib.HASH, '__getitem__') == False — no subscript protocol anywhere in the MRO."
    - "list.__len__.__class__.__name__ == 'wrapper_descriptor' — reference type for sequences."
    - "list.__getitem__.__class__.__name__ == 'method_descriptor' — reference type for sequence indexing."
    - "The absence of __len__ and __getitem__ distinguishes HASH from sequence types like list, tuple, and bytes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _hashlib.HASH — __len__ and __getitem__ absence checks
#
# Wave 545 theme: HASH objects are not sequences; neither __len__ nor
# __getitem__ is present in HASH.__dict__ or anywhere in the MRO. This table
# confirms the absence and also verifies that known HASH methods are present,
# ensuring the __dict__ lookup mechanism is functioning correctly.
# ---------------------------------------------------------------------------

table hashlib_extra1471.HASH_len_getitem:
  description: "_hashlib.HASH has no __len__ or __getitem__ — HASH is not a sequence type; neither method appears in HASH.__dict__; wave 545 __len__/__getitem__ absence theme; hl1471lg anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl1471lg

  columns: [id, function, args, expected, description]
  rows:
    - [hl1471lg001, "_hashlib.HASH.__dict__.__contains__", ["__len__"],      false, "_hashlib.HASH.__dict__ does not contain '__len__' — HASH is not a sized sequence"]
    - [hl1471lg002, "_hashlib.HASH.__dict__.__contains__", ["__getitem__"],  false, "_hashlib.HASH.__dict__ does not contain '__getitem__' — HASH does not support subscript indexing"]
    - [hl1471lg003, "_hashlib.HASH.__dict__.__contains__", ["digest"],       true,  "_hashlib.HASH.__dict__ contains 'digest' — confirms __dict__ lookup works correctly on HASH"]
    - [hl1471lg004, "_hashlib.HASH.__dict__.__contains__", ["hexdigest"],    true,  "_hashlib.HASH.__dict__ contains 'hexdigest' — confirms __dict__ lookup works correctly on HASH"]
    - [hl1471lg005, "_hashlib.HASH.__dict__.__contains__", ["update"],       true,  "_hashlib.HASH.__dict__ contains 'update' — confirms __dict__ lookup works correctly on HASH"]
    - [hl1471lg006, "_hashlib.HASH.__dict__.__contains__", ["digest_size"],  true,  "_hashlib.HASH.__dict__ contains 'digest_size' — HASH exposes digest byte length, not a sequence length"]

# ---------------------------------------------------------------------------
# _hashlib.HASHXOF — __len__ and __getitem__ absence checks
#
# HASHXOF is the XOF (extendable-output function) type backing shake_128 and
# shake_256. Like HASH, it is not a sequence and has neither __len__ nor
# __getitem__ in its __dict__. HASHXOF does expose digest_size and block_size
# as attributes, but those are properties of the hash algorithm, not a sequence
# length or item accessor.
# ---------------------------------------------------------------------------

table hashlib_extra1471.HASHXOF_len_getitem:
  description: "_hashlib.HASHXOF has no __len__ or __getitem__ — HASHXOF is not a sequence type; neither method appears in HASHXOF.__dict__; wave 545 theme continued; hl1471xf anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl1471xf

  columns: [id, function, args, expected, description]
  rows:
    - [hl1471xf001, "_hashlib.HASHXOF.__dict__.__contains__", ["__len__"],      false, "_hashlib.HASHXOF.__dict__ does not contain '__len__' — HASHXOF is not a sized sequence"]
    - [hl1471xf002, "_hashlib.HASHXOF.__dict__.__contains__", ["__getitem__"],  false, "_hashlib.HASHXOF.__dict__ does not contain '__getitem__' — HASHXOF does not support subscript indexing"]
    - [hl1471xf003, "_hashlib.HASHXOF.__dict__.__contains__", ["digest"],       true,  "_hashlib.HASHXOF.__dict__ contains 'digest' — confirms __dict__ lookup works correctly on HASHXOF"]
    - [hl1471xf004, "_hashlib.HASHXOF.__dict__.__contains__", ["hexdigest"],    true,  "_hashlib.HASHXOF.__dict__ contains 'hexdigest' — confirms __dict__ lookup works correctly on HASHXOF"]
    - [hl1471xf005, "_hashlib.HASHXOF.__dict__.__contains__", ["update"],       true,  "_hashlib.HASHXOF.__dict__ contains 'update' — confirms __dict__ lookup works correctly on HASHXOF"]
    - [hl1471xf006, "_hashlib.HASHXOF.__dict__.__contains__", ["copy"],         true,  "_hashlib.HASHXOF.__dict__ contains 'copy' — confirms __dict__ lookup works correctly on HASHXOF"]

# ---------------------------------------------------------------------------
# HASH vs list symmetry — HASH lacks sequence protocol that list has
#
# list defines both __len__ (wrapper_descriptor) and __getitem__
# (method_descriptor). This table anchors the contrast: HASH.__dict__ is
# absent for both, while list's descriptor type names confirm the expected
# reference values. Row pairs demonstrate the asymmetry explicitly.
# ---------------------------------------------------------------------------

table hashlib_extra1471.HASH_vs_list_protocol:
  description: "_hashlib.HASH lacks __len__/__getitem__ that list provides — list.__len__ is 'wrapper_descriptor', list.__getitem__ is 'method_descriptor'; HASH has neither; contrast confirms HASH is not a sequence; wave 545 hl1471vs anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl1471vs

  columns: [id, function, args, expected, description]
  rows:
    - [hl1471vs001, "_hashlib.HASH.__dict__.__contains__",       ["__len__"],            false, "_hashlib.HASH.__dict__ does not contain '__len__' — contrast with list which defines __len__"]
    - [hl1471vs002, "_hashlib.HASH.__dict__.__contains__",       ["__getitem__"],        false, "_hashlib.HASH.__dict__ does not contain '__getitem__' — contrast with list which defines __getitem__"]
    - [hl1471vs003, "list.__len__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true,  "list.__len__.__class__.__name__ == 'wrapper_descriptor' — reference value that HASH does NOT have"]
    - [hl1471vs004, "list.__getitem__.__class__.__name__.__eq__", ["method_descriptor"], true,  "list.__getitem__.__class__.__name__ == 'method_descriptor' — reference value that HASH does NOT have"]
    - [hl1471vs005, "_hashlib.HASH.__name__.__eq__",             ["HASH"],               true,  "_hashlib.HASH.__name__ == 'HASH' — confirms we are testing the correct C-level type"]
    - [hl1471vs006, "_hashlib.HASHXOF.__name__.__eq__",          ["HASHXOF"],            true,  "_hashlib.HASHXOF.__name__ == 'HASHXOF' — confirms we are testing the correct C-level XOF type"]
