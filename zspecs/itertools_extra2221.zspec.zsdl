spec: itertools_extra2221
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2221: identity/display protocol dict-presence — __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__."
    - "All itertools types are C extension types defined in Modules/itertoolsmodule.c. Their __dict__ is a mappingproxy."
    - "itertools.count and itertools.repeat each define __repr__ in their own __dict__; all other itertools types do NOT define __repr__ in their __dict__."
    - "None of the itertools C extension types define __hash__, __str__, __qualname__, or __name__ in their __dict__."
    - "All itertools types define __doc__ and __module__ in their own __dict__."
    - "__module__ for itertools C types is 'itertools', confirming the defining module."
    - "__qualname__ and __name__ are never in a class __dict__ for C extension types — they are type-level attributes from the metaclass (type)."
    - "itertools.pairwise was added in Python 3.10; it also defines __doc__ and __module__ but not __repr__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table itertools_extra2221.chain_identity_display:
  description: "itertools.chain dict-presence for identity/display protocol: __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2221

  columns: [id, function, args, expected]
  rows:
    - ["it2221001", "itertools.chain.__dict__.__contains__", ["__hash__"], false]
    - ["it2221002", "itertools.chain.__dict__.__contains__", ["__repr__"], false]
    - ["it2221003", "itertools.chain.__dict__.__contains__", ["__str__"], false]
    - ["it2221004", "itertools.chain.__dict__.__contains__", ["__doc__"], true]
    - ["it2221005", "itertools.chain.__dict__.__contains__", ["__module__"], true]
    - ["it2221006", "itertools.chain.__dict__.__contains__", ["__qualname__"], false]
    - ["it2221007", "itertools.chain.__dict__.__contains__", ["__name__"], false]

