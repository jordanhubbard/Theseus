spec: js_yaml
version: ">=4.1.0"
backend: node(js-yaml)

docs: https://github.com/nodeca/js-yaml#readme

provenance:
  derived_from:
    - "js-yaml README — https://github.com/nodeca/js-yaml#readme"
    - "YAML 1.2 specification — https://yaml.org/spec/1.2.2/"
    - "Test vectors verified with js-yaml via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "js-yaml source"
  notes:
    - "js-yaml is an npm package. Install: npm install js-yaml"
    - "Usage: const yaml = require('js-yaml'); yaml.load(yamlString) -> object; yaml.dump(object) -> yamlString."
    - "load() parses one document; loadAll() parses multi-document streams (not covered here)."
    - "dump() output ends with a trailing newline."
    - "js-yaml is the canonical YAML parser for Node.js (#46 most-depended-upon)."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "load(s) returns the parsed JS value (object/array/scalar); dump(v) returns a YAML string."
  stderr: "null"
  stickiness: "N/A — each call is independent."
  codes: {}

# ── load() — YAML → JS value ────────────────────────────────────────────────

table js_yaml.load:
  kind: node_module_call_eq
  category: load
  function: load
  id_prefix: load

  columns: [id, args, expected]
  rows:
    - [string_value,    ["foo: bar"],                          {foo: "bar"}]
    - [two_keys,        ["a: 1\nb: 2"],                         {a: 1, b: 2}]
    - [list_of_strings, ["items:\n  - x\n  - y"],               {items: ["x", "y"]}]
    - [bool_true,       ["value: true"],                        {value: true}]
    - [bool_false,      ["value: false"],                       {value: false}]
    - [float_value,     ["val: 42.5"],                          {val: 42.5}]
    - [null_explicit,   ["null_val: null"],                     {null_val: null}]
    - [nested_object,   ["nested:\n  key: value"],              {nested: {key: "value"}}]
    - [explicit_null,   ["null"],                                ~]
    - [tilde_null,      ["~"],                                   ~]
    - [scalar_int,      ["42"],                                  42]
    - [scalar_string,   ["hello"],                               "hello"]
    - [inline_list,     ["[1, 2, 3]"],                           [1, 2, 3]]
    - [inline_map,      ["{a: 1, b: 2}"],                        {a: 1, b: 2}]

# ── dump() — JS value → YAML ────────────────────────────────────────────────

table js_yaml.dump:
  kind: node_module_call_eq
  category: dump
  function: dump
  id_prefix: dump

  columns: [id, args, expected]
  rows:
    - [single_pair,    [{foo: "bar"}],                           "foo: bar\n"]
    - [sorted_keys,    [{a: 1, b: 2}, {sortKeys: true}],         "a: 1\nb: 2\n"]
    - [boolean,        [{flag: true}],                            "flag: true\n"]
    - [list_safe_strings, [{items: ["xx", "yy"]}],                "items:\n  - xx\n  - yy\n"]
    - [number,         [{count: 42}],                             "count: 42\n"]
    - [yaml11_alias_quoted,
                       [{n: 42}],
                       "'n': 42\n",
                       {description: "js-yaml v4 quotes single-letter keys that would parse as YAML 1.1 boolean aliases (y/Y/n/N/yes/no)"}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:48:42Z
  iterations: 2
  pass_count: 20
  fail_count: 0
  total_invariants: 20
  notes: Synthesis succeeded in 2 iteration(s). 20 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
