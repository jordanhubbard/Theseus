spec: ms
version: ">=2.0.0"
backend: node(ms)

docs: https://www.npmjs.com/package/ms

provenance:
  derived_from:
    - "ms README — https://www.npmjs.com/package/ms"
    - "Test vectors verified with ms@2.1.3 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "ms source"
  notes:
    - "ms exports a function directly as module.exports."
    - "ms(string) converts a time string to milliseconds."
    - "ms(number) converts milliseconds to a short time string."
    - "Supported units: ms, s, m, h, d, w, y."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns number (from string) or string (from number)."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table ms.ms:
  kind: node_module_call_eq
  function: ~
  category: ms
  id_prefix: ms

  columns: [id, args, expected]
  rows:
    - [seconds,    ["2s"],       2000]
    - [minutes,    ["1m"],       60000]
    - [hours,      ["1h"],       3600000]
    - [days,       ["2d"],       172800000]
    - [ms_to_str,  [60000],      "1m"]
    - [ms_small,   [1000],       "1s"]
    - [ms_hours,   [3600000],    "1h"]
