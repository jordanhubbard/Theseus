spec: ms
version: ">=2.0.0"
backend: node(ms)

docs: https://github.com/vercel/ms#readme

provenance:
  derived_from:
    - "ms README — https://github.com/vercel/ms#readme"
    - "Test vectors verified with ms@2.1.3 via Node.js 22.20.0 on macOS/Darwin 25.4.0, 2026-04-08"
    - "ms source: index.js — ms() routing between parse and format branches (MIT; source inspection permitted)"
  not_derived_from:
    - "ms source: internal regex patterns"
  notes:
    - "ms exports the ms() function directly as the module default export. Invariants use function: ~ (null) to call the module itself."
    - "Number inputs → human-readable string. String inputs → milliseconds as a number."
    - "Rounding: ms() rounds to the nearest whole unit. 1500 ms rounds to '2s', 500 ms stays '500ms'."
    - "The {long: true} option returns verbose English strings: '1 second', '2 seconds', etc."
    - "Zero ms: ms(0) returns '0ms'."
    - "ms does not expose a version property; version invariant is omitted."
  created_at: "2026-04-08T00:00:00Z"

error_model:
  semantics: "ms does not throw for normal numeric or string inputs. node exits 0 for all invariants in this spec."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# number → string (short format)
# ---------------------------------------------------------------------------

table ms.format.short:
  kind: node_module_call_eq
  function: ~
  id_prefix: fmt

  columns: [id, category, args, expected]
  rows:
    - [zero_ms,     zero,        [0],       "0ms"]
    - [one_ms,      sub_second,  [1],       "1ms"]
    - [hundred_ms,  sub_second,  [100],     "100ms"]
    - [five_hundred_ms, sub_second, [500],  "500ms"]
    - [one_second,  seconds,     [1000],    "1s"]
    - [two_seconds, seconds,     [2000],    "2s"]
    - [one_minute,  minutes,     [60000],   "1m"]
    - [one_hour,    hours,       [3600000], "1h"]
    - [one_day,     days,        [86400000],"1d"]

# ---------------------------------------------------------------------------
# string → number (parse)
# ---------------------------------------------------------------------------

table ms.parse:
  kind: node_module_call_eq
  function: ~
  id_prefix: parse

  columns: [id, category, args, expected]
  rows:
    - [parse_500ms, sub_second, ["500ms"], 500]
    - [parse_1s,    seconds,    ["1s"],    1000]
    - [parse_1dot5s, seconds,   ["1.5s"],  1500]
    - [parse_2m,    minutes,    ["2m"],    120000]
    - [parse_1h,    hours,      ["1h"],    3600000]
    - [parse_1d,    days,       ["1d"],    86400000]

# ---------------------------------------------------------------------------
# number → string (long format, {long: true})
# ---------------------------------------------------------------------------

table ms.format.long:
  kind: node_module_call_eq
  function: ~
  id_prefix: long

  columns: [id, category, args, expected]
  rows:
    - [long_1s,  seconds, [1000,    {long: true}], "1 second"]
    - [long_2s,  seconds, [2000,    {long: true}], "2 seconds"]
    - [long_1m,  minutes, [60000,   {long: true}], "1 minute"]
    - [long_1h,  hours,   [3600000, {long: true}], "1 hour"]
    - [long_1d,  days,    [86400000,{long: true}], "1 day"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-04-15T08:25:26Z
  iterations: 1
  pass_count: 20
  fail_count: 0
  total_invariants: 20
  notes: Synthesis succeeded in 1 iteration(s). 20 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
