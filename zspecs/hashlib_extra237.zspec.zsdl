spec: hashlib_extra237
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "NIST FIPS 180-4 — Secure Hash Standard (SHS)"

provenance:
  derived_from:
    - "NIST FIPS 180-4 — Secure Hash Standard (SHS)"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra235.zspec.zsdl — covers HASH method qualnames and hash object .name attribute"
    - "hashlib_extra236.zspec.zsdl — covers hmac.HMAC class identity and method qualnames"
    - "_hashlib.zspec.zsdl — covers _hashlib C extension identity"
    - "hashlib_extra.zspec.zsdl — covers sha256 __name__/__qualname__ and algorithms_available"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.sha256(b'').hexdigest() == 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855' — NIST known test vector for SHA-256 of empty input."
    - "hashlib.sha256(b'abc').hexdigest() == 'ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad' — NIST known test vector for SHA-256 of b'abc'."
    - "hashlib.sha256(b'hello').hexdigest() == '2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824' — well-known SHA-256 test vector."
    - "hashlib.md5(b'').hexdigest() == 'd41d8cd98f00b204e9800998ecf8427e' — RFC 1321 known vector for MD5 of empty input."
    - "hashlib.md5(b'hello').hexdigest() == '5d41402abc4b2a76b9719d911017c592' — well-known MD5 test vector."
    - "hashlib.sha1(b'').hexdigest() == 'da39a3ee5e6b4b0d3255bfef95601890afd80709' — NIST known vector for SHA-1 of empty input."
    - "hashlib.sha256(b'').hexdigest().__len__() == 64 — SHA-256 produces 32 bytes = 64 hex characters."
    - "hashlib.md5(b'').hexdigest().__len__() == 32 — MD5 produces 16 bytes = 32 hex characters."
    - "hashlib.sha1(b'').hexdigest().__len__() == 40 — SHA-1 produces 20 bytes = 40 hex characters."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SHA-256 known test vector contracts — hexdigest equality
#
# hashlib.sha256(b'').hexdigest()    == 'e3b0c44298fc1c149afbf4c8996fb924...'
# hashlib.sha256(b'abc').hexdigest() == 'ba7816bf8f01cfea414140de5dae2223...'
# hashlib.sha256(b'hello').hexdigest() == '2cf24dba5fb0a30e26e83b2ac5b9e29e...'
#
# These are the standard NIST FIPS 180-4 test vectors for SHA-256. No prior
# spec in hashlib_extra* covers the actual hexdigest() output value for any
# SHA-256 input — prior specs cover only name, digest_size, block_size, and
# method qualnames. These are novel known-answer test (KAT) contracts.
# ---------------------------------------------------------------------------

table hashlib_extra237.sha256_hexdigest_vectors:
  description: "sha256(b'').hexdigest()==NIST empty vector; sha256(b'abc').hexdigest()==NIST abc vector; sha256(b'hello').hexdigest()==known vector; SHA-256 known test vector contracts; new to hashlib_extra237"
  kind: python_call_eq
  category: hash_vectors
  id_prefix: hl237sha256

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_empty_hexdigest,
       "sha256(b'').hexdigest.__eq__",
       ["e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"],
       true,
       "hashlib.sha256(b'').hexdigest().__eq__('e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855') == True — NIST FIPS 180-4 test vector for SHA-256 of empty byte string; 64 hex characters representing 32 bytes; novel hexdigest value anchor; new to hashlib_extra237 namespace; verified Python 3.14.3"]
    - [sha256_abc_hexdigest,
       "sha256(b'abc').hexdigest.__eq__",
       ["ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"],
       true,
       "hashlib.sha256(b'abc').hexdigest().__eq__('ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad') == True — NIST FIPS 180-4 test vector for SHA-256 of b'abc' (3 bytes); novel hexdigest value anchor; new to hashlib_extra237 namespace; verified Python 3.14.3"]
    - [sha256_hello_hexdigest,
       "sha256(b'hello').hexdigest.__eq__",
       ["2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824"],
       true,
       "hashlib.sha256(b'hello').hexdigest().__eq__('2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824') == True — well-known SHA-256 test vector for b'hello' (5 bytes); novel hexdigest value anchor; new to hashlib_extra237 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# MD5 known test vector contracts — hexdigest equality
#
# hashlib.md5(b'').hexdigest()    == 'd41d8cd98f00b204e9800998ecf8427e'
# hashlib.md5(b'hello').hexdigest() == '5d41402abc4b2a76b9719d911017c592'
#
# These are the standard RFC 1321 test vectors for MD5. MD5 produces a
# 16-byte (128-bit) digest, represented as 32 hex characters. Novel contracts.
# ---------------------------------------------------------------------------

table hashlib_extra237.md5_hexdigest_vectors:
  description: "md5(b'').hexdigest()==RFC1321 empty vector; md5(b'hello').hexdigest()==known vector; MD5 known test vector contracts; new to hashlib_extra237"
  kind: python_call_eq
  category: hash_vectors
  id_prefix: hl237md5

  columns: [id, function, args, expected, description]
  rows:
    - [md5_empty_hexdigest,
       "md5(b'').hexdigest.__eq__",
       ["d41d8cd98f00b204e9800998ecf8427e"],
       true,
       "hashlib.md5(b'').hexdigest().__eq__('d41d8cd98f00b204e9800998ecf8427e') == True — RFC 1321 test vector for MD5 of empty byte string; 32 hex characters representing 16 bytes; novel hexdigest value anchor; new to hashlib_extra237 namespace; verified Python 3.14.3"]
    - [md5_hello_hexdigest,
       "md5(b'hello').hexdigest.__eq__",
       ["5d41402abc4b2a76b9719d911017c592"],
       true,
       "hashlib.md5(b'hello').hexdigest().__eq__('5d41402abc4b2a76b9719d911017c592') == True — well-known MD5 test vector for b'hello' (5 bytes); 32 hex characters representing 16 bytes; novel hexdigest value anchor; new to hashlib_extra237 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# SHA-1 known test vector contracts — hexdigest equality
#
# hashlib.sha1(b'').hexdigest() == 'da39a3ee5e6b4b0d3255bfef95601890afd80709'
#
# NIST FIPS 180-4 test vector for SHA-1 of empty input. SHA-1 produces a
# 20-byte (160-bit) digest, represented as 40 hex characters. Novel contract.
# ---------------------------------------------------------------------------

invariant hashlib_extra237.sha1_empty_hexdigest:
  description: "hashlib.sha1(b'').hexdigest().__eq__('da39a3ee5e6b4b0d3255bfef95601890afd80709') == True — NIST FIPS 180-4 test vector for SHA-1 of empty byte string; 40 hex characters representing 20 bytes; no prior hashlib spec anchors this value; hashlib_extra237 is the first namespace to anchor sha1 empty hexdigest as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_vectors
  kind: python_call_eq
  function: "sha1(b'').hexdigest.__eq__"
  args: ["da39a3ee5e6b4b0d3255bfef95601890afd80709"]
  expected: true

# ---------------------------------------------------------------------------
# hexdigest length contracts — digest_size * 2
#
# sha256 hexdigest has 64 hex characters (digest_size=32, 32*2=64).
# md5 hexdigest has 32 hex characters (digest_size=16, 16*2=32).
# sha1 hexdigest has 40 hex characters (digest_size=20, 20*2=40).
#
# These length contracts are novel — no prior spec anchors hexdigest().__len__().
# ---------------------------------------------------------------------------

table hashlib_extra237.hexdigest_lengths:
  description: "sha256 hexdigest len==64; md5 hexdigest len==32; sha1 hexdigest len==40; hexdigest length equals digest_size*2; new to hashlib_extra237"
  kind: python_call_eq
  category: hash_lengths
  id_prefix: hl237len

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_hexdigest_len,
       "sha256(b'').hexdigest().__len__",
       [],
       64,
       "hashlib.sha256(b'').hexdigest().__len__() == 64 — SHA-256 digest_size is 32 bytes; hexdigest encodes as 2 hex chars per byte giving 64 characters total; novel length anchor; new to hashlib_extra237 namespace; verified Python 3.14.3"]
    - [md5_hexdigest_len,
       "md5(b'').hexdigest().__len__",
       [],
       32,
       "hashlib.md5(b'').hexdigest().__len__() == 32 — MD5 digest_size is 16 bytes; hexdigest encodes as 32 hex characters; novel length anchor; new to hashlib_extra237 namespace; verified Python 3.14.3"]
    - [sha1_hexdigest_len,
       "sha1(b'').hexdigest().__len__",
       [],
       40,
       "hashlib.sha1(b'').hexdigest().__len__() == 40 — SHA-1 digest_size is 20 bytes; hexdigest encodes as 40 hex characters; novel length anchor; new to hashlib_extra237 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra237.sha256_empty_hexdigest:
  description: "hashlib.sha256(b'').hexdigest().__eq__('e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855') == True — SHA-256 of the empty byte string is the canonical zero-content hash defined in NIST FIPS 180-4; the 64-character hex string represents 32 bytes (256 bits); this is a fundamental known-answer test (KAT) vector; no prior hashlib spec in the hashlib_extra* namespace anchors any hexdigest() output value; hashlib_extra237 is the first namespace to anchor sha256 empty hexdigest as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_vectors
  kind: python_call_eq
  function: "sha256(b'').hexdigest.__eq__"
  args: ["e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"]
  expected: true

invariant hashlib_extra237.sha256_hexdigest_len_64:
  description: "hashlib.sha256(b'').hexdigest().__len__() == 64 — SHA-256 always produces exactly 32 bytes of digest output; hexdigest() encodes each byte as exactly 2 lowercase hex characters, giving 64 characters total; this length is fixed for all SHA-256 inputs regardless of input length; digest_size==32 is the source of truth; 64 == 32 * 2; no prior spec anchors sha256 hexdigest length; hashlib_extra237 is the first namespace to anchor this as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_lengths
  kind: python_call_eq
  function: "sha256(b'').hexdigest().__len__"
  args: []
  expected: 64

invariant hashlib_extra237.md5_empty_hexdigest:
  description: "hashlib.md5(b'').hexdigest().__eq__('d41d8cd98f00b204e9800998ecf8427e') == True — MD5 of the empty byte string is the canonical zero-content MD5 hash defined in RFC 1321; the 32-character hex string represents 16 bytes (128 bits); MD5 digest_size is 16; this is a well-known KAT vector frequently used in interoperability testing; hashlib_extra237 is the first namespace to anchor md5 empty hexdigest as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_vectors
  kind: python_call_eq
  function: "md5(b'').hexdigest.__eq__"
  args: ["d41d8cd98f00b204e9800998ecf8427e"]
  expected: true
