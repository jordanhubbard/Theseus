spec: pp3196
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 660 (pp3196): __pow__, __lshift__, __rshift__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "No pathlib class defines __pow__ in its own __dict__: path objects do not support the exponentiation operator."
    - "No pathlib class defines __lshift__ in its own __dict__: path objects do not support the left-shift operator."
    - "No pathlib class defines __rshift__ in its own __dict__: path objects do not support the right-shift operator."
    - "Contrast with wave 659 where pathlib.PurePath.__truediv__ was True (path joining via /); __pow__, __lshift__, and __rshift__ are not defined on PurePath or any subclass."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __pow__ dict-presence — operator.contains(Cls.__dict__, '__pow__')
#
# No pathlib class defines __pow__ in its own __dict__; all false.
# pathlib types represent immutable filesystem paths; exponentiation is not
# supported. Contrast with __truediv__ (wave 659) which PurePath does define.
# ---------------------------------------------------------------------------

table pp3196.pow:
  description: "pathlib types __pow__ dict-presence checks; wave 660"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3196

  columns: [id, function, args, expected]
  rows:
    - ["pp3196001", operator.contains, [pathlib.PurePath.__dict__,         "__pow__"], false]
    - ["pp3196002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__pow__"], false]
    - ["pp3196003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__pow__"], false]
    - ["pp3196004", operator.contains, [pathlib.Path.__dict__,             "__pow__"], false]
    - ["pp3196005", operator.contains, [pathlib.PosixPath.__dict__,        "__pow__"], false]

# ---------------------------------------------------------------------------
