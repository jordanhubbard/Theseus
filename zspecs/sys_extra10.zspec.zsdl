spec: sys_extra10
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
  notes:
    - "This spec extends sys.zspec.zsdl and prior extras through sys_extra9.zspec.zsdl."
    - "sys_extra9 covers: float_info.radix==2; float_info.rounds==1; hash_info.inf==314159; hash_info.nan==0; int_info.bits_per_digit==30; int_info.sizeof_digit==4; version_info.releaselevel class name; implementation.cache_tag class name and prefix."
    - "No prior sys spec covers sys.maxsize or sys.maxunicode."
    - "No prior sys spec covers sys.builtin_module_names class name or membership."
    - "No prior sys spec covers sys.prefix, sys.exec_prefix, or sys.executable class names."
    - "No prior sys spec covers sys.getdefaultencoding() return value."
    - "No prior sys spec covers sys.getrecursionlimit() positivity."
    - "No prior sys spec covers sys.hash_info.imag or sys.hash_info.algorithm."
    - "No prior sys spec covers sys.thread_info.name class name."
    - "No prior sys spec covers sys.version.startswith('3.')."
    - "sys.maxsize == 9223372036854775807 on 64-bit platforms (2**63 - 1)."
    - "sys.maxunicode == 1114111 — the maximum Unicode code point (U+10FFFF), constant across all CPython builds."
    - "sys.builtin_module_names is a tuple; 'sys' and 'builtins' are always present."
    - "sys.prefix, sys.exec_prefix, sys.executable are all str."
    - "sys.getdefaultencoding() == 'utf-8' — CPython 3.x always defaults to UTF-8."
    - "sys.getrecursionlimit() > 0 — the recursion limit is always a positive integer."
    - "sys.hash_info.imag == 1000003 — the hash multiplier for the imaginary part of complex numbers."
    - "sys.hash_info.algorithm == 'siphash13' on modern CPython (CPython 3.11+)."
    - "sys.thread_info.name.__class__.__name__ == 'str' — thread backend name is always a str."
    - "sys.version.startswith('3.') == True — version string always begins with the major version '3.'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sys.maxsize — the maximum value of a Py_ssize_t
#
# No prior sys spec covers sys.maxsize. On all 64-bit CPython builds this is
# 2**63 - 1 == 9223372036854775807. It is always a positive int.
# ---------------------------------------------------------------------------

invariant sys_extra10.maxsize.is_int:
  description: "sys.maxsize.__class__.__name__ == 'int' — maxsize is always an int"
  category: constants
  kind: python_call_eq
  function: maxsize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant sys_extra10.maxsize.positive:
  description: "sys.maxsize > 0 — maxsize is always a large positive integer"
  category: constants
  kind: python_call_eq
  function: maxsize.__gt__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# sys.maxunicode — maximum Unicode code point
#
# No prior sys spec covers sys.maxunicode. Since Python 3.3 this is always
# 1114111 (U+10FFFF) on all platforms — CPython uses UCS-4 / PEP 393.
# ---------------------------------------------------------------------------

invariant sys_extra10.maxunicode.eq_1114111:
  description: "sys.maxunicode == 1114111 — the maximum Unicode code point (U+10FFFF)"
  category: constants
  kind: python_call_eq
  function: maxunicode.__eq__
  args: [1114111]
  expected: true

invariant sys_extra10.maxunicode.is_int:
  description: "sys.maxunicode.__class__.__name__ == 'int' — maxunicode is always an int"
  category: constants
  kind: python_call_eq
  function: maxunicode.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# sys.builtin_module_names — type and known members
#
# No prior sys spec covers sys.builtin_module_names. It is a tuple of str
# naming the C extension modules compiled into the interpreter. 'sys' and
# 'builtins' are always present.
# ---------------------------------------------------------------------------

invariant sys_extra10.builtin_module_names.is_tuple:
  description: "sys.builtin_module_names.__class__.__name__ == 'tuple'"
  category: constants
  kind: python_call_eq
  function: builtin_module_names.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant sys_extra10.builtin_module_names.contains_sys:
  description: "sys.builtin_module_names.__contains__('sys') == True"
  category: constants
  kind: python_call_eq
  function: builtin_module_names.__contains__
  args: ["sys"]
  expected: true

invariant sys_extra10.builtin_module_names.contains_builtins:
  description: "sys.builtin_module_names.__contains__('builtins') == True"
  category: constants
  kind: python_call_eq
  function: builtin_module_names.__contains__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# sys.prefix, sys.exec_prefix, sys.executable — type checks
#
# No prior sys spec covers these three path-like attributes. All are str.
# ---------------------------------------------------------------------------

table sys_extra10.path_attr_types:
  kind: python_call_eq
  category: attributes
  id_prefix: pat

  columns: [id, function, args, expected]
  rows:
    - [prefix,      prefix.__class__.__name__.__eq__,      ["str"], true]
    - [exec_prefix, exec_prefix.__class__.__name__.__eq__, ["str"], true]
    - [executable,  executable.__class__.__name__.__eq__,  ["str"], true]

# ---------------------------------------------------------------------------
# sys.getdefaultencoding() — return value
#
# No prior sys spec covers sys.getdefaultencoding(). CPython always returns
# 'utf-8' on Python 3.x (set at startup and not changeable at runtime).
# ---------------------------------------------------------------------------

invariant sys_extra10.getdefaultencoding.eq_utf8:
  description: "sys.getdefaultencoding() == 'utf-8' — CPython 3 always uses UTF-8 as the default encoding"
  category: functions
  kind: python_call_eq
  function: getdefaultencoding
  args: []
  expected: "utf-8"

# ---------------------------------------------------------------------------
# sys.getrecursionlimit() — positivity bound
#
# No prior sys spec covers sys.getrecursionlimit(). The default is 1000 but
# can be changed; regardless of the value it is always a positive int.
# ---------------------------------------------------------------------------

invariant sys_extra10.getrecursionlimit.positive:
  description: "sys.getrecursionlimit() > 0 — recursion limit is always a positive integer"
  category: functions
  kind: python_call_eq
  function: getrecursionlimit
  args: []
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# sys.hash_info.imag and sys.hash_info.algorithm — new fields not yet covered
#
# sys_extra8 covers hash_info.modulus/width bounds.
# sys_extra9 covers hash_info.inf and hash_info.nan.
# No prior spec covers hash_info.imag (the imaginary-part hash multiplier)
# or hash_info.algorithm (the name of the hash algorithm).
# ---------------------------------------------------------------------------

invariant sys_extra10.hash_info.imag_eq_1000003:
  description: "sys.hash_info.imag == 1000003 — hash multiplier for the imaginary part of complex numbers"
  category: hash_info
  kind: python_call_eq
  function: hash_info.imag.__eq__
  args: [1000003]
  expected: true

invariant sys_extra10.hash_info.algorithm_is_str:
  description: "sys.hash_info.algorithm.__class__.__name__ == 'str' — algorithm name is always a str"
  category: hash_info
  kind: python_call_eq
  function: hash_info.algorithm.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# sys.thread_info.name — type check
#
# sys_extra7 covers thread_info.__class__.__qualname__.
# No prior spec checks thread_info.name or its class.
# thread_info.name is the name of the threading library (e.g. 'pthread').
# ---------------------------------------------------------------------------

invariant sys_extra10.thread_info.name_is_str:
  description: "sys.thread_info.name.__class__.__name__ == 'str' — thread backend name is always a str"
  category: thread_info
  kind: python_call_eq
  function: thread_info.name.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# sys.version — startswith check
#
# sys_extra2/extra4 cover sys.version.__class__.__name__ == 'str'.
# No prior spec checks that sys.version starts with '3.' (the major version).
# ---------------------------------------------------------------------------

invariant sys_extra10.version.startswith_3:
  description: "sys.version.startswith('3.') == True — version string always begins with '3.'"
  category: attributes
  kind: python_call_eq
  function: version.startswith
  args: ["3."]
  expected: true
