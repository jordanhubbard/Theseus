spec: re_extra503
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re.Match object methods and attributes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers re.Match method __name__ identity and descriptor attribute __class__.__name__ checks"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra503.match_method_names:
  description: "re.Match method __name__ identity checks"
  kind: python_call_eq
  category: method_identity
  id_prefix: remt

  columns: [id, function, args, expected]
  rows:
    - [remt001, re.Match.group.__name__.__eq__, ["group"], true]
    - [remt002, re.Match.groups.__name__.__eq__, ["groups"], true]
    - [remt003, re.Match.groupdict.__name__.__eq__, ["groupdict"], true]
    - [remt004, re.Match.start.__name__.__eq__, ["start"], true]
    - [remt005, re.Match.end.__name__.__eq__, ["end"], true]
    - [remt006, re.Match.span.__name__.__eq__, ["span"], true]
    - [remt007, re.Match.expand.__name__.__eq__, ["expand"], true]

table re_extra503.match_descriptor_types:
  description: "re.Match descriptor attribute __class__.__name__ checks"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: remd

  columns: [id, function, args, expected]
  rows:
    - [remd001, re.Match.string.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [remd002, re.Match.re.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [remd003, re.Match.pos.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [remd004, re.Match.endpos.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [remd005, re.Match.lastindex.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [remd006, re.Match.lastgroup.__class__.__name__.__eq__, ["getset_descriptor"], true]
