spec: rxjs
version: ">=7.0.0"
backend: node(rxjs)

docs: https://rxjs.dev

provenance:
  derived_from:
    - "RxJS docs — https://rxjs.dev"
    - "Test vectors verified with rxjs via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "rxjs source"
  notes:
    - "Reactive Extensions for JavaScript — Observable, Subject, BehaviorSubject, ReplaySubject, AsyncSubject."
    - "Install: npm install rxjs"
    - "v7 CJS; named exports include Observable, Subject, BehaviorSubject, ReplaySubject, AsyncSubject, of, from, etc."
    - "Subject mutators (.next, .complete) return undefined — chained reads use {tap: true}."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Subject methods throw if called after .complete(); subscribe never throws synchronously."
  stderr: "null"
  stickiness: "N/A — each instance independent."
  codes: {}

invariant rxjs.behavior_subject_initial_value:
  description: "new BehaviorSubject(42).getValue() returns 42"
  category: BehaviorSubject
  kind: node_chain_eq
  entry: constructor
  class: BehaviorSubject
  entry_args: [42]
  chain:
    - {method: getValue, args: []}
  expected: 42

invariant rxjs.behavior_subject_next_then_get:
  description: "BehaviorSubject.next(v) then getValue() returns v"
  category: BehaviorSubject
  kind: node_chain_eq
  entry: constructor
  class: BehaviorSubject
  entry_args: [0]
  chain:
    - {method: next, args: [99], tap: true}
    - {method: getValue, args: []}
  expected: 99

invariant rxjs.behavior_subject_initial_string:
  description: "new BehaviorSubject('hello').getValue() is 'hello'"
  category: BehaviorSubject
  kind: node_chain_eq
  entry: constructor
  class: BehaviorSubject
  entry_args: ["hello"]
  chain:
    - {method: getValue, args: []}
  expected: "hello"

invariant rxjs.observable_class_present:
  description: "Observable is exported as a class"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Observable.constructor.name"}
  expected: "Function"

invariant rxjs.subject_is_function:
  description: "Subject is exported as a constructor (Function)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Subject.constructor.name"}
  expected: "Function"

invariant rxjs.replay_subject_is_function:
  description: "ReplaySubject is exported as a constructor (Function)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "ReplaySubject.constructor.name"}
  expected: "Function"

invariant rxjs.async_subject_is_function:
  description: "AsyncSubject is exported as a constructor (Function)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "AsyncSubject.constructor.name"}
  expected: "Function"

invariant rxjs.of_is_function:
  description: "of() creator is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "of.constructor.name"}
  expected: "Function"

invariant rxjs.behavior_subject_closed_initially_false:
  description: "Fresh BehaviorSubject.closed is false"
  category: BehaviorSubject
  kind: node_chain_eq
  entry: constructor
  class: BehaviorSubject
  entry_args: [0]
  chain:
    - {get: closed}
  expected: false

invariant rxjs.behavior_subject_isStopped_after_complete:
  description: "BehaviorSubject.complete() then .isStopped is true (.closed remains false until unsubscribe)"
  category: BehaviorSubject
  kind: node_chain_eq
  entry: constructor
  class: BehaviorSubject
  entry_args: [0]
  chain:
    - {method: complete, args: [], tap: true}
    - {get: isStopped}
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:23:44Z
  iterations: 1
  pass_count: 10
  fail_count: 0
  total_invariants: 10
  notes: Synthesis succeeded in 1 iteration(s). 10 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
