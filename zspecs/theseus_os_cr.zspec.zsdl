spec: theseus_os_cr
version: ">=3.0"
backend: python_cleanroom(theseus_os_cr)
blocks: os

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/os.html"
  not_derived_from:
    - "CPython source: Lib/os.py"
  notes:
    - "Clean-room os module. Do NOT import os."

error_model: python_exceptions

invariant theseus_os_cr.os2_getcwd:
  description: "getcwd() returns a non-empty string"
  category: behavior
  kind: python_call_eq
  function: os2_getcwd
  args: []
  expected: true

invariant theseus_os_cr.os2_environ:
  description: "environ is a dict-like mapping"
  category: behavior
  kind: python_call_eq
  function: os2_environ
  args: []
  expected: true

invariant theseus_os_cr.os2_path:
  description: "os.path functions work correctly"
  category: behavior
  kind: python_call_eq
  function: os2_path
  args: []
  expected: true
