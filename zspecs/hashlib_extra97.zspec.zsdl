spec: hashlib_extra97
version: ">=3.9"
extends: hashlib_extra96
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / hashlib.new __qualname__/__module__/co_argcount cross-checks / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__.__eq__('__hash_new') / new/__code__/co_name.__eq__ / new/__code__/co_argcount.__eq__(1) / new/__module__.__eq__('hashlib') / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__.__eq__ and __module__.__eq__('_hashlib') (table + invariants)."
    - "hashlib_extra94.zspec.zsdl — covers hashlib.algorithms_available/algorithms_guaranteed set class identity and membership / sha256/sha512/sha1/md5 constructor __class__.__name__=='builtin_function_or_method' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra96; it does NOT duplicate invariants present in those files."
    - "Wave 257 theme: hashlib.algorithms_guaranteed membership for specific algorithm name strings + hashlib.new __qualname__ length."
    - "'sha256' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha512' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha1' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'md5' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha224' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha384' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha3_256' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha3_512' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha3_224' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha3_384' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'blake2b' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'blake2s' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'shake_128' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'shake_256' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha256' in hashlib.algorithms_available == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha512' in hashlib.algorithms_available == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha256_224' in hashlib.algorithms_guaranteed == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha2' in hashlib.algorithms_guaranteed == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__qualname__ == '__hash_new'. len('__hash_new') == 10. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# 'sha256' in hashlib.algorithms_guaranteed == True
# 'sha512' in hashlib.algorithms_guaranteed == True
# 'sha1'   in hashlib.algorithms_guaranteed == True
# 'md5'    in hashlib.algorithms_guaranteed == True
# 'sha224' in hashlib.algorithms_guaranteed == True
# 'sha384' in hashlib.algorithms_guaranteed == True
#
# Wave 257 theme: core SHA and MD5 algorithms in algorithms_guaranteed.
#
# The six most common digest algorithms — sha256, sha512, sha1, md5, sha224,
# sha384 — are all present in hashlib.algorithms_guaranteed. They are
# OpenSSL-backed and guaranteed across all Python platforms. No prior hashlib
# spec anchors algorithms_guaranteed.__contains__ row-by-row for these six
# together under hashlibalgmembership97. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra97.core_sha_md5_in_algorithms_guaranteed:
  description: "'sha256' in algorithms_guaranteed.__contains__==True / 'sha512'.__contains__==True / 'sha1'.__contains__==True / 'md5'.__contains__==True / 'sha224'.__contains__==True / 'sha384'.__contains__==True — sha256/sha512/sha1/md5/sha224/sha384 are all in algorithms_guaranteed (OpenSSL-backed, guaranteed on every Python platform); no prior hashlib spec anchors these six membership tests together under hashlibalgmembership97; first hashlibalgmembership97 anchor for core SHA/MD5 algorithms_guaranteed membership"
  kind: python_call_eq
  category: module_identity
  id_prefix: hashlibalgmembership97

  columns: [id, function, args, expected]
  rows:
    - [sha256_in_guaranteed,  algorithms_guaranteed.__contains__, ["sha256"],  true]
    - [sha512_in_guaranteed,  algorithms_guaranteed.__contains__, ["sha512"],  true]
    - [sha1_in_guaranteed,    algorithms_guaranteed.__contains__, ["sha1"],    true]
    - [md5_in_guaranteed,     algorithms_guaranteed.__contains__, ["md5"],     true]
    - [sha224_in_guaranteed,  algorithms_guaranteed.__contains__, ["sha224"],  true]
    - [sha384_in_guaranteed,  algorithms_guaranteed.__contains__, ["sha384"],  true]

# ---------------------------------------------------------------------------
# 'sha3_256' in hashlib.algorithms_guaranteed == True
# 'sha3_512' in hashlib.algorithms_guaranteed == True
# 'sha3_224' in hashlib.algorithms_guaranteed == True
# 'sha3_384' in hashlib.algorithms_guaranteed == True
#
# Wave 257 theme: SHA-3 family algorithms in algorithms_guaranteed.
#
# The four SHA-3 (Keccak-based) digest algorithms — sha3_256, sha3_512,
# sha3_224, sha3_384 — are all guaranteed in Python 3.6+. No prior hashlib
# spec anchors algorithms_guaranteed.__contains__ for the SHA-3 family together
# under hashlibalgmembership97. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra97.sha3_family_in_algorithms_guaranteed:
  description: "'sha3_256' in algorithms_guaranteed.__contains__==True / 'sha3_512'.__contains__==True / 'sha3_224'.__contains__==True / 'sha3_384'.__contains__==True — sha3_256/sha3_512/sha3_224/sha3_384 are all in algorithms_guaranteed (SHA-3/Keccak family, guaranteed from Python 3.6+); no prior hashlib spec anchors these four membership tests together under hashlibalgmembership97; first hashlibalgmembership97 anchor for SHA-3 family algorithms_guaranteed membership"
  kind: python_call_eq
  category: module_identity
  id_prefix: hashlibalgmembership97

  columns: [id, function, args, expected]
  rows:
    - [sha3_256_in_guaranteed, algorithms_guaranteed.__contains__, ["sha3_256"], true]
    - [sha3_512_in_guaranteed, algorithms_guaranteed.__contains__, ["sha3_512"], true]
    - [sha3_224_in_guaranteed, algorithms_guaranteed.__contains__, ["sha3_224"], true]
    - [sha3_384_in_guaranteed, algorithms_guaranteed.__contains__, ["sha3_384"], true]

# ---------------------------------------------------------------------------
# 'blake2b'   in hashlib.algorithms_guaranteed == True
# 'blake2s'   in hashlib.algorithms_guaranteed == True
# 'shake_128' in hashlib.algorithms_guaranteed == True
# 'shake_256' in hashlib.algorithms_guaranteed == True
#
# Wave 257 theme: BLAKE2 and SHAKE algorithms in algorithms_guaranteed.
#
# BLAKE2b, BLAKE2s (tree-hashable digests) and SHAKE-128, SHAKE-256 (XOFs —
# extendable-output functions) are all present in algorithms_guaranteed in
# Python 3.6+. No prior hashlib spec anchors these four together under
# hashlibalgmembership97. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra97.blake2_shake_in_algorithms_guaranteed:
  description: "'blake2b' in algorithms_guaranteed.__contains__==True / 'blake2s'.__contains__==True / 'shake_128'.__contains__==True / 'shake_256'.__contains__==True — blake2b/blake2s (BLAKE2 tree-hashable digests) and shake_128/shake_256 (XOFs) are all in algorithms_guaranteed (Python 3.6+); no prior hashlib spec anchors these four together under hashlibalgmembership97; first hashlibalgmembership97 anchor for BLAKE2/SHAKE algorithms_guaranteed membership"
  kind: python_call_eq
  category: module_identity
  id_prefix: hashlibalgmembership97

  columns: [id, function, args, expected]
  rows:
    - [blake2b_in_guaranteed,   algorithms_guaranteed.__contains__, ["blake2b"],   true]
    - [blake2s_in_guaranteed,   algorithms_guaranteed.__contains__, ["blake2s"],   true]
    - [shake_128_in_guaranteed, algorithms_guaranteed.__contains__, ["shake_128"], true]
    - [shake_256_in_guaranteed, algorithms_guaranteed.__contains__, ["shake_256"], true]

# ---------------------------------------------------------------------------
# hashlib.new.__qualname__.__eq__('__hash_new')
# hashlib.new.__qualname__.__len__() == 10
#
# Wave 257 theme: hashlib.new __qualname__ equality and length.
#
# hashlib.new.__qualname__ is '__hash_new' (length 10). hashlib_extra95 first
# anchors the __qualname__ equality; this table cross-checks it and adds the
# __len__ call together under hashlibalgmembership97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra97.hashlib_new_qualname_eq_and_len:
  description: "hashlib.new/__qualname__.__eq__('__hash_new')==True / hashlib.new/__qualname__.__len__()==10 — hashlib.new's __qualname__ is the internal name '__hash_new' with length 10; hashlib_extra95 first anchors the __qualname__ equality; this table cross-checks __eq__ and adds the __len__ call together under hashlibalgmembership97; first hashlibalgmembership97 anchor for hashlib.new __qualname__ equality and length"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibalgmembership97

  columns: [id, function, args, expected]
  rows:
    - [new_qualname_eq,  new.__qualname__.__eq__,  ["__hash_new"], true]
    - [new_qualname_len, new.__qualname__.__len__, [],             10]

# ---------------------------------------------------------------------------
# 'sha256' in hashlib.algorithms_guaranteed == True — standalone
#
# 'sha256' is in hashlib.algorithms_guaranteed. sha256 is the most commonly
# used digest algorithm in Python; it is guaranteed on every conforming Python
# platform. No prior hashlib spec anchors algorithms_guaranteed.__contains__
# for 'sha256' as a standalone under hashlibalgmembership97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra97.sha256_in_guaranteed:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256') == True — sha256 is the most commonly used digest algorithm in Python; it is in algorithms_guaranteed on every conforming Python platform; no prior hashlib spec anchors this as a standalone; first standalone for sha256 algorithms_guaranteed membership under hashlibalgmembership97"
  category: module_identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# 'sha3_256' in hashlib.algorithms_guaranteed == True — standalone
#
# 'sha3_256' is in hashlib.algorithms_guaranteed. SHA-3 (Keccak) was added
# to Python's guaranteed set in Python 3.6. sha3_256 is the SHA-3 analogue
# of sha256. No prior hashlib spec anchors algorithms_guaranteed.__contains__
# for 'sha3_256' as a standalone under hashlibalgmembership97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra97.sha3_256_in_guaranteed:
  description: "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True — sha3_256 is the SHA-3 (Keccak) analogue of sha256; it was added to algorithms_guaranteed in Python 3.6; no prior hashlib spec anchors this as a standalone; first standalone for sha3_256 algorithms_guaranteed membership under hashlibalgmembership97"
  category: module_identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha3_256"]
  expected: true

# ---------------------------------------------------------------------------
# 'blake2b' in hashlib.algorithms_guaranteed == True — standalone
#
# 'blake2b' is in hashlib.algorithms_guaranteed. BLAKE2b is a fast and secure
# cryptographic hash function with a 512-bit output, added to Python's
# guaranteed set in Python 3.6. No prior hashlib spec anchors
# algorithms_guaranteed.__contains__ for 'blake2b' as a standalone under
# hashlibalgmembership97. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra97.blake2b_in_guaranteed:
  description: "hashlib.algorithms_guaranteed.__contains__('blake2b') == True — blake2b is a fast and secure BLAKE2 hash function (512-bit output) added to Python's guaranteed set in Python 3.6; no prior hashlib spec anchors this as a standalone; first standalone for blake2b algorithms_guaranteed membership under hashlibalgmembership97"
  category: module_identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# 'shake_256' in hashlib.algorithms_guaranteed == True — standalone
#
# 'shake_256' is in hashlib.algorithms_guaranteed. SHAKE-256 is an
# extendable-output function (XOF) from the SHA-3 family that produces
# variable-length digests. Added to Python's guaranteed set in Python 3.6.
# No prior hashlib spec anchors algorithms_guaranteed.__contains__ for
# 'shake_256' as a standalone under hashlibalgmembership97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra97.shake_256_in_guaranteed:
  description: "hashlib.algorithms_guaranteed.__contains__('shake_256') == True — shake_256 is an extendable-output function (XOF) from the SHA-3 family producing variable-length digests; added to Python's guaranteed set in Python 3.6; no prior hashlib spec anchors this as a standalone; first standalone for shake_256 algorithms_guaranteed membership under hashlibalgmembership97"
  category: module_identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["shake_256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__qualname__.__len__() == 10 — standalone
#
# hashlib.new.__qualname__ is '__hash_new', which has length 10.
# The name counts: '__hash_new' = 10 characters (underscore-underscore-hash-
# underscore-new, plus leading and trailing double underscores).
# No prior hashlib spec anchors new.__qualname__.__len__() as a standalone
# under hashlibalgmembership97. First standalone for hashlib.new qualname length.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra97.new_qualname_len:
  description: "hashlib.new.__qualname__.__len__() == 10 — hashlib.new.__qualname__ is '__hash_new', which has exactly 10 characters; no prior hashlib spec anchors new.__qualname__.__len__() as a standalone; first standalone for hashlib.new __qualname__ length under hashlibalgmembership97"
  category: type_identity
  kind: python_call_eq
  function: new.__qualname__.__len__
  args: []
  expected: 10
