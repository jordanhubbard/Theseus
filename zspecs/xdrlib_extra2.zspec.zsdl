spec: xdrlib_extra2
version: ">=3.9,<3.13"
backend: python_module(xdrlib)

docs: https://docs.python.org/3/library/xdrlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xdrlib.html — Python xdrlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xdrlib.py"
  notes:
    - "This spec extends xdrlib.zspec.zsdl and xdrlib_extra.zspec.zsdl."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Packer — __qualname__ check
# ---------------------------------------------------------------------------

invariant xdrlib_extra2.Packer.qualname:
  description: "xdrlib.Packer.__qualname__ == 'Packer'"
  category: classnames
  kind: python_call_eq
  function: Packer.__qualname__.__eq__
  args: ["Packer"]
  expected: true

# ---------------------------------------------------------------------------
# Unpacker — __qualname__ check
# ---------------------------------------------------------------------------

invariant xdrlib_extra2.Unpacker.qualname:
  description: "xdrlib.Unpacker.__qualname__ == 'Unpacker'"
  category: classnames
  kind: python_call_eq
  function: Unpacker.__qualname__.__eq__
  args: ["Unpacker"]
  expected: true

# ---------------------------------------------------------------------------
# ConversionError — __name__ and __qualname__
# (xdrlib_extra.zspec.zsdl covers ConversionError.__name__ and module;
#  here we add __qualname__ and verify no nested scope)
# ---------------------------------------------------------------------------

invariant xdrlib_extra2.ConversionError.qualname:
  description: "xdrlib.ConversionError.__qualname__ == 'ConversionError'"
  category: classnames
  kind: python_call_eq
  function: ConversionError.__qualname__.__eq__
  args: ["ConversionError"]
  expected: true

# ---------------------------------------------------------------------------
# Error — __qualname__ check
# (xdrlib_extra.zspec.zsdl covers Error.__name__ and module;
#  here we add __qualname__)
# ---------------------------------------------------------------------------

invariant xdrlib_extra2.Error.qualname:
  description: "xdrlib.Error.__qualname__ == 'Error'"
  category: classnames
  kind: python_call_eq
  function: Error.__qualname__.__eq__
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# Packer.__module__ — already in xdrlib.zspec.zsdl; extend with Unpacker.__module__
# (Unpacker.__module__ is confirmed 'xdrlib'; not yet tested in prior specs)
# ---------------------------------------------------------------------------

invariant xdrlib_extra2.Unpacker.module:
  description: "xdrlib.Unpacker.__module__ == 'xdrlib'"
  category: classnames
  kind: python_call_eq
  function: Unpacker.__module__.__eq__
  args: ["xdrlib"]
  expected: true

# ---------------------------------------------------------------------------
# Top-level class check — no dots in qualname means not a nested class
# ---------------------------------------------------------------------------

invariant xdrlib_extra2.Packer.qualname_no_dots:
  description: "xdrlib.Packer.__qualname__ contains no dots — Packer is a top-level class"
  category: classnames
  kind: python_call_eq
  function: Packer.__qualname__.__contains__
  args: ["."]
  expected: false

invariant xdrlib_extra2.Unpacker.qualname_no_dots:
  description: "xdrlib.Unpacker.__qualname__ contains no dots — Unpacker is a top-level class"
  category: classnames
  kind: python_call_eq
  function: Unpacker.__qualname__.__contains__
  args: ["."]
  expected: false
