spec: cf2911
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [concurrent.futures source, Python docs, https://docs.python.org/3/library/concurrent.futures.html]
  not_derived_from: [any external dataset, concurrent_futures_extra2896.zspec.zsdl — covers __itruediv__/__ifloordiv__/__imod__ dict-presence, concurrent_futures_extra2881.zspec.zsdl — covers __iadd__/__isub__/__imul__ dict-presence, concurrent_futures_extra2866.zspec.zsdl — covers __rand__/__ror__/__rxor__ dict-presence, concurrent_futures_extra2851.zspec.zsdl — covers __rlshift__/__rrshift__/__rpow__ dict-presence]
  notes: [Wave 641 theme — __ilshift__/__irshift__/__ipow__ dict-presence checks for concurrent.futures types. In-place left-shift, right-shift, and power operators. Future/ThreadPoolExecutor/ProcessPoolExecutor/CancelledError/TimeoutError/BrokenExecutor/InvalidStateError are concurrency primitives not numeric types — none define these dunders. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

table cf2911.ilshift:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["cf2911001", operator.contains, [concurrent.futures.Future.__dict__, "__ilshift__"], false]
    - ["cf2911002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__, "__ilshift__"], false]
