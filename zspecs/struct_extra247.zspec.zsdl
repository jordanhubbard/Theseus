spec: struct_extra247
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra246.zspec.zsdl — covers Struct instance method identity (pack, unpack, pack_into, unpack_from, iter_unpack) and Struct attribute descriptor identity (size, format as getset_descriptors)."
  notes:
    - "Wave 247 theme: struct module error handling — pack errors for out-of-range values, unpack buffer size mismatch, and calcsize with unknown format characters."
    - "struct.pack('B', 256) raises struct.error: 'B' format requires 0 <= number <= 255. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('B', -1) raises struct.error: 'B' format requires 0 <= number <= 255 (negative is also out of range for unsigned byte). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('>H', 65536) raises struct.error: 'H' format requires 0 <= number <= 65535. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('B', b'\\x00\\x00') raises struct.error: unpack requires a buffer of 1 bytes (buffer is 2 bytes, format expects 1). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('X') raises struct.error: bad char in struct format ('X' is not a valid format character). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__name__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception'. struct.error inherits directly from Exception. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.error class identity
#
# Wave 247 theme: struct.error class metadata.
#
# struct.error is the exception class raised by all struct validation failures.
# Its __name__ is 'error' (lowercase, following the old Python convention for
# exception classes in some C modules). It inherits directly from Exception.
# struct.error.__bases__[0].__name__ is 'Exception'. Verified Python 3.14.3
# macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra247.error_class_identity:
  description: "struct.error class identity — error.__name__=='error' (lowercase; C module exception naming convention); error.__bases__[0].__name__=='Exception' (inherits directly from Exception, not from ValueError or OSError); wave 247 theme: struct error class metadata; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: structerrcls247

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_eq,  error.__name__.__eq__,               ["error"],     true, "struct.error.__name__ == 'error'; lowercase following C module convention"]
    - [error_base_eq,  "error.__bases__[0].__name__.__eq__", ["Exception"], true, "struct.error.__bases__[0].__name__ == 'Exception'; inherits directly from Exception"]

# ---------------------------------------------------------------------------
# struct.pack — raises struct.error for out-of-range values
#
# Wave 247 theme: struct.pack error handling for value range violations.
#
# struct.pack('B', 256) — 'B' is unsigned char (0..255); 256 is one past the
# maximum. struct.pack('B', -1) — negative values are also out of range for
# unsigned format codes. struct.pack('>H', 65536) — '>H' is big-endian unsigned
# short (0..65535); 65536 is one past the maximum.
# All three raise struct.error. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra247.pack_B_overflow:
  description: "struct.pack('B', 256) raises struct.error — 'B' format is unsigned char (0..255); 256 exceeds the maximum; CPython raises 'B format requires 0 <= number <= 255'; wave 247; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: pack
  args: ["B", 256]
  raises: error

invariant struct_extra247.pack_B_negative:
  description: "struct.pack('B', -1) raises struct.error — 'B' format is unsigned char requiring 0 <= number <= 255; negative values are out of range for all unsigned format codes (B, H, I, L, Q); wave 247; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: pack
  args: ["B", -1]
  raises: error

invariant struct_extra247.pack_H_overflow:
  description: "struct.pack('>H', 65536) raises struct.error — '>H' is big-endian unsigned short (0..65535); 65536 is one past the maximum value for a 16-bit unsigned integer; wave 247; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: pack
  args: [">H", 65536]
  raises: error

# ---------------------------------------------------------------------------
# struct.unpack — raises struct.error for wrong buffer size
#
# Wave 247 theme: struct.unpack buffer size mismatch error handling.
#
# struct.unpack('B', b'\x00\x00') — 'B' requires exactly 1 byte but the buffer
# is 2 bytes. struct.unpack raises struct.error: "unpack requires a buffer of
# 1 bytes". The buffer size must exactly match calcsize(fmt).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra247.unpack_B_wrong_size:
  description: "struct.unpack('B', b'\\x00\\x00') raises struct.error — 'B' format expects exactly 1 byte (calcsize('B')==1) but the buffer contains 2 bytes; struct.unpack requires an exact buffer size match; raises 'unpack requires a buffer of 1 bytes'; wave 247; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: unpack
  args: ["B", "b'\\x00\\x00'"]
  raises: error

# ---------------------------------------------------------------------------
# struct.calcsize — raises struct.error for unknown format character
#
# Wave 247 theme: struct format string validation.
#
# struct.calcsize('X') raises struct.error: "bad char in struct format".
# 'X' is not a valid format character in the struct module format string
# mini-language. Valid format characters include: x, c, b, B, h, H, i, I,
# l, L, q, Q, n, N, e, f, d, s, p, P and byte order prefixes @, =, <, >, !.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra247.calcsize_unknown_format:
  description: "struct.calcsize('X') raises struct.error — 'X' is not a valid struct format character; raises 'bad char in struct format'; valid characters are: x c b B h H i I l L q Q n N e f d s p P plus byte-order prefixes @=<>!; wave 247; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: calcsize
  args: ["X"]
  raises: error

# ---------------------------------------------------------------------------
# Standalone invariants — struct.error class identity
# ---------------------------------------------------------------------------

invariant struct_extra247.error_name_is_lowercase:
  description: "struct.error.__name__.__eq__('error') == True — struct.error uses lowercase 'error' following an older Python C module convention for exception class names (same pattern as socket.error, select.error in older Python); since Python 3.3, struct.error is a direct subclass of Exception; the name is 'error' not 'Error' or 'StructError'; wave 247; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant struct_extra247.error_base_is_Exception:
  description: "struct.error.__bases__[0].__name__.__eq__('Exception') == True — struct.error inherits directly from Exception (not from ValueError, not from OSError); this means it must be caught explicitly as struct.error or as Exception; callers checking for struct packing errors should catch struct.error; wave 247; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true
