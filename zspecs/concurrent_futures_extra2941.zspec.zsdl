    - ["pos_ProcessPoolExecutor", operator.contains, [ProcessPoolExecutor.__dict__, "__pos__"], false]
    - ["pos_CancelledError",      operator.contains, [CancelledError.__dict__,      "__pos__"], false]
    - ["pos_TimeoutError",        operator.contains, [TimeoutError.__dict__,        "__pos__"], false]
    - ["pos_BrokenExecutor",      operator.contains, [BrokenExecutor.__dict__,      "__pos__"], false]
    - ["pos_InvalidStateError",   operator.contains, [InvalidStateError.__dict__,   "__pos__"], false]

