  columns: [id, function, args, expected]
  rows:
    - ["abs_Future",              operator.contains, [Future.__dict__,              "__abs__"], false]
    - ["abs_ThreadPoolExecutor",  operator.contains, [ThreadPoolExecutor.__dict__,  "__abs__"], false]
    - ["abs_ProcessPoolExecutor", operator.contains, [ProcessPoolExecutor.__dict__, "__abs__"], false]
    - ["abs_CancelledError",      operator.contains, [CancelledError.__dict__,      "__abs__"], false]
    - ["abs_TimeoutError",        operator.contains, [TimeoutError.__dict__,        "__abs__"], false]
    - ["abs_BrokenExecutor",      operator.contains, [BrokenExecutor.__dict__,      "__abs__"], false]
