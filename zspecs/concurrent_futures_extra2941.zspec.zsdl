# ---------------------------------------------------------------------------
# combined — all three operators across all seven classes in one table
#
# Cross-product of 7 classes × 3 operators = 21 rows confirming full absence
# of numeric unary slots in the concurrent.futures public API surface.
# ---------------------------------------------------------------------------

table cf2941.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_Future_neg",              operator.contains, [Future.__dict__,              "__neg__"], false]
    - ["comb_Future_pos",              operator.contains, [Future.__dict__,              "__pos__"], false]
    - ["comb_Future_abs",              operator.contains, [Future.__dict__,              "__abs__"], false]
    - ["comb_ThreadPoolExecutor_neg",  operator.contains, [ThreadPoolExecutor.__dict__,  "__neg__"], false]
    - ["comb_ThreadPoolExecutor_pos",  operator.contains, [ThreadPoolExecutor.__dict__,  "__pos__"], false]
    - ["comb_ThreadPoolExecutor_abs",  operator.contains, [ThreadPoolExecutor.__dict__,  "__abs__"], false]
    - ["comb_ProcessPoolExecutor_neg", operator.contains, [ProcessPoolExecutor.__dict__, "__neg__"], false]
    - ["comb_ProcessPoolExecutor_pos", operator.contains, [ProcessPoolExecutor.__dict__, "__pos__"], false]
    - ["comb_ProcessPoolExecutor_abs", operator.contains, [ProcessPoolExecutor.__dict__, "__abs__"], false]
    - ["comb_CancelledError_neg",      operator.contains, [CancelledError.__dict__,      "__neg__"], false]
    - ["comb_CancelledError_pos",      operator.contains, [CancelledError.__dict__,      "__pos__"], false]
    - ["comb_CancelledError_abs",      operator.contains, [CancelledError.__dict__,      "__abs__"], false]
    - ["comb_TimeoutError_neg",        operator.contains, [TimeoutError.__dict__,        "__neg__"], false]
    - ["comb_TimeoutError_pos",        operator.contains, [TimeoutError.__dict__,        "__pos__"], false]
    - ["comb_TimeoutError_abs",        operator.contains, [TimeoutError.__dict__,        "__abs__"], false]
    - ["comb_BrokenExecutor_neg",      operator.contains, [BrokenExecutor.__dict__,      "__neg__"], false]
    - ["comb_BrokenExecutor_pos",      operator.contains, [BrokenExecutor.__dict__,      "__pos__"], false]
    - ["comb_BrokenExecutor_abs",      operator.contains, [BrokenExecutor.__dict__,      "__abs__"], false]
    - ["comb_InvalidStateError_neg",   operator.contains, [InvalidStateError.__dict__,   "__neg__"], false]
    - ["comb_InvalidStateError_pos",   operator.contains, [InvalidStateError.__dict__,   "__pos__"], false]
    - ["comb_InvalidStateError_abs",   operator.contains, [InvalidStateError.__dict__,   "__abs__"], false]
