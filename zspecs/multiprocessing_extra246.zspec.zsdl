spec: multiprocessing_extra246
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "multiprocessing.pool.Pool.__name__ == 'Pool' (len=4); __module__ == 'multiprocessing.pool' (len=20); __bases__[0].__name__ == 'object' (len=6) — Pool inherits directly from object."
    - "Pool.apply.__qualname__ == 'Pool.apply' (len=10); Pool.map.__qualname__ == 'Pool.map' (len=8); Pool.starmap.__qualname__ == 'Pool.starmap' (len=12)."
    - "Pool.apply_async.__qualname__ == 'Pool.apply_async' (len=16); Pool.map_async.__qualname__ == 'Pool.map_async' (len=14)."
    - "Pool.close.__qualname__ == 'Pool.close' (len=10); Pool.terminate.__qualname__ == 'Pool.terminate' (len=14); Pool.join.__qualname__ == 'Pool.join' (len=9)."
    - "apply and close share qualname length 10; map_async and terminate share qualname length 14; apply_async has the longest qualname (len=16); join has the shortest (len=9) after map (len=8)."
    - "All eight methods are defined directly on Pool — all qualnames are rooted at 'Pool.'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

