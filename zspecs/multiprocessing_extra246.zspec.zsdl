    - [pool_mod_eq,     pool.Pool.__module__.__eq__,                      ["multiprocessing.pool"],   true, "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool'; verified with Python 3.14.3"]
    - [pool_mod_len,    pool.Pool.__module__.__len__,                     [],                         20,   "multiprocessing.pool.Pool.__module__.__len__() == 20; verified with Python 3.14.3"]
    - [pool_base_eq,    "pool.Pool.__bases__[0].__name__.__eq__",         ["object"],                 true, "multiprocessing.pool.Pool.__bases__[0].__name__ == 'object' — Pool inherits directly from object; verified with Python 3.14.3"]
    - [pool_base_len,   "pool.Pool.__bases__[0].__name__.__len__",        [],                         6,    "multiprocessing.pool.Pool.__bases__[0].__name__.__len__() == 6; verified with Python 3.14.3"]

