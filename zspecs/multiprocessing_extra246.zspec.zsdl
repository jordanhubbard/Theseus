# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra246
# ---------------------------------------------------------------------------

invariant multiprocessing_extra246.pool_inherits_from_object:
  description: "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__('object') returns True — Pool inherits directly from object(len=6), unlike multiprocessing synchronize primitives (Semaphore/Lock/RLock) that inherit from SemLock; Pool is a standalone class with no abstract base; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "pool.Pool.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra246.apply_async_longest_qualname:
  description: "multiprocessing.pool.Pool.apply_async.__qualname__.__len__() == 16 — 'Pool.apply_async' (len=16) is the longest method qualname among all eight Pool methods; apply_async(16) > put_nowait/get_nowait from asyncio.Queue(16, tied) — in multiprocessing.pool.Pool the async variants have the longest qualnames; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pool.Pool.apply_async.__qualname__.__len__
  args: []
  expected: 16
