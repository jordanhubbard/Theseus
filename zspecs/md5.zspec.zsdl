spec: md5
version: ">=2.0.0"
backend: node(md5)

docs: https://github.com/pvorb/node-md5#readme

provenance:
  derived_from:
    - "md5 README — https://github.com/pvorb/node-md5#readme"
    - "Test vectors verified with md5@2.3.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "md5 source: md5.js"
  notes:
    - "md5 exports the md5 function as the module default (CJS)."
    - "md5(string) returns the lowercase hex MD5 hash."
    - "MD5 of empty string is 'd41d8cd98f00b204e9800998ecf8427e'."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a hex string. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table md5.hash:
  kind: node_module_call_eq
  function: ~
  category: hash
  id_prefix: md5

  columns: [id, args, expected]
  rows:
    - [hello,  ["hello"],  "5d41402abc4b2a76b9719d911017c592"]
    - [empty,  [""],       "d41d8cd98f00b204e9800998ecf8427e"]
