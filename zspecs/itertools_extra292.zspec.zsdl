spec: itertools_extra292
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — combinations, permutations, combinations_with_replacement, islice error behaviors; count, cycle, chain, repeat, product __doc__ lengths"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "combinations/permutations/combinations_with_replacement raise ValueError for negative r"
    - "islice raises ValueError for negative stop or step=0"
    - "Doc string lengths: count=205, cycle=95, chain=190, repeat=154, product=681"
    - "Doc lengths were verified on CPython 3.14.3; may differ on other implementations"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table itertools_extra292.negative_r_errors:
  description: "itertools raises ValueError for negative r in combination-type iterators"
  kind: python_call_raises
  category: errors
  id_prefix: ite292a

  columns: [id, function, args, raises, description]
  rows:
    - [ite292a001, itertools.combinations, "[range(3), -1]", ValueError, "combinations raises ValueError for r=-1"]
    - [ite292a002, itertools.permutations, "[range(3), -1]", ValueError, "permutations raises ValueError for r=-1"]
    - [ite292a003, itertools.combinations_with_replacement, "[range(3), -1]", ValueError, "combinations_with_replacement raises ValueError for r=-1"]
    - [ite292a004, itertools.islice, "['abc', -1]", ValueError, "islice raises ValueError for negative stop"]
    - [ite292a005, itertools.islice, "['abc', 1, 2, 0]", ValueError, "islice raises ValueError for step=0"]

table itertools_extra292.doc_lengths:
  description: "__doc__ length for key itertools types"
  kind: python_call_eq
  category: identity
  id_prefix: ite292b

  columns: [id, function, args, expected, description]
  rows:
    - [ite292b001, itertools.count.__doc__.__len__, [], 205, "itertools.count __doc__ length is 205"]
    - [ite292b002, itertools.cycle.__doc__.__len__, [], 95, "itertools.cycle __doc__ length is 95"]
    - [ite292b003, itertools.chain.__doc__.__len__, [], 190, "itertools.chain __doc__ length is 190"]
    - [ite292b004, itertools.repeat.__doc__.__len__, [], 154, "itertools.repeat __doc__ length is 154"]
    - [ite292b005, itertools.product.__doc__.__len__, [], 681, "itertools.product __doc__ length is 681"]

invariant itertools_extra292.combinations_negative_r:
  description: "itertools.combinations(range(3), -1) raises ValueError"
  category: errors
  kind: python_call_raises
  function: itertools.combinations
  args: ["[range(3), -1]"]
  raises: ValueError

invariant itertools_extra292.islice_step_zero:
  description: "itertools.islice('abc', 1, 2, 0) raises ValueError for step=0"
  category: errors
  kind: python_call_raises
  function: itertools.islice
  args: ["['abc', 1, 2, 0]"]
  raises: ValueError

invariant itertools_extra292.count_doc_len:
  description: "itertools.count.__doc__.__len__() == 205"
  category: identity
  kind: python_call_eq
  function: itertools.count.__doc__.__len__
  args: []
  expected: 205
