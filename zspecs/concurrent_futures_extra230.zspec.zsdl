spec: concurrent_futures_extra230
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.Executor.submit.__name__ == 'submit' — 6 characters; qualname is 'Executor.submit'; verified with Python 3.14.3."
    - "concurrent.futures.Executor.map.__name__ == 'map' — 3 characters; qualname is 'Executor.map'; verified with Python 3.14.3."
    - "concurrent.futures.Executor.shutdown.__name__ == 'shutdown' — 8 characters; qualname is 'Executor.shutdown'; verified with Python 3.14.3."
    - "concurrent.futures.Executor.__enter__.__name__ == '__enter__' — 9 characters; qualname is 'Executor.__enter__'; verified with Python 3.14.3."
    - "concurrent.futures.Executor.__exit__.__name__ == '__exit__' — 8 characters; qualname is 'Executor.__exit__'; verified with Python 3.14.3."
    - "concurrent.futures.Executor.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Executor method name contracts — extra230 namespace
#
# Executor.submit, map, shutdown define the core executor interface.
# All three have qualnames with 'Executor.' prefix.
# submit (6 chars), map (3 chars), shutdown (8 chars).
# ---------------------------------------------------------------------------

table concurrent_futures_extra230.executor_method_names:
  description: "concurrent.futures.Executor method __name__ and __qualname__ contracts in cf230emn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cf230emn

  columns: [id, function, args, expected, description]
  rows:
    - [exec_submit_name_eq,      Executor.submit.__name__.__eq__,       ["submit"],            true, "concurrent.futures.Executor.submit.__name__ == 'submit'; verified with Python 3.14.3"]
    - [exec_submit_name_len_6,   Executor.submit.__name__.__len__,      [],                    6,    "concurrent.futures.Executor.submit.__name__.__len__() == 6 — 'submit' has 6 characters; verified with Python 3.14.3"]
    - [exec_submit_qualname_eq,  Executor.submit.__qualname__.__eq__,   ["Executor.submit"],   true, "concurrent.futures.Executor.submit.__qualname__ == 'Executor.submit'; verified with Python 3.14.3"]
    - [exec_map_name_eq,         Executor.map.__name__.__eq__,          ["map"],               true, "concurrent.futures.Executor.map.__name__ == 'map'; verified with Python 3.14.3"]
    - [exec_map_name_len_3,      Executor.map.__name__.__len__,         [],                    3,    "concurrent.futures.Executor.map.__name__.__len__() == 3 — 'map' has 3 characters; verified with Python 3.14.3"]
    - [exec_map_qualname_eq,     Executor.map.__qualname__.__eq__,      ["Executor.map"],      true, "concurrent.futures.Executor.map.__qualname__ == 'Executor.map'; verified with Python 3.14.3"]
    - [exec_shutdown_name_eq,    Executor.shutdown.__name__.__eq__,     ["shutdown"],          true, "concurrent.futures.Executor.shutdown.__name__ == 'shutdown'; verified with Python 3.14.3"]
    - [exec_shutdown_name_len_8, Executor.shutdown.__name__.__len__,    [],                    8,    "concurrent.futures.Executor.shutdown.__name__.__len__() == 8 — 'shutdown' has 8 characters; verified with Python 3.14.3"]
    - [exec_shutdown_qualname_eq, Executor.shutdown.__qualname__.__eq__, ["Executor.shutdown"], true, "concurrent.futures.Executor.shutdown.__qualname__ == 'Executor.shutdown'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Executor context manager method name contracts — extra230 namespace
#
# Executor.__enter__ and __exit__ enable the 'with' statement.
# Both have qualnames with 'Executor.' prefix.
# __enter__ (9 chars), __exit__ (8 chars).
# ---------------------------------------------------------------------------

table concurrent_futures_extra230.executor_context_manager_names:
  description: "concurrent.futures.Executor __enter__ and __exit__ method name contracts in cf230ecm namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cf230ecm

  columns: [id, function, args, expected, description]
  rows:
    - [exec_enter_name_eq,      Executor.__enter__.__name__.__eq__,      ["__enter__"],           true, "concurrent.futures.Executor.__enter__.__name__ == '__enter__'; verified with Python 3.14.3"]
    - [exec_enter_name_len_9,   Executor.__enter__.__name__.__len__,     [],                      9,    "concurrent.futures.Executor.__enter__.__name__.__len__() == 9 — '__enter__' has 9 characters; verified with Python 3.14.3"]
    - [exec_enter_qualname_eq,  Executor.__enter__.__qualname__.__eq__,  ["Executor.__enter__"],  true, "concurrent.futures.Executor.__enter__.__qualname__ == 'Executor.__enter__'; verified with Python 3.14.3"]
    - [exec_exit_name_eq,       Executor.__exit__.__name__.__eq__,       ["__exit__"],            true, "concurrent.futures.Executor.__exit__.__name__ == '__exit__'; verified with Python 3.14.3"]
    - [exec_exit_name_len_8,    Executor.__exit__.__name__.__len__,      [],                      8,    "concurrent.futures.Executor.__exit__.__name__.__len__() == 8 — '__exit__' has 8 characters; verified with Python 3.14.3"]
    - [exec_exit_qualname_eq,   Executor.__exit__.__qualname__.__eq__,   ["Executor.__exit__"],   true, "concurrent.futures.Executor.__exit__.__qualname__ == 'Executor.__exit__'; verified with Python 3.14.3"]
