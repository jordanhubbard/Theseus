spec: theseus_unicodedata_cr
version: ">=3.9"
backend: python_cleanroom(theseus_unicodedata_cr)
blocks: unicodedata

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html"
  notes:
    - "Clean-room Unicode character utilities. Do NOT import unicodedata."
    - "category(chr): Unicode general category string (e.g. 'Lu', 'Ll', 'Nd', 'Zs')."
    - "is_alpha(c): True if character is alphabetic (category starts with L)."
    - "is_digit(c): True if character is decimal digit (category Nd)."
    - "normalize_nfc(s): NFC normalization — for pure ASCII input, returns unchanged."
    - "unicodedata_category_A(): category('A') == 'Lu' (uppercase letter)."
    - "unicodedata_category_5(): category('5') == 'Nd' (decimal digit)."
    - "unicodedata_is_alpha_A(): is_alpha('A') == True."
    - "Export: category, is_alpha, is_digit, normalize_nfc."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_unicodedata_cr.category_A:
  description: "category('A') == 'Lu'"
  category: category
  kind: python_call_eq
  function: unicodedata_category_A
  args: []
  expected: "Lu"

invariant theseus_unicodedata_cr.category_5:
  description: "category('5') == 'Nd'"
  category: category
  kind: python_call_eq
  function: unicodedata_category_5
  args: []
  expected: "Nd"

invariant theseus_unicodedata_cr.is_alpha_A:
  description: "is_alpha('A') == True"
  category: predicates
  kind: python_call_eq
  function: unicodedata_is_alpha_A
  args: []
  expected: true
