# ---------------------------------------------------------------------------

table multiprocessing_extra186.basecontext_identity:
  description: "multiprocessing.context.BaseContext name (len=11), module, and base class identity; new to multiprocessing_extra186"
  kind: python_call_eq
  category: identity
  id_prefix: mpcontext186

  columns: [id, function, args, expected, description]
  rows:
    - [basecontext_name_eq,
       BaseContext.__name__.__eq__,
       ["BaseContext"],
       true,
       "multiprocessing.context.BaseContext.__name__.__eq__('BaseContext') == True — class name string identity; str.__eq__ returns True; new to multiprocessing_extra186"]
    - [basecontext_name_len_11,
       BaseContext.__name__.__len__,
       [],
       11,
       "multiprocessing.context.BaseContext.__name__.__len__() == 11 — 'BaseContext' has 11 characters: B-a-s-e-C-o-n-t-e-x-t; str.__len__() returns 11; new to multiprocessing_extra186"]
    - [basecontext_module_eq,
       BaseContext.__module__.__eq__,
       ["multiprocessing.context"],
       true,
       "multiprocessing.context.BaseContext.__module__.__eq__('multiprocessing.context') == True — BaseContext is defined in multiprocessing.context; str.__eq__ returns True; new to multiprocessing_extra186"]
    - [basecontext_bases0_name_eq,
       "BaseContext.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "multiprocessing.context.BaseContext.__bases__[0].__name__.__eq__('object') == True — BaseContext directly subclasses object; str.__eq__ returns True; new to multiprocessing_extra186"]
    - [basecontext_name_len_11b,
       BaseContext.__name__.__len__,
       [],
       11,
       "multiprocessing.context.BaseContext.__name__.__len__() == 11 — length ordering anchor: BaseContext(11) < SpawnContext(12) < DefaultContext(14); str.__len__() returns 11; new to multiprocessing_extra186"]

