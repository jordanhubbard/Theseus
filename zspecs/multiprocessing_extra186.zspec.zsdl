spec: multiprocessing_extra186
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "multiprocessing.context.BaseContext.__name__ == 'BaseContext' (len=11); __module__ == 'multiprocessing.context'."
    - "multiprocessing.context.BaseContext.__bases__[0].__name__ == 'object' — BaseContext directly subclasses object."
    - "multiprocessing.context.SpawnContext.__name__ == 'SpawnContext' (len=12); __module__ == 'multiprocessing.context'."
    - "multiprocessing.context.SpawnContext.__bases__[0].__name__ == 'BaseContext' — SpawnContext subclasses BaseContext."
    - "multiprocessing.context.DefaultContext.__name__ == 'DefaultContext' (len=14); __bases__[0].__name__ == 'BaseContext'."
    - "Length ordering: BaseContext(11) < SpawnContext(12) < DefaultContext(14)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

