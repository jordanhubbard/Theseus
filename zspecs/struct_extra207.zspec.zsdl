spec: struct_extra207
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra206.zspec.zsdl — covers struct checks prior to extra207"
  notes:
    - "struct.Struct.__qualname__ == 'Struct' — the Struct class is implemented in C (_struct module); its __qualname__ is 'Struct' and __module__ is '_struct'. Verified with Python 3.14.3."
    - "struct.pack.__qualname__ == 'pack' — all struct functions (pack, unpack, pack_into, unpack_from, iter_unpack, calcsize) are C builtins in _struct; their __qualname__ equals their bare function name; all have __module__ == '_struct'. Verified with Python 3.14.3."
    - "struct.error.__qualname__ == 'error' — struct.error is a pure-Python exception defined in the struct module (not _struct); its __module__ == 'struct' (not '_struct'). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct class and function __qualname__ checks -- extra207
# ---------------------------------------------------------------------------

table struct_extra207.struct_qualname_class:
  description: "struct.Struct class __qualname__ checks in structqn207 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: structqn207

  columns: [id, function, args, expected, description]
  rows:
    - [struct_qualname,  struct.Struct.__qualname__.__eq__,   ["Struct"],   true,   "struct.Struct.__qualname__ == 'Struct' (C class in _struct, len=6); verified with Python 3.14.3"]
    - [struct_module,    struct.Struct.__module__.__eq__,     ["_struct"],  true,   "struct.Struct.__module__ == '_struct' (C extension); verified with Python 3.14.3"]
    - [error_qualname,   struct.error.__qualname__.__eq__,    ["error"],    true,   "struct.error.__qualname__ == 'error' (Python exception in struct module); verified with Python 3.14.3"]
    - [error_module,     struct.error.__module__.__eq__,      ["struct"],   true,   "struct.error.__module__ == 'struct' (Python struct module, not _struct); verified with Python 3.14.3"]

table struct_extra207.struct_qualname_funcs:
  description: "struct function __qualname__ checks in structfn207 namespace — all core struct functions are C builtins in _struct; their __qualname__ equals their bare function name and __module__ == '_struct'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structfn207

  columns: [id, function, args, expected, description]
  rows:
    - [pack_qualname,         struct.pack.__qualname__.__eq__,         ["pack"],         true,  "struct.pack.__qualname__ == 'pack' (len=4); verified with Python 3.14.3"]
    - [pack_module,           struct.pack.__module__.__eq__,           ["_struct"],      true,  "struct.pack.__module__ == '_struct'; verified with Python 3.14.3"]
    - [unpack_qualname,       struct.unpack.__qualname__.__eq__,       ["unpack"],       true,  "struct.unpack.__qualname__ == 'unpack' (len=6); verified with Python 3.14.3"]
    - [unpack_module,         struct.unpack.__module__.__eq__,         ["_struct"],      true,  "struct.unpack.__module__ == '_struct'; verified with Python 3.14.3"]
    - [pack_into_qualname,    struct.pack_into.__qualname__.__eq__,    ["pack_into"],    true,  "struct.pack_into.__qualname__ == 'pack_into' (len=9); verified with Python 3.14.3"]
    - [unpack_from_qualname,  struct.unpack_from.__qualname__.__eq__,  ["unpack_from"],  true,  "struct.unpack_from.__qualname__ == 'unpack_from' (len=11); verified with Python 3.14.3"]
    - [iter_unpack_qualname,  struct.iter_unpack.__qualname__.__eq__,  ["iter_unpack"],  true,  "struct.iter_unpack.__qualname__ == 'iter_unpack' (len=11); verified with Python 3.14.3"]
    - [calcsize_qualname,     struct.calcsize.__qualname__.__eq__,     ["calcsize"],     true,  "struct.calcsize.__qualname__ == 'calcsize' (len=8); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct function __module__ checks -- extra207
# All C builtins have __module__ == '_struct'
# ---------------------------------------------------------------------------

table struct_extra207.struct_func_modules:
  description: "struct function __module__ checks in structmod207 namespace — all C builtins in _struct have __module__ == '_struct'; struct.unpack.__module__=='_struct'; struct.calcsize.__module__=='_struct'; struct.pack_into.__module__=='_struct'; struct.unpack_from.__module__=='_struct'; struct.iter_unpack.__module__=='_struct'; contrast with struct.error.__module__=='struct' (Python wrapper); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structmod207

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_module,        struct.unpack.__module__.__eq__,        ["_struct"], true, "struct.unpack.__module__ == '_struct'; C extension; verified with Python 3.14.3"]
    - [calcsize_module,      struct.calcsize.__module__.__eq__,      ["_struct"], true, "struct.calcsize.__module__ == '_struct'; C extension; verified with Python 3.14.3"]
    - [pack_into_module,     struct.pack_into.__module__.__eq__,     ["_struct"], true, "struct.pack_into.__module__ == '_struct'; C extension; verified with Python 3.14.3"]
    - [unpack_from_module,   struct.unpack_from.__module__.__eq__,   ["_struct"], true, "struct.unpack_from.__module__ == '_struct'; C extension; verified with Python 3.14.3"]
    - [iter_unpack_module,   struct.iter_unpack.__module__.__eq__,   ["_struct"], true, "struct.iter_unpack.__module__ == '_struct'; C extension; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants -- extra207
# ---------------------------------------------------------------------------

invariant struct_extra207.struct_Struct_qualname_is_Struct:
  description: "struct.Struct.__qualname__.__eq__('Struct') returns True — struct.Struct is a C-implemented class in _struct; __qualname__ is 'Struct' (len=6); __module__=='_struct' (C extension, not Python struct wrapper); struct.error contrasts: it IS in Python wrapper, __module__=='struct'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__qualname__.__eq__
  args: ["Struct"]
  expected: true

invariant struct_extra207.struct_pack_qualname_is_pack:
  description: "struct.pack.__qualname__.__eq__('pack') returns True — struct.pack is a C builtin in _struct; __qualname__ == 'pack' (len=4, same as __name__); __module__=='_struct'; len 4 is shortest among struct functions; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: struct.pack.__qualname__.__eq__
  args: ["pack"]
  expected: true

invariant struct_extra207.struct_error_module_is_struct:
  description: "struct.error.__module__.__eq__('struct') returns True — struct.error is defined in the pure-Python struct wrapper (not _struct C extension); __module__=='struct' distinguishes it from C functions with __module__=='_struct'; struct.error inherits from Exception; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: struct.error.__module__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra207.struct_unpack_qualname_is_unpack:
  description: "struct.unpack.__qualname__.__eq__('unpack') returns True — struct.unpack is a C builtin in _struct; its qualname is 'unpack' (len=6) matching the public attribute name; __module__=='_struct'; unpack(fmt, buffer) returns a tuple of values unpacked from the buffer according to fmt; the buffer must be exactly calcsize(fmt) bytes; contrast: struct.unpack_from allows an offset and a larger buffer; NEW in struct_extra207: first standalone unpack.__qualname__ invariant in structqualname207 namespace; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: struct.unpack.__qualname__.__eq__
  args: ["unpack"]
  expected: true

invariant struct_extra207.struct_calcsize_qualname_is_calcsize:
  description: "struct.calcsize.__qualname__.__eq__('calcsize') returns True — struct.calcsize is a C builtin in _struct; its qualname is 'calcsize' (len=8) matching the public name; __module__=='_struct'; calcsize(fmt) returns the size in bytes of the struct described by fmt; this is the expected buffer length for struct.pack and struct.unpack; calcsize is the shortest-named struct function after pack (len=4); NEW in struct_extra207: first standalone calcsize.__qualname__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: struct.calcsize.__qualname__.__eq__
  args: ["calcsize"]
  expected: true

invariant struct_extra207.struct_Struct_module_is_c_struct:
  description: "struct.Struct.__module__.__eq__('_struct') returns True — struct.Struct is a C extension type whose __module__ is '_struct'; the underscore prefix follows the CPython convention for C extension modules backing public stdlib modules; the public 'struct' module (Lib/struct.py) is a thin wrapper that imports Struct from _struct; compare: struct.error.__module__=='struct' (defined in the Python wrapper); NEW in struct_extra207: first standalone Struct.__module__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

invariant struct_extra207.struct_error_qualname_is_error:
  description: "struct.error.__qualname__.__eq__('error') returns True — struct.error is a module-level exception class defined in Lib/struct.py; its qualname is 'error' (lowercase, len=5, matching the class name); struct.error is raised when a format string is invalid or data cannot be packed/unpacked; it inherits from Exception (struct.error.__bases__[0].__name__ == 'Exception'); contrast with socket.error whose qualname is 'OSError' (socket.error is an alias, not its own class); struct.error IS its own class with __module__=='struct'; NEW in struct_extra207: first standalone error.__qualname__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: struct.error.__qualname__.__eq__
  args: ["error"]
  expected: true

invariant struct_extra207.struct_pack_into_qualname_is_pack_into:
  description: "struct.pack_into.__qualname__.__eq__('pack_into') returns True — struct.pack_into is a C builtin in _struct; its qualname is 'pack_into' (len=9) matching the public name; __module__=='_struct'; pack_into(fmt, buffer, offset, v1, v2, ...) packs values into a writable buffer in place at the given byte offset; unlike struct.pack it does not return a new bytes object but modifies the buffer (bytearray or similar writable bytes-like object); the qualname contains an underscore separating 'pack' and 'into'; NEW in struct_extra207: first standalone pack_into.__qualname__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: struct.pack_into.__qualname__.__eq__
  args: ["pack_into"]
  expected: true

