invariant concurrent_futures_extra248.future_module_is_base:
  description: "concurrent.futures.Future.__module__.__eq__('concurrent.futures._base') returns True — Future is defined in the internal _base submodule (len=24), not directly in concurrent.futures (len=18); the public concurrent.futures package re-exports it; Future.__name__ == 'Future' (len=6); Future.__bases__[0].__name__ == 'object' (len=6); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra248.future_base_is_object:
  description: "concurrent.futures.Future.__bases__[0].__name__.__eq__('object') returns True — Future has exactly one base class: object; Future does not subclass threading.Thread or any other concurrency primitive; Future.__name__ == 'Future' (len=6); Future.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Future.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant concurrent_futures_extra248.future_add_done_callback_is_longest_name:
  description: "concurrent.futures.Future.add_done_callback.__name__.__len__() == 17 — add_done_callback has the longest __name__ (len=17) among all nine Future methods; set_exception is next at len=13; contrast with done.__name__.__len__()==4 (shortest); add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24); all methods share __module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.add_done_callback.__name__.__len__
  args: []
  expected: 17
