spec: common_prefix
version: ">=1.1.0"
backend: node(common-prefix)

docs: https://www.npmjs.com/package/common-prefix

provenance:
  derived_from:
    - "common-prefix README — https://www.npmjs.com/package/common-prefix"
    - "Test vectors verified with common-prefix via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "common-prefix source"
  notes:
    - "common-prefix is an npm package. Install: npm install common-prefix"
    - "Returns the longest common prefix shared by all strings in an array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table common_prefix.find:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: cpfx

  columns: [id, args, expected]
  rows:
    - [foo_prefix,  [["foobar", "foobaz", "fooqux"]],  "foo"]
    - [abc_prefix,  [["abc", "abcd", "abcde"]],        "abc"]
