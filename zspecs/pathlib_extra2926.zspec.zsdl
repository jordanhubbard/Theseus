spec: pp2926
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/pathlib_extra2911.zspec.zsdl — wave 641 predecessor (covered __ilshift__, __irshift__, __ipow__)"
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "Wave 642 theme: __iand__, __ior__, __ixor__ dict-presence checks (in-place bitwise AND, OR, XOR operators)."
    - "pathlib path objects define __truediv__ for the / path-joining operator, but have no bitwise semantics of any kind."
    - "pathlib.PurePath, PurePosixPath, PureWindowsPath, and Path all lack __iand__, __ior__, and __ixor__."
    - "The non-inplace counterparts (__and__, __or__, __xor__) are also absent from all pathlib classes — no bitwise support at all."
    - "This continues the pattern established across prior waves: pathlib's only arithmetic-adjacent operator is __truediv__ (path joining)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __iand__ dict-presence — absent from all pathlib path classes
# ---------------------------------------------------------------------------

table pp2926.iand:
  description: "__iand__ is absent from all pathlib class __dict__s — path objects have no bitwise AND semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2926

  columns: [id, function, args, expected]
  rows:
    - ["pp2926001", "pathlib.PurePath.__dict__.__contains__",        ["__iand__"], false]
    - ["pp2926002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__iand__"], false]
    - ["pp2926003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__iand__"], false]
    - ["pp2926004", "pathlib.Path.__dict__.__contains__",            ["__iand__"], false]
    - ["pp2926005", "pathlib.PurePath.__dict__.__contains__",        ["__and__"],  false]
    - ["pp2926006", "pathlib.Path.__dict__.__contains__",            ["__and__"],  false]

