# ---------------------------------------------------------------------------
# Table: combined — all three in-place bitwise ops absent; __truediv__ present on PurePath
# Highlights that pathlib's only operator is path-joining via __truediv__
# ---------------------------------------------------------------------------

table pp2926.combined:
  description: "pathlib defines __truediv__ on PurePath for / path joining but NO bitwise operators — __iand__, __ior__, __ixor__ absent from all classes"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2926

  columns: [id, function, args, expected]
  rows:
    - ["pp2926019", "pathlib.PurePath.__dict__.__contains__",        ["__truediv__"], true]
    - ["pp2926020", "pathlib.PurePath.__dict__.__contains__",        ["__iand__"],    false]
    - ["pp2926021", "pathlib.PurePath.__dict__.__contains__",        ["__ior__"],     false]
    - ["pp2926022", "pathlib.PurePath.__dict__.__contains__",        ["__ixor__"],    false]
