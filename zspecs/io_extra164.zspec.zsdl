spec: io_extra164
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.BufferedReader and io.TextIOWrapper method __qualname__ values."
    - "A key discovery: io.BufferedReader and io.TextIOWrapper method qualnames use the PUBLIC class name (e.g., 'BufferedReader.read', 'TextIOWrapper.read'), NOT the private '_IOBase' prefix seen on io.IOBase methods (established in io_extra163)."
    - "This is a two-tier pattern within the io module: abstract base class methods (IOBase) use the private C type '_IOBase.' prefix; concrete subclass methods (BufferedReader, TextIOWrapper) use the public class name prefix."
    - "io.BufferedReader method qualnames: read='BufferedReader.read' (len=19), readline='BufferedReader.readline' (len=23), readinto='BufferedReader.readinto' (len=23)."
    - "io.TextIOWrapper method qualnames: read='TextIOWrapper.read' (len=18), readline='TextIOWrapper.readline' (len=22), write='TextIOWrapper.write' (len=19), flush='TextIOWrapper.flush' (len=19), seek='TextIOWrapper.seek' (len=18)."
    - "readline and readinto are tied at len=23 for BufferedReader; read and seek are tied at len=18 for TextIOWrapper; write and flush are tied at len=19 for TextIOWrapper."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedReader method __qualname__ values
# read, readline, readinto — all use 'BufferedReader.' prefix (15 chars).
# This contrasts with io.IOBase methods which use '_IOBase.' (private C name).
# read=19, readline=23, readinto=23
# readline and readinto are tied at 23 — both 8-character method names.
# ---------------------------------------------------------------------------

table io_extra164.BufferedReader_method_qualnames:
  description: "io.BufferedReader method __qualname__ values: read='BufferedReader.read' (len=19), readline='BufferedReader.readline' (len=23), readinto='BufferedReader.readinto' (len=23); all use public 'BufferedReader.' prefix; readline and readinto are tied at 23"
  kind: python_call_eq
  category: qualname
  id_prefix: iobufrdq164

  columns: [id, function, args, expected, description]
  rows:
    - [read_qeq,     BufferedReader.read.__qualname__.__eq__,     ["BufferedReader.read"],     true, "io.BufferedReader.read.__qualname__ == 'BufferedReader.read' (BufferedReader.read() reads and returns up to size bytes from the buffered stream; unlike io.IOBase methods whose qualnames use the private '_IOBase.' prefix, BufferedReader.read uses the public class name 'BufferedReader.' (15 chars) + 'read' (4 chars) = 19 chars total for 'BufferedReader.read'; this public prefix pattern matches pathlib.Path method qualnames which also use the public class name)"]
    - [readline_qeq, BufferedReader.readline.__qualname__.__eq__, ["BufferedReader.readline"], true, "io.BufferedReader.readline.__qualname__ == 'BufferedReader.readline' (BufferedReader.readline() reads and returns one line from the buffered binary stream, up to and including the newline character; 'BufferedReader.readline' has 23 characters: 'BufferedReader.' (15) + 'readline' (8) = 23; tied with 'BufferedReader.readinto' (also 23) — both readline and readinto have 8-character method names making their qualnames the same length)"]
    - [readinto_qeq, BufferedReader.readinto.__qualname__.__eq__, ["BufferedReader.readinto"], true, "io.BufferedReader.readinto.__qualname__ == 'BufferedReader.readinto' (BufferedReader.readinto() reads bytes into a pre-allocated, writable bytes-like object b, returning the number of bytes read; 'BufferedReader.readinto' has 23 characters: 'BufferedReader.' (15) + 'readinto' (8) = 23; tied with 'BufferedReader.readline' (also 23) because both method names are 8 characters; readinto() is more memory-efficient than read() for large I/O as it avoids allocating a new bytes object)"]
    - [read_qlen,    BufferedReader.read.__qualname__.__len__,    [],                          19,  "io.BufferedReader.read.__qualname__.__len__() == 19 ('BufferedReader.read' has 19 characters: 'BufferedReader.' (15) + 'read' (4) = 19; the 'BufferedReader.' prefix is 15 characters — much longer than the '_IOBase.' prefix (8 chars) used by IOBase methods; this longer prefix means BufferedReader method qualnames are longer than IOBase method qualnames even for the same method name: BufferedReader.read (19) vs _IOBase.readline (16))"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper method __qualname__ values
# read, readline, write, flush, seek — all use 'TextIOWrapper.' prefix (14 chars).
# TextIOWrapper method qualnames use the public class name 'TextIOWrapper'.
# read=18, seek=18, write=19, flush=19, readline=22
# ---------------------------------------------------------------------------

table io_extra164.TextIOWrapper_method_qualnames:
  description: "io.TextIOWrapper method __qualname__ values: read='TextIOWrapper.read' (len=18), seek='TextIOWrapper.seek' (len=18), write='TextIOWrapper.write' (len=19), flush='TextIOWrapper.flush' (len=19), readline='TextIOWrapper.readline' (len=22); all use public 'TextIOWrapper.' prefix"
  kind: python_call_eq
  category: qualname
  id_prefix: iotextwrapq164

  columns: [id, function, args, expected, description]
  rows:
    - [read_qeq,     TextIOWrapper.read.__qualname__.__eq__,     ["TextIOWrapper.read"],     true, "io.TextIOWrapper.read.__qualname__ == 'TextIOWrapper.read' (TextIOWrapper.read() reads and returns at most size characters from the text stream; returns a str (not bytes); 'TextIOWrapper.read' has 18 characters: 'TextIOWrapper.' (14) + 'read' (4) = 18; the 'TextIOWrapper.' prefix is 14 characters; tied with 'TextIOWrapper.seek' (also 18 — both have 4-character method names); TextIOWrapper is the most commonly used io class, returned by open() in text mode)"]
    - [readline_qeq, TextIOWrapper.readline.__qualname__.__eq__, ["TextIOWrapper.readline"], true, "io.TextIOWrapper.readline.__qualname__ == 'TextIOWrapper.readline' (TextIOWrapper.readline() reads one line from the text stream up to and including the newline; returns a str; 'TextIOWrapper.readline' has 22 characters: 'TextIOWrapper.' (14) + 'readline' (8) = 22; the longest TextIOWrapper method qualname in this spec — 'readline' (8 chars) is the longest method name covered here for TextIOWrapper; compare with BufferedReader.readline (23) which is 1 char longer due to the longer prefix)"]
    - [write_qeq,    TextIOWrapper.write.__qualname__.__eq__,    ["TextIOWrapper.write"],    true, "io.TextIOWrapper.write.__qualname__ == 'TextIOWrapper.write' (TextIOWrapper.write() writes the string s to the text stream and returns the number of characters written; 'TextIOWrapper.write' has 19 characters: 'TextIOWrapper.' (14) + 'write' (5) = 19; tied with 'TextIOWrapper.flush' (also 19 — both have 5-character method names); TextIOWrapper.write() is the primary way to write text to files when opened in text mode)"]
    - [flush_qeq,    TextIOWrapper.flush.__qualname__.__eq__,    ["TextIOWrapper.flush"],    true, "io.TextIOWrapper.flush.__qualname__ == 'TextIOWrapper.flush' (TextIOWrapper.flush() flushes the write buffers of the text stream; it forces any buffered data to be written to the underlying binary buffered stream; 'TextIOWrapper.flush' has 19 characters: 'TextIOWrapper.' (14) + 'flush' (5) = 19; tied with 'TextIOWrapper.write' (also 19); note that io.IOBase.flush.__qualname__ == '_IOBase.flush' (len=13) uses the private prefix — a 6-char difference from TextIOWrapper.flush (19))"]
    - [seek_qeq,     TextIOWrapper.seek.__qualname__.__eq__,     ["TextIOWrapper.seek"],     true, "io.TextIOWrapper.seek.__qualname__ == 'TextIOWrapper.seek' (TextIOWrapper.seek() sets the stream position; accepts whence parameter (SEEK_SET=0, SEEK_CUR=1, SEEK_END=2); for text streams, seek() is limited compared to binary streams — only seek(0) and positions from tell() are guaranteed to work when mode is not 'b'; 'TextIOWrapper.seek' has 18 characters: 'TextIOWrapper.' (14) + 'seek' (4) = 18; tied with 'TextIOWrapper.read' (also 18))"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra164.BufferedReader_read_qualname_uses_public_prefix:
  description: "io.BufferedReader.read.__qualname__ == 'BufferedReader.read' — BufferedReader.read() uses the public class name 'BufferedReader' in its qualname (NOT the private '_IOBase' prefix used by io.IOBase methods like close, flush, readline); this reveals a two-tier pattern within the io module: abstract IOBase methods use '_IOBase.' while concrete subclass methods (BufferedReader, TextIOWrapper) use the public class name; 'BufferedReader.read' has 19 characters; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: BufferedReader.read.__qualname__.__eq__
  args: ["BufferedReader.read"]
  expected: true

invariant io_extra164.BufferedReader_readline_readinto_tied_at_23:
  description: "io.BufferedReader.readline.__qualname__.__len__() == 23 — 'BufferedReader.readline' has 23 characters: 'BufferedReader.' (15) + 'readline' (8) = 23; tied with 'BufferedReader.readinto' (also 23: 'BufferedReader.' (15) + 'readinto' (8) = 23); both readline and readinto have exactly 8-character method names, making them the longest BufferedReader method qualnames in this spec; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: BufferedReader.readline.__qualname__.__len__
  args: []
  expected: 23

invariant io_extra164.TextIOWrapper_read_seek_tied_at_18:
  description: "io.TextIOWrapper.read.__qualname__.__len__() == 18 — 'TextIOWrapper.read' has 18 characters: 'TextIOWrapper.' (14) + 'read' (4) = 18; tied with 'TextIOWrapper.seek' (also 18: 'TextIOWrapper.' (14) + 'seek' (4) = 18); both read and seek have 4-character method names producing the same qualname length; TextIOWrapper.read (18) is shorter than BufferedReader.read (19) because 'TextIOWrapper.' (14 chars) < 'BufferedReader.' (15 chars); confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: TextIOWrapper.read.__qualname__.__len__
  args: []
  expected: 18

invariant io_extra164.TextIOWrapper_readline_is_longest_at_22:
  description: "io.TextIOWrapper.readline.__qualname__.__len__() == 22 — 'TextIOWrapper.readline' has 22 characters: 'TextIOWrapper.' (14) + 'readline' (8) = 22; this is the longest TextIOWrapper method qualname in this spec; the complete length ranking for TextIOWrapper methods: read=18, seek=18, write=19, flush=19, readline=22; 'TextIOWrapper.readline' (22) is shorter than 'BufferedReader.readline' (23) by 1 character due to the shorter 'TextIOWrapper.' prefix (14) vs 'BufferedReader.' prefix (15); confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: TextIOWrapper.readline.__qualname__.__len__
  args: []
  expected: 22

