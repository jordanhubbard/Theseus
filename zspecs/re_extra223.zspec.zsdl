spec: re_extra223
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module and function __name__ lengths; re.compile.__name__.__gt__('match') predicate."
    - "re.__name__ == 're'; len == 2; verified with Python 3.14.3."
    - "re.compile.__name__ == 'compile'; len == 7; verified with Python 3.14.3."
    - "re.match.__name__ == 'match'; len == 5; verified with Python 3.14.3."
    - "re.search.__name__ == 'search'; len == 6; verified with Python 3.14.3."
    - "re.fullmatch.__name__ == 'fullmatch'; len == 9; verified with Python 3.14.3."
    - "re.findall.__name__ == 'findall'; len == 7; verified with Python 3.14.3."
    - "re.finditer.__name__ == 'finditer'; len == 8; verified with Python 3.14.3."
    - "re.sub.__name__ == 'sub'; len == 3; verified with Python 3.14.3."
    - "re.subn.__name__ == 'subn'; len == 4; verified with Python 3.14.3."
    - "re.split.__name__ == 'split'; len == 5; verified with Python 3.14.3."
    - "re.escape.__name__ == 'escape'; len == 6; verified with Python 3.14.3."
    - "re.purge.__name__ == 'purge'; len == 5; verified with Python 3.14.3."
    - "re.compile.__name__.__gt__('match') == False — 'compile' < 'match' alphabetically ('c' < 'm'); verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re function __name__ lengths
# All public re functions; lengths verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table re_extra223.function_name_lengths:
  description: "re function __name__ lengths for compile, match, search, fullmatch, findall, finditer, sub, subn, split, escape, purge; verified with Python 3.14.3"
  kind: python_call_eq
  category: function_metadata
  id_prefix: refnnamelen223

  columns: [id, function, args, expected]
  rows:
    - [compile_len,   compile.__name__.__len__,   [], 7]
    - [match_len,     match.__name__.__len__,     [], 5]
    - [search_len,    search.__name__.__len__,    [], 6]
    - [fullmatch_len, fullmatch.__name__.__len__, [], 9]
    - [findall_len,   findall.__name__.__len__,   [], 7]
    - [finditer_len,  finditer.__name__.__len__,  [], 8]
    - [sub_len,       sub.__name__.__len__,       [], 3]
    - [subn_len,      subn.__name__.__len__,      [], 4]
    - [split_len,     split.__name__.__len__,     [], 5]
    - [escape_len,    escape.__name__.__len__,    [], 6]
    - [purge_len,     purge.__name__.__len__,     [], 5]

# ---------------------------------------------------------------------------
# re module __name__ length
# ---------------------------------------------------------------------------

invariant re_extra223.re.name.len:
  description: "re.__name__.__len__() == 2 — module name 're' has 2 characters; verified with Python 3.14.3"
  category: module_metadata
  kind: python_call_eq
  function: re.__name__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# re.compile.__name__.__gt__('match') predicate
# 'compile' < 'match' alphabetically because 'c' < 'm'.
# ---------------------------------------------------------------------------

invariant re_extra223.compile.name.gt_match:
  description: "re.compile.__name__.__gt__('match') == False — 'compile' is not greater than 'match'; 'c' < 'm' alphabetically; verified with Python 3.14.3"
  category: function_metadata
  kind: python_call_eq
  function: compile.__name__.__gt__
  args: ["match"]
  expected: false

# ---------------------------------------------------------------------------
# Standalone invariants for key function name lengths
# ---------------------------------------------------------------------------

invariant re_extra223.compile.name.len:
  description: "re.compile.__name__.__len__() == 7 — 'compile' has 7 characters; verified with Python 3.14.3"
  category: function_metadata
  kind: python_call_eq
  function: compile.__name__.__len__
  args: []
  expected: 7

invariant re_extra223.match.name.len:
  description: "re.match.__name__.__len__() == 5 — 'match' has 5 characters; verified with Python 3.14.3"
  category: function_metadata
  kind: python_call_eq
  function: match.__name__.__len__
  args: []
  expected: 5

invariant re_extra223.fullmatch.name.len:
  description: "re.fullmatch.__name__.__len__() == 9 — 'fullmatch' has 9 characters; verified with Python 3.14.3"
  category: function_metadata
  kind: python_call_eq
  function: fullmatch.__name__.__len__
  args: []
  expected: 9

invariant re_extra223.finditer.name.len:
  description: "re.finditer.__name__.__len__() == 8 — 'finditer' has 8 characters; verified with Python 3.14.3"
  category: function_metadata
  kind: python_call_eq
  function: finditer.__name__.__len__
  args: []
  expected: 8
