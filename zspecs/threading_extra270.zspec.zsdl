spec: threading_extra270
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Thread.name, daemon, ident, and native_id are all property objects (type == 'property')."
    - "Thread.name.fget.__name__ == 'name' (len=4); Thread.name.fget.__qualname__ == 'Thread.name' (len=11)."
    - "Thread.daemon.fget.__name__ == 'daemon' (len=6); Thread.daemon.fget.__qualname__ == 'Thread.daemon' (len=13)."
    - "Thread.ident.fget.__name__ == 'ident' (len=5); Thread.ident.fget.__qualname__ == 'Thread.ident' (len=12)."
    - "Thread.native_id.fget.__name__ == 'native_id' (len=9 — longest fget name); Thread.native_id.fget.__qualname__ == 'Thread.native_id' (len=16 — longest fget qualname)."
    - "Thread.start.__name__ == 'start' (len=5); __qualname__ == 'Thread.start' (len=12); __class__.__name__ == 'function'."
    - "Thread.join.__name__ == 'join' (len=4 — shortest method name); Thread.join.__qualname__ == 'Thread.join' (len=11)."
    - "Thread.is_alive.__name__ == 'is_alive' (len=8); Thread.run.__name__ == 'run' (len=3 — shortest overall)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Thread property fget identity
#
# name.fget.__name__ (4) < ident.fget.__name__ (5) < daemon.fget.__name__ (6)
# < native_id.fget.__name__ (9 — longest).
# All four properties have __qualname__ starting with 'Thread.'.
# ---------------------------------------------------------------------------

table threading_extra270.thread_property_fget_identity:
  description: "threading.Thread property fget identity — name(4), ident(5), daemon(6), native_id(9 longest) fget names; all qualnames start with 'Thread.'; all properties are type 'property'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex270p

  columns: [id, function, args, expected, description]
  rows:
    - [na_type_eq,          Thread.name.__class__.__name__.__eq__,       ["property"],                   true, "type(threading.Thread.name).__name__ == 'property'; verified with Python 3.14.3"]
    - [na_fget_name_eq,     Thread.name.fget.__name__.__eq__,            ["name"],                       true, "threading.Thread.name.fget.__name__ == 'name' (len=4); verified with Python 3.14.3"]
    - [na_fget_name_len,    Thread.name.fget.__name__.__len__,           [],                             4,    "threading.Thread.name.fget.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [na_fget_qn_eq,       Thread.name.fget.__qualname__.__eq__,        ["Thread.name"],                true, "threading.Thread.name.fget.__qualname__ == 'Thread.name' (len=11); verified with Python 3.14.3"]
    - [na_fget_qn_len,      Thread.name.fget.__qualname__.__len__,       [],                             11,   "threading.Thread.name.fget.__qualname__.__len__() == 11; verified with Python 3.14.3"]
    - [da_type_eq,          Thread.daemon.__class__.__name__.__eq__,     ["property"],                   true, "type(threading.Thread.daemon).__name__ == 'property'; verified with Python 3.14.3"]
    - [da_fget_name_eq,     Thread.daemon.fget.__name__.__eq__,          ["daemon"],                     true, "threading.Thread.daemon.fget.__name__ == 'daemon' (len=6); verified with Python 3.14.3"]
    - [da_fget_name_len,    Thread.daemon.fget.__name__.__len__,         [],                             6,    "threading.Thread.daemon.fget.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [da_fget_qn_eq,       Thread.daemon.fget.__qualname__.__eq__,      ["Thread.daemon"],              true, "threading.Thread.daemon.fget.__qualname__ == 'Thread.daemon' (len=13); verified with Python 3.14.3"]
    - [da_fget_qn_len,      Thread.daemon.fget.__qualname__.__len__,     [],                             13,   "threading.Thread.daemon.fget.__qualname__.__len__() == 13; verified with Python 3.14.3"]
    - [id_type_eq,          Thread.ident.__class__.__name__.__eq__,      ["property"],                   true, "type(threading.Thread.ident).__name__ == 'property'; verified with Python 3.14.3"]
    - [id_fget_name_eq,     Thread.ident.fget.__name__.__eq__,           ["ident"],                      true, "threading.Thread.ident.fget.__name__ == 'ident' (len=5); verified with Python 3.14.3"]
    - [id_fget_name_len,    Thread.ident.fget.__name__.__len__,          [],                             5,    "threading.Thread.ident.fget.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [id_fget_qn_eq,       Thread.ident.fget.__qualname__.__eq__,       ["Thread.ident"],               true, "threading.Thread.ident.fget.__qualname__ == 'Thread.ident' (len=12); verified with Python 3.14.3"]
    - [id_fget_qn_len,      Thread.ident.fget.__qualname__.__len__,      [],                             12,   "threading.Thread.ident.fget.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [ni_type_eq,          Thread.native_id.__class__.__name__.__eq__,  ["property"],                   true, "type(threading.Thread.native_id).__name__ == 'property'; verified with Python 3.14.3"]
    - [ni_fget_name_eq,     Thread.native_id.fget.__name__.__eq__,       ["native_id"],                  true, "threading.Thread.native_id.fget.__name__ == 'native_id' (len=9 — longest fget name); verified with Python 3.14.3"]
    - [ni_fget_name_len,    Thread.native_id.fget.__name__.__len__,      [],                             9,    "threading.Thread.native_id.fget.__name__.__len__() == 9 — longest property fget name in spec; verified with Python 3.14.3"]
    - [ni_fget_qn_eq,       Thread.native_id.fget.__qualname__.__eq__,   ["Thread.native_id"],           true, "threading.Thread.native_id.fget.__qualname__ == 'Thread.native_id' (len=16); verified with Python 3.14.3"]
    - [ni_fget_qn_len,      Thread.native_id.fget.__qualname__.__len__,  [],                             16,   "threading.Thread.native_id.fget.__qualname__.__len__() == 16 — longest fget qualname in spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# threading.Thread method identity: start, join, is_alive, run
#
# run.__name__ (3) is shortest.
# join.__name__ (4) < start.__name__ (5) < is_alive.__name__ (8).
# All four are 'function' class.
# ---------------------------------------------------------------------------

table threading_extra270.thread_method_identity:
  description: "threading.Thread methods start(5), join(4), is_alive(8), run(3) identity — run(3) shortest name; is_alive(8) longest name; all are function class with qualname 'Thread.<name>'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex270m

  columns: [id, function, args, expected, description]
  rows:
    - [st_name_eq,          Thread.start.__name__.__eq__,                ["start"],                      true, "threading.Thread.start.__name__ == 'start' (len=5); verified with Python 3.14.3"]
    - [st_name_len,         Thread.start.__name__.__len__,               [],                             5,    "threading.Thread.start.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [st_qn_eq,            Thread.start.__qualname__.__eq__,            ["Thread.start"],               true, "threading.Thread.start.__qualname__ == 'Thread.start' (len=12); verified with Python 3.14.3"]
    - [st_qn_len,           Thread.start.__qualname__.__len__,           [],                             12,   "threading.Thread.start.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [st_cls_eq,           Thread.start.__class__.__name__.__eq__,      ["function"],                   true, "threading.Thread.start.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [jo_name_eq,          Thread.join.__name__.__eq__,                 ["join"],                       true, "threading.Thread.join.__name__ == 'join' (len=4); verified with Python 3.14.3"]
    - [jo_name_len,         Thread.join.__name__.__len__,                [],                             4,    "threading.Thread.join.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [jo_qn_eq,            Thread.join.__qualname__.__eq__,             ["Thread.join"],                true, "threading.Thread.join.__qualname__ == 'Thread.join' (len=11); verified with Python 3.14.3"]
    - [jo_cls_eq,           Thread.join.__class__.__name__.__eq__,       ["function"],                   true, "threading.Thread.join.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [ia_name_eq,          Thread.is_alive.__name__.__eq__,             ["is_alive"],                   true, "threading.Thread.is_alive.__name__ == 'is_alive' (len=8 — longest method name); verified with Python 3.14.3"]
    - [ia_name_len,         Thread.is_alive.__name__.__len__,            [],                             8,    "threading.Thread.is_alive.__name__.__len__() == 8 — longest method name in spec; verified with Python 3.14.3"]
    - [ia_qn_eq,            Thread.is_alive.__qualname__.__eq__,         ["Thread.is_alive"],            true, "threading.Thread.is_alive.__qualname__ == 'Thread.is_alive' (len=15); verified with Python 3.14.3"]
    - [ia_cls_eq,           Thread.is_alive.__class__.__name__.__eq__,   ["function"],                   true, "threading.Thread.is_alive.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [ru_name_eq,          Thread.run.__name__.__eq__,                  ["run"],                        true, "threading.Thread.run.__name__ == 'run' (len=3 — shortest method name); verified with Python 3.14.3"]
    - [ru_name_len,         Thread.run.__name__.__len__,                 [],                             3,    "threading.Thread.run.__name__.__len__() == 3 — shortest method name in spec; verified with Python 3.14.3"]
    - [ru_qn_eq,            Thread.run.__qualname__.__eq__,              ["Thread.run"],                 true, "threading.Thread.run.__qualname__ == 'Thread.run' (len=10); verified with Python 3.14.3"]
    - [ru_cls_eq,           Thread.run.__class__.__name__.__eq__,        ["function"],                   true, "threading.Thread.run.__class__.__name__ == 'function'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra270
# ---------------------------------------------------------------------------

invariant threading_extra270.thread_name_is_property:
  description: "threading.Thread.name.__class__.__name__ == 'property' — name is a property descriptor; all four Thread properties (name, daemon, ident, native_id) are type 'property'"
  category: identity
  kind: python_call_eq
  function: Thread.name.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra270.thread_native_id_fget_name_is_longest:
  description: "threading.Thread.native_id.fget.__name__.__len__() == 9 — 'native_id' is the longest property fget name; longer than daemon(6), ident(5), name(4)"
  category: identity
  kind: python_call_eq
  function: Thread.native_id.fget.__name__.__len__
  args: []
  expected: 9

invariant threading_extra270.thread_run_name_is_shortest:
  description: "threading.Thread.run.__name__.__len__() == 3 — 'run' is the shortest method name in spec; shorter than join(4), start(5), is_alive(8)"
  category: identity
  kind: python_call_eq
  function: Thread.run.__name__.__len__
  args: []
  expected: 3

invariant threading_extra270.thread_is_alive_name_is_longest:
  description: "threading.Thread.is_alive.__name__.__len__() == 8 — 'is_alive' is the longest method name in spec; longer than start(5), join(4), run(3)"
  category: identity
  kind: python_call_eq
  function: Thread.is_alive.__name__.__len__
  args: []
  expected: 8

invariant threading_extra270.thread_start_is_function:
  description: "threading.Thread.start.__class__.__name__ == 'function' — start is a pure Python function; all Thread methods (start, join, is_alive, run) have __class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: Thread.start.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra270.thread_name_fget_qualname:
  description: "threading.Thread.name.fget.__qualname__ == 'Thread.name' (len=11) — fget qualname includes owning class prefix 'Thread.'"
  category: identity
  kind: python_call_eq
  function: Thread.name.fget.__qualname__.__eq__
  args: ["Thread.name"]
  expected: true
