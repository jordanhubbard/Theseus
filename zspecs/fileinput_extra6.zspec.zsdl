spec: fileinput_extra6
version: ">=3.9"
backend: python_module(fileinput)

docs: https://docs.python.org/3/library/fileinput.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fileinput.html — Python fileinput module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fileinput.py"
    - "fileinput_extra2.zspec.zsdl — covers FileInput.__qualname__ equality; function qualnames table for input/filename/fileno/lineno/filelineno/isfirstline/isstdin/nextfile/close/hook_compressed/hook_encoded"
    - "fileinput_extra3.zspec.zsdl — covers hook_compressed/__qualname__ and hook_encoded/__qualname__ standalone"
    - "fileinput_extra5.zspec.zsdl — covers qualname lengths for lineno/filelineno/isfirstline/isstdin/nextfile"
  notes:
    - "This spec extends fileinput.zspec.zsdl and all prior fileinput_extra specs through fileinput_extra5.zspec.zsdl."
    - "Focus: __qualname__ string lengths for FileInput/input/filename/fileno/hook_compressed/hook_encoded — not covered as standalone length invariants in any prior fileinput spec."
    - "fileinput_extra5 covers length for lineno/filelineno/isfirstline/isstdin/nextfile; this spec fills the remaining gaps."
    - "fileinput.FileInput.__qualname__.__len__() == 9 — 'FileInput' has 9 characters; qualname equality covered in extra2/3 but length not yet covered."
    - "fileinput.input.__qualname__.__len__() == 5 — 'input' has 5 characters; qualname equality covered in extra2/5 but length not yet covered."
    - "fileinput.filename.__qualname__.__len__() == 8 — 'filename' has 8 characters; qualname equality covered in extra2/5 but length not yet covered."
    - "fileinput.fileno.__qualname__.__len__() == 6 — 'fileno' has 6 characters; qualname equality covered in extra2/5 but length not yet covered."
    - "fileinput.hook_compressed.__qualname__.__len__() == 15 — 'hook_compressed' has 15 characters; qualname equality covered in extra2/3 but length not yet covered."
    - "fileinput.hook_encoded.__qualname__.__len__() == 12 — 'hook_encoded' has 12 characters; qualname equality covered in extra2/3 but length not yet covered."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ length table — FileInput, input, filename, fileno,
# hook_compressed, hook_encoded
#
# fileinput_extra5 covers qualname lengths for lineno/filelineno/isfirstline/
# isstdin/nextfile. No prior fileinput spec covers the __len__() for
# FileInput, input, filename, fileno, hook_compressed, or hook_encoded.
# This table anchors the remaining qualname-length facts in the extra6
# namespace.
# ---------------------------------------------------------------------------

table fileinput_extra6.qualname_lengths:
  description: "__qualname__ string length for FileInput class and hook/utility fileinput functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: qlen6

  columns: [id, function, args, expected]
  rows:
    - [FileInput,        FileInput.__qualname__.__len__,        [], 9]
    - [input,            input.__qualname__.__len__,            [], 5]
    - [filename,         filename.__qualname__.__len__,         [], 8]
    - [fileno,           fileno.__qualname__.__len__,           [], 6]
    - [hook_compressed,  hook_compressed.__qualname__.__len__,  [], 15]
    - [hook_encoded,     hook_encoded.__qualname__.__len__,     [], 12]

# ---------------------------------------------------------------------------
# Standalone qualname length invariants
# ---------------------------------------------------------------------------

invariant fileinput_extra6.FileInput.qualname_length:
  description: "fileinput.FileInput.__qualname__.__len__() == 9 — 'FileInput' has 9 characters"
  category: function_identity
  kind: python_call_eq
  function: FileInput.__qualname__.__len__
  args: []
  expected: 9

invariant fileinput_extra6.input.qualname_length:
  description: "fileinput.input.__qualname__.__len__() == 5 — 'input' has 5 characters"
  category: function_identity
  kind: python_call_eq
  function: input.__qualname__.__len__
  args: []
  expected: 5

invariant fileinput_extra6.filename.qualname_length:
  description: "fileinput.filename.__qualname__.__len__() == 8 — 'filename' has 8 characters"
  category: function_identity
  kind: python_call_eq
  function: filename.__qualname__.__len__
  args: []
  expected: 8

invariant fileinput_extra6.fileno.qualname_length:
  description: "fileinput.fileno.__qualname__.__len__() == 6 — 'fileno' has 6 characters"
  category: function_identity
  kind: python_call_eq
  function: fileno.__qualname__.__len__
  args: []
  expected: 6

invariant fileinput_extra6.hook_compressed.qualname_length:
  description: "fileinput.hook_compressed.__qualname__.__len__() == 15 — 'hook_compressed' has 15 characters"
  category: function_identity
  kind: python_call_eq
  function: hook_compressed.__qualname__.__len__
  args: []
  expected: 15

invariant fileinput_extra6.hook_encoded.qualname_length:
  description: "fileinput.hook_encoded.__qualname__.__len__() == 12 — 'hook_encoded' has 12 characters"
  category: function_identity
  kind: python_call_eq
  function: hook_encoded.__qualname__.__len__
  args: []
  expected: 12
