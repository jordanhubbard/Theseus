spec: theseus_getpass_cr
version: ">=3.9"
backend: python_cleanroom(theseus_getpass_cr)
blocks: getpass

docs: https://docs.python.org/3/library/getpass.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/getpass.html"
  notes:
    - "Clean-room user/login name utilities. Do NOT import getpass, os, or pwd."
    - "getuser(): return current username string (non-empty)."
    - "getpass(prompt): return a password string (in non-interactive mode, return empty string)."
    - "getpass_getuser_nonempty(): len(getuser()) > 0."
    - "getpass_getuser_is_str(): isinstance(getuser(), str) == True."
    - "getpass_returns_str(): isinstance(getpass(''), str) == True."
    - "Export: getuser() -> str, getpass(prompt='') -> str."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_getpass_cr.getuser_nonempty:
  description: "len(getuser()) > 0"
  category: getuser
  kind: python_call_eq
  function: getpass_getuser_nonempty
  args: []
  expected: true

invariant theseus_getpass_cr.getuser_is_str:
  description: "isinstance(getuser(), str) == True"
  category: getuser
  kind: python_call_eq
  function: getpass_getuser_is_str
  args: []
  expected: true

invariant theseus_getpass_cr.returns_str:
  description: "isinstance(getpass(''), str) == True"
  category: getpass
  kind: python_call_eq
  function: getpass_returns_str
  args: []
  expected: true
