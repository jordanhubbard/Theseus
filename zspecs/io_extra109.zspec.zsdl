spec: io_extra109
version: ">=3.9"
backend: python_module(io)
extends: io_extra99

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
  notes:
    - "This spec extends io_extra99.zspec.zsdl."
    - "This spec covers: io class __qualname__ values and lengths for all major io classes."
    - "io.BytesIO.__qualname__ = 'BytesIO' (length 7)."
    - "io.StringIO.__qualname__ = 'StringIO' (length 8)."
    - "io.BufferedReader.__qualname__ = 'BufferedReader' (length 14)."
    - "io.BufferedWriter.__qualname__ = 'BufferedWriter' (length 14)."
    - "io.FileIO.__qualname__ = 'FileIO' (length 6)."
    - "io.TextIOWrapper.__qualname__ = 'TextIOWrapper' (length 13)."
    - "io.IOBase.__qualname__ = 'IOBase' (length 6)."
    - "io.RawIOBase.__qualname__ = 'RawIOBase' (length 9)."
    - "io.BufferedIOBase.__qualname__ = 'BufferedIOBase' (length 14)."
    - "io.TextIOBase.__qualname__ = 'TextIOBase' (length 10)."
    - "io.UnsupportedOperation.__qualname__ = 'UnsupportedOperation' (length 20)."
    - "io.BufferedRandom.__qualname__ = 'BufferedRandom' (length 14)."
    - "For all io classes defined at module level, __qualname__ == __name__ (no nested class scoping)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io concrete class __qualname__ values (BytesIO, StringIO, BufferedReader,
# BufferedWriter, FileIO, TextIOWrapper)
# All are C extension types from _io. __qualname__ equals the class name
# (no nested scoping). Lengths: BytesIO=7, StringIO=8, BufferedReader=14,
# BufferedWriter=14, FileIO=6, TextIOWrapper=13.
# ---------------------------------------------------------------------------

table io_extra109.concrete_class_qualnames:
  description: "io concrete class __qualname__ values: BytesIO='BytesIO'(7), StringIO='StringIO'(8), BufferedReader='BufferedReader'(14), BufferedWriter='BufferedWriter'(14), FileIO='FileIO'(6), TextIOWrapper='TextIOWrapper'(13)"
  kind: python_call_eq
  category: class_names
  id_prefix: ioqualname109

  columns: [id, function, args, expected, description]
  rows:
    - [bytesio_qname_eq,    BytesIO.__qualname__.__eq__,       ["BytesIO"],        true,  "io.BytesIO.__qualname__ == 'BytesIO'"]
    - [bytesio_qname_len,   BytesIO.__qualname__.__len__,      [],                 7,     "io.BytesIO.__qualname__.__len__() == 7 ('BytesIO' has 7 characters)"]
    - [stringio_qname_eq,   StringIO.__qualname__.__eq__,      ["StringIO"],       true,  "io.StringIO.__qualname__ == 'StringIO'"]
    - [stringio_qname_len,  StringIO.__qualname__.__len__,     [],                 8,     "io.StringIO.__qualname__.__len__() == 8 ('StringIO' has 8 characters)"]
    - [br_qname_eq,         BufferedReader.__qualname__.__eq__,["BufferedReader"],  true,  "io.BufferedReader.__qualname__ == 'BufferedReader'"]
    - [br_qname_len,        BufferedReader.__qualname__.__len__,[],                14,     "io.BufferedReader.__qualname__.__len__() == 14 ('BufferedReader' has 14 characters)"]
    - [bw_qname_eq,         BufferedWriter.__qualname__.__eq__,["BufferedWriter"],  true,  "io.BufferedWriter.__qualname__ == 'BufferedWriter'"]
    - [bw_qname_len,        BufferedWriter.__qualname__.__len__,[],                14,     "io.BufferedWriter.__qualname__.__len__() == 14 ('BufferedWriter' has 14 characters)"]
    - [fileio_qname_eq,     FileIO.__qualname__.__eq__,        ["FileIO"],          true,  "io.FileIO.__qualname__ == 'FileIO'"]
    - [fileio_qname_len,    FileIO.__qualname__.__len__,       [],                  6,     "io.FileIO.__qualname__.__len__() == 6 ('FileIO' has 6 characters)"]
    - [tiow_qname_eq,       TextIOWrapper.__qualname__.__eq__, ["TextIOWrapper"],   true,  "io.TextIOWrapper.__qualname__ == 'TextIOWrapper'"]
    - [tiow_qname_len,      TextIOWrapper.__qualname__.__len__,[],                 13,     "io.TextIOWrapper.__qualname__.__len__() == 13 ('TextIOWrapper' has 13 characters)"]

# ---------------------------------------------------------------------------
# io abstract base class __qualname__ values (IOBase, RawIOBase, BufferedIOBase,
# TextIOBase, UnsupportedOperation, BufferedRandom)
# Lengths: IOBase=6, RawIOBase=9, BufferedIOBase=14, TextIOBase=10,
# UnsupportedOperation=20, BufferedRandom=14.
# ---------------------------------------------------------------------------

table io_extra109.abstract_class_qualnames:
  description: "io abstract class __qualname__ values: IOBase='IOBase'(6), RawIOBase='RawIOBase'(9), BufferedIOBase='BufferedIOBase'(14), TextIOBase='TextIOBase'(10), UnsupportedOperation='UnsupportedOperation'(20), BufferedRandom='BufferedRandom'(14)"
  kind: python_call_eq
  category: class_names
  id_prefix: ioqualname109

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_qname_eq,     IOBase.__qualname__.__eq__,            ["IOBase"],             true,  "io.IOBase.__qualname__ == 'IOBase'"]
    - [iobase_qname_len,    IOBase.__qualname__.__len__,           [],                     6,     "io.IOBase.__qualname__.__len__() == 6 ('IOBase' has 6 characters)"]
    - [rawiobase_qname_eq,  RawIOBase.__qualname__.__eq__,         ["RawIOBase"],           true,  "io.RawIOBase.__qualname__ == 'RawIOBase'"]
    - [rawiobase_qname_len, RawIOBase.__qualname__.__len__,        [],                     9,     "io.RawIOBase.__qualname__.__len__() == 9 ('RawIOBase' has 9 characters)"]
    - [bufiobase_qname_eq,  BufferedIOBase.__qualname__.__eq__,    ["BufferedIOBase"],      true,  "io.BufferedIOBase.__qualname__ == 'BufferedIOBase'"]
    - [bufiobase_qname_len, BufferedIOBase.__qualname__.__len__,   [],                    14,     "io.BufferedIOBase.__qualname__.__len__() == 14 ('BufferedIOBase' has 14 characters)"]
    - [txiobase_qname_eq,   TextIOBase.__qualname__.__eq__,        ["TextIOBase"],          true,  "io.TextIOBase.__qualname__ == 'TextIOBase'"]
    - [txiobase_qname_len,  TextIOBase.__qualname__.__len__,       [],                    10,     "io.TextIOBase.__qualname__.__len__() == 10 ('TextIOBase' has 10 characters)"]
    - [unsupop_qname_eq,    UnsupportedOperation.__qualname__.__eq__,["UnsupportedOperation"],true,"io.UnsupportedOperation.__qualname__ == 'UnsupportedOperation'"]
    - [unsupop_qname_len,   UnsupportedOperation.__qualname__.__len__,[],                 20,     "io.UnsupportedOperation.__qualname__.__len__() == 20 ('UnsupportedOperation' has 20 characters)"]
    - [bufrnd_qname_eq,     BufferedRandom.__qualname__.__eq__,    ["BufferedRandom"],      true,  "io.BufferedRandom.__qualname__ == 'BufferedRandom'"]
    - [bufrnd_qname_len,    BufferedRandom.__qualname__.__len__,   [],                    14,     "io.BufferedRandom.__qualname__.__len__() == 14 ('BufferedRandom' has 14 characters)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra109.BytesIO.qualname_is_BytesIO:
  description: "io.BytesIO.__qualname__ == 'BytesIO' (for module-level classes, __qualname__ equals the bare class name with no enclosing scope prefix)"
  category: class_names
  kind: python_call_eq
  function: BytesIO.__qualname__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra109.BytesIO.qualname_len_7:
  description: "io.BytesIO.__qualname__.__len__() == 7 ('BytesIO' has 7 characters: B-y-t-e-s-I-O)"
  category: class_names
  kind: python_call_eq
  function: BytesIO.__qualname__.__len__
  args: []
  expected: 7

invariant io_extra109.UnsupportedOperation.qualname_len_20:
  description: "io.UnsupportedOperation.__qualname__.__len__() == 20 ('UnsupportedOperation' is the longest __qualname__ among io classes at 20 characters)"
  category: class_names
  kind: python_call_eq
  function: UnsupportedOperation.__qualname__.__len__
  args: []
  expected: 20

invariant io_extra109.TextIOWrapper.qualname_len_13:
  description: "io.TextIOWrapper.__qualname__.__len__() == 13 ('TextIOWrapper' has 13 characters: T-e-x-t-I-O-W-r-a-p-p-e-r)"
  category: class_names
  kind: python_call_eq
  function: TextIOWrapper.__qualname__.__len__
  args: []
  expected: 13

invariant io_extra109.BufferedIOBase.qualname_is_BufferedIOBase:
  description: "io.BufferedIOBase.__qualname__ == 'BufferedIOBase' (the abstract base for buffered I/O; __qualname__ is the unqualified class name)"
  category: class_names
  kind: python_call_eq
  function: BufferedIOBase.__qualname__.__eq__
  args: ["BufferedIOBase"]
  expected: true
