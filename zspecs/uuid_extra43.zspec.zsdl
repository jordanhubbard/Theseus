spec: uuid_extra43
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra42.zspec.zsdl — covers UUID.time_low/time_mid/clock_seq_low fget.__qualname__.__eq__, getnode.__module__.__eq__('uuid'), uuid4/getnode/UUID __module__.__class__.__name__.__eq__('str')."
    - "uuid_extra41.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/getnode/module __doc__.__class__.__name__.__eq__('str') and UUID.hex/int/bytes/version .fget.__qualname__.__eq__."
    - "uuid_extra40.zspec.zsdl — covers UUID.hex/int/bytes/version/urn/variant/node/time/is_safe __class__.__qualname__.__eq__('property') and __class__.__qualname__.__len__()==8."
    - "uuid_extra39.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/getnode/NAMESPACE_DNS __class__.__qualname__.__eq__ and __class__.__module__.__eq__."
    - "uuid_extra38.zspec.zsdl — covers UUID/__class__.__name__.__eq__('type'), uuid4/uuid1/uuid3/uuid5/NAMESPACE_DNS/getnode.__class__.__name__.__eq__, UUID.time.fget.__class__.__name__.__eq__('function')."
    - "uuid_extra36.zspec.zsdl — covers UUID dunder method __module__.__eq__('uuid') for __repr__/__hash__/__eq__/__int__/__lt__/__le__/__gt__/__ge__."
    - "uuid_extra35.zspec.zsdl — covers UUID dunder method __name__.__eq__ string values."
    - "uuid_extra16.zspec.zsdl — covers UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__ __qualname__.__eq__ and __qualname__.__len__() (already covers all dunder method qualname axes)."
  notes:
    - "This spec extends uuid through uuid_extra42; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: No prior uuid spec checks __class__.__name__.__eq__('UUID') for NAMESPACE_URL, NAMESPACE_OID, or NAMESPACE_X500. uuid_extra38 covers NAMESPACE_DNS.__class__.__name__.__eq__('UUID') (only DNS). The four NAMESPACE_* constants (DNS, URL, OID, X500) are all UUID instances defined in RFC 4122, but only DNS has been checked via __class__.__name__. URL, OID, and X500 are novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID'. NAMESPACE_URL is a UUID instance (RFC 4122 §C, URL namespace). Its __class__.__name__ is 'UUID'. uuid_extra38 covers only NAMESPACE_DNS. No prior spec checks NAMESPACE_URL.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID'. NAMESPACE_OID is a UUID instance (RFC 4122 §C, OID namespace). Its __class__.__name__ is 'UUID'. No prior spec checks NAMESPACE_OID.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID'. NAMESPACE_X500 is a UUID instance (RFC 4122 §C, X.500 namespace). Its __class__.__name__ is 'UUID'. No prior spec checks NAMESPACE_X500.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior uuid spec checks __class__.__qualname__.__eq__('UUID') for NAMESPACE_URL, NAMESPACE_OID, or NAMESPACE_X500. uuid_extra39 covers NAMESPACE_DNS.__class__.__qualname__.__eq__('UUID') (only DNS). The __qualname__ axis is distinct from __name__; for non-nested classes they are equal, but the access chain is independent. URL, OID, and X500 are novel on this axis. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__qualname__ == 'UUID'. uuid.UUID.__qualname__ is 'UUID'. uuid_extra39 covers NAMESPACE_DNS only. No prior spec checks NAMESPACE_URL.__class__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.__class__.__qualname__ == 'UUID'. uuid_extra39 covers NAMESPACE_DNS only. No prior spec checks NAMESPACE_OID.__class__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.__class__.__qualname__ == 'UUID'. uuid_extra39 covers NAMESPACE_DNS only. No prior spec checks NAMESPACE_X500.__class__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior uuid spec checks __class__.__module__.__eq__('uuid') for NAMESPACE_URL, NAMESPACE_OID, or NAMESPACE_X500. uuid_extra39 covers NAMESPACE_DNS.__class__.__module__.__eq__('uuid') (only DNS). uuid.UUID is defined in Lib/uuid.py, so any UUID instance's __class__.__module__ is 'uuid'. URL, OID, and X500 are novel on this axis. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__module__ == 'uuid'. uuid.UUID is defined in Lib/uuid.py; NAMESPACE_URL is a UUID instance. uuid_extra39 covers NAMESPACE_DNS only. No prior spec checks NAMESPACE_URL.__class__.__module__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.__class__.__module__ == 'uuid'. No prior spec checks NAMESPACE_OID.__class__.__module__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.__class__.__module__ == 'uuid'. No prior spec checks NAMESPACE_X500.__class__.__module__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_URL / NAMESPACE_OID / NAMESPACE_X500 __class__.__name__
#
# uuid_extra38 covers NAMESPACE_DNS.__class__.__name__.__eq__('UUID') (only DNS).
# The three remaining RFC 4122 namespace constants (URL, OID, X500) are all
# UUID instances and have not been checked on the __class__.__name__ axis.
# This table completes the NAMESPACE_* coverage for __class__.__name__.
# ---------------------------------------------------------------------------

table uuid_extra43.namespace_class_names:
  description: "uuid.NAMESPACE_URL/OID/X500 __class__.__name__.__eq__('UUID') — all three are UUID instances (RFC 4122 §C); uuid_extra38 covers only NAMESPACE_DNS on this axis; no prior spec checks __class__.__name__.__eq__('UUID') for NAMESPACE_URL, NAMESPACE_OID, or NAMESPACE_X500"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidmeth43

  columns: [id, function, args, expected]
  rows:
    - [NAMESPACE_URL_class_name_eq,   NAMESPACE_URL.__class__.__name__.__eq__,   ["UUID"], true]
    - [NAMESPACE_OID_class_name_eq,   NAMESPACE_OID.__class__.__name__.__eq__,   ["UUID"], true]
    - [NAMESPACE_X500_class_name_eq,  NAMESPACE_X500.__class__.__name__.__eq__,  ["UUID"], true]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_URL / NAMESPACE_OID / NAMESPACE_X500 __class__.__qualname__
#
# uuid_extra39 covers NAMESPACE_DNS.__class__.__qualname__.__eq__('UUID') (only DNS).
# The __qualname__ axis is distinct from __name__ — for non-nested classes the
# values are equal, but the attribute access chain is independent, providing a
# separate regression vector. URL, OID, and X500 are novel on this axis.
# ---------------------------------------------------------------------------

table uuid_extra43.namespace_class_qualnames:
  description: "uuid.NAMESPACE_URL/OID/X500 __class__.__qualname__.__eq__('UUID') — uuid.UUID.__qualname__ == 'UUID'; uuid_extra39 covers NAMESPACE_DNS only on this axis; no prior spec checks __class__.__qualname__.__eq__('UUID') for NAMESPACE_URL, NAMESPACE_OID, or NAMESPACE_X500"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidmeth43

  columns: [id, function, args, expected]
  rows:
    - [NAMESPACE_URL_class_qualname_eq,  NAMESPACE_URL.__class__.__qualname__.__eq__,  ["UUID"], true]
    - [NAMESPACE_OID_class_qualname_eq,  NAMESPACE_OID.__class__.__qualname__.__eq__,  ["UUID"], true]
    - [NAMESPACE_X500_class_qualname_eq, NAMESPACE_X500.__class__.__qualname__.__eq__, ["UUID"], true]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_URL / NAMESPACE_OID / NAMESPACE_X500 __class__.__module__
#
# uuid_extra39 covers NAMESPACE_DNS.__class__.__module__.__eq__('uuid') (only DNS).
# uuid.UUID is defined in Lib/uuid.py; any UUID instance's __class__.__module__
# is 'uuid'. URL, OID, and X500 are novel on this axis. This confirms that the
# UUID class remains defined in the uuid module for all four RFC 4122 namespace
# constants.
# ---------------------------------------------------------------------------

table uuid_extra43.namespace_class_modules:
  description: "uuid.NAMESPACE_URL/OID/X500 __class__.__module__.__eq__('uuid') — uuid.UUID is defined in Lib/uuid.py; uuid_extra39 covers NAMESPACE_DNS only on this axis; no prior spec checks __class__.__module__.__eq__('uuid') for NAMESPACE_URL, NAMESPACE_OID, or NAMESPACE_X500"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidmeth43

  columns: [id, function, args, expected]
  rows:
    - [NAMESPACE_URL_class_module_eq,   NAMESPACE_URL.__class__.__module__.__eq__,   ["uuid"], true]
    - [NAMESPACE_OID_class_module_eq,   NAMESPACE_OID.__class__.__module__.__eq__,   ["uuid"], true]
    - [NAMESPACE_X500_class_module_eq,  NAMESPACE_X500.__class__.__module__.__eq__,  ["uuid"], true]
