spec: bisect_extra_rust
version: ">=3.9"
backend: rust_module(bisect_extra_rust)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — bisect stdlib"
  notes:
    - "bisect provides binary search algorithm."
    - "bisect.bisect_left([1,2,3,4,5], 3) == 2."
    - "bisect.bisect_right([1,2,3,4,5], 3) == 3."
    - "bisect.insort([1,3,5], 4) modifies the list in-place."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant bisect_extra_rust.bisect_left_3:
  description: "bisect.bisect_left([1,2,3,4,5], 3) == 2"
  category: bisect_left
  kind: python_call_eq
  function: bisect_extra_bisect_left_3
  args: []
  expected: 2

invariant bisect_extra_rust.bisect_right_3:
  description: "bisect.bisect_right([1,2,3,4,5], 3) == 3"
  category: bisect_right
  kind: python_call_eq
  function: bisect_extra_bisect_right_3
  args: []
  expected: 3

invariant bisect_extra_rust.has_insort:
  description: "bisect.insort is callable"
  category: presence
  kind: python_call_eq
  function: bisect_extra_has_insort
  args: []
  expected: true

