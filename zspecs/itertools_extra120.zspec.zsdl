spec: itertools_extra120
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra119.zspec.zsdl."
    - "This spec covers: itertools.product and itertools.permutations class slot attributes not yet covered — product.__iter__.__qualname__ ('product.__iter__', len 16), permutations.__next__.__qualname__ ('permutations.__next__', len 21), permutations.__iter__.__qualname__ ('permutations.__iter__', len 21), combinations.__next__.__qualname__ ('combinations.__next__', len 21); wave 271."
    - "Prior spec extra23 covered product.__next__.__qualname__ == 'product.__next__' (True). New here: product.__iter__ and all permutations/combinations slot qualnames."
    - "itertools.product.__iter__.__qualname__ == 'product.__iter__' (len 16). Verified with Python 3.14.3."
    - "itertools.permutations.__next__.__qualname__ == 'permutations.__next__' (len 21). Verified with Python 3.14.3."
    - "itertools.permutations.__iter__.__qualname__ == 'permutations.__iter__' (len 21). Verified with Python 3.14.3."
    - "itertools.combinations.__next__.__qualname__ == 'combinations.__next__' (len 21). Verified with Python 3.14.3."
    - "itertools.permutations.__name__.__len__() == 12. Verified with Python 3.14.3."
    - "itertools.combinations.__name__.__len__() == 12. Verified with Python 3.14.3."
    - "12 (class name) + 1 (dot) + 8 (__next__/__iter__) == 21 for both permutations and combinations slots."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.product.__iter__ slot qualname
#
# Wave 271 theme: itertools.product is a C-extension combinatoric type that
# yields the cartesian product of input iterables. Prior spec extra23 established
# product.__next__.__qualname__ == 'product.__next__' (True). New here: the
# tp_iter slot __iter__. 'product' has 7 chars, so both slots have qualname
# length 7+1+8 = 16 — identical to starmap (also 7-char class name, covered in
# extra119). product.__iter__.__class__.__name__ == 'wrapper_descriptor' like
# all itertools C iterator slots covered previously.
#
# product.__iter__.__qualname__ == 'product.__iter__'  (len 16)
# product.__iter__.__class__.__name__ == 'wrapper_descriptor'
#
# New to extra120.
# ---------------------------------------------------------------------------

table itertools_extra120.product_iter_qualname:
  description: "itertools.product.__iter__ slot qualname: 'product.__iter__'(16); 7-char class name gives 7+1+8=16; equal to starmap.__iter__ qualname length (extra119); wrapper_descriptor; wave 271; new to extra120"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolspiq120

  columns: [id, function, args, expected, description]
  rows:
    - [product_iter_qualname_eq,
       "product.__iter__.__qualname__.__eq__",
       ["product.__iter__"],
       true,
       "itertools.product.__iter__.__qualname__.__eq__('product.__iter__') == True — product exposes its tp_iter C slot as __iter__; qualname is 'product.__iter__' (16 chars); str.__eq__('product.__iter__') returns True; new to extra120"]
    - [product_iter_qualname_len,
       "product.__iter__.__qualname__.__len__",
       [],
       16,
       "itertools.product.__iter__.__qualname__.__len__() == 16 — 'product.__iter__' has 16 chars: product(7)+dot(1)+__iter__(8); equal to product.__next__.__qualname__ length (also 16); str.__len__() returns 16; new to extra120"]
    - [product_iter_class_name,
       "product.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.product.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — C tp_iter slot on product is a wrapper_descriptor; same type as all other itertools slot descriptors; str.__eq__('wrapper_descriptor') returns True; new to extra120"]
    - [product_name_len,
       "product.__name__.__len__",
       [],
       7,
       "itertools.product.__name__.__len__() == 7 — 'product' has 7 chars: p-r-o-d-u-c-t; same as 'starmap' (extra119) — both 7-char names give slot qualname length 16; str.__len__() returns 7; new to extra120"]
    - [product_next_iter_qualname_eq_len,
       "product.__next__.__qualname__.__len__",
       [],
       16,
       "itertools.product.__next__.__qualname__.__len__() == 16 — confirming __next__ and __iter__ share qualname length 16 for product; both 7+1+8; prior extra23 verified the qualname value; str.__len__() returns 16; new to extra120"]

# ---------------------------------------------------------------------------
# Table 2: itertools.permutations __next__ and __iter__ slot qualnames
#
# Wave 271 theme: itertools.permutations is a C-extension type that yields
# all r-length permutations of elements from an input iterable. 'permutations'
# has 12 chars, so its slot qualnames have length 12+1+8 = 21:
# 'permutations.__next__' and 'permutations.__iter__'. This is 5 more than
# product/starmap (16, 7-char names) and equal to combinations (also 12 chars).
# Previously covered for permutations: __name__, __qualname__, __module__,
# __mro__.__len__(). NOT previously covered: __next__ and __iter__ slot qualnames.
#
# permutations.__next__.__qualname__ == 'permutations.__next__'  (len 21)
# permutations.__iter__.__qualname__ == 'permutations.__iter__'  (len 21)
#
# New to extra120.
# ---------------------------------------------------------------------------

table itertools_extra120.permutations_next_iter_qualnames:
  description: "itertools.permutations slot qualnames: __next__='permutations.__next__'(21), __iter__='permutations.__iter__'(21); 12-char class name gives 12+1+8=21; both equal length; wave 271; new to extra120"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolspmniq120

  columns: [id, function, args, expected, description]
  rows:
    - [perms_next_qualname_eq,
       "permutations.__next__.__qualname__.__eq__",
       ["permutations.__next__"],
       true,
       "itertools.permutations.__next__.__qualname__.__eq__('permutations.__next__') == True — permutations exposes its tp_iternext slot as __next__; qualname is 'permutations.__next__' (21 chars); str.__eq__('permutations.__next__') returns True; new to extra120"]
    - [perms_next_qualname_len,
       "permutations.__next__.__qualname__.__len__",
       [],
       21,
       "itertools.permutations.__next__.__qualname__.__len__() == 21 — 'permutations.__next__' has 21 chars: permutations(12)+dot(1)+__next__(8); 5 more than product (16) because 'permutations' is 12 chars vs 7; str.__len__() returns 21; new to extra120"]
    - [perms_iter_qualname_eq,
       "permutations.__iter__.__qualname__.__eq__",
       ["permutations.__iter__"],
       true,
       "itertools.permutations.__iter__.__qualname__.__eq__('permutations.__iter__') == True — permutations exposes its tp_iter slot as __iter__; qualname is 'permutations.__iter__' (21 chars); str.__eq__('permutations.__iter__') returns True; new to extra120"]
    - [perms_iter_qualname_len,
       "permutations.__iter__.__qualname__.__len__",
       [],
       21,
       "itertools.permutations.__iter__.__qualname__.__len__() == 21 — 'permutations.__iter__' has 21 chars: permutations(12)+dot(1)+__iter__(8); equal to __next__ qualname length (21); str.__len__() returns 21; new to extra120"]
    - [perms_name_len,
       "permutations.__name__.__len__",
       [],
       12,
       "itertools.permutations.__name__.__len__() == 12 — 'permutations' has 12 chars: p-e-r-m-u-t-a-t-i-o-n-s; 5 more than 'product' (7); drives slot qualname length 21; str.__len__() returns 12; new to extra120"]

# ---------------------------------------------------------------------------
# Table 3: itertools.combinations __next__ qualname and length comparison
#
# Wave 271 theme: itertools.combinations also has 12 chars in its name, so
# its __next__ and __iter__ slot qualnames also have length 21 — equal to
# permutations. The coincidence (permutations and combinations share name
# length 12 and hence slot qualname length 21) is notable: two distinct
# combinatoric types with the same length name. The formula
# qualname_len = class_name_len + 1 + slot_name_len is confirmed again.
# Also: combinations.__name__.__len__() == 12 (same as permutations).
#
# combinations.__next__.__qualname__ == 'combinations.__next__'  (len 21)
# combinations.__name__.__len__() == 12
# permutations.__name__.__len__() == 12
#
# New to extra120.
# ---------------------------------------------------------------------------

table itertools_extra120.combinations_next_qualname_and_comparison:
  description: "itertools.combinations.__next__ qualname: 'combinations.__next__'(21); combinations and permutations both have 12-char names giving slot qualname len=21; equal length despite different semantics; wave 271; new to extra120"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscnq120

  columns: [id, function, args, expected, description]
  rows:
    - [combs_next_qualname_eq,
       "combinations.__next__.__qualname__.__eq__",
       ["combinations.__next__"],
       true,
       "itertools.combinations.__next__.__qualname__.__eq__('combinations.__next__') == True — combinations exposes its tp_iternext slot as __next__; qualname is 'combinations.__next__' (21 chars); str.__eq__('combinations.__next__') returns True; new to extra120"]
    - [combs_next_qualname_len,
       "combinations.__next__.__qualname__.__len__",
       [],
       21,
       "itertools.combinations.__next__.__qualname__.__len__() == 21 — 'combinations.__next__' has 21 chars: combinations(12)+dot(1)+__next__(8); same length as permutations.__next__.__qualname__ (also 21); str.__len__() returns 21; new to extra120"]
    - [combs_name_len,
       "combinations.__name__.__len__",
       [],
       12,
       "itertools.combinations.__name__.__len__() == 12 — 'combinations' has 12 chars: c-o-m-b-i-n-a-t-i-o-n-s; equal to 'permutations' (12); both drive slot qualname length 21; str.__len__() returns 12; new to extra120"]
    - [perms_combs_name_len_equal,
       "permutations.__name__.__len__",
       [],
       12,
       "itertools.permutations.__name__.__len__() == 12 — confirming equal length with combinations (also 12); two distinct combinatoric types share the same class name length; str.__len__() returns 12; new to extra120"]
    - [combs_iter_class_name,
       "combinations.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.combinations.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — C tp_iter slot on combinations is a wrapper_descriptor; same type as all other itertools iterator slot descriptors; str.__eq__('wrapper_descriptor') returns True; new to extra120"]
    - [perms_next_class_name,
       "permutations.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.permutations.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — C tp_iternext slot on permutations is a wrapper_descriptor; same type as starmap.__next__, filterfalse.__next__, product.__next__; str.__eq__('wrapper_descriptor') returns True; new to extra120"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra120
# ---------------------------------------------------------------------------

invariant itertools_extra120.product_iter_qualname:
  description: "itertools.product.__iter__.__qualname__ == 'product.__iter__' — tp_iter slot; qualname length 16; 7-char class name; prior extra23 verified __next__; wave 271; new to extra120"
  kind: python_call_eq
  function: product.__iter__.__qualname__.__eq__
  args: ["product.__iter__"]
  expected: true

invariant itertools_extra120.perms_next_qualname:
  description: "itertools.permutations.__next__.__qualname__ == 'permutations.__next__' — tp_iternext slot; qualname length 21; 12-char class name; wave 271; new to extra120"
  kind: python_call_eq
  function: permutations.__next__.__qualname__.__eq__
  args: ["permutations.__next__"]
  expected: true

invariant itertools_extra120.perms_iter_qualname:
  description: "itertools.permutations.__iter__.__qualname__ == 'permutations.__iter__' — tp_iter slot; qualname length 21; equal to __next__ qualname length; wave 271; new to extra120"
  kind: python_call_eq
  function: permutations.__iter__.__qualname__.__eq__
  args: ["permutations.__iter__"]
  expected: true

invariant itertools_extra120.combs_next_qualname:
  description: "itertools.combinations.__next__.__qualname__ == 'combinations.__next__' — tp_iternext slot; qualname length 21; equal to permutations (both 12-char names); wave 271; new to extra120"
  kind: python_call_eq
  function: combinations.__next__.__qualname__.__eq__
  args: ["combinations.__next__"]
  expected: true

invariant itertools_extra120.perms_name_len:
  description: "itertools.permutations.__name__.__len__() == 12 — 'permutations' has 12 chars; drives slot qualname length 21; equal to combinations name length; wave 271; new to extra120"
  kind: python_call_eq
  function: permutations.__name__.__len__
  args: []
  expected: 12

