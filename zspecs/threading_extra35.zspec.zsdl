spec: threading_extra35
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra34.zspec.zsdl."
    - "Prior specs covered: Thread.__name__/__qualname__/__len__()==6; Lock.__name__.__len__()==4 ('lock'); RLock.__name__.__len__()==5; Event.__name__/__qualname__.__len__()==5; Thread/__mro__.__len__()==2; BoundedSemaphore/__mro__.__len__()==3; Event/__mro__.__len__()==2; Timer/__mro__.__len__()==3; Condition/__mro__.__len__()==2; Barrier/__mro__.__len__()==2; Semaphore/__mro__.__len__()==2; BoundedSemaphore/__bases__[0].__name__.__len__()==9 ('Semaphore'); Barrier/__bases__[0].__name__=='object'; Condition/__bases__[0].__name__=='object'; Thread method qualname lengths (start=12/run=10/join=11/is_alive=15); threading module metadata lengths; class __dict__.__class__.__name__.__len__() for all major classes (all 12)."
    - "This spec covers: Semaphore.__name__.__len__() (9 — 'Semaphore'); Semaphore.__qualname__.__len__() (9 — 'Semaphore'); Condition.__name__.__len__() (9 — 'Condition'); Condition.__qualname__.__len__() (9 — 'Condition'); Barrier.__name__.__len__() (7 — 'Barrier'); Barrier.__qualname__.__len__() (7 — 'Barrier'); Timer.__name__.__len__() (5 — 'Timer'); Timer.__qualname__.__len__() (5 — 'Timer'); Timer.__bases__[0].__name__.__len__() (6 — 'Thread'); threading.local.__name__.__len__() (6 — '_local', not 'local'); threading.local.__qualname__.__len__() (6 — '_local')."
    - "Key findings: Semaphore.__name__ is 'Semaphore' (9 chars) and Condition.__name__ is 'Condition' (9 chars) — both 9-char class names. Barrier.__name__ is 'Barrier' (7 chars). Timer.__name__ is 'Timer' (5 chars) — same length as Event. Timer.__bases__[0].__name__ is 'Thread' (6 chars) — Timer is a Thread subclass. threading.local.__name__ is '_local' (6 chars, with leading underscore) — the public alias 'local' maps to the C extension type _thread._local whose __name__ is '_local'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Semaphore/Condition __name__/__qualname__ lengths table — extra35 namespace
#
# threading.Semaphore.__name__ is 'Semaphore' (9 chars). threading.Semaphore.__qualname__
# is also 'Semaphore' (9 chars). threading.Condition.__name__ is 'Condition' (9 chars).
# threading.Condition.__qualname__ is also 'Condition' (9 chars). Both share the same
# 9-char length — same as BoundedSemaphore.__bases__[0].__name__.__len__() (==9,'Semaphore').
# Prior specs confirmed __mro__.__len__()==2 for both and __bases__[0].__name__=='object',
# but not their own __name__/__qualname__ lengths explicitly. No prior threading spec
# records these four values together in the extra35 namespace.
# ---------------------------------------------------------------------------

table threading_extra35.semaphore_condition_name_lengths:
  description: "threading.Semaphore and Condition __name__/__qualname__ lengths — all 9"
  kind: python_call_eq
  category: string_properties
  id_prefix: semcondnamelen35

  columns: [id, function, args, expected, description]
  rows:
    - [Semaphore_name,
       Semaphore.__name__.__len__,
       [],
       9,
       "len(threading.Semaphore.__name__) == 9 — 'Semaphore'"]
    - [Semaphore_qualname,
       Semaphore.__qualname__.__len__,
       [],
       9,
       "len(threading.Semaphore.__qualname__) == 9 — 'Semaphore' (not a nested class)"]
    - [Condition_name,
       Condition.__name__.__len__,
       [],
       9,
       "len(threading.Condition.__name__) == 9 — 'Condition'"]
    - [Condition_qualname,
       Condition.__qualname__.__len__,
       [],
       9,
       "len(threading.Condition.__qualname__) == 9 — 'Condition' (not a nested class)"]

# ---------------------------------------------------------------------------
# Barrier/Timer __name__/__qualname__ lengths and Timer.__bases__ table — extra35 namespace
#
# threading.Barrier.__name__ is 'Barrier' (7 chars). threading.Barrier.__qualname__
# is also 'Barrier' (7 chars). threading.Timer.__name__ is 'Timer' (5 chars).
# threading.Timer.__qualname__ is also 'Timer' (5 chars). threading.Timer.__bases__[0].
# __name__ is 'Thread' (6 chars) — Timer is a Thread subclass, not a direct object
# subclass. Prior specs covered Barrier/__mro__.__len__()==2 and Barrier/__bases__[0].
# __name__=='object', and Timer/__mro__.__len__()==3, but not Barrier/__name__ lengths
# or Timer/__name__ lengths explicitly. No prior threading spec records these five
# values together in a combined table in the extra35 namespace.
# ---------------------------------------------------------------------------

table threading_extra35.barrier_timer_name_lengths:
  description: "threading.Barrier and Timer __name__/__qualname__ lengths, and Timer.__bases__[0].__name__ length"
  kind: python_call_eq
  category: string_properties
  id_prefix: barrtimrnamelen35

  columns: [id, function, args, expected, description]
  rows:
    - [Barrier_name,
       Barrier.__name__.__len__,
       [],
       7,
       "len(threading.Barrier.__name__) == 7 — 'Barrier'"]
    - [Barrier_qualname,
       Barrier.__qualname__.__len__,
       [],
       7,
       "len(threading.Barrier.__qualname__) == 7 — 'Barrier' (not a nested class)"]
    - [Timer_name,
       Timer.__name__.__len__,
       [],
       5,
       "len(threading.Timer.__name__) == 5 — 'Timer' (same length as Event)"]
    - [Timer_qualname,
       Timer.__qualname__.__len__,
       [],
       5,
       "len(threading.Timer.__qualname__) == 5 — 'Timer' (not a nested class)"]
    - [Timer_base_name,
       "Timer.__bases__[0].__name__.__len__",
       [],
       6,
       "len(threading.Timer.__bases__[0].__name__) == 6 — 'Thread' (Timer subclasses Thread, not object directly)"]

# ---------------------------------------------------------------------------
# threading.local __name__ and __qualname__ lengths — standalone invariants
#
# threading.local.__name__ is '_local' (6 chars, with leading underscore). The public
# alias 'threading.local' maps to _thread._local, a C extension type whose real
# __name__ is '_local' — not 'local'. This is analogous to threading.Lock.__name__
# being 'lock' (lowercase) rather than 'Lock'. threading.local.__qualname__ is also
# '_local' (6 chars). No prior threading spec records threading.local.__name__.__len__()
# or threading.local.__qualname__.__len__() as standalones in the extra35 namespace.
# ---------------------------------------------------------------------------

invariant threading_extra35.local_name_len:
  description: "len(threading.local.__name__) == 6 — '_local' (C extension type, not 'local'; has leading underscore)"
  category: string_properties
  kind: python_call_eq
  function: "local.__name__.__len__"
  args: []
  expected: 6

invariant threading_extra35.local_qualname_len:
  description: "len(threading.local.__qualname__) == 6 — '_local' (qualname matches __name__ for top-level C type)"
  category: string_properties
  kind: python_call_eq
  function: "local.__qualname__.__len__"
  args: []
  expected: 6
