spec: threading_extra2086
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2086 (_extra2086): __format__, __bytes__, __fspath__, __buffer__, __release_buffer__ dict-presence checks for threading module types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "threading.Thread, Event, Condition, Semaphore, BoundedSemaphore, Timer, Barrier, and local are all pure-Python classes; none define __format__, __bytes__, __fspath__, __buffer__, or __release_buffer__ in their own __dict__."
    - "threading.Lock() returns a _thread.lock instance and threading.RLock() returns a _thread.RLock instance; neither C type defines any of the 5 protocol dunders in its own __dict__."
    - "Threading synchronization primitives represent concurrency state, not string-formattable, bytes-serializable, path-like, or buffer-backing objects."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __format__ dict-presence for threading types
#
# None of the threading synchronization or utility types define __format__
# in their own __dict__. They rely on the default object.__format__.
# ---------------------------------------------------------------------------

table threading_extra2086.format_protocol:
  description: "threading types __format__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2086

  columns: [id, function, args, expected]
  rows:
    - ["th2086001", "threading.Thread.__dict__.__contains__", ["__format__"], false]
    - ["th2086002", "threading.Event.__dict__.__contains__", ["__format__"], false]
    - ["th2086003", "threading.Condition.__dict__.__contains__", ["__format__"], false]
    - ["th2086004", "threading.Semaphore.__dict__.__contains__", ["__format__"], false]
    - ["th2086005", "threading.BoundedSemaphore.__dict__.__contains__", ["__format__"], false]
    - ["th2086006", "threading.Timer.__dict__.__contains__", ["__format__"], false]
    - ["th2086007", "threading.Barrier.__dict__.__contains__", ["__format__"], false]
    - ["th2086008", "threading.local.__dict__.__contains__", ["__format__"], false]

# ---------------------------------------------------------------------------
# Table 2: __bytes__ dict-presence for threading types
#
# Threading types manage thread lifecycle and synchronization state.
# None define __bytes__ for binary serialization in their own __dict__.
# ---------------------------------------------------------------------------

table threading_extra2086.bytes_protocol:
  description: "threading types __bytes__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2086

  columns: [id, function, args, expected]
  rows:
    - ["th2086009", "threading.Thread.__dict__.__contains__", ["__bytes__"], false]
    - ["th2086010", "threading.Event.__dict__.__contains__", ["__bytes__"], false]
    - ["th2086011", "threading.Condition.__dict__.__contains__", ["__bytes__"], false]
    - ["th2086012", "threading.Semaphore.__dict__.__contains__", ["__bytes__"], false]
    - ["th2086013", "threading.BoundedSemaphore.__dict__.__contains__", ["__bytes__"], false]
    - ["th2086014", "threading.Timer.__dict__.__contains__", ["__bytes__"], false]
    - ["th2086015", "threading.Barrier.__dict__.__contains__", ["__bytes__"], false]
    - ["th2086016", "threading.local.__dict__.__contains__", ["__bytes__"], false]

# ---------------------------------------------------------------------------
# Table 3: __fspath__ dict-presence for threading types
#
# Threading primitives are not filesystem path objects. None define
# __fspath__ in their own __dict__.
# ---------------------------------------------------------------------------

table threading_extra2086.fspath_protocol:
  description: "threading types __fspath__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2086

  columns: [id, function, args, expected]
  rows:
    - ["th2086017", "threading.Thread.__dict__.__contains__", ["__fspath__"], false]
    - ["th2086018", "threading.Event.__dict__.__contains__", ["__fspath__"], false]
    - ["th2086019", "threading.Condition.__dict__.__contains__", ["__fspath__"], false]
    - ["th2086020", "threading.Semaphore.__dict__.__contains__", ["__fspath__"], false]
    - ["th2086021", "threading.BoundedSemaphore.__dict__.__contains__", ["__fspath__"], false]
    - ["th2086022", "threading.Timer.__dict__.__contains__", ["__fspath__"], false]
    - ["th2086023", "threading.Barrier.__dict__.__contains__", ["__fspath__"], false]
    - ["th2086024", "threading.local.__dict__.__contains__", ["__fspath__"], false]

# ---------------------------------------------------------------------------
# Table 4: __buffer__ / __release_buffer__ dict-presence for threading types
#
# Buffer protocol dunders are absent from all threading types. Locks,
# events, and semaphores hold synchronization state in kernel objects,
# not contiguous memory buffers.
# ---------------------------------------------------------------------------

table threading_extra2086.buffer_protocol:
  description: "threading types __buffer__/__release_buffer__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2086

  columns: [id, function, args, expected]
  rows:
    - ["th2086025", "threading.Thread.__dict__.__contains__", ["__buffer__"], false]
    - ["th2086026", "threading.Thread.__dict__.__contains__", ["__release_buffer__"], false]
    - ["th2086027", "threading.Event.__dict__.__contains__", ["__buffer__"], false]
    - ["th2086028", "threading.Event.__dict__.__contains__", ["__release_buffer__"], false]
    - ["th2086029", "threading.Condition.__dict__.__contains__", ["__buffer__"], false]
    - ["th2086030", "threading.Condition.__dict__.__contains__", ["__release_buffer__"], false]
    - ["th2086031", "threading.Semaphore.__dict__.__contains__", ["__buffer__"], false]
    - ["th2086032", "threading.Semaphore.__dict__.__contains__", ["__release_buffer__"], false]
    - ["th2086033", "threading.BoundedSemaphore.__dict__.__contains__", ["__buffer__"], false]
    - ["th2086034", "threading.BoundedSemaphore.__dict__.__contains__", ["__release_buffer__"], false]
    - ["th2086035", "threading.Barrier.__dict__.__contains__", ["__buffer__"], false]
    - ["th2086036", "threading.Barrier.__dict__.__contains__", ["__release_buffer__"], false]

# ---------------------------------------------------------------------------
# Table 5: Cross-check — Thread defines none of the 5 wave-2086 dunders
#
# threading.Thread is the central threading type. Confirms it defines
# none of the 5 protocol dunders. Also cross-checks local and Timer.
# ---------------------------------------------------------------------------

table threading_extra2086.thread_protocol_cross_check:
  description: "threading.Thread and local: none of the 5 wave-2086 protocol dunders defined"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2086

  columns: [id, function, args, expected]
  rows:
    - ["th2086037", "threading.Thread.__dict__.__contains__", ["__format__"], false]
    - ["th2086038", "threading.Thread.__dict__.__contains__", ["__bytes__"], false]
    - ["th2086039", "threading.Thread.__dict__.__contains__", ["__fspath__"], false]
    - ["th2086040", "threading.Thread.__dict__.__contains__", ["__buffer__"], false]
    - ["th2086041", "threading.Thread.__dict__.__contains__", ["__release_buffer__"], false]
    - ["th2086042", "threading.local.__dict__.__contains__", ["__format__"], false]
    - ["th2086043", "threading.local.__dict__.__contains__", ["__bytes__"], false]
    - ["th2086044", "threading.local.__dict__.__contains__", ["__fspath__"], false]
    - ["th2086045", "threading.local.__dict__.__contains__", ["__buffer__"], false]
    - ["th2086046", "threading.local.__dict__.__contains__", ["__release_buffer__"], false]
    - ["th2086047", "threading.Timer.__dict__.__contains__", ["__format__"], false]
    - ["th2086048", "threading.Timer.__dict__.__contains__", ["__bytes__"], false]
    - ["th2086049", "threading.Timer.__dict__.__contains__", ["__fspath__"], false]
    - ["th2086050", "threading.Timer.__dict__.__contains__", ["__buffer__"], false]
    - ["th2086051", "threading.Timer.__dict__.__contains__", ["__release_buffer__"], false]
