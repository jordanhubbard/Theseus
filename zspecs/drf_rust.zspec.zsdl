spec: drf_rust
version: ">=3.9"
backend: rust_module(drf_rust)

docs: https://www.django-rest-framework.org/

provenance:
  derived_from:
    - "https://www.django-rest-framework.org/ — Django REST Framework"
  notes:
    - "Django REST Framework (DRF) builds Web APIs on Django."
    - "rest_framework.serializers.Serializer is a class."
    - "rest_framework.views.APIView is a class."
    - "rest_framework.VERSION is a tuple."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant drf_rust.has_serializer:
  description: "rest_framework.serializers.Serializer is a class"
  category: presence
  kind: python_call_eq
  function: drf_has_serializer
  args: []
  expected: true

invariant drf_rust.has_api_view:
  description: "rest_framework.views.APIView is a class"
  category: presence
  kind: python_call_eq
  function: drf_has_api_view
  args: []
  expected: true

invariant drf_rust.version_nonempty:
  description: "rest_framework.VERSION is a non-empty tuple"
  category: version
  kind: python_call_eq
  function: drf_version_nonempty
  args: []
  expected: true

