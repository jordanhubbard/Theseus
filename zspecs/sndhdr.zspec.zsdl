spec: sndhdr
version: ">=3.3,<3.13"
backend: python_module(sndhdr)

docs: https://docs.python.org/3/library/sndhdr.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/sndhdr.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "sndhdr source: Lib/sndhdr.py (PSF; source inspection permitted)"
  not_derived_from:
    - "sndhdr internal details"
  notes:
    - "Deprecated since Python 3.11; removed in Python 3.13."
    - "sndhdr.what(filename) tries to determine the type of sound data stored in a file."
    - "sndhdr.whathdr(filename) reads only the header of a sound file to determine its type."
    - "sndhdr.tests is a list of test functions used internally to probe file types."
    - "SndHeaders is a named tuple with fields: file_type, sampling_rate, channels, frames, bits_per_sample."
    - "sndhdr.what and sndhdr.whathdr return a SndHeaders named tuple on success, or None."
    - "All expected values verified by running Python 3.12 sndhdr module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant sndhdr.what_name:
  description: "sndhdr.what.__name__ == 'what'"
  category: functions
  kind: python_call_eq
  function: what.__name__.__eq__
  args: ["what"]
  expected: true

invariant sndhdr.what_module:
  description: "sndhdr.what.__module__ == 'sndhdr'"
  category: functions
  kind: python_call_eq
  function: what.__module__.__eq__
  args: ["sndhdr"]
  expected: true

invariant sndhdr.whathdr_name:
  description: "sndhdr.whathdr.__name__ == 'whathdr'"
  category: functions
  kind: python_call_eq
  function: whathdr.__name__.__eq__
  args: ["whathdr"]
  expected: true

invariant sndhdr.whathdr_module:
  description: "sndhdr.whathdr.__module__ == 'sndhdr'"
  category: functions
  kind: python_call_eq
  function: whathdr.__module__.__eq__
  args: ["sndhdr"]
  expected: true

# ---------------------------------------------------------------------------
# SndHeaders named tuple checks
# ---------------------------------------------------------------------------

invariant sndhdr.SndHeaders_name:
  description: "SndHeaders.__name__ == 'SndHeaders'"
  category: classnames
  kind: python_call_eq
  function: SndHeaders.__name__.__eq__
  args: ["SndHeaders"]
  expected: true

invariant sndhdr.SndHeaders_field_file_type:
  description: "SndHeaders._fields[0] == 'file_type'"
  category: classnames
  kind: python_call_eq
  function: SndHeaders._fields.__getitem__
  args: [0]
  expected: "file_type"

invariant sndhdr.SndHeaders_field_sampling_rate:
  description: "SndHeaders._fields[1] == 'sampling_rate'"
  category: classnames
  kind: python_call_eq
  function: SndHeaders._fields.__getitem__
  args: [1]
  expected: "sampling_rate"

invariant sndhdr.SndHeaders_field_channels:
  description: "SndHeaders._fields[2] == 'channels'"
  category: classnames
  kind: python_call_eq
  function: SndHeaders._fields.__getitem__
  args: [2]
  expected: "channels"

invariant sndhdr.SndHeaders_field_frames:
  description: "SndHeaders._fields[3] == 'frames'"
  category: classnames
  kind: python_call_eq
  function: SndHeaders._fields.__getitem__
  args: [3]
  expected: "frames"

invariant sndhdr.SndHeaders_field_bits_per_sample:
  description: "SndHeaders._fields[4] == 'bits_per_sample'"
  category: classnames
  kind: python_call_eq
  function: SndHeaders._fields.__getitem__
  args: [4]
  expected: "bits_per_sample"

# ---------------------------------------------------------------------------
# sndhdr.tests list check
# ---------------------------------------------------------------------------

invariant sndhdr.tests_is_list:
  description: "sndhdr.tests is a list"
  category: attributes
  kind: python_call_eq
  function: tests.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant sndhdr.tests_nonempty:
  description: "len(sndhdr.tests) > 0 — at least one probe function registered"
  category: attributes
  kind: python_call_eq
  function: tests.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true
