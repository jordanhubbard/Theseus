spec: os_path_extra23
version: ">=3.9"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python os.path module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py, Lib/genericpath.py"
    - "os_path_extra17.zspec.zsdl — covers __qualname__.__len__() for join/split/basename/dirname/exists/isfile/isdir/abspath/expanduser."
    - "os_path_extra20.zspec.zsdl — covers isabs.__qualname__.__len__() == 5."
    - "os_path_extra22.zspec.zsdl — covers __qualname__.__class__.__name__ == 'str' for all 12 functions; __qualname__.__len__() for splitext and normpath."
  notes:
    - "This spec extends os_path_extra22.zspec.zsdl."
    - "Prior specs covered: join/split/splitext/basename/dirname/normpath/abspath/isabs/isfile/isdir/exists/expanduser __qualname__ equality and lengths; __name__/__module__ equality; __qualname__.__class__.__name__ type checks."
    - "This spec covers: __module__.__len__() for join/split/splitext/basename/dirname/normpath/abspath/isabs; __name__.__len__() for join/split/splitext/basename/dirname."
    - "join/split/splitext/basename/dirname/abspath/isabs.__module__ == 'posixpath', len=9. Verified."
    - "normpath.__module__ == 'posix' (C extension), len=5. Distinct from other functions. Verified."
    - "isfile/isdir/exists.__module__ == 'genericpath', len=11. Verified."
    - "expanduser.__module__ == 'posixpath', len=9. Verified."
    - "join.__name__ == 'join', len=4. Verified."
    - "split.__name__ == 'split', len=5. Verified."
    - "splitext.__name__ == 'splitext', len=8. Verified."
    - "basename.__name__ == 'basename', len=8. Verified."
    - "dirname.__name__ == 'dirname', len=7. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __module__.__len__() for posixpath functions
#
# join/split/splitext/basename/dirname/abspath/isabs/expanduser all have
# __module__ == 'posixpath', so their lengths are all 9. No prior os.path spec
# covers __module__.__len__() as a grouped table.
# Verified: all nine yield 9.
# ---------------------------------------------------------------------------

table os_path_extra23.posixpath_module_lengths:
  description: "__module__.__len__() == 9 for posixpath-backed functions join/split/splitext/basename/dirname/abspath/isabs/expanduser"
  kind: python_call_eq
  category: module_identity
  id_prefix: pml23

  columns: [id, function, args, expected]
  rows:
    - [join,       join.__module__.__len__,       [], 9]
    - [split,      split.__module__.__len__,      [], 9]
    - [splitext,   splitext.__module__.__len__,   [], 9]
    - [basename,   basename.__module__.__len__,   [], 9]
    - [dirname,    dirname.__module__.__len__,    [], 9]
    - [abspath,    abspath.__module__.__len__,    [], 9]
    - [isabs,      isabs.__module__.__len__,      [], 9]
    - [expanduser, expanduser.__module__.__len__, [], 9]

# ---------------------------------------------------------------------------
# Table: __module__.__len__() for genericpath functions
#
# isfile/isdir/exists are defined in genericpath (shared between posixpath and
# ntpath), so their __module__ is 'genericpath' (len 11), not 'posixpath'.
# This is a meaningful distinction from the posixpath functions above.
# Verified: isfile=11, isdir=11, exists=11.
# ---------------------------------------------------------------------------

table os_path_extra23.genericpath_module_lengths:
  description: "__module__.__len__() == 11 for genericpath-backed functions isfile/isdir/exists — len('genericpath') == 11"
  kind: python_call_eq
  category: module_identity
  id_prefix: gml23

  columns: [id, function, args, expected]
  rows:
    - [isfile, isfile.__module__.__len__, [], 11]
    - [isdir,  isdir.__module__.__len__,  [], 11]
    - [exists, exists.__module__.__len__, [], 11]

# ---------------------------------------------------------------------------
# Table: __name__.__len__() for join/split/splitext/basename/dirname
#
# Prior specs cover __name__ equality for these functions. This table adds
# the length axis for the five core path manipulation functions.
# Verified: join=4, split=5, splitext=8, basename=8, dirname=7.
# ---------------------------------------------------------------------------

table os_path_extra23.name_lengths:
  description: "__name__.__len__() for join/split/splitext/basename/dirname — lengths 4/5/8/8/7"
  kind: python_call_eq
  category: function_identity
  id_prefix: fnlen23

  columns: [id, function, args, expected]
  rows:
    - [join,     join.__name__.__len__,     [], 4]
    - [split,    split.__name__.__len__,    [], 5]
    - [splitext, splitext.__name__.__len__, [], 8]
    - [basename, basename.__name__.__len__, [], 8]
    - [dirname,  dirname.__name__.__len__,  [], 7]

# ---------------------------------------------------------------------------
# Standalone: os.path.normpath.__module__.__len__() == 5
#
# normpath is a C extension function whose __module__ is 'posix' (len 5),
# distinct from all other os.path functions which report 'posixpath' (len 9)
# or 'genericpath' (len 11). This makes normpath.__module__.__len__() the
# unique outlier among the twelve standard path functions.
# No prior os.path spec covers normpath.__module__.__len__().
# Verified: len('posix') == 5.
# ---------------------------------------------------------------------------

invariant os_path_extra23.normpath.module_len:
  description: "os.path.normpath.__module__.__len__() == 5 — __module__ is 'posix' (C extension), not 'posixpath'; unique outlier among the twelve standard path functions"
  category: module_identity
  kind: python_call_eq
  function: normpath.__module__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# Standalone: os.path.join.__name__.__len__() == 4
#
# join is the shortest-named of the five core path manipulation functions.
# This standalone anchors the name length for join as an explicit invariant,
# complementing the table above with a named cross-reference entry.
# Verified: len('join') == 4.
# ---------------------------------------------------------------------------

invariant os_path_extra23.join.name_len:
  description: "os.path.join.__name__.__len__() == 4 — 'join' is the shortest name among the five core path manipulation functions"
  category: function_identity
  kind: python_call_eq
  function: join.__name__.__len__
  args: []
  expected: 4
