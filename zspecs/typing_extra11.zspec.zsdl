spec: typing_extra11
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "PEP 484 — Type Hints"
    - "PEP 544 — Protocols: Structural subtyping (Protocol)"
    - "PEP 585 — Type Hinting Generics in Standard Collections"
    - "PEP 604 — Allow writing union types as X | Y"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing.zspec.zsdl through typing_extra10.zspec.zsdl."
    - "typing_extra10 covers assert_never/__qualname__/__module__, assert_type/__qualname__/__module__, no_type_check/__qualname__/__module__, final/__qualname__/__module__, ParamSpec bases, TypeVarTuple bases, Never/Self/LiteralString __class__.__name__."
    - "typing_extra9 covers ForwardRef/__qualname__, ForwardRef/__bases__[0].__name__, get_overloads/__qualname__, TypeVar/__bases__[0].__name__, Generic/__mro__.__len__, Protocol/__mro__.__len__, is_typeddict/__qualname__, runtime_checkable/__name__."
    - "typing_extra8 covers Callable/_SpecialForm, NoReturn/_SpecialForm, TYPE_CHECKING, function __module__ table, Annotated/_SpecialForm, ParamSpec/__module__."
    - "NOT yet covered: typing.NamedTuple.__module__ as standalone invariant."
    - "NOT yet covered: typing.TypedDict.__module__ as standalone invariant."
    - "NOT yet covered: typing.AnyStr.__name__ — AnyStr is a TypeVar instance with __name__ == 'AnyStr'."
    - "NOT yet covered: typing.AnyStr.__module__ and typing.AnyStr.__qualname__."
    - "NOT yet covered: typing.SupportsInt.__name__, SupportsInt.__module__, SupportsInt.__qualname__ — runtime-checkable Protocol."
    - "NOT yet covered: typing.TypeVar.__name__ == 'TypeVar' (class name) is in extra specs; TypeVar('T').__name__ == 'T' (instance __name__) is not yet a standalone invariant."
    - "NOT yet covered: typing.get_args.__module__ confirmed in extra8 table; get_origin.__module__ also in table. No standalone invariant."
    - "NOT yet covered: typing.no_type_check_decorator.__qualname__/__module__."
    - "typing.NamedTuple.__module__ == 'typing'."
    - "typing.TypedDict.__module__ == 'typing'."
    - "typing.AnyStr.__name__ == 'AnyStr' — AnyStr is a TypeVar defined at module scope."
    - "typing.AnyStr.__module__ == 'typing'."
    - "typing.AnyStr.__class__.__name__ == 'TypeVar' — AnyStr is a TypeVar instance."
    - "typing.SupportsInt.__name__ == 'SupportsInt'."
    - "typing.SupportsInt.__module__ == 'typing'."
    - "typing.SupportsInt.__qualname__ == 'SupportsInt'."
    - "typing.TypeVar('T').__name__ == 'T' — instance __name__ is the variable's name."
    - "typing.no_type_check_decorator.__qualname__ == 'no_type_check_decorator'."
    - "typing.no_type_check_decorator.__module__ == 'typing'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NamedTuple and TypedDict — __module__ as standalone invariants
#
# typing_extra7 covers __qualname__ for NamedTuple and TypedDict.
# No prior spec records their __module__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant typing_extra11.NamedTuple.module:
  description: "typing.NamedTuple.__module__ == 'typing'"
  category: class_modules
  kind: python_call_eq
  function: NamedTuple.__module__.__eq__
  args: ["typing"]
  expected: true

invariant typing_extra11.TypedDict.module:
  description: "typing.TypedDict.__module__ == 'typing'"
  category: class_modules
  kind: python_call_eq
  function: TypedDict.__module__.__eq__
  args: ["typing"]
  expected: true

# ---------------------------------------------------------------------------
# AnyStr — name, module, and class identity
#
# typing.AnyStr is a TypeVar defined at module scope: AnyStr = TypeVar('AnyStr',
# bytes, str). No prior spec covers any AnyStr attribute.
# ---------------------------------------------------------------------------

invariant typing_extra11.AnyStr.name:
  description: "typing.AnyStr.__name__ == 'AnyStr' — AnyStr is a TypeVar with __name__ matching its variable name"
  category: AnyStr
  kind: python_call_eq
  function: AnyStr.__name__.__eq__
  args: ["AnyStr"]
  expected: true

invariant typing_extra11.AnyStr.module:
  description: "typing.AnyStr.__module__ == 'typing'"
  category: AnyStr
  kind: python_call_eq
  function: AnyStr.__module__.__eq__
  args: ["typing"]
  expected: true

invariant typing_extra11.AnyStr.class_name:
  description: "typing.AnyStr.__class__.__name__ == 'TypeVar' — AnyStr is a TypeVar instance"
  category: AnyStr
  kind: python_call_eq
  function: AnyStr.__class__.__name__.__eq__
  args: ["TypeVar"]
  expected: true

# ---------------------------------------------------------------------------
# SupportsInt — name, module, qualname
#
# typing.SupportsInt is a runtime-checkable Protocol for objects implementing
# __int__. No prior spec covers any SupportsInt identity attribute.
# ---------------------------------------------------------------------------

invariant typing_extra11.SupportsInt.name:
  description: "typing.SupportsInt.__name__ == 'SupportsInt'"
  category: SupportsInt
  kind: python_call_eq
  function: SupportsInt.__name__.__eq__
  args: ["SupportsInt"]
  expected: true

invariant typing_extra11.SupportsInt.module:
  description: "typing.SupportsInt.__module__ == 'typing'"
  category: SupportsInt
  kind: python_call_eq
  function: SupportsInt.__module__.__eq__
  args: ["typing"]
  expected: true

invariant typing_extra11.SupportsInt.qualname:
  description: "typing.SupportsInt.__qualname__ == 'SupportsInt'"
  category: SupportsInt
  kind: python_call_eq
  function: SupportsInt.__qualname__.__eq__
  args: ["SupportsInt"]
  expected: true

# ---------------------------------------------------------------------------
# TypeVar instance — __name__ reflects the variable name given at construction
#
# typing.zspec.zsdl covers TypeVar as a class (TypeVar.__name__ == 'TypeVar').
# No prior spec verifies that a TypeVar *instance* has __name__ equal to the
# string passed as the first argument. We use a simple 'T' variable.
# ---------------------------------------------------------------------------

invariant typing_extra11.TypeVar.instance_name:
  description: "typing.TypeVar('T').__name__ == 'T' — instance __name__ equals the bound variable name"
  category: TypeVar
  kind: python_call_eq
  function: TypeVar
  args: ["T"]
  method: __name__
  expected: "T"

# ---------------------------------------------------------------------------
# no_type_check_decorator — __qualname__ and __module__
#
# typing_extra10 covers no_type_check __qualname__ and __module__ but not
# no_type_check_decorator, which is a separate decorator function.
# No prior spec covers any identity attribute of no_type_check_decorator.
# ---------------------------------------------------------------------------

invariant typing_extra11.no_type_check_decorator.qualname:
  description: "typing.no_type_check_decorator.__qualname__ == 'no_type_check_decorator'"
  category: function_qualnames
  kind: python_call_eq
  function: no_type_check_decorator.__qualname__.__eq__
  args: ["no_type_check_decorator"]
  expected: true

invariant typing_extra11.no_type_check_decorator.module:
  description: "typing.no_type_check_decorator.__module__ == 'typing'"
  category: function_modules
  kind: python_call_eq
  function: no_type_check_decorator.__module__.__eq__
  args: ["typing"]
  expected: true
