spec: mp2866
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [multiprocessing source, Python docs, https://docs.python.org/3/library/multiprocessing.html]
  not_derived_from: [any external dataset, multiprocessing_extra2851.zspec.zsdl — covers __rlshift__/__rrshift__/__rpow__ dict-presence, multiprocessing_extra2836.zspec.zsdl — covers __rtruediv__/__rfloordiv__/__rmod__ dict-presence]
  notes: [Wave 638 theme — __rand__/__ror__/__rxor__ dict-presence checks for multiprocessing types. Reflected bitwise AND, OR, and XOR operators. Process/Pool/AsyncResult/MapResult/SyncManager and proxy types for Queue/Value/Lock/RLock/Event/Semaphore are process-management primitives not bitwise/set-like types — none define these dunders. multiprocessing.pool.AsyncResult.__name__ is ApplyResult on Python 3.14. type(multiprocessing.Queue()) used for Queue proxy class access — no nested brackets in YAML flow sequences. All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

table mp2866.rand:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["mp2866001", operator.contains, [multiprocessing.Process.__dict__, "__rand__"], false]
    - ["mp2866002", operator.contains, [multiprocessing.pool.Pool.__dict__, "__rand__"], false]
    - ["mp2866003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__, "__rand__"], false]
    - ["mp2866004", operator.contains, [multiprocessing.pool.MapResult.__dict__, "__rand__"], false]
    - ["mp2866005", operator.contains, [multiprocessing.managers.SyncManager.__dict__, "__rand__"], false]
    - ["mp2866006", operator.contains, [multiprocessing.Process.__dict__, "__rand__"], false]

