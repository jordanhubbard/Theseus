spec: socket_extra2116
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html"
    - "CPython source: Lib/socket.py"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2116: __or__/__ror__/__ior__, __and__/__rand__/__iand__, __xor__/__rxor__/__ixor__ dict-presence checks."
    - "socket.socket is a pure-Python class wrapping the C _socket.socket; it has no set/dict merge operators."
    - "socket.error, socket.timeout, and socket.gaierror are OSError subclasses; they do not define set operators."
    - "socket.AddressFamily is an IntEnum subclass; IntEnum inherits __or__/__and__/__xor__ from int (not from AddressFamily.__dict__)."
    - "socket.SocketKind is an IntEnum subclass; same situation as AddressFamily — operators not in own __dict__."
    - "None of socket.socket, socket.error, socket.timeout, socket.gaierror, socket.AddressFamily, or socket.SocketKind define __or__, __ror__, or __ior__ in their own __dict__."
    - "None of these socket classes define __and__, __rand__, or __iand__ in their own __dict__."
    - "None of these socket classes define __xor__, __rxor__, or __ixor__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __or__ / __ror__ / __ior__ — dict-merge / set-union dict-presence
# socket classes do not define these operators in their own __dict__
# ---------------------------------------------------------------------------

table socket_extra2116.or_protocol:
  description: "socket types __or__/__ror__/__ior__ dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2116

  columns: [id, function, args, expected]
  rows:
    - ["sk2116001", "socket.socket.__dict__.__contains__",        ["__or__"],  false]
    - ["sk2116002", "socket.socket.__dict__.__contains__",        ["__ror__"], false]
    - ["sk2116003", "socket.socket.__dict__.__contains__",        ["__ior__"], false]
    - ["sk2116004", "socket.error.__dict__.__contains__",         ["__or__"],  false]
    - ["sk2116005", "socket.error.__dict__.__contains__",         ["__ror__"], false]
    - ["sk2116006", "socket.error.__dict__.__contains__",         ["__ior__"], false]
    - ["sk2116007", "socket.AddressFamily.__dict__.__contains__", ["__or__"],  false]
    - ["sk2116008", "socket.AddressFamily.__dict__.__contains__", ["__ror__"], false]
    - ["sk2116009", "socket.AddressFamily.__dict__.__contains__", ["__ior__"], false]

