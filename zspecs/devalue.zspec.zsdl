spec: devalue
version: ">=5.0.0"
backend: node(devalue)

docs: https://github.com/Rich-Harris/devalue#readme

provenance:
  derived_from:
    - "devalue README — https://github.com/Rich-Harris/devalue#readme"
    - "Test vectors verified with devalue via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "devalue source"
  notes:
    - "Like JSON, but better — handles cyclical references, Date, Set, Map, BigInt."
    - "Install: npm install devalue"
    - "v5 ESM only; named exports stringify / parse / uneval / unflatten / DevalueError."
    - "stringify produces a flatten array form; uneval produces JS source code."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "DevalueError thrown on un-serialisable values (functions, etc.)."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes:
    DevalueError: "Cannot serialise this value type"

invariant devalue.stringify_simple_object:
  description: "stringify({a:1, b:2}) emits flatten-form array"
  category: stringify
  kind: node_chain_eq
  entry: named
  function: stringify
  entry_args: [{a: 1, b: 2}]
  chain: []
  expected: "[{\"a\":1,\"b\":2},1,2]"

invariant devalue.uneval_object_to_js_source:
  description: "uneval({a:1, b:'hi'}) produces JS source '{a:1,b:\"hi\"}'"
  category: uneval
  kind: node_chain_eq
  entry: named
  function: uneval
  entry_args: [{a: 1, b: "hi"}]
  chain: []
  expected: "{a:1,b:\"hi\"}"

invariant devalue.parse_simple_round_trip:
  description: "parse(stringify(...)) round-trips a simple object"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["[{\"a\":1},1]"]
  chain:
    - {get: a}
  expected: 1

invariant devalue.uneval_string:
  description: "uneval('hello') is '\"hello\"'"
  category: uneval
  kind: node_chain_eq
  entry: named
  function: uneval
  entry_args: ["hello"]
  chain: []
  expected: "\"hello\""

invariant devalue.uneval_number:
  description: "uneval(42) is '42'"
  category: uneval
  kind: node_chain_eq
  entry: named
  function: uneval
  entry_args: [42]
  chain: []
  expected: "42"

invariant devalue.uneval_array:
  description: "uneval([1,2,3]) is '[1,2,3]'"
  category: uneval
  kind: node_chain_eq
  entry: named
  function: uneval
  entry_args: [[1, 2, 3]]
  chain: []
  expected: "[1,2,3]"

invariant devalue.uneval_null:
  description: "uneval(null) is 'null'"
  category: uneval
  kind: node_chain_eq
  entry: named
  function: uneval
  entry_args: [~]
  chain: []
  expected: "null"

invariant devalue.has_DevalueError:
  description: "DevalueError class exported"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "DevalueError.constructor.name"}
  expected: "Function"
