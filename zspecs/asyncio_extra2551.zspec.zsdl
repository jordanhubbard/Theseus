spec: asyncio_extra2551
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio synchronization primitives, queues, and task documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "Theme: __reduce__, __reduce_ex__, and __getnewargs__ dict-presence — checking whether asyncio classes define their own pickling/serialization protocol in their class __dict__."
    - "asyncio.Queue is a coroutine-safe FIFO tied to a running event loop; it intentionally provides no pickling support. It defines no __reduce__, __reduce_ex__, or __getnewargs__ in its class __dict__. Verified with Python 3.14."
    - "asyncio.Task wraps a coroutine as a Future subclass for scheduling; its state (running loop, coroutine frame, callbacks) is non-transferable and therefore no pickling protocol is defined. Verified with Python 3.14."
    - "asyncio.Future is the base awaitable class; its result/exception state is ephemeral and loop-bound — no __reduce__, __reduce_ex__, or __getnewargs__ in its class __dict__. Verified with Python 3.14."
    - "asyncio.Lock, asyncio.Event, asyncio.Semaphore, asyncio.Condition, and asyncio.BoundedSemaphore are all pure-Python synchronization primitives whose state cannot survive pickling across process boundaries. None defines a custom pickling protocol. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Queue and asyncio.Task — __reduce__/__reduce_ex__/__getnewargs__ absence
#
# Theme: pickling/serialization protocol absent from asyncio.Queue and asyncio.Task __dict__.
# Queue is bound to an event loop and cannot be transferred across process boundaries.
# Task wraps a live coroutine frame; its state is inherently non-serializable.
# ---------------------------------------------------------------------------

table asyncio_extra2551.queue_task_pickle_protocol:
  description: "__reduce__, __reduce_ex__, __getnewargs__ absent from asyncio.Queue and asyncio.Task __dict__; wave 2551"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: as2551

  columns: [id, function, args, expected]
  rows:
    - ["as2551-001", asyncio.Queue.__dict__.__contains__, ["__reduce__"],     false]
    - ["as2551-002", asyncio.Queue.__dict__.__contains__, ["__reduce_ex__"],  false]
    - ["as2551-003", asyncio.Queue.__dict__.__contains__, ["__getnewargs__"], false]
    - ["as2551-004", asyncio.Task.__dict__.__contains__,  ["__reduce__"],     false]
    - ["as2551-005", asyncio.Task.__dict__.__contains__,  ["__reduce_ex__"],  false]
    - ["as2551-006", asyncio.Task.__dict__.__contains__,  ["__getnewargs__"], false]

# ---------------------------------------------------------------------------
# Table 2: asyncio.Future and asyncio.Lock — __reduce__/__reduce_ex__/__getnewargs__ absence
#
# Theme: pickling/serialization protocol absent from asyncio.Future and asyncio.Lock __dict__.
# Future is the base awaitable whose result/exception state is event-loop-bound.
# Lock is a mutual-exclusion primitive whose acquired/released state is not portable.
# Neither defines any pickling dunders in its class __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra2551.future_lock_pickle_protocol:
  description: "__reduce__, __reduce_ex__, __getnewargs__ absent from asyncio.Future and asyncio.Lock __dict__; wave 2551"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: as2551

  columns: [id, function, args, expected]
  rows:
    - ["as2551-007", asyncio.Future.__dict__.__contains__, ["__reduce__"],     false]
    - ["as2551-008", asyncio.Future.__dict__.__contains__, ["__reduce_ex__"],  false]
    - ["as2551-009", asyncio.Future.__dict__.__contains__, ["__getnewargs__"], false]
    - ["as2551-010", asyncio.Lock.__dict__.__contains__,   ["__reduce__"],     false]
    - ["as2551-011", asyncio.Lock.__dict__.__contains__,   ["__reduce_ex__"],  false]
    - ["as2551-012", asyncio.Lock.__dict__.__contains__,   ["__getnewargs__"], false]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Event and asyncio.Semaphore — __reduce__/__reduce_ex__/__getnewargs__ absence
#
# Theme: pickling/serialization protocol absent from asyncio.Event and asyncio.Semaphore __dict__.
# Event holds a boolean flag inside an event loop; it cannot be pickled across processes.
# Semaphore holds an internal counter that is event-loop-bound and non-transferable.
# ---------------------------------------------------------------------------

table asyncio_extra2551.event_semaphore_pickle_protocol:
  description: "__reduce__, __reduce_ex__, __getnewargs__ absent from asyncio.Event and asyncio.Semaphore __dict__; wave 2551"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: as2551

  columns: [id, function, args, expected]
  rows:
    - ["as2551-013", asyncio.Event.__dict__.__contains__,     ["__reduce__"],     false]
    - ["as2551-014", asyncio.Event.__dict__.__contains__,     ["__reduce_ex__"],  false]
    - ["as2551-015", asyncio.Event.__dict__.__contains__,     ["__getnewargs__"], false]
    - ["as2551-016", asyncio.Semaphore.__dict__.__contains__, ["__reduce__"],     false]
    - ["as2551-017", asyncio.Semaphore.__dict__.__contains__, ["__reduce_ex__"],  false]
    - ["as2551-018", asyncio.Semaphore.__dict__.__contains__, ["__getnewargs__"], false]

# ---------------------------------------------------------------------------
# Table 4: asyncio.Condition and asyncio.BoundedSemaphore — __reduce__/__reduce_ex__/__getnewargs__ absence
#
# Theme: pickling/serialization protocol absent from asyncio.Condition and
# asyncio.BoundedSemaphore __dict__.
# Condition wraps a lock with a waiter queue; its state depends on a live loop.
# BoundedSemaphore caps the internal counter at the initial value; like Semaphore
# it is loop-bound and not picklable.
# ---------------------------------------------------------------------------

table asyncio_extra2551.condition_bounded_semaphore_pickle_protocol:
  description: "__reduce__, __reduce_ex__, __getnewargs__ absent from asyncio.Condition and asyncio.BoundedSemaphore __dict__; wave 2551"
