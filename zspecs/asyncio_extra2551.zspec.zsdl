    - ["as2551-019", asyncio.Condition.__dict__.__contains__,       ["__reduce__"],     false]
    - ["as2551-020", asyncio.Condition.__dict__.__contains__,       ["__reduce_ex__"],  false]
    - ["as2551-021", asyncio.Condition.__dict__.__contains__,       ["__getnewargs__"], false]
    - ["as2551-022", asyncio.BoundedSemaphore.__dict__.__contains__, ["__reduce__"],     false]
