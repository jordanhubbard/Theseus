spec: concurrent_futures_extra259
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "InvalidStateError.__qualname__ == 'InvalidStateError' (no nesting)."
    - "InvalidStateError.__doc__ is a non-None str: 'The operation is not allowed in this state.'"
    - "InvalidStateError.__bases__[0].__name__ == 'Error' (inherits from concurrent.futures.Error)."
    - "concurrent.futures._base.__spec__.__class__.__name__ == 'ModuleSpec'."
    - "concurrent.futures._base.__loader__.__class__.__name__ == 'SourceFileLoader'."
    - "BrokenThreadPool and BrokenProcessPool are NOT present on Python 3.14 (verified False for hasattr)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# InvalidStateError identity
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra259.invalid_state_error.qualname:
  description: "concurrent.futures.InvalidStateError.__qualname__ == 'InvalidStateError'"
  category: identity
  kind: python_call_eq
  function: InvalidStateError.__qualname__.__eq__
  args: ["InvalidStateError"]
  expected: true

invariant concurrent_futures_extra259.invalid_state_error.doc_class:
  description: "type(concurrent.futures.InvalidStateError.__doc__).__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: InvalidStateError.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra259.invalid_state_error.base:
  description: "concurrent.futures.InvalidStateError.__bases__[0].__name__ == 'Error'"
  category: identity
  kind: python_call_eq
  function: InvalidStateError.__bases__[0].__name__.__eq__
  args: ["Error"]
  expected: true

invariant concurrent_futures_extra259.invalid_state_error.module:
  description: "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'"
  category: identity
  kind: python_call_eq
  function: InvalidStateError.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

# ---------------------------------------------------------------------------
# concurrent.futures._base module identity
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra259.cfb_module.name:
  description: "concurrent.futures._base.__name__ == 'concurrent.futures._base'"
  category: identity
  kind: python_call_eq
  function: _base.__name__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra259.cfb_module.package:
  description: "concurrent.futures._base.__package__ == 'concurrent.futures'"
  category: identity
  kind: python_call_eq
  function: _base.__package__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra259.cfb_module.spec_class:
  description: "type(concurrent.futures._base.__spec__).__name__ == 'ModuleSpec'"
  category: identity
  kind: python_call_eq
  function: _base.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant concurrent_futures_extra259.cfb_module.spec_name:
  description: "concurrent.futures._base.__spec__.name == 'concurrent.futures._base'"
  category: identity
  kind: python_call_eq
  function: _base.__spec__.name.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra259.cfb_module.loader_class:
  description: "type(concurrent.futures._base.__loader__).__name__ == 'SourceFileLoader'"
  category: identity
  kind: python_call_eq
  function: _base.__loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true
