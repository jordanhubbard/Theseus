invariant concurrent_futures_extra255.future_base_is_object:
  description: "concurrent.futures.Future.__bases__[0].__name__.__eq__('object') returns True — Future inherits directly from object(len=6) with no intermediate abstract base; unlike asyncio.Task which inherits from asyncio.Future, concurrent.futures.Future is a standalone class; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Future.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant concurrent_futures_extra255.add_done_callback_qualname_len_equals_module_len:
  description: "concurrent.futures.Future.add_done_callback.__qualname__.__len__() == 24 — 'Future.add_done_callback' (len=24) equals the length of Future.__module__ 'concurrent.futures._base' (also len=24); this numeric coincidence makes add_done_callback the longest qualname in the spec; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.add_done_callback.__qualname__.__len__
  args: []
  expected: 24
