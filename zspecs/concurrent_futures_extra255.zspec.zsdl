table concurrent_futures_extra255.future_class_identity:
  description: "concurrent.futures.Future(len=6) class identity — inherits from object(len=6); defined in concurrent.futures._base(len=24); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cf255fi

  columns: [id, function, args, expected, description]
  rows:
    - [f_name_eq,    Future.__name__.__eq__,                   ["Future"],                        true, "concurrent.futures.Future.__name__ == 'Future'; verified with Python 3.14.3"]
    - [f_name_len,   Future.__name__.__len__,                  [],                                6,    "concurrent.futures.Future.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [f_mod_eq,     Future.__module__.__eq__,                 ["concurrent.futures._base"],      true, "concurrent.futures.Future.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [f_mod_len,    Future.__module__.__len__,                [],                                24,   "concurrent.futures.Future.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [f_base_eq,    "Future.__bases__[0].__name__.__eq__",    ["object"],                        true, "concurrent.futures.Future.__bases__[0].__name__ == 'object' — Future inherits directly from object; verified with Python 3.14.3"]
    - [f_base_len,   "Future.__bases__[0].__name__.__len__",   [],                                6,    "concurrent.futures.Future.__bases__[0].__name__.__len__() == 6 — same length as Future.__name__; verified with Python 3.14.3"]

