spec: concurrent_futures_extra255
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.Future.__name__ == 'Future' (len=6); __module__ == 'concurrent.futures._base' (len=24); __bases__[0].__name__ == 'object' (len=6)."
    - "Future.cancel.__qualname__ == 'Future.cancel' (len=13); Future.result.__qualname__ == 'Future.result' (len=13) — cancel and result share qualname length 13."
    - "Future.cancelled.__qualname__ == 'Future.cancelled' (len=16); Future.exception.__qualname__ == 'Future.exception' (len=16) — cancelled and exception share qualname length 16."
    - "Future.running.__qualname__ == 'Future.running' (len=14); Future.done.__qualname__ == 'Future.done' (len=11) — done is shortest qualname (len=11)."
    - "Future.add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24); Future.set_result.__qualname__ == 'Future.set_result' (len=17); Future.set_exception.__qualname__ == 'Future.set_exception' (len=20)."
    - "add_done_callback qualname length (24) equals Future.__module__ length (24) — 'Future.add_done_callback' and 'concurrent.futures._base' both have 24 characters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

