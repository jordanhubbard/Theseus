spec: multiprocessing_extra47
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.context.BaseContext — BaseContext documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra46.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__ tables, DefaultContext method qualname lengths, BaseProcess metadata, function __name__.__len__() tables, pool result class tables, Process/__name__=='Process', Process/__module__=='multiprocessing.context', Queue/__name__=='Queue', Pipe/__name__=='Pipe', Process method qualname lens for start/join/run, Process.__bases__[0].__name__=='BaseProcess'/__mro__.__len__()==3/Manager.__name__=='Manager', function __name__/__module__ string equality for cpu_count/current_process/active_children, AuthenticationError/__name__/__module__/__bases__[0].__name__, ProcessError/__name__/__bases__[0].__name__, BufferTooShort/__name__, TimeoutError/__name__/__bases__[0].__name__, all four exception __module__ string equality, ProcessError/__mro__.__len__()==4, exception subclass MRO depths, Process/__qualname__=='Process', Process/__qualname__.__len__()==7, context.BaseContext/__name__=='BaseContext', Queue/__qualname__=='BaseContext.Queue', Pipe/__qualname__=='BaseContext.Pipe', cpu_count/__qualname__=='BaseContext.cpu_count', current_process/__qualname__=='current_process', active_children/__qualname__=='active_children', get_start_method/__qualname__=='DefaultContext.get_start_method', set_start_method/__name__=='set_start_method', ProcessError/__qualname__=='ProcessError', AuthenticationError/__qualname__=='AuthenticationError', TimeoutError/__qualname__=='TimeoutError', BufferTooShort/__qualname__=='BufferTooShort', BaseContext/__qualname__/__module__/__mro__.__len__(), SpawnContext/ForkContext/ForkServerContext/DefaultContext __name__ equality, context subclass __qualname__.__len__() tables, context subclass __mro__.__len__()==3 (extra43), SpawnContext/ForkContext/ForkServerContext/DefaultContext __qualname__ string equality, all four context subclass __module__ string equality and __module__.__len__()==23 (extra44), Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__name__=='function', active_children/__class__.__name__=='function', ProcessError/__class__.__name__=='type', AuthenticationError/__class__.__name__=='type', context.SpawnContext/__class__.__name__=='type', context.BaseContext/__class__.__name__=='type', __class__.__name__.__len__() for all eight objects (extra45), Process/__class__.__qualname__=='type', ProcessError/__class__.__qualname__=='type', AuthenticationError/__class__.__qualname__=='type', current_process/__class__.__qualname__=='function', active_children/__class__.__qualname__=='function', cpu_count/__class__.__qualname__=='method', Process/__class__.__module__=='builtins', current_process/__class__.__module__=='builtins', cpu_count/__class__.__module__=='builtins' (extra46)."
    - "This spec covers: ProcessError/__bases__[0].__name__=='Exception'; AuthenticationError/__bases__[0].__name__=='ProcessError'; ProcessError/__mro__.__len__()==4; AuthenticationError/__mro__.__len__()==5; ProcessError/__module__=='multiprocessing.context'; AuthenticationError/__module__=='multiprocessing.context'; Queue/__class__.__name__=='method'; Pipe/__class__.__name__=='method'."
    - "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception'. ProcessError is the root multiprocessing exception and directly subclasses Exception. MRO: [ProcessError, Exception, BaseException, object]. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError'. AuthenticationError subclasses ProcessError (one level deeper). MRO: [AuthenticationError, ProcessError, Exception, BaseException, object]. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__mro__.__len__() == 4. MRO: [ProcessError, Exception, BaseException, object] — four entries. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__mro__.__len__() == 5. MRO: [AuthenticationError, ProcessError, Exception, BaseException, object] — five entries, one deeper than ProcessError. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__module__ == 'multiprocessing.context'. ProcessError is defined in Lib/multiprocessing/context.py. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__module__ == 'multiprocessing.context'. AuthenticationError is defined in Lib/multiprocessing/context.py alongside ProcessError. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Queue.__class__.__name__ == 'method'. Unlike asyncio.Queue which is a class, multiprocessing.Queue is a bound method of the DefaultContext singleton (a factory method that returns a queue object). Therefore its __class__.__name__ is 'method', not 'type' or 'function'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pipe.__class__.__name__ == 'method'. Like Queue, multiprocessing.Pipe is also a bound method of the DefaultContext singleton, not a plain class or function. __class__.__name__ == 'method'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "The 'method' class for Queue and Pipe is noteworthy: multiprocessing exposes many context-bound methods as top-level module attributes (cpu_count, Queue, Pipe, etc.), and all of these report __class__.__name__ == 'method'. This distinguishes them from true classes (which report 'type') and standalone functions (which report 'function'). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessLookupError does not exist as a module-level attribute; it is not accessible directly from multiprocessing and was therefore excluded from this spec."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing exception __bases__[0].__name__ — extra47
#
# ProcessError is the root of the multiprocessing exception hierarchy:
#   ProcessError.__bases__[0].__name__ == 'Exception'
# AuthenticationError is one level deeper:
#   AuthenticationError.__bases__[0].__name__ == 'ProcessError'
# NOTE: function values contain '[' and therefore MUST be double-quoted per
# ZSDL critical quoting rules for table rows.
# ---------------------------------------------------------------------------

table multiprocessing_extra47.exc_bases_eq:
  description: "multiprocessing exception __bases__[0].__name__ string equality in extra47 namespace — hierarchy: ProcessError→Exception, AuthenticationError→ProcessError"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: mpexc47bases

  columns: [id, function, args, expected, description]
  rows:
    - [ProcessError,        "ProcessError.__bases__[0].__name__.__eq__",        ["Exception"],    true, "ProcessError.__bases__[0].__name__ == 'Exception' — ProcessError is the root mp exception, directly subclassing Exception"]
    - [AuthenticationError, "AuthenticationError.__bases__[0].__name__.__eq__", ["ProcessError"], true, "AuthenticationError.__bases__[0].__name__ == 'ProcessError' — AuthenticationError subclasses ProcessError (one level deeper)"]

# ---------------------------------------------------------------------------
# multiprocessing exception __mro__.__len__() — extra47
#
# ProcessError MRO depth is 4:
#   [ProcessError, Exception, BaseException, object]
# AuthenticationError MRO depth is 5:
#   [AuthenticationError, ProcessError, Exception, BaseException, object]
# AuthenticationError has one extra entry compared to ProcessError.
# ---------------------------------------------------------------------------

table multiprocessing_extra47.exc_mro_len:
  description: "multiprocessing exception __mro__.__len__() in extra47 namespace — ProcessError==4, AuthenticationError==5"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: mpexc47mrolen

  columns: [id, function, args, expected, description]
  rows:
    - [ProcessError,        ProcessError.__mro__.__len__,        [], 4, "ProcessError.__mro__.__len__() == 4 — MRO: [ProcessError, Exception, BaseException, object]"]
    - [AuthenticationError, AuthenticationError.__mro__.__len__, [], 5, "AuthenticationError.__mro__.__len__() == 5 — MRO: [AuthenticationError, ProcessError, Exception, BaseException, object]"]

# ---------------------------------------------------------------------------
# multiprocessing exception __module__ string equality — extra47
#
# Both ProcessError and AuthenticationError are defined in
# Lib/multiprocessing/context.py:
#   ProcessError.__module__        == 'multiprocessing.context'
#   AuthenticationError.__module__ == 'multiprocessing.context'
# This is consistent with extra45 which showed all four exception classes
# share the same __module__ string.
# ---------------------------------------------------------------------------

table multiprocessing_extra47.exc_module_eq:
  description: "multiprocessing exception __module__ string equality in extra47 namespace — both ProcessError and AuthenticationError defined in multiprocessing.context"
  kind: python_call_eq
  category: module_identity
  id_prefix: mpexc47module

  columns: [id, function, args, expected, description]
  rows:
    - [ProcessError,        ProcessError.__module__.__eq__,        ["multiprocessing.context"], true, "ProcessError.__module__ == 'multiprocessing.context' — defined in Lib/multiprocessing/context.py"]
    - [AuthenticationError, AuthenticationError.__module__.__eq__, ["multiprocessing.context"], true, "AuthenticationError.__module__ == 'multiprocessing.context' — defined in Lib/multiprocessing/context.py alongside ProcessError"]

# ---------------------------------------------------------------------------
# multiprocessing.Queue and Pipe __class__.__name__ — extra47
#
# Unlike asyncio.Queue (a true class), multiprocessing.Queue and Pipe are
# bound methods of the DefaultContext singleton:
#   Queue.__class__.__name__ == 'method'
#   Pipe.__class__.__name__  == 'method'
# This distinguishes them from classes ('type') and standalone functions
# ('function'). These are factory methods exposed at module level by the
# context machinery.
# ---------------------------------------------------------------------------

table multiprocessing_extra47.factory_class_name_eq:
  description: "multiprocessing.Queue and Pipe __class__.__name__ string equality in extra47 namespace — both are bound methods of DefaultContext, reporting 'method'"
  kind: python_call_eq
  category: class_names
  id_prefix: mpexc47factory

  columns: [id, function, args, expected, description]
  rows:
    - [Queue, Queue.__class__.__name__.__eq__, ["method"], true, "Queue.__class__.__name__ == 'method' — multiprocessing.Queue is a bound method of DefaultContext, not a class; returns a queue object"]
    - [Pipe,  Pipe.__class__.__name__.__eq__,  ["method"], true, "Pipe.__class__.__name__ == 'method' — multiprocessing.Pipe is a bound method of DefaultContext, not a class; returns a pair of connection objects"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra47
# ---------------------------------------------------------------------------

invariant multiprocessing_extra47.ProcessError_bases_eq:
  description: "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception' — ProcessError is the root mp exception, directly subclassing Exception"
  category: exception_hierarchy
  kind: python_call_eq
  function: "ProcessError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant multiprocessing_extra47.AuthenticationError_bases_eq:
  description: "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError' — AuthenticationError subclasses ProcessError (one level deeper in the mp exception hierarchy)"
  category: exception_hierarchy
  kind: python_call_eq
  function: "AuthenticationError.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra47.ProcessError_mro_len:
  description: "multiprocessing.ProcessError.__mro__.__len__() == 4 — MRO: [ProcessError, Exception, BaseException, object]"
  category: exception_hierarchy
  kind: python_call_eq
  function: ProcessError.__mro__.__len__
  args: []
  expected: 4

invariant multiprocessing_extra47.AuthenticationError_mro_len:
  description: "multiprocessing.AuthenticationError.__mro__.__len__() == 5 — MRO: [AuthenticationError, ProcessError, Exception, BaseException, object]"
  category: exception_hierarchy
  kind: python_call_eq
  function: AuthenticationError.__mro__.__len__
  args: []
  expected: 5

invariant multiprocessing_extra47.ProcessError_module_eq:
  description: "multiprocessing.ProcessError.__module__ == 'multiprocessing.context' — ProcessError is defined in Lib/multiprocessing/context.py"
  category: module_identity
  kind: python_call_eq
  function: ProcessError.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra47.AuthenticationError_module_eq:
  description: "multiprocessing.AuthenticationError.__module__ == 'multiprocessing.context' — AuthenticationError is defined in Lib/multiprocessing/context.py alongside ProcessError"
  category: module_identity
  kind: python_call_eq
  function: AuthenticationError.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra47.Queue_class_name_eq:
  description: "multiprocessing.Queue.__class__.__name__ == 'method' — Queue is a bound method of DefaultContext singleton, not a class; this distinguishes it from asyncio.Queue which is a true class"
  category: class_names
  kind: python_call_eq
  function: Queue.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra47.Pipe_class_name_eq:
  description: "multiprocessing.Pipe.__class__.__name__ == 'method' — Pipe is a bound method of DefaultContext singleton, not a class or standalone function"
  category: class_names
  kind: python_call_eq
  function: Pipe.__class__.__name__.__eq__
  args: ["method"]
  expected: true
