spec: timeit
version: ">=3.0"
backend: python_module(timeit)

docs: https://docs.python.org/3/library/timeit.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/timeit.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from: []
  notes:
    - "timeit.default_timer is time.perf_counter on all platforms since Python 3.3; its type is 'builtin_function_or_method'."
    - "timeit.timeit(stmt, setup, timer, number) — positional args; timer defaults to default_timer when omitted."
    - "The behavioral test for timeit() uses a single call with stmt='1+1' and verifies the return type is float."
    - "Timer method names are checked on the unbound class; they are Python-level functions."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Raises standard Python exceptions; invalid stmt raises SyntaxError or other errors at compile/run time."
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# Module-level function names
# ---------------------------------------------------------------------------

invariant timeit.timeit.function_name:
  description: "timeit.timeit.__name__ == 'timeit'"
  category: functions
  kind: python_call_eq
  function: timeit.__name__.__eq__
  args: ["timeit"]
  expected: true

invariant timeit.repeat.function_name:
  description: "timeit.repeat.__name__ == 'repeat'"
  category: functions
  kind: python_call_eq
  function: repeat.__name__.__eq__
  args: ["repeat"]
  expected: true

invariant timeit.default_timer.type:
  description: "timeit.default_timer is a builtin_function_or_method (time.perf_counter)"
  category: functions
  kind: python_call_eq
  function: default_timer.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# Class identity
# ---------------------------------------------------------------------------

invariant timeit.Timer.class_name:
  description: "timeit.Timer.__name__ == 'Timer'"
  category: classes
  kind: python_call_eq
  function: Timer.__name__.__eq__
  args: ["Timer"]
  expected: true

invariant timeit.Timer.class_module:
  description: "timeit.Timer.__module__ == 'timeit'"
  category: classes
  kind: python_call_eq
  function: Timer.__module__.__eq__
  args: ["timeit"]
  expected: true

# ---------------------------------------------------------------------------
# Timer method names
# ---------------------------------------------------------------------------

invariant timeit.Timer.timeit.method_name:
  description: "timeit.Timer.timeit.__name__ == 'timeit'"
  category: methods
  kind: python_call_eq
  function: Timer.timeit.__name__.__eq__
  args: ["timeit"]
  expected: true

invariant timeit.Timer.repeat.method_name:
  description: "timeit.Timer.repeat.__name__ == 'repeat'"
  category: methods
  kind: python_call_eq
  function: Timer.repeat.__name__.__eq__
  args: ["repeat"]
  expected: true

invariant timeit.Timer.print_exc.method_name:
  description: "timeit.Timer.print_exc.__name__ == 'print_exc'"
  category: methods
  kind: python_call_eq
  function: Timer.print_exc.__name__.__eq__
  args: ["print_exc"]
  expected: true

invariant timeit.Timer.autorange.method_name:
  description: "timeit.Timer.autorange.__name__ == 'autorange'"
  category: methods
  kind: python_call_eq
  function: Timer.autorange.__name__.__eq__
  args: ["autorange"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral: timeit() returns a float
# ---------------------------------------------------------------------------

invariant timeit.timeit.returns_float:
  description: "timeit.timeit('1+1') returns a float"
  category: behavior
  kind: python_call_eq
  function: timeit
  args: ["1+1"]
  method: __class__
  method_args: []
  method_chain: __name__
  expected: "float"
