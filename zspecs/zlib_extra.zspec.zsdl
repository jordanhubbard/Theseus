spec: zlib_extra
version: ">=3.9"
backend: python_module(zlib)

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib module documentation"
    - "RFC 1950 — ZLIB Compressed Data Format Specification version 3.3"
    - "RFC 1951 — DEFLATE Compressed Data Format Specification version 1.3"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "zlib/deflate.c"
    - "zlib/inflate.c"
    - "CPython source: Modules/zlibmodule.c"
  notes:
    - "This spec covers the Python zlib module (not the zlib C library directly)."
    - "The existing zlib.zspec.zsdl covers the C library via ctypes; this spec covers the Python wrapper."
    - "zlib.compress() returns bytes in ZLIB format (RFC 1950), not raw DEFLATE."
    - "zlib.decompress() decompresses ZLIB-format bytes."
    - "zlib.compressobj() and zlib.decompressobj() return streaming compress/decompress objects."
    - "zlib.adler32(b'') == 1 — the Adler-32 of empty input is 1 (RFC 1950 Section 9 initial value)."
    - "zlib.crc32(b'') == 0 — the CRC-32 of empty input is 0."
    - "zlib.DEFLATED == 8 — the deflate compression method constant."
    - "zlib.Z_DEFAULT_COMPRESSION == -1 — sentinel for the default compression level."
    - "zlib.error is a subclass of Exception raised on compression/decompression failures."
    - "Pre-computed compress(b'hello') hex (level=6): 789ccb48cdc9c907000610039d"
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "zlib.error is raised on invalid compressed data or bad arguments."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Function name identity
# ---------------------------------------------------------------------------

invariant zlib_extra.compress.function_name:
  description: "zlib.compress.__name__ == 'compress'"
  category: function_names
  kind: python_call_eq
  function: compress.__name__.__eq__
  args: ["compress"]
  expected: true

invariant zlib_extra.compress.module_name:
  description: "zlib.compress.__module__ == 'zlib'"
  category: function_names
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["zlib"]
  expected: true

invariant zlib_extra.decompress.function_name:
  description: "zlib.decompress.__name__ == 'decompress'"
  category: function_names
  kind: python_call_eq
  function: decompress.__name__.__eq__
  args: ["decompress"]
  expected: true

invariant zlib_extra.compressobj.function_name:
  description: "zlib.compressobj.__name__ == 'compressobj'"
  category: function_names
  kind: python_call_eq
  function: compressobj.__name__.__eq__
  args: ["compressobj"]
  expected: true

invariant zlib_extra.decompressobj.function_name:
  description: "zlib.decompressobj.__name__ == 'decompressobj'"
  category: function_names
  kind: python_call_eq
  function: decompressobj.__name__.__eq__
  args: ["decompressobj"]
  expected: true

invariant zlib_extra.adler32.function_name:
  description: "zlib.adler32.__name__ == 'adler32'"
  category: function_names
  kind: python_call_eq
  function: adler32.__name__.__eq__
  args: ["adler32"]
  expected: true

invariant zlib_extra.crc32.function_name:
  description: "zlib.crc32.__name__ == 'crc32'"
  category: function_names
  kind: python_call_eq
  function: crc32.__name__.__eq__
  args: ["crc32"]
  expected: true

# ---------------------------------------------------------------------------
# error class identity
# ---------------------------------------------------------------------------

invariant zlib_extra.error.class_name:
  description: "zlib.error.__name__ == 'error'"
  category: class_names
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant zlib_extra.error.base_is_exception:
  description: "zlib.error.__bases__[0].__name__ == 'Exception'"
  category: class_names
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Constants — integer type checks
# ---------------------------------------------------------------------------

invariant zlib_extra.DEFLATED.class_is_int:
  description: "zlib.DEFLATED.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: DEFLATED.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant zlib_extra.Z_DEFAULT_COMPRESSION.class_is_int:
  description: "zlib.Z_DEFAULT_COMPRESSION.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: Z_DEFAULT_COMPRESSION.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Checksum edge cases
# ---------------------------------------------------------------------------

invariant zlib_extra.adler32.empty_bytes:
  description: "zlib.adler32(b'') == 1 — Adler-32 of empty input is 1 (RFC 1950 initial value)"
  category: checksum
  kind: python_call_eq
  function: adler32
  args: [!ascii ""]
  expected: 1

invariant zlib_extra.crc32.empty_bytes:
  description: "zlib.crc32(b'') == 0 — CRC-32 of empty input is 0"
  category: checksum
  kind: python_call_eq
  function: crc32
  args: [!ascii ""]
  expected: 0

# ---------------------------------------------------------------------------
# Roundtrip: decompress(compress(b'hello')) == b'hello'
# Pre-computed: compress(b'hello', level=6) hex == 789ccb48cdc9c907000610039d
# ---------------------------------------------------------------------------

invariant zlib_extra.roundtrip.decompress_recovers_hello:
  description: "zlib.decompress(zlib.compress(b'hello')) == b'hello' — roundtrip via pre-computed compressed bytes"
  category: roundtrip
  kind: python_call_eq
  function: decompress
  args: [{type: bytes_hex, value: "789ccb48cdc9c907000610039d"}]
  method: __eq__
  method_args: [!ascii hello]
  expected: true
