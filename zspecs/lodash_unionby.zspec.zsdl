spec: lodash_unionby
version: ">=4.0.0"
backend: node(lodash.unionby)

docs: https://lodash.com/docs/#unionBy

provenance:
  derived_from:
    - "lodash.unionby README — https://www.npmjs.com/package/lodash.unionby"
    - "Test vectors verified with lodash.unionby@4.8.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.unionby exports the _.unionBy function directly as module.exports."
    - "unionBy(array, values, iteratee) creates a union of arrays using iteratee for uniqueness."
    - "String iteratee plucks property for comparison. Elements from first array take precedence."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of unique elements from all arrays."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_unionby.unionby:
  kind: node_module_call_eq
  function: ~
  category: unionby
  id_prefix: luby

  columns: [id, args, expected]
  rows:
    - [by_x,  [[{"x": 1, "y": "a"}, {"x": 2, "y": "b"}], [{"x": 2, "y": "c"}, {"x": 3, "y": "d"}], "x"],
       [{"x": 1, "y": "a"}, {"x": 2, "y": "b"}, {"x": 3, "y": "d"}]]

