spec: lodash_map
version: ">=4.0.0"
backend: node(lodash.map)

docs: https://lodash.com/docs/#map

provenance:
  derived_from:
    - "lodash.map README — https://www.npmjs.com/package/lodash.map"
    - "Test vectors verified with lodash.map@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.map exports the _.map function directly as module.exports."
    - "map(collection, iteratee) transforms each element via the iteratee."
    - "String iteratee plucks the named property from each element (shorthand)."
    - "map(obj, key) returns values from each element for the given key."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of transformed values."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_map.map:
  kind: node_module_call_eq
  function: ~
  category: map
  id_prefix: lmap

  columns: [id, args, expected]
  rows:
    - [pluck_n,    [[{"n": 1}, {"n": 2}, {"n": 3}], "n"],        [1, 2, 3]]
    - [pluck_str,  [[{"s": "a"}, {"s": "b"}], "s"],              ["a", "b"]]
    - [nested,     [[{"x": {"v": 10}}, {"x": {"v": 20}}], "x.v"], [10, 20]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:33:24Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
