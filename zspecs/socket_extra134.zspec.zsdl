spec: socket_extra134
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra133.zspec.zsdl — covers socket.gethostname/__name__/__qualname__/__module__ equality / socket.gethostbyname identity / socket.getfqdn __name__/__module__/co_varnames[0] / socket.getaddrinfo co_varnames.__len__()==12 / socket.socket class identity (table + invariants)."
    - "socket_extra132.zspec.zsdl — covers socket.socket.bind/connect/listen/send/recv __qualname__ and __class__.__name__=='method_descriptor' / socket.__init__ and accept qualname equality (table + invariants)."
    - "socket_extra131.zspec.zsdl — covers socket.AF_INET/AF_INET6/AF_UNIX/SOCK_STREAM/SOCK_DGRAM/SOCK_RAW enum value equality / AddressFamily and SocketKind class name lengths (table + invariants)."
    - "socket_extra130.zspec.zsdl — covers socket module Python function code attributes — create_connection/getfqdn/getaddrinfo co_name/co_argcount/co_varnames[0]/co_varnames.__len__() (table + invariants)."
    - "socket_extra129.zspec.zsdl — covers socket.__all__ list membership / socket.socket C method __objclass__.__name__ equality (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module function __qualname__.__len__() / SocketIO class identity (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC __class__.__name__=='AddressFamily' / gethostname/gethostbyname as C builtins / getaddrinfo/create_connection as Python functions (table + invariants)."
    - "socket_extra95.zspec.zsdl — covers socket.AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length (table + invariants)."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ / byte-order function class names (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior socket spec files."
    - "Wave 352 theme: socket exception hierarchy — socket.herror/__name__/__qualname__/__module__/__bases__[0].__name__/__class__.__name__/__mro__.__len__() / socket.gaierror identity / socket.timeout.__name__/__module__ (alias for TimeoutError) / socket.error.__name__/__module__ (alias for OSError)."
    - "socket.herror.__name__ == 'herror'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__qualname__ == 'herror'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__module__ == 'socket'. herror is a Python-level subclass defined in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__bases__[0].__name__ == 'OSError'. herror subclasses OSError. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__mro__.__len__() == 5. MRO: (herror, OSError, Exception, BaseException, object). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__name__ == 'gaierror'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__qualname__ == 'gaierror'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__module__ == 'socket'. gaierror is a Python-level subclass defined in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__bases__[0].__name__ == 'OSError'. gaierror subclasses OSError. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__mro__.__len__() == 5. MRO: (gaierror, OSError, Exception, BaseException, object). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__name__ == 'TimeoutError'. socket.timeout IS TimeoutError (alias). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__module__ == 'builtins'. TimeoutError is a built-in exception. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__name__ == 'OSError'. socket.error IS OSError (alias). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__module__ == 'builtins'. OSError is a built-in exception. Verified Python 3.14.3 macOS/Darwin 25.4.0."
