    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.herror.__name__.__eq__('herror')
# socket.herror.__qualname__.__eq__('herror')
# socket.herror.__module__.__eq__('socket')
# socket.herror.__bases__[0].__name__.__eq__('OSError')
# socket.herror.__class__.__name__.__eq__('type')
#
# Wave 352 theme: socket.herror exception class identity.
#
# socket.herror is the exception raised for host address errors (e.g., from
# gethostbyname). It is a Python-level class defined in Lib/socket.py that
# subclasses OSError. Unlike socket.error (which is OSError itself) and
# socket.timeout (which is TimeoutError), socket.herror is a distinct class
# with __name__=='herror' and __module__=='socket'. Its MRO is
# (herror, OSError, Exception, BaseException, object) — 5 entries. No prior
# socket spec anchors herror class identity via __eq__ under sockexc134.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra134.herror_class_identity:
  description: "socket.herror/__name__.__eq__('herror')==True / herror/__qualname__.__eq__('herror')==True / herror/__module__.__eq__('socket')==True / herror/__bases__[0]/__name__.__eq__('OSError')==True / herror/__class__.__name__.__eq__('type')==True — herror is a Python-level subclass of OSError defined in Lib/socket.py; raised for host address errors; distinct from socket.error alias and socket.gaierror; first sockexc134 anchor for herror class identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockexc134

  columns: [id, function, args, expected, description]
  rows:
    - [herror_name,     herror.__name__.__eq__,               ["herror"],  true, "herror.__name__ is 'herror' (6 chars; lowercase following older socket convention)"]
    - [herror_qualname, herror.__qualname__.__eq__,            ["herror"],  true, "herror.__qualname__ is 'herror' (no enclosing class; same as __name__)"]
    - [herror_module,   herror.__module__.__eq__,              ["socket"],  true, "herror.__module__ is 'socket' (defined in Lib/socket.py)"]
    - [herror_base,     "herror.__bases__[0].__name__.__eq__", ["OSError"], true, "herror.__bases__[0].__name__ is 'OSError' (herror subclasses OSError directly)"]
    - [herror_cls,      herror.__class__.__name__.__eq__,      ["type"],    true, "herror.__class__.__name__ is 'type' (it is a class object; metaclass is 'type')"]

# ---------------------------------------------------------------------------
# socket.gaierror.__name__.__eq__('gaierror')
# socket.gaierror.__qualname__.__eq__('gaierror')
# socket.gaierror.__module__.__eq__('socket')
# socket.gaierror.__bases__[0].__name__.__eq__('OSError')
# socket.gaierror.__mro__.__len__().__eq__(5)
#
# Wave 352 theme: socket.gaierror exception class identity.
#
# socket.gaierror is raised for address-related errors from getaddrinfo and
# getnameinfo. Like socket.herror, it is a Python-level class defined in
# Lib/socket.py subclassing OSError. Its name 'gaierror' is short for
# "getaddrinfo error". The MRO is (gaierror, OSError, Exception, BaseException,
# object) — 5 entries, same depth as herror. Both herror and gaierror have the
# same structure: __module__=='socket', __bases__[0].__name__=='OSError',
# __mro__.__len__()==5, __class__.__name__=='type'. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table socket_extra134.gaierror_class_identity:
  description: "socket.gaierror/__name__.__eq__('gaierror')==True / gaierror/__qualname__.__eq__('gaierror')==True / gaierror/__module__.__eq__('socket')==True / gaierror/__bases__[0]/__name__.__eq__('OSError')==True / gaierror/__mro__/__len__()==5 — gaierror is a Python-level subclass of OSError for getaddrinfo errors; same structure as herror (module 'socket', base OSError, MRO depth 5); first sockexc134 anchor for gaierror class identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockexc134

  columns: [id, function, args, expected, description]
  rows:
    - [gaierror_name,     gaierror.__name__.__eq__,               ["gaierror"], true, "gaierror.__name__ is 'gaierror' (8 chars; short for 'getaddrinfo error')"]
    - [gaierror_qualname, gaierror.__qualname__.__eq__,            ["gaierror"], true, "gaierror.__qualname__ is 'gaierror' (same as __name__; top-level class)"]
    - [gaierror_module,   gaierror.__module__.__eq__,              ["socket"],   true, "gaierror.__module__ is 'socket' (defined in Lib/socket.py)"]
    - [gaierror_base,     "gaierror.__bases__[0].__name__.__eq__", ["OSError"],  true, "gaierror.__bases__[0].__name__ is 'OSError' (gaierror subclasses OSError)"]
    - [gaierror_mro_len,  gaierror.__mro__.__len__,                [],           5,    "gaierror.__mro__ has 5 entries: (gaierror, OSError, Exception, BaseException, object)"]

# ---------------------------------------------------------------------------
# socket.timeout.__name__.__eq__('TimeoutError')
# socket.timeout.__module__.__eq__('builtins')
# socket.timeout.__mro__.__len__().__eq__(5)
# socket.error.__name__.__eq__('OSError')
# socket.error.__module__.__eq__('builtins')
#
# Wave 352 theme: socket.timeout and socket.error as built-in aliases.
#
# socket.timeout IS TimeoutError (socket.timeout is TimeoutError evaluates to
# True). Its __name__ is 'TimeoutError' (not 'timeout') and its __module__ is
# 'builtins' (not 'socket'). Similarly, socket.error IS OSError — its __name__
# is 'OSError' and its __module__ is 'builtins'. This contrasts sharply with
# socket.herror and socket.gaierror, which are distinct Python-level classes
# with __module__=='socket' and lowercase __name__ values. socket.timeout.__mro__
# has 5 entries: (TimeoutError, OSError, Exception, BaseException, object) — one
# more level than socket.error (TimeoutError subclasses OSError).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra134.timeout_error_alias_identity:
  description: "socket.timeout/__name__.__eq__('TimeoutError')==True / timeout/__module__.__eq__('builtins')==True / timeout/__mro__/__len__()==5 / socket.error/__name__.__eq__('OSError')==True / error/__module__.__eq__('builtins')==True — socket.timeout IS TimeoutError and socket.error IS OSError (both are built-in aliases); contrasts with herror/gaierror which are distinct Python-level classes; first sockexc134 anchor for timeout/error alias identity via __eq__ calls"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockexc134

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_name,    timeout.__name__.__eq__,    ["TimeoutError"], true, "socket.timeout.__name__ is 'TimeoutError' (not 'timeout'; socket.timeout IS TimeoutError)"]
    - [timeout_module,  timeout.__module__.__eq__,  ["builtins"],     true, "socket.timeout.__module__ is 'builtins' (built-in exception, not defined in socket.py)"]
    - [timeout_mro_len, timeout.__mro__.__len__,    [],               5,    "socket.timeout.__mro__ has 5 entries: (TimeoutError, OSError, Exception, BaseException, object)"]
    - [error_name,      error.__name__.__eq__,      ["OSError"],      true, "socket.error.__name__ is 'OSError' (not 'error'; socket.error IS OSError alias)"]
    - [error_module,    error.__module__.__eq__,    ["builtins"],     true, "socket.error.__module__ is 'builtins' (OSError is a built-in exception)"]

# ---------------------------------------------------------------------------
# socket.herror.__name__.__eq__('herror') — standalone
#
# socket.herror.__name__ is 'herror'. Unlike socket.error (whose __name__ is
# 'OSError') and socket.timeout (whose __name__ is 'TimeoutError'), socket.herror
# has a __name__ that matches the attribute name used to access it. herror is
# a distinct Python class defined in Lib/socket.py, not merely an alias for a
# built-in. It follows the older convention of lowercase exception class names
# (cf. socket.gaierror, struct.error). No prior socket spec anchors herror
# __name__ via __eq__ as a standalone under sockexc134.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra134.herror_name:
  description: "socket.herror.__name__.__eq__('herror') == True — herror.__name__ matches the attribute access name (unlike socket.error/'OSError' and socket.timeout/'TimeoutError'); distinct Python class in Lib/socket.py following lowercase convention; first standalone for herror.__name__.__eq__ under sockexc134"
  category: type_identity
  kind: python_call_eq
  function: herror.__name__.__eq__
  args: ["herror"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gaierror.__name__.__eq__('gaierror') — standalone
#
# socket.gaierror.__name__ is 'gaierror'. socket.gaierror is the canonical
# exception for failed address resolution — it is raised by getaddrinfo,
# getnameinfo, and the Python-level socket functions that wrap them. Its name
# 'gaierror' is an abbreviation of 'getaddrinfo error'. Like socket.herror, its
# __name__ matches the attribute access name and it is a distinct Python class
# (not a built-in alias). No prior socket spec anchors gaierror.__name__ via
# __eq__ as a standalone under sockexc134.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra134.gaierror_name:
  description: "socket.gaierror.__name__.__eq__('gaierror') == True — gaierror is the canonical address-resolution failure exception (short for 'getaddrinfo error'); distinct Python class (not a built-in alias); raised by getaddrinfo/getnameinfo; first standalone for gaierror.__name__.__eq__ under sockexc134"
  category: type_identity
  kind: python_call_eq
  function: gaierror.__name__.__eq__
  args: ["gaierror"]
  expected: true

# ---------------------------------------------------------------------------
# socket.timeout.__name__.__eq__('TimeoutError') — standalone
#
# socket.timeout.__name__ is 'TimeoutError'. socket.timeout is not a separate
# class — it is the same object as the built-in TimeoutError. Python 3.3
# reorganized the OS exception hierarchy and socket.timeout was made an alias
# for TimeoutError. Code that catches socket.timeout is equivalent to catching
# TimeoutError. Because it is the built-in TimeoutError, its __name__ is
# 'TimeoutError' (not 'timeout') and its __module__ is 'builtins'. No prior
# socket spec anchors socket.timeout.__name__ via __eq__ as a standalone under
# sockexc134. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra134.timeout_name_TimeoutError:
  description: "socket.timeout.__name__.__eq__('TimeoutError') == True — socket.timeout IS TimeoutError (built-in alias since Python 3.3 OS exception reorganization); __name__ is 'TimeoutError' (not 'timeout'); __module__ is 'builtins'; first standalone for socket.timeout.__name__.__eq__ under sockexc134"
  category: type_identity
  kind: python_call_eq
  function: timeout.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.herror.__mro__.__len__().__eq__(5) — standalone
#
# socket.herror.__mro__.__len__() is 5. The MRO is
# (herror, OSError, Exception, BaseException, object). Having 5 entries means
# herror subclasses OSError (one extra level beyond the standard 4-entry
# Exception MRO). This contrasts with struct.error whose MRO has only 4 entries
# because struct.error subclasses Exception directly. The additional level in
# herror's MRO (OSError between herror and Exception) makes herror catchable by
# code that catches OSError. No prior socket spec anchors herror.__mro__.__len__()
# as a standalone under sockexc134. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra134.herror_mro_len_5:
  description: "socket.herror.__mro__.__len__() == 5 — herror MRO is (herror, OSError, Exception, BaseException, object); 5 entries because herror -> OSError -> Exception -> BaseException -> object; contrasts with struct.error (4 entries: error->Exception->BaseException->object); first standalone for herror.__mro__.__len__()==5 under sockexc134"
  category: type_identity
  kind: python_call_eq
  function: herror.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# socket.error.__name__.__eq__('OSError') — standalone
#
# socket.error.__name__ is 'OSError'. socket.error is an alias for the built-in
# OSError. Like socket.timeout/TimeoutError, this alias was created during
# Python 3.3's exception hierarchy reorganization to make socket exceptions
# more consistent with the rest of the OS error system. Code catching
# socket.error catches OSError and all its subclasses (including herror,
# gaierror, and timeout). Because socket.error IS OSError, its __name__ and
# __module__ reveal the built-in identity. No prior socket spec anchors
# socket.error.__name__ via __eq__ as a standalone under sockexc134.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra134.error_name_OSError:
  description: "socket.error.__name__.__eq__('OSError') == True — socket.error IS OSError (built-in alias since Python 3.3); __name__ is 'OSError' (not 'error'); catching socket.error catches all OSError subclasses including herror/gaierror/timeout; first standalone for socket.error.__name__.__eq__ under sockexc134"
  category: type_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

