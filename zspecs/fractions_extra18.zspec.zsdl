spec: fractions_extra18
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions_extra through fractions_extra17."
    - "fractions_extra2 covers Fraction.__add__.__name__ == '__add__'."
    - "fractions_extra13 covers Fraction.__sub__/__mul__/__truediv__ __name__ via table."
    - "No prior fractions spec covers Fraction method __qualname__ values."
    - "Fraction arithmetic operators (__add__, __sub__, __mul__, __truediv__) are generated by _operator_fallbacks; their __qualname__ is 'Fraction._operator_fallbacks.<locals>.forward' (length 45)."
    - "Fraction.__str__ and Fraction.__repr__ are defined directly on the class; their __qualname__ follows the 'Fraction.<name>' pattern."
    - "Fraction.limit_denominator is defined directly; __qualname__ == 'Fraction.limit_denominator'."
    - "Focus: Fraction class method __qualname__ values, including the _operator_fallbacks closure pattern."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Fraction operator method __qualname__ values
#
# Fraction's arithmetic dunder methods are generated by the _operator_fallbacks
# helper.  The resulting functions are local closures named 'forward', so their
# __qualname__ is 'Fraction._operator_fallbacks.<locals>.forward' for all four
# arithmetic operators.  No prior fractions spec records this qualname form.
# ---------------------------------------------------------------------------

invariant fractions_extra18.add.qualname:
  description: "fractions.Fraction.__add__.__qualname__ == 'Fraction._operator_fallbacks.<locals>.forward'"
  category: method_identity
  kind: python_call_eq
  function: "Fraction.__add__.__qualname__.__eq__"
  args: ["Fraction._operator_fallbacks.<locals>.forward"]
  expected: true

invariant fractions_extra18.sub.qualname:
  description: "fractions.Fraction.__sub__.__qualname__ == 'Fraction._operator_fallbacks.<locals>.forward'"
  category: method_identity
  kind: python_call_eq
  function: "Fraction.__sub__.__qualname__.__eq__"
  args: ["Fraction._operator_fallbacks.<locals>.forward"]
  expected: true

invariant fractions_extra18.mul.qualname:
  description: "fractions.Fraction.__mul__.__qualname__ == 'Fraction._operator_fallbacks.<locals>.forward'"
  category: method_identity
  kind: python_call_eq
  function: "Fraction.__mul__.__qualname__.__eq__"
  args: ["Fraction._operator_fallbacks.<locals>.forward"]
  expected: true

invariant fractions_extra18.truediv.qualname:
  description: "fractions.Fraction.__truediv__.__qualname__ == 'Fraction._operator_fallbacks.<locals>.forward'"
  category: method_identity
  kind: python_call_eq
  function: "Fraction.__truediv__.__qualname__.__eq__"
  args: ["Fraction._operator_fallbacks.<locals>.forward"]
  expected: true

invariant fractions_extra18.add.qualname_len:
  description: "len(fractions.Fraction.__add__.__qualname__) == 45 — length of 'Fraction._operator_fallbacks.<locals>.forward'"
  category: method_identity
  kind: python_call_eq
  function: "Fraction.__add__.__qualname__.__len__"
  args: []
  expected: 45

# ---------------------------------------------------------------------------
# Directly-defined method __qualname__ values
#
# __str__, __repr__, and limit_denominator are defined directly on Fraction;
# their __qualname__ follows the standard 'Fraction.<name>' pattern.
# ---------------------------------------------------------------------------

table fractions_extra18.direct_method_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [str,               Fraction.__str__.__qualname__.__eq__,              ["Fraction.__str__"],              true, "Fraction.__str__.__qualname__ == 'Fraction.__str__'"]
    - [repr,              Fraction.__repr__.__qualname__.__eq__,             ["Fraction.__repr__"],             true, "Fraction.__repr__.__qualname__ == 'Fraction.__repr__'"]
    - [limit_denominator, Fraction.limit_denominator.__qualname__.__eq__,   ["Fraction.limit_denominator"],   true, "Fraction.limit_denominator.__qualname__ == 'Fraction.limit_denominator'"]

invariant fractions_extra18.str.qualname_len:
  description: "len(fractions.Fraction.__str__.__qualname__) == 16 — 'Fraction.__str__' is 16 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__str__.__qualname__.__len__
  args: []
  expected: 16

invariant fractions_extra18.repr.qualname_len:
  description: "len(fractions.Fraction.__repr__.__qualname__) == 17 — 'Fraction.__repr__' is 17 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__repr__.__qualname__.__len__
  args: []
  expected: 17

invariant fractions_extra18.limit_denominator.qualname_len:
  description: "len(fractions.Fraction.limit_denominator.__qualname__) == 26 — 'Fraction.limit_denominator' is 26 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.limit_denominator.__qualname__.__len__
  args: []
  expected: 26
