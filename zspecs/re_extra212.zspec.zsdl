spec: re_extra212
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers re module-level functions and constants"
  notes:
    - "re.Pattern.__dict__ contains concrete method implementations for compiled patterns."
    - "sub, subn, split, fullmatch, findall, finditer are all present in Pattern.__dict__."
    - "re.error.__dict__ contains: __module__, __firstlineno__, __doc__, __init__, __static_attributes__, __weakref__."
    - "re.error.__dict__ does NOT contain __str__ or msg or pos (those are inherited or set as instance attrs)."
    - "re.error.__init__ is present in __dict__ as the custom constructor that sets msg, pos, lineno, colno."
    - "All __dict__.__contains__ checks verified with Python 3.14.3 macOS."
    - "re.Pattern.__dict__.__contains__('sub') == True; confirmed Python 3.14.3 macOS."
    - "re.Pattern.__dict__.__contains__('fullmatch') == True; confirmed Python 3.14.3 macOS."
    - "re.error.__dict__.__contains__('__init__') == True; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.Pattern.__dict__ membership — substitution and split methods
# sub, subn, split are concrete methods on compiled Pattern objects
# ---------------------------------------------------------------------------

table re_extra212.pattern_dict_sub_split_methods:
  description: "re.Pattern.__dict__ contains concrete substitution and split method implementations"
  kind: python_call_eq
  category: dict_membership
  id_prefix: rerepr212

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_has_sub,    "re.Pattern.__dict__.__contains__",  ["sub"],    true,  "re.Pattern.__dict__.__contains__('sub') == True; sub is a concrete method on Pattern; confirmed Python 3.14.3 macOS"]
    - [pattern_has_subn,   "re.Pattern.__dict__.__contains__",  ["subn"],   true,  "re.Pattern.__dict__.__contains__('subn') == True; subn is a concrete method on Pattern; confirmed Python 3.14.3 macOS"]
    - [pattern_has_split,  "re.Pattern.__dict__.__contains__",  ["split"],  true,  "re.Pattern.__dict__.__contains__('split') == True; split is a concrete method on Pattern; confirmed Python 3.14.3 macOS"]
    - [pattern_has_match,  "re.Pattern.__dict__.__contains__",  ["match"],  true,  "re.Pattern.__dict__.__contains__('match') == True; match is a concrete method on Pattern; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.Pattern.__dict__ membership — match and find methods
# fullmatch, findall, finditer, search are concrete methods on compiled Pattern objects
# ---------------------------------------------------------------------------

table re_extra212.pattern_dict_find_methods:
  description: "re.Pattern.__dict__ contains concrete match and find method implementations"
  kind: python_call_eq
  category: dict_membership
  id_prefix: rerepr212

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_has_fullmatch,  "re.Pattern.__dict__.__contains__",  ["fullmatch"],  true,  "re.Pattern.__dict__.__contains__('fullmatch') == True; fullmatch is a concrete method on Pattern; confirmed Python 3.14.3 macOS"]
    - [pattern_has_findall,    "re.Pattern.__dict__.__contains__",  ["findall"],    true,  "re.Pattern.__dict__.__contains__('findall') == True; findall is a concrete method on Pattern; confirmed Python 3.14.3 macOS"]
    - [pattern_has_finditer,   "re.Pattern.__dict__.__contains__",  ["finditer"],   true,  "re.Pattern.__dict__.__contains__('finditer') == True; finditer is a concrete method on Pattern; confirmed Python 3.14.3 macOS"]
    - [pattern_has_search,     "re.Pattern.__dict__.__contains__",  ["search"],     true,  "re.Pattern.__dict__.__contains__('search') == True; search is a concrete method on Pattern; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.error.__dict__ membership — custom exception class attributes
# re.error defines __init__ in its __dict__; other slots are inherited
# ---------------------------------------------------------------------------

table re_extra212.error_dict_attributes:
  description: "re.error.__dict__ contains custom exception class attributes"
  kind: python_call_eq
  category: dict_membership
  id_prefix: rerepr212

  columns: [id, function, args, expected, description]
  rows:
    - [error_has_init,               "re.error.__dict__.__contains__",  ["__init__"],               true,   "re.error.__dict__.__contains__('__init__') == True; __init__ is defined on re.error for msg/pos/lineno/colno; confirmed Python 3.14.3 macOS"]
    - [error_has_module,             "re.error.__dict__.__contains__",  ["__module__"],             true,   "re.error.__dict__.__contains__('__module__') == True; __module__ is a class attribute on re.error; confirmed Python 3.14.3 macOS"]
    - [error_has_doc,                "re.error.__dict__.__contains__",  ["__doc__"],                true,   "re.error.__dict__.__contains__('__doc__') == True; __doc__ is a class attribute on re.error; confirmed Python 3.14.3 macOS"]
    - [error_no_str,                 "re.error.__dict__.__contains__",  ["__str__"],                false,  "re.error.__dict__.__contains__('__str__') == False; __str__ is NOT defined on re.error (inherited from Exception); confirmed Python 3.14.3 macOS"]

