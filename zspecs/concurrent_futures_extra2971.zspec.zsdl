    - ["idx_ThreadPoolExecutor",  operator.contains, [ThreadPoolExecutor.__dict__,  "__index__"], false]
    - ["idx_ProcessPoolExecutor", operator.contains, [ProcessPoolExecutor.__dict__, "__index__"], false]
    - ["idx_CancelledError",      operator.contains, [CancelledError.__dict__,      "__index__"], false]
    - ["idx_TimeoutError",        operator.contains, [TimeoutError.__dict__,        "__index__"], false]
    - ["idx_BrokenExecutor",      operator.contains, [BrokenExecutor.__dict__,      "__index__"], false]
    - ["idx_InvalidStateError",   operator.contains, [InvalidStateError.__dict__,   "__index__"], false]

# ---------------------------------------------------------------------------
# combined — all three operators for a cross-class sample
#
# Spot-checks __floor__, __ceil__, __index__ absence across a representative
# selection of concurrent.futures classes in a single table for concise coverage.
# ---------------------------------------------------------------------------

table cf2971.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_Future_flr",               operator.contains, [Future.__dict__,              "__floor__"], false]
    - ["comb_Future_ceil",              operator.contains, [Future.__dict__,              "__ceil__"],  false]
    - ["comb_Future_idx",               operator.contains, [Future.__dict__,              "__index__"], false]
    - ["comb_ThreadPoolExecutor_flr",   operator.contains, [ThreadPoolExecutor.__dict__,  "__floor__"], false]
    - ["comb_ThreadPoolExecutor_ceil",  operator.contains, [ThreadPoolExecutor.__dict__,  "__ceil__"],  false]
    - ["comb_ThreadPoolExecutor_idx",   operator.contains, [ThreadPoolExecutor.__dict__,  "__index__"], false]
    - ["comb_ProcessPoolExecutor_flr",  operator.contains, [ProcessPoolExecutor.__dict__, "__floor__"], false]
    - ["comb_ProcessPoolExecutor_ceil", operator.contains, [ProcessPoolExecutor.__dict__, "__ceil__"],  false]
    - ["comb_ProcessPoolExecutor_idx",  operator.contains, [ProcessPoolExecutor.__dict__, "__index__"], false]
    - ["comb_CancelledError_flr",       operator.contains, [CancelledError.__dict__,      "__floor__"], false]
    - ["comb_CancelledError_ceil",      operator.contains, [CancelledError.__dict__,      "__ceil__"],  false]
    - ["comb_CancelledError_idx",       operator.contains, [CancelledError.__dict__,      "__index__"], false]
    - ["comb_BrokenExecutor_flr",       operator.contains, [BrokenExecutor.__dict__,      "__floor__"], false]
    - ["comb_BrokenExecutor_ceil",      operator.contains, [BrokenExecutor.__dict__,      "__ceil__"],  false]
    - ["comb_BrokenExecutor_idx",       operator.contains, [BrokenExecutor.__dict__,      "__index__"], false]
    - ["comb_InvalidStateError_flr",    operator.contains, [InvalidStateError.__dict__,   "__floor__"], false]
    - ["comb_InvalidStateError_ceil",   operator.contains, [InvalidStateError.__dict__,   "__ceil__"],  false]
    - ["comb_InvalidStateError_idx",    operator.contains, [InvalidStateError.__dict__,   "__index__"], false]
    - ["comb_TimeoutError_flr",         operator.contains, [TimeoutError.__dict__,        "__floor__"], false]
    - ["comb_TimeoutError_ceil",        operator.contains, [TimeoutError.__dict__,        "__ceil__"],  false]
    - ["comb_TimeoutError_idx",         operator.contains, [TimeoutError.__dict__,        "__index__"], false]
