    - ["ceil_ThreadPoolExecutor",  operator.contains, [ThreadPoolExecutor.__dict__,  "__ceil__"], false]
    - ["ceil_ProcessPoolExecutor", operator.contains, [ProcessPoolExecutor.__dict__, "__ceil__"], false]
    - ["ceil_CancelledError",      operator.contains, [CancelledError.__dict__,      "__ceil__"], false]
    - ["ceil_TimeoutError",        operator.contains, [TimeoutError.__dict__,        "__ceil__"], false]
    - ["ceil_BrokenExecutor",      operator.contains, [BrokenExecutor.__dict__,      "__ceil__"], false]
    - ["ceil_InvalidStateError",   operator.contains, [InvalidStateError.__dict__,   "__ceil__"], false]

