spec: cf2971
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 645 — theme: __floor__, __ceil__, __index__ dict-presence (floor, ceiling, integer-index)."
    - "Tests operator.contains(SomeClass.__dict__, '__floor__') etc. for concurrent.futures classes."
    - "None of Future, ThreadPoolExecutor, ProcessPoolExecutor, CancelledError, TimeoutError, BrokenExecutor, InvalidStateError define __floor__, __ceil__, or __index__ in their own __dict__."
    - "These are executor/future concurrency types; numeric dunder absence is the expected invariant."
    - "CancelledError.__module__ is 'concurrent.futures._base'; TimeoutError.__module__ is 'builtins' (re-exported built-in)."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __floor__ dict-presence — operator.contains(Cls.__dict__, '__floor__')
#
# None of the concurrent.futures classes define __floor__; all results are false.
# ---------------------------------------------------------------------------

table cf2971.floor:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_floor
  id_prefix: flr

  columns: [id, function, args, expected]
  rows:
    - ["flr_Future",              operator.contains, [Future.__dict__,              "__floor__"], false]
    - ["flr_ThreadPoolExecutor",  operator.contains, [ThreadPoolExecutor.__dict__,  "__floor__"], false]
    - ["flr_ProcessPoolExecutor", operator.contains, [ProcessPoolExecutor.__dict__, "__floor__"], false]
    - ["flr_CancelledError",      operator.contains, [CancelledError.__dict__,      "__floor__"], false]
    - ["flr_TimeoutError",        operator.contains, [TimeoutError.__dict__,        "__floor__"], false]
    - ["flr_BrokenExecutor",      operator.contains, [BrokenExecutor.__dict__,      "__floor__"], false]
    - ["flr_InvalidStateError",   operator.contains, [InvalidStateError.__dict__,   "__floor__"], false]

