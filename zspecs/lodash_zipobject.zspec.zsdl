spec: lodash_zipobject
version: ">=4.0.0"
backend: node(lodash.zipobject)

docs: https://lodash.com/docs/#zipObject

provenance:
  derived_from:
    - "lodash.zipobject README — https://www.npmjs.com/package/lodash.zipobject"
    - "Test vectors verified with lodash.zipobject@4.1.3 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.zipobject exports the _.zipObject function directly as module.exports."
    - "zipObject(props, values) creates an object from parallel arrays of keys and values."
    - "Excess keys get undefined values; excess values are ignored."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an object. No errors for array inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_zipobject.zipobject:
  kind: node_module_call_eq
  function: ~
  category: zipobject
  id_prefix: lzo

  columns: [id, args, expected]
  rows:
    - [two_pairs,    [["a", "b"], [1, 2]],       {"a": 1, "b": 2}]
    - [three_pairs,  [["x", "y", "z"], [10, 20, 30]], {"x": 10, "y": 20, "z": 30}]
    - [single,       [["k"], [99]],               {"k": 99}]

