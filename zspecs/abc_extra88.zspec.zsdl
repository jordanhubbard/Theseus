# ---------------------------------------------------------------------------
# Standalone invariants — extra88
# ---------------------------------------------------------------------------

invariant abc_extra88.update_abstractmethods_co_name:
  description: "abc.update_abstractmethods.__code__.co_name.__eq__('update_abstractmethods') returns True — the code object's co_name equals 'update_abstractmethods', confirming the internal function name; update_abstractmethods was added in Python 3.10 to allow updating a class's __abstractmethods__ set after class creation; NEW in extra88: first standalone co_name invariant for update_abstractmethods in abcupdateabs88 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: update_abstractmethods.__code__.co_name.__eq__
  args: ["update_abstractmethods"]
  expected: true

invariant abc_extra88.update_abstractmethods_co_argcount:
  description: "abc.update_abstractmethods.__code__.co_argcount == 1 — update_abstractmethods takes a single argument: the class whose __abstractmethods__ should be recomputed; its co_argcount is 1; update_abstractmethods was added in Python 3.10; NEW in extra88: first standalone co_argcount invariant for update_abstractmethods in abcupdateabs88 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: update_abstractmethods.__code__.co_argcount
  args: []
  expected: 1

invariant abc_extra88.ABCMeta_instancecheck_co_name:
  description: "abc.ABCMeta.__instancecheck__.__code__.co_name.__eq__('__instancecheck__') returns True — ABCMeta.__instancecheck__ is a Python function defined in Lib/abc.py; it overrides type.__instancecheck__ to support virtual subclass registration; its co_name is '__instancecheck__'; NEW in extra88: first standalone co_name invariant for ABCMeta.__instancecheck__ in abcupdateabs88 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__code__.co_name.__eq__
  args: ["__instancecheck__"]
  expected: true

invariant abc_extra88.ABCMeta_init_is_wrapper_descriptor:
  description: "abc.ABCMeta.__init__.__class__.__name__.__eq__('wrapper_descriptor') returns True — ABCMeta.__init__ is a wrapper_descriptor inherited from type (the parent metaclass); it has no __code__ attribute unlike the Python-function methods __instancecheck__ and __subclasscheck__; wrapper_descriptor is the type for slot wrappers in C extension classes; NEW in extra88: first standalone wrapper_descriptor class name invariant for ABCMeta.__init__ in abcupdateabs88 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__init__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true

invariant abc_extra88.abstractmethod_co_argcount:
  description: "abc.abstractmethod.__code__.co_argcount == 1 — abstractmethod is a Python function used as a decorator; it takes a single argument (the function being decorated) and sets __isabstractmethod__=True on it; its co_argcount is 1; this is the same co_argcount as update_abstractmethods (both take exactly one argument); NEW in extra88: first standalone co_argcount invariant for abstractmethod in abcupdateabs88 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__code__.co_argcount
  args: []
  expected: 1
