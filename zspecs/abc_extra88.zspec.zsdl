spec: abc_extra88
version: ">=3.10"
backend: python_module(abc)
extends: abc_extra87

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra87.zspec.zsdl."
    - "This spec covers: wave 253 theme — abc update_abstractmethods function code attrs + ABCMeta.__instancecheck__ and __subclasscheck__ code attrs + abstractmethod code attrs. NEW in extra88: update_abstractmethods.__code__.co_name=='update_abstractmethods'; update_abstractmethods.__code__.co_argcount==1; update_abstractmethods.__module__=='abc'; update_abstractmethods.__qualname__=='update_abstractmethods'; ABCMeta.__instancecheck__.__code__.co_name=='__instancecheck__'; ABCMeta.__instancecheck__.__code__.co_argcount==2; ABCMeta.__subclasscheck__.__code__.co_name=='__subclasscheck__'; ABCMeta.__subclasscheck__.__code__.co_argcount==2; ABCMeta.__init__.__class__.__name__=='wrapper_descriptor' (no __code__); ABCMeta.__prepare__.__class__.__name__=='builtin_function_or_method' (no __code__); abstractmethod.__code__.co_name=='abstractmethod'; abstractmethod.__code__.co_argcount==1; abstractmethod.__module__=='abc'; abstractmethod.__qualname__=='abstractmethod'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods was added in Python 3.10. It takes a single argument (the class to update) and updates its __abstractmethods__ set. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_name == 'update_abstractmethods'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_argcount == 1. Takes a single argument (the class). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__code__.co_name == '__instancecheck__'. Python function defined in abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__code__.co_argcount == 2. Takes cls and instance. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__code__.co_name == '__subclasscheck__'. Python function defined in abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__code__.co_argcount == 2. Takes cls and subclass. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__init__.__class__.__name__ == 'wrapper_descriptor'. ABCMeta.__init__ is a wrapper_descriptor (inherited from type) with no __code__ attribute. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__prepare__.__class__.__name__ == 'builtin_function_or_method'. ABCMeta.__prepare__ is a C builtin with no __code__ attribute. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_name == 'abstractmethod'. abstractmethod is a Python function used as a decorator. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_argcount == 1. abstractmethod takes a single argument (the function being decorated). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__module__ == 'abc'. abstractmethod is defined in the abc module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__qualname__ == 'abstractmethod'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

