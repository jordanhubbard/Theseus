    - [prepare_class_name,  "ABCMeta.__prepare__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "ABCMeta.__prepare__.__class__.__name__ == 'builtin_function_or_method' — C builtin, no __code__; verified with Python 3.14.3"]
