spec: socket_extra2041
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
    - "CPython source: Lib/socket.py, Modules/_socket.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2041): __lshift__, __rshift__, __and__, __or__, __xor__, __invert__ dict-presence checks."
    - "socket.socket is not a bitwise type; it defines none of these bit-shift or bitwise protocols in its own __dict__."
    - "socket.error, socket.timeout, and socket.gaierror are Exception subclasses; they define no bitwise protocols in their own __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; they inherit bitwise methods from int but define none of them in their own __dict__."
    - "All bit-shift and bitwise dunder methods are absent from all checked socket type dicts."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra2041.socket_lshift_protocol:
  description: "socket.socket __lshift__/__rlshift__/__ilshift__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2041

  columns: [id, function, args, expected]
  rows:
    - ["sk2041001", "socket.socket.__dict__.__contains__", ["__lshift__"],  false]
    - ["sk2041002", "socket.socket.__dict__.__contains__", ["__rlshift__"], false]
    - ["sk2041003", "socket.socket.__dict__.__contains__", ["__ilshift__"], false]

