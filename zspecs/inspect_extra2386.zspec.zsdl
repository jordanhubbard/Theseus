spec: inspect_extra2386
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 606 (_extra2386): __str__ and __repr__ implementation type classification."
    - "Python-defined __repr__ returns 'function'; C-level or inherited from object returns 'wrapper_descriptor'."
    - "inspect.Parameter, inspect.Signature, inspect.BoundArguments, inspect.FrameInfo all define __repr__ in Python."
    - "inspect.BoundArguments and inspect.FrameInfo inherit __str__ from object → 'wrapper_descriptor'."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table inspect_extra2386.repr_class_names:
  description: "inspect class __repr__ implementation type via .__repr__.__class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: in2386
  columns: [id, function, args, expected]
  rows:
    - ["in2386001", "inspect.Parameter.__repr__.__class__.__name__", [], "function"]
    - ["in2386002", "inspect.Signature.__repr__.__class__.__name__", [], "function"]
    - ["in2386003", "inspect.BoundArguments.__repr__.__class__.__name__", [], "function"]
    - ["in2386004", "inspect.FrameInfo.__repr__.__class__.__name__", [], "function"]

table inspect_extra2386.str_class_names:
  description: "inspect class __str__ implementation type via .__str__.__class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: in2386
  columns: [id, function, args, expected]
  rows:
    - ["in2386005", "inspect.Parameter.__str__.__class__.__name__", [], "function"]
    - ["in2386006", "inspect.Signature.__str__.__class__.__name__", [], "function"]
    - ["in2386007", "inspect.BoundArguments.__str__.__class__.__name__", [], "wrapper_descriptor"]
    - ["in2386008", "inspect.FrameInfo.__str__.__class__.__name__", [], "wrapper_descriptor"]

table inspect_extra2386.repr_eq_function:
  description: "All four inspect classes define __repr__ in Python: __repr__.__class__.__name__ == 'function'"
  kind: python_call_eq
  category: type_identity
  id_prefix: in2386
  columns: [id, function, args, expected]
  rows:
    - ["in2386009", "inspect.Parameter.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["in2386010", "inspect.Signature.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["in2386011", "inspect.BoundArguments.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["in2386012", "inspect.FrameInfo.__repr__.__class__.__name__.__eq__", ["function"], true]

table inspect_extra2386.parameter_and_signature_str_eq_function:
  description: "inspect.Parameter and inspect.Signature also define __str__ in Python → 'function'"
  kind: python_call_eq
  category: type_identity
  id_prefix: in2386
  columns: [id, function, args, expected]
  rows:
    - ["in2386013", "inspect.Parameter.__str__.__class__.__name__.__eq__", ["function"], true]
    - ["in2386014", "inspect.Signature.__str__.__class__.__name__.__eq__", ["function"], true]

table inspect_extra2386.boundarguments_and_frameinfo_str_eq_wrapper_descriptor:
  description: "inspect.BoundArguments and inspect.FrameInfo inherit __str__ from object → 'wrapper_descriptor'"
  kind: python_call_eq
  category: type_identity
  id_prefix: in2386
  columns: [id, function, args, expected]
  rows:
    - ["in2386015", "inspect.BoundArguments.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["in2386016", "inspect.FrameInfo.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

table inspect_extra2386.cross_check_all:
  description: "Cross-check all repr/str classification results for the four inspect subjects"
  kind: python_call_eq
  category: type_identity
  id_prefix: in2386
  columns: [id, function, args, expected]
  rows:
    - ["in2386017", "inspect.Parameter.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["in2386018", "inspect.Parameter.__str__.__class__.__name__.__eq__", ["function"], true]
    - ["in2386019", "inspect.Signature.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["in2386020", "inspect.Signature.__str__.__class__.__name__.__eq__", ["function"], true]
    - ["in2386021", "inspect.BoundArguments.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["in2386022", "inspect.BoundArguments.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["in2386023", "inspect.FrameInfo.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["in2386024", "inspect.FrameInfo.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
