spec: re_extra35
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra34.zspec.zsdl — covers module-level function __qualname__.__len__() for compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape/purge; error.__bases__[0].__name__.__len__()==9; Pattern.sub/__qualname__.__len__()==11; Pattern.finditer/__qualname__.__len__()==16."
    - "re_extra33.zspec.zsdl — covers re.__all__.__len__()==31; __dict__.__class__.__name__.__len__()==12 for error/Pattern/Match/RegexFlag; __reduce__.__name__.__len__()==10 for same; __init_subclass__.__qualname__.__len__() for same; IGNORECASE.__class__.__name__.__len__()==9; int flag values."
    - "re_extra32.zspec.zsdl — covers Pattern/Match method __qualname__.__len__() for all main methods."
    - "re_extra31.zspec.zsdl — covers split/findall/finditer/purge/escape __module__.__len__()==2; __name__.__len__() for same; Pattern/__name__.__len__()==7; Match/__name__.__len__()==5."
    - "re_extra27.zspec.zsdl — covers RegexFlag.__module__, RegexFlag.__bases__[0].__name__, error.__qualname__/__bases__[0].__name__, IGNORECASE/MULTILINE class qualname/module."
  notes:
    - "This spec extends re_extra34.zspec.zsdl."
    - "Prior specs covered: all Pattern/Match/__name__/__module__/__qualname__ and their lengths, all public function __name__/__module__/__qualname__/__qualname__.__len__(), error/__name__/__module__/__qualname__/__bases__, RegexFlag/__module__/__bases__[0].__name__, IGNORECASE/MULTILINE/DOTALL/VERBOSE values and class names, Pattern/Match method __qualname__.__len__() for all main methods, __all__.__len__(), __dict__/__reduce__/__init_subclass__ class names for error/Pattern/Match/RegexFlag."
    - "This spec covers: re.__version__.__len__() (NOVEL — 'rX.Y.Z' version string; no prior re spec checks this); re.RegexFlag.__mro__.__len__() (NOVEL — RegexFlag MRO depth is 7 due to IntFlag/Flag/Enum hierarchy); re.RegexFlag.__name__.__len__() (NOVEL — 'RegexFlag' is 9 chars; prior specs check __qualname__.__eq__ and __module__.__eq__ but not __name__.__len__()); re.Pattern.__dict__.__len__() (NOVEL — 26 entries; no prior spec counts Pattern.__dict__ directly); re.Match.__dict__.__len__() (NOVEL — 21 entries); re.error.__dict__.__len__() (NOVEL — 6 entries); re.error.__init__.__qualname__.__len__() (NOVEL — 'PatternError.__init__' is 21 chars); re.error.__str__.__qualname__.__len__() (NOVEL — 'BaseException.__str__' is 21 chars); re.PatternError.__name__.__len__() (NOVEL — 'PatternError' is 12 chars accessed via the canonical class name, not the alias)."
    - "re.__version__ == '2.2.1' (len 5). The re module exports a version string. No prior re spec checks __version__ or its length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.RegexFlag.__mro__ == [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object] — length 7. IntFlag itself inherits from int, ReprEnum, Flag; Flag inherits from Enum. This gives RegexFlag the deepest MRO among re classes. No prior re spec checks RegexFlag.__mro__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.RegexFlag.__name__ == 'RegexFlag' (len 9). Prior specs check __qualname__.__eq__('RegexFlag') and __module__.__eq__('re') but not __name__.__len__(). Since __name__ == __qualname__ for top-level classes, the length is the same 9. Novel invariant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.Pattern.__dict__.__len__() == 26: Pattern has 26 entries in its class dict. No prior re spec measures this count. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.Match.__dict__.__len__() == 21: Match has 21 entries in its class dict. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.error.__dict__.__len__() == 6: PatternError has 6 entries in its class dict (fewer than Pattern/Match since it is an exception class). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.error.__init__.__qualname__ == 'PatternError.__init__' (len 21). re.error is an alias for PatternError; extra33 covers error.__init_subclass__.__qualname__.__len__()==30 but not __init__.__qualname__.__len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.error.__str__.__qualname__ == 'BaseException.__str__' (len 21). PatternError inherits __str__ from BaseException. No prior re spec checks error.__str__.__qualname__.__len__(). Note the same numeric value (21) as error.__init__.__qualname__.__len__() is a coincidence from different paths. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.PatternError.__name__ == 'PatternError' (len 12). re.error is an alias; the canonical class is re.PatternError. Prior specs (extra27/extra33) verify error.__qualname__.__eq__('PatternError') and error.__name__.__len__ is implicit from that, but no prior spec explicitly checks PatternError.__name__.__len__() directly. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.__version__.__len__() — module version string
#
# re.__version__ == '2.2.1' (length 5). No prior re spec checks the version
# string or its length. The version attribute is a module-level string; its
# type and length are stable invariants for Python 3.12 on this platform.
# ---------------------------------------------------------------------------

invariant re_extra35.module.version_len:
  description: "re.__version__.__len__() == 5 — '2.2.1' has 5 characters, novel invariant"
  category: module_identity
  kind: python_call_eq
  function: __version__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# re.RegexFlag — class name length and MRO depth
#
# RegexFlag is an IntFlag subclass. Its MRO traverses IntFlag → int →
# ReprEnum → Flag → Enum → object, giving 7 entries total (including
# RegexFlag itself). No prior re spec checks __mro__.__len__() or
# __name__.__len__() for RegexFlag. Both are novel invariants.
# ---------------------------------------------------------------------------

invariant re_extra35.RegexFlag.name_len:
  description: "re.RegexFlag.__name__.__len__() == 9 — 'RegexFlag' has 9 characters; novel length complement to __qualname__.__eq__ checked in extra27"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__name__.__len__
  args: []
  expected: 9

invariant re_extra35.RegexFlag.mro_len:
  description: "re.RegexFlag.__mro__.__len__() == 7 — [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object]; deepest MRO of any re class"
  category: class_hierarchy
  kind: python_call_eq
  function: RegexFlag.__mro__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Table: Pattern / Match / error __dict__.__len__()
#
# No prior re spec measures the number of entries in Pattern, Match, or
# error class dicts. Pattern has 26 entries, Match has 21, error has 6.
# These counts distinguish the relative complexity of each type:
# Pattern is richer than Match; error is minimal (exception semantics only).
# ---------------------------------------------------------------------------

table re_extra35.class_dict_sizes:
  description: "re.Pattern / Match / error __dict__.__len__() — entry counts; no prior re spec measures these sizes"
  kind: python_call_eq
  category: class_structure
  id_prefix: rcd35

  columns: [id, function, args, expected]
  rows:
    - [Pattern, Pattern.__dict__.__len__, [], 26]
    - [Match,   Match.__dict__.__len__,   [], 21]
    - [error,   error.__dict__.__len__,   [],  6]

# ---------------------------------------------------------------------------
# re.PatternError.__name__.__len__() — canonical class name length
#
# re.error is an alias for re.PatternError (Python 3.12+). The canonical class
# name is 'PatternError' (12 chars). Prior specs verify error.__qualname__
# equality but not the length via the PatternError name path. Novel invariant.
# ---------------------------------------------------------------------------

invariant re_extra35.PatternError.name_len:
  description: "re.PatternError.__name__.__len__() == 12 — 'PatternError' has 12 characters; accessed via canonical class name rather than error alias"
  category: class_identity
  kind: python_call_eq
  function: PatternError.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Table: re.error dunder method __qualname__.__len__()
#
# re.error is an alias for re.PatternError. Its __init__.__qualname__ is
# 'PatternError.__init__' (21 chars). Its __str__.__qualname__ is
# 'BaseException.__str__' (21 chars) — PatternError inherits __str__ from
# BaseException. extra33 covers error.__init_subclass__.__qualname__.__len__()==30
# but not __init__ or __str__. Both are novel and numerically coincide at 21.
# ---------------------------------------------------------------------------

table re_extra35.error_dunder_qualname_lens:
  description: "re.error.__init__ and __str__ __qualname__.__len__() — both equal 21; novel invariants not covered by extra33"
  kind: python_call_eq
  category: method_identity
  id_prefix: redq35

  columns: [id, function, args, expected]
  rows:
    - [init, error.__init__.__qualname__.__len__, [], 21]
    - [str,  error.__str__.__qualname__.__len__,  [], 21]
