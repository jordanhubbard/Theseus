spec: hashlib_extra1516
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "https://docs.python.org/3/library/_hashlib.html — CPython _hashlib C extension type docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha3/sha3module.c"
    - "hashlib_extra15.zspec.zsdl — covers new() digest_size/block_size/name for sha3_256/sha3_512/blake2b/shake_128; algorithms_guaranteed sha3_512/blake2b/shake_128; pbkdf2_hmac __name__/__module__; sha3_512 hexdigest vector."
    - "hashlib_extra14.zspec.zsdl — covers algorithms_guaranteed/available class_name=='set'; new('md5'/'sha1'/'sha512'/'sha3_256') block_size; new('sha256') class_name; sha256().copy() attrs; sha256/md5/sha1 hexdigest vectors."
  notes:
    - "This spec is wave 548 / suffix _extra1516. Theme: arithmetic/numeric operator dict-presence checks on _hashlib.HASH."
    - "_hashlib.HASH is the C-extension type returned by hashlib.md5(), hashlib.sha256(), etc. It is not numeric."
    - "Verified: _hashlib.HASH.__dict__.__contains__('__add__') == False — HASH does not implement __add__."
    - "Verified: _hashlib.HASH.__dict__.__contains__('__mul__') == False — HASH does not implement __mul__."
    - "Verified: _hashlib.HASH.__dict__.__contains__('__sub__') == False — HASH does not implement __sub__."
    - "Verified: _hashlib.HASH.__dict__.__contains__('__truediv__') == False — HASH does not implement __truediv__."
    - "Verified: _hashlib.HASH.__dict__.__contains__('__floordiv__') == False — HASH does not implement __floordiv__."
    - "Verified: _hashlib.HASH.__dict__.__contains__('__mod__') == False — HASH does not implement __mod__."
    - "Verified: _hashlib.HASH.__dict__.__contains__('__pow__') == False — HASH does not implement __pow__."
    - "Verified: _hashlib.HASH.__dict__.__contains__('update') == True; 'digest' == True; 'hexdigest' == True; 'copy' == True; 'name' == True; 'digest_size' == True; 'block_size' == True."
    - "The type returned by hashlib.md5() is _hashlib.HASH; the type() call itself is used to reference the class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _hashlib.HASH — arithmetic operator absence checks
#
# _hashlib.HASH is the internal C-extension hash object type. It is a
# cryptographic hash state, not a numeric type. None of the standard
# arithmetic dunder methods (__add__, __mul__, __sub__, __truediv__,
# __floordiv__, __mod__, __pow__) are present in its __dict__.
# Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table hashlib_extra1516.hash_arith_absent:
  description: "Arithmetic operator dunders absent from _hashlib.HASH.__dict__ — HASH is not a numeric type"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl1516aa

  columns: [id, function, args, expected]
  rows:
    - ["hl1516aa001", "new.__class__.__class__.__name__.__eq__", ["type"], true]
    - ["hl1516aa002", "md5().__class__.__dict__.__contains__", ["__add__"],      false]
    - ["hl1516aa003", "md5().__class__.__dict__.__contains__", ["__mul__"],      false]
    - ["hl1516aa004", "md5().__class__.__dict__.__contains__", ["__sub__"],      false]
    - ["hl1516aa005", "md5().__class__.__dict__.__contains__", ["__truediv__"],  false]
    - ["hl1516aa006", "md5().__class__.__dict__.__contains__", ["__floordiv__"], false]
    - ["hl1516aa007", "md5().__class__.__dict__.__contains__", ["__mod__"],      false]
    - ["hl1516aa008", "md5().__class__.__dict__.__contains__", ["__pow__"],      false]

# ---------------------------------------------------------------------------
# _hashlib.HASH — method presence checks
#
# The hash object type exposes its cryptographic API (update, digest,
# hexdigest, copy) and attribute descriptors (name, digest_size, block_size)
# directly in __dict__. These True entries contrast with the False arithmetic
# entries above, confirming the __dict__ lookup mechanism works correctly.
# ---------------------------------------------------------------------------

table hashlib_extra1516.hash_methods_present:
  description: "Cryptographic method/attribute dunders present in _hashlib.HASH.__dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl1516mp

  columns: [id, function, args, expected]
  rows:
    - ["hl1516mp001", "md5().__class__.__dict__.__contains__", ["update"],      true]
    - ["hl1516mp002", "md5().__class__.__dict__.__contains__", ["digest"],      true]
    - ["hl1516mp003", "md5().__class__.__dict__.__contains__", ["hexdigest"],   true]
    - ["hl1516mp004", "md5().__class__.__dict__.__contains__", ["copy"],        true]
    - ["hl1516mp005", "md5().__class__.__dict__.__contains__", ["name"],        true]
    - ["hl1516mp006", "md5().__class__.__dict__.__contains__", ["digest_size"], true]
    - ["hl1516mp007", "md5().__class__.__dict__.__contains__", ["block_size"],  true]

# ---------------------------------------------------------------------------
# _hashlib.HASH via sha256 — same arithmetic absence, different constructor
#
# Using sha256() confirms the same _hashlib.HASH type is returned by
# different hashlib constructors and that arithmetic ops are universally
# absent. These invariants are distinct from the md5()-based table above.
# ---------------------------------------------------------------------------

table hashlib_extra1516.sha256_hash_arith_absent:
  description: "Arithmetic operator dunders absent from sha256().__class__.__dict__ — same HASH type via sha256"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl1516sa

  columns: [id, function, args, expected]
  rows:
    - ["hl1516sa001", "sha256().__class__.__dict__.__contains__", ["__add__"],      false]
    - ["hl1516sa002", "sha256().__class__.__dict__.__contains__", ["__mul__"],      false]
    - ["hl1516sa003", "sha256().__class__.__dict__.__contains__", ["__sub__"],      false]
    - ["hl1516sa004", "sha256().__class__.__dict__.__contains__", ["__truediv__"],  false]
    - ["hl1516sa005", "sha256().__class__.__dict__.__contains__", ["__floordiv__"], false]
    - ["hl1516sa006", "sha256().__class__.__dict__.__contains__", ["__mod__"],      false]
    - ["hl1516sa007", "sha256().__class__.__dict__.__contains__", ["__pow__"],      false]
    - ["hl1516sa008", "sha256().__class__.__dict__.__contains__", ["update"],       true]
    - ["hl1516sa009", "sha256().__class__.__dict__.__contains__", ["hexdigest"],    true]
