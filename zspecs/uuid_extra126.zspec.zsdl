spec: uuid_extra126
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra125.zspec.zsdl — covers uuid.getnode __name__/__qualname__/__module__/co_argcount/co_name identity / uuid1/uuid3/uuid5/uuid4 co_varnames[0] / uuid.SafeUUID __name__/__qualname__/__module__/__class__.__name__/__bases__[0].__name__ (table + invariants)."
    - "uuid_extra124.zspec.zsdl — covers UUID property __class__.__name__ equality / UUID property fget __class__.__name__ and co_argcount / UUID.is_safe member_descriptor identity, qualname, and name (table + invariants)."
    - "uuid_extra123.zspec.zsdl — covers UUID.__slots__ class name/length/contains / UUID.__weakref__ descriptor / UUID.int member_descriptor identity / UUID.__hash__ code co_argcount (table + invariants)."
    - "uuid_extra122.zspec.zsdl — covers UUID.__init__/__str__/__repr__/__eq__ co_varnames[0] ('self') and co_varnames.__len__() / co_argcount for __str__/__repr__/__eq__ (table + invariants)."
    - "uuid_extra121.zspec.zsdl — covers uuid6/uuid7/uuid8 function __name__/__qualname__/__module__/__code__.co_argcount identity / uuid.NIL and uuid.MAX sentinel UUID values (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__ co_name/co_argcount/__qualname__ / UUID.__str__/__repr__/__eq__/__hash__/__lt__ method qualname equality (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__/__class__.__name__/__qualname__ (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior uuid spec files."
    - "Wave 350 theme: uuid.NAMESPACE_DNS/NAMESPACE_URL/NAMESPACE_OID/NAMESPACE_X500 class name equality / NAMESPACE_DNS/URL/OID/X500 version equality (all 1) / NAMESPACE_DNS.version.__class__.__name__ / NAMESPACE_DNS.hex equality and length / NIL.int and NIL.__class__.__name__."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.version == 1. All four namespace UUIDs are version-1 UUIDs. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.version.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.hex == '6ba7b8109dad11d180b400c04fd430c8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.hex == '6ba7b8119dad11d180b400c04fd430c8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.hex == '6ba7b8129dad11d180b400c04fd430c8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.hex == '6ba7b8149dad11d180b400c04fd430c8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(uuid.NAMESPACE_DNS.hex) == 32. UUID hex strings are 32 hex digits (128 bits / 4 bits per hex digit). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NIL.int == 0. NIL UUID is all-zeros. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NIL.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra121 anchors uuid.NIL and uuid.MAX sentinel values at table level. This spec is the first to anchor NAMESPACE_DNS/URL/OID/X500 class names, version values, hex strings, and NIL.int via __eq__ calls under uuidns126."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_OID.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_X500.__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_DNS.version.__class__.__name__.__eq__('int')
#
# Wave 350 theme: namespace constant type identity.
#
# uuid.NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500 are module-
# level UUID instances defined in RFC 4122. They serve as namespace identifiers
# for uuid3 (MD5-based) and uuid5 (SHA-1-based) name-based UUID generation.
# All four have __class__.__name__ == 'UUID', confirming they are UUID instances.
# Their .version attribute is the Python int 1 (version-1 UUID format), so
# .version.__class__.__name__ == 'int'. No prior uuid spec anchors namespace
# constant class names via __eq__ under uuidns126.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra126.namespace_class_identity:
  description: "uuid.NAMESPACE_DNS/__class__.__name__.__eq__('UUID')==True / NAMESPACE_URL/__class__.__name__.__eq__('UUID')==True / NAMESPACE_OID/__class__.__name__.__eq__('UUID')==True / NAMESPACE_X500/__class__.__name__.__eq__('UUID')==True / NAMESPACE_DNS/version/__class__.__name__.__eq__('int')==True — all four RFC 4122 namespace constants are UUID instances; used as namespace args to uuid3/uuid5; version is int 1; first uuidns126 anchor for namespace class names"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidns126

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_cls,   NAMESPACE_DNS.__class__.__name__.__eq__,    ["UUID"], true, "NAMESPACE_DNS.__class__.__name__ is 'UUID' (it is a UUID instance)"]
    - [ns_url_cls,   NAMESPACE_URL.__class__.__name__.__eq__,    ["UUID"], true, "NAMESPACE_URL.__class__.__name__ is 'UUID' (UUID instance for URL namespace)"]
    - [ns_oid_cls,   NAMESPACE_OID.__class__.__name__.__eq__,    ["UUID"], true, "NAMESPACE_OID.__class__.__name__ is 'UUID' (UUID instance for OID namespace)"]
    - [ns_x500_cls,  NAMESPACE_X500.__class__.__name__.__eq__,   ["UUID"], true, "NAMESPACE_X500.__class__.__name__ is 'UUID' (UUID instance for X.500 namespace)"]
    - [ns_ver_cls,   NAMESPACE_DNS.version.__class__.__name__.__eq__, ["int"], true, "NAMESPACE_DNS.version.__class__.__name__ is 'int' (version is Python int 1)"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.version.__eq__(1)
# uuid.NAMESPACE_URL.version.__eq__(1)
# uuid.NAMESPACE_OID.version.__eq__(1)
# uuid.NAMESPACE_X500.version.__eq__(1)
# uuid.NAMESPACE_DNS.hex.__len__().__eq__(32)
#
# Wave 350 theme: namespace constant version values and hex length.
#
# All four RFC 4122 namespace UUIDs are version-1 UUIDs — their top 4 bits of
# the time_hi_and_version field encode version 1. The UUID.version property
# returns the integer version number (1–5) or None if the UUID was not created
# with a specific version (like NIL and MAX). Each namespace UUID's .hex
# attribute is a 32-character lowercase hex string (4 bits per hex digit,
# 128-bit UUID = 32 hex chars). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra126.namespace_version_and_hex_len:
  description: "uuid.NAMESPACE_DNS/version.__eq__(1)==True / NAMESPACE_URL/version.__eq__(1)==True / NAMESPACE_OID/version.__eq__(1)==True / NAMESPACE_X500/version.__eq__(1)==True / NAMESPACE_DNS/hex/__len__()==32 — all four namespace constants are version-1 UUIDs (as defined in RFC 4122); hex is 32 hex chars (128 bits); first uuidns126 anchor for namespace version values and hex length"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidns126

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_ver,    NAMESPACE_DNS.version.__eq__,    [1],  true, "NAMESPACE_DNS.version is 1 (version-1 UUID as defined in RFC 4122)"]
    - [ns_url_ver,    NAMESPACE_URL.version.__eq__,    [1],  true, "NAMESPACE_URL.version is 1 (version-1 UUID for URL namespace)"]
    - [ns_oid_ver,    NAMESPACE_OID.version.__eq__,    [1],  true, "NAMESPACE_OID.version is 1 (version-1 UUID for OID namespace)"]
    - [ns_x500_ver,   NAMESPACE_X500.version.__eq__,   [1],  true, "NAMESPACE_X500.version is 1 (version-1 UUID for X.500 namespace)"]
    - [ns_dns_hexlen, NAMESPACE_DNS.hex.__len__,        [],   32,   "NAMESPACE_DNS.hex is 32 chars (128 bits / 4 bits per hex digit = 32 hex digits)"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.hex.__eq__('6ba7b8109dad11d180b400c04fd430c8')
# uuid.NAMESPACE_URL.hex.__eq__('6ba7b8119dad11d180b400c04fd430c8')
# uuid.NAMESPACE_OID.hex.__eq__('6ba7b8129dad11d180b400c04fd430c8')
# uuid.NAMESPACE_X500.hex.__eq__('6ba7b8149dad11d180b400c04fd430c8')
# uuid.NIL.int.__eq__(0)
#
# Wave 350 theme: namespace constant hex values and NIL.int.
#
# The four RFC 4122 namespace UUIDs have well-known hex values defined by the
# standard. NAMESPACE_DNS and NAMESPACE_URL differ only in the last hex digit
# of the first group (0 vs 1); NAMESPACE_OID has 2; NAMESPACE_X500 has 4
# (note: 3 is absent from the RFC 4122 namespace list). uuid.NIL.int is 0 —
# the NIL UUID is all-zero bits (128-bit integer value 0). This contrasts with
# uuid.MAX.int which is 2^128-1. extra121 anchors NIL and MAX at table level;
# this spec anchors NIL.int.__eq__(0) via __eq__ under uuidns126.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra126.namespace_hex_values:
  description: "uuid.NAMESPACE_DNS/hex.__eq__('6ba7b8109dad11d180b400c04fd430c8')==True / NAMESPACE_URL/hex.__eq__('6ba7b8119dad11d180b400c04fd430c8')==True / NAMESPACE_OID/hex.__eq__('6ba7b8129dad11d180b400c04fd430c8')==True / NAMESPACE_X500/hex.__eq__('6ba7b8149dad11d180b400c04fd430c8')==True / NIL/int.__eq__(0)==True — hex values per RFC 4122; NAMESPACE_X500 uses 4 (not 3) in last digit of first group; NIL.int==0 (all-zero 128-bit UUID); first uuidns126 anchor for namespace hex strings and NIL.int"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidns126

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_hex,   NAMESPACE_DNS.hex.__eq__,   ["6ba7b8109dad11d180b400c04fd430c8"],  true, "NAMESPACE_DNS hex is '6ba7b8109dad11d180b400c04fd430c8' (per RFC 4122)"]
    - [ns_url_hex,   NAMESPACE_URL.hex.__eq__,   ["6ba7b8119dad11d180b400c04fd430c8"],  true, "NAMESPACE_URL hex is '6ba7b8119dad11d180b400c04fd430c8' (differs from DNS in last digit of first group)"]
    - [ns_oid_hex,   NAMESPACE_OID.hex.__eq__,   ["6ba7b8129dad11d180b400c04fd430c8"],  true, "NAMESPACE_OID hex is '6ba7b8129dad11d180b400c04fd430c8'"]
    - [ns_x500_hex,  NAMESPACE_X500.hex.__eq__,  ["6ba7b8149dad11d180b400c04fd430c8"],  true, "NAMESPACE_X500 hex is '6ba7b8149dad11d180b400c04fd430c8' (note: 4, not 3 — RFC 4122 skips 3)"]
    - [nil_int_eq,   NIL.int.__eq__,              [0],                                   true, "NIL.int is 0 (all-zero 128-bit UUID; extra121 anchors NIL at table level)"]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') — standalone
#
# uuid.NAMESPACE_DNS.__class__.__name__ is 'UUID'. The NAMESPACE_DNS constant
# is a pre-constructed UUID instance defined per RFC 4122 Section 4.3. It
# represents the DNS namespace and is used when generating name-based UUIDs
# (uuid3 and uuid5) in the DNS namespace. Its __class__.__name__ being 'UUID'
# confirms it is a uuid.UUID instance (not a string, not a namedtuple). No
# prior uuid spec anchors NAMESPACE_DNS.__class__.__name__ via __eq__ as a
# standalone under uuidns126. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra126.NAMESPACE_DNS_class_UUID:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — NAMESPACE_DNS is a pre-constructed UUID instance per RFC 4122 Section 4.3; used as namespace arg to uuid3/uuid5 for DNS names; extra121 anchors NIL/MAX at table level; first standalone for NAMESPACE_DNS.__class__.__name__ under uuidns126"
  category: type_identity
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.version.__eq__(1) — standalone
#
# uuid.NAMESPACE_DNS.version is 1. The four RFC 4122 namespace UUIDs are all
# version-1 UUIDs — the 4-bit version nibble in their time_hi_and_version field
# encodes the value 1. This is distinct from uuid.NIL.version and uuid.MAX.version
# which are both None (sentinel UUIDs have no defined version). The .version
# property of uuid.UUID decodes the 4-bit field from the UUID integer
# representation and returns it as a Python int. No prior uuid spec anchors
# NAMESPACE_DNS.version.__eq__(1) as a standalone under uuidns126.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra126.NAMESPACE_DNS_version_1:
  description: "uuid.NAMESPACE_DNS.version.__eq__(1) == True — NAMESPACE_DNS is a version-1 UUID; all four RFC 4122 namespace constants have version==1; contrasts with NIL.version==None and MAX.version==None (sentinels have no version); first standalone for NAMESPACE_DNS.version.__eq__ under uuidns126"
  category: type_identity
  kind: python_call_eq
  function: NAMESPACE_DNS.version.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.hex.__eq__('6ba7b8109dad11d180b400c04fd430c8') — standalone
#
# uuid.NAMESPACE_DNS.hex is '6ba7b8109dad11d180b400c04fd430c8'. This is the
# canonical hex encoding of the DNS namespace UUID from RFC 4122 Appendix C:
# 6ba7b810-9dad-11d1-80b4-00c04fd430c8. The .hex property strips the four
# hyphens from the standard string representation, yielding 32 lowercase hex
# digits. The hex string is a read-only property computed from UUID.int. No
# prior uuid spec anchors NAMESPACE_DNS.hex equality as a standalone under
# uuidns126. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra126.NAMESPACE_DNS_hex:
  description: "uuid.NAMESPACE_DNS.hex.__eq__('6ba7b8109dad11d180b400c04fd430c8') == True — canonical RFC 4122 Appendix C DNS namespace UUID hex (32 lowercase hex digits; hyphen-stripped form of 6ba7b810-9dad-11d1-80b4-00c04fd430c8); first standalone for NAMESPACE_DNS.hex equality under uuidns126"
  category: type_identity
  kind: python_call_eq
  function: NAMESPACE_DNS.hex.__eq__
  args: ["6ba7b8109dad11d180b400c04fd430c8"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_X500.hex.__eq__('6ba7b8149dad11d180b400c04fd430c8') — standalone
#
# uuid.NAMESPACE_X500.hex is '6ba7b8149dad11d180b400c04fd430c8'. The X.500
# namespace UUID from RFC 4122 Appendix C is 6ba7b814-9dad-11d1-80b4-00c04fd430c8.
# Note the digit '4' in the last position of the first group — the RFC 4122
# namespace list defines DNS (0), URL (1), OID (2), and X.500 (4), skipping 3.
# The X.500 namespace is used when generating UUIDs for X.500 distinguished
# names. No prior uuid spec anchors NAMESPACE_X500.hex as a standalone under
# uuidns126. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra126.NAMESPACE_X500_hex:
  description: "uuid.NAMESPACE_X500.hex.__eq__('6ba7b8149dad11d180b400c04fd430c8') == True — RFC 4122 X.500 namespace UUID; note digit '4' in first group (DNS=0, URL=1, OID=2, X500=4; RFC 4122 skips 3); used for X.500 distinguished names in uuid3/uuid5; first standalone for NAMESPACE_X500.hex under uuidns126"
  category: type_identity
  kind: python_call_eq
  function: NAMESPACE_X500.hex.__eq__
  args: ["6ba7b8149dad11d180b400c04fd430c8"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NIL.int.__eq__(0) — standalone
#
# uuid.NIL.int is 0. The NIL UUID (all-zero 128-bit value) has an integer
# representation of 0. uuid.NIL was added in Python 3.11. Its .version property
# is None (not an integer version number like the namespace UUIDs) because the
# NIL UUID is a sentinel value, not a versioned UUID. Its hex is
# '00000000000000000000000000000000' (32 zeros). extra121 anchors NIL at table
# level; this is the first standalone for NIL.int.__eq__(0) under uuidns126.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra126.NIL_int_zero:
  description: "uuid.NIL.int.__eq__(0) == True — NIL UUID is all-zero 128-bit value; int representation is 0; NIL.version is None (sentinel, not versioned); added Python 3.11; extra121 anchors NIL at table level; first standalone for NIL.int.__eq__(0) under uuidns126"
  category: type_identity
  kind: python_call_eq
  function: NIL.int.__eq__
  args: [0]
  expected: true
