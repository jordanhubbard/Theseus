spec: bz2_extra3
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
  notes:
    - "This spec extends prior bz2 specs."
    - "Focus: class names and compress/decompress function behavior."
    - "bz2.BZ2File.__name__ == 'BZ2File'."
    - "bz2.BZ2Compressor.__name__ == 'BZ2Compressor'."
    - "bz2.BZ2Decompressor.__name__ == 'BZ2Decompressor'."
    - "bz2.compress.__name__ == 'compress'."
    - "bz2.decompress.__name__ == 'decompress'."
    - "bz2.open.__name__ == 'open'."
    - "bz2.compress(b'hello').__class__.__name__ == 'bytes'."
    - "bz2.compress(b'hello')[:2] == b'BZ' (bz2 magic)."
    - "bz2.BZ2File.__module__ == 'bz2'."
    - "bz2.BZ2Compressor.__module__ == '_bz2'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table bz2_extra3.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [BZ2File,         BZ2File.__name__.__eq__,         ["BZ2File"],         true]
    - [BZ2Compressor,   BZ2Compressor.__name__.__eq__,   ["BZ2Compressor"],   true]
    - [BZ2Decompressor, BZ2Decompressor.__name__.__eq__, ["BZ2Decompressor"], true]

table bz2_extra3.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [compress,   compress.__name__.__eq__,   ["compress"],   true]
    - [decompress, decompress.__name__.__eq__, ["decompress"], true]
    - [open,       open.__name__.__eq__,       ["open"],       true]

invariant bz2_extra3.BZ2File.module:
  description: "bz2.BZ2File.__module__ == 'bz2'"
  category: module
  kind: python_call_eq
  function: BZ2File.__module__.__eq__
  args: ["bz2"]
  expected: true

invariant bz2_extra3.BZ2Compressor.module:
  description: "bz2.BZ2Compressor.__module__ == '_bz2'"
  category: module
  kind: python_call_eq
  function: BZ2Compressor.__module__.__eq__
  args: ["_bz2"]
  expected: true

invariant bz2_extra3.compress.returns_bytes:
  description: "bz2.compress(b'hello').__class__.__name__ == 'bytes'"
  category: compress
  kind: python_call_eq
  function: compress
  args: [!hex 68656c6c6f]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bytes"]
  expected: true

invariant bz2_extra3.compress.magic_B:
  description: "bz2.compress(b'hello')[0] == ord('B') == 66"
  category: compress
  kind: python_call_eq
  function: compress
  args: [!hex 68656c6c6f]
  method: __getitem__
  method_args: [0]
  expected: 66

invariant bz2_extra3.compress.magic_Z:
  description: "bz2.compress(b'hello')[1] == ord('Z') == 90"
  category: compress
  kind: python_call_eq
  function: compress
  args: [!hex 68656c6c6f]
  method: __getitem__
  method_args: [1]
  expected: 90

invariant bz2_extra3.compress.module:
  description: "bz2.compress.__module__ == 'bz2'"
  category: module
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["bz2"]
  expected: true

invariant bz2_extra3.decompress.module:
  description: "bz2.decompress.__module__ == 'bz2'"
  category: module
  kind: python_call_eq
  function: decompress.__module__.__eq__
  args: ["bz2"]
  expected: true
