spec: cli_truncate
version: ">=4.0.0"
backend: node(cli-truncate)

docs: https://github.com/sindresorhus/cli-truncate#readme

provenance:
  derived_from:
    - "cli-truncate README — https://github.com/sindresorhus/cli-truncate#readme"
    - "Test vectors verified with cli-truncate via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "cli-truncate source"
  notes:
    - "Truncate a string to a target visual width — appends '…' (single-char ellipsis)."
    - "Install: npm install cli-truncate"
    - "v6 ESM only; default export is the truncate function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; throws TypeError on non-string input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant cli_truncate.basic_truncation:
  description: "Truncate 'hello world' to 5 chars yields 'hell…'"
  category: truncate
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["hello world", 5]
  chain: []
  expected: "hell…"

invariant cli_truncate.truncate_to_8:
  description: "Truncate 'hello world' to 8 chars (end position) yields 'hello w…'"
  category: truncate
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["hello world", 8]
  chain: []
  expected: "hello w…"

invariant cli_truncate.fits_passthrough:
  description: "If input fits, returned unchanged (no ellipsis)"
  category: truncate
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["hi", 10]
  chain: []
  expected: "hi"

invariant cli_truncate.exact_length_passthrough:
  description: "Input exactly at limit returns unchanged"
  category: truncate
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["hello", 5]
  chain: []
  expected: "hello"

invariant cli_truncate.truncate_to_2:
  description: "Truncate to 2 yields '…' + first char (or just '…')"
  category: truncate
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["hello world", 2]
  chain: []
  expected: "h…"

invariant cli_truncate.empty_input:
  description: "Empty string passes through"
  category: edge
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["", 5]
  chain: []
  expected: ""

invariant cli_truncate.position_middle:
  description: "{position: 'middle'} truncates from middle: 'hello world' → 'hel…rld'"
  category: position
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["hello world", 7, {position: "middle"}]
  chain: []
  expected: "hel…rld"

invariant cli_truncate.position_start:
  description: "{position: 'start'} truncates from start: 'hello world' → '… world' (ellipsis counts as 1 visual cell + 6 chars = 7)"
  category: position
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["hello world", 7, {position: "start"}]
  chain: []
  expected: "… world"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:20:25Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
