spec: isort_rust
version: ">=3.9"
backend: rust_module(isort_rust)

docs: https://pycqa.github.io/isort/

provenance:
  derived_from:
    - "https://pycqa.github.io/isort/ — isort documentation"
  not_derived_from:
    - "isort source: isort/__init__.py"
  notes:
    - "isort sorts Python imports alphabetically."
    - "isort.code('import b\\nimport a\\n') == 'import a\\nimport b\\n'."
    - "isort.code('import z\\nimport a\\n') == 'import a\\nimport z\\n'."
    - "isort.__version__ is a non-empty string."
    - "Expose isort_sort(code) -> str: isort.code(code)."
    - "Expose isort_version_nonempty() -> bool: len(isort.__version__) > 0."
    - "All test vectors verified against isort 5.13.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# isort_sort — sort imports
table isort_rust.sort.imports:
  kind: python_call_eq
  category: sort
  id_prefix: iso_s
  function: isort_sort

  columns: [id, args, expected]
  rows:
    - [ba, ["import b\nimport a\n"], "import a\nimport b\n"]
    - [za, ["import z\nimport a\n"], "import a\nimport z\n"]

# isort_version_nonempty — version non-empty
invariant isort_rust.version.nonempty:
  description: "isort.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: isort_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T02:04:27Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
