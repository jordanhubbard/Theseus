spec: termios_extra
version: ">=3.9"
backend: python_module(termios)

docs: https://docs.python.org/3/library/termios.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/termios.html — Python termios module documentation"
    - "POSIX.1-2017 — termios(3) terminal I/O interface specification"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/termios.c"
  notes:
    - "This spec complements termios.zspec.zsdl with additional invariants."
    - "tcflow.__name__ is covered here in addition to tcgetattr/tcsetattr/tcdrain/tcflush."
    - "TCSANOW/TCSADRAIN/TCSAFLUSH are verified both by value and by class (int)."
    - "IFLAG/OFLAG/CFLAG/LFLAG/ISPEED/OSPEED/CC are the termios attribute-list indices per POSIX."
    - "These index constants have the same values in the termios and tty modules."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks — dotted attr form, verified via __eq__
# ---------------------------------------------------------------------------

invariant termios_extra.tcgetattr.name:
  description: "termios.tcgetattr.__name__ == 'tcgetattr'"
  category: function_names
  kind: python_call_eq
  function: tcgetattr.__name__.__eq__
  args: ["tcgetattr"]
  expected: true

invariant termios_extra.tcsetattr.name:
  description: "termios.tcsetattr.__name__ == 'tcsetattr'"
  category: function_names
  kind: python_call_eq
  function: tcsetattr.__name__.__eq__
  args: ["tcsetattr"]
  expected: true

invariant termios_extra.tcdrain.name:
  description: "termios.tcdrain.__name__ == 'tcdrain'"
  category: function_names
  kind: python_call_eq
  function: tcdrain.__name__.__eq__
  args: ["tcdrain"]
  expected: true

invariant termios_extra.tcflush.name:
  description: "termios.tcflush.__name__ == 'tcflush'"
  category: function_names
  kind: python_call_eq
  function: tcflush.__name__.__eq__
  args: ["tcflush"]
  expected: true

invariant termios_extra.tcflow.name:
  description: "termios.tcflow.__name__ == 'tcflow'"
  category: function_names
  kind: python_call_eq
  function: tcflow.__name__.__eq__
  args: ["tcflow"]
  expected: true

# ---------------------------------------------------------------------------
# TCSANOW / TCSADRAIN / TCSAFLUSH — int class checks
# ---------------------------------------------------------------------------

invariant termios_extra.TCSANOW.class_is_int:
  description: "termios.TCSANOW.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: TCSANOW.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant termios_extra.TCSADRAIN.class_is_int:
  description: "termios.TCSADRAIN.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: TCSADRAIN.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant termios_extra.TCSAFLUSH.class_is_int:
  description: "termios.TCSAFLUSH.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: TCSAFLUSH.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Termios attribute-list index constants
# IFLAG=0, OFLAG=1, CFLAG=2, LFLAG=3, ISPEED=4, OSPEED=5, CC=6
# ---------------------------------------------------------------------------

invariant termios_extra.IFLAG.value:
  description: "termios.IFLAG == 0 — index of c_iflag in the tcgetattr list"
  category: index_constants
  kind: python_call_eq
  function: IFLAG.__eq__
  args: [0]
  expected: true

invariant termios_extra.OFLAG.value:
  description: "termios.OFLAG == 1 — index of c_oflag in the tcgetattr list"
  category: index_constants
  kind: python_call_eq
  function: OFLAG.__eq__
  args: [1]
  expected: true

invariant termios_extra.CFLAG.value:
  description: "termios.CFLAG == 2 — index of c_cflag in the tcgetattr list"
  category: index_constants
  kind: python_call_eq
  function: CFLAG.__eq__
  args: [2]
  expected: true

invariant termios_extra.LFLAG.value:
  description: "termios.LFLAG == 3 — index of c_lflag in the tcgetattr list"
  category: index_constants
  kind: python_call_eq
  function: LFLAG.__eq__
  args: [3]
  expected: true

invariant termios_extra.ISPEED.value:
  description: "termios.ISPEED == 4 — index of c_ispeed in the tcgetattr list"
  category: index_constants
  kind: python_call_eq
  function: ISPEED.__eq__
  args: [4]
  expected: true

invariant termios_extra.OSPEED.value:
  description: "termios.OSPEED == 5 — index of c_ospeed in the tcgetattr list"
  category: index_constants
  kind: python_call_eq
  function: OSPEED.__eq__
  args: [5]
  expected: true

invariant termios_extra.CC.value:
  description: "termios.CC == 6 — index of c_cc (control characters array) in the tcgetattr list"
  category: index_constants
  kind: python_call_eq
  function: CC.__eq__
  args: [6]
  expected: true
