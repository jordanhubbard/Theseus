spec: hashlib_extra1966
version: ">=3.9"
backend: python_module(_hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
    - "CPython source: Modules/_hashopenssl.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 1966 (_extra1966): __enter__/__exit__, __aenter__/__aexit__, __del__ dict-presence checks."
    - "_hashlib.HASH does not define __enter__ or __exit__ (not a context manager)."
    - "hashlib.blake2b and hashlib.blake2s are real type objects accessible from the hashlib module."
    - "blake2b and blake2s do not define context manager or async context manager protocols."
    - "No hashlib hash type defines __del__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra1966.hash_context_manager_protocol:
  description: "_hashlib.HASH __enter__/__exit__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1966

  columns: [id, function, args, expected]
  rows:
    - ["hl1966001", "_hashlib.HASH.__dict__.__contains__", ["__enter__"], false]
    - ["hl1966002", "_hashlib.HASH.__dict__.__contains__", ["__exit__"], false]
    - ["hl1966003", "_hashlib.HASH.__dict__.__contains__", ["__aenter__"], false]
    - ["hl1966004", "_hashlib.HASH.__dict__.__contains__", ["__aexit__"], false]
    - ["hl1966005", "_hashlib.HASH.__dict__.__contains__", ["__del__"], false]

