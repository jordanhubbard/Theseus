spec: threading_extra1096
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks Thread.__repr__/__str__ qualnames, ThreadError module/qualname/name, _DummyThread module, settrace/setprofile/stack_size function qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1096.thread_repr_str_qualnames:
  description: "threading.Thread.__repr__ and __str__ qualname identity not covered in _extra976/_extra991"
  kind: python_call_eq
  category: thread_repr_str_qualnames
  id_prefix: th1096ts
  columns: [id, function, args, expected]
  rows:
    - [th1096ts001, threading.Thread.__repr__.__qualname__.__eq__,              ["Thread.__repr__"],                  true]
    - [th1096ts002, threading.Thread.__repr__.__module__.__eq__,                ["threading"],                        true]
    - [th1096ts003, threading.Thread.__repr__.__class__.__name__.__eq__,        ["function"],                         true]
    - [th1096ts004, threading.Thread.__init__.__module__.__eq__,                ["threading"],                        true]
    - [th1096ts005, threading.Thread.__qualname__.__eq__,                       ["Thread"],                           true]
    - [th1096ts006, threading.Thread.__module__.__eq__,                         ["threading"],                        true]
    - [th1096ts007, threading.Thread.__class__.__name__.__eq__,                 ["type"],                             true]
    - [th1096ts008, threading.Thread.__doc__.__class__.__name__.__eq__,         ["str"],                              true]

table threading_extra1096.thread_error_identity:
  description: "threading.ThreadError module, qualname, and name identity"
  kind: python_call_eq
  category: thread_error_identity
  id_prefix: th1096te
  columns: [id, function, args, expected]
  rows:
    - [th1096te001, threading.ThreadError.__name__.__eq__,                      ["ThreadError"],                      true]
    - [th1096te002, threading.ThreadError.__qualname__.__eq__,                  ["ThreadError"],                      true]
    - [th1096te003, threading.ThreadError.__module__.__eq__,                    ["threading"],                        true]
    - [th1096te004, threading.ThreadError.__class__.__name__.__eq__,            ["type"],                             true]
    - [th1096te005, threading.ThreadError.__doc__.__class__.__name__.__eq__,    ["NoneType"],                         true]
    - [th1096te006, threading._DummyThread.__module__.__eq__,                   ["threading"],                        true]
    - [th1096te007, threading._DummyThread.__qualname__.__eq__,                 ["_DummyThread"],                     true]
    - [th1096te008, threading._DummyThread.__class__.__name__.__eq__,           ["type"],                             true]

table threading_extra1096.settrace_setprofile_stack_size_qualnames:
  description: "threading.settrace, setprofile, and stack_size function qualnames"
  kind: python_call_eq
  category: settrace_setprofile_stack_size
  id_prefix: th1096sp
  columns: [id, function, args, expected]
  rows:
    - [th1096sp001, threading.settrace.__qualname__.__eq__,                     ["settrace"],                         true]
    - [th1096sp002, threading.settrace.__module__.__eq__,                       ["threading"],                        true]
    - [th1096sp003, threading.settrace.__class__.__name__.__eq__,               ["function"],                         true]
    - [th1096sp004, threading.setprofile.__qualname__.__eq__,                   ["setprofile"],                       true]
    - [th1096sp005, threading.setprofile.__module__.__eq__,                     ["threading"],                        true]
    - [th1096sp006, threading.setprofile.__class__.__name__.__eq__,             ["function"],                         true]
    - [th1096sp007, threading.stack_size.__qualname__.__eq__,                   ["stack_size"],                       true]
    - [th1096sp008, threading.stack_size.__class__.__name__.__eq__,             ["builtin_function_or_method"],        true]
