spec: pathlib_extra194
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "pathlib.Path.__init__.__name__ == '__init__' (len=8); __qualname__ == 'PurePath.__init__' (inherited from PurePath)."
    - "pathlib.Path.__new__.__name__ == '__new__' (len=7); __qualname__ == 'Path.__new__' (defined on Path itself)."
    - "pathlib.Path.__str__.__name__ == '__str__' (len=7); __qualname__ == 'PurePath.__str__' (inherited from PurePath)."
    - "pathlib.Path.__repr__.__name__ == '__repr__' (len=8); __qualname__ == 'PurePath.__repr__' (inherited from PurePath)."
    - "pathlib.Path.__fspath__.__name__ == '__fspath__' (len=10); __qualname__ == 'PurePath.__fspath__' (inherited from PurePath)."
    - "pathlib.Path.__hash__.__name__ == '__hash__' (len=8); __qualname__ == 'PurePath.__hash__' (inherited from PurePath)."
    - "pathlib.Path.__eq__.__name__ == '__eq__' (len=6); __qualname__ == 'PurePath.__eq__' (inherited from PurePath)."
    - "pathlib.Path.__lt__.__name__ == '__lt__' (len=6); __qualname__ == 'PurePath.__lt__' (inherited from PurePath)."
    - "Path.stat() is a regular method (not a property), so it has no .fget attribute."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

