spec: io_extra2746
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
    - "io_extra.zspec.zsdl — covers existing io invariants"
    - "io_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
    - "io_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 630 (io_extra2746) theme: __round__, __divmod__, and __pow__ dict-presence checks."
    - "None of the io classes define __round__, __divmod__, or __pow__ in their own __dict__."
    - "__round__ supports the built-in round(); io stream classes are sequential I/O objects, not numeric types."
    - "__divmod__ supports divmod(); io stream classes do not implement quotient-remainder numeric semantics."
    - "__pow__ supports the ** operator; io stream classes do not implement exponentiation semantics."
    - "Covers io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, and io.TextIOWrapper."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __round__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2746.no_round_in_io_classes:
  description: "__round__ is absent from all io class __dict__s — io stream classes do not implement the round() protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2746

  columns: [id, function, args, expected]
  rows:
    - ["io2746001", "io.IOBase.__dict__.__contains__",         ["__round__"], false]
    - ["io2746002", "io.RawIOBase.__dict__.__contains__",      ["__round__"], false]
    - ["io2746003", "io.BufferedIOBase.__dict__.__contains__", ["__round__"], false]
    - ["io2746004", "io.TextIOBase.__dict__.__contains__",     ["__round__"], false]
    - ["io2746005", "io.BytesIO.__dict__.__contains__",        ["__round__"], false]
    - ["io2746006", "io.StringIO.__dict__.__contains__",       ["__round__"], false]

# ---------------------------------------------------------------------------
# __divmod__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2746.no_divmod_in_io_classes:
  description: "__divmod__ is absent from all io class __dict__s — io stream classes do not implement the divmod() protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2746

  columns: [id, function, args, expected]
  rows:
    - ["io2746007", "io.IOBase.__dict__.__contains__",          ["__divmod__"], false]
    - ["io2746008", "io.FileIO.__dict__.__contains__",          ["__divmod__"], false]
    - ["io2746009", "io.BufferedReader.__dict__.__contains__",  ["__divmod__"], false]
    - ["io2746010", "io.BufferedWriter.__dict__.__contains__",  ["__divmod__"], false]
    - ["io2746011", "io.BufferedRandom.__dict__.__contains__",  ["__divmod__"], false]
    - ["io2746012", "io.TextIOWrapper.__dict__.__contains__",   ["__divmod__"], false]

# ---------------------------------------------------------------------------
# __pow__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2746.no_pow_in_io_classes:
  description: "__pow__ is absent from all io class __dict__s — io stream classes do not implement the ** exponentiation protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2746

  columns: [id, function, args, expected]
  rows:
    - ["io2746013", "io.IOBase.__dict__.__contains__",         ["__pow__"], false]
    - ["io2746014", "io.BytesIO.__dict__.__contains__",        ["__pow__"], false]
    - ["io2746015", "io.StringIO.__dict__.__contains__",       ["__pow__"], false]
    - ["io2746016", "io.FileIO.__dict__.__contains__",         ["__pow__"], false]
    - ["io2746017", "io.BufferedReader.__dict__.__contains__", ["__pow__"], false]
    - ["io2746018", "io.BufferedWriter.__dict__.__contains__", ["__pow__"], false]

# ---------------------------------------------------------------------------
# Complementary: io stream classes have I/O methods but not arithmetic numeric hooks
# Confirms that io classes are sequential I/O objects, not numeric types
# ---------------------------------------------------------------------------

table io_extra2746.io_has_stream_methods_not_arithmetic_numeric_hooks:
  description: "io.BytesIO defines read/write/seek/tell but NOT __round__/__divmod__/__pow__; io.StringIO similarly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2746

  columns: [id, function, args, expected]
  rows:
    - ["io2746019", "io.BytesIO.__dict__.__contains__",  ["read"],      true]
    - ["io2746020", "io.BytesIO.__dict__.__contains__",  ["write"],     true]
    - ["io2746021", "io.BytesIO.__dict__.__contains__",  ["seek"],      true]
    - ["io2746022", "io.BytesIO.__dict__.__contains__",  ["tell"],      true]
    - ["io2746023", "io.BytesIO.__dict__.__contains__",  ["__round__"], false]
    - ["io2746024", "io.BytesIO.__dict__.__contains__",  ["__divmod__"],false]
    - ["io2746025", "io.BytesIO.__dict__.__contains__",  ["__pow__"],   false]
    - ["io2746026", "io.StringIO.__dict__.__contains__", ["read"],      true]
    - ["io2746027", "io.StringIO.__dict__.__contains__", ["write"],     true]
    - ["io2746028", "io.StringIO.__dict__.__contains__", ["seek"],      true]
    - ["io2746029", "io.StringIO.__dict__.__contains__", ["tell"],      true]
    - ["io2746030", "io.StringIO.__dict__.__contains__", ["__round__"], false]
    - ["io2746031", "io.StringIO.__dict__.__contains__", ["__divmod__"],false]
    - ["io2746032", "io.StringIO.__dict__.__contains__", ["__pow__"],   false]
