spec: pathlib_extra227
version: ">=3.4"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "This spec covers: pathlib class __name__ lengths and __lt__/__startswith__/__contains__ predicates for Path, PurePath, PosixPath, PurePosixPath, WindowsPath, PureWindowsPath."
    - "pathlib.Path.__name__ == 'Path'; len == 4; verified with Python 3.14.3."
    - "pathlib.PurePath.__name__ == 'PurePath'; len == 8; verified with Python 3.14.3."
    - "pathlib.PosixPath.__name__ == 'PosixPath'; len == 9; verified with Python 3.14.3."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath'; len == 13; verified with Python 3.14.3."
    - "pathlib.WindowsPath.__name__ == 'WindowsPath'; len == 11; verified with Python 3.14.3."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath'; len == 15; verified with Python 3.14.3."
    - "pathlib.Path.__name__.__lt__('PurePath') == True — 'Path' < 'PurePath' alphabetically: 'P'='P', 'a'<'u'; verified with Python 3.14.3."
    - "pathlib.PurePath.__name__.__startswith__('Pure') == True; verified with Python 3.14.3."
    - "pathlib.PurePosixPath.__name__.__startswith__('Pure') == True; verified with Python 3.14.3."
    - "pathlib.PureWindowsPath.__name__.__startswith__('Pure') == True; verified with Python 3.14.3."
    - "pathlib.PosixPath.__name__.__contains__('Posix') == True; verified with Python 3.14.3."
    - "pathlib.WindowsPath.__name__.__contains__('Windows') == True; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib class __name__ lengths
# All public pathlib classes; lengths verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table pathlib_extra227.class_name_lengths:
  description: "pathlib class __name__ lengths for Path, PurePath, PosixPath, PurePosixPath, WindowsPath, PureWindowsPath; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_metadata
  id_prefix: plclsnamelen227

  columns: [id, function, args, expected]
  rows:
    - [path_len,            Path.__name__.__len__,            [], 4]
    - [purepath_len,        PurePath.__name__.__len__,        [], 8]
    - [posixpath_len,       PosixPath.__name__.__len__,       [], 9]
    - [pureposixpath_len,   PurePosixPath.__name__.__len__,   [], 13]
    - [windowspath_len,     WindowsPath.__name__.__len__,     [], 11]
    - [purewindowspath_len, PureWindowsPath.__name__.__len__, [], 15]

# ---------------------------------------------------------------------------
# pathlib class __name__ __lt__ / __startswith__ / __contains__ predicates
# ---------------------------------------------------------------------------

invariant pathlib_extra227.Path.name.lt_PurePath:
  description: "pathlib.Path.__name__.__lt__('PurePath') == True — 'Path' < 'PurePath' alphabetically; 'P'='P', 'a'<'u'; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: Path.__name__.__lt__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra227.PurePath.name.startswith_Pure:
  description: "pathlib.PurePath.__name__.__startswith__('Pure') == True — 'PurePath' starts with 'Pure'; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: PurePath.__name__.__startswith__
  args: ["Pure"]
  expected: true

invariant pathlib_extra227.PurePosixPath.name.startswith_Pure:
  description: "pathlib.PurePosixPath.__name__.__startswith__('Pure') == True — 'PurePosixPath' starts with 'Pure'; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: PurePosixPath.__name__.__startswith__
  args: ["Pure"]
  expected: true

invariant pathlib_extra227.PureWindowsPath.name.startswith_Pure:
  description: "pathlib.PureWindowsPath.__name__.__startswith__('Pure') == True — 'PureWindowsPath' starts with 'Pure'; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: PureWindowsPath.__name__.__startswith__
  args: ["Pure"]
  expected: true

invariant pathlib_extra227.PosixPath.name.contains_Posix:
  description: "pathlib.PosixPath.__name__.__contains__('Posix') == True — 'PosixPath' contains 'Posix'; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: PosixPath.__name__.__contains__
  args: ["Posix"]
  expected: true

invariant pathlib_extra227.WindowsPath.name.contains_Windows:
  description: "pathlib.WindowsPath.__name__.__contains__('Windows') == True — 'WindowsPath' contains 'Windows'; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: WindowsPath.__name__.__contains__
  args: ["Windows"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants for key class name lengths
# ---------------------------------------------------------------------------

invariant pathlib_extra227.Path.name.len:
  description: "pathlib.Path.__name__.__len__() == 4 — 'Path' has 4 characters; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: Path.__name__.__len__
  args: []
  expected: 4

invariant pathlib_extra227.PurePath.name.len:
  description: "pathlib.PurePath.__name__.__len__() == 8 — 'PurePath' has 8 characters; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: PurePath.__name__.__len__
  args: []
  expected: 8

invariant pathlib_extra227.PurePosixPath.name.len:
  description: "pathlib.PurePosixPath.__name__.__len__() == 13 — 'PurePosixPath' has 13 characters; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: PurePosixPath.__name__.__len__
  args: []
  expected: 13

invariant pathlib_extra227.PureWindowsPath.name.len:
  description: "pathlib.PureWindowsPath.__name__.__len__() == 15 — 'PureWindowsPath' has 15 characters; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: PureWindowsPath.__name__.__len__
  args: []
  expected: 15
