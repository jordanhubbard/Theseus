spec: decimal_extra2056
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 584 (_extra2056): __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__ dict-presence checks."
    - "decimal.Decimal is a decimal floating-point type; it does not implement any sequence/mapping protocol."
    - "decimal.Context defines __setattr__ and __delattr__ (True) to guard its arithmetic configuration attributes."
    - "decimal.Context does NOT define __getitem__, __setitem__, __delitem__, __len__, or __getattr__."
    - "decimal.DecimalException is an exception base class; no item-access or attribute-hook operators are defined in its own __dict__."
    - "decimal.InvalidOperation, decimal.DivisionByZero, decimal.Overflow are concrete DecimalException subclasses; all show False for these operators."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __getitem__ / __setitem__ / __delitem__ — sequence/mapping protocol
# All False: decimal types do not implement item access protocol
# ---------------------------------------------------------------------------

table decimal_extra2056.getitem_protocol:
  description: "decimal types __getitem__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2056

  columns: [id, function, args, expected]
  rows:
    - ["dc2056001", "decimal.Decimal.__dict__.__contains__",             ["__getitem__"], false]
    - ["dc2056002", "decimal.Context.__dict__.__contains__",             ["__getitem__"], false]
    - ["dc2056003", "decimal.DecimalException.__dict__.__contains__",    ["__getitem__"], false]
    - ["dc2056022", "decimal.InvalidOperation.__dict__.__contains__",    ["__getitem__"], false]
    - ["dc2056023", "decimal.DivisionByZero.__dict__.__contains__",      ["__getitem__"], false]
    - ["dc2056024", "decimal.Overflow.__dict__.__contains__",            ["__getitem__"], false]

