spec: concurrent_futures_extra246
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#exception-classes — Exception classes section"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.BrokenExecutor — BrokenExecutor"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.thread.BrokenThreadPool — BrokenThreadPool"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.process.BrokenProcessPool — BrokenProcessPool"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py (internal implementation)"
    - "CPython source: Lib/concurrent/futures/thread.py (internal implementation)"
    - "CPython source: Lib/concurrent/futures/process.py (internal implementation)"
  notes:
    - "This spec covers BrokenExecutor, BrokenThreadPool, BrokenProcessPool, and Error class identity."
    - "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor' (len=14); __module__ == 'concurrent.futures._base' (len=24); __bases__[0].__name__ == 'RuntimeError'."
    - "BrokenExecutor inherits from RuntimeError (not Exception directly) — it signals a non-recoverable broken pool state."
    - "concurrent.futures.thread.BrokenThreadPool.__name__ == 'BrokenThreadPool' (len=16); __module__ == 'concurrent.futures.thread' (len=25); __bases__[0].__name__ == 'BrokenExecutor'."
    - "concurrent.futures.process.BrokenProcessPool.__name__ == 'BrokenProcessPool' (len=17); __module__ == 'concurrent.futures.process' (len=26); __bases__[0].__name__ == 'BrokenExecutor'."
    - "concurrent.futures._base.Error.__name__ == 'Error' (len=5); __module__ == 'concurrent.futures._base' (len=24); __bases__[0].__name__ == 'Exception'."
    - "Error is the base for CancelledError and TimeoutError; BrokenExecutor is separate (inherits RuntimeError, not Error)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BrokenExecutor, BrokenThreadPool, and BrokenProcessPool class identity
#
# BrokenExecutor.__name__ == 'BrokenExecutor' (len=14)
# BrokenExecutor.__module__ == 'concurrent.futures._base' (len=24)
# BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'
# BrokenThreadPool.__name__ == 'BrokenThreadPool' (len=16)
# BrokenThreadPool.__module__ == 'concurrent.futures.thread' (len=25)
# BrokenThreadPool.__bases__[0].__name__ == 'BrokenExecutor'
# BrokenProcessPool.__name__ == 'BrokenProcessPool' (len=17)
# BrokenProcessPool.__module__ == 'concurrent.futures.process' (len=26)
# BrokenProcessPool.__bases__[0].__name__ == 'BrokenExecutor'
# ---------------------------------------------------------------------------

table concurrent_futures_extra246.broken_executor_identity:
  description: "concurrent.futures BrokenExecutor subclass identity — BrokenExecutor.__name__.__eq__('BrokenExecutor')==True (len=14); BrokenExecutor.__module__.__eq__('concurrent.futures._base')==True (len=24); BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError')==True (BrokenExecutor signals a non-recoverable broken pool, hence RuntimeError rather than plain Exception); BrokenThreadPool.__name__.__eq__('BrokenThreadPool')==True (len=16); BrokenThreadPool.__module__.__eq__('concurrent.futures.thread')==True (len=25); BrokenThreadPool.__bases__[0].__name__.__eq__('BrokenExecutor')==True; BrokenProcessPool.__name__.__eq__('BrokenProcessPool')==True (len=17, one character longer than BrokenThreadPool); BrokenProcessPool.__module__.__eq__('concurrent.futures.process')==True (len=26); BrokenProcessPool.__bases__[0].__name__.__eq__('BrokenExecutor')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cf246brk

  columns: [id, function, args, expected, description]
  rows:
    - [be_name_eq,    BrokenExecutor.__name__.__eq__,                       ["BrokenExecutor"],               true, "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor'; verified with Python 3.14.3"]
    - [be_name_len,   BrokenExecutor.__name__.__len__,                      [],                               14,   "concurrent.futures.BrokenExecutor.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [be_mod_eq,     BrokenExecutor.__module__.__eq__,                     ["concurrent.futures._base"],     true, "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [be_mod_len,    BrokenExecutor.__module__.__len__,                    [],                               24,   "concurrent.futures.BrokenExecutor.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [be_base_eq,    "BrokenExecutor.__bases__[0].__name__.__eq__",        ["RuntimeError"],                 true, "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'; verified with Python 3.14.3"]
    - [btp_name_eq,   thread.BrokenThreadPool.__name__.__eq__,              ["BrokenThreadPool"],             true, "concurrent.futures.thread.BrokenThreadPool.__name__ == 'BrokenThreadPool'; verified with Python 3.14.3"]
    - [btp_name_len,  thread.BrokenThreadPool.__name__.__len__,             [],                               16,   "concurrent.futures.thread.BrokenThreadPool.__name__.__len__() == 16; verified with Python 3.14.3"]
    - [btp_mod_eq,    thread.BrokenThreadPool.__module__.__eq__,            ["concurrent.futures.thread"],    true, "concurrent.futures.thread.BrokenThreadPool.__module__ == 'concurrent.futures.thread'; verified with Python 3.14.3"]
    - [btp_mod_len,   thread.BrokenThreadPool.__module__.__len__,           [],                               25,   "concurrent.futures.thread.BrokenThreadPool.__module__.__len__() == 25; verified with Python 3.14.3"]
    - [btp_base_eq,   "thread.BrokenThreadPool.__bases__[0].__name__.__eq__",  ["BrokenExecutor"],            true, "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__ == 'BrokenExecutor'; verified with Python 3.14.3"]
    - [bpp_name_eq,   process.BrokenProcessPool.__name__.__eq__,            ["BrokenProcessPool"],            true, "concurrent.futures.process.BrokenProcessPool.__name__ == 'BrokenProcessPool'; verified with Python 3.14.3"]
    - [bpp_name_len,  process.BrokenProcessPool.__name__.__len__,           [],                               17,   "concurrent.futures.process.BrokenProcessPool.__name__.__len__() == 17; verified with Python 3.14.3"]
    - [bpp_mod_eq,    process.BrokenProcessPool.__module__.__eq__,          ["concurrent.futures.process"],   true, "concurrent.futures.process.BrokenProcessPool.__module__ == 'concurrent.futures.process'; verified with Python 3.14.3"]
    - [bpp_mod_len,   process.BrokenProcessPool.__module__.__len__,         [],                               26,   "concurrent.futures.process.BrokenProcessPool.__module__.__len__() == 26; verified with Python 3.14.3"]
    - [bpp_base_eq,   "process.BrokenProcessPool.__bases__[0].__name__.__eq__", ["BrokenExecutor"],           true, "concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__ == 'BrokenExecutor'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures._base.Error class identity
#
# Error.__name__ == 'Error' (len=5)
# Error.__module__ == 'concurrent.futures._base' (len=24)
# Error.__bases__[0].__name__ == 'Exception'
# ---------------------------------------------------------------------------

table concurrent_futures_extra246.base_error_identity:
  description: "concurrent.futures._base.Error class identity — Error.__name__.__eq__('Error')==True (len=5, shortest name in this spec); Error.__module__.__eq__('concurrent.futures._base')==True (len=24, same module as BrokenExecutor); Error.__bases__[0].__name__.__eq__('Exception')==True (Error inherits directly from Exception, unlike BrokenExecutor which inherits from RuntimeError); Error.__name__.__len__()==5; contrast: BrokenExecutor.__name__.__len__()==14; BrokenThreadPool.__name__.__len__()==16; BrokenProcessPool.__name__.__len__()==17; Error is the base for CancelledError and TimeoutError in concurrent.futures; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cf246err

  columns: [id, function, args, expected, description]
  rows:
    - [err_name_eq,   _base.Error.__name__.__eq__,                  ["Error"],                         true, "concurrent.futures._base.Error.__name__ == 'Error'; verified with Python 3.14.3"]
    - [err_name_len,  _base.Error.__name__.__len__,                 [],                                5,    "concurrent.futures._base.Error.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [err_mod_eq,    _base.Error.__module__.__eq__,                ["concurrent.futures._base"],      true, "concurrent.futures._base.Error.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [err_mod_len,   _base.Error.__module__.__len__,               [],                                24,   "concurrent.futures._base.Error.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [err_base_eq,   "_base.Error.__bases__[0].__name__.__eq__",   ["Exception"],                     true, "concurrent.futures._base.Error.__bases__[0].__name__ == 'Exception'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra246
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra246.brokenexecutor_name_eq:
  description: "concurrent.futures.BrokenExecutor.__name__.__eq__('BrokenExecutor') returns True — the exception is named 'BrokenExecutor' (len=14); it lives in concurrent.futures._base (len=24); BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' (not Exception directly); BrokenThreadPool and BrokenProcessPool both inherit from BrokenExecutor; BrokenThreadPool.__name__ == 'BrokenThreadPool' (len=16); BrokenProcessPool.__name__ == 'BrokenProcessPool' (len=17); NEW in extra246: first standalone BrokenExecutor name equality invariant in cf246brk namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BrokenExecutor.__name__.__eq__
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra246.brokenexecutor_base_is_runtimeerror:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError') returns True — BrokenExecutor signals a non-recoverable broken pool state, hence it inherits from RuntimeError rather than Exception; BrokenThreadPool.__bases__[0].__name__ == 'BrokenExecutor' (inherits from BrokenExecutor); BrokenProcessPool.__bases__[0].__name__ == 'BrokenExecutor' (also inherits from BrokenExecutor); _base.Error.__bases__[0].__name__ == 'Exception' (a separate hierarchy); BrokenExecutor.__module__ == 'concurrent.futures._base' (len=24); NEW in extra246: first standalone BrokenExecutor base-is-RuntimeError invariant; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "BrokenExecutor.__bases__[0].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true

invariant concurrent_futures_extra246.brokenprocesspool_single_base_raises_indexerror:
  description: "concurrent.futures.process.BrokenProcessPool.__bases__[1] raises IndexError — BrokenProcessPool has exactly one direct base class (BrokenExecutor); __bases__ is a 1-element tuple; accessing __bases__[1] is out of range and raises IndexError; this confirms single-inheritance: BrokenProcessPool -> BrokenExecutor -> RuntimeError; BrokenProcessPool.__name__ == 'BrokenProcessPool' (len=17); BrokenProcessPool.__module__ == 'concurrent.futures.process' (len=26); NEW in extra246: first standalone BrokenProcessPool single-base IndexError invariant; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: "process.BrokenProcessPool.__bases__[1].__name__.__eq__"
  args: ["ShouldNotReach"]
  raises: IndexError

invariant concurrent_futures_extra246.base_error_module_eq:
  description: "concurrent.futures._base.Error.__module__.__eq__('concurrent.futures._base') returns True — Error is defined in Lib/concurrent/futures/_base.py; __module__ == 'concurrent.futures._base' (len=24, same module as BrokenExecutor); Error.__name__ == 'Error' (len=5, shortest name in this spec); Error.__bases__[0].__name__ == 'Exception' (Error is the root of the CancelledError/TimeoutError hierarchy in concurrent.futures); BrokenExecutor.__module__ == 'concurrent.futures._base' (len=24, same as Error); NEW in extra246: first standalone Error module invariant; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: _base.Error.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true
