spec: turtle
version: ">=3.3"
backend: python_module(turtle)

docs: https://docs.python.org/3/library/turtle.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/turtle.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "turtle source: Lib/turtle.py (PSF; source inspection permitted)"
  not_derived_from:
    - "turtle internals: Tk canvas rendering, display interaction, event loop"
  notes:
    - "turtle provides turtle graphics via Tkinter; a display is required for most operations."
    - "Class and function name checks are safe without a display."
    - "Turtle and RawTurtle are the primary drawing classes; Screen and TurtleScreen manage the canvas."
    - "Vec2D is a 2-element tuple subclass for 2D vector arithmetic; it can be instantiated without a display."
    - "Pen is an alias for Turtle in the turtle module."
    - "Module-level functions (forward, backward, etc.) delegate to a default Turtle instance and require a display to call."
    - "Vec2D(3, 4).__len__() == 2 because Vec2D always holds exactly two components."
    - "All expected values verified by running Python 3.12 turtle module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "turtle raises TclError or Terminator when no display is available or the window is closed prematurely."
  stderr: "null"
  stickiness: "N/A — class and name checks are stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant turtle.Turtle_name:
  description: "Turtle class name is 'Turtle'"
  category: classnames
  kind: python_call_eq
  function: Turtle.__name__.__eq__
  args: ["Turtle"]
  expected: true

invariant turtle.Screen_name:
  description: "Screen class name is 'Screen'"
  category: classnames
  kind: python_call_eq
  function: Screen.__name__.__eq__
  args: ["Screen"]
  expected: true

invariant turtle.RawTurtle_name:
  description: "RawTurtle class name is 'RawTurtle'"
  category: classnames
  kind: python_call_eq
  function: RawTurtle.__name__.__eq__
  args: ["RawTurtle"]
  expected: true

invariant turtle.TurtleScreen_name:
  description: "TurtleScreen class name is 'TurtleScreen'"
  category: classnames
  kind: python_call_eq
  function: TurtleScreen.__name__.__eq__
  args: ["TurtleScreen"]
  expected: true

invariant turtle.Vec2D_name:
  description: "Vec2D class name is 'Vec2D'"
  category: classnames
  kind: python_call_eq
  function: Vec2D.__name__.__eq__
  args: ["Vec2D"]
  expected: true

invariant turtle.Pen_name:
  description: "Pen class name is 'Pen'"
  category: classnames
  kind: python_call_eq
  function: Pen.__name__.__eq__
  args: ["Pen"]
  expected: true

# ---------------------------------------------------------------------------
# Vec2D behavioral checks (no display required)
# ---------------------------------------------------------------------------

invariant turtle.Vec2D_instance_classname:
  description: "Vec2D(3, 4).__class__.__name__ == 'Vec2D'"
  category: behavior
  kind: python_call_eq
  function: Vec2D
  args: [3, 4]
  method: __class__.__name__.__eq__
  method_args: ["Vec2D"]
  expected: true

invariant turtle.Vec2D_len:
  description: "Vec2D(3, 4).__len__() == 2"
  category: behavior
  kind: python_call_eq
  function: Vec2D
  args: [3, 4]
  method: __len__
  method_args: []
  expected: 2

# ---------------------------------------------------------------------------
# Function name checks (no display required)
# ---------------------------------------------------------------------------

invariant turtle.forward_name:
  description: "turtle.forward.__name__ == 'forward'"
  category: functions
  kind: python_call_eq
  function: forward.__name__.__eq__
  args: ["forward"]
  expected: true

invariant turtle.backward_name:
  description: "turtle.backward.__name__ == 'backward'"
  category: functions
  kind: python_call_eq
  function: backward.__name__.__eq__
  args: ["backward"]
  expected: true

invariant turtle.penup_name:
  description: "turtle.penup.__name__ == 'penup'"
  category: functions
  kind: python_call_eq
  function: penup.__name__.__eq__
  args: ["penup"]
  expected: true

invariant turtle.pendown_name:
  description: "turtle.pendown.__name__ == 'pendown'"
  category: functions
  kind: python_call_eq
  function: pendown.__name__.__eq__
  args: ["pendown"]
  expected: true

invariant turtle.circle_name:
  description: "turtle.circle.__name__ == 'circle'"
  category: functions
  kind: python_call_eq
  function: circle.__name__.__eq__
  args: ["circle"]
  expected: true

invariant turtle.done_name:
  description: "turtle.done.__name__ == 'done'"
  category: functions
  kind: python_call_eq
  function: done.__name__.__eq__
  args: ["done"]
  expected: true
