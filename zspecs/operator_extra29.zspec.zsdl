spec: operator_extra29
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator_extra28.zspec.zsdl."
    - "Prior specs covered: add/sub/mul/truediv/floordiv/mod/pow/neg/pos/abs/eq/ne/lt/le/gt/ge/and_/or_/xor/not_/lshift/rshift/getitem/setitem/delitem/length_hint/index/contains/__name__/__module__, attrgetter/itemgetter/methodcaller __name__/__module__/__qualname__/__init__.__name__, iadd/isub/imul/itruediv __name__, operator.__name__/__package__, attrgetter/itemgetter/methodcaller __bases__[0].__name__."
    - "This spec covers: __name__.__len__() for add/sub/mul/truediv/eq/lt/attrgetter/itemgetter/methodcaller; __module__.__len__() for add/attrgetter/iadd."
    - "Key findings: add/sub/mul are 3 chars, eq/lt are 2 chars, truediv is 7; attrgetter/itemgetter are 10, methodcaller is 12; add.__module__ ('_operator', len 9) vs attrgetter.__module__ ('operator', len 8)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() table — arithmetic operator name string lengths
#
# operator.add, sub, and mul have 3-character names; operator.truediv has a
# 7-character name. eq and lt have the shortest names at 2 characters each.
# This table records the name lengths for a representative set of arithmetic
# and comparison operators. The short names reflect the concise naming style
# used for C-level builtin-function wrappers in _operator.c. No prior operator
# spec records __name__.__len__() for these functions together in the extra29
# namespace.
# ---------------------------------------------------------------------------

table operator_extra29.arith_name_str_lengths:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra29.arith_name_str_lengths.eq,
       eq.__name__.__len__,
       [],
       2,
       "len(operator.eq.__name__) == 2"]
    - [operator_extra29.arith_name_str_lengths.lt,
       lt.__name__.__len__,
       [],
       2,
       "len(operator.lt.__name__) == 2"]
    - [operator_extra29.arith_name_str_lengths.add,
       add.__name__.__len__,
       [],
       3,
       "len(operator.add.__name__) == 3"]
    - [operator_extra29.arith_name_str_lengths.sub,
       sub.__name__.__len__,
       [],
       3,
       "len(operator.sub.__name__) == 3"]
    - [operator_extra29.arith_name_str_lengths.mul,
       mul.__name__.__len__,
       [],
       3,
       "len(operator.mul.__name__) == 3"]
    - [operator_extra29.arith_name_str_lengths.truediv,
       truediv.__name__.__len__,
       [],
       7,
       "len(operator.truediv.__name__) == 7"]

# ---------------------------------------------------------------------------
# __name__.__len__() table — callable class name string lengths
#
# operator.attrgetter and itemgetter both have 10-character names; methodcaller
# has a 12-character name. These three C-level callable classes have the longest
# names in the operator module. Their names are descriptive compound words
# (attrgetter = attribute + getter, itemgetter = item + getter, methodcaller =
# method + caller). No prior operator spec records these three __name__ lengths
# together in the extra29 namespace.
# ---------------------------------------------------------------------------

table operator_extra29.callable_class_name_lengths:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra29.callable_class_name_lengths.attrgetter,
       attrgetter.__name__.__len__,
       [],
       10,
       "len(operator.attrgetter.__name__) == 10"]
    - [operator_extra29.callable_class_name_lengths.itemgetter,
       itemgetter.__name__.__len__,
       [],
       10,
       "len(operator.itemgetter.__name__) == 10"]
    - [operator_extra29.callable_class_name_lengths.methodcaller,
       methodcaller.__name__.__len__,
       [],
       12,
       "len(operator.methodcaller.__name__) == 12"]

# ---------------------------------------------------------------------------
# __module__.__len__() table — module string lengths: public vs C-extension
#
# operator.attrgetter reports __module__ == 'operator' (len 8), the public
# module name. operator.add and operator.iadd report __module__ == '_operator'
# (len 9), the private C extension module. This difference of one character
# (the leading underscore) distinguishes callable classes from plain C-level
# functions in the operator module. No prior operator spec records these three
# module string lengths together in the extra29 namespace.
# ---------------------------------------------------------------------------

table operator_extra29.module_str_lengths:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra29.module_str_lengths.attrgetter,
       attrgetter.__module__.__len__,
       [],
       8,
       "len(operator.attrgetter.__module__) == 8"]
    - [operator_extra29.module_str_lengths.add,
       add.__module__.__len__,
       [],
       9,
       "len(operator.add.__module__) == 9"]
    - [operator_extra29.module_str_lengths.iadd,
       iadd.__module__.__len__,
       [],
       9,
       "len(operator.iadd.__module__) == 9"]

# ---------------------------------------------------------------------------
# add.__name__.__len__() — standalone name string length
#
# operator.add.__name__ is 'add', a 3-character string. add is the C-level
# function implementing the + operator for two operands. It is the most
# fundamental arithmetic operator and its short name (3 chars) is shared by
# sub and mul. No prior operator spec records this standalone in the extra29
# namespace.
# ---------------------------------------------------------------------------

invariant operator_extra29.add.name_len:
  description: "len(operator.add.__name__) == 3"
  category: string_properties
  kind: python_call_eq
  function: add.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# methodcaller.__name__.__len__() — standalone name string length
#
# operator.methodcaller.__name__ is 'methodcaller', a 12-character string.
# This is the longest __name__ among the three callable classes in the operator
# module. methodcaller creates a callable that calls a named method with given
# arguments on its operand. Its compound name ('method' + 'caller') is longer
# than attrgetter and itemgetter. No prior operator spec records this standalone
# in the extra29 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra29.methodcaller.name_len:
  description: "len(operator.methodcaller.__name__) == 12"
  category: string_properties
  kind: python_call_eq
  function: methodcaller.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# attrgetter.__module__.__len__() — standalone module string length
#
# operator.attrgetter.__module__ is 'operator', an 8-character string. This
# differs from plain operator functions like add and iadd, whose __module__ is
# '_operator' (9 characters, with a leading underscore). The distinction
# captures the naming convention difference between C-level callable classes
# (attributed to the public namespace) and C-level functions (attributed to
# the private C extension). No prior operator spec records this standalone in
# the extra29 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra29.attrgetter.module_len:
  description: "len(operator.attrgetter.__module__) == 8"
  category: string_properties
  kind: python_call_eq
  function: attrgetter.__module__.__len__
  args: []
  expected: 8
