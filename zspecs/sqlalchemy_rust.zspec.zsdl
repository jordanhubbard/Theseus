spec: sqlalchemy_rust
version: ">=3.9"
backend: rust_module(sqlalchemy_rust)

docs: https://docs.sqlalchemy.org/en/20/

provenance:
  derived_from:
    - "https://docs.sqlalchemy.org/en/20/ — SQLAlchemy documentation"
  not_derived_from:
    - "sqlalchemy source: lib/sqlalchemy/engine/create.py"
  notes:
    - "SQLAlchemy provides SQL toolkit and ORM."
    - "create_engine('sqlite:///:memory:') creates in-memory SQLite DB."
    - "engine.dialect.name == 'sqlite' for SQLite engines."
    - "With engine.connect() as conn: conn.execute(text('SELECT 1')).scalar() == 1."
    - "Expose sqla_dialect_name() -> str: create_engine('sqlite:///:memory:').dialect.name."
    - "Expose sqla_select_one() -> int: engine.connect().execute(text('SELECT 1')).scalar()."
    - "Expose sqla_version_tuple_major() -> int: int(sqlalchemy.__version__.split('.')[0])."
    - "All test vectors verified against sqlalchemy 2.0.39."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# sqla_dialect_name — SQLite dialect name
invariant sqlalchemy_rust.engine.dialect_sqlite:
  description: "SQLite engine dialect.name == 'sqlite'"
  category: dialect
  kind: python_call_eq
  function: sqla_dialect_name
  args: []
  expected: "sqlite"

# sqla_select_one — execute SELECT 1
invariant sqlalchemy_rust.query.select_one:
  description: "SELECT 1 returns 1"
  category: query
  kind: python_call_eq
  function: sqla_select_one
  args: []
  expected: 1

# sqla_version_tuple_major — major version >= 1
table sqlalchemy_rust.version.major:
  kind: python_call_eq
  category: version_major
  id_prefix: sqla_vm
  function: sqla_version_tuple_major

  columns: [id, args, expected]
  rows:
    - [check, [], 2]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:16:12Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
