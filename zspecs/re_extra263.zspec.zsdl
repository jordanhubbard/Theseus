spec: re_extra263
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.compile is a Python function: type(re.compile).__name__ == 'function'."
    - "re.Pattern.__name__ == 'Pattern', re.Pattern.__module__ == 're'."
    - "re.match is a Python function: type(re.match).__name__ == 'function'."
    - "re.findall(r'\\d+', 'a1b2c3') returns ['1', '2', '3'] — three-element list of strings."
    - "re.subn() returns a 2-tuple (new_string, count); subn(r'\\d', 'X', 'a1b2') == ('aXbX', 2)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile — function identity and Pattern class identity
# ---------------------------------------------------------------------------

invariant re_extra263.compile.class_name:
  description: "type(re.compile).__name__ == 'function' — compile is a Python function"
  category: identity
  kind: python_call_eq
  function: compile.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant re_extra263.Pattern.name:
  description: "re.Pattern.__name__ == 'Pattern'"
  category: identity
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra263.Pattern.module:
  description: "re.Pattern.__module__ == 're'"
  category: identity
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.match — function identity
# ---------------------------------------------------------------------------

invariant re_extra263.match.class_name:
  description: "type(re.match).__name__ == 'function' — match is a Python function"
  category: identity
  kind: python_call_eq
  function: match.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# re.sub — substitution table
# ---------------------------------------------------------------------------

table re_extra263.sub:
  description: "re.sub substitution results for digit patterns"
  kind: python_call_eq
  category: substitution
  id_prefix: sub
  function: sub

  columns: [id, function, args, expected, description]
  rows:
    - [digit_to_X,  sub, ["\\d", "X", "a1b2"], "aXbX", "re.sub replaces each digit with X"]
    - [no_match,    sub, ["\\d", "X", "abc"],   "abc",  "re.sub with no digits is a no-op"]

# ---------------------------------------------------------------------------
# re.findall — returns a list with expected elements
# ---------------------------------------------------------------------------

invariant re_extra263.findall.digits_list:
  description: "re.findall(r'\\d+', 'a1b2c3') == ['1', '2', '3']"
  category: findall
  kind: python_call_eq
  function: findall
  args: ["\\d+", "a1b2c3"]
  expected: ["1", "2", "3"]

invariant re_extra263.findall.digits_length:
  description: "len(re.findall(r'\\d+', 'a1b2c3')) == 3"
  category: findall
  kind: python_call_eq
  function: findall
  args: ["\\d+", "a1b2c3"]
  method: __len__
  expected: 3

invariant re_extra263.findall.first_element:
  description: "re.findall(r'\\d+', 'a1b2c3')[0] == '1'"
  category: findall
  kind: python_call_eq
  function: findall
  args: ["\\d+", "a1b2c3"]
  method: __getitem__
  method_args: [0]
  expected: "1"

invariant re_extra263.findall.type_is_list:
  description: "type(re.findall(r'\\d+', 'a1b2c3')).__name__ == 'list'"
  category: findall
  kind: python_call_eq
  function: findall
  args: ["\\d+", "a1b2c3"]
  method: __class__
  method_chain: __name__
  expected: "list"

# ---------------------------------------------------------------------------
# re.sub — direct invariant for digit replacement
# ---------------------------------------------------------------------------

invariant re_extra263.sub.digit_to_X:
  description: "re.sub(r'\\d', 'X', 'a1b2') == 'aXbX'"
  category: substitution
  kind: python_call_eq
  function: sub
  args: ["\\d", "X", "a1b2"]
  expected: "aXbX"

# ---------------------------------------------------------------------------
# re.subn — returns (new_string, count) tuple
# ---------------------------------------------------------------------------

invariant re_extra263.subn.count:
  description: "re.subn(r'\\d', 'X', 'a1b2')[1] == 2 — two substitutions made"
  category: substitution
  kind: python_call_eq
  function: subn
  args: ["\\d", "X", "a1b2"]
  method: __getitem__
  method_args: [1]
  expected: 2

invariant re_extra263.subn.string:
  description: "re.subn(r'\\d', 'X', 'a1b2')[0] == 'aXbX'"
  category: substitution
  kind: python_call_eq
  function: subn
  args: ["\\d", "X", "a1b2"]
  method: __getitem__
  method_args: [0]
  expected: "aXbX"
