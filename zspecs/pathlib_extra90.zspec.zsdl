spec: pathlib_extra90
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra89."
    - "Prior specs covered: PurePath/Path class identity; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes for many methods; PurePath/__dict__ membership; Path/__dict__ membership; Path properties as descriptors; Path method co_name and co_argcount for open/read_text/write_text/iterdir/mkdir/rmdir/stat/lstat/exists/unlink/rename/resolve/absolute/expanduser; PurePath/__name__/__module__/__bases__/__mro__; PosixPath identity; Path.__init__/__new__ co_name and co_argcount; Path.is_dir/is_file/is_symlink/is_mount/is_absolute/is_relative_to/exists/samefile __code__ attributes; Path.__dict__.__contains__ for read_text/write_text/read_bytes/write_bytes/mkdir/iterdir/glob/exists/is_dir/stat; Path.__dict__.__class__.__name__; Path.__qualname__/__name__/__module__ and their lengths."
    - "This spec covers: pathlib.PurePath.__dict__.__contains__ for '__str__', '__repr__', '__eq__', '__hash__' (all True); pathlib.PurePath.__dict__.__contains__ for '__lt__', '__truediv__' (all True); pathlib.PurePath.__dict__.__contains__ for 'parent', 'name', 'suffix', 'suffixes' (all True — properties defined on PurePath); pathlib.PurePath.__dict__.__class__.__name__; pathlib.PurePath.__name__; pathlib.PurePath.__module__."
    - "pathlib.PurePath.__dict__.__contains__('__str__') == True — PurePath defines __str__ for its path string representation."
    - "pathlib.PurePath.__dict__.__contains__('__repr__') == True — PurePath defines __repr__."
    - "pathlib.PurePath.__dict__.__contains__('__eq__') == True — PurePath defines __eq__ for path equality."
    - "pathlib.PurePath.__dict__.__contains__('__hash__') == True — PurePath defines __hash__."
    - "pathlib.PurePath.__dict__.__contains__('__lt__') == True — PurePath defines __lt__ for ordering."
    - "pathlib.PurePath.__dict__.__contains__('__truediv__') == True — PurePath defines __truediv__ for the / join operator."
    - "pathlib.PurePath.__dict__.__contains__('parent') == True — 'parent' is a property defined on PurePath."
    - "pathlib.PurePath.__dict__.__contains__('name') == True — 'name' is a property defined on PurePath."
    - "pathlib.PurePath.__dict__.__contains__('suffix') == True — 'suffix' is a property defined on PurePath."
    - "pathlib.PurePath.__dict__.__contains__('suffixes') == True — 'suffixes' is a property defined on PurePath."
    - "pathlib.PurePath.__dict__.__class__.__name__ == 'mappingproxy' — as expected for any type's __dict__."
    - "pathlib.PurePath.__name__ == 'PurePath' — the class name (length 8)."
    - "pathlib.PurePath.__module__ == 'pathlib' — defined in the pathlib module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__.__contains__ for comparison/repr dunders
# '__str__', '__repr__', '__eq__', '__hash__' are all defined directly on PurePath.
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra90.PurePath_dict_cmp_dunders:
  description: "pathlib.PurePath.__dict__.__contains__ for '__str__', '__repr__', '__eq__', '__hash__' (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibextra90

  columns: [id, function, args, expected]
  rows:
    - [dict_str,    PurePath.__dict__.__contains__, ["__str__"],    true]
    - [dict_repr,   PurePath.__dict__.__contains__, ["__repr__"],   true]
    - [dict_eq,     PurePath.__dict__.__contains__, ["__eq__"],     true]
    - [dict_hash,   PurePath.__dict__.__contains__, ["__hash__"],   true]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__.__contains__ for ordering and join operators
# '__lt__' and '__truediv__' are defined on PurePath for ordering and path joining.
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra90.PurePath_dict_op_dunders:
  description: "pathlib.PurePath.__dict__.__contains__ for '__lt__', '__truediv__' (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibextra90

  columns: [id, function, args, expected]
  rows:
    - [dict_lt,       PurePath.__dict__.__contains__, ["__lt__"],       true]
    - [dict_truediv,  PurePath.__dict__.__contains__, ["__truediv__"],  true]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__.__contains__ for path component properties
# 'parent', 'name', 'suffix', 'suffixes' are properties defined on PurePath.
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra90.PurePath_dict_properties:
  description: "pathlib.PurePath.__dict__.__contains__ for 'parent', 'name', 'suffix', 'suffixes' (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibextra90

  columns: [id, function, args, expected]
  rows:
    - [dict_parent,   PurePath.__dict__.__contains__, ["parent"],   true]
    - [dict_name,     PurePath.__dict__.__contains__, ["name"],     true]
    - [dict_suffix,   PurePath.__dict__.__contains__, ["suffix"],   true]
    - [dict_suffixes, PurePath.__dict__.__contains__, ["suffixes"], true]

# ---------------------------------------------------------------------------
# pathlib.PurePath __dict__.__class__.__name__ and class identity
# PurePath.__dict__ is a mappingproxy; __name__ == 'PurePath'; __module__ == 'pathlib'.
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra90.PurePath_identity:
  description: "pathlib.PurePath __dict__.__class__.__name__, __name__, __module__"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibextra90

  columns: [id, function, args, expected]
  rows:
    - [pp_dict_cls, PurePath.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [pp_name,     PurePath.__name__.__eq__,                    ["PurePath"],     true]
    - [pp_module,   PurePath.__module__.__eq__,                  ["pathlib"],      true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra90.PurePath_dict.contains_str:
  description: "pathlib.PurePath.__dict__.__contains__('__str__') == True (PurePath defines __str__)"
  category: dict_membership
  kind: python_call_eq
  function: PurePath.__dict__.__contains__
  args: ["__str__"]
  expected: true

invariant pathlib_extra90.PurePath_dict.contains_truediv:
  description: "pathlib.PurePath.__dict__.__contains__('__truediv__') == True (PurePath defines / join operator)"
  category: dict_membership
  kind: python_call_eq
  function: PurePath.__dict__.__contains__
  args: ["__truediv__"]
  expected: true

invariant pathlib_extra90.PurePath_dict.contains_parent:
  description: "pathlib.PurePath.__dict__.__contains__('parent') == True (parent is a property on PurePath)"
  category: dict_membership
  kind: python_call_eq
  function: PurePath.__dict__.__contains__
  args: ["parent"]
  expected: true

invariant pathlib_extra90.PurePath.name:
  description: "pathlib.PurePath.__name__ == 'PurePath' (length 8)"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra90.PurePath.module:
  description: "pathlib.PurePath.__module__ == 'pathlib'"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true
