spec: typing_extra2
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "Python typing documentation — https://docs.python.org/3/library/typing.html"
    - "PEP 484 — Type Hints"
    - "PEP 586 — Literal Types"
    - "PEP 591 — Adding a final qualifier to typing"
    - "PEP 604 — Allow writing union types as X | Y"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "Complements typing_extra.zspec.zsdl, typing.zspec.zsdl, and typing_protocol.zspec.zsdl."
    - "typing.Union.__class__.__name__ is 'type' in Python 3.14 — Union is itself a type object, not a _SpecialForm."
    - "typing.Optional.__class__.__name__ is '_SpecialForm' — Optional is a special form that redirects to Union[X, None]."
    - "typing.ClassVar.__class__.__name__ is '_SpecialForm'."
    - "typing.Final.__class__.__name__ is '_SpecialForm'."
    - "typing.Literal.__class__.__name__ is '_TypedCacheSpecialForm' in Python 3.14."
    - "typing.TypeVar.__name__ is 'TypeVar' — the class itself, not an instance."
    - "typing.Generic.__name__ is 'Generic' — the class itself."
    - "get_type_hints, cast, overload are plain functions with __name__ equal to their identifier."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TypeVar and Generic — class __name__ checks
#
# TypeVar and Generic are ordinary classes (not special forms).
# Their __name__ attribute is the class identifier as a string.
# ---------------------------------------------------------------------------

invariant typing_extra2.typevar.class_name:
  description: "typing.TypeVar.__name__ == 'TypeVar'"
  category: class_names
  kind: python_call_eq
  function: TypeVar.__name__.__eq__
  args: ["TypeVar"]
  expected: true

invariant typing_extra2.generic.class_name:
  description: "typing.Generic.__name__ == 'Generic'"
  category: class_names
  kind: python_call_eq
  function: Generic.__name__.__eq__
  args: ["Generic"]
  expected: true

# ---------------------------------------------------------------------------
# Special forms — __class__.__name__ checks
#
# ClassVar, Final, Optional are _SpecialForm instances.
# Literal is a _TypedCacheSpecialForm in Python 3.14.
# Union is a type object (its __class__.__name__ is 'type').
# ---------------------------------------------------------------------------

invariant typing_extra2.classvar.class_of_class:
  description: "typing.ClassVar.__class__.__name__ == '_SpecialForm'"
  category: special_forms
  kind: python_call_eq
  function: ClassVar.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true

invariant typing_extra2.final.class_of_class:
  description: "typing.Final.__class__.__name__ == '_SpecialForm'"
  category: special_forms
  kind: python_call_eq
  function: Final.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true

invariant typing_extra2.literal.class_of_class:
  description: "typing.Literal.__class__.__name__ == '_TypedCacheSpecialForm'"
  category: special_forms
  kind: python_call_eq
  function: Literal.__class__.__name__.__eq__
  args: ["_TypedCacheSpecialForm"]
  expected: true

invariant typing_extra2.union.class_of_class:
  description: "typing.Union.__class__.__name__ == 'type'"
  category: special_forms
  kind: python_call_eq
  function: Union.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant typing_extra2.optional.class_of_class:
  description: "typing.Optional.__class__.__name__ == '_SpecialForm'"
  category: special_forms
  kind: python_call_eq
  function: Optional.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ checks
#
# get_type_hints, cast, and overload are plain functions in the typing module.
# ---------------------------------------------------------------------------

invariant typing_extra2.get_type_hints.name:
  description: "typing.get_type_hints.__name__ == 'get_type_hints'"
  category: function_names
  kind: python_call_eq
  function: get_type_hints.__name__.__eq__
  args: ["get_type_hints"]
  expected: true

invariant typing_extra2.cast.name:
  description: "typing.cast.__name__ == 'cast'"
  category: function_names
  kind: python_call_eq
  function: cast.__name__.__eq__
  args: ["cast"]
  expected: true

invariant typing_extra2.overload.name:
  description: "typing.overload.__name__ == 'overload'"
  category: function_names
  kind: python_call_eq
  function: overload.__name__.__eq__
  args: ["overload"]
  expected: true
