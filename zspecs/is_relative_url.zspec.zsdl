spec: is_relative_url
version: ">=4.1.0"
backend: node(is-relative-url)

docs: https://www.npmjs.com/package/is-relative-url

provenance:
  derived_from:
    - "is-relative-url README — https://www.npmjs.com/package/is-relative-url"
    - "Test vectors verified with is-relative-url via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-relative-url source"
  notes:
    - "is-relative-url is an npm package. Install: npm install is-relative-url"
    - "Returns true if the URL is relative (no scheme). ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_relative_url.isRelativeUrl:
  kind: node_module_call_eq
  function: "default"
  category: validate
  id_prefix: isrelurl

  columns: [id, args, expected]
  rows:
    - [root_path,   ["/foo/bar"],         true]
    - [rel_path,    ["./foo"],            true]
    - [http_url,    ["http://foo.com"],   false]

