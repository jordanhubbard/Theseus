spec: socket_extra215
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "verified with Python 3.14.3."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily'; socket.AF_INET.value == 2."
    - "socket.AF_INET6.value == 30 on macOS/Darwin; may differ on Linux (typically 10)."
    - "socket.AF_UNIX.value == 1."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'; socket.SOCK_STREAM.value == 1."
    - "socket.SOCK_DGRAM.value == 2."
    - "socket.IPPROTO_TCP == 6; socket.IPPROTO_UDP == 17."
    - "socket.INADDR_ANY == 0; socket.INADDR_LOOPBACK == 2130706433."
    - "socket.SOMAXCONN == 128 on macOS; may differ by platform."
    - "socket.inet_aton('999.999.999.999') raises OSError on macOS/Darwin."
    - "socket.setdefaulttimeout(-1) raises ValueError: Timeout value out of range."
    - "All exception types verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket address family constants — type identity and value checks
#
# socket.AF_INET.__class__.__name__  == 'AddressFamily'
# socket.AF_INET.value               == 2
# socket.AF_UNIX.value               == 1
# socket.AF_INET.name                == 'AF_INET'
# ---------------------------------------------------------------------------

table socket_extra215.af_constants_type_identity:
  description: "socket address family constants type identity in socketeq215 namespace — wave 215 theme: AF_INET, AF_INET6, AF_UNIX are AddressFamily enum members; their __class__.__name__ is 'AddressFamily'; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: identity
  id_prefix: socketeq215

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_type,   "socket.AF_INET.__class__.__name__.__eq__",   ["AddressFamily"],  true,  "socket.AF_INET.__class__.__name__ == 'AddressFamily' — AF_INET is an AddressFamily enum member"]
    - [af_inet6_type,  "socket.AF_INET6.__class__.__name__.__eq__",  ["AddressFamily"],  true,  "socket.AF_INET6.__class__.__name__ == 'AddressFamily' — AF_INET6 is an AddressFamily enum member"]
    - [af_unix_type,   "socket.AF_UNIX.__class__.__name__.__eq__",   ["AddressFamily"],  true,  "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' — AF_UNIX is an AddressFamily enum member"]

table socket_extra215.af_constants_values:
  description: "socket address family constant value checks in socketeq215a namespace — wave 215 theme: AF_INET.value == 2; AF_UNIX.value == 1; AF_INET.name == 'AF_INET'; AF_UNIX.name == 'AF_UNIX'; these are POSIX-defined constants; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: attributes
  id_prefix: socketeq215a

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_value,   "socket.AF_INET.value.__eq__",   [2],          true,  "socket.AF_INET.value == 2 — POSIX AF_INET is address family 2"]
    - [af_unix_value,   "socket.AF_UNIX.value.__eq__",   [1],          true,  "socket.AF_UNIX.value == 1 — POSIX AF_UNIX is address family 1"]
    - [af_inet_name,    "socket.AF_INET.name.__eq__",    ["AF_INET"],  true,  "socket.AF_INET.name == 'AF_INET' — enum name matches the constant name"]
    - [af_unix_name,    "socket.AF_UNIX.name.__eq__",    ["AF_UNIX"],  true,  "socket.AF_UNIX.name == 'AF_UNIX' — enum name matches the constant name"]

# ---------------------------------------------------------------------------
# socket type constants — type identity and value checks
#
# socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'
# socket.SOCK_STREAM.value              == 1
# socket.SOCK_DGRAM.value               == 2
# socket.SOCK_STREAM.name               == 'SOCK_STREAM'
# ---------------------------------------------------------------------------

table socket_extra215.sock_constants_type_identity:
  description: "socket type constants type identity in socketeq215b namespace — wave 215 theme: SOCK_STREAM and SOCK_DGRAM are SocketKind enum members; their __class__.__name__ is 'SocketKind'; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: identity
  id_prefix: socketeq215b

  columns: [id, function, args, expected, description]
  rows:
    - [sock_stream_type,  "socket.SOCK_STREAM.__class__.__name__.__eq__",  ["SocketKind"],  true,  "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — SOCK_STREAM is a SocketKind enum member"]
    - [sock_dgram_type,   "socket.SOCK_DGRAM.__class__.__name__.__eq__",   ["SocketKind"],  true,  "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind' — SOCK_DGRAM is a SocketKind enum member"]

table socket_extra215.sock_constants_values:
  description: "socket type constant value checks in socketeq215c namespace — wave 215 theme: SOCK_STREAM.value == 1; SOCK_DGRAM.value == 2; SOCK_STREAM.name == 'SOCK_STREAM'; SOCK_DGRAM.name == 'SOCK_DGRAM'; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: attributes
  id_prefix: socketeq215c

  columns: [id, function, args, expected, description]
  rows:
    - [sock_stream_value,  "socket.SOCK_STREAM.value.__eq__",  [1],             true,  "socket.SOCK_STREAM.value == 1 — POSIX SOCK_STREAM (TCP-style) is socket type 1"]
    - [sock_dgram_value,   "socket.SOCK_DGRAM.value.__eq__",   [2],             true,  "socket.SOCK_DGRAM.value == 2 — POSIX SOCK_DGRAM (UDP-style) is socket type 2"]
    - [sock_stream_name,   "socket.SOCK_STREAM.name.__eq__",   ["SOCK_STREAM"], true,  "socket.SOCK_STREAM.name == 'SOCK_STREAM' — enum name matches the constant name"]
    - [sock_dgram_name,    "socket.SOCK_DGRAM.name.__eq__",    ["SOCK_DGRAM"],  true,  "socket.SOCK_DGRAM.name == 'SOCK_DGRAM' — enum name matches the constant name"]

# ---------------------------------------------------------------------------
# socket protocol integer constants
#
# socket.IPPROTO_TCP == 6
# socket.IPPROTO_UDP == 17
# socket.SOL_TCP     == 6
# ---------------------------------------------------------------------------

table socket_extra215.protocol_constants:
  description: "socket protocol integer constant value checks in socketeq215d namespace — wave 215 theme: IPPROTO_TCP == 6; IPPROTO_UDP == 17; SOL_TCP == 6; these are IANA-assigned protocol numbers that are fixed across all platforms; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: attributes
  id_prefix: socketeq215d

  columns: [id, function, args, expected, description]
  rows:
    - [ipproto_tcp_value,  "socket.IPPROTO_TCP.__eq__",  [6],   true,  "socket.IPPROTO_TCP == 6 — IANA-assigned protocol number for TCP"]
    - [ipproto_udp_value,  "socket.IPPROTO_UDP.__eq__",  [17],  true,  "socket.IPPROTO_UDP == 17 — IANA-assigned protocol number for UDP"]
    - [sol_tcp_value,      "socket.SOL_TCP.__eq__",      [6],   true,  "socket.SOL_TCP == 6 — SOL_TCP protocol level equals IPPROTO_TCP"]

# ---------------------------------------------------------------------------
# socket.inet_aton — raises OSError for invalid IP address strings
# socket.setdefaulttimeout — raises ValueError for negative timeout
# ---------------------------------------------------------------------------

table socket_extra215.inet_aton_bad_addr_raises:
  description: "socket.inet_aton raises OSError for invalid IPv4 address strings in socketerr215 namespace — wave 215 theme: socket.inet_aton('999.999.999.999') raises OSError; socket.inet_aton('not-an-ip') raises OSError; inet_aton validates that its argument is a legal dotted-decimal IPv4 address; any non-conforming string raises OSError with 'illegal IP address string'; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_raises
  category: errors
  id_prefix: socketerr215

  columns: [id, function, args, expected, description]
  rows:
    - [inet_aton_invalid_octets,  socket.inet_aton,  ["999.999.999.999"],  OSError,  "socket.inet_aton('999.999.999.999') raises OSError — octets must be in range 0..255"]
    - [inet_aton_non_ip_string,   socket.inet_aton,  ["not-an-ip"],        OSError,  "socket.inet_aton('not-an-ip') raises OSError — argument is not a dotted-decimal IPv4 address"]

invariant socket_extra215.setdefaulttimeout_negative_raises:
  description: "socket.setdefaulttimeout(-1) raises ValueError — the timeout value must be a non-negative float or None; negative values indicate an invalid timeout; socket.setdefaulttimeout validates its argument immediately and raises ValueError with 'Timeout value out of range' when the value is negative; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  category: errors
  kind: python_call_raises
  function: socket.setdefaulttimeout
  args: [-1]
  expected_exception: ValueError

