spec: abc_extra5
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends prior abc specs."
    - "Focus: ABC class behavior and abstractmethod decorator behavior."
    - "abc.ABC.__abstractmethods__ == frozenset() — no abstract methods on ABC itself."
    - "abc.ABCMeta.__name__ == 'ABCMeta'."
    - "abc.abstractmethod.__name__ == 'abstractmethod'."
    - "abc.abstractmethod.__module__ == 'abc'."
    - "abc.ABC.__class__.__name__ == 'ABCMeta' — ABC is an instance of ABCMeta."
    - "abc.get_cache_token().__class__.__name__ == 'int'."
    - "abc.ABCMeta.__module__ == 'abc'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table abc_extra5.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [abstractmethod,  abstractmethod.__name__.__eq__,  ["abstractmethod"],  true]
    - [get_cache_token, get_cache_token.__name__.__eq__, ["get_cache_token"], true]

table abc_extra5.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [ABC,    ABC.__class__.__name__.__eq__, ["ABCMeta"], true]
    - [ABCMeta, ABCMeta.__name__.__eq__,     ["ABCMeta"], true]

invariant abc_extra5.abstractmethod.module:
  description: "abc.abstractmethod.__module__ == 'abc'"
  category: module
  kind: python_call_eq
  function: abstractmethod.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra5.ABCMeta.module:
  description: "abc.ABCMeta.__module__ == 'abc'"
  category: module
  kind: python_call_eq
  function: ABCMeta.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra5.get_cache_token.returns_int:
  description: "abc.get_cache_token().__class__.__name__ == 'int'"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["int"]
  expected: true

invariant abc_extra5.ABC.abstractmethods_class:
  description: "abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset'"
  category: ABC
  kind: python_call_eq
  function: ABC.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

invariant abc_extra5.abstractmethod.isabstractmethod_attr:
  description: "abc.abstractmethod(lambda: None).__isabstractmethod__ == True"
  category: abstractmethod
  kind: python_call_eq
  function: abstractmethod.__name__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra5.ABCMeta.bases:
  description: "abc.ABCMeta.__bases__[0].__name__ == 'type'"
  category: hierarchy
  kind: python_call_eq
  function: ABCMeta.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "type"

invariant abc_extra5.ABC.module:
  description: "abc.ABC.__module__ == 'abc'"
  category: module
  kind: python_call_eq
  function: ABC.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra5.abstractclassmethod.deprecated_name:
  description: "abc.abstractmethod.__qualname__ == 'abstractmethod'"
  category: function_names
  kind: python_call_eq
  function: abstractmethod.__qualname__.__eq__
  args: ["abstractmethod"]
  expected: true
