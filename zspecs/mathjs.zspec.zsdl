spec: mathjs
version: ">=10.0.0"
backend: node(mathjs)

docs: https://www.npmjs.com/package/mathjs

provenance:
  derived_from:
    - "mathjs README — https://www.npmjs.com/package/mathjs"
    - "Test vectors verified with mathjs via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "mathjs source"
  notes:
    - "mathjs is an npm package. Install: npm install mathjs"
    - "math.evaluate(expr) evaluates a math expression string."
    - "math.sqrt/factorial/gcd/floor/ceil are named functions on the math object."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns numeric result."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table mathjs.evaluate:
  kind: node_module_call_eq
  function: evaluate
  category: evaluate
  id_prefix: mjeval

  columns: [id, args, expected]
  rows:
    - [mul_add, ["2 + 3 * 4"], 14]
    - [simple,  ["10 / 2"],    5]

table mathjs.sqrt:
  kind: node_module_call_eq
  function: sqrt
  category: math
  id_prefix: mjsqrt

  columns: [id, args, expected]
  rows:
    - [sixteen, [16], 4]
    - [nine,    [9],  3]

table mathjs.factorial:
  kind: node_module_call_eq
  function: factorial
  category: math
  id_prefix: mjfact

  columns: [id, args, expected]
  rows:
    - [five, [5], 120]
    - [zero, [0], 1]

table mathjs.gcd:
  kind: node_module_call_eq
  function: gcd
  category: math
  id_prefix: mjgcd

  columns: [id, args, expected]
  rows:
    - [twelve_eight, [12, 8], 4]
    - [nine_six,     [9, 6],  3]

table mathjs.floor:
  kind: node_module_call_eq
  function: floor
  category: math
  id_prefix: mjfloor

  columns: [id, args, expected]
  rows:
    - [pos, [3.7],  3]
    - [neg, [-1.2], -2]

table mathjs.ceil:
  kind: node_module_call_eq
  function: ceil
  category: math
  id_prefix: mjceil

  columns: [id, args, expected]
  rows:
    - [pos, [3.2],  4]
    - [neg, [-1.7], -1]
