spec: mathjs
version: ">=11.0.0"
backend: node(mathjs)

docs: https://mathjs.org/docs/

provenance:
  derived_from:
    - "mathjs documentation — https://mathjs.org/docs/"
    - "Test vectors verified with mathjs via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "mathjs source"
  notes:
    - "mathjs is an npm package. Install: npm install mathjs"
    - "math.evaluate(expr) parses and evaluates a math expression string."
    - "In mathjs, ^ is the power operator (not XOR as in JavaScript)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns evaluated result of the expression."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table mathjs.evaluate:
  kind: node_module_call_eq
  function: evaluate
  category: evaluate
  id_prefix: mje

  columns: [id, args, expected]
  rows:
    - [add,      ["2 + 3"],      5]
    - [subtract, ["10 - 4"],     6]
    - [multiply, ["3 * 4"],      12]
    - [divide,   ["10 / 2"],     5]
    - [sqrt,     ["sqrt(16)"],   4]
    - [power,    ["2 ^ 8"],      256]
