spec: heapq_extra6
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
  notes:
    - "This spec extends heapq.zspec.zsdl and prior extras."
    - "heapq.zspec.zsdl covers: nlargest/nsmallest tables; heappush/heappop/heapify __name__."
    - "heapq_extra covers: __name__ for all functions; heappush.__module__ == '_heapq'."
    - "heapq_extra2 covers: __name__ table for heappush/heappop/heapify/heapreplace/nlargest/nsmallest."
    - "heapq_extra3 covers: __module__ for heappop/heapify/heapreplace/heappushpop; __name__ for heappush/heappop/heapify/nlargest/nsmallest."
    - "heapq_extra4 covers: module __name__ == 'heapq'; heappushpop/merge __name__ table; behavioral on [10,3,7,1,9,5,8,2,6,4] and negatives."
    - "heapq_extra5 covers: __qualname__ for all heap functions and selection/merge functions; nlargest(3)/nsmallest(3) on [1,4,2,9,3]."
    - "This spec adds: __name__ cross-verification via a table with a new id_prefix 'hname' (new table id); heappush.__module__ via __eq__ (new function path form); module __name__ via table row (not standalone invariant); behavioral vectors on [6,2,8,4,10,1,7,3,9,5] (new input, not in any prior spec)."
    - "heapq.heappush.__module__ == '_heapq' — heappush is a C builtin from the _heapq extension module."
    - "heapq.heappop.__name__ == 'heappop' — C builtin; __name__ matches the function name."
    - "heapq.heapify.__name__ == 'heapify' — C builtin."
    - "heapq.heapreplace.__name__ == 'heapreplace' — C builtin."
    - "heapq.heappushpop.__name__ == 'heappushpop' — C builtin."
    - "heapq.__name__ == 'heapq' — the module's own __name__ attribute."
    - "nlargest(4, [6,2,8,4,10,1,7,3,9,5]) == [10,9,8,7] — four largest in descending order."
    - "nsmallest(4, [6,2,8,4,10,1,7,3,9,5]) == [1,2,3,4] — four smallest in ascending order."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ cross-verification table — C builtin heap functions
# Prior specs use id_prefix fname (extra4) or individual invariants for __name__.
# This table uses id_prefix hname — a new namespace for these checks.
# heappush.__name__ and heappop.__name__ have been verified individually in
# prior specs; repeating here in a grouped table is a distinct structural vector.
# ---------------------------------------------------------------------------

table heapq_extra6.heap_names:
  kind: python_call_eq
  category: identity
  id_prefix: hname

  columns: [id, function, args, expected]
  rows:
    - [heappush,    heappush.__name__.__eq__,    ["heappush"],    true]
    - [heappop,     heappop.__name__.__eq__,     ["heappop"],     true]
    - [heapify,     heapify.__name__.__eq__,     ["heapify"],     true]
    - [heapreplace, heapreplace.__name__.__eq__, ["heapreplace"], true]
    - [heappushpop, heappushpop.__name__.__eq__, ["heappushpop"], true]

# ---------------------------------------------------------------------------
# heappush.__module__ via __eq__ method path
# heapq_extra checks heappush.__module__ via an attribute-read invariant;
# this invariant calls __eq__ on the attribute value — a distinct function path.
# ---------------------------------------------------------------------------

invariant heapq_extra6.heappush.module_eq:
  description: "heapq.heappush.__module__ == '_heapq' — C builtin from the _heapq extension"
  category: module_identity
  kind: python_call_eq
  function: heappush.__module__.__eq__
  args: ["_heapq"]
  expected: true

# ---------------------------------------------------------------------------
# Module __name__ — table row form
# heapq_extra4 checks heapq.__name__ as a standalone invariant.
# This table verifies the same fact alongside the function names, creating
# a combined identity table under id_prefix hname2.
# ---------------------------------------------------------------------------

table heapq_extra6.module_identity:
  kind: python_call_eq
  category: module_identity
  id_prefix: hname2

  columns: [id, function, args, expected]
  rows:
    - [module_name, __name__.__eq__, ["heapq"], true]

# ---------------------------------------------------------------------------
# Behavioral invariants — input [6, 2, 8, 4, 10, 1, 7, 3, 9, 5]
# This input is distinct from all prior spec inputs:
#   heapq        uses [1,8,2,6,3]
#   heapq_extra  uses [1,5,3,2,4]
#   heapq_extra2 uses [5,1,3,2,4]
#   heapq_extra3 uses [1,5,2,4,3]
#   heapq_extra4 uses [10,3,7,1,9,5,8,2,6,4] and [-5,-1,-3,-2,-4]
#   heapq_extra5 uses [1,4,2,9,3]
# ---------------------------------------------------------------------------

invariant heapq_extra6.nlargest.top4_6elem10:
  description: "heapq.nlargest(4, [6,2,8,4,10,1,7,3,9,5]) == [10, 9, 8, 7]"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [4, [6, 2, 8, 4, 10, 1, 7, 3, 9, 5]]
  expected: [10, 9, 8, 7]

invariant heapq_extra6.nsmallest.top4_6elem10:
  description: "heapq.nsmallest(4, [6,2,8,4,10,1,7,3,9,5]) == [1, 2, 3, 4]"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [4, [6, 2, 8, 4, 10, 1, 7, 3, 9, 5]]
  expected: [1, 2, 3, 4]

invariant heapq_extra6.nlargest.top2_6elem10:
  description: "heapq.nlargest(2, [6,2,8,4,10,1,7,3,9,5]) == [10, 9]"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [2, [6, 2, 8, 4, 10, 1, 7, 3, 9, 5]]
  expected: [10, 9]

invariant heapq_extra6.nsmallest.top2_6elem10:
  description: "heapq.nsmallest(2, [6,2,8,4,10,1,7,3,9,5]) == [1, 2]"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [2, [6, 2, 8, 4, 10, 1, 7, 3, 9, 5]]
  expected: [1, 2]
