spec: email_extra9
version: ">=3.6"
backend: python_module(email)

docs: https://docs.python.org/3/library/email.html

provenance:
  derived_from:
    - "Python 3 email package documentation — https://docs.python.org/3/library/email.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/email/"
    - "email_extra2.zspec.zsdl — covers email.errors HeaderParseError/MessageError/MessageDefect __name__; email.generator Generator/BytesGenerator names and modules"
    - "email_extra3.zspec.zsdl — covers email.message.Message/EmailMessage __name__ via dotted chain; email.headerregistry.Address __name__"
    - "email_extra4.zspec.zsdl — covers email.policy EmailPolicy/Policy/Compat32 qualnames and __module__; email.errors MessageError/HeaderParseError/MessageDefect qualnames and __module__; email.generator Generator/BytesGenerator hierarchy; email.headerregistry Address name/qualname/module"
    - "email_extra5.zspec.zsdl — covers email.errors BoundaryError/CharsetError qualnames and __module__; email.generator Generator/BytesGenerator __bases__.__getitem__; email.headerregistry Address/Group __bases__.__getitem__ and __module__"
    - "email_extra6.zspec.zsdl — covers email.errors MessageError/HeaderParseError __bases__.__getitem__; email.policy Policy __bases__.__getitem__"
    - "email_extra7.zspec.zsdl — covers email.message.Message/__module__; email.message.EmailMessage/__module__; email.errors MultipartConversionError/__module__; email.policy Compat32/__module__; email.contentmanager.get_content_manager/__module__"
    - "email_extra8.zspec.zsdl — covers email sub-module class __name__ attributes (Message/EmailMessage/MIMEText/MIMEMultipart/Address via email backend dotted paths); email.utils.parseaddr('Jordan <jordan@example.com>')"
  notes:
    - "This spec extends the email family through email_extra8; it does NOT duplicate invariants in any prior spec."
    - "Focus: email.errors class base hierarchy via dotted __bases__[0].__name__ chain — MessageDefect, MultipartConversionError, CharsetError base names not yet checked via this path; email.message.Message.__bases__[0].__name__ and email.headerregistry.Address.__bases__[0].__name__ also not yet checked via dotted chain (email_extra5/6 use __bases__.__getitem__ which is a distinct axis)."
    - "email.errors.MessageDefect.__bases__[0].__name__ == 'ValueError' — MessageDefect inherits from ValueError. email_extra6 checks MessageError.__bases__ via __getitem__; MessageDefect __bases__[0].__name__ via dotted chain is new. Verified Python 3.14."
    - "email.errors.MultipartConversionError.__bases__[0].__name__ == 'MessageError' — inherits from MessageError not Exception directly. Verified Python 3.14."
    - "email.errors.CharsetError.__bases__[0].__name__ == 'MessageError' — inherits from MessageError. Verified Python 3.14."
    - "email.message.Message.__bases__[0].__name__ == 'object' — Message has no intermediate base. Verified Python 3.14."
    - "email.headerregistry.Address.__bases__[0].__name__ == 'object' — Address has no intermediate base. email_extra5 uses __bases__.__getitem__ path; dotted chain is new. Verified Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# email.errors class base hierarchy via __bases__[0].__name__ dotted chain
#
# email_extra6 covers MessageError and HeaderParseError via __bases__.__getitem__(0)
# then reads .__name__ as the return value. This spec calls .__name__.__eq__ on the
# result — a distinct execution path. MessageDefect, MultipartConversionError, and
# CharsetError have no prior __bases__ invariants at all.
# ---------------------------------------------------------------------------

table email_extra9.error_base_names:
  description: "Direct base class name for email.errors classes via __bases__[0].__name__ chain"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: errbase9

  columns: [id, function, args, expected]
  rows:
    - [MessageDefect,          "errors.MessageDefect.__bases__[0].__name__.__eq__",          ["ValueError"],    true]
    - [MultipartConversionError, "errors.MultipartConversionError.__bases__[0].__name__.__eq__", ["MessageError"], true]
    - [CharsetError,           "errors.CharsetError.__bases__[0].__name__.__eq__",           ["MessageError"],  true]

# ---------------------------------------------------------------------------
# email.message.Message.__bases__[0].__name__ == 'object'
#
# email_extra6 checks Policy.__bases__ via __getitem__; email_extra5 checks
# generator.Generator/__bases__.__getitem__ and headerregistry.Address/__bases__.__getitem__.
# No prior spec checks message.Message.__bases__[0].__name__ via the dotted chain.
# Message has no intermediate base class — it inherits directly from object.
# ---------------------------------------------------------------------------

invariant email_extra9.message.Message.base_name:
  description: "email.message.Message.__bases__[0].__name__ == 'object' — Message inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: "message.Message.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# email.headerregistry.Address.__bases__[0].__name__ == 'object'
#
# email_extra5 covers headerregistry.Address.__bases__.__getitem__(0) and reads
# the return value directly. This invariant calls .__name__.__eq__('object') on
# the subscript result — a distinct chain. Address has no intermediate base.
# ---------------------------------------------------------------------------

invariant email_extra9.headerregistry.Address.base_name:
  description: "email.headerregistry.Address.__bases__[0].__name__ == 'object' — Address inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: "headerregistry.Address.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# email.errors.MessageDefect.__bases__[0].__name__.__len__() == 10
#
# email_extra9.error_base_names confirms the value is 'ValueError'.
# len('ValueError') == 10. No prior spec checks this string length.
# ---------------------------------------------------------------------------

invariant email_extra9.errors.MessageDefect.base_name_len:
  description: "len(email.errors.MessageDefect.__bases__[0].__name__) == 10 — len('ValueError') == 10"
  category: class_hierarchy
  kind: python_call_eq
  function: "errors.MessageDefect.__bases__[0].__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# email.errors.MultipartConversionError.__bases__[0].__name__.__len__() == 12
#
# 'MessageError' has 12 characters. No prior spec checks this length.
# ---------------------------------------------------------------------------

invariant email_extra9.errors.MultipartConversionError.base_name_len:
  description: "len(email.errors.MultipartConversionError.__bases__[0].__name__) == 12 — len('MessageError') == 12"
  category: class_hierarchy
  kind: python_call_eq
  function: "errors.MultipartConversionError.__bases__[0].__name__.__len__"
  args: []
  expected: 12
