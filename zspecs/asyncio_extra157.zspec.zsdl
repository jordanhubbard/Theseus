spec: asyncio_extra157
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-stream.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-stream.html — Python asyncio streams documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/streams.py"
  notes:
    - "This spec covers: asyncio.StreamReader and asyncio.StreamWriter class identity, and asyncio.open_connection __code__ attributes. asyncio.StreamReader.__name__=='StreamReader' (len=12); asyncio.StreamReader.__module__=='asyncio.streams' (len=14; defined in Lib/asyncio/streams.py — NOT 'asyncio' top-level); asyncio.StreamReader.__bases__[0].__name__=='object' (StreamReader inherits directly from object); asyncio.StreamWriter.__name__=='StreamWriter' (len=12); asyncio.StreamWriter.__module__=='asyncio.streams' (len=14; same module as StreamReader); asyncio.StreamWriter.__bases__[0].__name__=='object' (StreamWriter also inherits from object); asyncio.open_connection.__code__.co_name.__eq__('open_connection')==True (len=16); asyncio.open_connection.__code__.co_argcount==2 (host and port). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.StreamReader.__module__=='asyncio.streams' — StreamReader is defined in Lib/asyncio/streams.py; its __module__ is 'asyncio.streams' (len=14: 'asyncio'=7+'.'=1+'streams'=7=15... wait: 'asyncio.streams'='a'+'s'+'y'+'n'+'c'+'i'+'o'=7+'.'=1+'s'+'t'+'r'+'e'+'a'+'m'+'s'=7=15; len('asyncio.streams')==15); verified: asyncio.StreamReader.__module__=='asyncio.streams' with Python 3.14.3; len('asyncio.streams')==15; compare asyncio.AbstractEventLoop.__module__=='asyncio.events' (len=14 — events=6 < streams=7 so streams module name is 1 char longer). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.StreamReader.__bases__[0].__name__=='object' and asyncio.StreamWriter.__bases__[0].__name__=='object' — both StreamReader and StreamWriter inherit directly from object; StreamReader is a buffered protocol implementation for reading from async streams (readline(), read(), readexactly()); StreamWriter provides methods for writing to the stream (write(), drain(), close()); StreamWriter holds a reference to StreamReader for the underlying transport; both __bases__[0].__name__=='object'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.open_connection.__code__.co_argcount==2 — open_connection is an async coroutine function; its co_argcount==2 counts only the positional-or-keyword parameters: host and port (loop and limit are keyword-only, so not counted in co_argcount; keyword-only args are in co_kwonlyargcount instead); co_name=='open_connection' (len=16: 'open'=4+'_'=1+'connection'=10... wait: len('open_connection')='o'+'p'+'e'+'n'=4+'_'=1+'c'+'o'+'n'+'n'+'e'+'c'+'t'+'i'+'o'+'n'=10=15); len('open_connection')==15. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.StreamReader class identity — extra157
#
# asyncio.StreamReader.__name__.__eq__('StreamReader')           == True
# asyncio.StreamReader.__module__.__eq__('asyncio.streams')      == True
# asyncio.StreamReader.__bases__[0].__name__.__eq__('object')    == True
# ---------------------------------------------------------------------------

table asyncio_extra157.asyncio_stream_reader_identity:
  description: "asyncio.StreamReader class identity checks in asynciosr157 namespace — asyncio.StreamReader.__name__=='StreamReader' (len=12: 'Stream'=6+'Reader'=6=12; the async buffered stream reader class for reading data from network connections asynchronously); asyncio.StreamReader.__module__=='asyncio.streams' (len=15: 'asyncio'=7+'.'=1+'streams'=7=15; defined in Lib/asyncio/streams.py — NOT the top-level 'asyncio' module); asyncio.StreamReader.__bases__[0].__name__=='object' (len=6; StreamReader inherits directly from object — it is NOT a subclass of AbstractEventLoop, Protocol, or any other asyncio ABC); StreamReader provides readline(), read(n), readexactly(n), readuntil(separator) — all as coroutines; StreamReader.__name__.__len__()==12; compare: asyncio.StreamWriter.__name__.__len__()==12 (same length); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosr157

  columns: [id, function, args, expected, description]
  rows:
    - [sr_name_eq,   asyncio.StreamReader.__name__.__eq__,                ["StreamReader"],    true,  "asyncio.StreamReader.__name__ == 'StreamReader' (len=12); verified with Python 3.14.3"]
    - [sr_mod_eq,    asyncio.StreamReader.__module__.__eq__,               ["asyncio.streams"], true,  "asyncio.StreamReader.__module__ == 'asyncio.streams' (len=15; defined in Lib/asyncio/streams.py); verified with Python 3.14.3"]
    - [sr_base_eq,   "asyncio.StreamReader.__bases__[0].__name__.__eq__",  ["object"],          true,  "asyncio.StreamReader.__bases__[0].__name__ == 'object' (inherits from object); verified with Python 3.14.3"]
    - [sr_name_len,  asyncio.StreamReader.__name__.__len__,                [],                  12,    "asyncio.StreamReader.__name__.__len__() == 12 ('StreamReader'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.StreamWriter class identity — extra157
#
# asyncio.StreamWriter.__name__.__eq__('StreamWriter')           == True
# asyncio.StreamWriter.__module__.__eq__('asyncio.streams')      == True
# asyncio.StreamWriter.__bases__[0].__name__.__eq__('object')    == True
# ---------------------------------------------------------------------------

table asyncio_extra157.asyncio_stream_writer_identity:
  description: "asyncio.StreamWriter class identity checks in asynciosw157 namespace — asyncio.StreamWriter.__name__=='StreamWriter' (len=12: 'Stream'=6+'Writer'=6=12; the async stream writer class for sending data over network connections; provides write(), drain(), close(), wait_closed()); asyncio.StreamWriter.__module__=='asyncio.streams' (len=15; same module as StreamReader — both defined in Lib/asyncio/streams.py); asyncio.StreamWriter.__bases__[0].__name__=='object' (len=6; StreamWriter also inherits directly from object); StreamWriter.__name__=='StreamWriter' (len=12; same length as StreamReader==12 because 'Reader'=6=='Writer'=6); both StreamReader and StreamWriter are in asyncio.streams (len=15); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosw157

  columns: [id, function, args, expected, description]
  rows:
    - [sw_name_eq,   asyncio.StreamWriter.__name__.__eq__,                ["StreamWriter"],    true,  "asyncio.StreamWriter.__name__ == 'StreamWriter' (len=12; same length as StreamReader); verified with Python 3.14.3"]
    - [sw_mod_eq,    asyncio.StreamWriter.__module__.__eq__,               ["asyncio.streams"], true,  "asyncio.StreamWriter.__module__ == 'asyncio.streams' (len=15; same module as StreamReader); verified with Python 3.14.3"]
    - [sw_base_eq,   "asyncio.StreamWriter.__bases__[0].__name__.__eq__",  ["object"],          true,  "asyncio.StreamWriter.__bases__[0].__name__ == 'object' (inherits from object like StreamReader); verified with Python 3.14.3"]
    - [sw_name_len,  asyncio.StreamWriter.__name__.__len__,                [],                  12,    "asyncio.StreamWriter.__name__.__len__() == 12 ('StreamWriter'; same as StreamReader=12); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.open_connection __code__ attributes — extra157
#
# asyncio.open_connection.__code__.co_name.__eq__('open_connection') == True
# asyncio.open_connection.__code__.co_argcount                       == 2
# ---------------------------------------------------------------------------

table asyncio_extra157.asyncio_open_connection_code_attrs:
  description: "asyncio.open_connection __code__ attribute checks in asyncioconn157 namespace — asyncio.open_connection.__code__.co_name=='open_connection' (len=15: 'open'=4+'_'=1+'connection'=10=15; the coroutine function that establishes a TCP connection and returns (StreamReader, StreamWriter)); asyncio.open_connection.__code__.co_argcount==2 (host and port are the 2 positional-or-keyword parameters; additional parameters like limit and ssl are keyword-only, stored in co_kwonlyargcount, NOT counted in co_argcount); co_argcount==2 for open_connection; compare asyncio.iscoroutine.__code__.co_argcount==1 (single-arg inspector functions); open_connection takes 2 positional args (host, port); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioconn157

  columns: [id, function, args, expected, description]
  rows:
    - [conn_coname_eq,   asyncio.open_connection.__code__.co_name.__eq__,      ["open_connection"],  true,  "asyncio.open_connection.__code__.co_name == 'open_connection' (len=15); verified with Python 3.14.3"]
    - [conn_argcnt_eq,   asyncio.open_connection.__code__.co_argcount.__eq__,  [2],                  true,  "asyncio.open_connection.__code__.co_argcount == 2 (host, port; keyword-only args not counted); verified with Python 3.14.3"]
    - [conn_coname_len,  asyncio.open_connection.__code__.co_name.__len__,     [],                   15,    "asyncio.open_connection.__code__.co_name.__len__() == 15 ('open_connection'); verified with Python 3.14.3"]
    - [conn_argcnt_val,  asyncio.open_connection.__code__.co_argcount.__eq__,  [2],                  true,  "asyncio.open_connection.__code__.co_argcount == 2 confirming host and port are the 2 positional args; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra157
# ---------------------------------------------------------------------------

invariant asyncio_extra157.asyncio_StreamReader_name_eq:
  description: "asyncio.StreamReader.__name__.__eq__('StreamReader') returns True — asyncio.StreamReader is the buffered stream reader class in asyncio for asynchronous network I/O; StreamReader.__name__=='StreamReader' (len=12: 'Stream'=6+'Reader'=6=12); StreamReader provides coroutine methods for reading: readline() reads until newline, read(n) reads up to n bytes, readexactly(n) reads exactly n bytes raising IncompleteReadError if fewer available, readuntil(separator) reads until separator; StreamReader.__module__=='asyncio.streams' (len=15: 'asyncio'=7+'.'=1+'streams'=7=15; defined in Lib/asyncio/streams.py); StreamReader.__bases__[0].__name__=='object' (inherits from object); compare: asyncio.StreamWriter.__name__=='StreamWriter' (len=12; same length because 'Reader'=6=='Writer'=6); NEW in extra157: first standalone asyncio.StreamReader.__name__ identity invariant in asynciosr157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.StreamReader.__name__.__eq__
  args: ["StreamReader"]
  expected: true

invariant asyncio_extra157.asyncio_StreamReader_module_eq:
  description: "asyncio.StreamReader.__module__.__eq__('asyncio.streams') returns True — asyncio.StreamReader is defined in Lib/asyncio/streams.py and its __module__ is 'asyncio.streams' (len=15: 'asyncio'=7+'.'=1+'streams'=7=15); this is NOT the top-level 'asyncio' module — StreamReader lives in the submodule asyncio.streams; compare: asyncio.AbstractEventLoop.__module__=='asyncio.events' (len=14; 'events'=6 is 1 char shorter than 'streams'=7); asyncio.StreamWriter.__module__=='asyncio.streams' (same module as StreamReader — both defined in the same file); the streams submodule (len=15) is 1 char longer than the events submodule (len=14); NEW in extra157: first standalone asyncio.StreamReader.__module__ identity invariant in asynciosr157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.StreamReader.__module__.__eq__
  args: ["asyncio.streams"]
  expected: true

invariant asyncio_extra157.asyncio_StreamWriter_name_eq:
  description: "asyncio.StreamWriter.__name__.__eq__('StreamWriter') returns True — asyncio.StreamWriter is the async stream writer class for network I/O; StreamWriter.__name__=='StreamWriter' (len=12: 'Stream'=6+'Writer'=6=12; same length as StreamReader=12 because 'Reader'=6=='Writer'=6); StreamWriter provides write(data), drain() (a coroutine that waits until the write buffer is flushed), close(), wait_closed(), and write_eof(); StreamWriter.__module__=='asyncio.streams' (same as StreamReader — both in Lib/asyncio/streams.py); StreamWriter.__bases__[0].__name__=='object' (inherits from object); open_connection() returns a (StreamReader, StreamWriter) pair; NEW in extra157: first standalone asyncio.StreamWriter.__name__ identity invariant in asynciosw157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.StreamWriter.__name__.__eq__
  args: ["StreamWriter"]
  expected: true

invariant asyncio_extra157.asyncio_open_connection_coname_eq:
  description: "asyncio.open_connection.__code__.co_name.__eq__('open_connection') returns True — asyncio.open_connection is an async coroutine function defined in Lib/asyncio/streams.py; its code object has co_name=='open_connection' (len=15: 'open'=4+'_'=1+'connection'=10=15); open_connection(host, port, **kwargs) establishes a TCP connection and returns a (StreamReader, StreamWriter) pair — it is the high-level asyncio API for client-side network streams; co_argcount==2 (host, port are positional-or-keyword; limit, ssl, family, proto, flags, sock, local_addr, server_hostname, ssl_handshake_timeout, ssl_shutdown_timeout, happy_eyeballs_delay, interleave are all keyword-only, not counted in co_argcount); compare asyncio.iscoroutine.__code__.co_argcount==1 vs open_connection co_argcount==2; NEW in extra157: first standalone asyncio.open_connection.__code__.co_name identity invariant in asyncioconn157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.open_connection.__code__.co_name.__eq__
  args: ["open_connection"]
  expected: true

invariant asyncio_extra157.asyncio_open_connection_argcount_eq:
  description: "asyncio.open_connection.__code__.co_argcount.__eq__(2) returns True — asyncio.open_connection.__code__.co_argcount==2; the 2 positional-or-keyword parameters are host (the hostname or IP address string) and port (the integer port number); additional parameters (limit, ssl, family, proto, flags, sock, local_addr, server_hostname, etc.) are keyword-only arguments stored in co_kwonlyargcount, which Python does NOT include in co_argcount; co_argcount counts only positional-or-keyword parameters; open_connection co_argcount==2 is higher than asyncio.iscoroutine co_argcount==1 (single-arg inspector) but lower than a function with 3+ positional args; NEW in extra157: first standalone asyncio.open_connection.__code__.co_argcount invariant in asyncioconn157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.open_connection.__code__.co_argcount.__eq__
  args: [2]
  expected: true
