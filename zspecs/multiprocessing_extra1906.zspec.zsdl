spec: multiprocessing_extra1906
version: ">=3.9"
backend: python_module(multiprocessing)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 574 (_extra1906): __reversed__ reverse iteration protocol; __missing__ dict protocol; __match_args__ structural pattern matching (3.10+); __qualname__ values."
    - "multiprocessing.Process is a Python class; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "multiprocessing.queues.Queue is a Python class; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "multiprocessing.synchronize.Lock is a Python class; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "multiprocessing.synchronize.Event is a Python class; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "multiprocessing.synchronize.Semaphore is a Python class; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "multiprocessing.synchronize.Condition is a Python class; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "multiprocessing.pool.Pool is a Python class; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "multiprocessing.Process.__qualname__ == 'Process' — top-level Python class."
    - "multiprocessing.queues.Queue.__qualname__ == 'Queue' — Python class in multiprocessing.queues submodule."
    - "multiprocessing.synchronize.Lock.__qualname__ == 'Lock' — Python class in multiprocessing.synchronize submodule."
    - "multiprocessing.synchronize.Event.__qualname__ == 'Event' — Python class in multiprocessing.synchronize submodule."
    - "multiprocessing.synchronize.Semaphore.__qualname__ == 'Semaphore' — Python class in multiprocessing.synchronize submodule."
    - "multiprocessing.synchronize.Condition.__qualname__ == 'Condition' — Python class in multiprocessing.synchronize submodule."
    - "multiprocessing.pool.Pool.__qualname__ == 'Pool' — Python class in multiprocessing.pool submodule."
    - "multiprocessing.Process.__dict__ contains __doc__, __module__, __firstlineno__, __static_attributes__ but not __init__ or __repr__ (inherited)."
    - "multiprocessing.queues.Queue.__dict__ contains __init__ but not __repr__."
    - "multiprocessing.synchronize.Lock.__dict__ contains __init__ and __repr__ but not __enter__ or __exit__ (inherited from SemLock)."
    - "multiprocessing.pool.Pool.__dict__ contains __init__, __del__, __repr__, __reduce__, __enter__, __exit__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

