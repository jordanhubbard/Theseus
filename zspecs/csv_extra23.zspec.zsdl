spec: csv_extra23
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra22.zspec.zsdl."
    - "csv_extra22 covers: Dialect/__bases__[0]/__qualname__; DictReader/__bases__[0]/__qualname__; Error/__bases__[0]/__qualname__; DictReader/DictWriter/Error/Dialect __module__.__class__.__name__ type axis."
    - "csv_extra21 covers: unix_dialect/__module__; unix_dialect/__bases__[0]/__name__; QUOTE_NONNUMERIC/__class__/__qualname__; QUOTE_NONE/__class__/__qualname__; Dialect.delimiter/__class__/__name__."
    - "csv_extra20 covers: DictReader/__next__/__qualname__; DictReader/__iter__/__qualname__; DictWriter method qualnames; Sniffer method qualnames."
    - "csv_extra18 covers: list_dialects/__module__; get_dialect/__module__; DictReader/DictWriter/Sniffer/excel/excel_tab/Dialect __qualname__ table."
    - "csv_extra16 covers: reader/__module__; writer/__module__; QUOTE_ALL/QUOTE_MINIMAL/QUOTE_NONNUMERIC/QUOTE_NONE __class__.__name__."
    - "Focus: DictReader/__init__/__qualname__; DictWriter/__init__/__qualname__; register_dialect/__qualname__ and __module__; unregister_dialect/__qualname__ and __module__; list_dialects/__qualname__; field_size_limit/__qualname__ and __module__; QUOTE_NONNUMERIC/QUOTE_NONE __class__.__module__."
    - "No prior csv spec checks DictReader.__init__.__qualname__."
    - "No prior csv spec checks DictWriter.__init__.__qualname__."
    - "No prior csv spec checks register_dialect.__qualname__."
    - "No prior csv spec checks register_dialect.__module__."
    - "No prior csv spec checks unregister_dialect.__qualname__."
    - "No prior csv spec checks unregister_dialect.__module__."
    - "No prior csv spec checks list_dialects.__qualname__."
    - "No prior csv spec checks field_size_limit.__qualname__."
    - "No prior csv spec checks field_size_limit.__module__."
    - "No prior csv spec checks QUOTE_NONNUMERIC.__class__.__module__."
    - "No prior csv spec checks QUOTE_NONE.__class__.__module__."
    - "csv.DictReader.__init__.__qualname__ == 'DictReader.__init__' — compound dotted method qualname."
    - "csv.DictWriter.__init__.__qualname__ == 'DictWriter.__init__' — compound dotted method qualname."
    - "csv.register_dialect.__qualname__ == 'register_dialect' — C builtin qualname equals bare name."
    - "csv.register_dialect.__module__ == '_csv' — C extension function from _csv module."
    - "csv.unregister_dialect.__qualname__ == 'unregister_dialect' — C builtin qualname equals bare name."
    - "csv.unregister_dialect.__module__ == '_csv' — C extension function from _csv module."
    - "csv.list_dialects.__qualname__ == 'list_dialects' — C builtin qualname equals bare name."
    - "csv.field_size_limit.__qualname__ == 'field_size_limit' — C builtin qualname equals bare name."
    - "csv.field_size_limit.__module__ == '_csv' — C extension function from _csv module."
    - "csv.QUOTE_NONNUMERIC.__class__.__module__ == 'builtins' — int type is defined in builtins."
    - "csv.QUOTE_NONE.__class__.__module__ == 'builtins' — int type is defined in builtins."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# DictReader.__init__ and DictWriter.__init__ — __qualname__
#
# csv_extra18 checks __qualname__ for the DictReader and DictWriter classes
# themselves ('DictReader', 'DictWriter').  csv_extra20 checks __qualname__
# for __next__, __iter__, writerow, and writeheader methods.  No prior csv spec
# checks the __qualname__ of __init__ on either class.  These are pure-Python
# methods so their __qualname__ uses the compound dotted form.
# ---------------------------------------------------------------------------

invariant csv_extra23.DictReader.__init__.qualname:
  description: "csv.DictReader.__init__.__qualname__ == 'DictReader.__init__' — compound dunder method qualname"
  category: method_attrs
  kind: python_call_eq
  function: "DictReader.__init__.__qualname__.__eq__"
  args: ["DictReader.__init__"]
  expected: true

invariant csv_extra23.DictWriter.__init__.qualname:
  description: "csv.DictWriter.__init__.__qualname__ == 'DictWriter.__init__' — compound dunder method qualname"
  category: method_attrs
  kind: python_call_eq
  function: "DictWriter.__init__.__qualname__.__eq__"
  args: ["DictWriter.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# register_dialect, unregister_dialect, list_dialects — __qualname__ and __module__
#
# csv_extra18 checks list_dialects.__module__ == '_csv' and
# get_dialect.__module__ == '_csv'.  No prior csv spec checks the __qualname__
# of register_dialect, unregister_dialect, or list_dialects, and no prior
# spec checks __module__ for register_dialect or unregister_dialect.
# All three are C builtins from the _csv extension; their __qualname__ equals
# the bare function name.
# ---------------------------------------------------------------------------

invariant csv_extra23.register_dialect.qualname:
  description: "csv.register_dialect.__qualname__ == 'register_dialect' — C builtin qualname is its bare name"
  category: function_attrs
  kind: python_call_eq
  function: register_dialect.__qualname__.__eq__
  args: ["register_dialect"]
  expected: true

invariant csv_extra23.register_dialect.module:
  description: "csv.register_dialect.__module__ == '_csv' — C extension function from the _csv module"
  category: function_attrs
  kind: python_call_eq
  function: register_dialect.__module__.__eq__
  args: ["_csv"]
  expected: true

invariant csv_extra23.unregister_dialect.qualname:
  description: "csv.unregister_dialect.__qualname__ == 'unregister_dialect' — C builtin qualname is its bare name"
  category: function_attrs
  kind: python_call_eq
  function: unregister_dialect.__qualname__.__eq__
  args: ["unregister_dialect"]
  expected: true

invariant csv_extra23.unregister_dialect.module:
  description: "csv.unregister_dialect.__module__ == '_csv' — C extension function from the _csv module"
  category: function_attrs
  kind: python_call_eq
  function: unregister_dialect.__module__.__eq__
  args: ["_csv"]
  expected: true

invariant csv_extra23.list_dialects.qualname:
  description: "csv.list_dialects.__qualname__ == 'list_dialects' — C builtin qualname is its bare name"
  category: function_attrs
  kind: python_call_eq
  function: list_dialects.__qualname__.__eq__
  args: ["list_dialects"]
  expected: true

# ---------------------------------------------------------------------------
# field_size_limit — __qualname__ and __module__
#
# No prior csv spec checks field_size_limit.__qualname__ or __module__.
# It is a C builtin from the _csv extension.
# ---------------------------------------------------------------------------

invariant csv_extra23.field_size_limit.qualname:
  description: "csv.field_size_limit.__qualname__ == 'field_size_limit' — C builtin qualname is its bare name"
  category: function_attrs
  kind: python_call_eq
  function: field_size_limit.__qualname__.__eq__
  args: ["field_size_limit"]
  expected: true

invariant csv_extra23.field_size_limit.module:
  description: "csv.field_size_limit.__module__ == '_csv' — C extension function from the _csv module"
  category: function_attrs
  kind: python_call_eq
  function: field_size_limit.__module__.__eq__
  args: ["_csv"]
  expected: true

# ---------------------------------------------------------------------------
# QUOTE_NONNUMERIC and QUOTE_NONE — __class__.__module__
#
# csv_extra16 checks __class__.__name__ == 'int' for both constants.
# csv_extra21 checks __class__.__qualname__ == 'int' for both constants.
# No prior csv spec checks __class__.__module__ for either constant.
# The int type is defined in the 'builtins' module.
# ---------------------------------------------------------------------------

invariant csv_extra23.QUOTE_NONNUMERIC.class_module:
  description: "csv.QUOTE_NONNUMERIC.__class__.__module__ == 'builtins' — int type is defined in builtins"
  category: constant_types
  kind: python_call_eq
  function: QUOTE_NONNUMERIC.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant csv_extra23.QUOTE_NONE.class_module:
  description: "csv.QUOTE_NONE.__class__.__module__ == 'builtins' — int type is defined in builtins"
  category: constant_types
  kind: python_call_eq
  function: QUOTE_NONE.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all eleven new invariants
#
# All eleven are first covered in this spec (csv_extra23).
# ---------------------------------------------------------------------------

table csv_extra23.init_qualnames_func_attrs_and_constant_modules:
  description: "csv DictReader/DictWriter __init__ qualnames, dialect func attrs, QUOTE_* class modules"
  kind: python_call_eq
  category: method_attrs
  id_prefix: cfa23

  columns: [id, function, args, expected]
  rows:
    - [DictReader_init_qn,      "DictReader.__init__.__qualname__.__eq__",   ["DictReader.__init__"],  true]
    - [DictWriter_init_qn,      "DictWriter.__init__.__qualname__.__eq__",   ["DictWriter.__init__"],  true]
    - [register_dialect_qn,     register_dialect.__qualname__.__eq__,        ["register_dialect"],     true]
    - [register_dialect_mod,    register_dialect.__module__.__eq__,          ["_csv"],                 true]
    - [unregister_dialect_qn,   unregister_dialect.__qualname__.__eq__,      ["unregister_dialect"],   true]
    - [unregister_dialect_mod,  unregister_dialect.__module__.__eq__,        ["_csv"],                 true]
    - [list_dialects_qn,        list_dialects.__qualname__.__eq__,           ["list_dialects"],        true]
    - [field_size_limit_qn,     field_size_limit.__qualname__.__eq__,        ["field_size_limit"],     true]
    - [field_size_limit_mod,    field_size_limit.__module__.__eq__,          ["_csv"],                 true]
    - [QUOTE_NONNUMERIC_mod,    QUOTE_NONNUMERIC.__class__.__module__.__eq__, ["builtins"],            true]
    - [QUOTE_NONE_mod,          QUOTE_NONE.__class__.__module__.__eq__,       ["builtins"],            true]
