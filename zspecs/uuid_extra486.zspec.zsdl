spec: uuid_extra486
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid.UUID class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid.UUID inherits many dunder methods from object; only those explicitly defined on UUID are tested"
    - "__setattr__ is overridden on UUID to enforce immutability"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra486.uuid_method_names:
  description: "uuid.UUID method __name__ identity"
  kind: python_call_eq
  category: method_identity
  id_prefix: uid

  columns: [id, function, args, expected]
  rows:
    - [uid001, UUID.__str__.__name__.__eq__,       ["__str__"],       true]
    - [uid002, UUID.__repr__.__name__.__eq__,      ["__repr__"],      true]
    - [uid003, UUID.__eq__.__name__.__eq__,        ["__eq__"],        true]
    - [uid004, UUID.__lt__.__name__.__eq__,        ["__lt__"],        true]
    - [uid005, UUID.__hash__.__name__.__eq__,      ["__hash__"],      true]
    - [uid006, UUID.__init__.__name__.__eq__,      ["__init__"],      true]
    - [uid007, UUID.__setattr__.__name__.__eq__,   ["__setattr__"],   true]
    - [uid008, UUID.__int__.__name__.__eq__,       ["__int__"],       true]
