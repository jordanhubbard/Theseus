spec: pathlib_extra42
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra41.zspec.zsdl — covers Path.is_block_device(20)/is_char_device(19)/is_socket(14)/is_fifo(12) __qualname__.__len__(); Path.hardlink_to(16)/PurePath.with_stem(18) __qualname__.__len__(); PurePath property fget __qualname__.__len__() for drive(14)/root(13)/anchor(15)/parents(16)."
    - "pathlib_extra39.zspec.zsdl — covers PurePath property fget __qualname__.__len__() for name/parent/suffix/stem/parts; Path method __qualname__.__len__() for is_symlink/is_mount/touch/cwd/home/expanduser/samefile/lstat; PurePath method __qualname__.__len__() for relative_to/is_relative_to/match/__str__/__fspath__."
    - "pathlib_extra38.zspec.zsdl — covers Path.read_bytes/write_bytes/is_file/is_dir __qualname__.__len__(); PurePath.as_posix/joinpath/with_name/with_suffix __qualname__.__len__()."
    - "pathlib_extra36.zspec.zsdl — covers Path.rename/unlink/rmdir/chmod/symlink_to __qualname__.__len__()."
    - "pathlib_extra35.zspec.zsdl — covers Path.open/read_text/write_text/mkdir/exists/stat __qualname__.__len__(); class __qualname__.__len__() for PosixPath/PurePosixPath/PureWindowsPath/WindowsPath."
  notes:
    - "This spec extends pathlib_extra41.zspec.zsdl."
    - "Prior specs collectively covered: Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __name__/__module__/__qualname__ and lengths; MRO depths for all six classes; __bases__[0].__name__/__len__() for all six; all major Path/PurePath method __qualname__/__len__() and __qualname__.__len__(); PurePath property fget __qualname__.__len__() for name/parent/suffix/stem/parts/drive/root/anchor/parents; Path is_* methods including is_symlink/is_mount/is_file/is_dir/is_block_device/is_char_device/is_socket/is_fifo."
    - "This spec covers: Path.lchmod/__qualname__.__len__()==11 (NOVEL — no prior pathlib spec checks lchmod/__qualname__.__len__()); Path.replace/__qualname__.__len__()==12 (NOVEL); Path.group/__qualname__.__len__()==10 (NOVEL); Path.owner/__qualname__.__len__()==10 (NOVEL); PurePath.as_uri/__qualname__.__len__()==15 (NOVEL — pathlib_extra38 covers as_posix/joinpath/with_name/with_suffix but NOT as_uri); PurePath.__hash__/__qualname__.__len__()==17 (NOVEL); PurePath.__repr__/__qualname__.__len__()==17 (NOVEL); PurePath.__eq__/__qualname__.__len__()==15 (NOVEL); PurePath.__lt__/__qualname__.__len__()==15 (NOVEL); PurePath.__bytes__/__qualname__.__len__()==18 (NOVEL); PurePath.__rtruediv__/__qualname__.__len__()==21 (NOVEL)."
    - "pathlib.Path.lchmod.__qualname__ == 'Path.lchmod' — len 11. No prior pathlib spec checks lchmod.__qualname__.__len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.Path.replace.__qualname__ == 'Path.replace' — len 12. No prior pathlib spec checks replace.__qualname__.__len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.Path.group.__qualname__ == 'Path.group' — len 10. No prior pathlib spec checks group.__qualname__.__len__(). Novel. Equals Path.owner (10). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.Path.owner.__qualname__ == 'Path.owner' — len 10. No prior pathlib spec checks owner.__qualname__.__len__(). Novel. Equals Path.group (10). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.as_uri.__qualname__ == 'PurePath.as_uri' — len 15. pathlib_extra38 covers as_posix(17)/joinpath(17)/with_name(18)/with_suffix(20) but NOT as_uri. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__hash__.__qualname__ == 'PurePath.__hash__' — len 17. No prior pathlib spec checks __hash__.__qualname__.__len__(). Novel. Equals PurePath.__repr__ (17). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__repr__.__qualname__ == 'PurePath.__repr__' — len 17. No prior pathlib spec checks __repr__.__qualname__.__len__(). Novel. Equals PurePath.__hash__ (17). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__eq__.__qualname__ == 'PurePath.__eq__' — len 15. No prior pathlib spec checks __eq__.__qualname__.__len__(). Novel. Equals as_uri/PurePath.__lt__/__le__/__gt__/__ge__ (15 each). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__lt__.__qualname__ == 'PurePath.__lt__' — len 15. No prior pathlib spec checks __lt__.__qualname__.__len__(). Novel. Equals __eq__/__le__/__gt__/__ge__ (15). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__bytes__.__qualname__ == 'PurePath.__bytes__' — len 18. No prior pathlib spec checks __bytes__.__qualname__.__len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__rtruediv__.__qualname__ == 'PurePath.__rtruediv__' — len 21. Longest PurePath operator dunder qualname. No prior pathlib spec checks __rtruediv__.__qualname__.__len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.lchmod, replace, group, owner __qualname__.__len__()
#
# No prior pathlib spec checks __qualname__.__len__() for any of these
# four Path methods. All are novel.
#
#   Path.lchmod  -> 'Path.lchmod'  -> 11 (like rename/unlink)
#   Path.replace -> 'Path.replace' -> 12
#   Path.group   -> 'Path.group'   -> 10 (tied with Path.owner)
#   Path.owner   -> 'Path.owner'   -> 10 (tied with Path.group)
#
# Note: Path.group and Path.owner both have len 10, the shortest
# Path concrete-method qualnames alongside Path.cwd (8) and Path.home (9).
# All verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra42.Path_misc_method_qualname_lens:
  description: "pathlib.Path.lchmod(11)/replace(12)/group(10)/owner(10) __qualname__.__len__() — four uncovered Path methods; group/owner tied at 10 chars"
  kind: python_call_eq
  category: method_identity
  id_prefix: pmmq42

  columns: [id, function, args, expected]
  rows:
    - [lchmod,  Path.lchmod.__qualname__.__len__,  [], 11]
    - [replace, Path.replace.__qualname__.__len__, [], 12]
    - [group,   Path.group.__qualname__.__len__,   [], 10]
    - [owner,   Path.owner.__qualname__.__len__,   [], 10]

# ---------------------------------------------------------------------------
# PurePath.as_uri __qualname__.__len__()
#
# pathlib_extra38 covers PurePath.as_posix(17)/joinpath(17)/with_name(18)/
# with_suffix(20) but NOT as_uri. PurePath.as_uri converts the path to a
# file:// URL. Its qualname 'PurePath.as_uri' has 15 characters, equal to
# PurePath.__eq__/__lt__/__le__/__gt__/__ge__ (all 15). Novel.
# Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant pathlib_extra42.PurePath_as_uri_qualname_len:
  description: "len(pathlib.PurePath.as_uri.__qualname__) == 15 — 'PurePath.as_uri' has 15 characters; pathlib_extra38 covers as_posix/joinpath/with_name/with_suffix but not as_uri; novel"
  category: method_identity
  kind: python_call_eq
  function: PurePath.as_uri.__qualname__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# PurePath dunder operator/repr method __qualname__.__len__()
#
# No prior pathlib spec checks __qualname__.__len__() for any PurePath
# dunder method. PurePath defines rich comparison operators, __hash__,
# __repr__, __bytes__, and __rtruediv__. All carry the 'PurePath.' prefix
# (9 chars) plus the dunder name.
#
# Notable clusters:
#   len 15 — __eq__, __lt__, __le__, __gt__, __ge__ (4-char operator names)
#   len 17 — __hash__, __repr__                     (6-char names)
#   len 18 — __bytes__                              (7-char name)
#   len 21 — __rtruediv__                           (11-char name, longest)
#
# All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra42.PurePath_dunder_qualname_lens:
  description: "pathlib.PurePath dunder method __qualname__.__len__(): __eq__/__lt__(15), __hash__/__repr__(17), __bytes__(18), __rtruediv__(21) — all novel; no prior pathlib spec checks PurePath dunder qualname lengths"
  kind: python_call_eq
  category: method_identity
  id_prefix: ppdq42

  columns: [id, function, args, expected]
  rows:
    - [dunder_eq,       PurePath.__eq__.__qualname__.__len__,       [], 15]
    - [dunder_lt,       PurePath.__lt__.__qualname__.__len__,       [], 15]
    - [dunder_hash,     PurePath.__hash__.__qualname__.__len__,     [], 17]
    - [dunder_repr,     PurePath.__repr__.__qualname__.__len__,     [], 17]
    - [dunder_bytes,    PurePath.__bytes__.__qualname__.__len__,    [], 18]
    - [dunder_rtruediv, PurePath.__rtruediv__.__qualname__.__len__, [], 21]
