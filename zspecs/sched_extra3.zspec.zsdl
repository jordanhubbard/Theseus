spec: sched_extra3
version: ">=3.9"
backend: python_module(sched)

docs: https://docs.python.org/3/library/sched.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sched.html — Python sched module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sched.py"
    - "sched.zspec.zsdl — covers scheduler.__name__, scheduler.__module__, scheduler is_type, Event.__name__, scheduler().empty(), scheduler().queue==[], method names table (enter/enterabs/cancel/run/empty), Event._fields membership"
    - "sched_extra.zspec.zsdl — covers scheduler.__name__, scheduler.__module__, Event.__name__, Event.__module__, scheduler().queue.__class__.__name__=='list', scheduler().empty()==True, Event._fields.__class__.__name__=='tuple'"
    - "sched_extra2.zspec.zsdl — covers scheduler.__name__, scheduler.__module__, scheduler.__qualname__, scheduler is_type, method __name__ table (enter/cancel/run/empty), method __qualname__ table, Event.__name__, Event.__module__, Event._fields is tuple, Event._fields.__eq__, Event._fields.__len__, Event._fields field-presence table"
  notes:
    - "This spec adds invariants not present in any prior sched spec."
    - "scheduler.__bases__[0].__name__ == 'object' — scheduler inherits directly from object (pure Python class)."
    - "scheduler.enterabs.__name__ == 'enterabs' — absolute-time variant; __qualname__ == 'scheduler.enterabs'."
    - "scheduler.enterabs.__qualname__ == 'scheduler.enterabs' — covered in sched_extra2 for enter/cancel/run/empty; enterabs qualname not checked there."
    - "Event.__qualname__ == 'Event' — namedtuple subclass defined at module top-level has flat qualname."
    - "Event.__bases__[0].__name__ == 'tuple' — Event inherits from tuple (as all namedtuples do)."
    - "Event._fields[0] == 'time' — the first field of the namedtuple is 'time'."
    - "Event._fields[1] == 'priority' — the second field is 'priority'."
    - "Event._fields[2] == 'sequence' — added in Python 3.3 for insertion-order tiebreaking."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# scheduler class hierarchy — inherits from object
# (sched/sched_extra/sched_extra2 do not check scheduler.__bases__)
# ---------------------------------------------------------------------------

invariant sched_extra3.scheduler.base_is_object:
  description: "scheduler.__bases__[0].__name__ == 'object' — scheduler is a pure Python class inheriting from object"
  category: class_hierarchy
  kind: python_call_eq
  function: scheduler.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# scheduler.enterabs — __name__ and __qualname__
# sched.zspec.zsdl table covers enterabs.__name__; sched_extra2 table covers
# enter/cancel/run/empty qualnames but NOT enterabs qualname.
# ---------------------------------------------------------------------------

invariant sched_extra3.scheduler.enterabs_qualname:
  description: "scheduler.enterabs.__qualname__ == 'scheduler.enterabs'"
  category: method_qualnames
  kind: python_call_eq
  function: scheduler.enterabs.__qualname__.__eq__
  args: ["scheduler.enterabs"]
  expected: true

# ---------------------------------------------------------------------------
# Event namedtuple — __qualname__ and base class
# (sched_extra2 checks __name__ and __module__; no prior spec checks __qualname__ or __bases__)
# ---------------------------------------------------------------------------

invariant sched_extra3.Event.qualname:
  description: "Event.__qualname__ == 'Event' — module-level namedtuple has flat qualname"
  category: event_identity
  kind: python_call_eq
  function: Event.__qualname__.__eq__
  args: ["Event"]
  expected: true

invariant sched_extra3.Event.base_is_tuple:
  description: "Event.__bases__[0].__name__ == 'tuple' — Event is a namedtuple, which inherits from tuple"
  category: event_hierarchy
  kind: python_call_eq
  function: Event.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "tuple"

# ---------------------------------------------------------------------------
# Event._fields — indexed access to individual fields
# sched_extra2 checks __len__, __eq__, and __contains__ for all six fields.
# This spec adds indexed element access (not covered by any prior sched spec).
# ---------------------------------------------------------------------------

table sched_extra3.Event.fields_by_index:
  kind: python_call_eq
  category: event_fields
  id_prefix: field_idx

  columns: [id, function, args, expected]
  rows:
    - [idx0, Event._fields.__getitem__, [0], "time"]
    - [idx1, Event._fields.__getitem__, [1], "priority"]
    - [idx2, Event._fields.__getitem__, [2], "sequence"]
    - [idx3, Event._fields.__getitem__, [3], "action"]
    - [idx4, Event._fields.__getitem__, [4], "argument"]
    - [idx5, Event._fields.__getitem__, [5], "kwargs"]

# ---------------------------------------------------------------------------
# scheduler.__doc__ — exists and is a string (not None)
# No prior sched spec checks __doc__
# ---------------------------------------------------------------------------

invariant sched_extra3.scheduler.doc_is_str:
  description: "scheduler.__doc__.__class__.__name__ == 'str' — scheduler has a docstring"
  category: class_identity
  kind: python_call_eq
  function: scheduler.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
