spec: itertools_extra1846
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module reference"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools.zspec.zsdl — covers class_names, function identity, and module-level type checks"
    - "itertools_extra.zspec.zsdl — covers __name__, __module__, qualname checks"
  notes:
    - "Wave 570 theme: arithmetic operator protocol (__add__/__sub__/__mul__/__truediv__/__floordiv__/__mod__) and comparison operator protocol (__gt__/__ge__/__le__/__ne__/__lt__/__eq__)."
    - "All itertools types are C extension types implemented in itertoolsmodule.c. None define arithmetic or comparison dunder methods in their own __dict__."
    - "itertools.count.__dict__.__contains__('__add__') == False — count is a C type with no arithmetic protocol in its own __dict__."
    - "itertools.count.__dict__.__contains__('__eq__') == False — C types inherit __eq__ from object; count does not define its own __eq__."
    - "itertools.chain.__dict__.__contains__('__add__') == False — chain is a C type with no arithmetic protocol."
    - "itertools.cycle.__dict__.__contains__('__add__') == False — cycle is a C type with no arithmetic protocol."
    - "itertools.repeat.__dict__.__contains__('__add__') == False — repeat is a C type with no arithmetic protocol."
    - "itertools.__dict__.__contains__('compress') == True — compress was added in Python 2.7/3.1."
    - "itertools.__dict__.__contains__('starmap') == True — starmap is a public itertools symbol."
    - "itertools.__dict__.__contains__('tee') == True — tee returns two independent iterators from a single iterable."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operators for itertools C types
#
# All itertools types are C extension types. None define arithmetic dunder
# methods (__add__, __sub__, __mul__, etc.) in their own __dict__.
# ---------------------------------------------------------------------------

table itertools_extra1846.arithmetic_operators:
  description: "Arithmetic operator dunder methods absent from itertools C type own __dict__"
  kind: python_call_eq
  category: arithmetic_operators
  id_prefix: it1846

  columns: [id, function, args, expected]
  rows:
    - ["it1846001", itertools.count.__dict__.__contains__,        ["__add__"], false]
    - ["it1846002", itertools.count.__dict__.__contains__,        ["__sub__"], false]
    - ["it1846003", itertools.count.__dict__.__contains__,        ["__mul__"], false]
    - ["it1846004", itertools.chain.__dict__.__contains__,        ["__add__"], false]
    - ["it1846005", itertools.cycle.__dict__.__contains__,        ["__add__"], false]
    - ["it1846006", itertools.repeat.__dict__.__contains__,       ["__add__"], false]
    - ["it1846007", itertools.product.__dict__.__contains__,      ["__add__"], false]
    - ["it1846008", itertools.combinations.__dict__.__contains__,  ["__add__"], false]

# ---------------------------------------------------------------------------
# Table 2: comparison operators for itertools C types
#
# All itertools C types inherit __eq__ from object and do not define their
# own comparison dunder methods (__eq__, __lt__, __gt__, etc.).
# ---------------------------------------------------------------------------

table itertools_extra1846.comparison_operators:
  description: "Comparison operator dunder methods absent from itertools C type own __dict__"
  kind: python_call_eq
  category: comparison_operators
  id_prefix: it1846

  columns: [id, function, args, expected]
  rows:
    - ["it1846009",  itertools.count.__dict__.__contains__,        ["__eq__"], false]
    - ["it1846010", itertools.count.__dict__.__contains__,        ["__lt__"], false]
    - ["it1846011", itertools.count.__dict__.__contains__,        ["__gt__"], false]
    - ["it1846012", itertools.chain.__dict__.__contains__,        ["__eq__"], false]
    - ["it1846013", itertools.cycle.__dict__.__contains__,        ["__eq__"], false]
    - ["it1846014", itertools.repeat.__dict__.__contains__,       ["__eq__"], false]
    - ["it1846015", itertools.product.__dict__.__contains__,      ["__eq__"], false]
    - ["it1846016", itertools.combinations.__dict__.__contains__,  ["__eq__"], false]

# ---------------------------------------------------------------------------
# Table 3: itertools module-level attribute membership
#
# Verifies the public API symbols present in the itertools module namespace.
# ---------------------------------------------------------------------------

table itertools_extra1846.itertools_module_attrs:
  description: "Public itertools module symbols present in itertools.__dict__"
  kind: python_call_eq
  category: module_attrs
  id_prefix: it1846

  columns: [id, function, args, expected]
  rows:
    - ["it1846017", itertools.__dict__.__contains__, ["count"],       true]
    - ["it1846018", itertools.__dict__.__contains__, ["cycle"],       true]
    - ["it1846019", itertools.__dict__.__contains__, ["repeat"],      true]
    - ["it1846020", itertools.__dict__.__contains__, ["chain"],       true]
    - ["it1846021", itertools.__dict__.__contains__, ["compress"],    true]
    - ["it1846022", itertools.__dict__.__contains__, ["dropwhile"],   true]
    - ["it1846023", itertools.__dict__.__contains__, ["takewhile"],   true]
    - ["it1846024", itertools.__dict__.__contains__, ["islice"],      true]
    - ["it1846025", itertools.__dict__.__contains__, ["starmap"],     true]
    - ["it1846026", itertools.__dict__.__contains__, ["tee"],         true]
