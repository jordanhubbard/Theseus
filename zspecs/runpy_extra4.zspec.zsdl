spec: runpy_extra4
version: ">=3.9"
backend: python_module(runpy)

docs: https://docs.python.org/3/library/runpy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/runpy.html — Python runpy module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/runpy.py"
  notes:
    - "This spec extends runpy.zspec.zsdl through runpy_extra3.zspec.zsdl."
    - "runpy (base) covers: run_module/run_path __name__/__module__/type; run_module returns dict for 'runpy' and 'os'; result contains __name__/__spec__ keys."
    - "runpy_extra covers: run_module/run_path __name__/__module__/__qualname__."
    - "runpy_extra2 covers: run_path/run_module __name__/__module__/__qualname__/type; _run_code __name__/__module__/type."
    - "runpy_extra3 covers: _run_module_as_main __name__/__module__/type; function_names table."
    - "This spec adds: module __name__ == 'runpy'; module __spec__.name == 'runpy'; run_module/__doc__ is str; run_path/__doc__ is str; _run_code/__qualname__; _run_module_as_main/__qualname__; run_module result contains '__builtins__' key; _run_code/__code__.co_name."
    - "runpy.__name__ == 'runpy' — the module self-reports its own name."
    - "runpy.__spec__.name == 'runpy' — the ModuleSpec confirms the fully-qualified module name."
    - "run_module.__doc__ and run_path.__doc__ are both non-None strings (documented public API)."
    - "runpy._run_code.__qualname__ == '_run_code' — top-level internal, qualname equals name."
    - "runpy._run_module_as_main.__qualname__ == '_run_module_as_main' — top-level internal."
    - "run_module('runpy') result always contains '__builtins__' because Python injects it into every exec'd namespace."
    - "runpy._run_code.__code__.co_name == '_run_code' — the code object records the function name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# module __name__ — runpy reports its own name as 'runpy'.
# Not covered in any prior runpy spec.
# ---------------------------------------------------------------------------

invariant runpy_extra4.module.self_name:
  description: "runpy.__name__ == 'runpy' — the module's own __name__ attribute"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__eq__
  args: ["runpy"]
  expected: true

# ---------------------------------------------------------------------------
# module __spec__.name — the importlib ModuleSpec records 'runpy'.
# Not covered in any prior runpy spec.
# ---------------------------------------------------------------------------

invariant runpy_extra4.module.spec_name:
  description: "runpy.__spec__.name == 'runpy' — the ModuleSpec records the module name"
  category: module_metadata
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["runpy"]
  expected: true

# ---------------------------------------------------------------------------
# run_module and run_path __doc__ type — both public functions are documented.
# Prior specs check __name__/__module__/__qualname__/type; __doc__ is new.
# Not covered in any prior runpy spec.
# ---------------------------------------------------------------------------

table runpy_extra4.function_docs:
  kind: python_call_eq
  category: functions
  id_prefix: doc_type

  columns: [id, function, args, expected]
  rows:
    - [run_module, run_module.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [run_path,   run_path.__doc__.__class__.__name__.__eq__,   ["str"], true]

# ---------------------------------------------------------------------------
# _run_code and _run_module_as_main __qualname__ — both are top-level functions
# so qualname equals name. runpy_extra2 checked _run_code __name__/__module__/type;
# runpy_extra3 checked _run_module_as_main __name__/__module__/type.
# __qualname__ for either is not covered in any prior runpy spec.
# ---------------------------------------------------------------------------

invariant runpy_extra4.internals._run_code_qualname:
  description: "runpy._run_code.__qualname__ == '_run_code' — top-level function, qualname equals name"
  category: internals
  kind: python_call_eq
  function: _run_code.__qualname__.__eq__
  args: ["_run_code"]
  expected: true

invariant runpy_extra4.internals._run_module_as_main_qualname:
  description: "runpy._run_module_as_main.__qualname__ == '_run_module_as_main' — top-level function"
  category: internals
  kind: python_call_eq
  function: _run_module_as_main.__qualname__.__eq__
  args: ["_run_module_as_main"]
  expected: true

# ---------------------------------------------------------------------------
# run_module result contains '__builtins__' key — Python always injects
# __builtins__ into any exec'd namespace. The base spec checks __name__ and
# __spec__; __builtins__ is a new complementary key check.
# Not covered in any prior runpy spec.
# ---------------------------------------------------------------------------

invariant runpy_extra4.runtime.result_contains_builtins_key:
  description: "runpy.run_module('runpy') result contains '__builtins__' key"
  category: runtime
  kind: python_call_eq
  function: run_module
  args: ["runpy"]
  method: __contains__
  method_args: ["__builtins__"]
  expected: true

# ---------------------------------------------------------------------------
# _run_code.__code__.co_name — code object records the function name.
# Prior specs check _run_code via __name__ attribute; this checks the
# bytecode-level co_name for a different angle of coverage.
# Not covered in any prior runpy spec.
# ---------------------------------------------------------------------------

invariant runpy_extra4.internals._run_code_co_name:
  description: "runpy._run_code.__code__.co_name == '_run_code' — code object function name"
  category: internals
  kind: python_call_eq
  function: _run_code.__code__.co_name.__eq__
  args: ["_run_code"]
  expected: true
