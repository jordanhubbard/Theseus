spec: theseus_fractions
version: ">=3.9"
backend: python_cleanroom(theseus_fractions)
blocks: fractions

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html"
  notes:
    - "Clean-room rational number arithmetic. Do NOT import fractions or decimal."
    - "Fraction(numerator, denominator) stores reduced form using GCD."
    - "Fraction(1, 2) + Fraction(1, 3) == Fraction(5, 6)."
    - "Fraction(2, 4) reduces to Fraction(1, 2) (numerator=1, denominator=2)."
    - "Fraction(1, 2) * Fraction(2, 3) == Fraction(1, 3)."
    - "Export: Fraction class with numerator/denominator properties, +/-/* operators."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_fractions.add:
  description: "Fraction(1,2) + Fraction(1,3) == Fraction(5,6)"
  category: arithmetic
  kind: python_call_eq
  function: fractions_add
  args: []
  expected: true

invariant theseus_fractions.reduce:
  description: "Fraction(2,4) has numerator=1, denominator=2"
  category: reduce
  kind: python_call_eq
  function: fractions_reduce
  args: []
  expected: true

invariant theseus_fractions.multiply:
  description: "Fraction(1,2) * Fraction(2,3) == Fraction(1,3)"
  category: arithmetic
  kind: python_call_eq
  function: fractions_multiply
  args: []
  expected: true
