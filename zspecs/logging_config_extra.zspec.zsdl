spec: logging_config_extra
version: ">=3.2"
backend: python_module(logging.config)

docs: https://docs.python.org/3/library/logging.config.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.config.html — Python logging.config documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/config.py"
  notes:
    - "This spec extends logging_config.zspec.zsdl."
    - "logging_config covers: function __name__ table (dictConfig/fileConfig/listen/stopListening), class __name__ table (BaseConfigurator/DictConfigurator/ConvertingList/ConvertingDict/ConvertingTuple), ConvertingDict/ConvertingList/ConvertingTuple type checks, DictConfigurator MRO."
    - "NEW in this spec: __qualname__ checks for all public functions and classes (top-level qualname equals name), __module__ checks for all public functions and classes (all in 'logging.config')."
    - "dictConfig.__qualname__ == 'dictConfig' — top-level function."
    - "fileConfig.__qualname__ == 'fileConfig' — top-level function."
    - "listen.__qualname__ == 'listen' — top-level function."
    - "stopListening.__qualname__ == 'stopListening' — top-level function."
    - "BaseConfigurator.__qualname__ == 'BaseConfigurator' — top-level class."
    - "DictConfigurator.__qualname__ == 'DictConfigurator' — top-level class."
    - "ConvertingList.__qualname__ == 'ConvertingList' — top-level class."
    - "ConvertingDict.__qualname__ == 'ConvertingDict' — top-level class."
    - "ConvertingTuple.__qualname__ == 'ConvertingTuple' — top-level class."
    - "All __module__ values == 'logging.config' — all public symbols defined in Lib/logging/config.py."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ checks — not covered by logging_config.zspec.zsdl
#
# All four public functions are top-level, so __qualname__ equals __name__.
# This is a distinct test axis from the __name__ checks in the base spec.
# ---------------------------------------------------------------------------

table logging_config_extra.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqn

  columns: [id, function, args, expected]
  rows:
    - [dictconfig,    dictConfig.__qualname__.__eq__,    ["dictConfig"],    true]
    - [fileconfig,    fileConfig.__qualname__.__eq__,    ["fileConfig"],    true]
    - [listen,        listen.__qualname__.__eq__,        ["listen"],        true]
    - [stoplistening, stopListening.__qualname__.__eq__, ["stopListening"], true]

# ---------------------------------------------------------------------------
# Class __qualname__ checks — not covered by logging_config.zspec.zsdl
# ---------------------------------------------------------------------------

table logging_config_extra.class_qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: cqn

  columns: [id, function, args, expected]
  rows:
    - [baseconfigurator, BaseConfigurator.__qualname__.__eq__, ["BaseConfigurator"], true]
    - [dictconfigurator, DictConfigurator.__qualname__.__eq__, ["DictConfigurator"], true]
    - [convertinglist,   ConvertingList.__qualname__.__eq__,   ["ConvertingList"],   true]
    - [convertingdict,   ConvertingDict.__qualname__.__eq__,   ["ConvertingDict"],   true]
    - [convertingtuple,  ConvertingTuple.__qualname__.__eq__,  ["ConvertingTuple"],  true]

# ---------------------------------------------------------------------------
# Function __module__ checks — all logging.config public functions are
# defined in Lib/logging/config.py, so __module__ == 'logging.config'.
# Not covered by logging_config.zspec.zsdl.
# ---------------------------------------------------------------------------

table logging_config_extra.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [dictconfig,    dictConfig.__module__.__eq__,    ["logging.config"], true]
    - [fileconfig,    fileConfig.__module__.__eq__,    ["logging.config"], true]
    - [listen,        listen.__module__.__eq__,        ["logging.config"], true]
    - [stoplistening, stopListening.__module__.__eq__, ["logging.config"], true]

# ---------------------------------------------------------------------------
# Class __module__ checks — all logging.config classes are defined in
# Lib/logging/config.py.  Not covered by logging_config.zspec.zsdl.
# ---------------------------------------------------------------------------

table logging_config_extra.class_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [baseconfigurator, BaseConfigurator.__module__.__eq__, ["logging.config"], true]
    - [dictconfigurator, DictConfigurator.__module__.__eq__, ["logging.config"], true]
    - [convertinglist,   ConvertingList.__module__.__eq__,   ["logging.config"], true]
    - [convertingdict,   ConvertingDict.__module__.__eq__,   ["logging.config"], true]
    - [convertingtuple,  ConvertingTuple.__module__.__eq__,  ["logging.config"], true]
