spec: is_url
version: ">=1.2.4"
backend: node(is-url)

docs: https://www.npmjs.com/package/is-url

provenance:
  derived_from:
    - "is-url README — https://www.npmjs.com/package/is-url"
    - "Test vectors verified with is-url via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-url source"
  notes:
    - "is-url is an npm package. Install: npm install is-url"
    - "The module exports a single function that returns true if the string is a valid URL."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_url.isUrl:
  kind: node_module_call_eq
  function: ~
  category: validate
  id_prefix: isurl

  columns: [id, args, expected]
  rows:
    - [http_url,   ["http://example.com"],        true]
    - [https_path, ["https://foo.bar/path"],       true]
    - [not_url,    ["not-url"],                    false]
    - [bare_word,  ["hello"],                      false]

