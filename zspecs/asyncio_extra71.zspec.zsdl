spec: asyncio_extra71
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec extends asyncio_extra70.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition __name__/__module__/__qualname__, Task/Future __name__/__module__/__qualname__/__class__.__name__, CancelledError/InvalidStateError/TimeoutError identity, QueueEmpty/QueueFull identity, gather/sleep/wait/__name__/__qualname__, class __dict__/__mro__/__all__ metadata, method qualname/name equality and length tables, __loader__/__spec__/__file__/__cached__ class names, __spec__ attributes, code object attribute chains, __defaults__/__kwdefaults__ class names, exception hierarchy and module identity, module spec and synchronization class doc content."
    - "This spec covers (asynciocode71 namespace): wave 237 theme — asyncio class __init__ code object attributes. NEW in extra71: Queue.__init__.__code__.co_name=='__init__'; Queue.__init__.__code__.co_argcount==2 (self + maxsize); Lock.__init__.__code__.co_name=='__init__'; Lock.__init__.__code__.co_argcount==1 (just self); Event.__init__.__code__.co_name=='__init__'; Event.__init__.__code__.co_argcount==1 (just self); Semaphore.__init__.__code__.co_name=='__init__'; Semaphore.__init__.__code__.co_argcount==2 (self + value); Queue.__init__.__code__.co_varnames.__class__.__name__=='tuple'. Task.__init__ is a C extension wrapper_descriptor in Python 3.14 and has no __code__ attribute — excluded."
    - "asyncio.Queue.__init__.__code__.co_name == '__init__'. Queue is a pure Python class in asyncio/queues.py; its __init__ is a Python function; the code object's co_name is the function's simple name '__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__init__.__code__.co_argcount == 2. Queue.__init__ signature is def __init__(self, maxsize=0): — 2 positional parameters; co_argcount is 2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__init__.__code__.co_name == '__init__'. Lock is a pure Python class in asyncio/locks.py; its __init__ is a Python function; co_name is '__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__init__.__code__.co_argcount == 1. Lock.__init__ takes only self; co_argcount is 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__init__.__code__.co_name == '__init__'. Event is a pure Python class in asyncio/locks.py; co_name is '__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__init__.__code__.co_argcount == 1. Event.__init__ takes only self; co_argcount is 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__init__.__code__.co_name == '__init__'. Semaphore is a pure Python class in asyncio/locks.py; co_name is '__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__init__.__code__.co_argcount == 2. Semaphore.__init__ signature is def __init__(self, value=1): — 2 positional parameters; co_argcount is 2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__init__.__code__.co_varnames.__class__.__name__ == 'tuple'. co_varnames is always a tuple in CPython; Queue.__init__.__code__.co_varnames.__class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Queue.__init__ code object checks — extra71
#
# Wave 237 theme: asyncio class __init__ code object attributes.
#
# Queue.__init__.__code__.co_name == '__init__'
# Queue.__init__.__code__.co_argcount == 2
# ---------------------------------------------------------------------------

table asyncio_extra71.Queue_init_code:
  description: "asyncio Queue.__init__ code object attribute checks in asynciocode71 namespace — wave 237 theme: asyncio class __init__ code object attributes; Queue.__init__.__code__.co_name=='__init__' (Queue is a pure Python class in asyncio/queues.py; its __init__ code object stores the function name); Queue.__init__.__code__.co_argcount==2 (self + maxsize); NEW in extra71: first co_name and co_argcount checks for Queue.__init__ in the asynciocode71 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asynciocode71

  columns: [id, function, args, expected, description]
  rows:
    - [queue_init_co_name,     Queue.__init__.__code__.co_name.__eq__,     ["__init__"], true, "Queue.__init__.__code__.co_name == '__init__' — asyncio.Queue is a pure Python class in asyncio/queues.py; its __init__ is a Python function; the code object's co_name is '__init__'; NEW in extra71: first co_name.__eq__('__init__') check for Queue.__init__ in the asynciocode71 namespace; verified with Python 3.14.3"]
    - [queue_init_co_argcount, Queue.__init__.__code__.co_argcount.__eq__, [2],          true, "Queue.__init__.__code__.co_argcount == 2 — asyncio.Queue.__init__ has signature def __init__(self, maxsize=0): with 2 positional parameters (self + maxsize); co_argcount is 2; NEW in extra71: first co_argcount.__eq__(2) check for Queue.__init__ in the asynciocode71 namespace; verified with Python 3.14.3"]

