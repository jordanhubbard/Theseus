spec: re_extra141
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec covers: re.Pattern data descriptor identity for flags, groups, pattern (member_descriptor) and groupindex (getset_descriptor), plus their __qualname__, __name__, and __objclass__.__name__."
    - "re.Pattern.flags is a member_descriptor (not getset_descriptor): type(re.Pattern.flags).__name__ == 'member_descriptor'."
    - "re.Pattern.groups is a member_descriptor: type(re.Pattern.groups).__name__ == 'member_descriptor'."
    - "re.Pattern.pattern is a member_descriptor: type(re.Pattern.pattern).__name__ == 'member_descriptor'."
    - "re.Pattern.groupindex is a getset_descriptor (uses get/set C slot, not a raw struct member): type(re.Pattern.groupindex).__name__ == 'getset_descriptor'."
    - "Pattern.flags.__qualname__ == 'Pattern.flags' (length 13); Pattern.groups.__qualname__ == 'Pattern.groups' (length 14)."
    - "Pattern.pattern.__qualname__ == 'Pattern.pattern' (length 15); Pattern.groupindex.__qualname__ == 'Pattern.groupindex' (length 18)."
    - "All four descriptors have __objclass__.__name__ == 'Pattern' and __objclass__.__module__ == 're'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern data descriptor type identity
# flags, groups, pattern are member_descriptor; groupindex is getset_descriptor.
# All have __objclass__.__name__ == 'Pattern' and __objclass__.__module__ == 're'.
# ---------------------------------------------------------------------------

table re_extra141.Pattern_descriptor_types:
  description: "re.Pattern data descriptor types: flags/groups/pattern are member_descriptor, groupindex is getset_descriptor; all with __objclass__.__name__='Pattern'"
  kind: python_call_eq
  category: data_descriptor
  id_prefix: repat141

  columns: [id, function, args, expected]
  rows:
    - [flags_cls_eq,      Pattern.flags.__class__.__name__.__eq__,      ["member_descriptor"],  true]
    - [groups_cls_eq,     Pattern.groups.__class__.__name__.__eq__,     ["member_descriptor"],  true]
    - [pattern_cls_eq,    Pattern.pattern.__class__.__name__.__eq__,    ["member_descriptor"],  true]
    - [groupidx_cls_eq,   Pattern.groupindex.__class__.__name__.__eq__, ["getset_descriptor"],  true]
    - [flags_obj_eq,      Pattern.flags.__objclass__.__name__.__eq__,   ["Pattern"],            true]
    - [groups_obj_eq,     Pattern.groups.__objclass__.__name__.__eq__,  ["Pattern"],            true]
    - [pattern_obj_eq,    Pattern.pattern.__objclass__.__name__.__eq__, ["Pattern"],            true]
    - [groupidx_obj_eq,   Pattern.groupindex.__objclass__.__name__.__eq__, ["Pattern"],         true]

# ---------------------------------------------------------------------------
# re.Pattern data descriptor __qualname__ values
# flags: 'Pattern.flags' (13), groups: 'Pattern.groups' (14),
# pattern: 'Pattern.pattern' (15), groupindex: 'Pattern.groupindex' (18).
# ---------------------------------------------------------------------------

table re_extra141.Pattern_descriptor_qualnames:
  description: "re.Pattern data descriptor __qualname__ values: flags=13, groups=14, pattern=15, groupindex=18"
  kind: python_call_eq
  category: data_descriptor
  id_prefix: repat141

  columns: [id, function, args, expected]
  rows:
    - [flags_qn_eq,     Pattern.flags.__qualname__.__eq__,      ["Pattern.flags"],      true]
    - [flags_qn_len,    Pattern.flags.__qualname__.__len__,     [],                     13]
    - [groups_qn_eq,    Pattern.groups.__qualname__.__eq__,     ["Pattern.groups"],     true]
    - [groups_qn_len,   Pattern.groups.__qualname__.__len__,    [],                     14]
    - [pattern_qn_eq,   Pattern.pattern.__qualname__.__eq__,    ["Pattern.pattern"],    true]
    - [pattern_qn_len,  Pattern.pattern.__qualname__.__len__,   [],                     15]
    - [groupidx_qn_eq,  Pattern.groupindex.__qualname__.__eq__, ["Pattern.groupindex"], true]
    - [groupidx_qn_len, Pattern.groupindex.__qualname__.__len__, [],                    18]

# ---------------------------------------------------------------------------
# re.Pattern data descriptor __name__ values
# flags: 'flags' (5), groups: 'groups' (6),
# pattern: 'pattern' (7), groupindex: 'groupindex' (10).
# ---------------------------------------------------------------------------

table re_extra141.Pattern_descriptor_names:
  description: "re.Pattern data descriptor __name__ values: flags='flags' (5), groups='groups' (6), pattern='pattern' (7), groupindex='groupindex' (10)"
  kind: python_call_eq
  category: data_descriptor
  id_prefix: repat141

  columns: [id, function, args, expected]
  rows:
    - [flags_name_eq,     Pattern.flags.__name__.__eq__,      ["flags"],      true]
    - [flags_name_len,    Pattern.flags.__name__.__len__,     [],             5]
    - [groups_name_eq,    Pattern.groups.__name__.__eq__,     ["groups"],     true]
    - [groups_name_len,   Pattern.groups.__name__.__len__,    [],             6]
    - [pattern_name_eq,   Pattern.pattern.__name__.__eq__,    ["pattern"],    true]
    - [pattern_name_len,  Pattern.pattern.__name__.__len__,   [],             7]
    - [groupidx_name_eq,  Pattern.groupindex.__name__.__eq__, ["groupindex"], true]
    - [groupidx_name_len, Pattern.groupindex.__name__.__len__, [],            10]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra141.Pattern.flags_is_member_descriptor:
  description: "re.Pattern.flags.__class__.__name__ == 'member_descriptor' (not 'getset_descriptor'; flags is stored as a raw struct member in the C pattern object, accessed via the member_descriptor protocol)"
  category: data_descriptor
  kind: python_call_eq
  function: Pattern.flags.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant re_extra141.Pattern.groupindex_is_getset_descriptor:
  description: "re.Pattern.groupindex.__class__.__name__ == 'getset_descriptor' (unlike flags/groups/pattern which are member_descriptor; groupindex uses a C get/set slot because it returns a dict built on demand, not a raw struct member)"
  category: data_descriptor
  kind: python_call_eq
  function: Pattern.groupindex.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant re_extra141.Pattern.flags_qualname_len_13:
  description: "re.Pattern.flags.__qualname__.__len__() == 13 ('Pattern.flags' has 13 characters; shortest of the four Pattern data descriptor qualnames)"
  category: data_descriptor
  kind: python_call_eq
  function: Pattern.flags.__qualname__.__len__
  args: []
  expected: 13

invariant re_extra141.Pattern.groupindex_qualname_len_18:
  description: "re.Pattern.groupindex.__qualname__.__len__() == 18 ('Pattern.groupindex' has 18 characters; the longest of the four Pattern data descriptor qualnames)"
  category: data_descriptor
  kind: python_call_eq
  function: Pattern.groupindex.__qualname__.__len__
  args: []
  expected: 18

invariant re_extra141.Pattern.pattern_objclass_module_re:
  description: "re.Pattern.pattern.__objclass__.__module__ == 're' (the owning class Pattern lives in the re module, even though the C implementation is in _sre; the re module exposes Pattern with module 're')"
  category: data_descriptor
  kind: python_call_eq
  function: Pattern.pattern.__objclass__.__module__.__eq__
  args: ["re"]
  expected: true
