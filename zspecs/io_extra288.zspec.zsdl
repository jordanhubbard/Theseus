spec: io_extra288
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "io_extra287 covers io.__all__ type, length, and membership."
    - "This spec focuses on io.StringIO write/read roundtrip behavior."
    - "StringIO().write('hello') returns 5 — write() returns the number of characters written."
    - "StringIO('hello').getvalue() returns 'hello' — StringIO can be initialized with a string."
    - "StringIO('hello world').getvalue() returns 'hello world' — getvalue() returns the full buffer regardless of cursor position."
    - "StringIO().write('') returns 0 — writing an empty string returns zero."
    - "StringIO('hello').tell() returns 0 — the cursor starts at position 0 even when initialized with content."
    - "StringIO('hello').read() returns 'hello' — read() from position 0 returns all content."
    - "StringIO().readable() returns True — StringIO is always readable."
    - "StringIO().writable() returns True — StringIO is always writable."
    - "StringIO().seekable() returns True — StringIO is always seekable."
    - "StringIO.__name__ == 'StringIO' — the class is named 'StringIO'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.StringIO.write() — returns character count
#
# StringIO.write(s) appends s to the buffer and returns len(s).
# This matches the contract for all Python writable text streams.
# StringIO().write('hello') -> 5
# StringIO().write('hello world') -> 11
# StringIO().write('abc') -> 3
# StringIO().write('') -> 0
# ---------------------------------------------------------------------------

table io_extra288.StringIO_write_return_values:
  description: "io.StringIO.write() returns the number of characters written"
  kind: python_call_eq
  category: write_return
  id_prefix: siowrite288

  columns: [id, function, args, expected, description]
  rows:
    - [write_hello,       "StringIO().write",        ["hello"],       5,  "StringIO().write('hello') == 5 — five characters written"]
    - [write_hello_world, "StringIO().write",        ["hello world"], 11, "StringIO().write('hello world') == 11 — eleven characters written"]
    - [write_abc,         "StringIO().write",        ["abc"],         3,  "StringIO().write('abc') == 3 — three characters written"]
    - [write_empty,       "StringIO().write",        [""],            0,  "StringIO().write('') == 0 — zero characters written for empty string"]
    - [write_single,      "StringIO().write",        ["x"],           1,  "StringIO().write('x') == 1 — single character returns 1"]

# ---------------------------------------------------------------------------
# io.StringIO with initial value — getvalue() and read()
#
# StringIO(initial_value) initializes the buffer and places the cursor at
# position 0. getvalue() always returns the full buffer contents; read()
# returns content from the current cursor position to the end.
# StringIO('hello').getvalue() -> 'hello'
# StringIO('hello').read() -> 'hello'
# StringIO('hello world').getvalue() -> 'hello world'
# ---------------------------------------------------------------------------

table io_extra288.StringIO_init_and_getvalue:
  description: "io.StringIO initialized with a string: getvalue() returns the full buffer; read() returns from cursor position"
  kind: python_call_eq
  category: init_and_read
  id_prefix: sioinit288

  columns: [id, function, args, expected, description]
  rows:
    - [getvalue_hello,       "StringIO('hello').getvalue",       [], "hello",       "StringIO('hello').getvalue() == 'hello'"]
    - [getvalue_hello_world, "StringIO('hello world').getvalue", [], "hello world", "StringIO('hello world').getvalue() == 'hello world'"]
    - [getvalue_empty,       "StringIO('').getvalue",            [], "",             "StringIO('').getvalue() == '' — empty initial value"]
    - [read_hello,           "StringIO('hello').read",           [], "hello",       "StringIO('hello').read() == 'hello' — cursor starts at 0"]
    - [tell_zero,            "StringIO('hello').tell",           [], 0,             "StringIO('hello').tell() == 0 — cursor at start even when initialized"]
    - [tell_fresh,           "StringIO().tell",                  [], 0,             "StringIO().tell() == 0 — fresh StringIO cursor is at position 0"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra288.StringIO.write_hello_returns_5:
  description: "StringIO().write('hello') == 5 — write() returns the number of characters written; 'hello' has 5 characters"
  category: write_return
  kind: python_call_eq
  function: "StringIO().write"
  args: ["hello"]
  expected: 5

invariant io_extra288.StringIO.write_empty_returns_0:
  description: "StringIO().write('') == 0 — writing an empty string returns 0; no characters are added to the buffer"
  category: write_return
  kind: python_call_eq
  function: "StringIO().write"
  args: [""]
  expected: 0

invariant io_extra288.StringIO.getvalue_hello:
  description: "StringIO('hello').getvalue() == 'hello' — getvalue() returns the full buffer contents, not just the unread portion"
  category: init_and_read
  kind: python_call_eq
  function: "StringIO('hello').getvalue"
  args: []
  expected: "hello"

invariant io_extra288.StringIO.tell_is_0_after_init:
  description: "StringIO('hello').tell() == 0 — when StringIO is initialized with a string, the stream cursor is at position 0, not at the end"
  category: init_and_read
  kind: python_call_eq
  function: "StringIO('hello').tell"
  args: []
  expected: 0

invariant io_extra288.StringIO.readable_true:
  description: "StringIO().readable() == True — StringIO is always readable regardless of how it was created"
  category: stream_flags
  kind: python_call_eq
  function: "StringIO().readable"
  args: []
  expected: true

invariant io_extra288.StringIO.writable_true:
  description: "StringIO().writable() == True — StringIO is always writable; it is not opened in read-only mode"
  category: stream_flags
  kind: python_call_eq
  function: "StringIO().writable"
  args: []
  expected: true

invariant io_extra288.StringIO.seekable_true:
  description: "StringIO().seekable() == True — StringIO supports arbitrary seek operations unlike, e.g., socket streams"
  category: stream_flags
  kind: python_call_eq
  function: "StringIO().seekable"
  args: []
  expected: true

invariant io_extra288.StringIO.class_name:
  description: "io.StringIO.__name__ == 'StringIO' — the class name is exactly 'StringIO'"
  category: class_metadata
  kind: python_call_eq
  function: StringIO.__name__.__eq__
  args: ["StringIO"]
  expected: true
