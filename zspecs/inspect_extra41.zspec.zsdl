spec: inspect_extra41
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra40.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/iscode/isframe/istraceback __name__/__qualname__.__len__(); iscoroutinefunction/isgeneratorfunction/isasyncgenfunction __name__/__qualname__.__len__(); getmembers/getfile/getsource/getsourcelines/getmodule/signature/stack/currentframe/getfullargspec __qualname__.__len__(); Parameter/__mro__.__len__()==2; Signature/__mro__.__len__()==2; BoundArguments/__mro__.__len__()==2; Parameter.empty/kind constants; inspect.__all__.__len__()==107; CO_OPTIMIZED==1; cleandoc/formatannotation/getattr_static/classify_class_attrs __name__ lengths; Signature/Parameter/BoundArguments method qualnames; getmembers/__module__.__len__(7); parameter kind integer values (0-4); Parameter.__name__/'Parameter'; Parameter.__module__/'inspect'; Signature.__name__/'Signature'; Signature.__module__/'inspect'; isfunction/__name__=='isfunction'; isfunction/__module__=='inspect'; isbuiltin/__name__=='isbuiltin'; isbuiltin/__module__=='inspect'; isclass/__name__=='isclass'; isclass/__module__=='inspect'; ismodule/__name__=='ismodule'; ismodule/__module__=='inspect'; ismethod/__name__=='ismethod'; ismethod/__module__=='inspect'; getcallargs/__name__=='getcallargs'; getcallargs/__module__=='inspect'; getfile/__name__=='getfile'; getfile/__module__=='inspect'."
    - "This spec covers: inspect.getdoc.__name__ == 'getdoc'; inspect.getdoc.__module__ == 'inspect'; inspect.getsource.__name__ == 'getsource'; inspect.getsource.__module__ == 'inspect'; inspect.getmembers.__name__ == 'getmembers'; inspect.getmembers.__module__ == 'inspect'; inspect.signature.__name__ == 'signature'; inspect.signature.__module__ == 'inspect'; inspect.cleandoc.__name__ == 'cleandoc'; inspect.cleandoc.__module__ == 'inspect'."
    - "Key findings: All five inspect utility functions covered here have __module__ == 'inspect' (7 chars) — they are all pure-Python functions defined in Lib/inspect.py. The __name__ values: 'getdoc' (6 chars), 'getsource' (9 chars), 'getmembers' (10 chars), 'signature' (9 chars), 'cleandoc' (8 chars). Notable length coincidences: getsource.__name__ (9 chars) == signature.__name__ (9 chars); all five __module__ values are identical 7-char 'inspect'. Prior specs recorded __name__.__len__() for cleandoc and __qualname__.__len__() for getmembers/getsource/signature, but not the string equality invariants for __name__ or the exact __module__ string. No prior inspect spec records these equality invariants in the extra41 namespace."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.getdoc and inspect.getsource identity metadata — extra41 namespace
#
# inspect.getdoc.__name__ is 'getdoc' (6 chars) and inspect.getdoc.__module__
# is 'inspect' (7 chars). inspect.getsource.__name__ is 'getsource' (9 chars)
# and inspect.getsource.__module__ is 'inspect' (7 chars). Both are pure-Python
# functions defined in Lib/inspect.py. Prior specs recorded __name__.__len__()
# for neither; __qualname__.__len__() for getsource but not getdoc. The string
# equality invariants for __name__ and __module__ are new to the extra41 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra41.getdoc_name:
  description: "inspect.getdoc.__name__ == 'getdoc' — pure-Python utility; 6-char name; retrieves cleaned docstring for an object; same length as getfile.__name__ (7) minus 1"
  category: identity
  kind: python_call_eq
  function: getdoc.__name__.__eq__
  args: ["getdoc"]
  expected: true

invariant inspect_extra41.getdoc_module:
  description: "inspect.getdoc.__module__ == 'inspect' — pure-Python function defined in Lib/inspect.py; 7-char module name"
  category: module_metadata
  kind: python_call_eq
  function: getdoc.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra41.getsource_name:
  description: "inspect.getsource.__name__ == 'getsource' — pure-Python utility; 9-char name; same length as signature.__name__; returns source code text for an object"
  category: identity
  kind: python_call_eq
  function: getsource.__name__.__eq__
  args: ["getsource"]
  expected: true

invariant inspect_extra41.getsource_module:
  description: "inspect.getsource.__module__ == 'inspect' — pure-Python function defined in Lib/inspect.py; 7-char module name; same as getdoc.__module__"
  category: module_metadata
  kind: python_call_eq
  function: getsource.__module__.__eq__
  args: ["inspect"]
  expected: true

# ---------------------------------------------------------------------------
# inspect.getmembers and inspect.signature identity metadata — extra41 namespace
#
# inspect.getmembers.__name__ is 'getmembers' (10 chars) and inspect.getmembers.
# __module__ is 'inspect' (7 chars). inspect.signature.__name__ is 'signature'
# (9 chars) and inspect.signature.__module__ is 'inspect' (7 chars). Both are
# pure-Python functions in Lib/inspect.py. Prior specs recorded __qualname__.__len__
# () for both and __module__.__len__()==7 for getmembers, but not the string equality
# invariants for __name__ or the exact __module__ string. These four equality
# invariants are new to the extra41 namespace.
# ---------------------------------------------------------------------------

table inspect_extra41.getmembers_signature_names:
  description: "inspect.getmembers and inspect.signature __name__ and __module__ string equality — both pure-Python functions in Lib/inspect.py"
  kind: python_call_eq
  category: identity
  id_prefix: gmsigname41

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_name,
       getmembers.__name__.__eq__,
       ["getmembers"],
       true,
       "inspect.getmembers.__name__ == 'getmembers' — pure-Python utility; 10-char name; returns all attributes of an object as (name, value) pairs"]
    - [getmembers_module,
       getmembers.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getmembers.__module__ == 'inspect' — pure-Python function in Lib/inspect.py; 7-char module name"]
    - [signature_name,
       signature.__name__.__eq__,
       ["signature"],
       true,
       "inspect.signature.__name__ == 'signature' — pure-Python utility; 9-char name; same length as getsource.__name__; returns Signature for a callable"]
    - [signature_module,
       signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.signature.__module__ == 'inspect' — pure-Python function in Lib/inspect.py; 7-char module name; same as getmembers.__module__"]

# ---------------------------------------------------------------------------
# inspect.cleandoc identity metadata — extra41 namespace
#
# inspect.cleandoc.__name__ is 'cleandoc' (8 chars) and inspect.cleandoc.
# __module__ is 'inspect' (7 chars). cleandoc is a pure-Python utility defined
# in Lib/inspect.py that trims leading whitespace from docstrings. Prior specs
# recorded cleandoc.__name__.__len__()==8 but not the string equality invariants
# for __name__ or __module__. These two equality invariants are new to the
# extra41 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra41.cleandoc_name:
  description: "inspect.cleandoc.__name__ == 'cleandoc' — pure-Python utility; 8-char name; trims leading whitespace from docstrings; name length between getdoc(6) and getsource(9)"
  category: identity
  kind: python_call_eq
  function: cleandoc.__name__.__eq__
  args: ["cleandoc"]
  expected: true

invariant inspect_extra41.cleandoc_module:
  description: "inspect.cleandoc.__module__ == 'inspect' — pure-Python function defined in Lib/inspect.py; 7-char module name; same as all other inspect functions in this spec"
  category: module_metadata
  kind: python_call_eq
  function: cleandoc.__module__.__eq__
  args: ["inspect"]
  expected: true
