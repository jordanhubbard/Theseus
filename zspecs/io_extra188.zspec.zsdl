spec: io_extra188
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/io.py"
  notes:
    - "io.FileIO.__name__=='FileIO' (len=6); __module__=='_io' (C extension); __qualname__=='FileIO'."
    - "io.FileIO.__bases__[0].__name__=='_RawIOBase' — the C-level internal base class name includes underscore prefix."
    - "io.DEFAULT_BUFFER_SIZE==131072 on Python 3.14.3/macOS Darwin 25.4.0; the documented default of 8192 is overridden by platform/build; actual value is 131072 (128 KiB)."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__name__=='int' — the constant is a plain Python int."
    - "io.RawIOBase.__name__=='RawIOBase' (len=9); io.BufferedIOBase.__name__=='BufferedIOBase' (len=14)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.FileIO class identity
# __name__=='FileIO' (len=6); __module__=='_io'; __qualname__=='FileIO'
# ---------------------------------------------------------------------------

table io_extra188.fileio_class_identity:
  description: "io.FileIO class identity: __name__=='FileIO' (len=6); __module__=='_io' (C extension); __qualname__=='FileIO'; len('FileIO')==6: F(1)i(2)l(3)e(4)I(5)O(6)"
  kind: python_call_eq
  category: identity
  id_prefix: iofileio188

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_name,        FileIO.__name__.__eq__,      ["FileIO"],  true,  "io.FileIO.__name__ == 'FileIO' — the raw file I/O class has the expected name; len('FileIO')==6; confirmed Python 3.14.3 macOS"]
    - [fileio_name_len,    FileIO.__name__.__len__,     [],          6,     "io.FileIO.__name__.__len__() == 6 — 'FileIO' has 6 characters: F(1)i(2)l(3)e(4)I(5)O(6); confirmed Python 3.14.3 macOS"]
    - [fileio_module,      FileIO.__module__.__eq__,    ["_io"],     true,  "io.FileIO.__module__ == '_io' — FileIO is implemented in the C extension module _io; confirmed Python 3.14.3 macOS"]
    - [fileio_qualname,    FileIO.__qualname__.__eq__,  ["FileIO"],  true,  "io.FileIO.__qualname__ == 'FileIO' — top-level class so __qualname__ matches __name__; confirmed Python 3.14.3 macOS"]
    - [fileio_name_ne,     FileIO.__name__.__eq__,      ["io"],      false, "io.FileIO.__name__.__eq__('io') == False — the class name is 'FileIO', not the module name 'io'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.FileIO base class and io.DEFAULT_BUFFER_SIZE
# __bases__[0].__name__=='_RawIOBase'; DEFAULT_BUFFER_SIZE==131072 (int)
# ---------------------------------------------------------------------------

table io_extra188.fileio_base_and_buffer_size:
  description: "io.FileIO base class and DEFAULT_BUFFER_SIZE: __bases__[0].__name__=='_RawIOBase' (C-level internal); DEFAULT_BUFFER_SIZE==131072 (128 KiB on macOS Darwin 25.4.0); DEFAULT_BUFFER_SIZE.__class__.__name__=='int'"
  kind: python_call_eq
  category: identity
  id_prefix: iofileio188

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_base_name,    "FileIO.__bases__[0].__name__.__eq__",           ["_RawIOBase"], true,  "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — the C-level internal base class; underscore prefix distinguishes it from the public io.RawIOBase; confirmed Python 3.14.3 macOS"]
    - [buf_size_val,        DEFAULT_BUFFER_SIZE.__eq__,                      [131072],       true,  "io.DEFAULT_BUFFER_SIZE.__eq__(131072) == True — actual buffer size on Python 3.14.3/macOS Darwin 25.4.0 is 131072 (128 KiB); confirmed Python 3.14.3 macOS"]
    - [buf_size_cls,        DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__,   ["int"],        true,  "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — the DEFAULT_BUFFER_SIZE constant is a plain Python int; confirmed Python 3.14.3 macOS"]
    - [buf_size_ne_zero,    DEFAULT_BUFFER_SIZE.__eq__,                      [0],            false, "io.DEFAULT_BUFFER_SIZE.__eq__(0) == False — the buffer size is 131072, not 0; confirmed Python 3.14.3 macOS"]
    - [fileio_base_ne_raw,  "FileIO.__bases__[0].__name__.__eq__",           ["RawIOBase"],  false, "io.FileIO.__bases__[0].__name__.__eq__('RawIOBase') == False — the C-level base is '_RawIOBase', not 'RawIOBase' (public ABC); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io.RawIOBase and io.BufferedIOBase class identity
# RawIOBase.__name__=='RawIOBase' (len=9); BufferedIOBase.__name__=='BufferedIOBase' (len=14)
# ---------------------------------------------------------------------------

table io_extra188.abstract_base_class_identity:
  description: "io.RawIOBase and io.BufferedIOBase abstract base class identity: RawIOBase.__name__=='RawIOBase' (len=9); BufferedIOBase.__name__=='BufferedIOBase' (len=14)"
  kind: python_call_eq
  category: identity
  id_prefix: iofileio188

  columns: [id, function, args, expected, description]
  rows:
    - [rawio_name,       RawIOBase.__name__.__eq__,         ["RawIOBase"],       true,  "io.RawIOBase.__name__ == 'RawIOBase' — the public raw I/O abstract base class name; confirmed Python 3.14.3 macOS"]
    - [rawio_name_len,   RawIOBase.__name__.__len__,        [],                  9,     "io.RawIOBase.__name__.__len__() == 9 — 'RawIOBase' has 9 characters: R(1)a(2)w(3)I(4)O(5)B(6)a(7)s(8)e(9); confirmed Python 3.14.3 macOS"]
    - [bufio_name,       BufferedIOBase.__name__.__eq__,    ["BufferedIOBase"],  true,  "io.BufferedIOBase.__name__ == 'BufferedIOBase' — the public buffered I/O abstract base class name; confirmed Python 3.14.3 macOS"]
    - [bufio_name_len,   BufferedIOBase.__name__.__len__,   [],                  14,    "io.BufferedIOBase.__name__.__len__() == 14 — 'BufferedIOBase' has 14 characters: B(1)u(2)f(3)f(4)e(5)r(6)e(7)d(8)I(9)O(10)B(11)a(12)s(13)e(14); confirmed Python 3.14.3 macOS"]
    - [rawio_ne_bufio,   RawIOBase.__name__.__eq__,         ["BufferedIOBase"],  false, "io.RawIOBase.__name__.__eq__('BufferedIOBase') == False — RawIOBase and BufferedIOBase are distinct ABC classes; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra188.fileio_name_is_fileio:
  description: "io.FileIO.__name__ == 'FileIO' — the raw file I/O class has name 'FileIO'; len('FileIO')==6: F(1)i(2)l(3)e(4)I(5)O(6); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: FileIO.__name__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra188.fileio_name_len_is_6:
  description: "io.FileIO.__name__.__len__() == 6 — 'FileIO' has 6 characters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: FileIO.__name__.__len__
  args: []
  expected: 6

invariant io_extra188.fileio_module_is_underscore_io:
  description: "io.FileIO.__module__ == '_io' — FileIO is implemented in the C extension _io, not the pure Python io module; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: FileIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra188.fileio_qualname_is_fileio:
  description: "io.FileIO.__qualname__ == 'FileIO' — top-level class so __qualname__ matches __name__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: FileIO.__qualname__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra188.fileio_base_name_is_rawiobase:
  description: "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — the C-level internal base; underscore prefix distinguishes from public io.RawIOBase; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "FileIO.__bases__[0].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

invariant io_extra188.default_buffer_size_eq_131072:
  description: "io.DEFAULT_BUFFER_SIZE.__eq__(131072) == True — actual value on Python 3.14.3/macOS Darwin 25.4.0 is 131072 (128 KiB); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true

invariant io_extra188.default_buffer_size_class_is_int:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — DEFAULT_BUFFER_SIZE is a plain Python int; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra188.rawiobase_name_is_rawiobase:
  description: "io.RawIOBase.__name__ == 'RawIOBase' — the public raw I/O abstract base class; len('RawIOBase')==9; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: RawIOBase.__name__.__eq__
  args: ["RawIOBase"]
  expected: true

invariant io_extra188.rawiobase_name_len_is_9:
  description: "io.RawIOBase.__name__.__len__() == 9 — 'RawIOBase' has 9 characters: R(1)a(2)w(3)I(4)O(5)B(6)a(7)s(8)e(9); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: RawIOBase.__name__.__len__
  args: []
  expected: 9

invariant io_extra188.bufferediobase_name_is_bufferediobase:
  description: "io.BufferedIOBase.__name__ == 'BufferedIOBase' — the public buffered I/O abstract base class; len('BufferedIOBase')==14; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BufferedIOBase.__name__.__eq__
  args: ["BufferedIOBase"]
  expected: true

invariant io_extra188.bufferediobase_name_len_is_14:
  description: "io.BufferedIOBase.__name__.__len__() == 14 — 'BufferedIOBase' has 14 characters: B(1)u(2)f(3)f(4)e(5)r(6)e(7)d(8)I(9)O(10)B(11)a(12)s(13)e(14); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BufferedIOBase.__name__.__len__
  args: []
  expected: 14
