spec: re_extra961
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module class and exception documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.error, re.Pattern, re.Match, re.RegexFlag class identity and module attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra961.exception_identity:
  description: "re.error exception class structural identity"
  kind: python_call_eq
  category: exception_identity
  id_prefix: re961e
  columns: [id, function, args, expected]
  rows:
    - [re961e001, re.error.__name__.__eq__,                    ["error"],        true]
    - [re961e002, re.error.__module__.__eq__,                  ["re"],           true]
    - [re961e003, re.error.__qualname__.__eq__,                ["error"],        true]
    - [re961e004, re.error.__bases__.__class__.__name__.__eq__, ["tuple"],       true]
    - [re961e005, re.error.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [re961e006, re.error.__class__.__name__.__eq__,          ["type"],         true]

table re_extra961.compiled_type_identity:
  description: "re.Pattern and re.Match class name and module identity"
  kind: python_call_eq
  category: compiled_type_identity
  id_prefix: re961t
  columns: [id, function, args, expected]
  rows:
    - [re961t001, re.Pattern.__name__.__eq__,   ["Pattern"], true]
    - [re961t002, re.Pattern.__module__.__eq__, ["re"],      true]
    - [re961t003, re.Match.__name__.__eq__,     ["Match"],   true]
    - [re961t004, re.Match.__module__.__eq__,   ["re"],      true]
    - [re961t005, re.Pattern.__class__.__name__.__eq__, ["type"], true]
    - [re961t006, re.Match.__class__.__name__.__eq__,   ["type"], true]

table re_extra961.regexflag_identity:
  description: "re.RegexFlag enum class identity and module"
  kind: python_call_eq
  category: regexflag_identity
  id_prefix: re961f
  columns: [id, function, args, expected]
  rows:
    - [re961f001, re.RegexFlag.__name__.__eq__,   ["RegexFlag"], true]
    - [re961f002, re.RegexFlag.__module__.__eq__, ["re"],        true]
    - [re961f003, re.RegexFlag.__qualname__.__eq__, ["RegexFlag"], true]
    - [re961f004, re.__name__.__eq__,             ["re"],        true]
    - [re961f005, re.__spec__.name.__eq__,        ["re"],        true]
