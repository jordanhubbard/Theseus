spec: hashlib_extra112
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra111.zspec.zsdl — covers pbkdf2_hmac/scrypt class names and qualnames / md5/sha256/sha3_256 class name homogeneity / sha3_256 module vs blake2b module / blake2b is a type not a function (table + invariants)."
    - "hashlib_extra110.zspec.zsdl — covers HASH class-level method descriptor qualnames for digest/copy / method_descriptor type names for update/digest/copy at class level / sha256 instance-bound method qualnames (digest/copy/hexdigest) / hexdigest descriptor type name and length confirmations (table + invariants)."
    - "hashlib_extra109.zspec.zsdl — covers algorithms_guaranteed and algorithms_available class names and sizes / subset relationship / hashlib.new code attributes (co_name, co_argcount, type, module) / blake2s membership (table + invariants)."
    - "hashlib_extra108.zspec.zsdl — covers sha224/sha384/sha3_256/sha3_512 digest_size and block_size / blake2b/blake2s digest_size and block_size and type names / sha3_256/sha3_512 HASH type identity / HASH.update and HASH.hexdigest qualname string equality via sha256().__class__ (table + invariants)."
    - "hashlib_extra107.zspec.zsdl — covers HASH type identity (__name__=='HASH', __module__=='_hashlib', __mro__.__len__()==2, __bases__[0].__name__=='object') / HASH method qualname lengths / md5/sha1/sha256/sha512 digest_size and block_size (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s class/module/qualname / algorithms_guaranteed.__len__()==14 (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra111; it does NOT duplicate invariants present in those files."
    - "Wave 271 theme: md5/sha1/sha256/sha512 function __qualname__ string equality / sha224/sha384 qualname equality / sha3_256/sha3_512 qualname equality / blake2b/blake2s qualname equality — all qualnames verified directly for the first time as a grouped equality table under hashhkdf112."
    - "hashlib.md5.__qualname__ == 'openssl_md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__qualname__ == 'openssl_sha1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__qualname__ == 'openssl_sha256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__qualname__ == 'openssl_sha512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__qualname__ == 'openssl_sha224'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__qualname__ == 'openssl_sha384'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__qualname__ == 'openssl_sha3_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__qualname__ == 'openssl_sha3_512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__qualname__ == 'blake2b'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__qualname__ == 'blake2s'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.md5.__qualname__) == 11 ('openssl_md5': 'openssl_'=8 + 'md5'=3). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.sha256.__qualname__) == 14 ('openssl_sha256': 'openssl_'=8 + 'sha256'=6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.sha3_256.__qualname__) == 16 ('openssl_sha3_256': 'openssl_'=8 + 'sha3_256'=8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.blake2b.__qualname__) == 7 ('blake2b': 7 chars; no 'openssl_' prefix — from _blake2, not _hashlib). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All OpenSSL-backed hash functions (md5, sha1, sha224, sha256, sha384, sha512, sha3_256, sha3_512) have qualnames prefixed with 'openssl_', reflecting their implementation via OpenSSL. blake2b and blake2s use the _blake2 C extension and have plain qualnames ('blake2b', 'blake2s') without the 'openssl_' prefix."
    - "Note: hashlib_extra111 anchors sha3_256.__qualname__.__eq__('openssl_sha3_256') and blake2b.__qualname__.__eq__('blake2b') in a table; this spec anchors the full set of 10 qualname equalities across md5/sha1/sha224/sha256/sha384/sha512/sha3_256/sha3_512/blake2b/blake2s as dedicated grouped tables."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5.__qualname__.__eq__('openssl_md5')
# hashlib.sha1.__qualname__.__eq__('openssl_sha1')
# hashlib.sha256.__qualname__.__eq__('openssl_sha256')
# hashlib.sha512.__qualname__.__eq__('openssl_sha512')
# len(hashlib.md5.__qualname__)==11
#
# Wave 271 theme: md5/sha1/sha256/sha512 function __qualname__ string equality.
#
# md5, sha1, sha256, and sha512 are builtin_function_or_method objects from
# _hashlib. Their qualnames all carry the 'openssl_' prefix, reflecting OpenSSL
# as the underlying implementation. md5.__qualname__ is 'openssl_md5' (11 chars),
# sha1.__qualname__ is 'openssl_sha1' (12 chars), sha256.__qualname__ is
# 'openssl_sha256' (14 chars), sha512.__qualname__ is 'openssl_sha512' (14 chars).
# hashlib_extra111 anchors the blake2b/sha3_256 qualname equalities; this spec
# adds the core SHA-1/2 family as a new grouped table under hashhkdf112.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra112.md5_sha1_sha256_sha512_qualname_equality:
  description: "md5.__qualname__.__eq__('openssl_md5')==True / sha1.__qualname__.__eq__('openssl_sha1')==True / sha256.__qualname__.__eq__('openssl_sha256')==True / sha512.__qualname__.__eq__('openssl_sha512')==True / md5.__qualname__.__len__()==11 — all four carry the 'openssl_' prefix (OpenSSL-backed via _hashlib); md5=11 chars / sha1=12 chars / sha256=14 chars / sha512=14 chars; extra111 anchors sha3_256/blake2b qualnames; this spec anchors the SHA-1/2 core family; first hashhkdf112 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashhkdf112

  columns: [id, function, args, expected, description]
  rows:
    - [md5_qualname_eq,    "md5.__qualname__.__eq__",    ["openssl_md5"],    true, "md5.__qualname__ is 'openssl_md5' (11 chars; 'openssl_' prefix reflects OpenSSL SHA-1/2 implementation in _hashlib)"]
    - [sha1_qualname_eq,   "sha1.__qualname__.__eq__",   ["openssl_sha1"],   true, "sha1.__qualname__ is 'openssl_sha1' (12 chars; OpenSSL-backed via _hashlib; SHA-1 is 20-byte digest)"]
    - [sha256_qualname_eq, "sha256.__qualname__.__eq__", ["openssl_sha256"], true, "sha256.__qualname__ is 'openssl_sha256' (14 chars; OpenSSL-backed via _hashlib; SHA-256 is 32-byte digest)"]
    - [sha512_qualname_eq, "sha512.__qualname__.__eq__", ["openssl_sha512"], true, "sha512.__qualname__ is 'openssl_sha512' (14 chars; OpenSSL-backed via _hashlib; SHA-512 is 64-byte digest)"]
    - [md5_qualname_len,   "md5.__qualname__.__len__",   [],                 11,   "md5.__qualname__.__len__() is 11 ('openssl_md5': 'openssl_'=8 + 'md5'=3)"]

# ---------------------------------------------------------------------------
# hashlib.sha224.__qualname__.__eq__('openssl_sha224')
# hashlib.sha384.__qualname__.__eq__('openssl_sha384')
# hashlib.sha3_512.__qualname__.__eq__('openssl_sha3_512')
# hashlib.blake2s.__qualname__.__eq__('blake2s')
# len(hashlib.sha3_512.__qualname__)==16
#
# Wave 271 theme: sha224/sha384 qualname equality and sha3_512/blake2s qualnames.
#
# sha224.__qualname__ is 'openssl_sha224' (14 chars), sha384.__qualname__ is
# 'openssl_sha384' (14 chars). sha3_512.__qualname__ is 'openssl_sha3_512'
# (16 chars — same as sha3_256). blake2s.__qualname__ is 'blake2s' (7 chars —
# same as blake2b). sha224/sha384 are truncated variants of sha256/sha512
# respectively; their qualnames share the 'openssl_sha' prefix and have the
# same length (14 chars) as sha256/sha512. No prior hashlib spec anchors
# sha224/sha384 qualnames as equality checks in a grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra112.sha224_sha384_sha3_512_blake2s_qualname_equality:
  description: "sha224.__qualname__.__eq__('openssl_sha224')==True / sha384.__qualname__.__eq__('openssl_sha384')==True / sha3_512.__qualname__.__eq__('openssl_sha3_512')==True / blake2s.__qualname__.__eq__('blake2s')==True / sha3_512.__qualname__.__len__()==16 — sha224/sha384 are truncated variants (both 14 chars; same length as sha256/sha512); sha3_512 is 16 chars (same as sha3_256); blake2s is 7 chars (same as blake2b; no 'openssl_' prefix); no prior spec anchors sha224/sha384 qualnames; first hashhkdf112 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashhkdf112

  columns: [id, function, args, expected, description]
  rows:
    - [sha224_qualname_eq,   "sha224.__qualname__.__eq__",   ["openssl_sha224"],   true, "sha224.__qualname__ is 'openssl_sha224' (14 chars; truncated SHA-256 variant from OpenSSL via _hashlib)"]
    - [sha384_qualname_eq,   "sha384.__qualname__.__eq__",   ["openssl_sha384"],   true, "sha384.__qualname__ is 'openssl_sha384' (14 chars; truncated SHA-512 variant from OpenSSL via _hashlib)"]
    - [sha3_512_qualname_eq, "sha3_512.__qualname__.__eq__", ["openssl_sha3_512"], true, "sha3_512.__qualname__ is 'openssl_sha3_512' (16 chars; same length as sha3_256; OpenSSL SHA-3 family)"]
    - [blake2s_qualname_eq,  "blake2s.__qualname__.__eq__",  ["blake2s"],          true, "blake2s.__qualname__ is 'blake2s' (7 chars; same as blake2b; from _blake2 module; no 'openssl_' prefix)"]
    - [sha3_512_qualname_len, "sha3_512.__qualname__.__len__", [],                 16,   "sha3_512.__qualname__.__len__() is 16 ('openssl_sha3_512': 'openssl_'=8 + 'sha3_512'=8)"]

# ---------------------------------------------------------------------------
# len(hashlib.sha1.__qualname__)==12
# len(hashlib.sha256.__qualname__)==14
# len(hashlib.sha224.__qualname__)==14
# len(hashlib.sha384.__qualname__)==14
# len(hashlib.blake2b.__qualname__)==7
#
# Wave 271 theme: qualname length groupings across SHA families and BLAKE2.
#
# sha1 qualname length is 12. sha256/sha224/sha384/sha512 all share length 14.
# sha3_256/sha3_512 share length 16. blake2b/blake2s share length 7. This table
# anchors the lengths for sha1 (12) and the SHA-2/SHA-3 family (14/14/16) and
# BLAKE2 (7) as a grouped length comparison. No prior hashlib spec groups all
# these qualname lengths together in a dedicated table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra112.qualname_length_groupings:
  description: "sha1.__qualname__.__len__()==12 / sha256.__qualname__.__len__()==14 / sha224.__qualname__.__len__()==14 / sha384.__qualname__.__len__()==14 / blake2b.__qualname__.__len__()==7 — sha1 is 12; sha256/sha224/sha384 are all 14 (same length group); sha3_256/sha3_512 are 16; blake2b/blake2s are 7; grouping reveals qualname length structure across OpenSSL vs BLAKE2 hash families; no prior spec groups these lengths; first hashhkdf112 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashhkdf112

  columns: [id, function, args, expected, description]
  rows:
    - [sha1_qualname_len,   "sha1.__qualname__.__len__",   [], 12, "sha1.__qualname__.__len__() is 12 ('openssl_sha1': 'openssl_'=8 + 'sha1'=4)"]
    - [sha256_qualname_len, "sha256.__qualname__.__len__", [], 14, "sha256.__qualname__.__len__() is 14 ('openssl_sha256': 'openssl_'=8 + 'sha256'=6)"]
    - [sha224_qualname_len, "sha224.__qualname__.__len__", [], 14, "sha224.__qualname__.__len__() is 14 ('openssl_sha224': 'openssl_'=8 + 'sha224'=6; same length as sha256/sha384/sha512)"]
    - [sha384_qualname_len, "sha384.__qualname__.__len__", [], 14, "sha384.__qualname__.__len__() is 14 ('openssl_sha384': 'openssl_'=8 + 'sha384'=6; same length as sha224/sha256/sha512)"]
    - [blake2b_qualname_len, "blake2b.__qualname__.__len__", [], 7, "blake2b.__qualname__.__len__() is 7 ('blake2b': 7 chars; no 'openssl_' prefix; from _blake2 not _hashlib)"]

# ---------------------------------------------------------------------------
# hashlib.md5.__qualname__.__eq__('openssl_md5') — standalone
#
# hashlib.md5.__qualname__ is 'openssl_md5' (11 chars). The 'openssl_' prefix
# is the canonical marker for hash functions backed by OpenSSL in CPython's
# _hashlib C extension. MD5 (Message Digest Algorithm 5) was designed by
# Ron Rivest in 1991 and produces a 128-bit (16-byte) digest. Although MD5 is
# cryptographically broken (collision attacks exist), it remains widely used for
# checksumming and non-security applications. Its qualname length (11) equals
# that of pbkdf2_hmac (also 11 chars), but for a different reason — 'openssl_md5'
# is an unqualified function name, not a KDF name.
# No prior hashlib spec anchors md5.__qualname__ equality as a standalone
# under hashhkdf112. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra112.md5_qualname_eq:
  description: "hashlib.md5.__qualname__.__eq__('openssl_md5') == True — qualname is 'openssl_md5' (11 chars; 'openssl_' prefix marks OpenSSL-backed implementation in _hashlib); MD5 produces 128-bit digest; length 11 equals pbkdf2_hmac qualname but for different reason; no prior spec anchors md5 qualname equality as standalone; first standalone under hashhkdf112"
  category: function_identity
  kind: python_call_eq
  function: "md5.__qualname__.__eq__"
  args: ["openssl_md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256.__qualname__.__eq__('openssl_sha256') — standalone
#
# hashlib.sha256.__qualname__ is 'openssl_sha256' (14 chars). SHA-256 (Secure
# Hash Algorithm 256-bit) is part of the SHA-2 family designed by the NSA and
# published by NIST. It produces a 256-bit (32-byte) digest. It is the most
# widely used cryptographic hash function in modern applications (TLS, Bitcoin,
# code signing). Its qualname 'openssl_sha256' has the same length (14 chars)
# as sha224, sha384, and sha512 qualnames — reflecting the uniform naming
# convention within the SHA-2 family under the 'openssl_' prefix.
# No prior hashlib spec anchors sha256.__qualname__ equality as a standalone
# under hashhkdf112. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra112.sha256_qualname_eq:
  description: "hashlib.sha256.__qualname__.__eq__('openssl_sha256') == True — qualname is 'openssl_sha256' (14 chars); SHA-256 is the most widely used SHA-2 variant (TLS, Bitcoin, code signing); 32-byte digest; same qualname length as sha224/sha384/sha512; no prior spec anchors sha256 qualname equality as standalone; first standalone under hashhkdf112"
  category: function_identity
  kind: python_call_eq
  function: "sha256.__qualname__.__eq__"
  args: ["openssl_sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__qualname__.__eq__('openssl_sha3_256') — standalone
#
# hashlib.sha3_256.__qualname__ is 'openssl_sha3_256' (16 chars). SHA-3
# (Keccak) is a cryptographic hash standard adopted by NIST in 2015, distinct
# from the SHA-2 family. Despite using OpenSSL as the backend (hence 'openssl_'
# prefix), sha3_256 produces a 256-bit digest using the Keccak sponge
# construction. The qualname length (16) is longer than sha256 (14) due to the
# 'sha3_' infix ('sha3_256' is 8 chars vs 'sha256' which is 6 chars). The
# qualname 'openssl_sha3_256' differs from what a pure-Python SHA-3 implementation
# would use. No prior hashlib spec anchors this as a standalone under hashhkdf112.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra112.sha3_256_qualname_eq:
  description: "hashlib.sha3_256.__qualname__.__eq__('openssl_sha3_256') == True — qualname is 'openssl_sha3_256' (16 chars; 'openssl_'=8 + 'sha3_256'=8); SHA-3 uses Keccak sponge construction (distinct from SHA-2); longer than sha256 qualname (14) because 'sha3_256' has 'sha3_' infix; extra111 anchors in table; first standalone under hashhkdf112"
  category: function_identity
  kind: python_call_eq
  function: "sha3_256.__qualname__.__eq__"
  args: ["openssl_sha3_256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__qualname__.__eq__('blake2b') — standalone
#
# hashlib.blake2b.__qualname__ is 'blake2b' (7 chars). Unlike all OpenSSL-backed
# hash functions (md5, sha1, sha256, etc.) which carry the 'openssl_' prefix,
# blake2b has a plain unqualified qualname without the prefix. This is because
# blake2b is implemented as a type in the _blake2 C extension module, not as
# a function in _hashlib. BLAKE2b is the 64-bit variant of BLAKE2 (BLAKE2s is
# the 32-bit variant). blake2b.__qualname__ == 'blake2b' (same as its __name__)
# because it is a type object — types use their plain name as qualname when
# defined at module level. extra111 anchors blake2b qualname in a table row;
# this spec anchors it as a standalone under hashhkdf112.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra112.blake2b_qualname_eq:
  description: "hashlib.blake2b.__qualname__.__eq__('blake2b') == True — qualname is 'blake2b' (7 chars; no 'openssl_' prefix; from _blake2 C extension, not _hashlib); blake2b is a type object (not builtin_function_or_method like sha256); BLAKE2b is the 64-bit BLAKE2 variant; plain qualname because type objects use name as qualname at module level; extra111 anchors in table; first standalone under hashhkdf112"
  category: function_identity
  kind: python_call_eq
  function: "blake2b.__qualname__.__eq__"
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.__qualname__.__eq__('blake2s') — standalone
#
# hashlib.blake2s.__qualname__ is 'blake2s' (7 chars). Like blake2b, blake2s
# is implemented as a type in the _blake2 C extension, and its qualname carries
# no 'openssl_' prefix. BLAKE2s is the 32-bit variant of BLAKE2, optimized for
# 8-bit to 32-bit platforms. Both blake2b and blake2s share qualname length 7.
# No prior hashlib spec anchors blake2s.__qualname__ equality as a standalone
# under hashhkdf112. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra112.blake2s_qualname_eq:
  description: "hashlib.blake2s.__qualname__.__eq__('blake2s') == True — qualname is 'blake2s' (7 chars; same length as blake2b; no 'openssl_' prefix; from _blake2 C extension); BLAKE2s is the 32-bit BLAKE2 variant (optimized for 8-32 bit platforms); both blake2b/blake2s are types with plain qualnames; no prior spec anchors blake2s qualname as standalone; first standalone under hashhkdf112"
  category: function_identity
  kind: python_call_eq
  function: "blake2s.__qualname__.__eq__"
  args: ["blake2s"]
  expected: true

