spec: itertools_extra186
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools module __name__ and __package__ identity, and itertools class __doc__ attribute type — itertools.__name__=='itertools' (len 9); itertools.__package__=='' (empty string, C extension module); itertools.__doc__.__class__.__name__=='str'; itertools.count.__doc__.__class__.__name__=='str'; itertools.cycle.__doc__.__class__.__name__=='str'; itertools.repeat.__doc__.__class__.__name__=='str'; itertools.chain.__doc__.__class__.__name__=='str'."
    - "itertools.__name__ == 'itertools' — the module's __name__ attribute is the string 'itertools', 9 characters; verified with Python 3.14.3 on macOS/Darwin 25.4.0."
    - "itertools.__package__ == '' — itertools is a built-in C extension module; its __package__ is the empty string '' (not 'itertools'); verified with Python 3.14.3."
    - "itertools.__doc__.__class__.__name__ == 'str' — the module docstring is a plain Python str; verified with Python 3.14.3."
    - "itertools.count.__doc__.__class__.__name__ == 'str' — the count class docstring is a plain Python str; verified with Python 3.14.3."
    - "itertools.cycle.__doc__.__class__.__name__ == 'str' — the cycle class docstring is a plain Python str; verified with Python 3.14.3."
    - "itertools.repeat.__doc__.__class__.__name__ == 'str' — the repeat class docstring is a plain Python str; verified with Python 3.14.3."
    - "itertools.chain.__doc__.__class__.__name__ == 'str' — the chain class docstring is a plain Python str; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools module __name__ and __package__
#
# itertools.__name__.__eq__('itertools') == True
# itertools.__name__.__len__() == 9
# itertools.__package__.__eq__('') == True
# itertools.__package__.__len__() == 0
#
# itertools is a built-in C extension module. Its __name__ is 'itertools'
# (9 chars) and its __package__ is the empty string '' (not 'itertools'),
# which is the convention for top-level C extension modules. New to extra186.
# ---------------------------------------------------------------------------

table itertools_extra186.module_name_and_package:
  description: "itertools.__name__=='itertools' (len 9); __package__=='' (empty, C extension module top-level); new to extra186"
  kind: python_call_eq
  category: identity
  id_prefix: itermodule186

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,
       __name__.__eq__,
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — the module __name__ attribute is the string 'itertools' (9 chars); str.__eq__('itertools') returns True; new to extra186"]
    - [module_name_len_9,
       __name__.__len__,
       [],
       9,
       "itertools.__name__.__len__() == 9 — the name 'itertools' has exactly 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; new to extra186"]
    - [module_package_eq_empty,
       __package__.__eq__,
       [""],
       true,
       "itertools.__package__.__eq__('') == True — itertools is a top-level C extension module; its __package__ is the empty string '', not 'itertools'; str.__eq__('') returns True; verified with Python 3.14.3; new to extra186"]
    - [module_package_len_0,
       __package__.__len__,
       [],
       0,
       "itertools.__package__.__len__() == 0 — the empty string __package__ has length 0; str.__len__() returns 0; new to extra186"]

# ---------------------------------------------------------------------------
# Table 2: itertools module __doc__ and itertools.count/__doc__ class name
#
# itertools.__doc__.__class__.__name__.__eq__('str') == True
# itertools.count.__doc__.__class__.__name__.__eq__('str') == True
# itertools.cycle.__doc__.__class__.__name__.__eq__('str') == True
#
# The module docstring and the per-class docstrings are all plain str objects.
# New to extra186.
# ---------------------------------------------------------------------------

table itertools_extra186.module_doc_and_count_cycle_doc:
  description: "itertools.__doc__, count.__doc__, and cycle.__doc__ all have __class__.__name__=='str'; new to extra186"
  kind: python_call_eq
  category: identity
  id_prefix: itermodule186

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_class_eq,
       __doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.__doc__.__class__.__name__.__eq__('str') == True — the module-level docstring is a plain Python str; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra186"]
    - [count_doc_class_eq,
       count.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.count.__doc__.__class__.__name__.__eq__('str') == True — the count class docstring (infinite counter from start by step) is a plain Python str; str.__eq__('str') returns True; new to extra186"]
    - [cycle_doc_class_eq,
       cycle.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.cycle.__doc__.__class__.__name__.__eq__('str') == True — the cycle class docstring (cycle repeatedly through an iterable) is a plain Python str; str.__eq__('str') returns True; new to extra186"]
    - [repeat_doc_class_eq,
       repeat.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.repeat.__doc__.__class__.__name__.__eq__('str') == True — the repeat class docstring (repeat element optionally n times) is a plain Python str; str.__eq__('str') returns True; new to extra186"]

# ---------------------------------------------------------------------------
# Table 3: itertools.chain and itertools.islice __doc__ class names
#
# itertools.chain.__doc__.__class__.__name__.__eq__('str') == True
# itertools.islice.__doc__.__class__.__name__.__eq__('str') == True
# itertools.product.__doc__.__class__.__name__.__eq__('str') == True
# itertools.combinations.__doc__.__class__.__name__.__eq__('str') == True
#
# Additional C-extension iterator classes in itertools all have str docstrings.
# New to extra186.
# ---------------------------------------------------------------------------

table itertools_extra186.chain_islice_product_combinations_doc:
  description: "itertools.chain, islice, product, combinations all have __doc__.__class__.__name__=='str'; new to extra186"
  kind: python_call_eq
  category: identity
  id_prefix: itermodule186

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_class_eq,
       chain.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.chain.__doc__.__class__.__name__.__eq__('str') == True — the chain class docstring (chain multiple iterables together) is a plain Python str; str.__eq__('str') returns True; new to extra186"]
    - [islice_doc_class_eq,
       islice.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.islice.__doc__.__class__.__name__.__eq__('str') == True — the islice class docstring (slice an iterator) is a plain Python str; str.__eq__('str') returns True; new to extra186"]
    - [product_doc_class_eq,
       product.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.product.__doc__.__class__.__name__.__eq__('str') == True — the product class docstring (Cartesian product) is a plain Python str; str.__eq__('str') returns True; new to extra186"]
    - [combinations_doc_class_eq,
       combinations.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.combinations.__doc__.__class__.__name__.__eq__('str') == True — the combinations class docstring (r-length combinations) is a plain Python str; str.__eq__('str') returns True; new to extra186"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra186
# ---------------------------------------------------------------------------

invariant itertools_extra186.module_name_is_itertools:
  description: "itertools.__name__.__eq__('itertools') == True — the module __name__ is the string 'itertools' (9 chars); verified with Python 3.14.3; new to extra186"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra186.module_name_len_9:
  description: "itertools.__name__.__len__() == 9 — the name 'itertools' has exactly 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; verified with Python 3.14.3; new to extra186"
  category: identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 9

invariant itertools_extra186.module_package_is_empty:
  description: "itertools.__package__.__eq__('') == True — itertools is a top-level C extension module; __package__ is '' (empty string, not 'itertools'); verified with Python 3.14.3; new to extra186"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant itertools_extra186.module_doc_is_str:
  description: "itertools.__doc__.__class__.__name__.__eq__('str') == True — the module docstring is a plain Python str; verified with Python 3.14.3; new to extra186"
  category: identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra186.count_doc_is_str:
  description: "itertools.count.__doc__.__class__.__name__.__eq__('str') == True — the count class (infinite counter) docstring is a plain Python str; verified with Python 3.14.3; new to extra186"
  category: identity
  kind: python_call_eq
  function: count.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra186.cycle_doc_is_str:
  description: "itertools.cycle.__doc__.__class__.__name__.__eq__('str') == True — the cycle class docstring is a plain Python str; verified with Python 3.14.3; new to extra186"
  category: identity
  kind: python_call_eq
  function: cycle.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra186.repeat_doc_is_str:
  description: "itertools.repeat.__doc__.__class__.__name__.__eq__('str') == True — the repeat class docstring is a plain Python str; verified with Python 3.14.3; new to extra186"
  category: identity
  kind: python_call_eq
  function: repeat.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra186.chain_doc_is_str:
  description: "itertools.chain.__doc__.__class__.__name__.__eq__('str') == True — the chain class docstring is a plain Python str; verified with Python 3.14.3; new to extra186"
  category: identity
  kind: python_call_eq
  function: chain.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
