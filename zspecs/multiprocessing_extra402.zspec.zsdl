spec: multiprocessing_extra402
version: ">=3.9"
backend: python_module(multiprocessing.context)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "multiprocessing.context.BaseContext.__name__ == 'BaseContext', __module__ == 'multiprocessing.context', __bases__[0].__name__ == 'object'"
    - "multiprocessing.context.SpawnContext.__name__ == 'SpawnContext', __module__ == 'multiprocessing.context', __bases__[0].__name__ == 'BaseContext'"
    - "multiprocessing.context.ForkContext.__name__ == 'ForkContext', __module__ == 'multiprocessing.context', __bases__[0].__name__ == 'BaseContext' (available on macOS)"
    - "ForkContext is available on macOS where fork start method is supported"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra402.context_class_names:
  description: "Verify __name__ attribute of multiprocessing.context classes"
  kind: python_call_eq
  category: identity
  id_prefix: mp402cn

  columns: [id, function, args, expected]
  rows:
    - [mp402cn001, multiprocessing.context.BaseContext.__name__.__eq__, ["BaseContext"], true]
    - [mp402cn002, multiprocessing.context.SpawnContext.__name__.__eq__, ["SpawnContext"], true]
    - [mp402cn003, multiprocessing.context.ForkContext.__name__.__eq__, ["ForkContext"], true]

table multiprocessing_extra402.context_class_modules:
  description: "Verify __module__ attribute of multiprocessing.context classes"
  kind: python_call_eq
  category: identity
  id_prefix: mp402cm

  columns: [id, function, args, expected]
  rows:
    - [mp402cm001, multiprocessing.context.BaseContext.__module__.__eq__, ["multiprocessing.context"], true]
    - [mp402cm002, multiprocessing.context.SpawnContext.__module__.__eq__, ["multiprocessing.context"], true]
    - [mp402cm003, multiprocessing.context.ForkContext.__module__.__eq__, ["multiprocessing.context"], true]

table multiprocessing_extra402.context_class_bases:
  description: "Verify __bases__[0].__name__ (first immediate base class name) of multiprocessing.context classes"
  kind: python_call_eq
  category: identity
  id_prefix: mp402cb

  columns: [id, function, args, expected]
  rows:
    - ["mp402cb001", "multiprocessing.context.BaseContext.__bases__[0].__name__.__eq__", ["object"], true]
    - ["mp402cb002", "multiprocessing.context.SpawnContext.__bases__[0].__name__.__eq__", ["BaseContext"], true]
    - ["mp402cb003", "multiprocessing.context.ForkContext.__bases__[0].__name__.__eq__", ["BaseContext"], true]
