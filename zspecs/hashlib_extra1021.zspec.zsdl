spec: hashlib_extra1021
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib module metadata types and builtin function __self__ identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1021.module_metadata_types:
  description: "hashlib module top-level attribute class name checks"
  kind: python_call_eq
  category: module_metadata
  id_prefix: hl1021x
  columns: [id, function, args, expected]
  rows:
    - [hl1021x001, hashlib.__cached__.__class__.__name__.__eq__, ["str"],  true]
    - [hl1021x002, hashlib.__file__.__class__.__name__.__eq__,   ["str"],  true]
    - [hl1021x003, hashlib.__all__.__class__.__name__.__eq__,    ["list"], true]
    - [hl1021x004, hashlib.__name__.__class__.__name__.__eq__,   ["str"],  true]
    - [hl1021x005, hashlib.__doc__.__class__.__name__.__eq__,    ["str"],  true]
    - [hl1021x006, hashlib.__package__.__class__.__name__.__eq__, ["str"], true]

table hashlib_extra1021.loader_identity:
  description: "hashlib module __loader__ class name"
  kind: python_call_eq
  category: loader_identity
  id_prefix: hl1021l
  columns: [id, function, args, expected]
  rows:
    - [hl1021l001, hashlib.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true]
    - [hl1021l002, hashlib.__spec__.__class__.__name__.__eq__,   ["ModuleSpec"],       true]
    - [hl1021l003, hashlib.__spec__.name.__eq__,                 ["hashlib"],          true]
    - [hl1021l004, hashlib.__name__.__eq__,                      ["hashlib"],          true]

table hashlib_extra1021.builtin_function_self_identity:
  description: "hashlib builtin functions __self__ class name checks"
  kind: python_call_eq
  category: builtin_self_identity
  id_prefix: hl1021s
  columns: [id, function, args, expected]
  rows:
    - [hl1021s001, hashlib.md5.__self__.__class__.__name__.__eq__,     ["module"], true]
    - [hl1021s002, hashlib.sha256.__self__.__class__.__name__.__eq__,  ["module"], true]
    - [hl1021s003, hashlib.sha1.__self__.__class__.__name__.__eq__,    ["module"], true]
    - [hl1021s004, hashlib.sha512.__self__.__class__.__name__.__eq__,  ["module"], true]
    - [hl1021s005, hashlib.new.__self__.__class__.__name__.__eq__,     ["module"], true]
