spec: stripe_rust
version: ">=3.9"
backend: rust_module(stripe_rust)

docs: https://stripe.com/docs/api?lang=python

provenance:
  derived_from:
    - "https://stripe.com/docs/api?lang=python — stripe-python"
  notes:
    - "stripe provides Stripe payment API integration."
    - "stripe.VERSION is non-empty."
    - "stripe.Charge is a class."
    - "stripe.api_key can be set."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant stripe_rust.version_nonempty:
  description: "stripe.VERSION is non-empty"
  category: version
  kind: python_call_eq
  function: stripe_version_nonempty
  args: []
  expected: true

invariant stripe_rust.has_charge:
  description: "stripe.Charge is a class"
  category: presence
  kind: python_call_eq
  function: stripe_has_charge
  args: []
  expected: true

invariant stripe_rust.has_customer:
  description: "stripe.Customer is a class"
  category: presence
  kind: python_call_eq
  function: stripe_has_customer
  args: []
  expected: true

