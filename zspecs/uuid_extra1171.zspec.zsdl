spec: uuid_extra1171
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid.__all__ __class__.__name__ and __contains__ for 'UUID'/'uuid1'/'uuid3'/'uuid4'/'uuid5'/'NAMESPACE_DNS'/'NAMESPACE_URL', uuid.SafeUUID __module__ and __qualname__, uuid.SafeUUID._value2member_map_ class name, uuid.UUID.__eq__/__hash__ method attrs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1171.all_class_name_and_contains:
  description: "uuid.__all__ __class__.__name__ and __contains__ membership checks for expected names"
  kind: python_call_eq
  category: all_class_name_contains
  id_prefix: uu1171al
  columns: [id, function, args, expected]
  rows:
    - [uu1171al001, uuid.__all__.__class__.__name__.__eq__,                    ["list"],         true]
    - [uu1171al002, uuid.__all__.__class__.__qualname__.__eq__,                ["list"],         true]
    - [uu1171al003, uuid.__all__.__class__.__module__.__eq__,                  ["builtins"],     true]
    - [uu1171al004, uuid.__all__.__contains__,                                 ["UUID"],         true]
    - [uu1171al005, uuid.__all__.__contains__,                                 ["uuid1"],        true]
    - [uu1171al006, uuid.__all__.__contains__,                                 ["uuid3"],        true]
    - [uu1171al007, uuid.__all__.__contains__,                                 ["uuid4"],        true]
    - [uu1171al008, uuid.__all__.__contains__,                                 ["uuid5"],        true]
    - [uu1171al009, uuid.__all__.__contains__,                                 ["NAMESPACE_DNS"], true]
    - [uu1171al010, uuid.__all__.__contains__,                                 ["NAMESPACE_URL"], true]

table uuid_extra1171.safeuuid_module_qualname_and_value2member:
  description: "uuid.SafeUUID __module__ and __qualname__ and _value2member_map_ class name"
  kind: python_call_eq
  category: safeuuid_module_qualname_value2member
  id_prefix: uu1171su
  columns: [id, function, args, expected]
  rows:
    - [uu1171su001, uuid.SafeUUID.__module__.__eq__,                           ["uuid"],         true]
    - [uu1171su002, uuid.SafeUUID.__qualname__.__eq__,                         ["SafeUUID"],     true]
    - [uu1171su003, uuid.SafeUUID.__module__.__class__.__name__.__eq__,        ["str"],          true]
    - [uu1171su004, uuid.SafeUUID.__qualname__.__class__.__name__.__eq__,      ["str"],          true]
    - [uu1171su005, uuid.SafeUUID.__qualname__.__class__.__module__.__eq__,    ["builtins"],     true]
    - [uu1171su006, uuid.SafeUUID._value2member_map_.__class__.__name__.__eq__, ["dict"],        true]
    - [uu1171su007, uuid.SafeUUID._value2member_map_.__class__.__qualname__.__eq__, ["dict"],    true]
    - [uu1171su008, uuid.SafeUUID._value2member_map_.__class__.__module__.__eq__, ["builtins"],  true]
    - [uu1171su009, uuid.SafeUUID.__class__.__name__.__eq__,                   ["EnumType"],     true]
    - [uu1171su010, uuid.SafeUUID.__class__.__module__.__eq__,                 ["enum"],         true]

table uuid_extra1171.uuid_class_eq_hash_method_attrs:
  description: "uuid.UUID __eq__ and __hash__ method qualname, class name, and module attrs"
  kind: python_call_eq
  category: uuid_class_eq_hash_method_attrs
  id_prefix: uu1171eh
  columns: [id, function, args, expected]
  rows:
    - [uu1171eh001, uuid.UUID.__eq__.__qualname__.__eq__,                      ["UUID.__eq__"],  true]
    - [uu1171eh002, uuid.UUID.__eq__.__class__.__name__.__eq__,                ["function"],     true]
    - [uu1171eh003, uuid.UUID.__eq__.__module__.__eq__,                        ["uuid"],         true]
    - [uu1171eh004, uuid.UUID.__hash__.__qualname__.__eq__,                    ["UUID.__hash__"], true]
    - [uu1171eh005, uuid.UUID.__hash__.__class__.__name__.__eq__,              ["function"],     true]
    - [uu1171eh006, uuid.UUID.__hash__.__module__.__eq__,                      ["uuid"],         true]
    - [uu1171eh007, uuid.UUID.__eq__.__module__.__class__.__name__.__eq__,     ["str"],          true]
    - [uu1171eh008, uuid.UUID.__hash__.__module__.__class__.__name__.__eq__,   ["str"],          true]
    - [uu1171eh009, uuid.UUID.__eq__.__qualname__.__class__.__name__.__eq__,   ["str"],          true]
