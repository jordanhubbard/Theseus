spec: io_extra61
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/"
    - "io_extra60.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper/IOBase __dict__.__class__.__name__.__eq__('mappingproxy'); BytesIO/FileIO __dict__.__class__.__qualname__.__eq__('mappingproxy'); io module __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy')."
    - "io_extra59.zspec.zsdl — covers DEFAULT_BUFFER_SIZE __class__.__module__.__eq__('builtins') and __class__.__module__.__len__()==8; BufferedIOBase/TextIOBase __module__ equality/length."
    - "io_extra58.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper __module__.__eq__('_io'); IOBase/RawIOBase __module__.__eq__('io'); open __module__.__eq__('_io'); class __module__.__len__()==3 for several classes."
    - "io_extra57.zspec.zsdl — covers BytesIO/StringIO method qualname equality for read/write/seek/tell/getvalue."
    - "io_extra56.zspec.zsdl — covers __doc__.__class__.__name__/qualname for io classes and module."
    - "io_extra37.zspec.zsdl — covers __dict__.__class__.__name__.__len__()==12 for StringIO/BytesIO/IOBase/FileIO/RawIOBase/BufferedReader/TextIOWrapper."
  notes:
    - "This spec extends io_extra60.zspec.zsdl."
    - "Prior specs collectively covered: io_extra59 covers DEFAULT_BUFFER_SIZE.__class__.__module__.__eq__('builtins') (the constant's type module); io_extra58 covers class __module__.__eq__() for all main io classes (their own __module__, not their metaclass's __module__); NO prior io spec checks BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper __class__.__module__.__eq__('builtins') (the metaclass 'type' module); NO prior io spec checks IOBase/RawIOBase/BufferedIOBase/TextIOBase __class__.__module__.__eq__('abc') (these use ABCMeta as metaclass, and ABCMeta.__module__=='abc'); NO prior io spec checks io.__spec__.name.__eq__('io') or io.__spec__.name.__len__()==2."
    - "This spec covers: io.BytesIO.__class__.__module__.__eq__('builtins') (NOVEL — BytesIO is a C extension type with metaclass 'type'; 'type' is a C-level builtin whose __module__=='builtins'; no prior io spec checks BytesIO.__class__.__module__; novel in iomod61 namespace); io.StringIO.__class__.__module__.__eq__('builtins') (NOVEL); io.FileIO.__class__.__module__.__eq__('builtins') (NOVEL); io.BufferedReader.__class__.__module__.__eq__('builtins') (NOVEL); io.BufferedWriter.__class__.__module__.__eq__('builtins') (NOVEL); io.TextIOWrapper.__class__.__module__.__eq__('builtins') (NOVEL); io.IOBase.__class__.__module__.__eq__('abc') (NOVEL — IOBase uses ABCMeta as metaclass; ABCMeta is defined in the 'abc' module; no prior io spec checks IOBase.__class__.__module__; novel); io.RawIOBase.__class__.__module__.__eq__('abc') (NOVEL); io.BufferedIOBase.__class__.__module__.__eq__('abc') (NOVEL); io.TextIOBase.__class__.__module__.__eq__('abc') (NOVEL); io.__spec__.name.__eq__('io') (NOVEL — no prior io spec checks io.__spec__.name; the ModuleSpec .name attribute is the fully-qualified module name; novel module-spec anchor in iomod61 namespace); io.__spec__.name.__len__()==2 (NOVEL — 'io' has 2 characters; novel length anchor)."
    - "io.BytesIO.__class__.__module__ == 'builtins'. BytesIO is implemented in C (_io extension). Its metaclass is the standard 'type' builtin. The 'type' type has __module__=='builtins'. No prior io spec checks BytesIO.__class__.__module__. io_extra59 covers DEFAULT_BUFFER_SIZE.__class__.__module__ (for the int constant) but not for io class objects themselves. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.StringIO.__class__.__module__ == 'builtins'. StringIO is also a C extension type. Same metaclass reasoning as BytesIO. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.FileIO.__class__.__module__ == 'builtins'. FileIO is the raw file I/O class, implemented in C. Its metaclass is 'type' from builtins. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.BufferedReader.__class__.__module__ == 'builtins'. BufferedReader is a C extension type. Metaclass is 'type' from builtins. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.BufferedWriter.__class__.__module__ == 'builtins'. BufferedWriter is a C extension type. Metaclass is 'type' from builtins. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.TextIOWrapper.__class__.__module__ == 'builtins'. TextIOWrapper is a C extension type. Metaclass is 'type' from builtins. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.IOBase.__class__.__module__ == 'abc'. IOBase is an abstract base class using ABCMeta as its metaclass. ABCMeta is defined in the 'abc' module, so IOBase.__class__.__module__ == 'abc'. This distinguishes IOBase/RawIOBase/BufferedIOBase/TextIOBase (ABCMeta, 'abc') from BytesIO/StringIO/TextIOWrapper (type, 'builtins'). Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.RawIOBase.__class__.__module__ == 'abc'. RawIOBase extends IOBase; same ABCMeta reasoning. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.BufferedIOBase.__class__.__module__ == 'abc'. BufferedIOBase is also an ABC. Same reasoning. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.TextIOBase.__class__.__module__ == 'abc'. TextIOBase is also an ABC. Same reasoning. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.__spec__.name == 'io'. The io module's ModuleSpec object has a .name attribute (not .__name__) that equals the module's fully-qualified name, 'io'. No prior io spec checks io.__spec__.name. Novel module-spec anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.__spec__.name.__len__() == 2. 'io' has 2 characters. Novel length anchor for the io module spec name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io C-extension class __class__.__module__ == 'builtins'
#
# BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, and TextIOWrapper
# are all C-extension types whose metaclass is the standard 'type' builtin.
# The 'type' metaclass has __module__ == 'builtins'. Therefore:
#
#   BytesIO.__class__.__module__       == 'builtins'
#   StringIO.__class__.__module__      == 'builtins'
#   FileIO.__class__.__module__        == 'builtins'
#   BufferedReader.__class__.__module__ == 'builtins'
#   BufferedWriter.__class__.__module__ == 'builtins'
#   TextIOWrapper.__class__.__module__ == 'builtins'
#
# io_extra59 covers DEFAULT_BUFFER_SIZE.__class__.__module__.__eq__('builtins')
# (for the int constant) but no prior io spec checks __class__.__module__
# for any io class object. All six anchors are novel in iomod61 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra61.cext_class_module_eq:
  description: "io C-extension class __class__.__module__.__eq__('builtins') for BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper — C-extension types have metaclass 'type' from builtins; io_extra59 covers DEFAULT_BUFFER_SIZE.__class__.__module__ (constant) but no prior io spec checks class-object __class__.__module__; all six novel anchors in iomod61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: iomod61cext

  columns: [id, function, args, expected]
  rows:
    - [BytesIO_class_module,       "BytesIO.__class__.__module__.__eq__",       ["builtins"], true]
    - [StringIO_class_module,      "StringIO.__class__.__module__.__eq__",      ["builtins"], true]
    - [FileIO_class_module,        "FileIO.__class__.__module__.__eq__",        ["builtins"], true]
    - [BufferedReader_class_module, "BufferedReader.__class__.__module__.__eq__", ["builtins"], true]
    - [BufferedWriter_class_module, "BufferedWriter.__class__.__module__.__eq__", ["builtins"], true]
    - [TextIOWrapper_class_module,  "TextIOWrapper.__class__.__module__.__eq__",  ["builtins"], true]

# ---------------------------------------------------------------------------
# io abstract base class __class__.__module__ == 'abc'
#
# IOBase, RawIOBase, BufferedIOBase, and TextIOBase are abstract base classes
# that use ABCMeta as their metaclass. ABCMeta is defined in the 'abc' module,
# so their __class__.__module__ is 'abc'. This contrasts with the C-extension
# types above (BytesIO etc.) which use the standard 'type' from 'builtins'.
#
#   IOBase.__class__.__module__       == 'abc'
#   RawIOBase.__class__.__module__    == 'abc'
#   BufferedIOBase.__class__.__module__ == 'abc'
#   TextIOBase.__class__.__module__   == 'abc'
#
# No prior io spec checks __class__.__module__ for any io abstract base class.
# All four anchors are novel in the iomod61 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra61.abc_class_module_eq:
  description: "io abstract base class __class__.__module__.__eq__('abc') for IOBase/RawIOBase/BufferedIOBase/TextIOBase — these use ABCMeta as metaclass; ABCMeta is defined in the 'abc' module so __class__.__module__=='abc'; distinguishes ABCs from C-extension types above; no prior io spec checks __class__.__module__ for any io ABC; all four novel anchors in iomod61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: iomod61abc

  columns: [id, function, args, expected]
  rows:
    - [IOBase_class_module,       "IOBase.__class__.__module__.__eq__",       ["abc"], true]
    - [RawIOBase_class_module,    "RawIOBase.__class__.__module__.__eq__",    ["abc"], true]
    - [BufferedIOBase_class_module, "BufferedIOBase.__class__.__module__.__eq__", ["abc"], true]
    - [TextIOBase_class_module,   "TextIOBase.__class__.__module__.__eq__",   ["abc"], true]

# ---------------------------------------------------------------------------
# io module __spec__.name equality and length
#
# The io module's ModuleSpec object (accessible as io.__spec__) has a .name
# attribute that equals the module's fully-qualified name. For the io module,
# __spec__.name == 'io' (a 2-character string). No prior io spec checks
# io.__spec__.name. Note: ModuleSpec uses .name (not .__name__).
#
#   io.__spec__.name.__eq__('io') == True
#   io.__spec__.name.__len__()    == 2
#
# Both anchors are novel in the iomod61 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra61.spec_name_eq:
  description: "io.__spec__.name.__eq__('io') — the io module ModuleSpec .name attribute equals the module's fully-qualified name 'io'; no prior io spec checks io.__spec__.name; novel module-spec anchor in iomod61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["io"]
  expected: true

invariant io_extra61.spec_name_len:
  description: "io.__spec__.name.__len__() == 2 — 'io' has 2 characters; no prior io spec checks io.__spec__.name.__len__(); novel length anchor in iomod61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__len__
  args: []
  expected: 2

invariant io_extra61.BytesIO_class_module_builtins:
  description: "io.BytesIO.__class__.__module__ == 'builtins' — BytesIO is a C-extension type whose metaclass is 'type'; the 'type' type has __module__=='builtins'; this contrasts with ABCMeta-based classes (IOBase etc.) whose __class__.__module__=='abc'; novel anchor in iomod61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true
