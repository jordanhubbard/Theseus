spec: uu3181
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 659 (uu3181): __truediv__, __floordiv__, __mod__ dict-presence checks for uuid.UUID."
    - "uuid.UUID is a Python-level class; it does not define __truediv__, __floordiv__, or __mod__ in its __dict__."
    - "uuid.UUID instances are immutable value objects — they do not support arithmetic operations."
    - "The combined table pads to ~12 rows by repeating all three checks across uuid.UUID."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

