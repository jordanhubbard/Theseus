spec: abc_extra117
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra116.zspec.zsdl."
    - "This spec covers: wave 261 theme — abc.abstractclassmethod and abc.abstractstaticmethod __init__ co_consts and co_freevars element-level checks not previously covered. Prior specs covered: extra91 covered abstractclassmethod.__init__.__qualname__.__len__()==28 and abstractstaticmethod.__init__.__qualname__.__len__()==29; extra104 covered abstractclassmethod.__init__.__code__.co_argcount==2 and abstractstaticmethod.__init__.__code__.co_argcount==2; extra115 covered abstractclassmethod.__init__.__code__.co_varnames[1].__eq__('callable') and abstractstaticmethod.__init__.__code__.co_varnames[1].__eq__('callable'). NOT previously covered: abstractclassmethod.__init__.__code__.co_consts.__len__()==2; abstractclassmethod.__init__.__code__.co_consts[0].__eq__(True); abstractclassmethod.__init__.__code__.co_freevars.__len__()==1; abstractclassmethod.__init__.__code__.co_freevars[0].__eq__('__class__'); abstractstaticmethod.__init__.__code__.co_freevars[0].__eq__('__class__'); abstractclassmethod.__init__.__code__.co_cellvars.__len__()==0; abstractclassmethod.__init__.__code__.co_qualname.__eq__('abstractclassmethod.__init__'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractclassmethod.__init__.__code__.co_consts == (True, None): len=2. co_consts[0] is True (bool): abstractclassmethod.__init__ sets self.__isabstractmethod__ = True via super().__init__(callable); co_consts[1] is None. co_freevars == ('__class__',): len=1. '__class__' is captured from the enclosing class scope because __init__ uses super() which implicitly references __class__ as a cell variable from the class body; co_cellvars == (): len=0. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractstaticmethod.__init__.__code__.co_consts == (True, None): len=2 (identical to abstractclassmethod: same constants True and None). co_freevars == ('__class__',): len=1 (same: both __init__ methods use super() which captures __class__). co_cellvars == (): len=0. co_qualname == 'abstractstaticmethod.__init__' (len=29: 1 more than abstractclassmethod=28). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Note: abstractclassmethod and abstractstaticmethod both have co_freevars==('__class__',) because their __init__ methods use super() which Python 3 implements via an implicit __class__ cell variable captured from the class body. This contrasts with abstractmethod (a standalone function, not a class method) which has co_freevars==() with len=0. The presence of '__class__' in co_freevars is a structural marker distinguishing class-body methods from standalone functions. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.abstractclassmethod.__init__ co_consts and co_freevars element checks — extra117
#
# Wave 261 theme: abstractclassmethod.__init__ co_consts[0]=True, co_freevars[0]='__class__'.
#
# abstractclassmethod.__init__.__code__.co_consts  == (True, None)   len=2
# abstractclassmethod.__init__.__code__.co_freevars == ('__class__',) len=1
# abstractclassmethod.__init__.__code__.co_cellvars == ()             len=0
# abstractclassmethod.__init__.__code__.co_qualname == 'abstractclassmethod.__init__' (len=28)
# ---------------------------------------------------------------------------

table abc_extra117.abstractclassmethod_init_co_attrs:
  description: "abc.abstractclassmethod.__init__ co_consts, co_freevars, co_cellvars, and co_qualname checks in abcacm117 namespace — wave 261 theme: abstractclassmethod.__init__ uses super() which captures __class__ in co_freevars; co_consts.__len__()==2 (co_consts==(True, None): True is the boolean stored into __isabstractmethod__; None is the implicit return value; 2 constants: same count as abstractmethod co_consts.__len__()==2 covered in extra116, but the content differs: abstractclassmethod has co_consts==(True,None) while abstractmethod has co_consts==(docstring,True)); co_consts[0].__eq__(True)==True (abstractclassmethod.__init__ stores self.__isabstractmethod__=True; unlike abstractmethod where True is at index 1, in abstractclassmethod.__init__ True is at index 0 because there is no docstring in the code object constants — the docstring if present is stored differently in Python 3.14); co_freevars.__len__()==1 (co_freevars==('__class__',): 1 free variable; this contrasts with abstractmethod co_freevars.__len__()==0 covered in extra116 — abstractmethod is a module-level function with no closure, while abstractclassmethod.__init__ is a class body method that uses super() which requires __class__ as an implicit cell variable from the class definition scope; co_freevars len=1 is greater than co_freevars len=0 for abstractmethod); co_freevars[0].__eq__('__class__')==True (len=9: '__class__' is the implicit super() free variable: Python 3 implements super() via a cell variable named '__class__' that is automatically added to any method that uses super(); double-underscore prefix and suffix: '__'=2+'class'=5+'__'=2=9); co_cellvars.__len__()==0 (abstractclassmethod.__init__ has no nested functions that would require cell variables; it only captures from the enclosing class scope, making '__class__' a free variable rather than a cell variable); co_qualname.__eq__('abstractclassmethod.__init__')==True (len=28: covered in extra91 as a length; this spec adds the equality check: 'abstractclassmethod.'=20+'__init__'=8=20+8=28); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcacm117

  columns: [id, function, args, expected, description]
  rows:
    - [acm_consts_len,   abstractclassmethod.__init__.__code__.co_consts.__len__,               [],             2,    "abstractclassmethod.__init__ co_consts.__len__() == 2 ((True, None); same count as abstractmethod=2 but different content); verified with Python 3.14.3"]
    - [acm_consts0_eq,   "abstractclassmethod.__init__.__code__.co_consts[0].__eq__",            [true],         true, "abstractclassmethod.__init__ co_consts[0] == True (bool; stored into __isabstractmethod__); verified with Python 3.14.3"]
    - [acm_freevars_len, abstractclassmethod.__init__.__code__.co_freevars.__len__,              [],             1,    "abstractclassmethod.__init__ co_freevars.__len__() == 1 (('__class__',); 1 more than abstractmethod=0); verified with Python 3.14.3"]
    - [acm_fv0_eq,       "abstractclassmethod.__init__.__code__.co_freevars[0].__eq__",          ["__class__"],  true, "abstractclassmethod.__init__ co_freevars[0] == '__class__' (len=9; implicit super() cell variable); verified with Python 3.14.3"]
    - [acm_fv0_len,      "abstractclassmethod.__init__.__code__.co_freevars[0].__len__",         [],             9,    "abstractclassmethod.__init__ co_freevars[0].__len__() == 9 ('__class__'=9: '__'=2+'class'=5+'__'=2=9); verified with Python 3.14.3"]
    - [acm_cellvars_len, abstractclassmethod.__init__.__code__.co_cellvars.__len__,              [],             0,    "abstractclassmethod.__init__ co_cellvars.__len__() == 0 (no nested functions; only captures from class scope); verified with Python 3.14.3"]
    - [acm_qn_eq,        abstractclassmethod.__init__.__code__.co_qualname.__eq__,               ["abstractclassmethod.__init__"], true, "abstractclassmethod.__init__ co_qualname == 'abstractclassmethod.__init__' (len=28); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractstaticmethod.__init__ co_consts and co_freevars element checks — extra117
#
# Wave 261 theme: abstractstaticmethod.__init__ co_freevars[0]='__class__', co_consts len=2.
#
# abstractstaticmethod.__init__.__code__.co_consts   == (True, None)    len=2 (tied with abstractclassmethod)
# abstractstaticmethod.__init__.__code__.co_freevars == ('__class__',)  len=1 (tied with abstractclassmethod)
# abstractstaticmethod.__init__.__code__.co_cellvars == ()              len=0 (tied with abstractclassmethod)
# abstractstaticmethod.__init__.__code__.co_qualname == 'abstractstaticmethod.__init__' (len=29)
# ---------------------------------------------------------------------------

table abc_extra117.abstractstaticmethod_init_co_attrs:
  description: "abc.abstractstaticmethod.__init__ co_consts, co_freevars, co_cellvars, and co_qualname checks in abcasm117 namespace — wave 261 theme: abstractstaticmethod.__init__ has identical co_consts and co_freevars structure to abstractclassmethod.__init__; co_consts.__len__()==2 (co_consts==(True, None): same as abstractclassmethod.__init__ co_consts; both deprecated abstract decorators have the same constant structure — True for __isabstractmethod__ and None for the implicit return; 2 is tied with abstractclassmethod=2 and abstractmethod=2 covered in extra116); co_freevars.__len__()==1 (co_freevars==('__class__',): same as abstractclassmethod=1; both __init__ methods use super() which requires the implicit __class__ free variable; compare: abstractmethod co_freevars.__len__()==0 — abstractmethod is not a class body method so it has no __class__ capture); co_freevars[0].__eq__('__class__')==True (len=9: tied with abstractclassmethod co_freevars[0]='__class__'=9; the symmetry between abstractclassmethod and abstractstaticmethod in co_freevars is total: same name, same index, same length); co_cellvars.__len__()==0 (tied with abstractclassmethod=0; no nested functions in abstractstaticmethod.__init__); co_qualname.__eq__('abstractstaticmethod.__init__')==True (len=29: 'abstractstaticmethod.'=21+'__init__'=8=29; 1 more than abstractclassmethod=28: 'abstractstaticmethod'=20 vs 'abstractclassmethod'=19, diff=1); co_qualname.__len__()==29 (1 more than abstractclassmethod=28; covered in extra91 as a length; this spec adds the equality check); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcasm117

  columns: [id, function, args, expected, description]
  rows:
    - [asm_consts_len,   abstractstaticmethod.__init__.__code__.co_consts.__len__,               [],             2,    "abstractstaticmethod.__init__ co_consts.__len__() == 2 ((True, None); tied with abstractclassmethod=2); verified with Python 3.14.3"]
    - [asm_consts0_eq,   "abstractstaticmethod.__init__.__code__.co_consts[0].__eq__",            [true],         true, "abstractstaticmethod.__init__ co_consts[0] == True (bool; tied with abstractclassmethod co_consts[0]=True); verified with Python 3.14.3"]
    - [asm_freevars_len, abstractstaticmethod.__init__.__code__.co_freevars.__len__,              [],             1,    "abstractstaticmethod.__init__ co_freevars.__len__() == 1 (('__class__',); tied with abstractclassmethod=1); verified with Python 3.14.3"]
    - [asm_fv0_eq,       "abstractstaticmethod.__init__.__code__.co_freevars[0].__eq__",          ["__class__"],  true, "abstractstaticmethod.__init__ co_freevars[0] == '__class__' (len=9; tied with abstractclassmethod); verified with Python 3.14.3"]
    - [asm_cellvars_len, abstractstaticmethod.__init__.__code__.co_cellvars.__len__,              [],             0,    "abstractstaticmethod.__init__ co_cellvars.__len__() == 0 (tied with abstractclassmethod=0); verified with Python 3.14.3"]
    - [asm_qn_eq,        abstractstaticmethod.__init__.__code__.co_qualname.__eq__,               ["abstractstaticmethod.__init__"], true, "abstractstaticmethod.__init__ co_qualname == 'abstractstaticmethod.__init__' (len=29; 1 more than abstractclassmethod=28); verified with Python 3.14.3"]
    - [asm_qn_len,       abstractstaticmethod.__init__.__code__.co_qualname.__len__,              [],             29,   "abstractstaticmethod.__init__ co_qualname.__len__() == 29 (1 more than abstractclassmethod=28); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc deprecated decorator __init__ co_freevars cross-comparison — extra117
#
# Wave 261 theme: abstractclassmethod vs abstractstaticmethod co_freevars vs abstractmethod co_freevars.
#
# abstractclassmethod.__init__ co_freevars == ('__class__',)  len=1
# abstractstaticmethod.__init__ co_freevars == ('__class__',) len=1 (tied)
# abstractmethod co_freevars == ()                            len=0 (differs by 1)
# Both deprecated decorators differ from abstractmethod in co_freevars because they use super().
# ---------------------------------------------------------------------------

table abc_extra117.deprecated_init_co_freevars_cross_compare:
  description: "abc deprecated decorator __init__ co_freevars cross-comparison in abcfv117 namespace — wave 261 theme: abstractclassmethod and abstractstaticmethod both have co_freevars.__len__()==1 while abstractmethod has co_freevars.__len__()==0; abstractclassmethod.__init__ co_freevars.__len__()==1 (('__class__',): 1 free variable from class scope due to super() usage; 1 more than abstractmethod=0); abstractstaticmethod.__init__ co_freevars.__len__()==1 (tied with abstractclassmethod: both deprecated __init__ methods use super() and therefore both capture '__class__' as a free variable; the structural symmetry between abstractclassmethod and abstractstaticmethod is complete — same co_consts, same co_freevars, same co_cellvars, same co_varnames, same co_argcount — they differ only in their qualnames and what they inherit from); abstractmethod co_freevars.__len__()==0 (covered in extra116: abstractmethod is a module-level standalone function not a class body method; it does not use super() so it does not capture '__class__'; 0 < 1); co_freevars[0].__len__()==9 for both deprecated decorators ('__class__'=9: the only free variable in both cases; '__class__'=9 is the same length as 'namespace'=9 from ABCMeta.__new__ in extra115, and 'abstracts'=9 from update_abstractmethods in extra114 — three different abc concepts all with 9-char names); abstractclassmethod.__init__ co_cellvars.__len__()==0 (cross-check: no cell variables, only free variables from enclosing class scope); abstractstaticmethod.__init__ co_cellvars.__len__()==0 (tied: same structure); abstractmethod co_cellvars.__len__()==0 (covered in extra116: also 0, for a different reason — abstractmethod has no closure at all); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcfv117

  columns: [id, function, args, expected, description]
  rows:
    - [acm_fv_len1,   abstractclassmethod.__init__.__code__.co_freevars.__len__,      [],  1,  "abstractclassmethod.__init__ co_freevars.__len__() == 1 (('__class__',); 1 more than abstractmethod=0); verified with Python 3.14.3"]
    - [asm_fv_len1,   abstractstaticmethod.__init__.__code__.co_freevars.__len__,     [],  1,  "abstractstaticmethod.__init__ co_freevars.__len__() == 1 (tied with abstractclassmethod=1; both use super()); verified with Python 3.14.3"]
    - [am_fv_len0,    abstractmethod.__code__.co_freevars.__len__,                    [],  0,  "abstractmethod co_freevars.__len__() == 0 (no closure; covered in extra116; 1 fewer than deprecated decorators); verified with Python 3.14.3"]
    - [acm_fv0_len9,  "abstractclassmethod.__init__.__code__.co_freevars[0].__len__", [],  9,  "abstractclassmethod.__init__ co_freevars[0].__len__() == 9 ('__class__'=9: '__'=2+'class'=5+'__'=2=9); verified with Python 3.14.3"]
    - [asm_fv0_len9,  "abstractstaticmethod.__init__.__code__.co_freevars[0].__len__", [], 9,  "abstractstaticmethod.__init__ co_freevars[0].__len__() == 9 (tied with abstractclassmethod: '__class__'=9); verified with Python 3.14.3"]
    - [acm_cv_len0,   abstractclassmethod.__init__.__code__.co_cellvars.__len__,      [],  0,  "abstractclassmethod.__init__ co_cellvars.__len__() == 0 (no nested functions; cell vs free vars asymmetry); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra117
# ---------------------------------------------------------------------------

invariant abc_extra117.abstractclassmethod_init_co_freevars_len_1:
  description: "abc.abstractclassmethod.__init__.__code__.co_freevars.__len__() == 1 — co_freevars==('__class__',): 1 free variable; abstractclassmethod.__init__ uses super().__init__(callable) to call classmethod.__init__; Python 3 implements super() via an implicit cell variable named '__class__' that is created automatically in the class body and captured by methods that use super(); '__class__' appears in co_freevars (not co_cellvars) of the method code object because '__class__' is defined in the enclosing class scope and captured by the method; this contrasts with abstractmethod which has co_freevars.__len__()==0 (covered in extra116) because abstractmethod is a standalone module-level function and does not use super(); co_freevars.__len__()==1 is 1 more than abstractmethod=0; co_freevars.__len__()==1 is tied with abstractstaticmethod.__init__=1 (both deprecated class methods use super()); co_freevars[0]='__class__'=9 chars (double-underscore dunder name: '__'=2+'class'=5+'__'=2=9); abstractclassmethod.__init__.__code__.co_cellvars.__len__()==0 (no cell vars: abstractclassmethod.__init__ does not define nested functions that would capture its own locals); first standalone abstractclassmethod.__init__ co_freevars length invariant in abcacm117 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abstractclassmethod.__init__.__code__.co_freevars.__len__
  args: []
  expected: 1

invariant abc_extra117.abstractclassmethod_init_fv0_class:
  description: "abc.abstractclassmethod.__init__.__code__.co_freevars[0].__eq__('__class__') returns True — co_freevars[0]='__class__' (len=9); '__class__' is the implicit free variable added by Python 3 to any method that uses super(); abstractclassmethod.__init__ calls super().__init__(callable) to initialize the classmethod wrapper; Python 3 automatically inserts '__class__' as a closure variable for super() — the bytecode uses LOAD_DEREF '__class__' to access the class in which the method is defined; '__class__'=9: '__'=2+'class'=5+'__'=2=9 — a dunder name with double-underscore prefix and suffix; co_freevars=('__class__',).__len__()==1 (only one free variable: just __class__); abstractstaticmethod.__init__ co_freevars[0]='__class__' (len=9, tied: same dunder name for the same reason — abstractstaticmethod.__init__ also uses super().__init__(callable)); compare: abstractmethod has co_freevars.__len__()==0 — no free variables because it is a standalone function not using super(); len('__class__')=9 is tied with 'namespace'=9 from ABCMeta.__new__ (extra115) and 'abstracts'=9 from update_abstractmethods (extra114); first standalone abstractclassmethod.__init__ co_freevars[0] equality invariant in abcacm117 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "abstractclassmethod.__init__.__code__.co_freevars[0].__eq__"
  args: ["__class__"]
  expected: true

invariant abc_extra117.abstractstaticmethod_init_fv0_class:
  description: "abc.abstractstaticmethod.__init__.__code__.co_freevars[0].__eq__('__class__') returns True — co_freevars[0]='__class__' (len=9; tied with abstractclassmethod.__init__ co_freevars[0]='__class__'=9); abstractstaticmethod.__init__ calls super().__init__(callable) to initialize the staticmethod wrapper; the same super()-driven '__class__' capture mechanism applies: Python 3 inserts '__class__' as a closure free variable for any method using super(); abstractstaticmethod.__init__ co_freevars==('__class__',) is structurally identical to abstractclassmethod.__init__ co_freevars==('__class__',) — same tuple, same single element, same string value, same length; the symmetry is total: both deprecated abstract class method decorators have the same co_consts==(True,None), co_freevars==('__class__',), co_cellvars==(), co_varnames==('self','callable'), co_argcount==2; they differ only in their qualnames ('abstractclassmethod.__init__'=28 vs 'abstractstaticmethod.__init__'=29) and their inheritance chain (from classmethod vs staticmethod); first standalone abstractstaticmethod.__init__ co_freevars[0] equality invariant in abcasm117 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "abstractstaticmethod.__init__.__code__.co_freevars[0].__eq__"
  args: ["__class__"]
  expected: true

invariant abc_extra117.abstractclassmethod_init_co_consts_len_2:
  description: "abc.abstractclassmethod.__init__.__code__.co_consts.__len__() == 2 — co_consts==(True, None): len=2; abstractclassmethod.__init__ stores self.__isabstractmethod__=True using the literal True (co_consts[0]=True) and implicitly returns None (co_consts[1]=None); compare: abstractmethod co_consts==(docstring, True) len=2 (covered in extra116: same length=2 but different content: abstractmethod has docstring at index 0 while abstractclassmethod.__init__ has True at index 0; this positional difference reflects that abstractmethod's code object is the function itself with its docstring while abstractclassmethod.__init__ is a method within a class where the docstring is handled differently); abstractstaticmethod.__init__ co_consts.__len__()==2 (tied with abstractclassmethod=2: both have (True, None) in co_consts); compare: ABCMeta.__instancecheck__ co_consts.__len__()==1 (1 fewer: covered in extra116; __instancecheck__ is a delegation wrapper with only the docstring constant, no True literal); the pattern 2 for deprecated abstract decorator __init__ methods vs 1 for delegation wrappers (__instancecheck__, __subclasscheck__) vs 2 for abstractmethod (which uses True as a bytecode constant): all three categories have small co_consts (1 or 2); first standalone abstractclassmethod.__init__ co_consts length invariant in abcacm117 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abstractclassmethod.__init__.__code__.co_consts.__len__
  args: []
  expected: 2

invariant abc_extra117.abstractstaticmethod_init_co_qualname_len_29:
  description: "abc.abstractstaticmethod.__init__.__code__.co_qualname.__len__() == 29 — 'abstractstaticmethod.__init__'=29: 'abstractstaticmethod.'=21+'__init__'=8=29; compare: abstractclassmethod.__init__ qualname len=28 ('abstractclassmethod.__init__'=28: 'abstractclassmethod.'=20+'__init__'=8=28; 1 shorter because 'abstractstaticmethod'=20 vs 'abstractclassmethod'=19, diff=1); the qualname length difference of 1 between abstractstaticmethod=29 and abstractclassmethod=28 propagates from the class name difference: 'abstractstaticmethod'=20 vs 'abstractclassmethod'=19 (diff=1: 'static'=6 vs 'class'=5, diff=1: 'static' is 1 char longer than 'class'); co_qualname==__code__.co_qualname=='/abstractstaticmethod.__init__' was covered in extra91 as a length (29); this standalone invariant provides the explicit length value; abstractstaticmethod.__init__.__code__.co_qualname.__eq__('abstractstaticmethod.__init__')==True (covered in this spec's table abcasm117); length ordering in abc deprecated decorator __init__ qualnames: abstractclassmethod=28 < abstractstaticmethod=29 (diff=1: 'class'=5 vs 'static'=6 in the middle segment); both are the longest co_qualname values seen in abc specs: abstractclassmethod.__init__=28 and abstractstaticmethod.__init__=29 exceed ABCMeta.__new__.__code__.co_qualname='ABCMeta.__new__'=15 by 13 and 14 chars respectively; first standalone abstractstaticmethod.__init__ co_qualname length invariant in abcasm117 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abstractstaticmethod.__init__.__code__.co_qualname.__len__
  args: []
  expected: 29

