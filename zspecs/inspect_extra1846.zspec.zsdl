spec: inspect_extra1846
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module reference"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect.zspec.zsdl — covers class_names, module attribute checks, Parameter.kind enum values"
    - "inspect_extra.zspec.zsdl — covers __name__, __module__, qualname checks"
  notes:
    - "Wave 570 theme: arithmetic operator protocol (__add__/__sub__/__mul__/__truediv__/__floordiv__/__mod__) and comparison operator protocol (__gt__/__ge__/__le__/__ne__/__lt__/__eq__)."
    - "inspect.Parameter.__dict__.__contains__('__add__') == False — Parameter is a Python class with no arithmetic protocol."
    - "inspect.Parameter.__dict__.__contains__('__eq__') == True — Parameter explicitly defines __eq__ for structural equality comparison."
    - "inspect.Parameter.__dict__.__contains__('__or__') == False — Parameter does not implement the bitwise OR / union type operator."
    - "inspect.Signature.__dict__.__contains__('__eq__') == True — Signature explicitly defines __eq__ for structural equality."
    - "inspect.BoundArguments.__dict__.__contains__('__eq__') == False — BoundArguments does not define __eq__; uses object identity."
    - "inspect.__dict__.__contains__('ArgSpec') == False — ArgSpec was removed in Python 3.11."
    - "inspect.__dict__.__contains__('FullArgSpec') == True — FullArgSpec is a namedtuple added in Python 3.0."
    - "inspect.__dict__.__contains__('FrameInfo') == True — FrameInfo is a named tuple returned by stack() and related functions."
    - "inspect.__dict__.__contains__('ClosureVars') == True — ClosureVars is a namedtuple returned by getclosurevars()."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operators for inspect types
#
# inspect.Parameter, Signature, and BoundArguments are all pure Python classes.
# None define arithmetic dunder methods in their own __dict__.
# __or__ is also excluded (it is not part of the inspect protocol).
# ---------------------------------------------------------------------------

table inspect_extra1846.arithmetic_operators:
  description: "Arithmetic operator dunder methods absent from inspect type own __dict__"
  kind: python_call_eq
  category: arithmetic_operators
  id_prefix: in1846

  columns: [id, function, args, expected]
  rows:
    - ["in1846001", inspect.Parameter.__dict__.__contains__,      ["__add__"], false]
    - ["in1846002", inspect.Parameter.__dict__.__contains__,      ["__sub__"], false]
    - ["in1846003", inspect.Signature.__dict__.__contains__,      ["__add__"], false]
    - ["in1846004", inspect.Signature.__dict__.__contains__,      ["__mul__"], false]
    - ["in1846005", inspect.BoundArguments.__dict__.__contains__,  ["__add__"], false]
    - ["in1846006", inspect.BoundArguments.__dict__.__contains__,  ["__mul__"], false]
    - ["in1846007", inspect.Parameter.__dict__.__contains__,      ["__or__"],  false]
    - ["in1846008", inspect.Signature.__dict__.__contains__,      ["__or__"],  false]

# ---------------------------------------------------------------------------
# Table 2: comparison operators for inspect types
#
# Parameter defines __eq__ for structural equality but no ordering operators.
# Signature defines __eq__ for structural equality but no ordering operators.
# BoundArguments does not define __eq__ or any comparison operators.
# ---------------------------------------------------------------------------

table inspect_extra1846.comparison_operators:
  description: "Comparison operator dunder method presence in inspect type own __dict__"
  kind: python_call_eq
  category: comparison_operators
  id_prefix: in1846

  columns: [id, function, args, expected]
  rows:
    - ["in1846009", inspect.Parameter.__dict__.__contains__,      ["__eq__"], true]
    - ["in1846010", inspect.Parameter.__dict__.__contains__,      ["__lt__"], false]
    - ["in1846011", inspect.Parameter.__dict__.__contains__,      ["__gt__"], false]
    - ["in1846012", inspect.Signature.__dict__.__contains__,      ["__eq__"], true]
    - ["in1846013", inspect.Signature.__dict__.__contains__,      ["__lt__"], false]
    - ["in1846014", inspect.BoundArguments.__dict__.__contains__,  ["__eq__"], false]
    - ["in1846015", inspect.BoundArguments.__dict__.__contains__,  ["__lt__"], false]
    - ["in1846016", inspect.BoundArguments.__dict__.__contains__,  ["__ne__"], false]

# ---------------------------------------------------------------------------
# Table 3: inspect module class and function attribute membership
#
# Verifies public class and function names in the inspect module namespace.
# ArgSpec was removed in Python 3.11 and is expected to be absent.
# ---------------------------------------------------------------------------

table inspect_extra1846.inspect_module_classes:
  description: "Public inspect module class and function symbols in inspect.__dict__"
  kind: python_call_eq
  category: module_attrs
  id_prefix: in1846

  columns: [id, function, args, expected]
  rows:
    - ["in1846017", inspect.__dict__.__contains__, ["Parameter"],     true]
    - ["in1846018", inspect.__dict__.__contains__, ["Signature"],     true]
    - ["in1846019", inspect.__dict__.__contains__, ["BoundArguments"], true]
    - ["in1846020", inspect.__dict__.__contains__, ["FullArgSpec"],   true]
    - ["in1846021", inspect.__dict__.__contains__, ["ArgSpec"],       false]
    - ["in1846022", inspect.__dict__.__contains__, ["FrameInfo"],     true]
    - ["in1846023", inspect.__dict__.__contains__, ["Traceback"],     true]
    - ["in1846024", inspect.__dict__.__contains__, ["ClosureVars"],   true]
    - ["in1846025", inspect.__dict__.__contains__, ["getfile"],       true]
    - ["in1846026", inspect.__dict__.__contains__, ["getmodule"],     true]
