spec: asyncio_extra352
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio-exceptions.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-exceptions.html — asyncio exceptions documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "asyncio.CancelledError base class is BaseException (not Exception) since Python 3.8"
    - "asyncio.TimeoutError is an alias for the built-in TimeoutError (module=builtins, base=OSError)"
    - "asyncio.InvalidStateError and asyncio.LimitOverrunError both derive from Exception"
    - "asyncio.SendfileNotAvailableError derives from RuntimeError"
    - "asyncio.IncompleteReadError derives from EOFError"
    - "CancelledError, InvalidStateError, SendfileNotAvailableError, IncompleteReadError, LimitOverrunError have module asyncio.exceptions"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra352.exception_names:
  description: "Verify __name__ attribute of asyncio exception classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio352n

  columns: [id, function, args, expected]
  rows:
    - [aio352n001, asyncio.CancelledError.__name__.__eq__, ["CancelledError"], true]
    - [aio352n002, asyncio.TimeoutError.__name__.__eq__, ["TimeoutError"], true]
    - [aio352n003, asyncio.InvalidStateError.__name__.__eq__, ["InvalidStateError"], true]
    - [aio352n004, asyncio.SendfileNotAvailableError.__name__.__eq__, ["SendfileNotAvailableError"], true]
    - [aio352n005, asyncio.IncompleteReadError.__name__.__eq__, ["IncompleteReadError"], true]
    - [aio352n006, asyncio.LimitOverrunError.__name__.__eq__, ["LimitOverrunError"], true]

table asyncio_extra352.exception_modules:
  description: "Verify __module__ attribute of asyncio exception classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio352m

  columns: [id, function, args, expected]
  rows:
    - [aio352m001, asyncio.CancelledError.__module__.__eq__, ["asyncio.exceptions"], true]
    - [aio352m002, asyncio.TimeoutError.__module__.__eq__, ["builtins"], true]
    - [aio352m003, asyncio.InvalidStateError.__module__.__eq__, ["asyncio.exceptions"], true]
    - [aio352m004, asyncio.SendfileNotAvailableError.__module__.__eq__, ["asyncio.exceptions"], true]
    - [aio352m005, asyncio.IncompleteReadError.__module__.__eq__, ["asyncio.exceptions"], true]
    - [aio352m006, asyncio.LimitOverrunError.__module__.__eq__, ["asyncio.exceptions"], true]

table asyncio_extra352.exception_bases:
  description: "Verify __bases__[0].__name__ (immediate base class name) of asyncio exception classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio352b

  columns: [id, function, args, expected]
  rows:
    - [aio352b001, "asyncio.CancelledError.__bases__[0].__name__.__eq__", ["BaseException"], true]
    - [aio352b002, "asyncio.TimeoutError.__bases__[0].__name__.__eq__", ["OSError"], true]
    - [aio352b003, "asyncio.InvalidStateError.__bases__[0].__name__.__eq__", ["Exception"], true]
    - [aio352b004, "asyncio.SendfileNotAvailableError.__bases__[0].__name__.__eq__", ["RuntimeError"], true]
    - [aio352b005, "asyncio.IncompleteReadError.__bases__[0].__name__.__eq__", ["EOFError"], true]
    - [aio352b006, "asyncio.LimitOverrunError.__bases__[0].__name__.__eq__", ["Exception"], true]
