spec: uuid_extra1066
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid1/uuid3/uuid4/uuid5 module and qualname attributes, UUID dunder method class names, and UUID raises for bad input"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1066.generator_function_module_and_qualname:
  description: "uuid module generator function __module__ and __qualname__ identity"
  kind: python_call_eq
  category: generator_function_attrs
  id_prefix: uu1066gf
  columns: [id, function, args, expected]
  rows:
    - [uu1066gf001, uuid.uuid1.__module__.__eq__,          ["uuid"],  true]
    - [uu1066gf002, uuid.uuid3.__module__.__eq__,          ["uuid"],  true]
    - [uu1066gf003, uuid.uuid4.__module__.__eq__,          ["uuid"],  true]
    - [uu1066gf004, uuid.uuid5.__module__.__eq__,          ["uuid"],  true]
    - [uu1066gf005, uuid.uuid1.__module__.__class__.__name__.__eq__,  ["str"], true]
    - [uu1066gf006, uuid.uuid4.__module__.__class__.__name__.__eq__,  ["str"], true]
    - [uu1066gf007, uuid.uuid3.__class__.__name__.__eq__,  ["function"], true]
    - [uu1066gf008, uuid.uuid5.__class__.__name__.__eq__,  ["function"], true]

table uuid_extra1066.uuid_dunder_class_names:
  description: "uuid.UUID dunder method __class__.__name__ and qualname class name checks"
  kind: python_call_eq
  category: dunder_class_names
  id_prefix: uu1066dc
  columns: [id, function, args, expected]
  rows:
    - [uu1066dc001, uuid.UUID.__str__.__class__.__name__.__eq__,      ["function"],  true]
    - [uu1066dc002, uuid.UUID.__int__.__class__.__name__.__eq__,      ["function"],  true]
    - [uu1066dc003, uuid.UUID.__repr__.__class__.__name__.__eq__,     ["function"],  true]
    - [uu1066dc004, uuid.UUID.__hash__.__class__.__name__.__eq__,     ["function"],  true]
    - [uu1066dc005, uuid.UUID.__eq__.__class__.__name__.__eq__,       ["function"],  true]
    - [uu1066dc006, uuid.UUID.__lt__.__class__.__name__.__eq__,       ["function"],  true]
    - [uu1066dc007, uuid.UUID.__str__.__qualname__.__class__.__name__.__eq__,  ["str"], true]
    - [uu1066dc008, uuid.UUID.__int__.__qualname__.__class__.__name__.__eq__,  ["str"], true]
    - [uu1066dc009, uuid.UUID.__repr__.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [uu1066dc010, uuid.UUID.__hash__.__qualname__.__class__.__name__.__eq__, ["str"], true]

table uuid_extra1066.uuid_raises_bad_input:
  description: "uuid.UUID raises ValueError for malformed input strings"
  kind: python_call_raises
  category: uuid_bad_input
  id_prefix: uu1066rb
  columns: [id, function, args, exception]
  rows:
    - [uu1066rb001, uuid.UUID, ["not-a-uuid"],         "ValueError"]
    - [uu1066rb002, uuid.UUID, [""],                   "ValueError"]
    - [uu1066rb003, uuid.UUID, ["12345678"],            "ValueError"]
    - [uu1066rb004, uuid.UUID, ["zzzzzzzz-zzzz-zzzz-zzzz-zzzzzzzzzzzz"], "ValueError"]
    - [uu1066rb005, uuid.UUID, ["00000000-0000-0000-0000-00000000000g"], "ValueError"]
