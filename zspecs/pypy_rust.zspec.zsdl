spec: pypy_rust
version: ">=3.9"
backend: rust_module(pypy_rust)

docs: https://www.pypy.org/

provenance:
  derived_from:
    - "https://www.pypy.org/ — PyPy Python interpreter"
  notes:
    - "PyPy is a fast Python interpreter."
    - "pypy module is not typically importable in CPython."
    - "Check via platform.python_implementation()."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pypy_rust.python_impl_nonempty:
  description: "platform.python_implementation() is non-empty"
  category: platform
  kind: python_call_eq
  function: pypy_python_impl_nonempty
  args: []
  expected: true

invariant pypy_rust.python_version_nonempty:
  description: "platform.python_version() is non-empty"
  category: platform
  kind: python_call_eq
  function: pypy_python_version_nonempty
  args: []
  expected: true

invariant pypy_rust.sys_version_nonempty:
  description: "sys.version is non-empty"
  category: platform
  kind: python_call_eq
  function: pypy_sys_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T04:14:10Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
