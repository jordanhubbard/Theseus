spec: itertools_extra149
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.__dict__.__class__.__name__ 'dict' len 28; itertools.chain.__dict__.__class__.__name__ 'mappingproxy' len 8; itertools.product.__dict__.__class__.__name__ 'mappingproxy' len 7; itertools.count.__dict__.__class__.__name__ 'mappingproxy' len 7; itertools.cycle.__dict__ len 6; itertools.repeat.__dict__ len 8; itertools.__name__ 'itertools' len 9 (Wave 278)."
    - "itertools.__dict__.__class__.__name__ == 'dict' — the module __dict__ for a built-in C module is a plain dict (not a mappingproxy). len(itertools.__dict__) == 28. Verified with Python 3.14.3."
    - "itertools.chain.__dict__.__class__.__name__ == 'mappingproxy'; len == 8 — the class dict of a C extension type is a mappingproxy. Verified with Python 3.14.3."
    - "itertools.product.__dict__.__class__.__name__ == 'mappingproxy'; len == 7. Verified with Python 3.14.3."
    - "itertools.count.__dict__.__class__.__name__ == 'mappingproxy'; len == 7. Verified with Python 3.14.3."
    - "itertools.cycle.__dict__ len == 6; itertools.repeat.__dict__ len == 8. Verified with Python 3.14.3."
    - "itertools.__name__ == 'itertools' (len 9) — the module __name__ attribute for the itertools built-in module. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.__dict__ — module dict is a plain dict
#
# Wave 278 theme: itertools.__dict__.__class__.__name__ and len.
#
# itertools.__dict__.__class__.__name__ == 'dict'
# len(itertools.__dict__) == 28
#
# Unlike C extension type class dicts (mappingproxy), the module __dict__
# for a built-in C module is a plain dict. In Python 3.14.3 it has 28 entries.
# New to extra149.
# ---------------------------------------------------------------------------

table itertools_extra149.module_dict_identity:
  description: "itertools.__dict__: plain dict (not mappingproxy), len 28; module-level dict for a C built-in module; wave 278; new to extra149"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsmoddict149

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_class_eq_dict,
       "__dict__.__class__.__name__.__eq__",
       ["dict"],
       true,
       "itertools.__dict__.__class__.__name__.__eq__('dict') == True — the module __dict__ of a built-in C extension module is a plain Python dict (not a mappingproxy); __class__.__name__ is 'dict'; str.__eq__('dict') returns True; new to extra149"]
    - [module_dict_len_eq_28,
       "__dict__.__len__",
       [],
       28,
       "itertools.__dict__.__len__() == 28 — itertools has 28 entries in its module __dict__ in Python 3.14.3; these include all exported C types plus dunder attributes like __name__, __doc__, __spec__, __loader__, __package__; len == 28; verified with Python 3.14.3; new to extra149"]
    - [module_name_eq_itertools,
       "__name__.__eq__",
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — the module __name__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra149"]
    - [module_name_len_eq_9,
       "__name__.__len__",
       [],
       9,
       "itertools.__name__.__len__() == 9 — __name__ is 'itertools' which has 9 characters; len('itertools') == 9; new to extra149"]

# ---------------------------------------------------------------------------
# Table 2: itertools C-type __dict__ — mappingproxy identity and lengths
#
# Wave 278 theme: the class __dict__ of C extension types is a mappingproxy.
#
# itertools.chain.__dict__.__class__.__name__ == 'mappingproxy'
# len(itertools.chain.__dict__) == 8
# len(itertools.product.__dict__) == 7
# len(itertools.count.__dict__) == 7
#
# Each itertools C extension type has a class dict exposed as a read-only
# mappingproxy. New to extra149.
# ---------------------------------------------------------------------------

table itertools_extra149.ctype_dict_mappingproxy:
  description: "itertools C-type __dict__: mappingproxy; chain len 8, product len 7, count len 7; C extension type class dicts are mappingproxies; wave 278; new to extra149"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolstypedict149

  columns: [id, function, args, expected, description]
  rows:
    - [chain_dict_class_eq_mappingproxy,
       "chain.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "itertools.chain.__dict__.__class__.__name__.__eq__('mappingproxy') == True — the class __dict__ of a C extension type is a read-only mappingproxy of its tp_dict; chain.__dict__.__class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra149"]
    - [chain_dict_len_eq_8,
       "chain.__dict__.__len__",
       [],
       8,
       "itertools.chain.__dict__.__len__() == 8 — chain has 8 entries in its class dict: __new__, __iter__, __next__, __reduce__, from_iterable, __doc__, __module__, __dict__; len == 8; verified with Python 3.14.3; new to extra149"]
    - [product_dict_class_eq_mappingproxy,
       "product.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "itertools.product.__dict__.__class__.__name__.__eq__('mappingproxy') == True — product's class __dict__ is a mappingproxy; str.__eq__('mappingproxy') returns True; new to extra149"]
    - [product_dict_len_eq_7,
       "product.__dict__.__len__",
       [],
       7,
       "itertools.product.__dict__.__len__() == 7 — product has 7 entries in its class dict in Python 3.14.3; len == 7; verified with Python 3.14.3; new to extra149"]
    - [count_dict_class_eq_mappingproxy,
       "count.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "itertools.count.__dict__.__class__.__name__.__eq__('mappingproxy') == True — count's class __dict__ is a mappingproxy; str.__eq__('mappingproxy') returns True; new to extra149"]
    - [count_dict_len_eq_7,
       "count.__dict__.__len__",
       [],
       7,
       "itertools.count.__dict__.__len__() == 7 — count has 7 entries in its class dict in Python 3.14.3; len == 7; verified with Python 3.14.3; new to extra149"]

# ---------------------------------------------------------------------------
# Table 3: itertools.cycle and itertools.repeat __dict__ lengths
#
# Wave 278 theme: cycle and repeat class dict mappingproxy lengths.
#
# len(itertools.cycle.__dict__) == 6
# len(itertools.repeat.__dict__) == 8
#
# New to extra149.
# ---------------------------------------------------------------------------

table itertools_extra149.cycle_repeat_dict_lens:
  description: "itertools.cycle.__dict__ len 6; itertools.repeat.__dict__ len 8; both are C extension type class dicts (mappingproxy); wave 278; new to extra149"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscyclerep149

  columns: [id, function, args, expected, description]
  rows:
    - [cycle_dict_class_eq_mappingproxy,
       "cycle.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "itertools.cycle.__dict__.__class__.__name__.__eq__('mappingproxy') == True — cycle's class __dict__ is a mappingproxy; str.__eq__('mappingproxy') returns True; new to extra149"]
    - [cycle_dict_len_eq_6,
       "cycle.__dict__.__len__",
       [],
       6,
       "itertools.cycle.__dict__.__len__() == 6 — cycle has 6 entries in its class dict in Python 3.14.3; len == 6; verified with Python 3.14.3; new to extra149"]
    - [repeat_dict_class_eq_mappingproxy,
       "repeat.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "itertools.repeat.__dict__.__class__.__name__.__eq__('mappingproxy') == True — repeat's class __dict__ is a mappingproxy; str.__eq__('mappingproxy') returns True; new to extra149"]
    - [repeat_dict_len_eq_8,
       "repeat.__dict__.__len__",
       [],
       8,
       "itertools.repeat.__dict__.__len__() == 8 — repeat has 8 entries in its class dict in Python 3.14.3; len == 8; verified with Python 3.14.3; new to extra149"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra149
# ---------------------------------------------------------------------------

invariant itertools_extra149.module_dict_class_dict:
  description: "itertools.__dict__.__class__.__name__ == 'dict' — module __dict__ of a C built-in is a plain dict; wave 278; new to extra149"
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant itertools_extra149.module_dict_len:
  description: "len(itertools.__dict__) == 28 — itertools module dict has 28 entries; wave 278; new to extra149"
  kind: python_call_eq
  function: __dict__.__len__
  args: []
  expected: 28

invariant itertools_extra149.module_name_eq:
  description: "itertools.__name__ == 'itertools' — module __name__ attribute; wave 278; new to extra149"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra149.module_name_len:
  description: "len(itertools.__name__) == 9 — 'itertools' has 9 characters; wave 278; new to extra149"
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 9

invariant itertools_extra149.chain_dict_class_mappingproxy:
  description: "itertools.chain.__dict__.__class__.__name__ == 'mappingproxy' — C extension type class dict is a mappingproxy; wave 278; new to extra149"
  kind: python_call_eq
  function: chain.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant itertools_extra149.chain_dict_len:
  description: "len(itertools.chain.__dict__) == 8 — chain class dict has 8 entries; wave 278; new to extra149"
  kind: python_call_eq
  function: chain.__dict__.__len__
  args: []
  expected: 8

invariant itertools_extra149.product_dict_len:
  description: "len(itertools.product.__dict__) == 7 — product class dict has 7 entries; wave 278; new to extra149"
  kind: python_call_eq
  function: product.__dict__.__len__
  args: []
  expected: 7

invariant itertools_extra149.count_dict_len:
  description: "len(itertools.count.__dict__) == 7 — count class dict has 7 entries; wave 278; new to extra149"
  kind: python_call_eq
  function: count.__dict__.__len__
  args: []
  expected: 7

invariant itertools_extra149.cycle_dict_len:
  description: "len(itertools.cycle.__dict__) == 6 — cycle class dict has 6 entries; wave 278; new to extra149"
  kind: python_call_eq
  function: cycle.__dict__.__len__
  args: []
  expected: 6

invariant itertools_extra149.repeat_dict_len:
  description: "len(itertools.repeat.__dict__) == 8 — repeat class dict has 8 entries; wave 278; new to extra149"
  kind: python_call_eq
  function: repeat.__dict__.__len__
  args: []
  expected: 8
