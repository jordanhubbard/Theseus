spec: decimal_extra124
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal conversion method __qualname__ and __name__ values."
    - "decimal.Decimal.to_eng_string.__qualname__ = 'Decimal.to_eng_string' (len=21)."
    - "decimal.Decimal.to_integral.__qualname__ = 'Decimal.to_integral' (len=19)."
    - "decimal.Decimal.to_integral_value.__qualname__ = 'Decimal.to_integral_value' (len=25)."
    - "decimal.Decimal.to_integral_exact.__qualname__ = 'Decimal.to_integral_exact' (len=25)."
    - "decimal.Decimal.normalize.__qualname__ = 'Decimal.normalize' (len=17)."
    - "decimal.Decimal.quantize.__qualname__ = 'Decimal.quantize' (len=16)."
    - "decimal.Decimal.same_quantum.__qualname__ = 'Decimal.same_quantum' (len=20)."
    - "decimal.Decimal.sqrt.__qualname__ = 'Decimal.sqrt' (len=12)."
    - "All these methods are C extension method_descriptor objects."
    - "to_integral_value and to_integral_exact share the same qualname length (25)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.to_eng_string, to_integral, normalize, quantize qualnames
# to_eng_string.__qualname__ == 'Decimal.to_eng_string' (len 21).
# to_integral.__qualname__ == 'Decimal.to_integral' (len 19).
# normalize.__qualname__ == 'Decimal.normalize' (len 17).
# quantize.__qualname__ == 'Decimal.quantize' (len 16).
# ---------------------------------------------------------------------------

table decimal_extra124.Decimal_conversion_qualnames_basic:
  description: "decimal.Decimal conversion method __qualname__ values: to_eng_string='Decimal.to_eng_string'(21), to_integral='Decimal.to_integral'(19), normalize='Decimal.normalize'(17), quantize='Decimal.quantize'(16)"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: decconv124

  columns: [id, function, args, expected]
  rows:
    - [tes_qname_eq,  Decimal.to_eng_string.__qualname__.__eq__, ["Decimal.to_eng_string"], true]
    - [tes_qname_len, Decimal.to_eng_string.__qualname__.__len__,[],                        21]
    - [ti_qname_eq,   Decimal.to_integral.__qualname__.__eq__,   ["Decimal.to_integral"],   true]
    - [ti_qname_len,  Decimal.to_integral.__qualname__.__len__,  [],                        19]
    - [norm_qname_eq, Decimal.normalize.__qualname__.__eq__,     ["Decimal.normalize"],     true]
    - [norm_qname_len,Decimal.normalize.__qualname__.__len__,    [],                        17]
    - [quant_qname_eq,Decimal.quantize.__qualname__.__eq__,      ["Decimal.quantize"],      true]
    - [quant_qname_len,Decimal.quantize.__qualname__.__len__,    [],                        16]
    - [tes_not_bare,  Decimal.to_eng_string.__qualname__.__eq__, ["to_eng_string"],          false]

# ---------------------------------------------------------------------------
# decimal.Decimal.to_integral_value and to_integral_exact qualnames
# Both have __qualname__ == 'Decimal.to_integral_value' and
# 'Decimal.to_integral_exact' respectively, both len 25.
# ---------------------------------------------------------------------------

table decimal_extra124.Decimal_to_integral_variants:
  description: "decimal.Decimal to_integral_value and to_integral_exact __qualname__ values: both have len 25"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: decconv124

  columns: [id, function, args, expected]
  rows:
    - [tiv_qname_eq,  Decimal.to_integral_value.__qualname__.__eq__,  ["Decimal.to_integral_value"],  true]
    - [tiv_qname_len, Decimal.to_integral_value.__qualname__.__len__,  [],                            25]
    - [tie_qname_eq,  Decimal.to_integral_exact.__qualname__.__eq__,  ["Decimal.to_integral_exact"],  true]
    - [tie_qname_len, Decimal.to_integral_exact.__qualname__.__len__,  [],                            25]
    - [tiv_not_exact, Decimal.to_integral_value.__qualname__.__eq__,  ["Decimal.to_integral_exact"],  false]
    - [tie_not_value, Decimal.to_integral_exact.__qualname__.__eq__,  ["Decimal.to_integral_value"],  false]
    - [tiv_not_bare,  Decimal.to_integral_value.__qualname__.__eq__,  ["to_integral_value"],          false]

# ---------------------------------------------------------------------------
# decimal.Decimal.same_quantum and sqrt qualnames and __name__ values
# same_quantum.__qualname__ == 'Decimal.same_quantum' (len 20).
# same_quantum.__name__ == 'same_quantum' (len 12).
# sqrt.__qualname__ == 'Decimal.sqrt' (len 12).
# sqrt.__name__ == 'sqrt' (len 4).
# All are C extension method_descriptor objects.
# ---------------------------------------------------------------------------

table decimal_extra124.Decimal_same_quantum_sqrt:
  description: "decimal.Decimal same_quantum and sqrt: qualnames and __name__ values"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: decconv124

  columns: [id, function, args, expected]
  rows:
    - [sq_qname_eq,   Decimal.same_quantum.__qualname__.__eq__,  ["Decimal.same_quantum"],  true]
    - [sq_qname_len,  Decimal.same_quantum.__qualname__.__len__, [],                        20]
    - [sq_name_eq,    Decimal.same_quantum.__name__.__eq__,      ["same_quantum"],          true]
    - [sq_name_len,   Decimal.same_quantum.__name__.__len__,     [],                        12]
    - [sqrt_qname_eq, Decimal.sqrt.__qualname__.__eq__,          ["Decimal.sqrt"],          true]
    - [sqrt_qname_len,Decimal.sqrt.__qualname__.__len__,         [],                        12]
    - [sqrt_name_eq,  Decimal.sqrt.__name__.__eq__,              ["sqrt"],                  true]
    - [sqrt_name_len, Decimal.sqrt.__name__.__len__,             [],                         4]
    - [sqrt_not_bare, Decimal.sqrt.__qualname__.__eq__,          ["sqrt"],                  false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra124.Decimal.to_eng_string_qualname_len_21:
  description: "decimal.Decimal.to_eng_string.__qualname__.__len__() == 21 ('Decimal.to_eng_string' has 21 characters: 'Decimal.'(8) + 'to_eng_string'(13) = 21)"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.to_eng_string.__qualname__.__len__
  args: []
  expected: 21

invariant decimal_extra124.Decimal.to_integral_value_qualname_len_25:
  description: "decimal.Decimal.to_integral_value.__qualname__.__len__() == 25 ('Decimal.to_integral_value' has 25 characters: 'Decimal.'(8) + 'to_integral_value'(17) = 25)"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.to_integral_value.__qualname__.__len__
  args: []
  expected: 25

invariant decimal_extra124.Decimal.to_integral_exact_qualname_len_25:
  description: "decimal.Decimal.to_integral_exact.__qualname__.__len__() == 25 ('Decimal.to_integral_exact' has 25 characters: 'Decimal.'(8) + 'to_integral_exact'(17) = 25; tied with to_integral_value)"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.to_integral_exact.__qualname__.__len__
  args: []
  expected: 25

invariant decimal_extra124.Decimal.normalize_qualname_eq:
  description: "decimal.Decimal.normalize.__qualname__ == 'Decimal.normalize' (len=17; normalize reduces the Decimal to its shortest equivalent form; it is a C extension method_descriptor on the Decimal type)"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.normalize.__qualname__.__eq__
  args: ["Decimal.normalize"]
  expected: true

invariant decimal_extra124.Decimal.sqrt_qualname_eq:
  description: "decimal.Decimal.sqrt.__qualname__ == 'Decimal.sqrt' (len=12; the shortest conversion method qualname in this spec; sqrt computes the square root to full precision per the current context)"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.sqrt.__qualname__.__eq__
  args: ["Decimal.sqrt"]
  expected: true
