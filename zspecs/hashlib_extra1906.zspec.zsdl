spec: hashlib_extra1906
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
  notes:
    - "Wave 574 (_extra1906): __reversed__ reverse iteration protocol; __missing__ dict protocol; __match_args__ structural pattern matching (3.10+); __qualname__ values."
    - "hashlib exposes C-extension constructor functions (openssl_md5, openssl_sha256, etc.) whose __qualname__ reflects the C-level name."
    - "The HASH type is accessible via _hashlib.HASH; it is a C extension type and has no __reversed__, __missing__, or __match_args__ in its own __dict__."
    - "hashlib.md5.__qualname__ == 'openssl_md5' — C-level builtin_function_or_method, not a class."
    - "hashlib.sha256.__qualname__ == 'openssl_sha256'; hashlib.sha512.__qualname__ == 'openssl_sha512'."
    - "The HASH type's own __dict__ contains digest, hexdigest, update, copy, block_size, digest_size, name."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra1906.hash_type_reversed_missing:
  description: "HASH C-extension type __reversed__ and __missing__ dict-presence checks via _hashlib.HASH"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1906

  columns: [id, function, args, expected]
  rows:
    - ["hl1906001", "hashlib.new.__class__.__dict__.__contains__", ["__reversed__"], false]
    - ["hl1906002", "hashlib.new.__class__.__dict__.__contains__", ["__missing__"], false]

table hashlib_extra1906.hash_constructor_qualnames:
  description: "hashlib constructor function __qualname__ values (C-level builtin_function_or_method)"
  kind: python_call_eq
  category: qualname_values
  id_prefix: hl1906

  columns: [id, function, args, expected]
  rows:
    - ["hl1906011", "hashlib.md5.__qualname__", [], "openssl_md5"]
    - ["hl1906012", "hashlib.sha1.__qualname__", [], "openssl_sha1"]
    - ["hl1906013", "hashlib.sha224.__qualname__", [], "openssl_sha224"]
    - ["hl1906014", "hashlib.sha256.__qualname__", [], "openssl_sha256"]
    - ["hl1906015", "hashlib.sha384.__qualname__", [], "openssl_sha384"]
    - ["hl1906016", "hashlib.sha512.__qualname__", [], "openssl_sha512"]

table hashlib_extra1906.hash_constructor_names:
  description: "hashlib constructor function __name__ values"
  kind: python_call_eq
  category: attr_values
  id_prefix: hl1906

  columns: [id, function, args, expected]
  rows:
    - ["hl1906021", "hashlib.md5.__name__", [], "openssl_md5"]
    - ["hl1906022", "hashlib.sha1.__name__", [], "openssl_sha1"]
    - ["hl1906023", "hashlib.sha224.__name__", [], "openssl_sha224"]
    - ["hl1906024", "hashlib.sha256.__name__", [], "openssl_sha256"]
    - ["hl1906025", "hashlib.sha384.__name__", [], "openssl_sha384"]
    - ["hl1906026", "hashlib.sha512.__name__", [], "openssl_sha512"]

table hashlib_extra1906.hash_instance_type_qualname:
  description: "type(hashlib.new('ALG')).__qualname__ == 'HASH' for all algorithm variants"
  kind: python_call_eq
  category: qualname_values
  id_prefix: hl1906

  columns: [id, function, args, expected]
  rows:
    - ["hl1906031", "hashlib.md5.__class__.__qualname__", [], "builtin_function_or_method"]
    - ["hl1906032", "hashlib.sha256.__class__.__qualname__", [], "builtin_function_or_method"]
    - ["hl1906033", "hashlib.sha512.__class__.__qualname__", [], "builtin_function_or_method"]

table hashlib_extra1906.hash_type_match_args:
  description: "HASH type __match_args__ dict-presence check"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1906

  columns: [id, function, args, expected]
  rows:
    - ["hl1906041", "hashlib.md5.__class__.__dict__.__contains__", ["__match_args__"], false]
    - ["hl1906042", "hashlib.md5.__class__.__dict__.__contains__", ["__reversed__"], false]
    - ["hl1906043", "hashlib.md5.__class__.__dict__.__contains__", ["__missing__"], false]

table hashlib_extra1906.hash_type_method_presence:
  description: "HASH type method presence checks via constructor function class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1906

  columns: [id, function, args, expected]
  rows:
    - ["hl1906051", "hashlib.md5.__class__.__dict__.__contains__", ["digest"], false]
    - ["hl1906052", "hashlib.md5.__class__.__dict__.__contains__", ["hexdigest"], false]
    - ["hl1906053", "hashlib.md5.__class__.__dict__.__contains__", ["update"], false]
    - ["hl1906054", "hashlib.md5.__class__.__dict__.__contains__", ["copy"], false]
    - ["hl1906055", "hashlib.md5.__class__.__dict__.__contains__", ["__doc__"], true]

table hashlib_extra1906.algorithms_available_type:
  description: "hashlib.algorithms_available is a set; set type qualname checks"
  kind: python_call_eq
  category: qualname_values
  id_prefix: hl1906

  columns: [id, function, args, expected]
  rows:
    - ["hl1906061", "hashlib.algorithms_available.__class__.__qualname__", [], "set"]
    - ["hl1906062", "hashlib.algorithms_guaranteed.__class__.__qualname__", [], "set"]
    - ["hl1906063", "hashlib.algorithms_available.__class__.__dict__.__contains__", ["__reversed__"], false]
    - ["hl1906064", "hashlib.algorithms_available.__class__.__dict__.__contains__", ["__missing__"], false]
    - ["hl1906065", "hashlib.algorithms_available.__class__.__dict__.__contains__", ["__match_args__"], false]
    - ["hl1906066", "hashlib.algorithms_guaranteed.__class__.__dict__.__contains__", ["__reversed__"], false]
