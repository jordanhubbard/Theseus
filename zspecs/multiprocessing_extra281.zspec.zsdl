spec: multiprocessing_extra281
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing synchronization primitives class identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "multiprocessing.Lock, Semaphore, Event, Queue, Value, Array are all bound methods on the context object"
    - "Their __name__ and __module__ reflect the method name and 'multiprocessing.context', not the returned class"
    - "The actual synchronization classes live in multiprocessing.synchronize (Lock, Semaphore, BoundedSemaphore, Event, Condition, RLock)"
    - "multiprocessing.synchronize.Lock.__bases__[0].__name__ == 'SemLock' (Lock is built on SemLock)"
    - "multiprocessing.synchronize.Semaphore.__bases__[0].__name__ == 'SemLock'"
    - "multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'"
    - "multiprocessing.synchronize.Event and Condition both inherit from object"
    - "multiprocessing.queues.Queue.__bases__[0].__name__ == 'object'"
    - "multiprocessing.sharedctypes.Value and Array are functions, not classes"
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra281.context_method_identity:
  description: "multiprocessing top-level Lock, Semaphore, Event, Queue, Value, Array are bound context methods with __module__ 'multiprocessing.context'"
  kind: python_call_eq
  category: identity
  id_prefix: mp281a

  columns: [id, function, args, expected, description]
  rows:
    - [mp281a001, multiprocessing.Lock.__name__.__eq__, ["Lock"], true, "multiprocessing.Lock.__name__ is 'Lock'"]
    - [mp281a002, multiprocessing.Lock.__module__.__eq__, ["multiprocessing.context"], true, "multiprocessing.Lock.__module__ is 'multiprocessing.context'"]
    - [mp281a003, multiprocessing.Semaphore.__name__.__eq__, ["Semaphore"], true, "multiprocessing.Semaphore.__name__ is 'Semaphore'"]
    - [mp281a004, multiprocessing.Semaphore.__module__.__eq__, ["multiprocessing.context"], true, "multiprocessing.Semaphore.__module__ is 'multiprocessing.context'"]
    - [mp281a005, multiprocessing.Event.__name__.__eq__, ["Event"], true, "multiprocessing.Event.__name__ is 'Event'"]
    - [mp281a006, multiprocessing.Event.__module__.__eq__, ["multiprocessing.context"], true, "multiprocessing.Event.__module__ is 'multiprocessing.context'"]
    - [mp281a007, multiprocessing.Queue.__name__.__eq__, ["Queue"], true, "multiprocessing.Queue.__name__ is 'Queue'"]
    - [mp281a008, multiprocessing.Queue.__module__.__eq__, ["multiprocessing.context"], true, "multiprocessing.Queue.__module__ is 'multiprocessing.context'"]
    - [mp281a009, multiprocessing.Value.__name__.__eq__, ["Value"], true, "multiprocessing.Value.__name__ is 'Value'"]
    - [mp281a010, multiprocessing.Value.__module__.__eq__, ["multiprocessing.context"], true, "multiprocessing.Value.__module__ is 'multiprocessing.context'"]
    - [mp281a011, multiprocessing.Array.__name__.__eq__, ["Array"], true, "multiprocessing.Array.__name__ is 'Array'"]
    - [mp281a012, multiprocessing.Array.__module__.__eq__, ["multiprocessing.context"], true, "multiprocessing.Array.__module__ is 'multiprocessing.context'"]

table multiprocessing_extra281.synchronize_class_identity:
  description: "multiprocessing.synchronize Lock, Semaphore, BoundedSemaphore, Event, Condition class name, module, and base class identity"
  kind: python_call_eq
  category: identity
  id_prefix: mp281b

  columns: [id, function, args, expected, description]
  rows:
    - [mp281b001, multiprocessing.synchronize.Lock.__name__.__eq__, ["Lock"], true, "synchronize.Lock.__name__ is 'Lock'"]
    - [mp281b002, multiprocessing.synchronize.Lock.__module__.__eq__, ["multiprocessing.synchronize"], true, "synchronize.Lock.__module__ is 'multiprocessing.synchronize'"]
    - [mp281b003, "multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__", ["SemLock"], true, "synchronize.Lock base class is SemLock"]
    - [mp281b004, multiprocessing.synchronize.Semaphore.__name__.__eq__, ["Semaphore"], true, "synchronize.Semaphore.__name__ is 'Semaphore'"]
    - [mp281b005, multiprocessing.synchronize.Semaphore.__module__.__eq__, ["multiprocessing.synchronize"], true, "synchronize.Semaphore.__module__ is 'multiprocessing.synchronize'"]
    - [mp281b006, "multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__eq__", ["SemLock"], true, "synchronize.Semaphore base class is SemLock"]
    - [mp281b007, multiprocessing.synchronize.BoundedSemaphore.__name__.__eq__, ["BoundedSemaphore"], true, "synchronize.BoundedSemaphore.__name__ is 'BoundedSemaphore'"]
    - [mp281b008, multiprocessing.synchronize.BoundedSemaphore.__module__.__eq__, ["multiprocessing.synchronize"], true, "synchronize.BoundedSemaphore.__module__ is 'multiprocessing.synchronize'"]
    - [mp281b009, "multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__.__eq__", ["Semaphore"], true, "synchronize.BoundedSemaphore base class is Semaphore"]
    - [mp281b010, multiprocessing.synchronize.Event.__name__.__eq__, ["Event"], true, "synchronize.Event.__name__ is 'Event'"]
    - [mp281b011, multiprocessing.synchronize.Event.__module__.__eq__, ["multiprocessing.synchronize"], true, "synchronize.Event.__module__ is 'multiprocessing.synchronize'"]
    - [mp281b012, "multiprocessing.synchronize.Event.__bases__[0].__name__.__eq__", ["object"], true, "synchronize.Event base class is object"]
    - [mp281b013, multiprocessing.synchronize.Condition.__name__.__eq__, ["Condition"], true, "synchronize.Condition.__name__ is 'Condition'"]
    - [mp281b014, multiprocessing.synchronize.Condition.__module__.__eq__, ["multiprocessing.synchronize"], true, "synchronize.Condition.__module__ is 'multiprocessing.synchronize'"]
    - [mp281b015, "multiprocessing.synchronize.Condition.__bases__[0].__name__.__eq__", ["object"], true, "synchronize.Condition base class is object"]

invariant multiprocessing_extra281.lock_is_context_method:
  description: "multiprocessing.Lock is a bound method on the context, with __module__ 'multiprocessing.context'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Lock.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra281.synchronize_lock_base_is_semlock:
  description: "multiprocessing.synchronize.Lock inherits from SemLock, not from object or threading.Lock"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__"
  args: ["SemLock"]
  expected: true

invariant multiprocessing_extra281.bounded_semaphore_base_is_semaphore:
  description: "multiprocessing.synchronize.BoundedSemaphore inherits from Semaphore"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

invariant multiprocessing_extra281.synchronize_event_base_is_object:
  description: "multiprocessing.synchronize.Event inherits directly from object"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.synchronize.Event.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
