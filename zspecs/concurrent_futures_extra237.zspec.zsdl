spec: concurrent_futures_extra237
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers concurrent.futures.as_completed and concurrent.futures.wait function identity."
    - "as_completed.__name__ == 'as_completed' — 12 characters."
    - "as_completed.__module__ == 'concurrent.futures._base' — defined in the private _base submodule (24 chars)."
    - "as_completed.__qualname__ == 'as_completed' — top-level function; qualname equals __name__."
    - "wait.__name__ == 'wait' — 4 characters."
    - "wait.__module__ == 'concurrent.futures._base' — also defined in _base (24 chars)."
    - "wait.__qualname__ == 'wait' — top-level function; qualname equals __name__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: as_completed function identity contracts
#
# Verifies __name__, __module__, __qualname__, and name/module lengths.
# ---------------------------------------------------------------------------

table concurrent_futures_extra237.as_completed_identity:
  description: "concurrent.futures.as_completed function identity: name, module, qualname; new to extra237"
  kind: python_call_eq
  category: function_identity
  id_prefix: cf237fns

  columns: [id, function, args, expected, description]
  rows:
    - [asc_name_eq,
       as_completed.__name__.__eq__,
       ["as_completed"],
       true,
       "concurrent.futures.as_completed.__name__.__eq__('as_completed') == True — function carries its simple name; new to extra237"]
    - [asc_module_eq,
       as_completed.__module__.__eq__,
       ["concurrent.futures._base"],
       true,
       "concurrent.futures.as_completed.__module__.__eq__('concurrent.futures._base') == True — defined in _base submodule; new to extra237"]
    - [asc_qualname_eq,
       as_completed.__qualname__.__eq__,
       ["as_completed"],
       true,
       "concurrent.futures.as_completed.__qualname__.__eq__('as_completed') == True — top-level function; qualname equals __name__; new to extra237"]
    - [asc_name_len_12,
       as_completed.__name__.__len__,
       [],
       12,
       "concurrent.futures.as_completed.__name__.__len__() == 12 — 'as_completed' has 12 characters; new to extra237"]
    - [asc_module_len_24,
       as_completed.__module__.__len__,
       [],
       24,
       "concurrent.futures.as_completed.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 characters; new to extra237"]

# ---------------------------------------------------------------------------
# Table 2: wait function identity contracts
#
# Verifies __name__, __module__, __qualname__, and name/module lengths.
# ---------------------------------------------------------------------------

table concurrent_futures_extra237.wait_identity:
  description: "concurrent.futures.wait function identity: name, module, qualname; new to extra237"
  kind: python_call_eq
  category: function_identity
  id_prefix: cf237fns

  columns: [id, function, args, expected, description]
  rows:
    - [wait_name_eq,
       wait.__name__.__eq__,
       ["wait"],
       true,
       "concurrent.futures.wait.__name__.__eq__('wait') == True — function carries its simple name; new to extra237"]
    - [wait_module_eq,
       wait.__module__.__eq__,
       ["concurrent.futures._base"],
       true,
       "concurrent.futures.wait.__module__.__eq__('concurrent.futures._base') == True — defined in _base submodule; new to extra237"]
    - [wait_qualname_eq,
       wait.__qualname__.__eq__,
       ["wait"],
       true,
       "concurrent.futures.wait.__qualname__.__eq__('wait') == True — top-level function; qualname equals __name__; new to extra237"]
    - [wait_name_len_4,
       wait.__name__.__len__,
       [],
       4,
       "concurrent.futures.wait.__name__.__len__() == 4 — 'wait' has 4 characters; new to extra237"]
    - [wait_module_len_24,
       wait.__module__.__len__,
       [],
       24,
       "concurrent.futures.wait.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 characters; new to extra237"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra237
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra237.as_completed.name:
  description: "concurrent.futures.as_completed.__name__ == 'as_completed'; new to extra237"
  category: function_identity
  kind: python_call_eq
  function: as_completed.__name__.__eq__
  args: ["as_completed"]
  expected: true

invariant concurrent_futures_extra237.as_completed.module:
  description: "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base'; new to extra237"
  category: function_identity
  kind: python_call_eq
  function: as_completed.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra237.as_completed.qualname:
  description: "concurrent.futures.as_completed.__qualname__ == 'as_completed'; new to extra237"
  category: function_identity
  kind: python_call_eq
  function: as_completed.__qualname__.__eq__
  args: ["as_completed"]
  expected: true

invariant concurrent_futures_extra237.as_completed.name_len:
  description: "concurrent.futures.as_completed.__name__.__len__() == 12; new to extra237"
  category: function_identity
  kind: python_call_eq
  function: as_completed.__name__.__len__
  args: []
  expected: 12

invariant concurrent_futures_extra237.as_completed.module_len:
  description: "concurrent.futures.as_completed.__module__.__len__() == 24; new to extra237"
  category: function_identity
  kind: python_call_eq
  function: as_completed.__module__.__len__
  args: []
  expected: 24

invariant concurrent_futures_extra237.wait.name:
  description: "concurrent.futures.wait.__name__ == 'wait'; new to extra237"
  category: function_identity
  kind: python_call_eq
  function: wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant concurrent_futures_extra237.wait.module:
  description: "concurrent.futures.wait.__module__ == 'concurrent.futures._base'; new to extra237"
  category: function_identity
  kind: python_call_eq
  function: wait.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra237.wait.qualname:
  description: "concurrent.futures.wait.__qualname__ == 'wait'; new to extra237"
  category: function_identity
  kind: python_call_eq
  function: wait.__qualname__.__eq__
  args: ["wait"]
  expected: true

invariant concurrent_futures_extra237.wait.name_len:
  description: "concurrent.futures.wait.__name__.__len__() == 4; new to extra237"
  category: function_identity
  kind: python_call_eq
  function: wait.__name__.__len__
  args: []
  expected: 4

invariant concurrent_futures_extra237.wait.module_len:
  description: "concurrent.futures.wait.__module__.__len__() == 24; new to extra237"
  category: function_identity
  kind: python_call_eq
  function: wait.__module__.__len__
  args: []
  expected: 24
