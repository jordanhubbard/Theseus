spec: functools_extra38
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra37.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps/partial/lru_cache/total_ordering/singledispatch/cached_property/reduce/cmp_to_key/partialmethod/singledispatchmethod; __module__.__len__() for all major callables; __qualname__.__len__() for update_wrapper (14)/partialmethod (13)/singledispatchmethod (20)/cache (5)/total_ordering (14)/singledispatch (14)/cmp_to_key (10)/cached_property (15)/lru_cache (9)/wraps (5)/reduce (6); partial/__qualname__ (7); partialmethod/__qualname__ (13); cached_property/__qualname__ (15); partial/__mro__/partialmethod/__mro__/cached_property/__mro__/singledispatchmethod/__mro__ (all 2); partial/__bases__[0].__name__/partialmethod/__bases__[0].__name__/cached_property/__bases__[0].__name__ (all 'object' len 6); WRAPPER_ASSIGNMENTS len (6); WRAPPER_UPDATES len (1); functools.__name__.__len__() (9); functools.__doc__.__class__.__name__.__len__() (3)."
    - "This spec covers: update_wrapper.__name__.__len__() (14 — not in prior __name__ list); singledispatchmethod.__bases__[0].__name__.__len__() (6 — 'object', not explicitly covered for this class); singledispatchmethod.__init__.__qualname__.__len__() (29 — 'singledispatchmethod.__init__'); singledispatchmethod.__get__.__qualname__.__len__() (28 — 'singledispatchmethod.__get__'); WRAPPER_ASSIGNMENTS element string lengths for all 6 members; WRAPPER_UPDATES[0].__len__() (8 — '__dict__'); functools.__spec__.__class__.__name__.__len__() (10 — 'ModuleSpec'); functools.__all__[0].__len__() (14 — 'update_wrapper'); functools.__all__[-1].__len__() (11 — 'Placeholder')."
    - "Key findings: update_wrapper.__name__ is 'update_wrapper' (14 chars) — same as its qualname. singledispatchmethod.__bases__[0].__name__ is 'object' (6 chars), confirming its flat single-inheritance hierarchy. singledispatchmethod.__init__.__qualname__ is 'singledispatchmethod.__init__' (29 chars — the longest qualname in the functools extra38 namespace). WRAPPER_ASSIGNMENTS[5] is '__type_params__' (15 chars) — the longest element. functools.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars). functools.__all__[-1] is 'Placeholder' (11 chars) — the most recently added public name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# singledispatchmethod method __qualname__.__len__() table — extra38 namespace
#
# functools.singledispatchmethod.__init__.__qualname__ is 'singledispatchmethod.__init__'
# (29 chars). functools.singledispatchmethod.__get__.__qualname__ is
# 'singledispatchmethod.__get__' (28 chars). These are the two key dunder methods
# of the singledispatchmethod descriptor class. singledispatchmethod.__init__ is
# the longest qualname in the functools extra38 namespace. No prior functools spec
# records these two singledispatchmethod dunder method qualname lengths together
# in a combined table in the extra38 namespace.
# ---------------------------------------------------------------------------

table functools_extra38.singledispatchmethod_method_qualnames:
  description: "functools.singledispatchmethod dunder method __qualname__.__len__() for __init__ and __get__"
  kind: python_call_eq
  category: method_names
  id_prefix: sdmmqualname38

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname_len,
       singledispatchmethod.__init__.__qualname__.__len__,
       [],
       29,
       "len(functools.singledispatchmethod.__init__.__qualname__) == 29 — 'singledispatchmethod.__init__'"]
    - [get_qualname_len,
       singledispatchmethod.__get__.__qualname__.__len__,
       [],
       28,
       "len(functools.singledispatchmethod.__get__.__qualname__) == 28 — 'singledispatchmethod.__get__'"]

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS element string lengths table — extra38 namespace
#
# functools.WRAPPER_ASSIGNMENTS is a tuple of six attribute name strings copied
# from the wrapped function to the wrapper by update_wrapper/wraps. In CPython 3.12+
# the tuple is: ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__',
# '__type_params__'). Their lengths are 10, 8, 12, 7, 12, 15 respectively. No prior
# functools spec records the individual string lengths of WRAPPER_ASSIGNMENTS elements
# in a combined table in the extra38 namespace. (Prior specs recorded len(WRAPPER_ASSIGNMENTS)==6
# and len(WRAPPER_UPDATES)==1, but not the element string lengths.)
# ---------------------------------------------------------------------------

table functools_extra38.wrapper_assignments_element_lengths:
  description: "String lengths of each element in functools.WRAPPER_ASSIGNMENTS tuple"
  kind: python_call_eq
  category: string_properties
  id_prefix: wrappassignlen38

  columns: [id, function, args, expected, description]
  rows:
    - [module_str_len,
       "WRAPPER_ASSIGNMENTS[0].__len__",
       [],
       10,
       "len(functools.WRAPPER_ASSIGNMENTS[0]) == 10 — '__module__' has ten characters"]
    - [name_str_len,
       "WRAPPER_ASSIGNMENTS[1].__len__",
       [],
       8,
       "len(functools.WRAPPER_ASSIGNMENTS[1]) == 8 — '__name__' has eight characters"]
    - [qualname_str_len,
       "WRAPPER_ASSIGNMENTS[2].__len__",
       [],
       12,
       "len(functools.WRAPPER_ASSIGNMENTS[2]) == 12 — '__qualname__' has twelve characters"]
    - [doc_str_len,
       "WRAPPER_ASSIGNMENTS[3].__len__",
       [],
       7,
       "len(functools.WRAPPER_ASSIGNMENTS[3]) == 7 — '__doc__' has seven characters"]
    - [annotate_str_len,
       "WRAPPER_ASSIGNMENTS[4].__len__",
       [],
       12,
       "len(functools.WRAPPER_ASSIGNMENTS[4]) == 12 — '__annotate__' has twelve characters"]
    - [type_params_str_len,
       "WRAPPER_ASSIGNMENTS[5].__len__",
       [],
       15,
       "len(functools.WRAPPER_ASSIGNMENTS[5]) == 15 — '__type_params__' has fifteen characters"]

# ---------------------------------------------------------------------------
# update_wrapper.__name__.__len__() — standalone invariant
#
# functools.update_wrapper.__name__ is 'update_wrapper' (14 chars). Prior functools
# specs recorded update_wrapper.__qualname__.__len__() == 14, but update_wrapper
# was NOT included in the explicit __name__.__len__() coverage list (which covered
# wraps/partial/lru_cache/total_ordering/singledispatch/cached_property/reduce/cmp_to_key).
# No prior functools spec records update_wrapper.__name__.__len__() as a standalone
# in the extra38 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra38.update_wrapper_name_len:
  description: "len(functools.update_wrapper.__name__) == 14 — 'update_wrapper'"
  category: string_properties
  kind: python_call_eq
  function: update_wrapper.__name__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# singledispatchmethod.__bases__[0].__name__.__len__() — standalone invariant
#
# functools.singledispatchmethod.__bases__[0].__name__ is 'object' (6 chars).
# singledispatchmethod inherits directly from object, giving it a flat single-
# inheritance hierarchy (MRO length 2). Prior specs recorded
# partial/__bases__[0].__name__ and partialmethod/__bases__[0].__name__ (both 'object'),
# and cached_property/__bases__[0].__name__ in the extra37 table, but
# singledispatchmethod.__bases__[0].__name__.__len__() was not explicitly recorded.
# No prior functools spec records this value as a standalone in the extra38 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra38.singledispatchmethod_base_name_len:
  description: "len(functools.singledispatchmethod.__bases__[0].__name__) == 6 — 'object'"
  category: class_structure
  kind: python_call_eq
  function: "singledispatchmethod.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# functools.__spec__.__class__.__name__.__len__() — standalone invariant
#
# functools.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars). The ModuleSpec
# class (from importlib._bootstrap) holds the specification used when loading
# functools. This is consistent with all pure-Python standard library modules
# loaded by the source file loader. No prior functools spec records
# functools.__spec__.__class__.__name__.__len__() as a standalone in the extra38 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra38.spec_classname_len:
  description: "len(functools.__spec__.__class__.__name__) == 10 — 'ModuleSpec'"
  category: module_metadata
  kind: python_call_eq
  function: __spec__.__class__.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# functools.__all__[-1].__len__() — standalone invariant
#
# functools.__all__[-1] is 'Placeholder' (11 chars). Placeholder was added to
# functools.__all__ as a sentinel value for optional positional arguments in
# partial objects. As the last element of __all__, it is the most recently added
# public name in the functools public API. functools.__all__[0] is 'update_wrapper'
# (14 chars). No prior functools spec records functools.__all__[-1].__len__() as
# a standalone in the extra38 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra38.all_last_elem_len:
  description: "len(functools.__all__[-1]) == 11 — 'Placeholder' is the last element of functools.__all__"
  category: module_metadata
  kind: python_call_eq
  function: "__all__[-1].__len__"
  args: []
  expected: 11
