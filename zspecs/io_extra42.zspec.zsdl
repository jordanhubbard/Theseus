spec: io_extra42
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra41.zspec.zsdl — covers StringIO.readline(17)/BytesIO.tell(12) __qualname__.__len__(); TextIOWrapper.tell/flush/close/readable/writable/seekable __qualname__.__len__(); BufferedWriter.tell/seek/writable __qualname__.__len__()."
    - "io_extra38.zspec.zsdl — covers StringIO/BytesIO/BufferedWriter/TextIOWrapper __mro__.__len__()==4 and __bases__[0].__name__.__len__(); StringIO/BytesIO/TextIOWrapper method __qualname__.__len__() for read/write/getvalue/seek/readline."
    - "io_extra36.zspec.zsdl — covers BufferedReader.read(19)/readline(23)/read1(20)/readinto(23)/peek(19); BufferedWriter.write(20)/flush(20); FileIO.readinto(15) __qualname__.__len__()."
    - "io_extra40.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase ABC method __qualname__.__len__() for readable/writable/seekable/tell/flush/close/read/readall/readinto/write/readline."
  notes:
    - "This spec extends io_extra41.zspec.zsdl."
    - "Prior specs collectively covered: __name__/__module__/__qualname__/__dict__.__class__.__name__/__reduce__.__name__/__init_subclass__.__qualname__ for all ten io classes; __mro__.__len__() for all ten classes; __bases__[0].__name__/__len__() for all ten classes; SEEK_*/DEFAULT_BUFFER_SIZE constants; StringIO/BytesIO/TextIOWrapper method __qualname__.__len__() for read/write/getvalue/seek/readline/tell/flush/close/readable/writable/seekable; BufferedReader/BufferedWriter/FileIO method __qualname__.__len__() for all main methods; IOBase/RawIOBase/BufferedIOBase/TextIOBase ABC method __qualname__.__len__(); BufferedWriter.tell/seek/writable __qualname__.__len__()."
    - "This spec covers: BufferedRandom.__qualname__.__len__()==14 (NOVEL — prior specs check __mro__.__len__() and __bases__[0] for BufferedRandom but NOT __qualname__.__len__()); BufferedRandom method __qualname__.__len__() for read(19)/write(20)/seek(19)/tell(19)/flush(20)/read1(20)/peek(19)/readline(23)/readinto(23)/readable(23)/writable(23)/seekable(23) (NOVEL — no prior io spec checks __qualname__.__len__() for any BufferedRandom method); IncrementalNewlineDecoder method __qualname__.__len__() for decode(32)/reset(31)/getstate(34)/setstate(34) (NOVEL — no prior io spec checks __qualname__.__len__() for any IncrementalNewlineDecoder method)."
    - "io.BufferedRandom.__qualname__ == 'BufferedRandom' — len 14. Prior io specs (extra12/extra38) check __mro__.__len__()==4 and __bases__[0].__name__.__len__()==15 but NOT __qualname__.__len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedRandom.read.__qualname__ == 'BufferedRandom.read' — len 19. Shortest dotted BufferedRandom method qualname. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedRandom.write.__qualname__ == 'BufferedRandom.write' — len 20. Equals flush/read1 (20). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedRandom.seek.__qualname__ == 'BufferedRandom.seek' — len 19. Equals read/tell/peek (19). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedRandom.tell.__qualname__ == 'BufferedRandom.tell' — len 19. Equals read/seek/peek (19). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedRandom.flush.__qualname__ == 'BufferedRandom.flush' — len 20. Equals write/read1 (20). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedRandom.read1.__qualname__ == 'BufferedRandom.read1' — len 20. Equals write/flush (20). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedRandom.peek.__qualname__ == 'BufferedRandom.peek' — len 19. Equals read/seek/tell (19). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedRandom.readline.__qualname__ == 'BufferedRandom.readline' — len 23. Equals readinto/readable/writable/seekable (23). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedRandom.readinto.__qualname__ == 'BufferedRandom.readinto' — len 23. Equals readline/readable/writable/seekable (23). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedRandom.readable.__qualname__ == 'BufferedRandom.readable' — len 23. Equals readline/readinto/writable/seekable (23). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedRandom.writable.__qualname__ == 'BufferedRandom.writable' — len 23. Equals readline/readinto/readable/seekable (23). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedRandom.seekable.__qualname__ == 'BufferedRandom.seekable' — len 23. Equals readline/readinto/readable/writable (23). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.IncrementalNewlineDecoder.decode.__qualname__ == 'IncrementalNewlineDecoder.decode' — len 32. Longest class name (25 chars) + '.decode' (7 chars). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.IncrementalNewlineDecoder.reset.__qualname__ == 'IncrementalNewlineDecoder.reset' — len 31. Shortest IncrementalNewlineDecoder method qualname. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.IncrementalNewlineDecoder.getstate.__qualname__ == 'IncrementalNewlineDecoder.getstate' — len 34. Equals setstate (34). Longest IncrementalNewlineDecoder method qualname. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.IncrementalNewlineDecoder.setstate.__qualname__ == 'IncrementalNewlineDecoder.setstate' — len 34. Equals getstate (34). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedRandom.__qualname__.__len__()
#
# Prior specs check BufferedRandom.__mro__.__len__()==4 (io_extra12/extra38)
# and __bases__[0].__name__.__len__()==15 (io_extra38) but no prior spec
# checks BufferedRandom.__qualname__.__len__(). It is the same as __name__
# since BufferedRandom is a top-level C class ('BufferedRandom' has 14 chars).
#
#   BufferedRandom.__qualname__ == 'BufferedRandom' -> 14
#
# Novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra42.BufferedRandom.qualname_len:
  description: "io.BufferedRandom.__qualname__.__len__() == 14 — 'BufferedRandom' has 14 characters; top-level C class; novel (prior specs check __mro__/__bases__ but not __qualname__.__len__())"
  category: class_identity
  kind: python_call_eq
  function: BufferedRandom.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# io.BufferedRandom method __qualname__.__len__()
#
# No prior io spec checks __qualname__.__len__() for any BufferedRandom method.
# BufferedRandom supports both read and write operations (it wraps a file
# opened in read+write mode). Its method qualnames all have the prefix
# 'BufferedRandom.' (15 chars) followed by the method name.
#
# Clusters:
#   len 19 — read, seek, tell, peek              (shortest, 4 chars)
#   len 20 — write, flush, read1                 (+1 char)
#   len 23 — readline, readinto, readable,       (+4 chars, longest cluster)
#             writable, seekable
#
# All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra42.BufferedRandom_method_qualname_lens:
  description: "io.BufferedRandom method __qualname__.__len__(): read/seek/tell/peek(19), write/flush/read1(20), readline/readinto/readable/writable/seekable(23) — all novel"
  kind: python_call_eq
  category: method_identity
  id_prefix: brmq42

  columns: [id, function, args, expected]
  rows:
    - [read,     BufferedRandom.read.__qualname__.__len__,     [], 19]
    - [seek,     BufferedRandom.seek.__qualname__.__len__,     [], 19]
    - [tell,     BufferedRandom.tell.__qualname__.__len__,     [], 19]
    - [peek,     BufferedRandom.peek.__qualname__.__len__,     [], 19]
    - [write,    BufferedRandom.write.__qualname__.__len__,    [], 20]
    - [flush,    BufferedRandom.flush.__qualname__.__len__,    [], 20]
    - [read1,    BufferedRandom.read1.__qualname__.__len__,    [], 20]
    - [readline, BufferedRandom.readline.__qualname__.__len__, [], 23]
    - [readinto, BufferedRandom.readinto.__qualname__.__len__, [], 23]
    - [readable, BufferedRandom.readable.__qualname__.__len__, [], 23]
    - [writable, BufferedRandom.writable.__qualname__.__len__, [], 23]
    - [seekable, BufferedRandom.seekable.__qualname__.__len__, [], 23]

# ---------------------------------------------------------------------------
# io.IncrementalNewlineDecoder method __qualname__.__len__()
#
# IncrementalNewlineDecoder is an internal codec helper used by TextIOWrapper
# to normalize line endings. No prior io spec checks __qualname__.__len__()
# for any IncrementalNewlineDecoder method. Its class name is 25 chars
# ('IncrementalNewlineDecoder'), making its method qualnames unusually long.
#
# The four public methods of IncrementalNewlineDecoder:
#   decode   -> 'IncrementalNewlineDecoder.decode'   -> 32
#   reset    -> 'IncrementalNewlineDecoder.reset'    -> 31 (shortest)
#   getstate -> 'IncrementalNewlineDecoder.getstate' -> 34 (longest, tied)
#   setstate -> 'IncrementalNewlineDecoder.setstate' -> 34 (longest, tied)
#
# All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra42.IncrementalNewlineDecoder_method_qualname_lens:
  description: "io.IncrementalNewlineDecoder method __qualname__.__len__(): decode(32)/reset(31)/getstate(34)/setstate(34) — all novel; class prefix of 25 chars makes these the longest method qualnames in the io module"
  kind: python_call_eq
  category: method_identity
  id_prefix: indq42

  columns: [id, function, args, expected]
  rows:
    - [decode,   IncrementalNewlineDecoder.decode.__qualname__.__len__,   [], 32]
    - [reset,    IncrementalNewlineDecoder.reset.__qualname__.__len__,    [], 31]
    - [getstate, IncrementalNewlineDecoder.getstate.__qualname__.__len__, [], 34]
    - [setstate, IncrementalNewlineDecoder.setstate.__qualname__.__len__, [], 34]
