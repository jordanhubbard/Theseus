spec: uuid_extra175
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "uuid.UUID.int is a member_descriptor, not a property — it is stored as a C-level slot, so it has no fget."
    - "uuid.UUID.hex.fget.__name__ == 'hex' — len=3; hex is a Python property with a named getter."
    - "uuid.UUID.bytes.fget.__name__ == 'bytes' — len=5."
    - "uuid.UUID.bytes_le.fget.__name__ == 'bytes_le' — len=8."
    - "uuid.UUID.fields.fget.__name__ == 'fields' — len=6."
    - "uuid.UUID.time.fget.__name__ == 'time' — len=4."
    - "uuid.UUID.clock_seq.fget.__name__ == 'clock_seq' — len=9."
    - "uuid.UUID.node.fget.__name__ == 'node' — len=4."
    - "uuid.UUID.variant.fget.__name__ == 'variant' — len=7; extra property beyond spec requirements."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

