spec: os_path_extra14
version: ">=3.9"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python os.path module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py"
    - "os_path_extra.zspec.zsdl — covers join('/a','b')=='/a/b'; exists/isfile/isdir/isabs/__name__; dirname/basename on '/a/b/c.txt'"
    - "os_path_extra13.zspec.zsdl — covers normpath/abspath/expanduser/expandvars in prior vectors; split/splitext on various paths"
  notes:
    - "This spec extends os_path.zspec.zsdl and prior extras through os_path_extra13.zspec.zsdl."
    - "os.path.join('/a', 'b', 'c') == '/a/b/c' — three-argument join with absolute base; no prior spec covers this 3-arg form."
    - "os.path.join('a', '/b') == '/b' — when an argument is absolute, all prior components are discarded; no prior spec covers this reset behavior."
    - "os.path.normpath('/a/b/../c') == '/a/c' — dotdot resolution; no prior spec covers this exact input."
    - "os.path.normpath('/a/./b') == '/a/b' — single-dot removal; no prior spec covers this exact input."
    - "os.path.normpath('//a') == '//a' — POSIX special case: exactly two leading slashes are preserved (POSIX 1003.1 allows implementations to treat // specially); no prior spec covers this."
    - "os.path.expandvars('$HOME').__class__.__name__ == 'str' — expandvars always returns a string regardless of whether the variable is set; no prior spec covers this type check."
    - "os.path.lexists.__name__ == 'lexists' — function name attribute; no prior spec covers lexists.__name__."
    - "os.path.realpath.__name__ == 'realpath' — function name attribute; no prior spec covers realpath.__name__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# os.path.join — three-argument form with absolute base
#
# Prior specs cover join('/a', 'b') == '/a/b' (two-argument form).
# No prior spec covers the three-argument form join('/a', 'b', 'c').
# Result: '/a/b/c' — segments are joined with os.sep.
# ---------------------------------------------------------------------------

invariant os_path_extra14.join.three_args:
  description: "os.path.join('/a', 'b', 'c') == '/a/b/c' — three-argument join with absolute base"
  category: join
  kind: python_call_eq
  function: join
  args: ["/a", "b", "c"]
  expected: "/a/b/c"

# ---------------------------------------------------------------------------
# os.path.join — absolute argument resets prior components
#
# POSIX rule: if a component is an absolute pathname, all prior components
# are discarded. join('a', '/b') == '/b'. No prior spec covers this.
# ---------------------------------------------------------------------------

invariant os_path_extra14.join.absolute_resets:
  description: "os.path.join('a', '/b') == '/b' — absolute argument discards prior components"
  category: join
  kind: python_call_eq
  function: join
  args: ["a", "/b"]
  expected: "/b"

# ---------------------------------------------------------------------------
# os.path.normpath — dotdot resolution
#
# normpath('/a/b/../c') collapses the '..' to give '/a/c'.
# No prior spec covers this exact dotdot input vector.
# ---------------------------------------------------------------------------

invariant os_path_extra14.normpath.dotdot:
  description: "os.path.normpath('/a/b/../c') == '/a/c' — dotdot resolution"
  category: normpath
  kind: python_call_eq
  function: normpath
  args: ["/a/b/../c"]
  expected: "/a/c"

# ---------------------------------------------------------------------------
# os.path.normpath — single-dot removal
#
# normpath('/a/./b') collapses the '.' to give '/a/b'.
# No prior spec covers this exact single-dot input vector.
# ---------------------------------------------------------------------------

invariant os_path_extra14.normpath.singledot:
  description: "os.path.normpath('/a/./b') == '/a/b' — single-dot component is removed"
  category: normpath
  kind: python_call_eq
  function: normpath
  args: ["/a/./b"]
  expected: "/a/b"

# ---------------------------------------------------------------------------
# os.path.normpath — double leading slash preserved (POSIX special case)
#
# POSIX 1003.1 allows implementations to treat paths beginning with exactly
# two slashes specially. CPython on macOS/Linux preserves '//a' as '//a'.
# Three or more leading slashes are collapsed to one. No prior spec covers this.
# ---------------------------------------------------------------------------

invariant os_path_extra14.normpath.double_slash:
  description: "os.path.normpath('//a') == '//a' — exactly two leading slashes preserved on POSIX"
  category: normpath
  kind: python_call_eq
  function: normpath
  args: ["//a"]
  expected: "//a"

# ---------------------------------------------------------------------------
# os.path.expandvars — return type
#
# expandvars() substitutes environment variables in the path string.
# It always returns a str. No prior spec checks expandvars(...)__class__.__name__.
# Using '$HOME' which is always defined on POSIX; result type is str either way.
# ---------------------------------------------------------------------------

invariant os_path_extra14.expandvars.class_name:
  description: "os.path.expandvars('$HOME').__class__.__name__ == 'str' — expandvars always returns str"
  category: expandvars
  kind: python_call_eq
  function: expandvars
  args: ["$HOME"]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# os.path function __name__ attributes — lexists and realpath
#
# No prior spec covers lexists.__name__ or realpath.__name__.
# Each function's __name__ attribute equals the function's own identifier.
# ---------------------------------------------------------------------------

table os_path_extra14.function_names:
  description: "os.path function __name__ attributes for lexists and realpath"
  kind: python_call_eq
  category: function_names

  columns: [id, function, args, expected]
  rows:
    - [lexists,  lexists.__name__.__eq__,  ["lexists"],  true]
    - [realpath, realpath.__name__.__eq__, ["realpath"], true]
