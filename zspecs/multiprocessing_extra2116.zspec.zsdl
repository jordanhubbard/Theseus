spec: multiprocessing_extra2116
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
    - "multiprocessing_extra.zspec.zsdl — covers __module__/__name__ checks and factory function names"
    - "multiprocessing_extra1126.zspec.zsdl — covers __flags__/__basicsize__/__itemsize__ and synchronize class identity"
  notes:
    - "Wave (_extra2116): __or__/__ror__/__ior__, __and__/__rand__/__iand__, __xor__/__rxor__/__ixor__ dict-presence checks."
    - "These are the set/dict merge operators (|, &, ^) and their reflected/in-place variants."
    - "Classes checked: Process, synchronize.Lock, synchronize.RLock, synchronize.Semaphore, synchronize.BoundedSemaphore, synchronize.Event, synchronize.Condition, queues.Queue, queues.SimpleQueue."
    - "None of these multiprocessing classes define set/dict algebra operators in their own __dict__."
    - "multiprocessing synchronization primitives wrap OS-level primitives; dict/set merge semantics do not apply."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table multiprocessing_extra2116.or_operator:
