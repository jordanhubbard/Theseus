spec: struct_extra1261
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra126.zspec.zsdl — covers earlier struct invariants from wave 289."
  notes:
    - "Wave 531: struct has __all__ (a list). This spec checks struct.__all__.__contains__ for names in __all__ (true), names NOT in __all__ (false), and __all__.__class__.__name__.__eq__ identity."
    - "struct.__all__ == ['calcsize', 'pack', 'pack_into', 'unpack', 'unpack_from', 'iter_unpack', 'Struct', 'error']. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__.__class__.__name__ == 'list'. On this Python version struct.__all__ is a plain list. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Names NOT in __all__: iter_pack, format, compile, size, calcsize_from (misspellings and absent names). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1261.all_contains_true:
  description: "struct.__all__.__contains__ returns true for names that are members of struct.__all__"
  kind: python_call_eq
  category: all_membership_true
  id_prefix: st1261at
  columns: [id, function, args, expected]
  rows:
    - [st1261at001, struct.__all__.__contains__, ["calcsize"],    true]
    - [st1261at002, struct.__all__.__contains__, ["pack"],        true]
    - [st1261at003, struct.__all__.__contains__, ["pack_into"],   true]
    - [st1261at004, struct.__all__.__contains__, ["unpack"],      true]
    - [st1261at005, struct.__all__.__contains__, ["unpack_from"], true]
    - [st1261at006, struct.__all__.__contains__, ["iter_unpack"], true]
    - [st1261at007, struct.__all__.__contains__, ["Struct"],      true]
    - [st1261at008, struct.__all__.__contains__, ["error"],       true]

table struct_extra1261.all_contains_false:
  description: "struct.__all__.__contains__ returns false for names not in struct.__all__ (absent functions, misspellings, private names)"
  kind: python_call_eq
  category: all_membership_false
  id_prefix: st1261af
  columns: [id, function, args, expected]
  rows:
    - [st1261af001, struct.__all__.__contains__, ["iter_pack"],      false]
    - [st1261af002, struct.__all__.__contains__, ["format"],         false]
    - [st1261af003, struct.__all__.__contains__, ["compile"],        false]
    - [st1261af004, struct.__all__.__contains__, ["size"],           false]
    - [st1261af005, struct.__all__.__contains__, ["calcsize_from"],  false]
    - [st1261af006, struct.__all__.__contains__, ["pack_from"],      false]
    - [st1261af007, struct.__all__.__contains__, ["struct"],         false]
    - [st1261af008, struct.__all__.__contains__, ["Error"],          false]
    - [st1261af009, struct.__all__.__contains__, ["unpack_into"],    false]
    - [st1261af010, struct.__all__.__contains__, ["os"],             false]
    - [st1261af011, struct.__all__.__contains__, ["sys"],            false]
    - [st1261af012, struct.__all__.__contains__, [""],               false]

table struct_extra1261.all_class_and_type_checks:
  description: "struct.__all__ is a list; class name identity checks and module name checks"
  kind: python_call_eq
  category: all_class_checks
  id_prefix: st1261ac
  columns: [id, function, args, expected]
  rows:
    - [st1261ac001, struct.__all__.__class__.__name__.__eq__,     ["list"],    true]
    - [st1261ac002, struct.__all__.__class__.__name__.__eq__,     ["tuple"],   false]
    - [st1261ac003, struct.__all__.__class__.__name__.__eq__,     ["set"],     false]
    - [st1261ac004, struct.__all__.__class__.__name__.__eq__,     ["frozenset"],false]
    - [st1261ac005, struct.__all__.__class__.__name__.__eq__,     ["dict"],    false]
    - [st1261ac006, struct.__all__.__class__.__qualname__.__eq__, ["list"],    true]
    - [st1261ac007, struct.__all__.__class__.__module__.__eq__,   ["builtins"],true]
    - [st1261ac008, struct.__name__.__eq__,                       ["struct"],  true]
    - [st1261ac009, struct.__spec__.name.__eq__,                  ["struct"],  true]
    - [st1261ac010, struct.__all__.__len__.__class__.__name__.__eq__, ["method-wrapper"], true]
