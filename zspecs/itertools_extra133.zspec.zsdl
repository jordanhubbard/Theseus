spec: itertools_extra133
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.chain, itertools.product, itertools.combinations, itertools.permutations — class identity (__class__.__name__=='type'), __module__, __name__, MRO, and slot qualnames (Wave 261)."
    - "itertools.chain.__class__.__name__ == 'type' — chain is a C extension type defined in itertoolsmodule.c; its metaclass is the built-in type. Verified with Python 3.14.3."
    - "itertools.chain.__module__ == 'itertools' — C extension type reports its module as 'itertools'. Verified with Python 3.14.3."
    - "itertools.chain.__name__ == 'chain' (len 5). Verified with Python 3.14.3."
    - "itertools.chain.__mro__ has len 2: [chain, object]. Verified with Python 3.14.3."
    - "itertools.chain.__iter__.__qualname__ == 'chain.__iter__' (len 14). Verified with Python 3.14.3."
    - "itertools.chain.__next__.__qualname__ == 'chain.__next__' (len 14). Verified with Python 3.14.3."
    - "itertools.product.__class__.__name__ == 'type' — product is a C extension type. Verified with Python 3.14.3."
    - "itertools.product.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.product.__name__ == 'product' (len 7). Verified with Python 3.14.3."
    - "itertools.product.__iter__.__qualname__ == 'product.__iter__' (len 16). Verified with Python 3.14.3."
    - "itertools.product.__next__.__qualname__ == 'product.__next__' (len 16). Verified with Python 3.14.3."
    - "itertools.combinations.__class__.__name__ == 'type' — combinations is a C extension type. Verified with Python 3.14.3."
    - "itertools.combinations.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.combinations.__name__ == 'combinations' (len 12). Verified with Python 3.14.3."
    - "itertools.combinations.__iter__.__qualname__ == 'combinations.__iter__' (len 21). Verified with Python 3.14.3."
    - "itertools.permutations.__class__.__name__ == 'type' — permutations is a C extension type. Verified with Python 3.14.3."
    - "itertools.permutations.__name__ == 'permutations' (len 12). Verified with Python 3.14.3."
    - "itertools.permutations.__iter__.__qualname__ == 'permutations.__iter__' (len 21). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain class identity, __module__, __name__, MRO
#
# Wave 261 theme: itertools.chain C type identity.
#
# itertools.chain.__class__.__name__ == 'type'
# itertools.chain.__module__ == 'itertools'
# itertools.chain.__name__ == 'chain' (len 5)
# len(itertools.chain.__mro__) == 2
# itertools.chain.__bases__[0].__name__ == 'object'
#
# chain is a C extension type in itertoolsmodule.c with metaclass type.
# New to extra133.
# ---------------------------------------------------------------------------

table itertools_extra133.chain_identity:
  description: "itertools.chain class identity: __class__.__name__=='type', __module__=='itertools', __name__=='chain' (len 5), MRO len 2; wave 261; new to extra133"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolschain133

  columns: [id, function, args, expected, description]
  rows:
    - [chain_class_name_eq_type,
       "chain.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.chain.__class__.__name__.__eq__('type') == True — chain is a C extension type defined in Modules/itertoolsmodule.c; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra133"]
    - [chain_module_eq_itertools,
       "chain.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.chain.__module__.__eq__('itertools') == True — chain is a C extension type exported from the itertools module; its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra133"]
    - [chain_name_eq_chain,
       "chain.__name__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__name__.__eq__('chain') == True — chain is the C extension type whose type name is 'chain' as declared in itertoolsmodule.c; str.__eq__('chain') returns True; new to extra133"]
    - [chain_name_len_eq_5,
       "chain.__name__.__len__",
       [],
       5,
       "itertools.chain.__name__.__len__() == 5 — __name__ is 'chain' which has 5 characters; len('chain') == 5; new to extra133"]
    - [chain_mro_len_eq_2,
       "chain.__mro__.__len__",
       [],
       2,
       "itertools.chain.__mro__.__len__() == 2 — chain's MRO is [chain, object]; it inherits only from object; len(__mro__) is 2; new to extra133"]
    - [chain_bases_first_eq_object,
       "chain.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.chain.__bases__[0].__name__.__eq__('object') == True — chain inherits only from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra133"]

# ---------------------------------------------------------------------------
# Table 2: itertools.chain slot qualnames (__iter__, __next__, __new__)
#
# Wave 261 theme: itertools.chain C type slot method qualnames.
#
# itertools.chain.__iter__.__qualname__ == 'chain.__iter__' (len 14)
# itertools.chain.__next__.__qualname__ == 'chain.__next__' (len 14)
# itertools.chain.__new__.__qualname__ == 'chain.__new__' (len 13)
#
# Slot methods on C types have qualnames prefixed with the type name.
# New to extra133.
# ---------------------------------------------------------------------------

table itertools_extra133.chain_slot_qualnames:
  description: "itertools.chain slot qualnames: __iter__ len 14, __next__ len 14, __new__ len 13; wave 261; new to extra133"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolschain133

  columns: [id, function, args, expected, description]
  rows:
    - [chain_iter_qualname_eq,
       "chain.__iter__.__qualname__.__eq__",
       ["chain.__iter__"],
       true,
       "itertools.chain.__iter__.__qualname__.__eq__('chain.__iter__') == True — chain.__iter__ is a slot method on the C type; its qualname is 'chain.__iter__' prefixed with the type name; str.__eq__('chain.__iter__') returns True; new to extra133"]
    - [chain_iter_qualname_len_eq_14,
       "chain.__iter__.__qualname__.__len__",
       [],
       14,
       "itertools.chain.__iter__.__qualname__.__len__() == 14 — __qualname__ is 'chain.__iter__' which has 14 characters; len('chain.__iter__') == 14; new to extra133"]
    - [chain_next_qualname_eq,
       "chain.__next__.__qualname__.__eq__",
       ["chain.__next__"],
       true,
       "itertools.chain.__next__.__qualname__.__eq__('chain.__next__') == True — chain.__next__ is a slot method on the C type; its qualname is 'chain.__next__'; str.__eq__('chain.__next__') returns True; new to extra133"]
    - [chain_next_qualname_len_eq_14,
       "chain.__next__.__qualname__.__len__",
       [],
       14,
       "itertools.chain.__next__.__qualname__.__len__() == 14 — __qualname__ is 'chain.__next__' which has 14 characters; len('chain.__next__') == 14; new to extra133"]
    - [chain_new_qualname_eq,
       "chain.__new__.__qualname__.__eq__",
       ["chain.__new__"],
       true,
       "itertools.chain.__new__.__qualname__.__eq__('chain.__new__') == True — chain.__new__ is a slot method on the C type; its qualname is 'chain.__new__'; str.__eq__('chain.__new__') returns True; new to extra133"]
    - [chain_new_qualname_len_eq_13,
       "chain.__new__.__qualname__.__len__",
       [],
       13,
       "itertools.chain.__new__.__qualname__.__len__() == 13 — __qualname__ is 'chain.__new__' which has 13 characters; len('chain.__new__') == 13; new to extra133"]

# ---------------------------------------------------------------------------
# Table 3: itertools.product and itertools.combinations identity
#
# Wave 261 theme: itertools.product and itertools.combinations C type identity.
#
# itertools.product.__class__.__name__ == 'type'
# itertools.product.__module__ == 'itertools'
# itertools.product.__name__ == 'product' (len 7)
# itertools.product.__iter__.__qualname__ == 'product.__iter__' (len 16)
# itertools.combinations.__class__.__name__ == 'type'
# itertools.combinations.__module__ == 'itertools'
# itertools.combinations.__name__ == 'combinations' (len 12)
# itertools.combinations.__iter__.__qualname__ == 'combinations.__iter__' (len 21)
#
# Both are C extension types in itertoolsmodule.c. New to extra133.
# ---------------------------------------------------------------------------

