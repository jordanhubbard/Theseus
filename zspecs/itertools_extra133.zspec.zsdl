# ---------------------------------------------------------------------------
# Standalone invariants — extra133
# ---------------------------------------------------------------------------

invariant itertools_extra133.chain_class_is_type:
  description: "itertools.chain.__class__.__name__ == 'type' — chain is a C extension type, not a Python class or function; wave 261; new to extra133"
  kind: python_call_eq
  function: chain.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra133.product_class_is_type:
  description: "itertools.product.__class__.__name__ == 'type' — product is a C extension type; wave 261; new to extra133"
  kind: python_call_eq
  function: product.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra133.combinations_class_is_type:
  description: "itertools.combinations.__class__.__name__ == 'type' — combinations is a C extension type; wave 261; new to extra133"
  kind: python_call_eq
  function: combinations.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra133.permutations_class_is_type:
  description: "itertools.permutations.__class__.__name__ == 'type' — permutations is a C extension type; wave 261; new to extra133"
  kind: python_call_eq
  function: permutations.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra133.chain_mro_len:
  description: "len(itertools.chain.__mro__) == 2 — chain MRO is [chain, object]; wave 261; new to extra133"
  kind: python_call_eq
  function: chain.__mro__.__len__
  args: []
  expected: 2
