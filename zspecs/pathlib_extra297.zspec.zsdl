spec: pathlib_extra297
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module public API and __all__ membership"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py, Lib/pathlib/_abc.py"
  notes:
    - "pathlib.__all__ is a list of publicly exported path classes"
    - "PurePath.__slots__ is a tuple (may be empty or contain slot names)"
    - "PosixPath and WindowsPath are platform-specific concrete path types"
    - "pathlib.__all__ length verified to be 6 in CPython 3.11+"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table pathlib_extra297.all_membership:
  description: "pathlib.__all__ membership for all exported path classes"
  kind: python_call_eq
  category: identity
  id_prefix: pl297a

  columns: [id, function, args, expected, description]
  rows:
    - [pl297a001, pathlib.__all__.__contains__, ["PurePath"], true, "PurePath is in pathlib.__all__"]
    - [pl297a002, pathlib.__all__.__contains__, ["PurePosixPath"], true, "PurePosixPath is in pathlib.__all__"]
    - [pl297a003, pathlib.__all__.__contains__, ["PureWindowsPath"], true, "PureWindowsPath is in pathlib.__all__"]
    - [pl297a004, pathlib.__all__.__contains__, ["Path"], true, "Path is in pathlib.__all__"]
    - [pl297a005, pathlib.__all__.__contains__, ["PosixPath"], true, "PosixPath is in pathlib.__all__"]
    - [pl297a006, pathlib.__all__.__contains__, ["WindowsPath"], true, "WindowsPath is in pathlib.__all__"]

table pathlib_extra297.all_metadata:
  description: "__all__ metadata and PurePath __slots__ class name"
  kind: python_call_eq
  category: identity
  id_prefix: pl297b

  columns: [id, function, args, expected, description]
  rows:
    - [pl297b001, pathlib.__all__.__class__.__name__.__eq__, ["list"], true, "pathlib.__all__ is a list"]
    - [pl297b002, pathlib.__all__.__len__, [], 6, "pathlib.__all__ has exactly 6 entries"]
    - [pl297b003, pathlib.PurePath.__slots__.__class__.__name__.__eq__, ["tuple"], true, "PurePath.__slots__ is a tuple"]
    - [pl297b004, pathlib.__name__.__eq__, ["pathlib"], true, "pathlib module __name__ is 'pathlib'"]
    - [pl297b005, pathlib.__package__.__eq__, ["pathlib"], true, "pathlib module __package__ is 'pathlib'"]

invariant pathlib_extra297.purepath_in_all:
  description: "PurePath is exported from pathlib.__all__"
  category: identity
  kind: python_call_eq
  function: pathlib.__all__.__contains__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra297.path_in_all:
  description: "Path is exported from pathlib.__all__"
  category: identity
  kind: python_call_eq
  function: pathlib.__all__.__contains__
  args: ["Path"]
  expected: true

invariant pathlib_extra297.all_len:
  description: "pathlib.__all__ has exactly 6 members"
  category: identity
  kind: python_call_eq
  function: pathlib.__all__.__len__
  args: []
  expected: 6
