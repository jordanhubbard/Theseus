spec: email_message
version: ">=3.0"
backend: python_module(email.message)

docs: https://docs.python.org/3/library/email.message.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/email.message.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "email.message source: Lib/email/message.py (PSF; source inspection permitted)"
  not_derived_from:
    - "email.message source: internal MIME parsing internals"
  notes:
    - "Message is the central class representing an email message as a collection of headers and a payload."
    - "EmailMessage (Python 3.6+) is a subclass of Message with an improved API."
    - "MIMEPart (Python 3.6+) is also available as a base for EmailMessage."
    - "Default content type for Message is 'text/plain' before any explicit set_type() call."
    - "Accessing a missing header via __getitem__ returns None (not raising KeyError)."
    - "Message.get(name, failobj=None) mirrors dict.get() semantics."
    - "Message.keys() returns a list of all header names in insertion order."
    - "Message.is_multipart() returns False for plain single-part messages."
    - "Message.get_charset() returns None for messages without an explicit charset."
    - "Message.defects is a list of detected parsing defects, empty for freshly created messages."
    - "EmailMessage is a subclass of Message."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

table email_message.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [Message,      Message.__name__.__eq__,      ["Message"],      true]
    - [MIMEPart,     MIMEPart.__name__.__eq__,     ["MIMEPart"],     true]
    - [EmailMessage, EmailMessage.__name__.__eq__,  ["EmailMessage"], true]

# ---------------------------------------------------------------------------
# Message — missing header access
# ---------------------------------------------------------------------------

invariant email_message.missing_header:
  description: "Message().__getitem__('X-Nonexistent') == None — missing headers return None"
  category: Message
  kind: python_call_eq
  function: Message
  args: []
  method: __getitem__
  method_args: ["X-Nonexistent"]
  expected: null

invariant email_message.get_missing:
  description: "Message().get('X-Missing') == None — missing headers return None"
  category: Message
  kind: python_call_eq
  function: Message
  args: []
  method: get
  method_args: ["X-Missing"]
  expected: null

invariant email_message.get_with_default:
  description: "Message().get('X-Missing', 'fallback') == 'fallback'"
  category: Message
  kind: python_call_eq
  function: Message
  args: []
  method: get
  method_args: ["X-Missing", "fallback"]
  expected: "fallback"

# ---------------------------------------------------------------------------
# Message — empty header list
# ---------------------------------------------------------------------------

invariant email_message.empty_keys:
  description: "Message().keys() == [] — freshly created message has no headers"
  category: Message
  kind: python_call_eq
  function: Message
  args: []
  method: keys
  method_args: []
  expected: []

invariant email_message.empty_len:
  description: "Message().__len__() == 0 — freshly created message has zero headers"
  category: Message
  kind: python_call_eq
  function: Message
  args: []
  method: __len__
  method_args: []
  expected: 0

# ---------------------------------------------------------------------------
# Message — default content type
# ---------------------------------------------------------------------------

invariant email_message.default_content_type:
  description: "Message().get_content_type() == 'text/plain' — default MIME type"
  category: Message
  kind: python_call_eq
  function: Message
  args: []
  method: get_content_type
  method_args: []
  expected: "text/plain"

invariant email_message.default_maintype:
  description: "Message().get_content_maintype() == 'text'"
  category: Message
  kind: python_call_eq
  function: Message
  args: []
  method: get_content_maintype
  method_args: []
  expected: "text"

invariant email_message.default_subtype:
  description: "Message().get_content_subtype() == 'plain'"
  category: Message
  kind: python_call_eq
  function: Message
  args: []
  method: get_content_subtype
  method_args: []
  expected: "plain"

# ---------------------------------------------------------------------------
# Message — is_multipart, get_charset, defects
# ---------------------------------------------------------------------------

invariant email_message.not_multipart:
  description: "Message().is_multipart() == False — single-part message"
  category: Message
  kind: python_call_eq
  function: Message
  args: []
  method: is_multipart
  method_args: []
  expected: false

invariant email_message.charset_default:
  description: "Message().get_charset() == None — no explicit charset set"
  category: Message
  kind: python_call_eq
  function: Message
  args: []
  method: get_charset
  method_args: []
  expected: null

invariant email_message.defects_empty:
  description: "Message().defects == [] — no defects in a freshly created message"
  category: Message
  kind: python_call_eq
  function: Message
  args: []
  method: defects
  expected: []

# ---------------------------------------------------------------------------
# EmailMessage — subclass of Message
# ---------------------------------------------------------------------------

invariant email_message.emailmessage_default_content_type:
  description: "EmailMessage().get_content_type() == 'text/plain'"
  category: EmailMessage
  kind: python_call_eq
  function: EmailMessage
  args: []
  method: get_content_type
  method_args: []
  expected: "text/plain"

invariant email_message.emailmessage_is_message_subclass:
  description: "EmailMessage is a subclass of Message"
  category: EmailMessage
  kind: python_call_eq
  function: issubclass
  args: ["EmailMessage", "Message"]
  expected: true
