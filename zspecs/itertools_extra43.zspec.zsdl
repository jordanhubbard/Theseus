spec: itertools_extra43
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra42.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for all major itertools types; __qualname__.__len__() for groupby/islice/zip_longest/accumulate/chain.from_iterable/combinations_with_replacement/count/cycle/repeat/starmap/compress/dropwhile/takewhile/filterfalse; __mro__.__len__()==2 for all major types; __bases__[0].__name__.__len__()==6 for all; chain/__name__/__qualname__=='chain'; chain.from_iterable/__qualname__=='chain.from_iterable'; zip_longest/__name__/__qualname__=='zip_longest'; islice/__name__/__qualname__=='islice'; accumulate/__name__/__qualname__=='accumulate'; groupby/__name__/__qualname__; compress/__name__/__qualname__; dropwhile/__name__/__qualname__; takewhile/__name__/__qualname__; starmap/__name__/__qualname__; filterfalse/__name__/__qualname__; pairwise/__name__/__qualname__=='pairwise'; batched/__name__/__qualname__=='batched'; count/__name__/__qualname__=='count'; product/__name__/__qualname__=='product'; permutations/__name__/__qualname__=='permutations'; combinations/__name__/__qualname__=='combinations'; combinations_with_replacement/__name__/__qualname__=='combinations_with_replacement'; cycle/__name__/__qualname__=='cycle'; repeat/__name__/__qualname__=='repeat'; chain.__bases__[0].__name__=='object'; count.__bases__[0].__name__=='object'."
    - "This spec covers: itertools.product.__bases__[0].__name__ == 'object'; itertools.permutations.__bases__[0].__name__ == 'object'; itertools.combinations.__bases__[0].__name__ == 'object'; itertools.combinations_with_replacement.__bases__[0].__name__ == 'object'; itertools.groupby.__bases__[0].__name__ == 'object'; itertools.islice.__bases__[0].__name__ == 'object'; itertools.zip_longest.__bases__[0].__name__ == 'object'; itertools.accumulate.__bases__[0].__name__ == 'object'."
    - "Key findings: All eight itertools C-extension types (product, permutations, combinations, combinations_with_replacement, groupby, islice, zip_longest, accumulate) have __bases__[0].__name__ == 'object'. This completes the __bases__[0].__name__ string equality coverage for the major itertools types — prior spec extra42 covered chain and count (the first two), and this spec covers the remaining eight. All itertools C-extension types are defined in Modules/itertoolsmodule.c as PyTypeObject structures with tp_base == NULL (which CPython resolves to &PyBaseObject_Type, i.e., object). The pattern is universal: every itertools type inherits directly from object with no intermediate base class. Prior specs recorded __bases__[0].__name__.__len__()==6 for all types (confirming the length is 'object') but not the string equality invariants for these eight types."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools combinatoric types __bases__[0].__name__ — extra43 namespace
#
# itertools.product, permutations, combinations, and
# combinations_with_replacement all have __bases__[0].__name__ == 'object'.
# These four types are the combinatoric iterators in itertoolsmodule.c, each
# implemented as a C PyTypeObject that inherits directly from object. Prior
# specs recorded __bases__[0].__name__.__len__()==6 for all itertools types
# (extra41) and string equality for chain and count (extra42), but not for
# these four combinatoric types. These four equality invariants are new.
# ---------------------------------------------------------------------------

table itertools_extra43.combinatoric_bases:
  description: "itertools combinatoric types __bases__[0].__name__ == 'object' — product/permutations/combinations/combinations_with_replacement all inherit directly from object"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: combases43

  columns: [id, function, args, expected, description]
  rows:
    - [product_bases_name,
       "product.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.product.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; produces Cartesian products of input iterables"]
    - [permutations_bases_name,
       "permutations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.permutations.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; produces r-length permutations of input elements"]
    - [combinations_bases_name,
       "combinations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; produces r-length subsequences without repeated elements"]
    - [combinations_with_replacement_bases_name,
       "combinations_with_replacement.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations_with_replacement.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; produces r-length subsequences with repeated elements"]

# ---------------------------------------------------------------------------
# itertools filtering and grouping types __bases__[0].__name__ — extra43 namespace
#
# itertools.groupby, itertools.islice, itertools.zip_longest, and
# itertools.accumulate all have __bases__[0].__name__ == 'object'. These are
# the remaining major itertools C-extension types not covered in extra42 or the
# combinatoric table above. All follow the same inheritance pattern: a single
# base class object (C tp_base == NULL → &PyBaseObject_Type). Prior specs
# recorded __bases__[0].__name__.__len__()==6 for all but not string equality.
# These four equality invariants complete the __bases__[0].__name__ coverage.
# ---------------------------------------------------------------------------

table itertools_extra43.filtering_grouping_bases:
  description: "itertools groupby/islice/zip_longest/accumulate __bases__[0].__name__ == 'object' — all C-extension types inheriting directly from object"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: fgbases43

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_bases_name,
       "groupby.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.groupby.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; groups consecutive elements by a key function"]
    - [islice_bases_name,
       "islice.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.islice.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; slices an iterator without materializing it"]
    - [zip_longest_bases_name,
       "zip_longest.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.zip_longest.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; zips iterables filling shorter ones with a fillvalue"]
    - [accumulate_bases_name,
       "accumulate.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.accumulate.__bases__[0].__name__ == 'object' — C-extension type; inherits directly from object; produces running totals or accumulated results of a binary function"]
