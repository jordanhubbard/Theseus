spec: socket_extra3
version: ">=3.4"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "Python 3 socket module documentation — https://docs.python.org/3/library/socket.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec extends socket.zspec.zsdl, socket_extra.zspec.zsdl, and socket_extra2.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "socket.zspec.zsdl covers: AF_INET/AF_INET6/AF_UNIX integer values; SOCK_STREAM/DGRAM/RAW integer values; IPPROTO_IP/TCP/UDP integer values; SOL_SOCKET; SHUT_RD/WR/RDWR; socket/herror/gaierror __name__; gethostname/getdefaulttimeout/inet_aton/inet_ntoa/htonl/ntohl function names; getdefaulttimeout()==None; inet_aton vectors; htonl(0)==0."
    - "socket_extra.zspec.zsdl covers: create_connection/create_server/setdefaulttimeout/htons/ntohs function names; setdefaulttimeout(None)==None; inet_aton broadcast/len; inet_ntoa loopback/broadcast/zero; htons/ntohs/ntohl zero; htonl(1) little-endian."
    - "socket_extra2.zspec.zsdl covers: AF_INET/AF_INET6/AF_UNIX class names ('AddressFamily'); SOCK_STREAM/DGRAM/RAW class names ('SocketKind'); AF_INET==2; SOCK_STREAM==1; SOCK_DGRAM==2; gethostname/getfqdn return type; socket.error.__name__=='OSError'; socket.timeout.__name__=='TimeoutError'; timeout.__bases__[0].__name__=='OSError'."
    - "This spec focuses on: AddressFamily.__name__; SocketKind.__name__; herror/gaierror base class hierarchy; IPPROTO_TCP/UDP class name ('int'); socket.socket.__module__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; their __name__ attribute is 'AddressFamily' and 'SocketKind' respectively."
    - "socket.herror and socket.gaierror both inherit from OSError; __bases__[0].__name__ == 'OSError'."
    - "socket.IPPROTO_TCP and socket.IPPROTO_UDP are plain int constants (not enum members on all platforms); __class__.__name__ == 'int'."
    - "socket.socket.__module__ == 'socket' — the socket class is defined in the Python socket module wrapper."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "socket raises OSError (and subclasses herror, gaierror, timeout) for I/O failures. Class attribute reads are stateless and never raise."
  stderr: "null"
  stickiness: "N/A — all tested invariants are class name or pure attribute reads."
  codes: {}

# ---------------------------------------------------------------------------
# AddressFamily and SocketKind enum class __name__ checks
# These test the class itself (not its instances); the enum type name is a
# stable string attribute on the class object.
# ---------------------------------------------------------------------------

invariant socket_extra3.AddressFamily.name:
  description: "socket.AddressFamily.__name__ == 'AddressFamily'"
  category: class_metadata
  kind: python_call_eq
  function: AddressFamily.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra3.SocketKind.name:
  description: "socket.SocketKind.__name__ == 'SocketKind'"
  category: class_metadata
  kind: python_call_eq
  function: SocketKind.__name__.__eq__
  args: ["SocketKind"]
  expected: true

# ---------------------------------------------------------------------------
# herror and gaierror — base class hierarchy
# Both are direct subclasses of OSError (POSIX error semantics).
# socket.zspec.zsdl checks __name__; this spec checks the base class.
# ---------------------------------------------------------------------------

invariant socket_extra3.herror.base:
  description: "socket.herror.__bases__[0].__name__ == 'OSError'"
  category: hierarchy
  kind: python_call_eq
  function: herror.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

invariant socket_extra3.gaierror.base:
  description: "socket.gaierror.__bases__[0].__name__ == 'OSError'"
  category: hierarchy
  kind: python_call_eq
  function: gaierror.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# IPPROTO_TCP and IPPROTO_UDP — plain int type check
# socket.zspec.zsdl tests their integer values (6 and 17); this spec verifies
# that their Python type is plain 'int' (not an enum member).
# ---------------------------------------------------------------------------

table socket_extra3.ipproto_class_names:
  kind: python_call_eq
  category: constants
  id_prefix: ipproto_class

  columns: [id, function, args, expected]
  rows:
    - [tcp, IPPROTO_TCP.__class__.__name__.__eq__, ["int"], true]
    - [udp, IPPROTO_UDP.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# socket.socket.__module__ — the socket class lives in the 'socket' module
# ---------------------------------------------------------------------------

invariant socket_extra3.socket_class.module:
  description: "socket.socket.__module__ == 'socket'"
  category: modules
  kind: python_call_eq
  function: socket.__module__.__eq__
  args: ["socket"]
  expected: true
