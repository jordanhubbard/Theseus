spec: lodash_unescape
version: ">=4.0.0"
backend: node(lodash.unescape)

docs: https://lodash.com/docs/#unescape

provenance:
  derived_from:
    - "lodash.unescape README — https://www.npmjs.com/package/lodash.unescape"
    - "Test vectors verified with lodash.unescape@4.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.unescape exports the _.unescape function directly as module.exports."
    - "unescape(string) converts HTML entities back to characters."
    - "Inverse of _.escape."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns unescaped string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_unescape.unescape:
  kind: node_module_call_eq
  function: ~
  category: unescape
  id_prefix: lunesc

  columns: [id, args, expected]
  rows:
    - [amp,     ["a&amp;b"],   "a&b"]
    - [lt,      ["a&lt;b"],    "a<b"]
    - [gt,      ["a&gt;b"],    "a>b"]
    - [dquote,  ["a&quot;b"],  'a"b']
    - [squote,  ["a&#39;b"],   "a'b"]
    - [plain,   ["hello"],     "hello"]
