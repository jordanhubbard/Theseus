spec: pathlib_extra138
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path property descriptors — __class__.__name__, fget.__qualname__, and fget.__qualname__.__len__() for parent, name, stem, suffix, suffixes, parts."
    - "All of pathlib.Path's path-component properties (parent, name, stem, suffix, suffixes, parts) are plain 'property' descriptors."
    - "pathlib.Path.parent.__class__.__name__ == 'property'."
    - "pathlib.Path.name.__class__.__name__ == 'property'."
    - "pathlib.Path.stem.__class__.__name__ == 'property'."
    - "pathlib.Path.suffix.__class__.__name__ == 'property'."
    - "pathlib.Path.suffixes.__class__.__name__ == 'property'."
    - "pathlib.Path.parts.__class__.__name__ == 'property'."
    - "The fget functions for these properties are defined on PurePath (the abstract base), so their __qualname__ is 'PurePath.<property_name>'."
    - "pathlib.Path.parent.fget.__qualname__ == 'PurePath.parent' (length 15)."
    - "pathlib.Path.name.fget.__qualname__ == 'PurePath.name' (length 13)."
    - "pathlib.Path.stem.fget.__qualname__ == 'PurePath.stem' (length 13)."
    - "pathlib.Path.suffix.fget.__qualname__ == 'PurePath.suffix' (length 15)."
    - "pathlib.Path.suffixes.fget.__qualname__ == 'PurePath.suffixes' (length 17)."
    - "pathlib.Path.parts.fget.__qualname__ == 'PurePath.parts' (length 14)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path property descriptor __class__.__name__ for all six properties
# All are plain 'property' descriptors (not DynamicClassAttribute or similar).
# parent, name, stem, suffix, suffixes, parts all return 'property'.
# ---------------------------------------------------------------------------

table pathlib_extra138.path_property_class_names:
  description: "pathlib.Path property descriptor __class__.__name__ for parent, name, stem, suffix, suffixes, parts: all equal 'property'"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: pathlibprop138

  columns: [id, function, args, expected]
  rows:
    - [parent_cls,    Path.parent.__class__.__name__.__eq__,   ["property"], true]
    - [name_cls,      Path.name.__class__.__name__.__eq__,     ["property"], true]
    - [stem_cls,      Path.stem.__class__.__name__.__eq__,     ["property"], true]
    - [suffix_cls,    Path.suffix.__class__.__name__.__eq__,   ["property"], true]
    - [suffixes_cls,  Path.suffixes.__class__.__name__.__eq__, ["property"], true]
    - [parts_cls,     Path.parts.__class__.__name__.__eq__,    ["property"], true]
    - [parent_not_fn, Path.parent.__class__.__name__.__eq__,   ["function"], false]
    - [name_not_fn,   Path.name.__class__.__name__.__eq__,     ["function"], false]

# ---------------------------------------------------------------------------
# pathlib.Path property fget.__qualname__ values
# fget functions are defined on PurePath, so __qualname__ == 'PurePath.<name>'.
# parent: 'PurePath.parent' (len 15), name: 'PurePath.name' (len 13),
# stem: 'PurePath.stem' (len 13), suffix: 'PurePath.suffix' (len 15).
# ---------------------------------------------------------------------------

table pathlib_extra138.path_property_fget_qualnames:
  description: "pathlib.Path property fget.__qualname__ values: PurePath.parent (15), PurePath.name (13), PurePath.stem (13), PurePath.suffix (15)"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: pathlibprop138

  columns: [id, function, args, expected]
  rows:
    - [parent_qn_eq,   Path.parent.fget.__qualname__.__eq__,   ["PurePath.parent"],  true]
    - [parent_qn_len,  Path.parent.fget.__qualname__.__len__,  [],                   15]
    - [name_qn_eq,     Path.name.fget.__qualname__.__eq__,     ["PurePath.name"],    true]
    - [name_qn_len,    Path.name.fget.__qualname__.__len__,    [],                   13]
    - [stem_qn_eq,     Path.stem.fget.__qualname__.__eq__,     ["PurePath.stem"],    true]
    - [stem_qn_len,    Path.stem.fget.__qualname__.__len__,    [],                   13]
    - [suffix_qn_eq,   Path.suffix.fget.__qualname__.__eq__,   ["PurePath.suffix"],  true]
    - [suffix_qn_len,  Path.suffix.fget.__qualname__.__len__,  [],                   15]
    - [parent_not_pp,  Path.parent.fget.__qualname__.__eq__,   ["Path.parent"],      false]

# ---------------------------------------------------------------------------
# pathlib.Path property fget.__qualname__ for suffixes and parts
# suffixes: 'PurePath.suffixes' (len 17), parts: 'PurePath.parts' (len 14).
# ---------------------------------------------------------------------------

table pathlib_extra138.path_property_fget_suffixes_parts:
  description: "pathlib.Path.suffixes and Path.parts fget.__qualname__ and __len__: PurePath.suffixes (17), PurePath.parts (14)"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: pathlibprop138

  columns: [id, function, args, expected]
  rows:
    - [suffixes_qn_eq,  Path.suffixes.fget.__qualname__.__eq__,  ["PurePath.suffixes"], true]
    - [suffixes_qn_len, Path.suffixes.fget.__qualname__.__len__, [],                    17]
    - [parts_qn_eq,     Path.parts.fget.__qualname__.__eq__,     ["PurePath.parts"],    true]
    - [parts_qn_len,    Path.parts.fget.__qualname__.__len__,    [],                    14]
    - [suffixes_not_pp, Path.suffixes.fget.__qualname__.__eq__,  ["Path.suffixes"],     false]
    - [parts_not_pp,    Path.parts.fget.__qualname__.__eq__,     ["Path.parts"],        false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra138.Path.parent_is_property:
  description: "pathlib.Path.parent.__class__.__name__ == 'property' (parent is a plain property descriptor, not a DynamicClassAttribute or other descriptor type)"
  category: descriptor_identity
  kind: python_call_eq
  function: Path.parent.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra138.Path.parent_fget_qualname_PurePath:
  description: "pathlib.Path.parent.fget.__qualname__ == 'PurePath.parent' (the fget is defined on PurePath, the abstract base, not on Path itself)"
  category: descriptor_identity
  kind: python_call_eq
  function: Path.parent.fget.__qualname__.__eq__
  args: ["PurePath.parent"]
  expected: true

invariant pathlib_extra138.Path.parent_fget_qualname_len_15:
  description: "pathlib.Path.parent.fget.__qualname__.__len__() == 15 ('PurePath.parent' is 15 characters: 'PurePath' (8) + '.' (1) + 'parent' (6))"
  category: descriptor_identity
  kind: python_call_eq
  function: Path.parent.fget.__qualname__.__len__
  args: []
  expected: 15

invariant pathlib_extra138.Path.suffixes_fget_qualname_PurePath:
  description: "pathlib.Path.suffixes.fget.__qualname__ == 'PurePath.suffixes' (len 17); suffixes property fget is inherited from PurePath"
  category: descriptor_identity
  kind: python_call_eq
  function: Path.suffixes.fget.__qualname__.__eq__
  args: ["PurePath.suffixes"]
  expected: true

invariant pathlib_extra138.Path.name_is_property:
  description: "pathlib.Path.name.__class__.__name__ == 'property' (the 'name' attribute of Path is a property descriptor, not a plain data attribute)"
  category: descriptor_identity
  kind: python_call_eq
  function: Path.name.__class__.__name__.__eq__
  args: ["property"]
  expected: true

