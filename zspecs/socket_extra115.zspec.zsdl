spec: socket_extra115
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra114.zspec.zsdl — covers gethostname/gethostbyname/getnameinfo/getfqdn/getaddrinfo __name__ equality and lengths / getaddrinfo co_argcount==6 and co_name / function __qualname__ equality (table + invariants)."
    - "socket_extra113.zspec.zsdl — covers socket.socket.send/recv/listen/accept/setsockopt/getsockopt qualname equality and type identity (table + invariants)."
    - "socket_extra112.zspec.zsdl — covers AddressFamily/SocketKind enum .name equality and lengths / socket.socket MRO structure / socket.socket.bind and connect qualname lengths (table + invariants)."
    - "socket_extra111.zspec.zsdl — covers socket module-level __name__/__package__/__spec__/__all__/__loader__ dunder attributes (table + invariants)."
    - "socket_extra110.zspec.zsdl — covers socket.socket context manager methods / socket.__repr__ qualname / socket.socket.__module__/__qualname__ equality (table + invariants)."
    - "socket_extra109.zspec.zsdl — covers socket.socket Python-defined method co_argcount values and qualnames (table + invariants)."
    - "socket_extra108.zspec.zsdl — covers gethostname/gethostbyname/getnameinfo/getaddrinfo/getfqdn function identities and __module__ equality / setdefaulttimeout/getdefaulttimeout type / getfqdn code attributes (table + invariants)."
    - "socket_extra107.zspec.zsdl — covers SO_* option constants class names and integer values / socket.error/__name__/bases/mro / socket.timeout/__name__/mro (table + invariants)."
    - "socket_extra103.zspec.zsdl — covers socket.inet_aton/ntoa/pton/ntop __class__.__name__ / herror/gaierror __mro__.__len__()==5 / AddressFamily/SocketKind __mro__.__len__()==6 (table + invariants)."
    - "socket_extra102.zspec.zsdl — covers socket.socket/__qualname__/__name__/__len__()==6 / error/__name__.__eq__('OSError') / herror/gaierror qualname/module/bases as lengths / AddressFamily/SocketKind qualname lengths and module (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module-level function qualname lengths / SocketIO class metaclass/module/bases (table + invariants)."
  notes:
    - "This spec extends socket through socket_extra114; it does NOT duplicate invariants present in those files."
    - "Wave 275 theme: socket module error class hierarchy not yet covered as __eq__ calls — socket_extra107 anchors error/__name__/'OSError', error bases, error mro, timeout/__name__/'TimeoutError', timeout mro; socket_extra102 anchors herror/gaierror __qualname__ and __module__ as table rows but via __len__() not __eq__(); not yet covered: herror.__name__.__eq__('herror'), gaierror.__name__.__eq__('gaierror'), error.__module__.__eq__('builtins'), timeout.__module__.__eq__('builtins'), timeout.__bases__[0].__name__.__eq__('OSError'), and __name__ lengths."
    - "socket.herror.__name__ == 'herror'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__name__ == 'gaierror'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__bases__[0].__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__name__.__len__() == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__name__.__len__() == 12. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__name__.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__name__.__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.error is an alias for the built-in OSError (defined in builtins; __module__=='builtins'). socket.timeout is an alias for the built-in TimeoutError (also __module__=='builtins'). By contrast, socket.herror and socket.gaierror are genuine socket-specific exceptions defined in Lib/socket.py (__module__=='socket'). This distinction — builtins vs socket — separates the alias exceptions from the socket-defined ones."
    - "Note: socket_extra107 anchors error.__mro__.__len__()==4 and timeout.__mro__.__len__()==5; socket_extra103 anchors herror/gaierror __mro__.__len__()==5. socket_extra102 anchors herror.__module__ and herror.__bases__[0].__name__ via table notes (len-based rows). This spec anchors the __name__/__module__ equality as direct __eq__ calls for a new angle."
    - "Note: socket.timeout.__bases__[0].__name__=='OSError' (not covered as __eq__ in extra107 which only has timeout.__mro__.__len__()==5). timeout inherits from OSError, which inherits from Exception, BaseException, object — MRO depth 5."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.herror.__name__.__eq__('herror')
# socket.gaierror.__name__.__eq__('gaierror')
# socket.herror.__module__.__eq__('socket')
# socket.gaierror.__module__.__eq__('socket')
# socket.herror.__name__.__len__() == 6
#
# Wave 275 theme: socket-defined exception class __name__ and __module__ equality.
#
# herror and gaierror are genuine socket exceptions defined in Lib/socket.py.
# Their __name__ values are 'herror' (6 chars) and 'gaierror' (8 chars).
# Their __module__ is 'socket' (not 'builtins'). socket_extra102 anchors
# herror/__qualname__.__len__() and herror/__module__ via table rows (len-based
# not __eq__-based). This spec anchors __name__.__eq__ and __module__.__eq__
# calls as the primary form. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra115.socket_defined_exception_name_and_module:
  description: "herror.__name__.__eq__('herror')==True / gaierror.__name__.__eq__('gaierror')==True / herror.__module__.__eq__('socket')==True / gaierror.__module__.__eq__('socket')==True / herror.__name__.__len__()==6 — herror and gaierror are socket-defined exceptions (__module__=='socket'); contrasts with error/timeout which are builtins aliases (__module__=='builtins'); herror=6 chars, gaierror=8 chars; extra102 anchors qualname len/module but not as __eq__; first sockerr115 anchor for name/module equality"
  kind: python_call_eq
  category: exception_identity
  id_prefix: sockerr115

  columns: [id, function, args, expected, description]
  rows:
    - [herror_name_eq,    "herror.__name__.__eq__",    ["herror"],  true, "socket.herror.__name__ is 'herror' (6 chars; host resolution error; socket-defined exception in Lib/socket.py)"]
    - [gaierror_name_eq,  "gaierror.__name__.__eq__",  ["gaierror"],true, "socket.gaierror.__name__ is 'gaierror' (8 chars; address info error from getaddrinfo; socket-defined exception)"]
    - [herror_module_eq,  "herror.__module__.__eq__",  ["socket"],  true, "socket.herror.__module__ is 'socket' (defined in Lib/socket.py; not a builtins alias; contrasts with error/timeout)"]
    - [gaierror_module_eq,"gaierror.__module__.__eq__",["socket"],  true, "socket.gaierror.__module__ is 'socket' (defined in Lib/socket.py; same module as herror; both are socket-specific)"]
    - [herror_name_len,   "herror.__name__.__len__",   [],          6,    "socket.herror.__name__.__len__() is 6 ('herror': 6 chars; shorter than gaierror at 8)"]

# ---------------------------------------------------------------------------
# socket.error.__module__.__eq__('builtins')
# socket.timeout.__module__.__eq__('builtins')
# socket.error.__name__.__len__() == 7
# socket.timeout.__name__.__len__() == 12
# socket.gaierror.__name__.__len__() == 8
#
# Wave 275 theme: socket alias exception __module__ equality and __name__ lengths.
#
# socket.error is an alias for OSError and socket.timeout is an alias for
# TimeoutError — both are built-in exceptions with __module__ == 'builtins'.
# socket_extra107 anchors error.__name__=='OSError' and timeout.__name__=='TimeoutError'
# but NOT their __module__ as an __eq__ call. error.__name__.__len__() == 7 ('OSError'),
# timeout.__name__.__len__() == 12 ('TimeoutError'). gaierror.__name__.__len__() == 8.
# No prior socket spec anchors these as a grouped table. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table socket_extra115.builtin_alias_exception_module_and_name_lens:
  description: "error.__module__.__eq__('builtins')==True / timeout.__module__.__eq__('builtins')==True / error.__name__.__len__()==7 / timeout.__name__.__len__()==12 / gaierror.__name__.__len__()==8 — error and timeout are builtins aliases (__module__=='builtins'); herror/gaierror have __module__=='socket'; error name 'OSError'=7 chars; timeout name 'TimeoutError'=12 chars; gaierror=8 chars; extra107 anchors error/timeout __name__ equality but not __module__; first sockerr115 anchor"
  kind: python_call_eq
  category: exception_identity
  id_prefix: sockerr115

  columns: [id, function, args, expected, description]
  rows:
    - [error_module_eq,   "error.__module__.__eq__",   ["builtins"], true, "socket.error.__module__ is 'builtins' (socket.error is OSError alias; OSError is a built-in exception)"]
    - [timeout_module_eq, "timeout.__module__.__eq__", ["builtins"], true, "socket.timeout.__module__ is 'builtins' (socket.timeout is TimeoutError alias; TimeoutError is a built-in exception)"]
    - [error_name_len,    "error.__name__.__len__",    [],           7,    "socket.error.__name__.__len__() is 7 (len('OSError')==7; error is alias for OSError)"]
    - [timeout_name_len,  "timeout.__name__.__len__",  [],           12,   "socket.timeout.__name__.__len__() is 12 (len('TimeoutError')==12; timeout is alias for TimeoutError)"]
    - [gaierror_name_len, "gaierror.__name__.__len__", [],           8,    "socket.gaierror.__name__.__len__() is 8 (len('gaierror')==8; longer than herror at 6)"]

# ---------------------------------------------------------------------------
# socket.timeout.__bases__[0].__name__.__eq__('OSError')
# socket.herror.__bases__[0].__name__.__eq__('OSError')
# socket.gaierror.__bases__[0].__name__.__eq__('OSError')
# socket.herror.__module__.__eq__('socket')
# socket.gaierror.__module__.__eq__('socket')
#
# Wave 275 theme: socket exception base class identity — all inherit from OSError.
#
# socket.timeout, socket.herror, and socket.gaierror all have OSError as their
# direct base class (__bases__[0].__name__ == 'OSError'). socket_extra107 anchors
# error.__bases__[0].__name__=='Exception' (OSError inherits from Exception).
# That spec covers timeout.__mro__.__len__()==5 but NOT timeout.__bases__[0].__name__.
# socket_extra102 anchors herror.__bases__[0].__name__ as a note but the table
# rows use __len__() not __eq__(). This spec anchors all three direct base class
# identities as __eq__ calls. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra115.exception_direct_base_is_OSError:
  description: "timeout.__bases__[0].__name__.__eq__('OSError')==True / herror.__bases__[0].__name__.__eq__('OSError')==True / gaierror.__bases__[0].__name__.__eq__('OSError')==True / herror.__module__.__eq__('socket')==True / gaierror.__module__.__eq__('socket')==True — timeout/herror/gaierror all directly inherit from OSError; error itself IS OSError (__bases__[0]=='Exception'); this makes all four socket exceptions part of the OSError hierarchy; extra107 anchors timeout mro len but not timeout bases; extra102 anchors herror bases via notes; first sockerr115 anchor for these base equalities"
  kind: python_call_eq
  category: exception_identity
  id_prefix: sockerr115

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_base_eq,   "timeout.__bases__[0].__name__.__eq__",  ["OSError"], true, "socket.timeout.__bases__[0].__name__ is 'OSError' (TimeoutError directly inherits from OSError; MRO depth 5)"]
    - [herror_base_eq,    "herror.__bases__[0].__name__.__eq__",   ["OSError"], true, "socket.herror.__bases__[0].__name__ is 'OSError' (herror is a socket-defined exception inheriting from OSError)"]
    - [gaierror_base_eq,  "gaierror.__bases__[0].__name__.__eq__", ["OSError"], true, "socket.gaierror.__bases__[0].__name__ is 'OSError' (gaierror is a socket-defined exception inheriting from OSError)"]
    - [herror_module_eq2, "herror.__module__.__eq__",              ["socket"],  true, "socket.herror.__module__ is 'socket' (cross-check; same as in first table; defined in Lib/socket.py)"]
    - [gaierror_module_eq2,"gaierror.__module__.__eq__",           ["socket"],  true, "socket.gaierror.__module__ is 'socket' (cross-check; same as in first table; defined in Lib/socket.py)"]

# ---------------------------------------------------------------------------
# socket.herror.__name__.__eq__('herror') — standalone
#
# socket.herror.__name__ is 'herror' (6 chars). socket.herror is a socket-
# specific exception raised for host-related errors in address translation
# operations (like gethostbyname_ex, gethostbyaddr). It is defined in
# Lib/socket.py as a subclass of OSError. Unlike socket.error (which is an
# alias for the built-in OSError), herror is a genuine socket-defined class
# with __module__ == 'socket'. socket_extra102 anchors herror.__qualname__.__len__()
# and herror.__module__ via table rows; this spec anchors herror.__name__.__eq__
# as a standalone for the first time under sockerr115.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra115.herror_name_eq:
  description: "socket.herror.__name__.__eq__('herror') == True — __name__ is 'herror' (6 chars; host resolution error; socket-defined exception in Lib/socket.py; __module__=='socket'); contrasts with error.__name__=='OSError' (builtins alias); extra102 anchors herror qualname len; no prior spec anchors herror __name__ equality as standalone; first standalone under sockerr115"
  category: exception_identity
  kind: python_call_eq
  function: "herror.__name__.__eq__"
  args: ["herror"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gaierror.__name__.__eq__('gaierror') — standalone
#
# socket.gaierror.__name__ is 'gaierror' (8 chars). socket.gaierror is raised
# for address-related errors from getaddrinfo() and getnameinfo(). 'gai' stands
# for 'getaddrinfo'. gaierror is defined in Lib/socket.py as a subclass of
# OSError. It is a genuine socket-defined exception (__module__ == 'socket').
# socket_extra102 anchors gaierror.__qualname__.__len__() and gaierror.__module__
# via table rows; this spec anchors gaierror.__name__.__eq__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra115.gaierror_name_eq:
  description: "socket.gaierror.__name__.__eq__('gaierror') == True — __name__ is 'gaierror' (8 chars; 'gai'=getaddrinfo + 'error'=5=8; raised by getaddrinfo/getnameinfo; socket-defined exception; __module__=='socket'); extra102 anchors gaierror qualname len; no prior spec anchors gaierror __name__ equality as standalone; first standalone under sockerr115"
  category: exception_identity
  kind: python_call_eq
  function: "gaierror.__name__.__eq__"
  args: ["gaierror"]
  expected: true

# ---------------------------------------------------------------------------
# socket.error.__module__.__eq__('builtins') — standalone
#
# socket.error.__module__ is 'builtins'. socket.error is an alias for the
# built-in OSError exception. Since Python 3.3, socket.error was unified with
# OSError (PEP 3151). socket.error is OSError evaluates to True. Because
# OSError is a built-in exception, its __module__ is 'builtins'. This
# contrasts with herror and gaierror whose __module__ is 'socket'. socket_extra107
# anchors error.__name__=='OSError' and error.__mro__.__len__()==4 but NOT
# error.__module__ as an __eq__ call. No prior socket spec anchors error.__module__
# equality as a standalone under sockerr115.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra115.error_module_builtins:
  description: "socket.error.__module__.__eq__('builtins') == True — socket.error is an alias for OSError (since Python 3.3 PEP 3151); OSError is a built-in exception with __module__=='builtins'; contrasts with herror/gaierror (__module__=='socket'); extra107 anchors error __name__ and MRO; no prior spec anchors error __module__ as standalone; first standalone under sockerr115"
  category: exception_identity
  kind: python_call_eq
  function: "error.__module__.__eq__"
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# socket.timeout.__bases__[0].__name__.__eq__('OSError') — standalone
#
# socket.timeout.__bases__[0].__name__ is 'OSError'. socket.timeout is an
# alias for the built-in TimeoutError. TimeoutError directly inherits from
# OSError (its __bases__[0] is OSError). This makes the MRO:
# TimeoutError -> OSError -> Exception -> BaseException -> object (depth 5,
# anchored in socket_extra107). socket_extra107 anchors timeout.__mro__.__len__()==5
# but NOT timeout.__bases__[0].__name__ as an __eq__ call. No prior socket
# spec anchors socket.timeout.__bases__[0].__name__ equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra115.timeout_base_OSError:
  description: "socket.timeout.__bases__[0].__name__.__eq__('OSError') == True — timeout is TimeoutError alias; TimeoutError.__bases__[0] is OSError (MRO: TimeoutError->OSError->Exception->BaseException->object; depth 5); extra107 anchors timeout mro len but not bases; no prior spec anchors timeout bases as standalone; first standalone under sockerr115"
  category: exception_identity
  kind: python_call_eq
  function: "timeout.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.timeout.__module__.__eq__('builtins') — standalone
#
# socket.timeout.__module__ is 'builtins'. socket.timeout is an alias for
# the built-in TimeoutError. TimeoutError is defined in builtins (it was
# merged with socket.timeout in Python 3.3 via PEP 3151). Because TimeoutError
# is a built-in exception, its __module__ is 'builtins'. socket_extra107
# anchors timeout.__name__=='TimeoutError' and timeout.__mro__.__len__()==5
# but NOT timeout.__module__ as an __eq__ call. No prior socket spec anchors
# socket.timeout.__module__ equality as a standalone under sockerr115.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra115.timeout_module_builtins:
  description: "socket.timeout.__module__.__eq__('builtins') == True — socket.timeout is an alias for TimeoutError (built-in exception; __module__=='builtins'; merged in Python 3.3 PEP 3151); contrasts with herror/gaierror (__module__=='socket'); extra107 anchors timeout __name__ and MRO; no prior spec anchors timeout __module__ as standalone; first standalone under sockerr115"
  category: exception_identity
  kind: python_call_eq
  function: "timeout.__module__.__eq__"
  args: ["builtins"]
  expected: true

