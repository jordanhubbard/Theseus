spec: socket_extra58
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra57.zspec.zsdl — covers socket.__all__.__contains__ for gethostname/gethostbyname/getaddrinfo/timeout (table); socket.__dict__.__contains__ for socket/gethostname/AF_INET/herror (table); herror.__doc__.__class__.__name__.__eq__('NoneType') (invariant)."
    - "socket_extra56.zspec.zsdl — covers socket.__all__.__contains__ for AF_INET/SOCK_STREAM/socket/herror/gaierror (table); socket.socket/__eq__/__class__/__name__.__eq__('wrapper_descriptor'); herror/gaierror/timeout __eq__.__class__.__name__.__eq__('wrapper_descriptor')."
    - "socket_extra30.zspec.zsdl — covers socket.__all__.__len__()==238 and socket.__all__.__class__.__name__.__eq__('list')."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra57; it does NOT duplicate invariants present in those files."
    - "Wave 225 theme: __loader__ identity + __spec__ attribute chains + __file__/__cached__ class name checks."
    - "socket in Python 3 is a Python wrapper module (Lib/socket.py) that imports the _socket C extension internally. The top-level 'socket' module is loaded from socket.py; therefore socket.__loader__.__class__.__name__ == 'SourceFileLoader', socket.__file__ and socket.__cached__ are str paths. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 1: No prior socket spec checks socket.__loader__.__class__.__name__.__eq__('SourceFileLoader'). No prior socket spec checks any of socket.__loader__.__class__.__name__, socket.__spec__.__class__.__name__, socket.__file__.__class__.__name__, or socket.__cached__.__class__.__name__ via __eq__. All four are entirely novel for the socket module. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__loader__.__class__.__name__ == 'SourceFileLoader'. socket.py is loaded by importlib.machinery.SourceFileLoader. No prior socket spec checks socket.__loader__.__class__.__name__ in any form (__eq__ or __len__). Entirely novel loader identity anchor for socket. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__spec__.__class__.__name__ == 'ModuleSpec'. The socket module's __spec__ attribute is an importlib.machinery.ModuleSpec instance. No prior socket spec checks socket.__spec__.__class__.__name__ in any form. Entirely novel spec class identity anchor for socket. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__file__.__class__.__name__ == 'str'. socket is loaded from a .py source file (Lib/socket.py); its __file__ attribute is a Python str path. No prior socket spec checks socket.__file__.__class__.__name__ in any form. Entirely novel __file__ type anchor for socket. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__cached__.__class__.__name__ == 'str'. socket.py has a compiled bytecode cache; its __cached__ attribute is a Python str path to the .pyc file. No prior socket spec checks socket.__cached__.__class__.__name__ in any form. Entirely novel __cached__ type anchor for socket. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket loader identity + module spec/file/cached class name checks
#
# Wave 225 theme: __loader__ identity + __spec__ attribute chains +
# __file__/__cached__ class name checks.
#
# socket is a Python wrapper module (Lib/socket.py) that imports the _socket
# C extension. Its loader is SourceFileLoader; it has str __file__ and
# __cached__ paths. No prior socket spec has ever checked any of these four
# attribute chains in any form — all are entirely novel for socket.
# ---------------------------------------------------------------------------

table socket_extra58.loader_spec_file_cached:
  description: "socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') — loader/spec/file/cached class identity for the socket Python wrapper module; no prior socket spec checks any of these four attribute chains in any form (__eq__ or __len__); all four are entirely novel equality anchors for socket"
  kind: python_call_eq
  category: module_structure
  id_prefix: socketload58

  columns: [id, function, args, expected]
  rows:
    - [loader_class_name_eq,  __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"], true]
    - [spec_class_name_eq,    __spec__.__class__.__name__.__eq__,    ["ModuleSpec"],       true]
    - [file_class_name_eq,    __file__.__class__.__name__.__eq__,    ["str"],              true]
    - [cached_class_name_eq,  __cached__.__class__.__name__.__eq__,  ["str"],              true]

# ---------------------------------------------------------------------------
# socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# No prior socket spec checks socket.__loader__ in any form. SourceFileLoader
# identity is the primary confirmation that socket.py is loaded as a
# pure-Python source wrapper, not as the underlying C extension _socket.
# This is the primary loader identity anchor for the socket module.
# ---------------------------------------------------------------------------

invariant socket_extra58.loader_class_name_sourcefileloader:
  description: "socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — socket.py is a pure-Python wrapper loaded by SourceFileLoader; no prior socket spec checks socket.__loader__ in any form; primary loader identity anchor for socket confirming the Python-wrapper loading path"
  category: module_structure
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true
