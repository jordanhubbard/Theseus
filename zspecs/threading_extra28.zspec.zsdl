spec: threading_extra28
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends prior threading specs through threading_extra27.zspec.zsdl."
    - "threading_extra27 covers: Thread/RLock/Event/Condition/Semaphore __module__ table; Lock/local __module__ (_thread); Lock.__qualname__ (lock, lowercase); local.__qualname__ (_local); Thread.__bases__[0].__name__ (object)."
    - "threading_extra19 covers: Lock/RLock/Condition/Semaphore/Timer/Barrier/BoundedSemaphore __qualname__ eq table."
    - "NOT yet covered in any prior spec: threading.Event.__name__ standalone invariant in extra28 namespace."
    - "NOT yet covered: threading.Event.__qualname__ standalone invariant in extra28 namespace."
    - "NOT yet covered: threading.Condition.__name__ standalone invariant in extra28 namespace."
    - "NOT yet covered: threading.Semaphore.__name__ standalone invariant in extra28 namespace."
    - "NOT yet covered: threading.BoundedSemaphore.__name__ standalone invariant in extra28 namespace."
    - "NOT yet covered: threading.Timer.__name__ and __module__ standalone invariants in extra28 namespace."
    - "NOT yet covered: threading.Barrier.__name__ and __module__ standalone invariants in extra28 namespace."
    - "NOT yet covered: threading.Thread.__init__.__name__ standalone invariant in extra28 namespace."
    - "Event.__name__ == 'Event' — length 5."
    - "Event.__module__ == 'threading' — length 9."
    - "Event.__qualname__ == 'Event' — length 5."
    - "Condition.__name__ == 'Condition' — length 9."
    - "Semaphore.__name__ == 'Semaphore' — length 9."
    - "Semaphore.__module__ == 'threading' — length 9."
    - "BoundedSemaphore.__name__ == 'BoundedSemaphore' — length 16."
    - "Timer.__name__ == 'Timer' — length 5."
    - "Timer.__module__ == 'threading' — length 9."
    - "Barrier.__name__ == 'Barrier' — length 7."
    - "Barrier.__module__ == 'threading' — length 9."
    - "Thread.__init__.__name__ == '__init__' — length 8."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ table — extra28 namespace
#
# threading.Event, Condition, Semaphore, BoundedSemaphore, Timer, Barrier
# are all pure-Python classes defined in Lib/threading.py. Their __name__
# values match their class names. No prior spec groups these into a single
# __name__ table in the extra28 namespace.
# Lengths: Event(5), Condition(9), Semaphore(9), BoundedSemaphore(16),
#          Timer(5), Barrier(7).
# ---------------------------------------------------------------------------

table threading_extra28.class_names:
  description: "threading sync class __name__ values in extra28 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: clsname28

  columns: [id, function, args, expected]
  rows:
    - [Event,            Event.__name__.__eq__,            ["Event"],            true]
    - [Condition,        Condition.__name__.__eq__,        ["Condition"],        true]
    - [Semaphore,        Semaphore.__name__.__eq__,        ["Semaphore"],        true]
    - [BoundedSemaphore, BoundedSemaphore.__name__.__eq__, ["BoundedSemaphore"], true]
    - [Timer,            Timer.__name__.__eq__,            ["Timer"],            true]
    - [Barrier,          Barrier.__name__.__eq__,          ["Barrier"],          true]

# ---------------------------------------------------------------------------
# Class __name__ length table — extra28 namespace
#
# Lengths: Event(5), Condition(9), Semaphore(9), BoundedSemaphore(16),
#          Timer(5), Barrier(7).
# ---------------------------------------------------------------------------

table threading_extra28.class_name_lengths:
  description: "threading sync class __name__ lengths in extra28 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: clsnamelen28

  columns: [id, function, args, expected]
  rows:
    - [Event,            Event.__name__.__len__,            [], 5]
    - [Condition,        Condition.__name__.__len__,        [], 9]
    - [Semaphore,        Semaphore.__name__.__len__,        [], 9]
    - [BoundedSemaphore, BoundedSemaphore.__name__.__len__, [], 16]
    - [Timer,            Timer.__name__.__len__,            [], 5]
    - [Barrier,          Barrier.__name__.__len__,          [], 7]

# ---------------------------------------------------------------------------
# Class __module__ table — extra28 namespace (Timer and Barrier)
#
# threading_extra27 already covers Event/Condition/Semaphore __module__.
# This spec covers Timer and Barrier __module__ in the extra28 namespace.
# Both are defined in Lib/threading.py, so __module__ == 'threading' (length 9).
# ---------------------------------------------------------------------------

table threading_extra28.timer_barrier_modules:
  description: "threading.Timer and threading.Barrier __module__ values in extra28 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: tbmod28

  columns: [id, function, args, expected]
  rows:
    - [Timer,   Timer.__module__.__eq__,   ["threading"], true]
    - [Barrier, Barrier.__module__.__eq__, ["threading"], true]

# ---------------------------------------------------------------------------
# Class __module__ length table — extra28 namespace (Timer and Barrier)
#
# Both have __module__ == 'threading' (length 9).
# ---------------------------------------------------------------------------

table threading_extra28.timer_barrier_module_lengths:
  description: "threading.Timer and threading.Barrier __module__ lengths in extra28 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: tbmodlen28

  columns: [id, function, args, expected]
  rows:
    - [Timer,   Timer.__module__.__len__,   [], 9]
    - [Barrier, Barrier.__module__.__len__, [], 9]

# ---------------------------------------------------------------------------
# Event.__qualname__ — standalone extra28 invariant
#
# threading.Event is a pure-Python class; its __qualname__ == 'Event' (length 5).
# threading_extra19 checked __qualname__ for Lock/RLock/Condition/Semaphore/
# Timer/Barrier/BoundedSemaphore, but not for Event. No prior spec checks
# threading.Event.__qualname__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant threading_extra28.Event.qualname:
  description: "threading.Event.__qualname__ == 'Event' — pure-Python class, qualname matches name"
  category: method_names
  kind: python_call_eq
  function: Event.__qualname__.__eq__
  args: ["Event"]
  expected: true

# ---------------------------------------------------------------------------
# Thread.__init__.__name__ — standalone extra28 invariant
#
# threading.Thread.__init__ is the constructor method. Its __name__ is
# '__init__' (length 8). No prior spec checks Thread.__init__.__name__ directly.
# ---------------------------------------------------------------------------

invariant threading_extra28.Thread.init_name:
  description: "threading.Thread.__init__.__name__ == '__init__' — constructor method name"
  category: method_names
  kind: python_call_eq
  function: Thread.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true
