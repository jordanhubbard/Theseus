spec: threading_extra240
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading.RLock class identity and method contracts."
    - "threading.RLock is a factory function in Lib/threading.py that returns a _thread.RLock C instance."
    - "threading.RLock.__name__ == 'RLock' (len=5) — RLock is a Python factory function in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.RLock.__module__ == 'threading' (len=9) — the factory function is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading._RLock.acquire.__qualname__ == '_RLock.acquire' (len=14) — acquire is a Python method of _RLock in Lib/threading.py. Verified with Python 3.14.3."
    - "threading._RLock.release.__qualname__ == '_RLock.release' (len=14) — release is a Python method of _RLock in Lib/threading.py. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.RLock factory function identity contracts
#
# threading.RLock.__name__ == 'RLock' (len=5)
# threading.RLock.__module__ == 'threading' (len=9)
# threading.RLock.__qualname__ == 'RLock' (len=5)
# threading.RLock.__class__.__name__ == 'function'
# threading.RLock.__doc__.__contains__('reentrant') == True
#
# RLock is a factory function in Lib/threading.py. New to extra240.
# ---------------------------------------------------------------------------

table threading_extra240.rlock240_identity:
  description: "threading.RLock factory function identity: name, module, qualname, class, doc; new to extra240"
  kind: python_call_eq
  category: identity
  id_prefix: rlock240

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_name_eq,
       RLock.__name__.__eq__,
       ["RLock"],
       true,
       "threading.RLock.__name__.__eq__('RLock') == True — RLock is a factory function in Lib/threading.py; __name__ is 'RLock' (len=5); new to extra240"]
    - [rlock_name_len_5,
       RLock.__name__.__len__,
       [],
       5,
       "threading.RLock.__name__.__len__() == 5 — 'RLock' has exactly 5 characters (R-L-o-c-k); str.__len__() returns 5; new to extra240"]
    - [rlock_module_eq,
       RLock.__module__.__eq__,
       ["threading"],
       true,
       "threading.RLock.__module__.__eq__('threading') == True — RLock factory function is defined in Lib/threading.py; __module__ is 'threading' (len=9); new to extra240"]
    - [rlock_module_len_9,
       RLock.__module__.__len__,
       [],
       9,
       "threading.RLock.__module__.__len__() == 9 — 'threading' has exactly 9 characters; str.__len__() returns 9; new to extra240"]
    - [rlock_qualname_eq,
       RLock.__qualname__.__eq__,
       ["RLock"],
       true,
       "threading.RLock.__qualname__.__eq__('RLock') == True — __qualname__ is 'RLock' (len=5); same as __name__ for top-level function; new to extra240"]

# ---------------------------------------------------------------------------
# Table 2: threading.RLock factory function class and doc contracts
#
# threading.RLock.__class__.__name__ == 'function'
# threading.RLock.__qualname__.__len__() == 5
# threading.RLock.__doc__.__contains__('reentrant') == True
# threading.RLock.__doc__.__contains__('lock') == True
# threading.RLock.__doc__.__class__.__name__ == 'str'
#
# RLock docstring describes a factory function for reentrant locks. New to extra240.
# ---------------------------------------------------------------------------

table threading_extra240.rlock240_class_doc:
  description: "threading.RLock class, qualname len, doc checks; new to extra240"
  kind: python_call_eq
  category: identity
  id_prefix: rlock240doc

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_class_is_function,
       RLock.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.RLock.__class__.__name__.__eq__('function') == True — RLock is a Python function; its __class__ is the built-in function type; new to extra240"]
    - [rlock_qualname_len_5,
       RLock.__qualname__.__len__,
       [],
       5,
       "threading.RLock.__qualname__.__len__() == 5 — 'RLock' has exactly 5 characters; str.__len__() returns 5; new to extra240"]
    - [rlock_doc_contains_reentrant,
       RLock.__doc__.__contains__,
       ["reentrant"],
       true,
       "threading.RLock.__doc__.__contains__('reentrant') == True — docstring says 'Factory function that returns a new reentrant lock'; new to extra240"]
    - [rlock_doc_contains_lock,
       RLock.__doc__.__contains__,
       ["lock"],
       true,
       "threading.RLock.__doc__.__contains__('lock') == True — docstring describes a reentrant lock; str.__contains__('lock') returns True; new to extra240"]
    - [rlock_doc_class_is_str,
       RLock.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.RLock.__doc__.__class__.__name__.__eq__('str') == True — the RLock docstring is a plain Python str object; new to extra240"]

# ---------------------------------------------------------------------------
# Table 3: threading._RLock.acquire method identity contracts
#
# threading._RLock.acquire.__name__ == 'acquire' (len=7)
# threading._RLock.acquire.__qualname__ == '_RLock.acquire' (len=14)
# threading._RLock.acquire.__class__.__name__ == 'function'
# threading._RLock.acquire.__qualname__.__len__() == 14
# threading._RLock.acquire.__name__.__len__() == 7
#
# acquire is a Python method of _RLock in Lib/threading.py. New to extra240.
# ---------------------------------------------------------------------------

table threading_extra240.rlock240m_acquire_identity:
  description: "threading._RLock.acquire method identity: name, qualname, class, lengths; new to extra240"
  kind: python_call_eq
  category: identity
  id_prefix: rlock240m

  columns: [id, function, args, expected, description]
  rows:
    - [acquire_name_eq,
       _RLock.acquire.__name__.__eq__,
       ["acquire"],
       true,
       "threading._RLock.acquire.__name__.__eq__('acquire') == True — acquire is a Python method of _RLock in Lib/threading.py; __name__ is 'acquire' (len=7); new to extra240"]
    - [acquire_name_len_7,
       _RLock.acquire.__name__.__len__,
       [],
       7,
       "threading._RLock.acquire.__name__.__len__() == 7 — 'acquire' has exactly 7 characters (a-c-q-u-i-r-e); str.__len__() returns 7; new to extra240"]
    - [acquire_qualname_eq,
       _RLock.acquire.__qualname__.__eq__,
       ["_RLock.acquire"],
       true,
       "threading._RLock.acquire.__qualname__.__eq__('_RLock.acquire') == True — acquire is a method of _RLock; __qualname__ is '_RLock.acquire' (len=14); new to extra240"]
    - [acquire_qualname_len_14,
       _RLock.acquire.__qualname__.__len__,
       [],
       14,
       "threading._RLock.acquire.__qualname__.__len__() == 14 — '_RLock.acquire' has exactly 14 characters; str.__len__() returns 14; new to extra240"]
    - [acquire_class_is_function,
       _RLock.acquire.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading._RLock.acquire.__class__.__name__.__eq__('function') == True — acquire is a Python function; its __class__ is the built-in function type; new to extra240"]

# ---------------------------------------------------------------------------
# Table 4: threading._RLock.release method identity contracts
#
# threading._RLock.release.__name__ == 'release' (len=7)
# threading._RLock.release.__qualname__ == '_RLock.release' (len=14)
# threading._RLock.release.__class__.__name__ == 'function'
# threading._RLock.release.__qualname__.__len__() == 14
# threading._RLock.release.__name__.__len__() == 7
#
# release is a Python method of _RLock in Lib/threading.py. New to extra240.
# ---------------------------------------------------------------------------

table threading_extra240.rlock240m_release_identity:
  description: "threading._RLock.release method identity: name, qualname, class, lengths; new to extra240"
  kind: python_call_eq
  category: identity
  id_prefix: rlock240mrel

  columns: [id, function, args, expected, description]
  rows:
    - [release_name_eq,
       _RLock.release.__name__.__eq__,
       ["release"],
       true,
       "threading._RLock.release.__name__.__eq__('release') == True — release is a Python method of _RLock in Lib/threading.py; __name__ is 'release' (len=7); new to extra240"]
    - [release_name_len_7,
       _RLock.release.__name__.__len__,
       [],
       7,
       "threading._RLock.release.__name__.__len__() == 7 — 'release' has exactly 7 characters (r-e-l-e-a-s-e); str.__len__() returns 7; new to extra240"]
    - [release_qualname_eq,
       _RLock.release.__qualname__.__eq__,
       ["_RLock.release"],
       true,
       "threading._RLock.release.__qualname__.__eq__('_RLock.release') == True — release is a method of _RLock; __qualname__ is '_RLock.release' (len=14); new to extra240"]
    - [release_qualname_len_14,
       _RLock.release.__qualname__.__len__,
       [],
       14,
       "threading._RLock.release.__qualname__.__len__() == 14 — '_RLock.release' has exactly 14 characters; str.__len__() returns 14; new to extra240"]
    - [release_class_is_function,
       _RLock.release.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading._RLock.release.__class__.__name__.__eq__('function') == True — release is a Python function; its __class__ is the built-in function type; new to extra240"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra240
# ---------------------------------------------------------------------------

invariant threading_extra240.rlock_name_eq:
  description: "threading.RLock.__name__ == 'RLock' (len=5); new to extra240"
  kind: python_call_eq
  function: RLock.__name__.__eq__
  args: ["RLock"]
  expected: true

invariant threading_extra240.rlock_name_len_5:
  description: "threading.RLock.__name__.__len__() == 5 — 'RLock' has 5 characters; new to extra240"
  kind: python_call_eq
  function: RLock.__name__.__len__
  args: []
  expected: 5

invariant threading_extra240.rlock_module_eq:
  description: "threading.RLock.__module__ == 'threading'; new to extra240"
  kind: python_call_eq
  function: RLock.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra240.rlock_module_len_9:
  description: "threading.RLock.__module__.__len__() == 9 — 'threading' has 9 characters; new to extra240"
  kind: python_call_eq
  function: RLock.__module__.__len__
  args: []
  expected: 9

invariant threading_extra240.rlock_class_is_function:
  description: "threading.RLock.__class__.__name__ == 'function'; new to extra240"
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra240.rlock_doc_contains_reentrant:
  description: "threading.RLock.__doc__.__contains__('reentrant') == True; new to extra240"
  kind: python_call_eq
  function: RLock.__doc__.__contains__
  args: ["reentrant"]
  expected: true

invariant threading_extra240.acquire_name_eq:
  description: "threading._RLock.acquire.__name__ == 'acquire' (len=7); new to extra240"
  kind: python_call_eq
  function: _RLock.acquire.__name__.__eq__
  args: ["acquire"]
  expected: true

invariant threading_extra240.acquire_qualname_eq:
  description: "threading._RLock.acquire.__qualname__ == '_RLock.acquire' (len=14); new to extra240"
  kind: python_call_eq
  function: _RLock.acquire.__qualname__.__eq__
  args: ["_RLock.acquire"]
  expected: true

invariant threading_extra240.acquire_qualname_len_14:
  description: "threading._RLock.acquire.__qualname__.__len__() == 14 — '_RLock.acquire' has 14 characters; new to extra240"
  kind: python_call_eq
  function: _RLock.acquire.__qualname__.__len__
  args: []
  expected: 14

invariant threading_extra240.release_name_eq:
  description: "threading._RLock.release.__name__ == 'release' (len=7); new to extra240"
  kind: python_call_eq
  function: _RLock.release.__name__.__eq__
  args: ["release"]
  expected: true

invariant threading_extra240.release_qualname_eq:
  description: "threading._RLock.release.__qualname__ == '_RLock.release' (len=14); new to extra240"
  kind: python_call_eq
  function: _RLock.release.__qualname__.__eq__
  args: ["_RLock.release"]
  expected: true

invariant threading_extra240.release_qualname_len_14:
  description: "threading._RLock.release.__qualname__.__len__() == 14 — '_RLock.release' has 14 characters; new to extra240"
  kind: python_call_eq
  function: _RLock.release.__qualname__.__len__
  args: []
  expected: 14
