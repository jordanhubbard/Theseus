spec: hl2896
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib: Secure hashes and message digests"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 640 (hl2896): __itruediv__, __ifloordiv__, __imod__ dict-presence checks for hashlib types."
    - "hashlib hash classes are cryptographic digest objects, not numeric types — none define in-place true-divide, floor-divide, or modulo operators."
    - "Verified types: type(hashlib.md5()), type(hashlib.sha256()), hashlib.blake2b, hashlib.blake2s."
    - "type(hashlib.md5()) and type(hashlib.sha256()) both yield the C-level HASH type from _hashlib."
    - "hashlib.blake2b and hashlib.blake2s are C extension types exposed directly."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl2896.itruediv:
  description: "hashlib types __itruediv__ dict-presence checks; wave 640"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2896
  columns: [id, function, args, expected]
  rows:
    - ["hl2896001", operator.contains, [type(hashlib.md5()).__dict__,     "__itruediv__"], false]
    - ["hl2896002", operator.contains, [type(hashlib.sha256()).__dict__,  "__itruediv__"], false]
    - ["hl2896003", operator.contains, [hashlib.blake2b.__dict__,         "__itruediv__"], false]
    - ["hl2896004", operator.contains, [hashlib.blake2s.__dict__,         "__itruediv__"], false]

