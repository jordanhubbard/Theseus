spec: struct_extra52
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra51.zspec.zsdl — covers Struct/error __repr__/__class__.__name__.__eq__('wrapper_descriptor'); Struct/error __hash__.__class__.__name__.__eq__('wrapper_descriptor'); pack/unpack/calcsize __repr__.__class__.__name__.__eq__('method-wrapper')."
    - "struct_extra50.zspec.zsdl — covers unpack/calcsize/pack_into/unpack_from/iter_unpack __class__.__module__.__eq__('builtins'); Struct/error __init__.__class__.__name__/__module__.__eq__('wrapper_descriptor'/'builtins')."
    - "struct_extra45.zspec.zsdl — covers Struct/pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/error __doc__.__class__.__qualname__.__eq__('str')."
    - "struct_extra44.zspec.zsdl — covers Struct/pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/error __doc__.__class__.__name__.__eq__('str')."
    - "struct_extra43.zspec.zsdl — covers Struct/error __class__.__qualname__.__eq__('type') and module-level functions __class__.__qualname__.__eq__('builtin_function_or_method')."
    - "struct_extra26.zspec.zsdl — covers struct.__all__.__len__()==8 and struct.__all__.__class__.__name__.__len__()==4 (i.e., 'list'); struct.__spec__.__class__.__name__.__len__()==10."
  notes:
    - "This spec extends struct through struct_extra51; it does NOT duplicate invariants present in those files."
    - "Wave 223 theme: module __all__ content + __eq__.__class__.__name__ checks."
    - "Coverage gap 1: struct_extra26 covers struct.__all__.__len__()==8 and the class name length (len('list')==4). No prior struct spec checks struct.__all__.__contains__ for specific member names. struct.__all__ is a list: ['calcsize','pack','pack_into','unpack','unpack_from','iter_unpack','Struct','error']. Checking __contains__ for specific names confirms that the declared public API includes both the C extension types (Struct, error) and all the module-level functions. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__.__contains__('Struct') == True. 'Struct' is in struct.__all__; struct_extra26 checks __all__.__len__ and class name length but NOT __contains__. No prior struct spec checks __all__.__contains__('Struct'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__.__contains__('error') == True. 'error' is in struct.__all__; no prior struct spec checks __all__.__contains__('error'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__.__contains__('pack_into') == True. 'pack_into' is in struct.__all__; no prior struct spec checks __all__.__contains__('pack_into'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__.__contains__('iter_unpack') == True. 'iter_unpack' is in struct.__all__; no prior struct spec checks __all__.__contains__('iter_unpack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior struct spec checks Struct.__eq__.__class__.__name__ or error.__eq__.__class__.__name__. struct_extra51 covers Struct/error __repr__.__class__.__name__.__eq__('wrapper_descriptor') and __hash__.__class__.__name__.__eq__('wrapper_descriptor'). But the __eq__ slot is unchecked. Struct and error are C extension types (or inherit from C types); neither defines __eq__ explicitly, so __eq__ is inherited from object (for Struct) and from the exception hierarchy (for error) as a wrapper_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__eq__.__class__.__name__ == 'wrapper_descriptor'. Struct is a C extension type; it does not define __eq__, so __eq__ is inherited from object as a wrapper_descriptor (C slot wrapper for tp_richcompare). struct_extra51 covers __repr__ and __hash__ class names for Struct but NOT __eq__. No prior struct spec checks Struct.__eq__.__class__.__name__.__eq__('wrapper_descriptor'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__eq__.__class__.__name__ == 'wrapper_descriptor'. error is a Python subclass of Exception (ultimately BaseException, a C type); its __eq__ is inherited as a wrapper_descriptor from the C exception type hierarchy. struct_extra51 covers error.__repr__ and error.__hash__ class names but NOT __eq__. No prior struct spec checks error.__eq__.__class__.__name__.__eq__('wrapper_descriptor'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 3: struct_extra26 uses __all__.__class__.__name__.__len__()==4 (length of 'list'), not a direct __eq__ check. No prior struct spec checks struct.__all__.__class__.__name__.__eq__('list') as a direct __eq__ call. Verified Python 3.14.3 macOS/Darwin 25.4.0: struct.__all__.__class__.__name__.__eq__('list') == True."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__all__.__class__.__name__.__eq__('list') — direct __eq__ check
#
# struct_extra26 covers __all__.__class__.__name__.__len__()==4 (the length
# of 'list'), which implicitly identifies the class as 'list'. But no prior
# struct spec checks __all__.__class__.__name__.__eq__('list') as a direct
# equality call. The direct __eq__ check is a distinct regression vector:
# a type named 'List' would have __len__()==4 but would fail this __eq__ check.
# ---------------------------------------------------------------------------

table struct_extra52.all_class_name_eq:
  description: "struct.__all__.__class__.__name__.__eq__('list') — direct equality check; struct_extra26 covers __all__.__class__.__name__.__len__()==4 (implicit type identification by length) but NOT a direct __eq__ call; struct.__all__ is a plain list of 8 public names; no prior struct spec checks __all__.__class__.__name__.__eq__('list') as a python_call_eq"
  kind: python_call_eq
  category: module_structure
  id_prefix: structall52

  columns: [id, function, args, expected]
  rows:
    - [all_class_name_eq, __all__.__class__.__name__.__eq__, ["list"], true]

# ---------------------------------------------------------------------------
# struct.__all__.__contains__ for specific public names
#
# struct_extra26 covers __all__.__len__()==8 and __class__.__name__.__len__()==4.
# No prior struct spec checks __all__.__contains__ for any specific name.
# struct.__all__ == ['calcsize','pack','pack_into','unpack','unpack_from',
# 'iter_unpack','Struct','error']. Checking __contains__ for names that span
# both C extension types (Struct, error) and module-level functions confirms
# the completeness of the declared public API.
# ---------------------------------------------------------------------------

table struct_extra52.all_contains:
  description: "struct.__all__.__contains__('Struct'/'error'/'pack_into'/'iter_unpack') — confirms C extension type names and function names in the public API list; struct_extra26 covers __all__.__len__ and __class__.__name__.__len__ but NOT __contains__; no prior struct spec checks __all__.__contains__ for any name"
  kind: python_call_eq
  category: module_structure
  id_prefix: structall52

  columns: [id, function, args, expected]
  rows:
    - [all_contains_Struct,      __all__.__contains__, ["Struct"],      true]
    - [all_contains_error,       __all__.__contains__, ["error"],       true]
    - [all_contains_pack_into,   __all__.__contains__, ["pack_into"],   true]
    - [all_contains_iter_unpack, __all__.__contains__, ["iter_unpack"], true]

# ---------------------------------------------------------------------------
# struct.Struct and struct.error __eq__.__class__.__name__.__eq__('wrapper_descriptor')
#
# struct_extra51 covers Struct/error __repr__.__class__.__name__ and
# __hash__.__class__.__name__ (both 'wrapper_descriptor'). But no prior struct
# spec checks __eq__.__class__.__name__ for Struct or error. Neither Struct
# nor error defines __eq__ explicitly; both inherit __eq__ from the object
# hierarchy as a wrapper_descriptor (C slot wrapper for tp_richcompare).
# struct.Struct inherits from object; struct.error inherits from Exception
# (ultimately BaseException, a C type). Both yield wrapper_descriptor.
# ---------------------------------------------------------------------------

table struct_extra52.eq_class_name:
  description: "struct.Struct/__eq__/__class__/__name__.__eq__('wrapper_descriptor') and error same — C extension types inherit __eq__ from object/exception hierarchy as a wrapper_descriptor; struct_extra51 covers __repr__ and __hash__ class names for Struct/error but NOT __eq__; no prior struct spec checks __eq__.__class__.__name__.__eq__('wrapper_descriptor') for Struct or error"
  kind: python_call_eq
  category: type_structure
  id_prefix: structall52

  columns: [id, function, args, expected]
  rows:
    - [Struct_eq_class_name_eq, Struct.__eq__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [error_eq_class_name_eq,  error.__eq__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# struct.__all__.__contains__('calcsize') — the length-computing function
#
# 'calcsize' is the function that returns the size corresponding to a format
# string, commonly used for binary protocol work. Its presence in __all__
# confirms it is part of the declared public API. No prior struct spec checks
# __all__.__contains__('calcsize').
# ---------------------------------------------------------------------------

invariant struct_extra52.all_contains_calcsize:
  description: "struct.__all__.__contains__('calcsize') == True — 'calcsize' is in struct.__all__; no prior struct spec checks __all__.__contains__ for 'calcsize' specifically; struct_extra26 covers __all__.__len__ but NOT __contains__"
  category: module_structure
  kind: python_call_eq
  function: __all__.__contains__
  args: ["calcsize"]
  expected: true
