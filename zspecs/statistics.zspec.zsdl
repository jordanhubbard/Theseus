spec: statistics
version: ">=3.8"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified by running Python 3.x statistics module on macOS/Darwin 25.4.0, 2026-04-08"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "statistics.mean() of an all-integer list returns int on Python 3.11+; float list returns float."
    - "statistics.median() of an odd-length integer list returns int; even-length list returns float (average of two middle values)."
    - "statistics.median_low() and statistics.median_high() always return a value from the dataset (not averaged)."
    - "statistics.mode() returns the most common value; raises StatisticsError if there is no unique mode (Python <3.8)."
    - "statistics.variance() returns float (sample variance, ddof=1). statistics.pvariance() returns population variance (ddof=0)."
    - "For [2,4,4,4,5,5,7,9]: sample variance = 32/7 ≈ 4.571428..., pvariance = 4 (int), pstdev = 2.0 (float)."
    - "statistics.fmean() always returns float (Python 3.8+)."
    - "statistics.geometric_mean([1,2,4]) == 2.0 exactly — (1*2*4)^(1/3) = 8^(1/3) = 2.0."
    - "NormalDist(mu, sigma) stores mean and stdev as attributes; NormalDist(0,1) is the standard normal distribution."
    - "statistics.StatisticsError is raised for empty datasets and other invalid inputs."
    - "All expected values verified by running Python statistics module on macOS/Darwin 25.4.0, 2026-04-08."
  created_at: "2026-04-08T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# mean — arithmetic mean
# ---------------------------------------------------------------------------

table statistics.mean.vectors:
  kind: python_call_eq
  category: mean
  id_prefix: mean
  function: mean

  columns: [id, args, expected]
  rows:
    - [int_list,       [[1, 2, 3, 4, 5]],  3]
    - [float_list,     [[1.0, 2.0, 3.0]],  2.0]
    - [all_zeros,      [[0, 0, 0]],         0]
    - [single_element, [[10]],              10]

# ---------------------------------------------------------------------------
# fmean — fast floating-point mean (Python 3.8+, always returns float)
# ---------------------------------------------------------------------------

invariant statistics.fmean.basic:
  description: "statistics.fmean([1,2,3]) == 2.0 — fast mean always returns float"
  category: fmean
  kind: python_call_eq
  function: fmean
  args: [[1, 2, 3]]
  expected: 2.0

# ---------------------------------------------------------------------------
# geometric_mean — (Python 3.8+)
# ---------------------------------------------------------------------------

invariant statistics.geometric_mean.one_two_four:
  description: "statistics.geometric_mean([1,2,4]) == 2.0 — (1*2*4)^(1/3) = 8^(1/3) = 2.0"
  category: geometric_mean
  kind: python_call_eq
  function: geometric_mean
  args: [[1, 2, 4]]
  expected: 2.0

# ---------------------------------------------------------------------------
# median — middle value of dataset
# ---------------------------------------------------------------------------

table statistics.median.vectors:
  kind: python_call_eq
  category: median
  id_prefix: median
  function: median

  columns: [id, args, expected]
  rows:
    - [odd_length,    [[1, 2, 3, 4, 5]], 3]
    - [even_length,   [[1, 2, 3, 4]],    2.5]
    - [single_element,[[7]],             7]

# ---------------------------------------------------------------------------
# median_low / median_high — always returns value from the dataset
# ---------------------------------------------------------------------------

invariant statistics.median_low.even:
  description: "statistics.median_low([1,2,3,4]) == 2 — lower of the two middle values"
  category: median_low
  kind: python_call_eq
  function: median_low
  args: [[1, 2, 3, 4]]
  expected: 2

invariant statistics.median_high.even:
  description: "statistics.median_high([1,2,3,4]) == 3 — higher of the two middle values"
  category: median_high
  kind: python_call_eq
  function: median_high
  args: [[1, 2, 3, 4]]
  expected: 3

# ---------------------------------------------------------------------------
# mode — most common value
# ---------------------------------------------------------------------------

invariant statistics.mode.integer_list:
  description: "statistics.mode([1,1,2,3]) == 1 — 1 appears most frequently"
  category: mode
  kind: python_call_eq
  function: mode
  args: [[1, 1, 2, 3]]
  expected: 1

invariant statistics.mode.string_list:
  description: "statistics.mode(['a','b','a']) == 'a' — works with non-numeric data"
  category: mode
  kind: python_call_eq
  function: mode
  args: [["a", "b", "a"]]
  expected: "a"

# ---------------------------------------------------------------------------
# variance / stdev — sample statistics (ddof=1)
# ---------------------------------------------------------------------------

invariant statistics.variance.classic_dataset:
  description: "statistics.variance([2,4,4,4,5,5,7,9]) == 32/7 ≈ 4.571428... — sample variance"
  category: variance
  kind: python_call_eq
  function: variance
  args: [[2, 4, 4, 4, 5, 5, 7, 9]]
  expected: 4.571428571428571

invariant statistics.stdev.classic_dataset:
  description: "statistics.stdev([2,4,4,4,5,5,7,9]) ≈ 2.138... — sample standard deviation"
  category: stdev
  kind: python_call_eq
  function: stdev
  args: [[2, 4, 4, 4, 5, 5, 7, 9]]
  expected: 2.138089935299395

# ---------------------------------------------------------------------------
# pvariance / pstdev — population statistics (ddof=0)
# ---------------------------------------------------------------------------

invariant statistics.pvariance.classic_dataset:
  description: "statistics.pvariance([2,4,4,4,5,5,7,9]) == 4 — population variance"
  category: pvariance
  kind: python_call_eq
  function: pvariance
  args: [[2, 4, 4, 4, 5, 5, 7, 9]]
  expected: 4

invariant statistics.pstdev.classic_dataset:
  description: "statistics.pstdev([2,4,4,4,5,5,7,9]) == 2.0 — population standard deviation"
  category: pstdev
  kind: python_call_eq
  function: pstdev
  args: [[2, 4, 4, 4, 5, 5, 7, 9]]
  expected: 2.0

# ---------------------------------------------------------------------------
# NormalDist — normal distribution object (Python 3.8+)
#
# NormalDist(mu, sigma) stores the distribution parameters as attributes.
# Accessed via: function=NormalDist, args=[mu, sigma], method=mean/stdev.
# ---------------------------------------------------------------------------

invariant statistics.NormalDist.standard_mean:
  description: "NormalDist(0, 1).mean == 0.0 — standard normal distribution has mean 0"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [0, 1]
  method: mean
  expected: 0.0

invariant statistics.NormalDist.standard_stdev:
  description: "NormalDist(0, 1).stdev == 1.0 — standard normal distribution has stdev 1"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [0, 1]
  method: stdev
  expected: 1.0

invariant statistics.NormalDist.custom_mean:
  description: "NormalDist(5.0, 2.0).mean == 5.0"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [5.0, 2.0]
  method: mean
  expected: 5.0

invariant statistics.NormalDist.custom_stdev:
  description: "NormalDist(5.0, 2.0).stdev == 2.0"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [5.0, 2.0]
  method: stdev
  expected: 2.0

# ---------------------------------------------------------------------------
# error cases — StatisticsError for invalid/empty input
# ---------------------------------------------------------------------------

invariant statistics.mean.empty_raises:
  description: "statistics.mean([]) raises StatisticsError — mean requires at least one data point"
  category: error
  kind: python_call_raises
  function: mean
  args: [[]]
  expected_exception: StatisticsError

invariant statistics.variance.single_raises:
  description: "statistics.variance([5]) raises StatisticsError — sample variance requires at least 2 data points"
  category: error
  kind: python_call_raises
  function: variance
  args: [[5]]
  expected_exception: StatisticsError

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-04-15T14:20:16Z
  iterations: 1
  pass_count: 23
  fail_count: 0
  total_invariants: 23
  notes: Synthesis succeeded in 1 iteration(s). 23 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
