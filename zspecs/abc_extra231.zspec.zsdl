    - [new_qualname_eq,   ABCMeta.__new__.__qualname__.__eq__,  ["ABCMeta.__new__"], true, "abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__'; verified with Python 3.14.3"]
