spec: abc_extra231
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html#abc.ABCMeta

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html#abc.ABCMeta — abc.ABCMeta metaclass documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "abc.ABCMeta.__name__ == 'ABCMeta' — 7 characters; module is 'abc'; verified with Python 3.14.3."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta inherits directly from type; verified with Python 3.14.3."
    - "abc.ABCMeta.__new__.__name__ == '__new__' — 7 characters; qualname is 'ABCMeta.__new__' (15 chars); verified with Python 3.14.3."
    - "abc.ABCMeta.__init__.__qualname__ == 'type.__init__' — ABCMeta does not define its own __init__, inherits from type; verified with Python 3.14.3."
    - "abc.ABCMeta.register.__name__ == 'register' — 8 characters; qualname is 'ABCMeta.register'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta class identity contracts — extra231 namespace
#
# ABCMeta.__name__ == 'ABCMeta' (7 chars); module 'abc' (3 chars).
# ABCMeta.__bases__[0].__name__ == 'type'.
# ---------------------------------------------------------------------------

table abc_extra231.abcmeta_class_identity:
  description: "abc.ABCMeta class __name__ and __module__ contracts in abc231aci namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc231aci

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_name_eq,      ABCMeta.__name__.__eq__,     ["ABCMeta"], true, "abc.ABCMeta.__name__ == 'ABCMeta'; verified with Python 3.14.3"]
    - [abcmeta_name_len_7,   ABCMeta.__name__.__len__,    [],          7,    "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters; verified with Python 3.14.3"]
    - [abcmeta_module_eq,    ABCMeta.__module__.__eq__,   ["abc"],     true, "abc.ABCMeta.__module__ == 'abc'; verified with Python 3.14.3"]
    - [abcmeta_module_len_3, ABCMeta.__module__.__len__,  [],          3,    "abc.ABCMeta.__module__.__len__() == 3 — 'abc' has 3 characters; verified with Python 3.14.3"]

