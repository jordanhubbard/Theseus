spec: inspect_extra249
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Parameter class identity and kind constants behavioral contracts."
    - "inspect.Parameter.__name__ == 'Parameter' — Parameter is a class defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect' — Parameter is defined in the inspect module. Verified with Python 3.14.3."
    - "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter inherits directly from object. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY is an IntEnum member of _ParameterKind; int(POSITIONAL_ONLY) == 0. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD: int value 1. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_POSITIONAL: int value 2. Verified with Python 3.14.3."
    - "inspect.Parameter.KEYWORD_ONLY: int value 3. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_KEYWORD: int value 4. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — kind constants are instances of the _ParameterKind IntEnum. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is the sentinel class itself; type(Parameter.empty).__name__ == 'type'. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.name == 'POSITIONAL_ONLY' — .name is the IntEnum member name string. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter class identity
#
# inspect.Parameter.__name__ == 'Parameter'
# inspect.Parameter.__module__ == 'inspect'
# inspect.Parameter.__bases__[0].__name__ == 'object'
#
# Parameter is a pure-Python class defined in Lib/inspect.py representing
# a single parameter in a function signature. New to extra249.
# ---------------------------------------------------------------------------

table inspect_extra249.parameter_class_identity:
  description: "inspect.Parameter class __name__, __module__, __bases__; new to extra249"
  kind: python_call_eq
  category: identity
  id_prefix: insp249par

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_name_eq,
       Parameter.__name__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter is the class representing a single callable parameter in a Signature; its __name__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra249"]
    - [parameter_module_eq,
       Parameter.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra249"]
    - [parameter_bases0_object,
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra249"]
    - [parameter_name_len_9,
       Parameter.__name__.__len__,
       [],
       9,
       "inspect.Parameter.__name__.__len__() == 9 — 'Parameter' has 9 characters; __len__() returns 9; new to extra249"]
    - [parameter_module_len_7,
       Parameter.__module__.__len__,
       [],
       7,
       "inspect.Parameter.__module__.__len__() == 7 — 'inspect' has 7 characters; __len__() returns 7; new to extra249"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter kind constants
#
# inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.POSITIONAL_ONLY.name == 'POSITIONAL_ONLY'
# inspect.Parameter.POSITIONAL_OR_KEYWORD.name == 'POSITIONAL_OR_KEYWORD'
# inspect.Parameter.VAR_POSITIONAL.name == 'VAR_POSITIONAL'
# inspect.Parameter.KEYWORD_ONLY.name == 'KEYWORD_ONLY'
# inspect.Parameter.VAR_KEYWORD.name == 'VAR_KEYWORD'
#
# The kind constants are _ParameterKind IntEnum members. Their .name
# attribute returns the canonical string name. New to extra249.
# ---------------------------------------------------------------------------

table inspect_extra249.parameter_kind_constants:
  description: "inspect.Parameter kind constants __class__.__name__ and .name string values; new to extra249"
  kind: python_call_eq
  category: identity
  id_prefix: insp249kind

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_class_name,
       Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is an instance of the _ParameterKind IntEnum; __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra249"]
    - [positional_only_name_eq,
       Parameter.POSITIONAL_ONLY.name.__eq__,
       ["POSITIONAL_ONLY"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_ONLY') == True — the .name attribute of an IntEnum member is the member's canonical string name; str.__eq__('POSITIONAL_ONLY') returns True; new to extra249"]
    - [positional_or_keyword_name_eq,
       Parameter.POSITIONAL_OR_KEYWORD.name.__eq__,
       ["POSITIONAL_OR_KEYWORD"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__('POSITIONAL_OR_KEYWORD') == True — POSITIONAL_OR_KEYWORD is the most common parameter kind for regular def arguments; .name is 'POSITIONAL_OR_KEYWORD'; new to extra249"]
    - [var_positional_name_eq,
       Parameter.VAR_POSITIONAL.name.__eq__,
       ["VAR_POSITIONAL"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.name.__eq__('VAR_POSITIONAL') == True — VAR_POSITIONAL corresponds to *args parameters; .name is 'VAR_POSITIONAL'; str.__eq__('VAR_POSITIONAL') returns True; new to extra249"]
    - [keyword_only_name_eq,
       Parameter.KEYWORD_ONLY.name.__eq__,
       ["KEYWORD_ONLY"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.name.__eq__('KEYWORD_ONLY') == True — KEYWORD_ONLY corresponds to keyword-only parameters after *args; .name is 'KEYWORD_ONLY'; str.__eq__('KEYWORD_ONLY') returns True; new to extra249"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra249
# ---------------------------------------------------------------------------

invariant inspect_extra249.Parameter.name_eq:
  description: "inspect.Parameter.__name__ == 'Parameter' — the parameter class is named 'Parameter'; new to extra249"
  category: identity
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra249.Parameter.module_eq:
  description: "inspect.Parameter.__module__ == 'inspect' — Parameter is defined in the inspect module; new to extra249"
  category: identity
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra249.Parameter.bases0_is_object:
  description: "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter inherits directly from object; new to extra249"
  category: identity
  kind: python_call_eq
  function: "Parameter.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra249.Parameter.POSITIONAL_ONLY.class_name:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — kind constants are IntEnum members; new to extra249"
  category: identity
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra249.Parameter.POSITIONAL_ONLY.name_eq:
  description: "inspect.Parameter.POSITIONAL_ONLY.name == 'POSITIONAL_ONLY' — the .name of the IntEnum member; new to extra249"
  category: identity
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.name.__eq__
  args: ["POSITIONAL_ONLY"]
  expected: true

invariant inspect_extra249.Parameter.POSITIONAL_OR_KEYWORD.name_eq:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.name == 'POSITIONAL_OR_KEYWORD' — .name of the IntEnum member; new to extra249"
  category: identity
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.name.__eq__
  args: ["POSITIONAL_OR_KEYWORD"]
  expected: true

invariant inspect_extra249.Parameter.VAR_POSITIONAL.name_eq:
  description: "inspect.Parameter.VAR_POSITIONAL.name == 'VAR_POSITIONAL' — corresponds to *args; new to extra249"
  category: identity
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.name.__eq__
  args: ["VAR_POSITIONAL"]
  expected: true

invariant inspect_extra249.Parameter.KEYWORD_ONLY.name_eq:
  description: "inspect.Parameter.KEYWORD_ONLY.name == 'KEYWORD_ONLY' — corresponds to keyword-only params; new to extra249"
  category: identity
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.name.__eq__
  args: ["KEYWORD_ONLY"]
  expected: true

invariant inspect_extra249.Parameter.VAR_KEYWORD.name_eq:
  description: "inspect.Parameter.VAR_KEYWORD.name == 'VAR_KEYWORD' — corresponds to **kwargs; new to extra249"
  category: identity
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.name.__eq__
  args: ["VAR_KEYWORD"]
  expected: true

invariant inspect_extra249.Parameter.name_len_9:
  description: "inspect.Parameter.__name__.__len__() == 9 — 'Parameter' has 9 characters; new to extra249"
  category: identity
  kind: python_call_eq
  function: Parameter.__name__.__len__
  args: []
  expected: 9
