spec: symtable_extra5
version: ">=3.9"
backend: python_module(symtable)

docs: https://docs.python.org/3/library/symtable.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/symtable.html — Python symtable documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/symtable.py"
  notes:
    - "This spec extends symtable.zspec.zsdl through symtable_extra4.zspec.zsdl."
    - "symtable covers: symtable/__name__, SymbolTable/__name__/__module__, Function/__name__, Class/__name__, Symbol/__name__, SymbolTable/Symbol method names, symtable() exec returns Module."
    - "symtable_extra covers: class_names/class_modules tables, Function/Class __bases__[0].__name__, symtable() returns SymbolTable, get_type()=='module'."
    - "symtable_extra2 covers: SymbolTableError identity, symtable.__module__, SymbolTable.__bases__[0], class __qualname__ table, Symbol.__module__."
    - "symtable_extra3 covers: Symbol.__bases__[0], SymbolTableError.__qualname__, symtable.__qualname__, class __name__ type table, Function/Class __module__ standalone."
    - "symtable_extra4 covers: SymbolTable extra method names (is_optimized/is_nested/has_children/get_identifiers/lookup/get_lineno), Symbol extra method names, Function method names (get_parameters/get_locals/get_globals/get_frees), SymbolTableType class, behavioral is_optimized/is_nested/has_children."
    - "NEW in this spec: symtable module __name__ attr; symtable module __spec__.name; symtable() function __class__.__name__=='function'; SymbolTable method __qualname__ checks; Function.__bases__.__len__/Class.__bases__.__len__; Function.get_parameters.__qualname__."
    - "symtable.__name__ == 'symtable' — the module-level __name__ attribute (distinct from the symtable() function's __name__)."
    - "symtable.__spec__.name == 'symtable' — the importlib ModuleSpec confirms the module name."
    - "symtable.symtable.__class__.__name__ == 'function' — the top-level symtable() callable is a plain Python function."
    - "SymbolTable method qualnames are prefixed 'SymbolTable.' because they are defined inside the class body."
    - "len(symtable.Function.__bases__) == 1 — Function has exactly one direct base class (SymbolTable)."
    - "len(symtable.Class.__bases__) == 1 — Class has exactly one direct base class (SymbolTable)."
    - "symtable.Function.get_parameters.__qualname__ == 'Function.get_parameters' — method qualname carries class prefix."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# module __name__ and __spec__.name — module self-identification.
# symtable_extra3 covers symtable.__qualname__ and symtable.__module__;
# the module's own __name__ and __spec__.name are not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant symtable_extra5.module.self_name:
  description: "symtable.__name__ == 'symtable' — the module's own __name__ attribute"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__eq__
  args: ["symtable"]
  expected: true

invariant symtable_extra5.module.spec_name:
  description: "symtable.__spec__.name == 'symtable' — the importlib ModuleSpec records the module name"
  category: module_metadata
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["symtable"]
  expected: true

# ---------------------------------------------------------------------------
# symtable() function type — it is a plain Python function.
# Prior specs check symtable.__name__/__module__/__qualname__;
# __class__.__name__ == 'function' is a novel angle not covered before.
# Not covered in any prior symtable spec.
# ---------------------------------------------------------------------------

invariant symtable_extra5.symtable.is_function:
  description: "symtable.symtable.__class__.__name__ == 'function' — the top-level symtable() is a plain Python function"
  category: function_type
  kind: python_call_eq
  function: symtable.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# SymbolTable method __qualname__ checks.
# Methods are defined inside the class body so qualnames carry the 'SymbolTable.'
# prefix. Prior specs cover method __name__ (symtable base) and extra method
# names (symtable_extra4); __qualname__ for any SymbolTable method is new here.
# Not covered in any prior symtable spec.
# ---------------------------------------------------------------------------

table symtable_extra5.SymbolTable.method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: stmqname

  columns: [id, function, args, expected]
  rows:
    - [get_type,     SymbolTable.get_type.__qualname__.__eq__,     ["SymbolTable.get_type"],     true]
    - [get_id,       SymbolTable.get_id.__qualname__.__eq__,       ["SymbolTable.get_id"],       true]
    - [get_name,     SymbolTable.get_name.__qualname__.__eq__,     ["SymbolTable.get_name"],     true]
    - [get_children, SymbolTable.get_children.__qualname__.__eq__, ["SymbolTable.get_children"], true]
    - [get_symbols,  SymbolTable.get_symbols.__qualname__.__eq__,  ["SymbolTable.get_symbols"],  true]

# ---------------------------------------------------------------------------
# Function and Class __bases__ length.
# Prior specs check __bases__[0].__name__ for Function and Class;
# __bases__.__len__() is a novel angle not covered in any prior symtable spec.
# ---------------------------------------------------------------------------

invariant symtable_extra5.Function.bases_len:
  description: "len(symtable.Function.__bases__) == 1 — Function has exactly one direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: Function.__bases__.__len__
  args: []
  expected: 1

invariant symtable_extra5.Class.bases_len:
  description: "len(symtable.Class.__bases__) == 1 — Class has exactly one direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: Class.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Function.get_parameters __qualname__ — method qualname carries class prefix.
# symtable_extra4 covers Function.get_parameters.__name__;
# __qualname__ is a new angle not covered in any prior symtable spec.
# ---------------------------------------------------------------------------

invariant symtable_extra5.Function.get_parameters_qualname:
  description: "symtable.Function.get_parameters.__qualname__ == 'Function.get_parameters' — method qualname carries class prefix"
  category: method_qualnames
  kind: python_call_eq
  function: Function.get_parameters.__qualname__.__eq__
  args: ["Function.get_parameters"]
  expected: true
