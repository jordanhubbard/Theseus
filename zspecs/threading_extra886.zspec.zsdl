spec: threading_extra886
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "Python standard library threading module"
    - "CPython source: Lib/threading.py"
  not_derived_from:
    - "any third-party threading library"
    - "concurrent.futures or multiprocessing modules"
  notes:
    - "Covers __doc__.__class__.__name__ checks for Thread and synchronization primitive methods"
    - "Verifies that docstrings are str instances, not NoneType, for all covered methods"
    - "threading.Barrier and threading.Condition are higher-level synchronization primitives"
  created_at: "2026-04-12"

table threading_extra886.thread_doc_checks:
  description: "Verify that threading.Thread method docstrings are of type str"
  kind: python_call_eq
  category: docstring_type_introspection
  id_prefix: th886th
  columns: [id, function, args, expected]
  rows:
    - [th886th001, threading.Thread.__init__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th886th002, threading.Thread.start.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th886th003, threading.Thread.run.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th886th004, threading.Thread.join.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th886th005, threading.Thread.is_alive.__doc__.__class__.__name__.__eq__, ["str"], true]

table threading_extra886.semaphore_doc_checks:
  description: "Verify that threading.Semaphore method docstrings are of type str"
  kind: python_call_eq
  category: docstring_type_introspection
  id_prefix: th886se
  columns: [id, function, args, expected]
  rows:
    - [th886se001, threading.Semaphore.__init__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th886se002, threading.Semaphore.acquire.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th886se003, threading.Semaphore.release.__doc__.__class__.__name__.__eq__, ["str"], true]

table threading_extra886.event_doc_checks:
  description: "Verify that threading.Event method docstrings are of type str"
  kind: python_call_eq
  category: docstring_type_introspection
  id_prefix: th886ev
  columns: [id, function, args, expected]
  rows:
    - [th886ev001, threading.Event.__init__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th886ev002, threading.Event.set.__doc__.__class__.__name__.__eq__, ["str"], true]

table threading_extra886.condition_barrier_doc_checks:
  description: "Verify that threading.Condition and threading.Barrier __init__ docstrings are of type str"
  kind: python_call_eq
  category: docstring_type_introspection
  id_prefix: th886cb
  columns: [id, function, args, expected]
  rows:
    - [th886cb001, threading.Condition.__init__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th886cb002, threading.Barrier.__init__.__doc__.__class__.__name__.__eq__, ["str"], true]
