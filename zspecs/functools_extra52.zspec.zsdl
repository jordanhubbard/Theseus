spec: functools_extra52
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra51.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps/partial/lru_cache/total_ordering/singledispatch/cached_property/reduce/cmp_to_key/partialmethod/singledispatchmethod/update_wrapper; __qualname__.__len__() for all major functools objects; WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES lengths; __all__ lengths; partial/__class__.__name__; cached_property/__set_name__/__get__/__init__.__qualname__; partial/__new__.__qualname__; class __dict__.__class__.__name__.__len__ for partial/partialmethod/singledispatchmethod/cached_property; reduce with initial value; lru_cache(128).__ne__(None)==True; lru_cache(maxsize=2) behavioral; reduce/__qualname__=='reduce'; lru_cache/__qualname__=='lru_cache'; cache/__name__/__qualname__/__module__; cached_property/__name__/__qualname__/__module__/__bases__[0].__name__; total_ordering/__name__/__qualname__/__module__; singledispatch/__name__/__qualname__/__module__; wraps/__name__/__qualname__/__module__; update_wrapper/__name__/__qualname__/__module__; partial/__bases__[0].__name__=='object'; partial/__name__/__qualname__/__module__; lru_cache/__name__/__module__; cmp_to_key/__name__=='cmp_to_key'/__qualname__/'_functools'; partialmethod/__name__/__qualname__/__module__/__bases__[0].__name__; singledispatchmethod/__name__/__module__/__qualname__; singledispatchmethod/__mro__.__len__()==2; partial/__mro__.__len__()==2; partialmethod/__mro__.__len__()==2; cached_property/__mro__.__len__()==2; reduce/__module__.__len__()==10; cached_property/__bases__[0].__qualname__=='object'; partialmethod/__bases__[0].__qualname__=='object'; partial/__bases__[0].__qualname__=='object'; singledispatchmethod/__bases__[0].__qualname__=='object'; reduce/__class__.__name__=='builtin_function_or_method'; cmp_to_key/__class__.__name__=='builtin_function_or_method'; wraps/__class__.__name__=='function'; lru_cache/__class__.__name__=='function'; update_wrapper/__class__.__name__=='function'; singledispatch/__class__.__name__=='function'; total_ordering/__class__.__name__=='function'; cache/__class__.__name__=='function'; partial/__class__.__name__=='type'; cached_property/__class__.__name__=='type'; partialmethod/__class__.__name__=='type'; singledispatchmethod/__class__.__name__=='type'."
    - "This spec covers: functools.reduce.__class__.__qualname__ == 'builtin_function_or_method'; functools.wraps.__class__.__qualname__ == 'function'; functools.partial.__class__.__qualname__ == 'type'; functools.lru_cache.__class__.__qualname__ == 'function'; functools.cached_property.__class__.__qualname__ == 'type'; functools.singledispatch.__class__.__qualname__ == 'function'; functools.total_ordering.__class__.__qualname__ == 'function'."
    - "Key findings: For built-in top-level types (builtin_function_or_method, function, type) __class__.__qualname__ == __class__.__name__ — both attributes return the same string because these types are defined at the top level of the C runtime with no enclosing class scope. The __qualname__ attribute on a type resolves its qualified name within the module namespace; for built-in types that are directly accessible from builtins, __qualname__ equals __name__. This means functools.__class__.__qualname__ coverage yields the same seven values as __class__.__name__: 'builtin_function_or_method' for reduce (C-extension function), 'function' for wraps/lru_cache/singledispatch/total_ordering (pure-Python functions), and 'type' for partial/cached_property (class objects). Prior spec extra51 covered __class__.__name__ string equality for twelve functools objects; this spec records __class__.__qualname__ string equality for a representative subset of seven. No prior spec recorded __class__.__qualname__ string equality for any functools module-level object; all seven invariants are new to extra52."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools C-extension function __class__.__qualname__ — extra52 namespace
#
# functools.reduce is a C-extension function defined in Modules/_functoolsmodule.c.
# Its __class__.__qualname__ is 'builtin_function_or_method' — the same value as
# __class__.__name__ because built-in top-level types have __qualname__ == __name__
# (no enclosing class scope in the C runtime). Prior spec extra51 recorded
# reduce.__class__.__name__ == 'builtin_function_or_method' (string equality) but
# no prior spec recorded __class__.__qualname__ string equality. New to extra52.
# ---------------------------------------------------------------------------

invariant functools_extra52.reduce_class_qualname:
  description: "functools.reduce.__class__.__qualname__ == 'builtin_function_or_method' — C-extension function; __class__.__qualname__ == __class__.__name__ for built-in top-level types; 26-char qualname"
  category: identity
  kind: python_call_eq
  function: reduce.__class__.__qualname__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# functools pure-Python function objects __class__.__qualname__ — extra52
#
# functools.wraps, lru_cache, singledispatch, and total_ordering are pure-Python
# functions defined in Lib/functools.py. Their __class__.__qualname__ is
# 'function' — the same value as __class__.__name__ because the built-in
# 'function' type is a top-level type with __qualname__ == __name__. Prior spec
# extra51 recorded __class__.__name__ == 'function' for all four (and also for
# update_wrapper and cache). No prior spec recorded __class__.__qualname__
# string equality for any of these objects. All four are new to extra52.
# ---------------------------------------------------------------------------

table functools_extra52.pure_python_function_class_qualnames:
  description: "functools pure-Python function objects __class__.__qualname__ == 'function' — wraps/lru_cache/singledispatch/total_ordering; __class__.__qualname__ == __class__.__name__ for built-in function type; 8-char qualname"
  kind: python_call_eq
  category: identity
  id_prefix: ppfnqn52

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_class_qualname,
       wraps.__class__.__qualname__.__eq__,
       ["function"],
       true,
       "functools.wraps.__class__.__qualname__ == 'function' — pure-Python decorator function in Lib/functools.py; __class__ is the built-in function type; __class__.__qualname__ == __class__.__name__ == 'function' (8 chars) for top-level built-in types"]
    - [lru_cache_class_qualname,
       lru_cache.__class__.__qualname__.__eq__,
       ["function"],
       true,
       "functools.lru_cache.__class__.__qualname__ == 'function' — pure-Python decorator function in Lib/functools.py; memoizes calls with bounded LRU cache; __class__.__qualname__ == __class__.__name__ == 'function' (8 chars)"]
    - [singledispatch_class_qualname,
       singledispatch.__class__.__qualname__.__eq__,
       ["function"],
       true,
       "functools.singledispatch.__class__.__qualname__ == 'function' — pure-Python decorator function in Lib/functools.py; enables single-dispatch generic functions; __class__.__qualname__ == __class__.__name__ == 'function' (8 chars)"]
    - [total_ordering_class_qualname,
       total_ordering.__class__.__qualname__.__eq__,
       ["function"],
       true,
       "functools.total_ordering.__class__.__qualname__ == 'function' — pure-Python decorator function in Lib/functools.py; fills in missing comparison methods; __class__.__qualname__ == __class__.__name__ == 'function' (8 chars)"]

# ---------------------------------------------------------------------------
# functools class objects __class__.__qualname__ — extra52 namespace
#
# functools.partial and functools.cached_property are class objects — their
# __class__ is the metaclass 'type'. For the built-in 'type' metaclass,
# __qualname__ == __name__ == 'type' because type is a top-level built-in with
# no enclosing class scope. Prior spec extra51 recorded __class__.__name__ ==
# 'type' (string equality) for partial, cached_property, partialmethod, and
# singledispatchmethod. This spec records __class__.__qualname__ == 'type'
# for partial and cached_property. No prior spec recorded __class__.__qualname__
# string equality for any functools class object. Both are new to extra52.
# ---------------------------------------------------------------------------

table functools_extra52.class_objects_metaclass_qualnames:
  description: "functools class objects __class__.__qualname__ == 'type' — partial/cached_property are class objects; __class__ is the built-in 'type' metaclass; __class__.__qualname__ == __class__.__name__ == 'type'; 4-char qualname"
  kind: python_call_eq
  category: identity
  id_prefix: clsqn52

  columns: [id, function, args, expected, description]
  rows:
    - [partial_class_qualname,
       partial.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "functools.partial.__class__.__qualname__ == 'type' — C-extension type in Modules/_functoolsmodule.c; class objects are instances of the 'type' metaclass; __class__.__qualname__ == __class__.__name__ == 'type' (4 chars) for built-in top-level types"]
    - [cached_property_class_qualname,
       cached_property.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "functools.cached_property.__class__.__qualname__ == 'type' — pure-Python class in Lib/functools.py; class objects are instances of the 'type' metaclass; __class__.__qualname__ == __class__.__name__ == 'type' (4 chars)"]
