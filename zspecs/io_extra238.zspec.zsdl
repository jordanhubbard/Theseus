spec: io_extra238
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/iobase.c"
  notes:
    - "This spec covers: io.IOBase method __name__ contracts."
    - "io.IOBase.close.__name__ == 'close' — IOBase.close method name; verified Python 3.14.3 macOS."
    - "io.IOBase.flush.__name__ == 'flush' — IOBase.flush method name; verified Python 3.14.3 macOS."
    - "io.IOBase.readable.__name__ == 'readable' — IOBase.readable method name; verified Python 3.14.3 macOS."
    - "io.IOBase.writable.__name__ == 'writable' — IOBase.writable method name; verified Python 3.14.3 macOS."
    - "io.IOBase.seekable.__name__ == 'seekable' — IOBase.seekable method name; verified Python 3.14.3 macOS."
    - "io.IOBase.readline.__name__ == 'readline' — IOBase.readline method name; verified Python 3.14.3 macOS."
    - "io.IOBase.readlines.__name__ == 'readlines' — IOBase.readlines method name; length 9; verified Python 3.14.3 macOS."
    - "io.IOBase.writelines.__name__ == 'writelines' — IOBase.writelines method name; length 10; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.IOBase method __name__ contracts
# All standard IOBase methods carry their canonical name as __name__.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra238.IOBase_method_names:
  description: "io.IOBase method __name__ contracts — close, flush, readable, writable, seekable, readline, readlines, writelines; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_name
  id_prefix: ioiobasemnames238

  columns: [id, function, args, expected]
  rows:
    - [iobase_close_name,      IOBase.close.__name__.__eq__,      ["close"],      true]
    - [iobase_flush_name,      IOBase.flush.__name__.__eq__,      ["flush"],      true]
    - [iobase_readable_name,   IOBase.readable.__name__.__eq__,   ["readable"],   true]
    - [iobase_writable_name,   IOBase.writable.__name__.__eq__,   ["writable"],   true]
    - [iobase_seekable_name,   IOBase.seekable.__name__.__eq__,   ["seekable"],   true]
    - [iobase_readline_name,   IOBase.readline.__name__.__eq__,   ["readline"],   true]
    - [iobase_readlines_name,  IOBase.readlines.__name__.__eq__,  ["readlines"],  true]
    - [iobase_writelines_name, IOBase.writelines.__name__.__eq__, ["writelines"], true]

# ---------------------------------------------------------------------------
# io.IOBase method name length contracts
# Spot-check selected method name lengths.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra238.IOBase.close.name_length:
  description: "io.IOBase.close.__name__.__len__() == 5 — 'close' has 5 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: IOBase.close.__name__.__len__
  args: []
  expected: 5

invariant io_extra238.IOBase.readable.name_length:
  description: "io.IOBase.readable.__name__.__len__() == 8 — 'readable' has 8 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: IOBase.readable.__name__.__len__
  args: []
  expected: 8

invariant io_extra238.IOBase.readlines.name_length:
  description: "io.IOBase.readlines.__name__.__len__() == 9 — 'readlines' has 9 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: IOBase.readlines.__name__.__len__
  args: []
  expected: 9

invariant io_extra238.IOBase.writelines.name_length:
  description: "io.IOBase.writelines.__name__.__len__() == 10 — 'writelines' has 10 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: IOBase.writelines.__name__.__len__
  args: []
  expected: 10

invariant io_extra238.IOBase.flush.name_length:
  description: "io.IOBase.flush.__name__.__len__() == 5 — 'flush' has 5 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: IOBase.flush.__name__.__len__
  args: []
  expected: 5
