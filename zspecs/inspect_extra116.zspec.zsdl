    - [getmembers_static_co_varnames0,
       "getmembers_static.__code__.co_varnames.__getitem__",
       [0],
       "object",
       "inspect.getmembers_static.__code__.co_varnames[0] == 'object' — the first parameter is 'object', the object whose members are to be listed; tuple.__getitem__(0) returns 'object'; new to extra116"]
    - [getmembers_static_co_varnames1,
