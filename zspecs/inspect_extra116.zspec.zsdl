       ["function"],
       true,
       "inspect.getmembers_static.__class__.__name__.__eq__('function') == True — getmembers_static is a pure-Python function (not a C builtin); __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra116"]
    - [getmembers_static_module,
       "getmembers_static.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getmembers_static.__module__.__eq__('inspect') == True — getmembers_static is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra116"]

# ---------------------------------------------------------------------------
# Table 3: classify_class_attrs vs getmembers_static name lengths comparison
#
# Wave 267 theme: Both classify_class_attrs and getmembers_static are pure-
# Python functions in the inspect module with long names. classify_class_attrs
# has 20 chars, getmembers_static has 17 chars — a difference of 3. Both have
# __module__ == 'inspect' (7 chars). classify_class_attrs takes 1 argument,
# getmembers_static takes 2. The co_name length for each matches __name__ length
# (both are top-level functions).
#
# len(classify_class_attrs.__name__) == 20
# len(getmembers_static.__name__) == 17
# Both __module__ == 'inspect'  (len 7)
# classify_class_attrs co_argcount == 1  vs  getmembers_static co_argcount == 2
#
# New to extra116.
# ---------------------------------------------------------------------------

