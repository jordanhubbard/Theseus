  description: "inspect.classify_class_attrs: __name__ len=20 (longest in inspect), co_varnames[0]='cls', __module__ len=7; pure-Python function; wave 267; new to extra116"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectccanv116

