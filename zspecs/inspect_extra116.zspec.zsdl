    - [getmembers_static_module_len_7,
       "getmembers_static.__module__.__len__",
       [],
       7,
       "inspect.getmembers_static.__module__.__len__() == 7 — 'inspect' has 7 chars; same as classify_class_attrs.__module__.__len__(); str.__len__() returns 7; new to extra116"]
    - [classify_co_argcount_1,
