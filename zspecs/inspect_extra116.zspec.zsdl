# ---------------------------------------------------------------------------
# Table 1: inspect.classify_class_attrs __name__ length and co_varnames[0]
#
# Wave 267 theme: inspect.classify_class_attrs is a pure-Python function with
# a 20-character name — the longest in the inspect module. Its sole positional
# parameter is 'cls' (the class to classify). The __module__ is 'inspect'
# (7 chars). Previously covered: __name__, __qualname__, __module__,
# __class__.__name__, __code__.co_name, __code__.co_argcount (earlier specs).
# New here: __name__.__len__ (20), __code__.co_varnames[0] ('cls'),
# __module__.__len__ (7).
#
# classify_class_attrs.__name__.__len__() == 20
# classify_class_attrs.__code__.co_varnames[0] == 'cls'
# classify_class_attrs.__module__.__len__() == 7
#
# New to extra116.
# ---------------------------------------------------------------------------

