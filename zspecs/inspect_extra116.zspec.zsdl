       20,
       "inspect.classify_class_attrs.__name__.__len__() == 20 — 'classify_class_attrs' has 20 chars: c-l-a-s-s-i-f-y(8)+_(1)+c-l-a-s-s(5)+_(1)+a-t-t-r-s(5); longest function name in inspect; str.__len__() returns 20; new to extra116"]
    - [classify_co_varnames0,
       "classify_class_attrs.__code__.co_varnames.__getitem__",
       [0],
       "cls",
       "inspect.classify_class_attrs.__code__.co_varnames[0] == 'cls' — the sole positional parameter is 'cls', the class whose attributes are to be classified; tuple.__getitem__(0) returns 'cls'; new to extra116"]
    - [classify_module_len,
       "classify_class_attrs.__module__.__len__",
       [],
       7,
       "inspect.classify_class_attrs.__module__.__len__() == 7 — 'inspect' has 7 chars: i-n-s-p-e-c-t; str.__len__() returns 7; new to extra116"]
    - [classify_co_argcount,
       "classify_class_attrs.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.classify_class_attrs.__code__.co_argcount.__eq__(1) == True — classify_class_attrs(cls) takes exactly one positional argument; int.__eq__(1) returns True; new to extra116"]
    - [classify_co_name_len,
       "classify_class_attrs.__code__.co_name.__len__",
       [],
       20,
       "inspect.classify_class_attrs.__code__.co_name.__len__() == 20 — co_name is 'classify_class_attrs' (20 chars); same as __name__.__len__() for a top-level function; str.__len__() returns 20; new to extra116"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getmembers_static __name__ and co_varnames
#
# Wave 267 theme: inspect.getmembers_static was added in Python 3.11. It is a
# pure-Python function with __name__ 'getmembers_static' (17 chars). Its first
# parameter is 'object' (co_varnames[0]) and its second is 'predicate'
# (co_varnames[1]). __class__.__name__ is 'function' (it is a plain Python
# function, not a C builtin). __module__ is 'inspect'. Previously covered:
# __qualname__, __code__.co_name, __code__.co_argcount (earlier specs).
# New here: __name__, __name__.__len__, co_varnames[0], co_varnames[1],
# __module__, __class__.__name__.
#
# getmembers_static.__name__ == 'getmembers_static'    (len 17)
# getmembers_static.__code__.co_varnames[0] == 'object'
# getmembers_static.__code__.co_varnames[1] == 'predicate'
# getmembers_static.__class__.__name__ == 'function'
#
# New to extra116.
# ---------------------------------------------------------------------------

table inspect_extra116.getmembers_static_name_and_varnames:
  description: "inspect.getmembers_static (Python 3.11+): __name__='getmembers_static'(17), co_varnames[0]='object', co_varnames[1]='predicate', __class__.__name__='function'; wave 267; new to extra116"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgmsnv116

