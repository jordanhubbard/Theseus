spec: decimal_extra265
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "decimal.Decimal is a C-extension class; its comparison dunder methods are wrapper_descriptor objects."
    - "Decimal comparison methods: __lt__, __le__, __gt__, __ge__, __eq__, __ne__, __hash__ all have __class__.__name__ == 'wrapper_descriptor'."
    - "Decimal comparison method qualnames follow 'Decimal.<method_name>' pattern."
    - "decimal.Decimal.__name__ == 'Decimal' and decimal.Decimal.__module__ == 'decimal'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: Decimal comparison method __name__ identity
# ---------------------------------------------------------------------------

table decimal_extra265.decimal_comparison_method_names:
  description: "decimal.Decimal comparison dunder method __name__ for __lt__, __le__, __gt__, __ge__, __eq__, __ne__, __hash__"
  kind: python_call_eq
  category: identity
  id_prefix: nm

  columns: [id, function, args, expected, description]
  rows:
    - [lt_name,   Decimal.__lt__.__name__.__eq__,   ["__lt__"],   true, "decimal.Decimal.__lt__.__name__ == '__lt__'"]
    - [le_name,   Decimal.__le__.__name__.__eq__,   ["__le__"],   true, "decimal.Decimal.__le__.__name__ == '__le__'"]
    - [gt_name,   Decimal.__gt__.__name__.__eq__,   ["__gt__"],   true, "decimal.Decimal.__gt__.__name__ == '__gt__'"]
    - [ge_name,   Decimal.__ge__.__name__.__eq__,   ["__ge__"],   true, "decimal.Decimal.__ge__.__name__ == '__ge__'"]
    - [eq_name,   Decimal.__eq__.__name__.__eq__,   ["__eq__"],   true, "decimal.Decimal.__eq__.__name__ == '__eq__'"]
    - [ne_name,   Decimal.__ne__.__name__.__eq__,   ["__ne__"],   true, "decimal.Decimal.__ne__.__name__ == '__ne__'"]
    - [hash_name, Decimal.__hash__.__name__.__eq__, ["__hash__"], true, "decimal.Decimal.__hash__.__name__ == '__hash__'"]

# ---------------------------------------------------------------------------
# Table: Decimal comparison method __class__.__name__ (all wrapper_descriptor)
# ---------------------------------------------------------------------------

table decimal_extra265.decimal_comparison_method_classes:
  description: "decimal.Decimal comparison dunder method __class__.__name__ for __lt__, __le__, __gt__, __ge__, __eq__, __ne__, __hash__ (all wrapper_descriptor)"
  kind: python_call_eq
  category: identity
  id_prefix: cls

  columns: [id, function, args, expected, description]
  rows:
    - [lt_class,   Decimal.__lt__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "decimal.Decimal.__lt__.__class__.__name__ == 'wrapper_descriptor'"]
    - [le_class,   Decimal.__le__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "decimal.Decimal.__le__.__class__.__name__ == 'wrapper_descriptor'"]
    - [gt_class,   Decimal.__gt__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "decimal.Decimal.__gt__.__class__.__name__ == 'wrapper_descriptor'"]
    - [ge_class,   Decimal.__ge__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "decimal.Decimal.__ge__.__class__.__name__ == 'wrapper_descriptor'"]
    - [eq_class,   Decimal.__eq__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "decimal.Decimal.__eq__.__class__.__name__ == 'wrapper_descriptor'"]
    - [ne_class,   Decimal.__ne__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "decimal.Decimal.__ne__.__class__.__name__ == 'wrapper_descriptor'"]
    - [hash_class, Decimal.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"], true, "decimal.Decimal.__hash__.__class__.__name__ == 'wrapper_descriptor'"]

# ---------------------------------------------------------------------------
# Standalone invariants: qualnames and Decimal class identity
# ---------------------------------------------------------------------------

invariant decimal_extra265.Decimal.__lt__.qualname:
  description: "decimal.Decimal.__lt__.__qualname__ == 'Decimal.__lt__'"
  category: identity
  kind: python_call_eq
  function: Decimal.__lt__.__qualname__.__eq__
  args: ["Decimal.__lt__"]
  expected: true

invariant decimal_extra265.Decimal.__ge__.qualname:
  description: "decimal.Decimal.__ge__.__qualname__ == 'Decimal.__ge__'"
  category: identity
  kind: python_call_eq
  function: Decimal.__ge__.__qualname__.__eq__
  args: ["Decimal.__ge__"]
  expected: true

invariant decimal_extra265.Decimal.__eq__.qualname:
  description: "decimal.Decimal.__eq__.__qualname__ == 'Decimal.__eq__'"
  category: identity
  kind: python_call_eq
  function: Decimal.__eq__.__qualname__.__eq__
  args: ["Decimal.__eq__"]
  expected: true

invariant decimal_extra265.Decimal.__hash__.qualname:
  description: "decimal.Decimal.__hash__.__qualname__ == 'Decimal.__hash__'"
  category: identity
  kind: python_call_eq
  function: Decimal.__hash__.__qualname__.__eq__
  args: ["Decimal.__hash__"]
  expected: true

invariant decimal_extra265.Decimal.name:
  description: "decimal.Decimal.__name__ == 'Decimal'"
  category: identity
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra265.Decimal.module:
  description: "decimal.Decimal.__module__ == 'decimal'"
  category: identity
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true
