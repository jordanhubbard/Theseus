spec: inspect_extra198
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getsourcefile, inspect.getfile, inspect.getdoc, inspect.getcomments identity — __name__ and __module__."
    - "inspect.getsourcefile.__name__ == 'getsourcefile' — getsourcefile is a pure-Python function defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getsourcefile.__module__ == 'inspect' — getsourcefile is defined at module scope in Lib/inspect.py; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.getfile.__name__ == 'getfile' — getfile is a pure-Python function defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getfile.__module__ == 'inspect' — getfile is defined at module scope in Lib/inspect.py; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.getdoc.__name__ == 'getdoc' — getdoc is a pure-Python function defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getdoc.__module__ == 'inspect' — getdoc is defined at module scope in Lib/inspect.py; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.getcomments.__name__ == 'getcomments' — getcomments is a pure-Python function defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getcomments.__module__ == 'inspect' — getcomments is defined at module scope in Lib/inspect.py; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getsourcefile and inspect.getfile identity — __name__, __module__
#
# inspect.getsourcefile.__name__.__eq__('getsourcefile') == True
# inspect.getsourcefile.__module__.__eq__('inspect') == True
# inspect.getfile.__name__.__eq__('getfile') == True
# inspect.getfile.__module__.__eq__('inspect') == True
#
# Both getsourcefile and getfile are pure-Python functions defined at module
# scope in Lib/inspect.py. getsourcefile returns the Python source file for
# an object; getfile returns the file in which an object was defined.
# New to extra198.
# ---------------------------------------------------------------------------

table inspect_extra198.getsourcefile_getfile_identity:
  description: "inspect.getsourcefile and getfile __name__ and __module__; pure-Python functions defined in Lib/inspect.py; new to extra198"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgetsource198

  columns: [id, function, args, expected, description]
  rows:
    - [getsourcefile_name_eq,
       getsourcefile.__name__.__eq__,
       ["getsourcefile"],
       true,
       "inspect.getsourcefile.__name__.__eq__('getsourcefile') == True — getsourcefile is a pure-Python function in Lib/inspect.py; __name__ is 'getsourcefile'; str.__eq__('getsourcefile') returns True; new to extra198"]
    - [getsourcefile_module_eq_inspect,
       getsourcefile.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getsourcefile.__module__.__eq__('inspect') == True — getsourcefile is defined at module scope in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra198"]
    - [getfile_name_eq,
       getfile.__name__.__eq__,
       ["getfile"],
       true,
       "inspect.getfile.__name__.__eq__('getfile') == True — getfile is a pure-Python function in Lib/inspect.py; __name__ is 'getfile'; str.__eq__('getfile') returns True; new to extra198"]
    - [getfile_module_eq_inspect,
       getfile.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getfile.__module__.__eq__('inspect') == True — getfile is defined at module scope in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra198"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getdoc and inspect.getcomments identity — __name__, __module__
#
# inspect.getdoc.__name__.__eq__('getdoc') == True
# inspect.getdoc.__module__.__eq__('inspect') == True
# inspect.getcomments.__name__.__eq__('getcomments') == True
# inspect.getcomments.__module__.__eq__('inspect') == True
#
# getdoc retrieves the docstring for an object, cleaning up indentation.
# getcomments retrieves lines of comment before an object's definition.
# Both are pure-Python functions in Lib/inspect.py. New to extra198.
# ---------------------------------------------------------------------------

table inspect_extra198.getdoc_getcomments_identity:
  description: "inspect.getdoc and getcomments __name__ and __module__; pure-Python functions defined in Lib/inspect.py; new to extra198"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgetsource198

  columns: [id, function, args, expected, description]
  rows:
    - [getdoc_name_eq,
       getdoc.__name__.__eq__,
       ["getdoc"],
       true,
       "inspect.getdoc.__name__.__eq__('getdoc') == True — getdoc is a pure-Python function in Lib/inspect.py; __name__ is 'getdoc'; str.__eq__('getdoc') returns True; new to extra198"]
    - [getdoc_module_eq_inspect,
       getdoc.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getdoc.__module__.__eq__('inspect') == True — getdoc is defined at module scope in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra198"]
    - [getcomments_name_eq,
       getcomments.__name__.__eq__,
       ["getcomments"],
       true,
       "inspect.getcomments.__name__.__eq__('getcomments') == True — getcomments is a pure-Python function in Lib/inspect.py; __name__ is 'getcomments'; str.__eq__('getcomments') returns True; new to extra198"]
    - [getcomments_module_eq_inspect,
       getcomments.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getcomments.__module__.__eq__('inspect') == True — getcomments is defined at module scope in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra198"]

# ---------------------------------------------------------------------------
# Table 3: all four functions __qualname__ cross-check
#
# inspect.getsourcefile.__qualname__.__eq__('getsourcefile') == True
# inspect.getfile.__qualname__.__eq__('getfile') == True
# inspect.getdoc.__qualname__.__eq__('getdoc') == True
# inspect.getcomments.__qualname__.__eq__('getcomments') == True
#
# All four are top-level functions with no enclosing class or function scope;
# their __qualname__ equals their simple __name__. New to extra198.
# ---------------------------------------------------------------------------

table inspect_extra198.source_functions_qualnames:
  description: "inspect source functions __qualname__; all four are top-level functions; __qualname__ equals __name__ for each; new to extra198"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgetsource198

  columns: [id, function, args, expected, description]
  rows:
    - [getsourcefile_qualname_eq,
       getsourcefile.__qualname__.__eq__,
       ["getsourcefile"],
       true,
       "inspect.getsourcefile.__qualname__.__eq__('getsourcefile') == True — getsourcefile is a top-level function with no enclosing scope prefix; __qualname__ is 'getsourcefile'; str.__eq__('getsourcefile') returns True; new to extra198"]
    - [getfile_qualname_eq,
       getfile.__qualname__.__eq__,
       ["getfile"],
       true,
       "inspect.getfile.__qualname__.__eq__('getfile') == True — getfile is a top-level function with no enclosing scope prefix; __qualname__ is 'getfile'; str.__eq__('getfile') returns True; new to extra198"]
    - [getdoc_qualname_eq,
       getdoc.__qualname__.__eq__,
       ["getdoc"],
       true,
       "inspect.getdoc.__qualname__.__eq__('getdoc') == True — getdoc is a top-level function with no enclosing scope prefix; __qualname__ is 'getdoc'; str.__eq__('getdoc') returns True; new to extra198"]
    - [getcomments_qualname_eq,
       getcomments.__qualname__.__eq__,
       ["getcomments"],
       true,
       "inspect.getcomments.__qualname__.__eq__('getcomments') == True — getcomments is a top-level function with no enclosing scope prefix; __qualname__ is 'getcomments'; str.__eq__('getcomments') returns True; new to extra198"]

