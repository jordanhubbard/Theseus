spec: threading_extra54
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra53.zspec.zsdl."
    - "Prior specs covered for Timer: __module__.__eq__('threading') (extra16/extra19); __module__.__len__()==9 (extra34/extra48); __class__.__name__=='type' (extra14/extra48); __class__.__qualname__=='type' (extra49); __bases__[0].__name__=='Thread' (extra4/extra21/extra31/timer); __mro__.__len__()==3 (extra32); cancel/__name__.__eq__('cancel') (extra14); cancel/__qualname__.__eq__('Timer.cancel') (extra14); run/__name__.__eq__('run') (extra14); run/__qualname__.__eq__('Timer.run') (extra14); __module__.__class__.__name__=='str' (extra53); __name__.__len__()==5 (extra35); __qualname__.__len__()==5 (extra35)."
    - "Prior specs covered for BoundedSemaphore: __module__.__eq__('threading') (extra16/extra19); __module__.__len__()==9 (extra34/extra48); __bases__[0].__name__=='Semaphore' (extra11/extra21/extra31); __mro__.__len__()==3 noted in extra31 notes but not as a standalone invariant row; __module__.__class__.__name__=='str' (extra53)."
    - "This spec covers: threading.Timer.__module__.__class__.__qualname__.__eq__('str')==true; threading.Timer.cancel.__qualname__.__len__()==12; threading.Timer.cancel.__name__.__len__()==6; threading.Timer.run.__qualname__.__len__()==9; threading.BoundedSemaphore.__module__.__class__.__qualname__.__eq__('str')==true; threading.BoundedSemaphore.__mro__.__len__()==3 as explicit row; threading.Condition.__module__.__class__.__qualname__.__eq__('str')==true; threading.Barrier.__module__.__class__.__qualname__.__eq__('str')==true."
    - "Key findings: extra53 confirmed __module__.__class__.__name__=='str' for all major threading classes (Thread/Event/Semaphore/BoundedSemaphore/Condition/Barrier/Timer) but no prior spec records __module__.__class__.__qualname__=='str' for any threading class. The str built-in type has __qualname__ == __name__ == 'str' (3 chars) so this is a consistent complement. Timer.cancel.__qualname__ is 'Timer.cancel' (12 chars = 5+1+6) and Timer.cancel.__name__ is 'cancel' (6 chars); Timer.run.__qualname__ is 'Timer.run' (9 chars = 5+1+3); no prior spec records these lengths. BoundedSemaphore.__mro__.__len__()==3 ([BoundedSemaphore, Semaphore, object]) was noted in extra31 notes but never recorded as an explicit invariant row. All eight invariants are new to extra54."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading class __module__.__class__.__qualname__ == 'str' — extra54 namespace
#
# All pure-Python threading classes store their __module__ as the Python string
# 'threading' (9 chars). This string is a str object. The str built-in type is
# a top-level type with __qualname__ == __name__ == 'str' (3 chars). Prior
# extra53 recorded __module__.__class__.__name__=='str' for all major threading
# classes, but no prior spec records __module__.__class__.__qualname__=='str'
# for any threading class. The four checks below establish this pattern for
# Timer, BoundedSemaphore, Condition, and Barrier.
# ---------------------------------------------------------------------------

table threading_extra54.class_module_class_qualname:
  description: "threading class __module__.__class__.__qualname__ == 'str' — str built-in type has __qualname__ == __name__ == 'str' (3 chars); extra53 covered __class__.__name__ form; __class__.__qualname__ form not recorded in any prior threading spec"
  kind: python_call_eq
  category: identity
  id_prefix: thrdtimer54

  columns: [id, function, args, expected, description]
  rows:
    - [Timer_module_class_qualname,
       Timer.__module__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "threading.Timer.__module__.__class__.__qualname__ == 'str' — Timer is a pure-Python class in Lib/threading.py (Thread subclass that runs a function after a delay); __module__ is the Python string 'threading' (9 chars); the str built-in type has __qualname__ == 'str' (3 chars; top-level type, no enclosing scope); extra53 confirmed Timer.__module__.__class__.__name__.__eq__('str'); this is the first __module__.__class__.__qualname__ check for Timer; new to extra54"]
    - [BoundedSemaphore_module_class_qualname,
       BoundedSemaphore.__module__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "threading.BoundedSemaphore.__module__.__class__.__qualname__ == 'str' — BoundedSemaphore is a pure-Python class in Lib/threading.py (Semaphore subclass with an upper bound on the count); __module__ is the Python string 'threading' (9 chars); the str built-in type has __qualname__ == 'str' (3 chars); extra53 confirmed BoundedSemaphore.__module__.__class__.__name__.__eq__('str'); this is the first __module__.__class__.__qualname__ check for BoundedSemaphore; new to extra54"]
    - [Condition_module_class_qualname,
       Condition.__module__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "threading.Condition.__module__.__class__.__qualname__ == 'str' — Condition is a pure-Python class in Lib/threading.py implementing a condition variable for thread synchronization; __module__ is the Python string 'threading' (9 chars); the str built-in type has __qualname__ == 'str' (3 chars); extra53 confirmed Condition.__module__.__class__.__name__.__eq__('str'); this is the first __module__.__class__.__qualname__ check for Condition; new to extra54"]
    - [Barrier_module_class_qualname,
       Barrier.__module__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "threading.Barrier.__module__.__class__.__qualname__ == 'str' — Barrier is a pure-Python class in Lib/threading.py that allows a fixed number of threads to wait for each other; __module__ is the Python string 'threading' (9 chars); the str built-in type has __qualname__ == 'str' (3 chars); extra53 confirmed Barrier.__module__.__class__.__name__.__eq__('str'); this is the first __module__.__class__.__qualname__ check for Barrier; new to extra54"]

# ---------------------------------------------------------------------------
# threading.Timer method qualname/name lengths — extra54 namespace
#
# threading.Timer defines two methods of its own: cancel and run. Their
# qualnames follow the standard Python dotted-prefix convention:
#   Timer.cancel.__qualname__ == 'Timer.cancel'  (12 chars: 5+'.'+'cancel'=6)
#   Timer.cancel.__name__     == 'cancel'         (6 chars)
#   Timer.run.__qualname__    == 'Timer.run'      (9 chars: 5+'.'+'run'=3)
# Prior extra14 confirmed these qualname string values (.__eq__ checks) but no
# prior spec records their lengths as __len__() invariant rows. All three
# length checks below are new to extra54.
# ---------------------------------------------------------------------------

table threading_extra54.timer_method_qualname_lengths:
  description: "threading.Timer method qualname/name lengths — Timer.cancel.__qualname__.__len__()==12; Timer.cancel.__name__.__len__()==6; Timer.run.__qualname__.__len__()==9; extra14 confirmed string equality values but not lengths; new to extra54"
  kind: python_call_eq
  category: method_names
  id_prefix: thrdtimer54

  columns: [id, function, args, expected, description]
  rows:
    - [cancel_qualname_len,
       Timer.cancel.__qualname__.__len__,
       [],
       12,
       "threading.Timer.cancel.__qualname__.__len__() == 12 — Timer.cancel.__qualname__ is 'Timer.cancel' (5-char class prefix 'Timer' + '.' + 6-char method name 'cancel' = 12 chars total); Timer.cancel is defined directly on the Timer class to cancel a pending timer call; extra14 confirmed Timer.cancel.__qualname__.__eq__('Timer.cancel'); this is the first __qualname__.__len__() row for Timer.cancel; new to extra54"]
    - [cancel_name_len,
       Timer.cancel.__name__.__len__,
       [],
       6,
       "threading.Timer.cancel.__name__.__len__() == 6 — Timer.cancel.__name__ is 'cancel' (6 chars: c-a-n-c-e-l); extra14 confirmed Timer.cancel.__name__.__eq__('cancel'); this is the first __name__.__len__() row for Timer.cancel; new to extra54"]
    - [run_qualname_len,
       Timer.run.__qualname__.__len__,
       [],
       9,
       "threading.Timer.run.__qualname__.__len__() == 9 — Timer.run.__qualname__ is 'Timer.run' (5-char class prefix 'Timer' + '.' + 3-char method name 'run' = 9 chars total); Timer.run overrides Thread.run to wait for the delay then call the target function (unless cancel() is called first); extra14 confirmed Timer.run.__qualname__.__eq__('Timer.run'); this is the first __qualname__.__len__() row for Timer.run; new to extra54"]

# ---------------------------------------------------------------------------
# threading.BoundedSemaphore.__mro__.__len__() — extra54 standalone
#
# threading.BoundedSemaphore.__mro__ is [BoundedSemaphore, Semaphore, object],
# length 3. This was noted in threading_extra31 provenance notes but was never
# recorded as an explicit invariant row in extra31 (only MRO entry __name__
# checks were recorded there: __mro__[1].__name__=='Semaphore',
# __mro__[2].__name__=='object'). threading_extra32 covered __mro__.__len__()
# for Thread, Event, Condition, Barrier, Semaphore, and Timer but not for
# BoundedSemaphore. This is the first explicit __mro__.__len__()==3 row for
# BoundedSemaphore.
# ---------------------------------------------------------------------------

table threading_extra54.boundedsemaphore_mro_len:
  description: "threading.BoundedSemaphore.__mro__.__len__()==3 — [BoundedSemaphore, Semaphore, object]; noted in extra31 notes but never recorded as an explicit invariant row; extra32 covered __mro__.__len__ for other classes but not BoundedSemaphore"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: thrdtimer54

  columns: [id, function, args, expected, description]
  rows:
    - [BoundedSemaphore_mro_len,
       BoundedSemaphore.__mro__.__len__,
       [],
       3,
       "threading.BoundedSemaphore.__mro__.__len__() == 3 — BoundedSemaphore MRO is [BoundedSemaphore, Semaphore, object] (3 entries); BoundedSemaphore is a Semaphore subclass (prior specs confirmed __bases__[0].__name__=='Semaphore'), making its MRO one entry longer than flat classes like Thread/Event/Condition/Barrier/Semaphore (MRO length 2); threading_extra31 noted this value in provenance but did not record it as an explicit invariant; threading_extra32 covered __mro__.__len__ for Thread/Event/Condition/Barrier/Semaphore/Timer but not BoundedSemaphore; this is the first explicit row; new to extra54"]
