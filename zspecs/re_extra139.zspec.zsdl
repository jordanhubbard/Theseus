spec: re_extra139
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec covers: re.Match method descriptor __qualname__ and __class__.__name__ for group, groups, start, end, span, groupdict, and expand."
    - "re.Match is a C extension type (module == 're'); its methods are all method_descriptor instances."
    - "re.Match.__name__ == 'Match' (length 5), __module__ == 're' (length 2), __qualname__ == 'Match' (length 5)."
    - "Match.group.__qualname__ == 'Match.group' (length 11); __class__.__name__ == 'method_descriptor'."
    - "Match.groups.__qualname__ == 'Match.groups' (length 12); __class__.__name__ == 'method_descriptor'."
    - "Match.start.__qualname__ == 'Match.start' (length 11); __class__.__name__ == 'method_descriptor'."
    - "Match.end.__qualname__ == 'Match.end' (length 9); __class__.__name__ == 'method_descriptor'."
    - "Match.span.__qualname__ == 'Match.span' (length 10); __class__.__name__ == 'method_descriptor'."
    - "Match.groupdict.__qualname__ == 'Match.groupdict' (length 15); __class__.__name__ == 'method_descriptor'."
    - "Match.expand.__qualname__ == 'Match.expand' (length 12); __class__.__name__ == 'method_descriptor'."
    - "Each method descriptor's __objclass__.__name__ == 'Match', confirming the owning type."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Match class identity
# Match is a C extension type defined in the _sre module, exposed via re.
# __name__ == 'Match' (5), __module__ == 're' (2), __qualname__ == 'Match' (5).
# __class__.__name__ == 'type' (not ABCMeta; Match is a plain C type).
# ---------------------------------------------------------------------------

table re_extra139.Match_class_identity:
  description: "re.Match class identity: __name__='Match' (5), __module__='re' (2), __qualname__='Match' (5), __class__.__name__='type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: rematch139

  columns: [id, function, args, expected]
  rows:
    - [match_name_eq,      Match.__name__.__eq__,          ["Match"], true]
    - [match_name_len,     Match.__name__.__len__,         [],        5]
    - [match_module_eq,    Match.__module__.__eq__,        ["re"],    true]
    - [match_module_len,   Match.__module__.__len__,       [],        2]
    - [match_qualname_eq,  Match.__qualname__.__eq__,      ["Match"], true]
    - [match_qualname_len, Match.__qualname__.__len__,     [],        5]
    - [match_cls_eq,       Match.__class__.__name__.__eq__, ["type"],  true]

# ---------------------------------------------------------------------------
# re.Match core method descriptor __qualname__ values
# group: 'Match.group' (11), groups: 'Match.groups' (12),
# start: 'Match.start' (11), end: 'Match.end' (9), span: 'Match.span' (10).
# All are method_descriptor instances.
# ---------------------------------------------------------------------------

table re_extra139.Match_core_method_qualnames:
  description: "re.Match core method descriptor __qualname__ values: group='Match.group' (11), groups='Match.groups' (12), start='Match.start' (11), end='Match.end' (9), span='Match.span' (10)"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: rematch139

  columns: [id, function, args, expected]
  rows:
    - [group_cls_eq,    Match.group.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [groups_cls_eq,   Match.groups.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [start_cls_eq,    Match.start.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [end_cls_eq,      Match.end.__class__.__name__.__eq__,      ["method_descriptor"], true]
    - [span_cls_eq,     Match.span.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [group_qn_eq,     Match.group.__qualname__.__eq__,          ["Match.group"],       true]
    - [group_qn_len,    Match.group.__qualname__.__len__,         [],                    11]
    - [groups_qn_eq,    Match.groups.__qualname__.__eq__,         ["Match.groups"],      true]
    - [groups_qn_len,   Match.groups.__qualname__.__len__,        [],                    12]
    - [start_qn_eq,     Match.start.__qualname__.__eq__,          ["Match.start"],       true]
    - [start_qn_len,    Match.start.__qualname__.__len__,         [],                    11]
    - [end_qn_eq,       Match.end.__qualname__.__eq__,            ["Match.end"],         true]
    - [end_qn_len,      Match.end.__qualname__.__len__,           [],                    9]
    - [span_qn_eq,      Match.span.__qualname__.__eq__,           ["Match.span"],        true]
    - [span_qn_len,     Match.span.__qualname__.__len__,          [],                    10]

# ---------------------------------------------------------------------------
# re.Match groupdict and expand method descriptor __qualname__ values
# groupdict: 'Match.groupdict' (15), expand: 'Match.expand' (12).
# Both are method_descriptor instances.
# ---------------------------------------------------------------------------

table re_extra139.Match_extra_method_qualnames:
  description: "re.Match groupdict and expand method descriptor __qualname__ values: groupdict='Match.groupdict' (15), expand='Match.expand' (12)"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: rematch139

  columns: [id, function, args, expected]
  rows:
    - [groupdict_cls_eq,  Match.groupdict.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [expand_cls_eq,     Match.expand.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [groupdict_qn_eq,   Match.groupdict.__qualname__.__eq__,        ["Match.groupdict"],   true]
    - [groupdict_qn_len,  Match.groupdict.__qualname__.__len__,       [],                    15]
    - [expand_qn_eq,      Match.expand.__qualname__.__eq__,           ["Match.expand"],      true]
    - [expand_qn_len,     Match.expand.__qualname__.__len__,          [],                    12]

# ---------------------------------------------------------------------------
# re.Match method descriptor __objclass__.__name__
# Each method descriptor's __objclass__ is the owning type: Match.
# All of group, groups, start, end, span, groupdict, expand share the same owner.
# ---------------------------------------------------------------------------

table re_extra139.Match_method_objclass:
  description: "re.Match method descriptor __objclass__.__name__ == 'Match' for all core methods: group, groups, start, end, span, groupdict, expand"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: rematch139

  columns: [id, function, args, expected]
  rows:
    - [group_obj_eq,     Match.group.__objclass__.__name__.__eq__,     ["Match"], true]
    - [groups_obj_eq,    Match.groups.__objclass__.__name__.__eq__,    ["Match"], true]
    - [start_obj_eq,     Match.start.__objclass__.__name__.__eq__,     ["Match"], true]
    - [end_obj_eq,       Match.end.__objclass__.__name__.__eq__,       ["Match"], true]
    - [span_obj_eq,      Match.span.__objclass__.__name__.__eq__,      ["Match"], true]
    - [groupdict_obj_eq, Match.groupdict.__objclass__.__name__.__eq__, ["Match"], true]
    - [expand_obj_eq,    Match.expand.__objclass__.__name__.__eq__,    ["Match"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra139.Match.group_qualname_eq:
  description: "re.Match.group.__qualname__ == 'Match.group' (length 11; group is a method_descriptor on the C Match type, qualname has no module prefix)"
  category: method_descriptor
  kind: python_call_eq
  function: Match.group.__qualname__.__eq__
  args: ["Match.group"]
  expected: true

invariant re_extra139.Match.groups_qualname_len_12:
  description: "re.Match.groups.__qualname__.__len__() == 12 ('Match.groups' has 12 characters)"
  category: method_descriptor
  kind: python_call_eq
  function: Match.groups.__qualname__.__len__
  args: []
  expected: 12

invariant re_extra139.Match.end_qualname_len_9:
  description: "re.Match.end.__qualname__.__len__() == 9 ('Match.end' has 9 characters; the shortest of the core Match method qualnames)"
  category: method_descriptor
  kind: python_call_eq
  function: Match.end.__qualname__.__len__
  args: []
  expected: 9

invariant re_extra139.Match.groupdict_qualname_len_15:
  description: "re.Match.groupdict.__qualname__.__len__() == 15 ('Match.groupdict' has 15 characters)"
  category: method_descriptor
  kind: python_call_eq
  function: Match.groupdict.__qualname__.__len__
  args: []
  expected: 15

invariant re_extra139.Match.module_is_re:
  description: "re.Match.__module__ == 're' (length 2; the Match type is exposed through the re module despite being implemented in _sre C extension)"
  category: class_identity
  kind: python_call_eq
  function: Match.__module__.__eq__
  args: ["re"]
  expected: true
