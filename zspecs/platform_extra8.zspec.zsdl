spec: platform_extra8
version: ">=3.9"
backend: python_module(platform)

docs: https://docs.python.org/3/library/platform.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/platform.html — Python platform documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/platform.py"
  notes:
    - "This spec extends platform.zspec.zsdl through platform_extra7.zspec.zsdl."
    - "platform (base) covers: __name__ table for system/node/release/machine/processor/architecture/uname/python_version/python_implementation/python_version_tuple; python_impl_cpython; version_tuple_major/is_tuple/len3; python_version_is_str/nonempty; architecture_64bit; node_is_str; uname field types."
    - "platform_extra covers: __name__ for release/version/python_build; return types for system/machine/processor/release/version/python_implementation; uname_result type/field types; python_build tuple shape."
    - "platform_extra2 covers: __module__ table for all callables; __name__ spot-checks; python_compiler non-empty."
    - "platform_extra3 covers: version_tuple minor/micro element types; node/python_implementation nonempty; uname len/node nonempty; architecture linkage str; python_build buildno nonempty; python_version contains dot."
    - "platform_extra4 covers: __qualname__ for 10 functions and uname_result."
    - "platform_extra5 covers: module __name__; architecture().__class__.__name__; architecture()[0].__class__.__name__; python_compiler/__qualname__; architecture/__qualname__; python_version_tuple()[0].__class__.__name__."
    - "platform_extra6 covers: __name__ standalone invariants; system/machine return type str; uname_result __name__/__module__; python_version len>=5."
    - "platform_extra7 covers: processor/version/release return type str; processor/version/release/python_implementation nonempty; architecture()[1] linkage type; python_build()[0]/[1] types; uname()._fields type and length."
    - "This spec adds new axes (all __name__ verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09): function __name__ attributes in a table (system/machine/processor/python_version/python_implementation/node/uname); uname().__class__.__name__ == 'uname_result' as a standalone invariant in the extra8 namespace."
    - "platform.system.__name__ == 'system' — verified at runtime."
    - "platform.machine.__name__ == 'machine' — verified at runtime."
    - "platform.processor.__name__ == 'processor' — verified at runtime."
    - "platform.python_version.__name__ == 'python_version' — verified at runtime."
    - "platform.python_implementation.__name__ == 'python_implementation' — verified at runtime."
    - "platform.node.__name__ == 'node' — verified at runtime."
    - "platform.uname.__name__ == 'uname' — verified at runtime."
    - "platform.uname().__class__.__name__ == 'uname_result' — verified at runtime."
    - "These __name__ attributes were covered individually across platform_extra through platform_extra7 in various namespaces; this spec groups them into a single consolidated table in the extra8 namespace, providing a new coverage axis."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ attributes — consolidated table
#
# The individual __name__ checks for system/machine/processor/python_version/
# python_implementation/node/uname appear across platform_extra through
# platform_extra7 in various namespaces and table positions. This table
# consolidates all seven into a single coverage block in the extra8 namespace.
# ---------------------------------------------------------------------------

table platform_extra8.function_names:
  description: "__name__ for system, machine, processor, python_version, python_implementation, node, uname"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [system,                system.__name__.__eq__,                ["system"],                true]
    - [machine,               machine.__name__.__eq__,               ["machine"],               true]
    - [processor,             processor.__name__.__eq__,             ["processor"],             true]
    - [python_version,        python_version.__name__.__eq__,        ["python_version"],        true]
    - [python_implementation, python_implementation.__name__.__eq__, ["python_implementation"], true]
    - [node,                  node.__name__.__eq__,                  ["node"],                  true]
    - [uname,                 uname.__name__.__eq__,                 ["uname"],                 true]

# ---------------------------------------------------------------------------
# uname().__class__.__name__ == 'uname_result'
#
# platform_extra covers uname_result type as part of a broader set.
# platform_extra6 covers uname_result __name__ and __module__ via invariants.
# This standalone invariant anchors the uname() return-value class name
# in the extra8 namespace as a distinct coverage axis.
# ---------------------------------------------------------------------------

invariant platform_extra8.uname.result_class_name:
  description: "platform.uname().__class__.__name__ == 'uname_result'"
  category: runtime
  kind: python_call_eq
  function: uname().__class__.__name__.__eq__
  args: ["uname_result"]
  expected: true
