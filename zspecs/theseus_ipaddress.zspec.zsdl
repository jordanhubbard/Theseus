spec: theseus_ipaddress
version: ">=3.9"
backend: python_cleanroom(theseus_ipaddress)
blocks: ipaddress

docs: https://docs.python.org/3/library/ipaddress.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html"
    - "https://www.rfc-editor.org/rfc/rfc4291 — IPv6 Addressing"
  notes:
    - "Clean-room IP address parsing. Do NOT import ipaddress or socket."
    - "IPv4Address('192.168.1.1'): parses dotted-decimal; .packed returns 4 bytes."
    - "IPv4Network('192.168.1.0/24'): network_address, broadcast_address, prefixlen."
    - "ipaddress_parse_v4(): IPv4Address('192.168.1.1').packed == b'\\xc0\\xa8\\x01\\x01'."
    - "ipaddress_is_private(): IPv4Address('192.168.1.1').is_private == True."
    - "ipaddress_network_prefix(): IPv4Network('192.168.1.0/24').prefixlen == 24."
    - "Export: IPv4Address, IPv4Network classes."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_ipaddress.parse_v4:
  description: "IPv4Address('192.168.1.1').packed == b'\\xc0\\xa8\\x01\\x01'"
  category: parse
  kind: python_call_eq
  function: ipaddress_parse_v4
  args: []
  expected: true

invariant theseus_ipaddress.is_private:
  description: "IPv4Address('192.168.1.1').is_private == True"
  category: properties
  kind: python_call_eq
  function: ipaddress_is_private
  args: []
  expected: true

invariant theseus_ipaddress.network_prefix:
  description: "IPv4Network('192.168.1.0/24').prefixlen == 24"
  category: network
  kind: python_call_eq
  function: ipaddress_network_prefix
  args: []
  expected: 24
