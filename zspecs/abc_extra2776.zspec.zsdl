spec: abc_extra2776
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "abc_extra.zspec.zsdl — covers abstractmethod.__isabstractmethod__, ABC.__subclasshook__, ABC.__abstractmethods__, ABCMeta.__instancecheck__, get_cache_token"
    - "abc_extra2.zspec.zsdl — covers __name__, __module__, __qualname__, metaclass identity for ABC, ABCMeta, abstractmethod"
    - "abc_extra2761.zspec.zsdl — covers __matmul__, __truediv__, __iadd__ dict-presence checks"
  notes:
    - "Wave 632 theme: __isub__, __imul__, and __itruediv__ dict-presence checks (in-place arithmetic)."
    - "None of the abc public objects define __isub__, __imul__, or __itruediv__ in their __dict__."
    - "ABCMeta is a metaclass (type of type); ABC is the abstract base class helper; abstractmethod is a decorator."
    - "abc.abstractproperty was removed in Python 3.13; it is not covered in this spec."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta — __isub__/__imul__/__itruediv__ dict-presence checks
#
# ABCMeta is the metaclass for abstract base classes. Its __dict__ contains
# metaclass machinery (__instancecheck__, __subclasscheck__, register, etc.)
# but no in-place arithmetic operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2776.abcmeta_operator_dict:
  description: "abc.ABCMeta __isub__, __imul__, __itruediv__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2776am

  columns: [id, function, args, expected]
  rows:
    - ["ab2776am_isub",    abc.ABCMeta.__dict__.__contains__, ["__isub__"],    false]
    - ["ab2776am_imul",    abc.ABCMeta.__dict__.__contains__, ["__imul__"],    false]
    - ["ab2776am_itruediv", abc.ABCMeta.__dict__.__contains__, ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# abc.ABC — __isub__/__imul__/__itruediv__ dict-presence checks
#
# ABC is the convenience helper class for creating abstract base classes via
# inheritance. Its __dict__ is minimal (only __doc__ and __abstractmethods__).
# It does not define in-place arithmetic operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2776.abc_operator_dict:
  description: "abc.ABC __isub__, __imul__, __itruediv__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2776abc

  columns: [id, function, args, expected]
  rows:
    - ["ab2776abc_isub",    abc.ABC.__dict__.__contains__, ["__isub__"],    false]
    - ["ab2776abc_imul",    abc.ABC.__dict__.__contains__, ["__imul__"],    false]
    - ["ab2776abc_itruediv", abc.ABC.__dict__.__contains__, ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# abc.abstractmethod — __isub__/__imul__/__itruediv__ dict-presence checks
#
# abstractmethod is a pure-Python decorator function. Its __dict__ holds only
# __isabstractmethod__ == True and the usual function attributes. It does not
# implement in-place arithmetic operator dunders.
# ---------------------------------------------------------------------------

table abc_extra2776.abstractmethod_operator_dict:
  description: "abc.abstractmethod __isub__, __imul__, __itruediv__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2776abm

  columns: [id, function, args, expected]
  rows:
    - ["ab2776abm_isub",    abc.abstractmethod.__dict__.__contains__, ["__isub__"],    false]
    - ["ab2776abm_imul",    abc.abstractmethod.__dict__.__contains__, ["__imul__"],    false]
    - ["ab2776abm_itruediv", abc.abstractmethod.__dict__.__contains__, ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Full cross-type matrix — ABCMeta, ABC, abstractmethod × three in-place operator dunders
#
# Consolidates the 3×3 dict-presence check (excluding deprecated abstractproperty)
# in one table. Every cell is False: ABCMeta, ABC, and abstractmethod do not
# define -=, *=, or /= operator dunders in their __dict__.
# ---------------------------------------------------------------------------

table abc_extra2776.all_types_isub_imul_itruediv_matrix:
  description: "Full 3×3 dict-presence matrix for abc.ABCMeta, abc.ABC, abc.abstractmethod vs __isub__/__imul__/__itruediv__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ab2776mx

  columns: [id, function, args, expected]
  rows:
    - ["ab2776mx_am_is",  abc.ABCMeta.__dict__.__contains__,       ["__isub__"],    false]
    - ["ab2776mx_am_im",  abc.ABCMeta.__dict__.__contains__,       ["__imul__"],    false]
    - ["ab2776mx_am_it",  abc.ABCMeta.__dict__.__contains__,       ["__itruediv__"], false]
    - ["ab2776mx_ac_is",  abc.ABC.__dict__.__contains__,           ["__isub__"],    false]
    - ["ab2776mx_ac_im",  abc.ABC.__dict__.__contains__,           ["__imul__"],    false]
    - ["ab2776mx_ac_it",  abc.ABC.__dict__.__contains__,           ["__itruediv__"], false]
    - ["ab2776mx_ab_is",  abc.abstractmethod.__dict__.__contains__, ["__isub__"],   false]
    - ["ab2776mx_ab_im",  abc.abstractmethod.__dict__.__contains__, ["__imul__"],   false]
    - ["ab2776mx_ab_it",  abc.abstractmethod.__dict__.__contains__, ["__itruediv__"], false]
