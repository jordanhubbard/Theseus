spec: itertools_extra126
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.combinations class slot qualnames and type identity (Wave 258)."
    - "itertools.combinations.__iter__.__qualname__ == 'combinations.__iter__' (len 21) — wrapper_descriptor. Verified with Python 3.14.3."
    - "itertools.combinations.__next__.__qualname__ == 'combinations.__next__' (len 21) — wrapper_descriptor. Verified with Python 3.14.3."
    - "itertools.combinations.__new__.__qualname__ == 'combinations.__new__' (len 20) — builtin_function_or_method. Verified with Python 3.14.3."
    - "itertools.combinations.__class__.__name__ == 'type' — combinations is a C extension type. Verified with Python 3.14.3."
    - "itertools.combinations.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "len(itertools.combinations.__mro__) == 2 — MRO is [combinations, object]. Verified with Python 3.14.3."
    - "itertools.combinations.__qualname__ == 'combinations' (len 12). Verified with Python 3.14.3."
    - "itertools.combinations.__name__ == 'combinations' (len 12). Verified with Python 3.14.3."
    - "itertools.combinations.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.combinations class identity and MRO
#
# Wave 258 theme: itertools.combinations C extension type identity.
#
# itertools.combinations.__class__.__name__ == 'type'
# itertools.combinations.__module__ == 'itertools'
# itertools.combinations.__qualname__ == 'combinations' (len 12)
# itertools.combinations.__name__ == 'combinations' (len 12)
# len(itertools.combinations.__mro__) == 2
# itertools.combinations.__bases__[0].__name__ == 'object'
#
# combinations is a C extension type defined in Modules/itertoolsmodule.c;
# its metaclass is 'type'; it inherits directly from object; MRO length is 2.
# New to extra126.
# ---------------------------------------------------------------------------

table itertools_extra126.combinations_type_identity:
  description: "itertools.combinations C extension type identity: __class__.__name__, __module__, __qualname__, __name__, MRO len, __bases__[0]; wave 258; new to extra126"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscomb126

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_class_name_eq_type,
       "combinations.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.combinations.__class__.__name__.__eq__('type') == True — combinations is a C extension type defined in Modules/itertoolsmodule.c; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra126"]
    - [combinations_module_eq_itertools,
       "combinations.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.combinations.__module__.__eq__('itertools') == True — combinations is a C extension type; the module initializer sets __module__ to 'itertools'; str.__eq__('itertools') returns True; new to extra126"]
    - [combinations_qualname_eq,
       "combinations.__qualname__.__eq__",
       ["combinations"],
       true,
       "itertools.combinations.__qualname__.__eq__('combinations') == True — combinations is defined at module scope in the C extension; its __qualname__ is the simple type name 'combinations'; str.__eq__('combinations') returns True; new to extra126"]
    - [combinations_qualname_len_eq_12,
       "combinations.__qualname__.__len__",
       [],
       12,
       "itertools.combinations.__qualname__.__len__() == 12 — __qualname__ is 'combinations' which has exactly 12 characters; len('combinations') == 12; new to extra126"]
    - [combinations_name_eq,
       "combinations.__name__.__eq__",
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — the __name__ attribute of the combinations C extension type is 'combinations', matching the PyTypeObject tp_name; str.__eq__('combinations') returns True; new to extra126"]
    - [combinations_mro_len_eq_2,
       "combinations.__mro__.__len__",
       [],
       2,
       "itertools.combinations.__mro__.__len__() == 2 — combinations inherits directly from object with no intermediate base classes; MRO is [combinations, object]; len(__mro__) is 2; new to extra126"]
    - [combinations_bases_first_eq_object,
       "combinations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations.__bases__[0].__name__.__eq__('object') == True — combinations inherits directly from object; its only base class is the built-in object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra126"]

# ---------------------------------------------------------------------------
# Table 2: itertools.combinations __iter__ and __next__ slot qualnames
#
# Wave 258 theme: itertools.combinations iterator protocol slot qualnames.
#
# itertools.combinations.__iter__.__qualname__ == 'combinations.__iter__' (len 21)
# itertools.combinations.__iter__.__class__.__name__ == 'wrapper_descriptor'
# itertools.combinations.__next__.__qualname__ == 'combinations.__next__' (len 21)
# itertools.combinations.__next__.__class__.__name__ == 'wrapper_descriptor'
#
# combinations implements the iterator protocol via __iter__ and __next__;
# when accessed on the type, these are wrapper_descriptor objects.
# New to extra126.
# ---------------------------------------------------------------------------

table itertools_extra126.combinations_iter_next_qualnames:
  description: "itertools.combinations __iter__ and __next__ qualnames and class names; iterator protocol wrapper_descriptors; wave 258; new to extra126"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscomb126

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_iter_qualname_eq,
       "combinations.__iter__.__qualname__.__eq__",
       ["combinations.__iter__"],
       true,
       "itertools.combinations.__iter__.__qualname__.__eq__('combinations.__iter__') == True — the __iter__ slot method on the combinations C extension type follows the 'typename.method' qualname convention; __qualname__ is 'combinations.__iter__'; str.__eq__('combinations.__iter__') returns True; new to extra126"]
    - [combinations_iter_qualname_len_eq_21,
       "combinations.__iter__.__qualname__.__len__",
       [],
       21,
       "itertools.combinations.__iter__.__qualname__.__len__() == 21 — 'combinations.__iter__' has exactly 21 characters (12 + 1 + 8); len('combinations.__iter__') == 21; new to extra126"]
    - [combinations_iter_class_name_eq_wrapper_descriptor,
       "combinations.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.combinations.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — when accessed on the type, the __iter__ slot of a C extension type is exposed as a wrapper_descriptor; __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra126"]
    - [combinations_next_qualname_eq,
       "combinations.__next__.__qualname__.__eq__",
       ["combinations.__next__"],
       true,
       "itertools.combinations.__next__.__qualname__.__eq__('combinations.__next__') == True — the __next__ slot method on combinations follows the 'typename.method' qualname pattern; str.__eq__('combinations.__next__') returns True; new to extra126"]
    - [combinations_next_qualname_len_eq_21,
       "combinations.__next__.__qualname__.__len__",
       [],
       21,
       "itertools.combinations.__next__.__qualname__.__len__() == 21 — 'combinations.__next__' has exactly 21 characters (12 + 1 + 8); len('combinations.__next__') == 21; new to extra126"]
    - [combinations_next_class_name_eq_wrapper_descriptor,
       "combinations.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.combinations.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — __next__ on a C iterator type is a wrapper_descriptor when accessed on the type; __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra126"]

# ---------------------------------------------------------------------------
# Table 3: itertools.combinations __new__ qualname and class name
#
# Wave 258 theme: itertools.combinations __new__ builtin_function_or_method identity.
#
# itertools.combinations.__new__.__qualname__ == 'combinations.__new__' (len 20)
# itertools.combinations.__new__.__class__.__name__ == 'builtin_function_or_method'
#
# __new__ on C extension types is a builtin_function_or_method (unlike __iter__
# and __next__ which are wrapper_descriptors). New to extra126.
# ---------------------------------------------------------------------------

table itertools_extra126.combinations_new_qualname:
  description: "itertools.combinations __new__ qualname and class name; builtin_function_or_method; wave 258; new to extra126"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscomb126

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_new_qualname_eq,
       "combinations.__new__.__qualname__.__eq__",
       ["combinations.__new__"],
       true,
       "itertools.combinations.__new__.__qualname__.__eq__('combinations.__new__') == True — the __new__ method on the combinations C extension type has qualname 'combinations.__new__'; str.__eq__('combinations.__new__') returns True; new to extra126"]
    - [combinations_new_qualname_len_eq_20,
       "combinations.__new__.__qualname__.__len__",
       [],
       20,
       "itertools.combinations.__new__.__qualname__.__len__() == 20 — 'combinations.__new__' has exactly 20 characters (12 + 1 + 7); len('combinations.__new__') == 20; new to extra126"]
    - [combinations_new_class_name_eq_builtin_function_or_method,
       "combinations.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.combinations.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — __new__ on C extension types is a builtin_function_or_method (unlike slot wrappers such as __iter__ which are wrapper_descriptors); __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra126"]
    - [combinations_name_len_eq_12,
       "combinations.__name__.__len__",
       [],
       12,
       "itertools.combinations.__name__.__len__() == 12 — __name__ is 'combinations' which has exactly 12 characters; len('combinations') == 12; new to extra126"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra126
# ---------------------------------------------------------------------------

invariant itertools_extra126.combinations_class_name:
  description: "itertools.combinations.__class__.__name__ == 'type' — C extension type; metaclass is type; wave 258; new to extra126"
  kind: python_call_eq
  function: combinations.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra126.combinations_module:
  description: "itertools.combinations.__module__ == 'itertools' — C extension type from itertoolsmodule.c; wave 258; new to extra126"
  kind: python_call_eq
  function: combinations.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra126.combinations_mro_len:
  description: "len(itertools.combinations.__mro__) == 2 — MRO is [combinations, object]; inherits directly from object; wave 258; new to extra126"
  kind: python_call_eq
  function: combinations.__mro__.__len__
  args: []
  expected: 2

invariant itertools_extra126.combinations_iter_qualname_len:
  description: "len(itertools.combinations.__iter__.__qualname__) == 21 — 'combinations.__iter__' has 21 chars; wave 258; new to extra126"
  kind: python_call_eq
  function: combinations.__iter__.__qualname__.__len__
  args: []
  expected: 21

invariant itertools_extra126.combinations_new_class_name:
  description: "itertools.combinations.__new__.__class__.__name__ == 'builtin_function_or_method' — __new__ differs from wrapper_descriptor slots; wave 258; new to extra126"
  kind: python_call_eq
  function: combinations.__new__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
