spec: traceback_extra_rust
version: ">=3.9"
backend: rust_module(traceback_extra_rust)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — traceback stdlib"
  notes:
    - "traceback provides exception traceback utilities."
    - "traceback.format_exc() returns a string."
    - "traceback.TracebackException is a class."
    - "traceback.format_tb is callable."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant traceback_extra_rust.has_traceback_exception:
  description: "traceback.TracebackException is a class"
  category: presence
  kind: python_call_eq
  function: traceback_extra_has_traceback_exception
  args: []
  expected: true

invariant traceback_extra_rust.has_format_tb:
  description: "traceback.format_tb is callable"
  category: presence
  kind: python_call_eq
  function: traceback_extra_has_format_tb
  args: []
  expected: true

invariant traceback_extra_rust.format_exc_is_string:
  description: "traceback.format_exc() returns a string"
  category: format
  kind: python_call_eq
  function: traceback_extra_format_exc_is_string
  args: []
  expected: true

