spec: abc_extra1141
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc.abstractproperty __weakref__ descriptor identity, abc.update_abstractmethods qualname/module/name/class, abc.__package__ value and class, abc.abstractmethod qualname/module/name/class, abc.ABC.__abstractmethods__ class, abc.ABCMeta.__subclasshook__/__subclasses__ identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc.abstractproperty __weakref__ descriptor class name and qualname, abc.update_abstractmethods qualname/module/name/class, abc.__package__ value and class, abc.abstractmethod qualname/module/name/class, abc.ABC.__abstractmethods__ class, abc.ABCMeta.__subclasshook__/__subclasses__ identity — behaviors not covered by extra1111 or extra1126"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra1141.abstractproperty_weakref_and_package:
  description: "abc.abstractproperty __weakref__ descriptor class name/qualname/name, and abc.__package__ value and class identity"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: ab1141aw
  columns: [id, function, args, expected]
  rows:
    - [ab1141aw001, abc.abstractproperty.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"],              true]
    - [ab1141aw002, abc.abstractproperty.__weakref__.__qualname__.__eq__,       ["abstractproperty.__weakref__"],   true]
    - [ab1141aw003, abc.abstractproperty.__weakref__.__name__.__eq__,           ["__weakref__"],                    true]
    - [ab1141aw004, abc.__package__.__class__.__name__.__eq__,                  ["str"],                            true]
    - [ab1141aw005, abc.__package__.__eq__,                                     [""],                               true]
    - [ab1141aw006, abc.__loader__.__class__.__name__.__eq__,                   ["type"],                           true]
    - [ab1141aw007, abc.ABC.__abstractmethods__.__class__.__name__.__eq__,      ["frozenset"],                      true]
    - [ab1141aw008, abc.ABC.__bases__.__class__.__name__.__eq__,                ["tuple"],                          true]

table abc_extra1141.update_abstractmethods_and_abstractmethod_identity:
  description: "abc.update_abstractmethods and abc.abstractmethod qualname, module, name, and class identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: ab1141um
  columns: [id, function, args, expected]
  rows:
    - [ab1141um001, abc.update_abstractmethods.__qualname__.__eq__,  ["update_abstractmethods"],  true]
    - [ab1141um002, abc.update_abstractmethods.__module__.__eq__,    ["abc"],                      true]
    - [ab1141um003, abc.update_abstractmethods.__name__.__eq__,      ["update_abstractmethods"],  true]
    - [ab1141um004, abc.update_abstractmethods.__class__.__name__.__eq__, ["function"],            true]
    - [ab1141um005, abc.abstractmethod.__qualname__.__eq__,          ["abstractmethod"],           true]
    - [ab1141um006, abc.abstractmethod.__module__.__eq__,            ["abc"],                      true]
    - [ab1141um007, abc.abstractmethod.__name__.__eq__,              ["abstractmethod"],           true]
    - [ab1141um008, abc.abstractmethod.__class__.__name__.__eq__,    ["function"],                 true]

table abc_extra1141.abcmeta_subclasshook_and_subclasses:
  description: "abc.ABCMeta.__subclasshook__ and abc.ABCMeta.__subclasses__ qualname, name, and class identity"
