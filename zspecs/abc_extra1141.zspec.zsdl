    - [ab1141sh003, abc.ABCMeta.__subclasshook__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ab1141sh004, abc.ABCMeta.__subclasses__.__qualname__.__eq__,      ["type.__subclasses__"],         true]
    - [ab1141sh005, abc.ABCMeta.__subclasses__.__name__.__eq__,          ["__subclasses__"],              true]
    - [ab1141sh006, abc.ABCMeta.__subclasses__.__class__.__name__.__eq__, ["method_descriptor"],          true]
