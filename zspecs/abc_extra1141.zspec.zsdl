    - [ab1141sh008, abc.ABCMeta.__name__.__eq__,                         ["ABCMeta"],                     true]
    - [ab1141sh009, abc.ABCMeta.__module__.__eq__,                       ["abc"],                         true]
    - [ab1141sh010, abc.ABC.__qualname__.__eq__,                         ["ABC"],                         true]
