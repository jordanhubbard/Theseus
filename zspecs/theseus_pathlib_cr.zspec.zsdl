spec: theseus_pathlib_cr
version: ">=3.0"
backend: python_cleanroom(theseus_pathlib_cr)
blocks: pathlib

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "Clean-room pathlib module. Do NOT import pathlib."

error_model: python_exceptions

invariant theseus_pathlib_cr.pathlib2_pure:
  description: "PurePosixPath parts/name/suffix work"
  category: behavior
  kind: python_call_eq
  function: pathlib2_pure
  args: []
  expected: true

invariant theseus_pathlib_cr.pathlib2_concrete:
  description: "Path.cwd() and .is_dir() work"
  category: behavior
  kind: python_call_eq
  function: pathlib2_concrete
  args: []
  expected: true

invariant theseus_pathlib_cr.pathlib2_parts:
  description: "Path division operator and parts work"
  category: behavior
  kind: python_call_eq
  function: pathlib2_parts
  args: []
  expected: true
