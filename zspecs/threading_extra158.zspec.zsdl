       [],
       10,
       "threading.Thread.run.__qualname__.__len__() == 10 — the string 'Thread.run' has exactly 10 characters: T-h-r-e-a-d-.-r-u-n; str.__len__() returns 10; new to extra158"]
    - [thread_is_alive_qualname_len_eq_15,
       "Thread.is_alive.__qualname__.__len__",
       [],
       15,
       "threading.Thread.is_alive.__qualname__.__len__() == 15 — the string 'Thread.is_alive' has exactly 15 characters: T-h-r-e-a-d-.-i-s-_-a-l-i-v-e; str.__len__() returns 15; new to extra158"]
    - [thread_join_qualname_len_eq_11,
       "Thread.join.__qualname__.__len__",
