spec: threading_extra158
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Thread method qualnames — Thread.run.__qualname__ 'Thread.run', Thread.join.__qualname__ 'Thread.join', Thread.is_alive.__qualname__ 'Thread.is_alive', Thread.start.__qualname__ 'Thread.start', Thread.__init__.__qualname__ 'Thread.__init__'; qualname lengths: Thread.run 10, Thread.is_alive 15, Thread.join 11, Thread.start 12 (Wave 286)."
    - "threading.Thread.run.__qualname__ == 'Thread.run' — Thread defines run() in Lib/threading.py as the method invoked by the started thread; __qualname__ is 'Thread.run'. Verified with Python 3.14.3."
    - "threading.Thread.join.__qualname__ == 'Thread.join' — Thread defines join() in Lib/threading.py to wait until the thread terminates; __qualname__ is 'Thread.join'. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__qualname__ == 'Thread.is_alive' — Thread defines is_alive() in Lib/threading.py to test whether the thread is alive; __qualname__ is 'Thread.is_alive'. Verified with Python 3.14.3."
    - "threading.Thread.start.__qualname__ == 'Thread.start' — Thread defines start() in Lib/threading.py to begin thread activity; __qualname__ is 'Thread.start'. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__qualname__ == 'Thread.__init__' — Thread defines __init__ in Lib/threading.py to initialize thread objects; __qualname__ is 'Thread.__init__'. Verified with Python 3.14.3."
    - "threading.Thread.run.__qualname__.__len__() == 10 — 'Thread.run' has 10 characters: T-h-r-e-a-d-.-r-u-n. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__qualname__.__len__() == 15 — 'Thread.is_alive' has 15 characters: T-h-r-e-a-d-.-i-s-_-a-l-i-v-e. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread method qualnames (run, join, is_alive, start, __init__)
#
# Wave 286 theme: threading.Thread method __qualname__ attributes.
#
# threading.Thread.run.__qualname__ == 'Thread.run'
# threading.Thread.join.__qualname__ == 'Thread.join'
# threading.Thread.is_alive.__qualname__ == 'Thread.is_alive'
# threading.Thread.start.__qualname__ == 'Thread.start'
# threading.Thread.__init__.__qualname__ == 'Thread.__init__'
#
# All five methods are defined as Python functions within the Thread class body
# in Lib/threading.py. Each method's __qualname__ records the enclosing class
# scope as 'Thread.<method_name>'. run() is the method that performs the thread
# activity; start() invokes run() in a new thread; join() blocks until the thread
# finishes; is_alive() checks if the thread is running; __init__() configures
# the thread object. New to extra158.
# ---------------------------------------------------------------------------

table threading_extra158.thread_method_qualnames:
  description: "threading.Thread method qualnames: run 'Thread.run', join 'Thread.join', is_alive 'Thread.is_alive', start 'Thread.start', __init__ 'Thread.__init__'; wave 286; new to extra158"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthreadmq158

  columns: [id, function, args, expected, description]
  rows:
    - [thread_run_qualname_eq,
       "Thread.run.__qualname__.__eq__",
       ["Thread.run"],
       true,
       "threading.Thread.run.__qualname__.__eq__('Thread.run') == True — Thread.run is defined in Lib/threading.py as the method that performs the thread activity and is invoked by start(); its __qualname__ is 'Thread.run'; str.__eq__('Thread.run') returns True; new to extra158"]
    - [thread_join_qualname_eq,
       "Thread.join.__qualname__.__eq__",
       ["Thread.join"],
       true,
       "threading.Thread.join.__qualname__.__eq__('Thread.join') == True — Thread.join is defined in Lib/threading.py to block the caller until the thread terminates; its __qualname__ is 'Thread.join'; str.__eq__('Thread.join') returns True; new to extra158"]
    - [thread_is_alive_qualname_eq,
       "Thread.is_alive.__qualname__.__eq__",
       ["Thread.is_alive"],
       true,
       "threading.Thread.is_alive.__qualname__.__eq__('Thread.is_alive') == True — Thread.is_alive is defined in Lib/threading.py to return True if the thread is alive (between start() and termination); its __qualname__ is 'Thread.is_alive'; str.__eq__('Thread.is_alive') returns True; new to extra158"]
    - [thread_start_qualname_eq,
       "Thread.start.__qualname__.__eq__",
       ["Thread.start"],
       true,
       "threading.Thread.start.__qualname__.__eq__('Thread.start') == True — Thread.start is defined in Lib/threading.py to begin thread activity by arranging for run() to be called in a new thread; its __qualname__ is 'Thread.start'; str.__eq__('Thread.start') returns True; new to extra158"]
    - [thread_init_qualname_eq,
       "Thread.__init__.__qualname__.__eq__",
       ["Thread.__init__"],
       true,
       "threading.Thread.__init__.__qualname__.__eq__('Thread.__init__') == True — Thread.__init__ is defined in Lib/threading.py to initialize thread objects with the target, name, args, kwargs, daemon, and group parameters; its __qualname__ is 'Thread.__init__'; str.__eq__('Thread.__init__') returns True; new to extra158"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread method qualname lengths
#
# Wave 286 theme: threading.Thread method __qualname__ string lengths.
#
# threading.Thread.run.__qualname__.__len__() == 10
# threading.Thread.is_alive.__qualname__.__len__() == 15
# threading.Thread.join.__qualname__.__len__() == 11
# threading.Thread.start.__qualname__.__len__() == 12
#
# The qualname lengths reflect the full dotted path including the class prefix.
# 'Thread.run' = 10 chars, 'Thread.join' = 11 chars, 'Thread.start' = 12 chars,
# 'Thread.is_alive' = 15 chars. New to extra158.
# ---------------------------------------------------------------------------

table threading_extra158.thread_method_qualname_lengths:
