spec: itertools_extra275
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "zip_longest, accumulate, starmap, compress are all C-level types; __class__.__name__ == 'type'."
    - "All four have __module__ == 'itertools' and __name__ matching their export symbol."
    - "zip_longest.__name__ == 'zip_longest' (12 chars); accumulate.__name__ == 'accumulate' (10 chars)."
    - "starmap.__name__ == 'starmap' (7 chars); compress.__name__ == 'compress' (8 chars)."
    - "These are lazy iterator types, not functions; instantiation yields a C iterator object."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.zip_longest and itertools.accumulate — class identity
#
# Both are C-level types: __class__.__name__ == 'type'.
# __module__ == 'itertools'; __name__ matches the export symbol.
# zip_longest.__name__ == 'zip_longest' (12 chars).
# accumulate.__name__ == 'accumulate' (10 chars).
# ---------------------------------------------------------------------------

table itertools_extra275.zip_longest_accumulate_identity:
  description: "itertools.zip_longest and accumulate class identity — __name__, __module__, __class__.__name__; C-level types; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex275zla

  columns: [id, function, args, expected, description]
  rows:
    - [zl_name_eq,  zip_longest.__name__.__eq__,            ["zip_longest"], true, "itertools.zip_longest.__name__ == 'zip_longest'; verified with Python 3.14.3"]
    - [zl_name_len, zip_longest.__name__.__len__,            [],              12,   "itertools.zip_longest.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [zl_mod_eq,   zip_longest.__module__.__eq__,          ["itertools"],   true, "itertools.zip_longest.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [zl_cls_eq,   zip_longest.__class__.__name__.__eq__,  ["type"],        true, "itertools.zip_longest.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [ac_name_eq,  accumulate.__name__.__eq__,             ["accumulate"],  true, "itertools.accumulate.__name__ == 'accumulate'; verified with Python 3.14.3"]
    - [ac_name_len, accumulate.__name__.__len__,             [],              10,   "itertools.accumulate.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [ac_mod_eq,   accumulate.__module__.__eq__,           ["itertools"],   true, "itertools.accumulate.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [ac_cls_eq,   accumulate.__class__.__name__.__eq__,   ["type"],        true, "itertools.accumulate.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# itertools.starmap and itertools.compress — class identity
#
# Both are C-level types: __class__.__name__ == 'type'.
# starmap.__name__ == 'starmap' (7 chars); compress.__name__ == 'compress' (8 chars).
# ---------------------------------------------------------------------------

table itertools_extra275.starmap_compress_identity:
  description: "itertools.starmap and compress class identity — __name__, __module__, __class__.__name__; C-level types; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex275smc

  columns: [id, function, args, expected, description]
  rows:
    - [sm_name_eq,  starmap.__name__.__eq__,            ["starmap"],   true, "itertools.starmap.__name__ == 'starmap'; verified with Python 3.14.3"]
    - [sm_name_len, starmap.__name__.__len__,            [],            7,    "itertools.starmap.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [sm_mod_eq,   starmap.__module__.__eq__,          ["itertools"], true, "itertools.starmap.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [sm_cls_eq,   starmap.__class__.__name__.__eq__,  ["type"],      true, "itertools.starmap.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [cp_name_eq,  compress.__name__.__eq__,           ["compress"],  true, "itertools.compress.__name__ == 'compress'; verified with Python 3.14.3"]
    - [cp_name_len, compress.__name__.__len__,           [],            8,    "itertools.compress.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [cp_mod_eq,   compress.__module__.__eq__,         ["itertools"], true, "itertools.compress.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [cp_cls_eq,   compress.__class__.__name__.__eq__, ["type"],      true, "itertools.compress.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra275
# ---------------------------------------------------------------------------

invariant itertools_extra275.zip_longest_class_is_type:
  description: "itertools.zip_longest.__class__.__name__ == 'type' — zip_longest is a C-level type, not a Python function"
  category: identity
  kind: python_call_eq
  function: zip_longest.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra275.zip_longest_module_is_itertools:
  description: "itertools.zip_longest.__module__ == 'itertools' — C-level type registered under the itertools module"
  category: identity
  kind: python_call_eq
  function: zip_longest.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra275.zip_longest_name_length_is_12:
  description: "itertools.zip_longest.__name__.__len__() == 12 — 'zip_longest' has 12 characters including the underscore"
  category: identity
  kind: python_call_eq
  function: zip_longest.__name__.__len__
  args: []
  expected: 12

invariant itertools_extra275.accumulate_class_is_type:
  description: "itertools.accumulate.__class__.__name__ == 'type' — accumulate is a C-level type"
  category: identity
  kind: python_call_eq
  function: accumulate.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra275.starmap_class_is_type:
  description: "itertools.starmap.__class__.__name__ == 'type' — starmap is a C-level type"
  category: identity
  kind: python_call_eq
  function: starmap.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra275.starmap_name_length_is_7:
  description: "itertools.starmap.__name__.__len__() == 7 — 'starmap' has 7 characters"
  category: identity
  kind: python_call_eq
  function: starmap.__name__.__len__
  args: []
  expected: 7

invariant itertools_extra275.compress_class_is_type:
  description: "itertools.compress.__class__.__name__ == 'type' — compress is a C-level type"
  category: identity
  kind: python_call_eq
  function: compress.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra275.compress_module_is_itertools:
  description: "itertools.compress.__module__ == 'itertools' — C-level type registered under the itertools module"
  category: identity
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["itertools"]
  expected: true
