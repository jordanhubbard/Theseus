spec: decimal_extra2131
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "_decimal_extra.zspec.zsdl — covers _decimal C-module class metadata"
    - "decimal_extra1981.zspec.zsdl — covers __sizeof__/__floor__/__ceil__/__trunc__ dict-presence"
    - "decimal_extra1966.zspec.zsdl — covers __enter__/__exit__/__del__ dict-presence"
  notes:
    - "Wave 2131, theme: exception protocol dict-presence."
    - "Checks whether __cause__, __context__, __traceback__, __suppress_context__, __notes__, args, and with_traceback appear in the __dict__ of decimal classes."
    - "__cause__, __context__, __traceback__, __suppress_context__ are set by CPython exception machinery on exception instances — never in any class __dict__."
    - "args is a tuple instance attribute of BaseException set during __init__; not a class-level attribute."
    - "with_traceback is a BaseException C-level method; none of the decimal exception classes override it."
    - "__notes__ (PEP 678, Python 3.11+) is created on instances via add_note(); never in a class __dict__."
    - "decimal.DecimalException and its subclasses (InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded, Subnormal, FloatOperation) are all exceptions."
    - "decimal.DivisionImpossible, DivisionUndefined, InvalidContext, ConversionSyntax are additional exception subclasses."
    - "decimal.Decimal and decimal.Context are non-exception types; they define no exception protocol attrs."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __cause__ dict-presence — decimal types
# __cause__ is set by 'raise X from Y'; it lives on exception instances, not classes.
# Even decimal exception subclasses define no __cause__ in their own __dict__.
# ---------------------------------------------------------------------------

table decimal_extra2131.cause_protocol_core:
  description: "decimal core type __dict__.__contains__('__cause__') — all False (instance attribute)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2131

  columns: [id, function, args, expected]
  rows:
    - ["dc2131001", "decimal.Decimal.__dict__.__contains__",          ["__cause__"], false]
    - ["dc2131002", "decimal.Context.__dict__.__contains__",          ["__cause__"], false]
    - ["dc2131003", "decimal.DecimalException.__dict__.__contains__", ["__cause__"], false]
    - ["dc2131004", "decimal.InvalidOperation.__dict__.__contains__", ["__cause__"], false]
    - ["dc2131005", "decimal.DivisionByZero.__dict__.__contains__",   ["__cause__"], false]
    - ["dc2131006", "decimal.Overflow.__dict__.__contains__",         ["__cause__"], false]
    - ["dc2131007", "decimal.Underflow.__dict__.__contains__",        ["__cause__"], false]

table decimal_extra2131.cause_protocol_subclasses:
  description: "decimal exception subclass __dict__.__contains__('__cause__') — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2131

  columns: [id, function, args, expected]
  rows:
    - ["dc2131008", "decimal.Inexact.__dict__.__contains__",           ["__cause__"], false]
    - ["dc2131009", "decimal.Rounded.__dict__.__contains__",           ["__cause__"], false]
    - ["dc2131010", "decimal.Subnormal.__dict__.__contains__",         ["__cause__"], false]
    - ["dc2131011", "decimal.FloatOperation.__dict__.__contains__",    ["__cause__"], false]
    - ["dc2131012", "decimal.DivisionImpossible.__dict__.__contains__", ["__cause__"], false]
    - ["dc2131013", "decimal.DivisionUndefined.__dict__.__contains__",  ["__cause__"], false]
    - ["dc2131014", "decimal.InvalidContext.__dict__.__contains__",     ["__cause__"], false]
    - ["dc2131015", "decimal.ConversionSyntax.__dict__.__contains__",   ["__cause__"], false]

# ---------------------------------------------------------------------------
# __context__ dict-presence — decimal types
# __context__ is the implicit chained exception; set by the interpreter at raise time.
# ---------------------------------------------------------------------------

table decimal_extra2131.context_protocol:
  description: "decimal type __dict__.__contains__('__context__') — all False (instance attribute)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2131

  columns: [id, function, args, expected]
  rows:
    - ["dc2131016", "decimal.Decimal.__dict__.__contains__",          ["__context__"], false]
    - ["dc2131017", "decimal.Context.__dict__.__contains__",          ["__context__"], false]
    - ["dc2131018", "decimal.DecimalException.__dict__.__contains__", ["__context__"], false]
    - ["dc2131019", "decimal.InvalidOperation.__dict__.__contains__", ["__context__"], false]
    - ["dc2131020", "decimal.DivisionByZero.__dict__.__contains__",   ["__context__"], false]
    - ["dc2131021", "decimal.FloatOperation.__dict__.__contains__",   ["__context__"], false]

# ---------------------------------------------------------------------------
# __traceback__ dict-presence — decimal types
# __traceback__ holds the traceback object on exception instances; not class-level.
# ---------------------------------------------------------------------------

table decimal_extra2131.traceback_protocol:
  description: "decimal type __dict__.__contains__('__traceback__') — all False (instance attribute)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2131

  columns: [id, function, args, expected]
  rows:
    - ["dc2131022", "decimal.Decimal.__dict__.__contains__",          ["__traceback__"], false]
    - ["dc2131023", "decimal.Context.__dict__.__contains__",          ["__traceback__"], false]
    - ["dc2131024", "decimal.DecimalException.__dict__.__contains__", ["__traceback__"], false]
    - ["dc2131025", "decimal.InvalidOperation.__dict__.__contains__", ["__traceback__"], false]
    - ["dc2131026", "decimal.Overflow.__dict__.__contains__",         ["__traceback__"], false]
    - ["dc2131027", "decimal.Underflow.__dict__.__contains__",        ["__traceback__"], false]
    - ["dc2131028", "decimal.Inexact.__dict__.__contains__",          ["__traceback__"], false]

# ---------------------------------------------------------------------------
# __suppress_context__ dict-presence — decimal types
# __suppress_context__ is a bool on exception instances set by 'from' clause.
# ---------------------------------------------------------------------------

table decimal_extra2131.suppress_context_protocol:
  description: "decimal type __dict__.__contains__('__suppress_context__') — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2131

  columns: [id, function, args, expected]
  rows:
    - ["dc2131029", "decimal.Decimal.__dict__.__contains__",          ["__suppress_context__"], false]
    - ["dc2131030", "decimal.Context.__dict__.__contains__",          ["__suppress_context__"], false]
    - ["dc2131031", "decimal.DecimalException.__dict__.__contains__", ["__suppress_context__"], false]
    - ["dc2131032", "decimal.DivisionByZero.__dict__.__contains__",   ["__suppress_context__"], false]
    - ["dc2131033", "decimal.FloatOperation.__dict__.__contains__",   ["__suppress_context__"], false]
    - ["dc2131034", "decimal.DivisionImpossible.__dict__.__contains__", ["__suppress_context__"], false]
    - ["dc2131035", "decimal.ConversionSyntax.__dict__.__contains__",   ["__suppress_context__"], false]

# ---------------------------------------------------------------------------
# __notes__ dict-presence — decimal types
# __notes__ (PEP 678, Python 3.11+) is lazily created on instances via add_note().
# ---------------------------------------------------------------------------

table decimal_extra2131.notes_protocol:
  description: "decimal type __dict__.__contains__('__notes__') — all False (PEP 678 instance attribute)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2131

  columns: [id, function, args, expected]
  rows:
    - ["dc2131036", "decimal.Decimal.__dict__.__contains__",          ["__notes__"], false]
    - ["dc2131037", "decimal.Context.__dict__.__contains__",          ["__notes__"], false]
    - ["dc2131038", "decimal.DecimalException.__dict__.__contains__", ["__notes__"], false]
    - ["dc2131039", "decimal.InvalidOperation.__dict__.__contains__", ["__notes__"], false]
    - ["dc2131040", "decimal.Rounded.__dict__.__contains__",          ["__notes__"], false]
    - ["dc2131041", "decimal.Subnormal.__dict__.__contains__",        ["__notes__"], false]
    - ["dc2131042", "decimal.InvalidContext.__dict__.__contains__",   ["__notes__"], false]

# ---------------------------------------------------------------------------
# args dict-presence — decimal types
# args is a tuple instance attribute of BaseException; not in any class __dict__.
# decimal.DecimalException and all its subclasses inherit args from BaseException.
# ---------------------------------------------------------------------------

table decimal_extra2131.args_protocol:
  description: "decimal type __dict__.__contains__('args') — all False (instance attribute of BaseException)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2131

  columns: [id, function, args, expected]
  rows:
    - ["dc2131043", "decimal.Decimal.__dict__.__contains__",          ["args"], false]
    - ["dc2131044", "decimal.Context.__dict__.__contains__",          ["args"], false]
    - ["dc2131045", "decimal.DecimalException.__dict__.__contains__", ["args"], false]
    - ["dc2131046", "decimal.InvalidOperation.__dict__.__contains__", ["args"], false]
    - ["dc2131047", "decimal.DivisionByZero.__dict__.__contains__",   ["args"], false]
    - ["dc2131048", "decimal.Overflow.__dict__.__contains__",         ["args"], false]
    - ["dc2131049", "decimal.FloatOperation.__dict__.__contains__",   ["args"], false]
    - ["dc2131050", "decimal.DivisionUndefined.__dict__.__contains__", ["args"], false]

# ---------------------------------------------------------------------------
# with_traceback dict-presence — decimal types
# with_traceback is defined on BaseException in C; no decimal class overrides it.
# decimal.DecimalException and its hierarchy do not redefine with_traceback.
# ---------------------------------------------------------------------------

table decimal_extra2131.with_traceback_protocol:
  description: "decimal type __dict__.__contains__('with_traceback') — all False (BaseException C-level method)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2131

  columns: [id, function, args, expected]
  rows:
    - ["dc2131051", "decimal.Decimal.__dict__.__contains__",          ["with_traceback"], false]
    - ["dc2131052", "decimal.Context.__dict__.__contains__",          ["with_traceback"], false]
    - ["dc2131053", "decimal.DecimalException.__dict__.__contains__", ["with_traceback"], false]
    - ["dc2131054", "decimal.InvalidOperation.__dict__.__contains__", ["with_traceback"], false]
    - ["dc2131055", "decimal.DivisionByZero.__dict__.__contains__",   ["with_traceback"], false]
    - ["dc2131056", "decimal.Overflow.__dict__.__contains__",         ["with_traceback"], false]
    - ["dc2131057", "decimal.Underflow.__dict__.__contains__",        ["with_traceback"], false]
    - ["dc2131058", "decimal.Inexact.__dict__.__contains__",          ["with_traceback"], false]
    - ["dc2131059", "decimal.Rounded.__dict__.__contains__",          ["with_traceback"], false]
    - ["dc2131060", "decimal.Subnormal.__dict__.__contains__",        ["with_traceback"], false]
