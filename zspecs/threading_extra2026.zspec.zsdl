spec: threading_extra2026
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 582 (_extra2026): __truediv__/__rtruediv__/__itruediv__, __floordiv__/__rfloordiv__/__ifloordiv__, __mod__/__rmod__/__imod__, __pow__/__rpow__, __divmod__/__rdivmod__ dict-presence checks."
    - "threading synchronization primitives are not arithmetic types — none define division, modulo, exponentiation, or divmod operators."
    - "threading.Thread: Python class for managing OS threads — division/modulo/pow/divmod dunders absent from __dict__."
    - "threading.Event: Python synchronization primitive — division/modulo/pow/divmod dunders absent from __dict__."
    - "threading.Lock: C-level lock type — division/modulo/pow/divmod dunders absent from __dict__."
    - "threading.Condition: Python synchronization primitive — division/modulo/pow/divmod dunders absent from __dict__."
    - "threading.Semaphore: Python counting semaphore — division/modulo/pow/divmod dunders absent from __dict__."
    - "threading.Barrier: Python reusable barrier — division/modulo/pow/divmod dunders absent from __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __truediv__ / __rtruediv__ / __itruediv__ dict-presence
#
# threading.Thread, threading.Event, threading.Lock, threading.Condition,
# threading.Semaphore, threading.Barrier are concurrency primitives with no
# arithmetic semantics. None define true-division operators in their __dict__.
# All checks expected False.
# ---------------------------------------------------------------------------

table threading_extra2026.truediv_protocol:
  description: "threading types __truediv__/__rtruediv__/__itruediv__ dict-presence checks — all False — wave 582 _extra2026"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2026

  columns: [id, function, args, expected]
  rows:
    - ["th2026001", "threading.Thread.__dict__.__contains__", ["__truediv__"], false]
    - ["th2026002", "threading.Thread.__dict__.__contains__", ["__rtruediv__"], false]
    - ["th2026003", "threading.Thread.__dict__.__contains__", ["__itruediv__"], false]
    - ["th2026004", "threading.Event.__dict__.__contains__", ["__truediv__"], false]
    - ["th2026005", "threading.Event.__dict__.__contains__", ["__rtruediv__"], false]
    - ["th2026006", "threading.Event.__dict__.__contains__", ["__itruediv__"], false]
    - ["th2026007", "threading.Condition.__dict__.__contains__", ["__truediv__"], false]
    - ["th2026008", "threading.Condition.__dict__.__contains__", ["__rtruediv__"], false]
    - ["th2026009", "threading.Condition.__dict__.__contains__", ["__itruediv__"], false]
    - ["th2026010", "threading.Semaphore.__dict__.__contains__", ["__truediv__"], false]
    - ["th2026011", "threading.Semaphore.__dict__.__contains__", ["__rtruediv__"], false]
    - ["th2026012", "threading.Semaphore.__dict__.__contains__", ["__itruediv__"], false]

