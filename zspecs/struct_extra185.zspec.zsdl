spec: struct_extra185
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "struct.Struct.pack.__qualname__ == 'Struct.pack' — len=11; dotted qualname format."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack' — len=13."
    - "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into' — len=16."
    - "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from' — len=18."
    - "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack' — len=18."
    - "Length ordering: pack(11) < unpack(13) < pack_into(16) < unpack_from(18)==iter_unpack(18)."
    - "struct.Struct.__module__ == '_struct' — Struct class is defined in the C extension _struct."
    - "method_descriptor objects (Struct.pack, Struct.unpack) have no __module__ attribute; use struct.Struct.__module__ instead."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.Struct method qualnames — pack and unpack
#
# struct.Struct.pack.__qualname__    == 'Struct.pack'    (len=11)
# struct.Struct.unpack.__qualname__  == 'Struct.unpack'  (len=13)
#
# The C-level method_descriptor objects on struct.Struct expose a __qualname__
# attribute in the dotted 'ClassName.method' format.  pack is the shortest
# with 11 characters; unpack adds two more for 13.
# ---------------------------------------------------------------------------

table struct_extra185.struct_pack_unpack_qualnames:
  description: "struct.Struct.pack and unpack __qualname__ identity and length; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: structqualnames185

  columns: [id, function, args, expected, description]
  rows:
    - [pack_qualname_eq,
       struct.Struct.pack.__qualname__.__eq__,
       ["Struct.pack"],
       true,
       "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — dotted qualname; len=11; new to extra185"]
    - [pack_qualname_len,
       struct.Struct.pack.__qualname__.__len__,
       [],
       11,
       "struct.Struct.pack.__qualname__.__len__() == 11 — 'Struct.pack' has 11 characters; new to extra185"]
    - [unpack_qualname_eq,
       struct.Struct.unpack.__qualname__.__eq__,
       ["Struct.unpack"],
       true,
       "struct.Struct.unpack.__qualname__.__eq__('Struct.unpack') == True — dotted qualname; len=13; new to extra185"]
    - [unpack_qualname_len,
       struct.Struct.unpack.__qualname__.__len__,
       [],
       13,
       "struct.Struct.unpack.__qualname__.__len__() == 13 — 'Struct.unpack' has 13 characters; new to extra185"]

# ---------------------------------------------------------------------------
# Table 2: struct.Struct method qualnames — pack_into
#
# struct.Struct.pack_into.__qualname__  == 'Struct.pack_into'  (len=16)
#
# pack_into is the mid-length method: 'Struct.' (7) + 'pack_into' (9) = 16.
# ---------------------------------------------------------------------------

table struct_extra185.struct_pack_into_qualname:
  description: "struct.Struct.pack_into __qualname__ identity and length; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: structqualnames185

  columns: [id, function, args, expected, description]
  rows:
    - [pack_into_qualname_eq,
       struct.Struct.pack_into.__qualname__.__eq__,
       ["Struct.pack_into"],
       true,
       "struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into') == True — dotted qualname; len=16; new to extra185"]
    - [pack_into_qualname_len,
       struct.Struct.pack_into.__qualname__.__len__,
       [],
       16,
       "struct.Struct.pack_into.__qualname__.__len__() == 16 — 'Struct.pack_into' has 16 characters; new to extra185"]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct method qualnames — unpack_from and iter_unpack
#
# struct.Struct.unpack_from.__qualname__   == 'Struct.unpack_from'   (len=18)
# struct.Struct.iter_unpack.__qualname__   == 'Struct.iter_unpack'   (len=18)
# struct.Struct.__module__                 == '_struct'
#
# unpack_from and iter_unpack are the longest method qualnames at 18
# characters each: 'Struct.' (7) + 10-character method name + 1 = 18.
# struct.Struct.__module__ reflects the C extension _struct that defines them.
# ---------------------------------------------------------------------------

table struct_extra185.struct_long_qualnames_and_module:
  description: "struct.Struct.unpack_from and iter_unpack qualnames (len=18) and Struct module identity; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: structqualnames185

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_from_qualname_eq,
       struct.Struct.unpack_from.__qualname__.__eq__,
       ["Struct.unpack_from"],
       true,
       "struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') == True — dotted qualname; len=18; new to extra185"]
    - [unpack_from_qualname_len,
       struct.Struct.unpack_from.__qualname__.__len__,
       [],
       18,
       "struct.Struct.unpack_from.__qualname__.__len__() == 18 — 'Struct.unpack_from' has 18 characters; new to extra185"]
    - [iter_unpack_qualname_eq,
       struct.Struct.iter_unpack.__qualname__.__eq__,
       ["Struct.iter_unpack"],
       true,
       "struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack') == True — dotted qualname; len=18; new to extra185"]
    - [iter_unpack_qualname_len,
       struct.Struct.iter_unpack.__qualname__.__len__,
       [],
       18,
       "struct.Struct.iter_unpack.__qualname__.__len__() == 18 — 'Struct.iter_unpack' has 18 characters; new to extra185"]
    - [struct_module_eq,
       struct.Struct.__module__.__eq__,
       ["_struct"],
       true,
       "struct.Struct.__module__.__eq__('_struct') == True — Struct class defined in C extension _struct; new to extra185"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra185
# ---------------------------------------------------------------------------

invariant struct_extra185.pack_qualname_eq:
  description: "struct.Struct.pack.__qualname__ == 'Struct.pack' — dotted qualname; len=11; new to extra185"
  category: identity
  kind: python_call_eq
  function: struct.Struct.pack.__qualname__.__eq__
  args: ["Struct.pack"]
  expected: true

invariant struct_extra185.unpack_qualname_eq:
  description: "struct.Struct.unpack.__qualname__ == 'Struct.unpack' — dotted qualname; len=13; new to extra185"
  category: identity
  kind: python_call_eq
  function: struct.Struct.unpack.__qualname__.__eq__
  args: ["Struct.unpack"]
  expected: true

invariant struct_extra185.pack_into_qualname_eq:
  description: "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into' — dotted qualname; len=16; new to extra185"
  category: identity
  kind: python_call_eq
  function: struct.Struct.pack_into.__qualname__.__eq__
  args: ["Struct.pack_into"]
  expected: true

invariant struct_extra185.unpack_from_qualname_eq:
  description: "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from' — dotted qualname; len=18; new to extra185"
  category: identity
  kind: python_call_eq
  function: struct.Struct.unpack_from.__qualname__.__eq__
  args: ["Struct.unpack_from"]
  expected: true

invariant struct_extra185.iter_unpack_qualname_eq:
  description: "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack' — dotted qualname; len=18; new to extra185"
  category: identity
  kind: python_call_eq
  function: struct.Struct.iter_unpack.__qualname__.__eq__
  args: ["Struct.iter_unpack"]
  expected: true

invariant struct_extra185.struct_module_eq:
  description: "struct.Struct.__module__ == '_struct' — Struct class defined in C extension _struct; new to extra185"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

invariant struct_extra185.pack_qualname_len:
  description: "struct.Struct.pack.__qualname__.__len__() == 11 — 'Struct.pack' has 11 characters; new to extra185"
  category: identity
  kind: python_call_eq
  function: struct.Struct.pack.__qualname__.__len__
  args: []
  expected: 11

invariant struct_extra185.unpack_from_qualname_len:
  description: "struct.Struct.unpack_from.__qualname__.__len__() == 18 — 'Struct.unpack_from' has 18 characters; new to extra185"
  category: identity
  kind: python_call_eq
  function: struct.Struct.unpack_from.__qualname__.__len__
  args: []
  expected: 18
