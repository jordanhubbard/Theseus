spec: uuid_extra44
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra43.zspec.zsdl — covers NAMESPACE_URL/OID/X500 __class__.__name__/__qualname__/__module__.__eq__ string values."
    - "uuid_extra42.zspec.zsdl — covers UUID.time_low/time_mid/clock_seq_low fget.__qualname__.__eq__; getnode/__module__.__eq__; uuid4/getnode/UUID __module__.__class__.__name__.__eq__('str')."
    - "uuid_extra41.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/getnode/module __doc__.__class__.__name__.__eq__('str') and UUID.hex/int/bytes/version fget.__qualname__.__eq__."
    - "uuid_extra40.zspec.zsdl — covers UUID.hex/int/bytes/version/urn/variant/node/time/is_safe __class__.__qualname__.__eq__('property') and __class__.__qualname__.__len__()==8."
    - "uuid_extra39.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/NAMESPACE_DNS __class__.__qualname__.__eq__ and __class__.__module__.__eq__."
    - "uuid_extra38.zspec.zsdl — covers UUID/__class__.__name__.__eq__('type'), uuid4/uuid1/uuid3/uuid5/NAMESPACE_DNS/getnode.__class__.__name__.__eq__, UUID.time.fget.__class__.__name__.__eq__('function')."
    - "uuid_extra36.zspec.zsdl — covers UUID.__repr__/__hash__/__eq__/__int__/__lt__/__le__/__gt__/__ge__ __module__.__eq__('uuid')."
    - "uuid_extra35.zspec.zsdl — covers UUID.__init__/__repr__/__hash__/__eq__/__int__/__lt__/__le__/__gt__/__ge__ __name__.__eq__ (bare unqualified names)."
    - "uuid_extra16.zspec.zsdl — covers UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__ __qualname__.__eq__ and __qualname__.__len__()."
  notes:
    - "This spec extends uuid through uuid_extra43; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: No prior uuid spec checks __class__.__name__.__len__() for NAMESPACE_URL, NAMESPACE_OID, or NAMESPACE_X500. uuid_extra43 checks __class__.__name__.__eq__('UUID') for these three constants (the value axis). uuid_extra12 and uuid_extra23 cover NAMESPACE_DNS/URL __class__.__name__.__len__()==4 but NOT NAMESPACE_OID or NAMESPACE_X500. All four NAMESPACE_* constants are UUID instances; uuid.UUID.__name__ is 'UUID' (4 chars). OID and X500 are novel on the __len__ axis. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.__class__.__name__.__len__() == 4. NAMESPACE_OID is a UUID instance; UUID.__name__ is 'UUID' (4 chars). uuid_extra23 covers NAMESPACE_DNS/URL __class__.__name__.__len__() but NOT OID. No prior spec checks NAMESPACE_OID.__class__.__name__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.__class__.__name__.__len__() == 4. NAMESPACE_X500 is a UUID instance; UUID.__name__ is 'UUID' (4 chars). No prior spec checks NAMESPACE_X500.__class__.__name__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior uuid spec checks __class__.__qualname__.__len__() for NAMESPACE_URL, NAMESPACE_OID, or NAMESPACE_X500. uuid_extra43 checks __class__.__qualname__.__eq__('UUID') (the value axis). uuid_extra27 checks NAMESPACE_URL.__class__.__qualname__.__len__() for URL only. OID and X500 are novel on this __len__ axis. For non-nested classes, __qualname__ == __name__, so len == 4 for all. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.__class__.__qualname__.__len__() == 4. NAMESPACE_OID is a UUID instance; UUID.__qualname__ == 'UUID' (4 chars). uuid_extra27 covers NAMESPACE_URL.__class__.__qualname__.__len__()==4 but NOT OID. No prior spec checks NAMESPACE_OID.__class__.__qualname__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.__class__.__qualname__.__len__() == 4. NAMESPACE_X500 is a UUID instance; UUID.__qualname__ == 'UUID' (4 chars). No prior spec checks NAMESPACE_X500.__class__.__qualname__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior uuid spec checks the module-level __name__ attribute of the uuid module itself. uuid_extra25 checks uuid.__spec__.__name__.__len__()==4 (the spec import machinery attribute, not the module's own __name__). uuid_extra30 checks UUID.__name__=='UUID' (the class __name__) and uuid4/__name__.__eq__ (function __name__). But the module's own __name__ — uuid.__name__ == 'uuid' — has never been checked as a string equality value. Under python_module(uuid), function: __name__.__eq__ resolves to uuid.__name__.__eq__('uuid'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.__name__ == 'uuid'. The module's own __name__ attribute (not UUID.__name__, not function __name__, not __spec__.__name__). No prior uuid spec checks the module's own __name__.__eq__('uuid'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.__name__.__len__() == 4. len('uuid') == 4. Complementary length check. Note: uuid_extra25 covers uuid.__spec__.__name__.__len__()==4 (a different chain through __spec__); no prior spec checks the module's own __name__.__len__() directly. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_OID / NAMESPACE_X500 __class__.__name__.__len__()
#
# uuid_extra43 checks __class__.__name__.__eq__('UUID') for OID and X500
#   (the value axis). uuid_extra12 and uuid_extra23 cover NAMESPACE_DNS/URL
#   __class__.__name__.__len__()==4 but NOT NAMESPACE_OID or NAMESPACE_X500.
# All NAMESPACE_* constants are UUID instances; len('UUID') == 4.
# The __len__() axis is independent from __eq__: it provides a length
# regression vector that detects class renames regardless of the exact name.
# ---------------------------------------------------------------------------

table uuid_extra44.namespace_class_name_lengths:
  description: "uuid.NAMESPACE_OID/X500 __class__.__name__.__len__()==4 — len('UUID')==4; uuid_extra43 checks __class__.__name__.__eq__('UUID') for OID/X500 (value axis); uuid_extra12/23 cover DNS/URL __class__.__name__.__len__ but NOT OID or X500; no prior spec checks __class__.__name__.__len__() for NAMESPACE_OID or NAMESPACE_X500"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidmeth44

  columns: [id, function, args, expected]
  rows:
    - [NAMESPACE_OID_class_name_len,  NAMESPACE_OID.__class__.__name__.__len__,  [], 4]
    - [NAMESPACE_X500_class_name_len, NAMESPACE_X500.__class__.__name__.__len__, [], 4]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_OID / NAMESPACE_X500 __class__.__qualname__.__len__()
#
# uuid_extra43 checks __class__.__qualname__.__eq__('UUID') for OID and X500
#   (the value axis). uuid_extra27 checks NAMESPACE_URL.__class__.__qualname__.__len__()
#   but NOT NAMESPACE_OID or NAMESPACE_X500. For non-nested classes,
#   __qualname__ == __name__, so len('UUID') == 4.
# The __qualname__.__len__() axis is independent from __qualname__.__eq__:
# it provides a length regression vector distinct from the string equality check.
# ---------------------------------------------------------------------------

table uuid_extra44.namespace_class_qualname_lengths:
  description: "uuid.NAMESPACE_OID/X500 __class__.__qualname__.__len__()==4 — len('UUID')==4; uuid_extra43 checks __class__.__qualname__.__eq__('UUID') for OID/X500 (value axis); uuid_extra27 covers NAMESPACE_URL __class__.__qualname__.__len__ but NOT OID or X500; no prior spec checks __class__.__qualname__.__len__() for NAMESPACE_OID or NAMESPACE_X500"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidmeth44

  columns: [id, function, args, expected]
  rows:
    - [NAMESPACE_OID_class_qualname_len,  NAMESPACE_OID.__class__.__qualname__.__len__,  [], 4]
    - [NAMESPACE_X500_class_qualname_len, NAMESPACE_X500.__class__.__qualname__.__len__, [], 4]

# ---------------------------------------------------------------------------
# uuid module-level __name__ attribute
#
# No prior uuid spec checks the module's own __name__ attribute as a string
# equality value. uuid_extra25 checks uuid.__spec__.__name__.__len__()==4
#   (via import machinery, a different chain). uuid_extra30 checks
#   UUID.__name__=='UUID' (the class's __name__, not the module's).
# Under python_module(uuid), function: __name__.__eq__ resolves to
# uuid.__name__.__eq__('uuid'). The __len__ check is an independent
# regression vector: len('uuid') == 4.
# ---------------------------------------------------------------------------

invariant uuid_extra44.module.name_eq:
  description: "uuid.__name__ == 'uuid' — the module's own __name__ attribute; distinct from UUID.__name__ (class), uuid4.__name__ (function), and uuid.__spec__.__name__ (import machinery); no prior uuid spec checks the module object's own __name__.__eq__('uuid')"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra44.module.name_len:
  description: "uuid.__name__.__len__() == 4 — len('uuid') == 4; complementary length check on the module's own __name__; uuid_extra25 covers uuid.__spec__.__name__.__len__()==4 (different chain through __spec__); no prior spec checks the module's own __name__.__len__() directly"
  category: module_identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 4
