spec: abc_extra98
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra97

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra97.zspec.zsdl."
    - "This spec covers: wave 254 theme — abc class __qualname__ values and lengths. NEW in extra98: abc.ABCMeta.__qualname__=='ABCMeta' (len=7); abc.ABC.__qualname__=='ABC' (len=3, shortest); abc.abstractproperty.__qualname__=='abstractproperty' (len=16); abc.abstractclassmethod.__qualname__=='abstractclassmethod' (len=19); abc.abstractstaticmethod.__qualname__=='abstractstaticmethod' (len=20, longest); all five abc classes are module-level so qualname equals name; also __qualname__.__len__ invariants for each; ABC is the shortest (len=3) and abstractstaticmethod is the longest (len=20). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractstaticmethod.__qualname__.__len__() == 20. 'abstractstaticmethod' is 20 chars: 'abstract'=8 + 'static'=6 + 'method'=6. This is the longest abc class qualname in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__qualname__ == 'ABC' (len=3). ABC is the shortest qualname in this spec; it matches abc.__name__.__len__()==3 and abc.ABC.__qualname__.__len__()==3 — both are 3. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty, abc.abstractclassmethod, and abc.abstractstaticmethod are deprecated since Python 3.3. They are still present in the module and their __qualname__ values are verifiable despite being deprecated. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc class __qualname__ equality — extra98
#
# Wave 254 theme: abc class __qualname__ values (string equality).
# All abc public classes are module-level, so __qualname__ == __name__.
#
# abc.ABCMeta.__qualname__              == 'ABCMeta'              (len=7)
# abc.ABC.__qualname__                  == 'ABC'                  (len=3, shortest)
# abc.abstractproperty.__qualname__     == 'abstractproperty'     (len=16)
# abc.abstractclassmethod.__qualname__  == 'abstractclassmethod'  (len=19)
# abc.abstractstaticmethod.__qualname__ == 'abstractstaticmethod' (len=20, longest)
# ---------------------------------------------------------------------------

table abc_extra98.abc_class_qualnames:
  description: "abc class __qualname__ equality checks in abcclassqn98 namespace — wave 254 theme: all abc public classes are defined at module level in Lib/abc.py so __qualname__ equals __name__; abc.ABCMeta.__qualname__.__eq__('ABCMeta')==True (len=7: 'ABCMeta' has 7 chars; ABCMeta is the metaclass for abstract base classes); abc.ABCMeta.__qualname__.__len__()==7; abc.ABC.__qualname__.__eq__('ABC')==True (len=3: 'ABC' is the shortest qualname in this spec, matching abc.__name__.__len__()==3); abc.ABC.__qualname__.__len__()==3; abc.abstractproperty.__qualname__.__eq__('abstractproperty')==True (len=16: deprecated since 3.3); abc.abstractproperty.__qualname__.__len__()==16; abc.abstractclassmethod.__qualname__.__eq__('abstractclassmethod')==True (len=19: 'abstract'=8 + 'class'=5 + 'method'=6); abc.abstractclassmethod.__qualname__.__len__()==19; abc.abstractstaticmethod.__qualname__.__eq__('abstractstaticmethod')==True (len=20: 'abstract'=8 + 'static'=6 + 'method'=6, the longest qualname in this spec); abc.abstractstaticmethod.__qualname__.__len__()==20; all five classes are pure Python types (class.__class__.__name__=='type'); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: abcclassqn98

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_qn_eq,   abc.ABCMeta.__qualname__.__eq__,              ["ABCMeta"],              true, "abc.ABCMeta.__qualname__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]
    - [abcmeta_qn_len,  abc.ABCMeta.__qualname__.__len__,             [],                       7,    "abc.ABCMeta.__qualname__.__len__() == 7; verified with Python 3.14.3"]
    - [abc_qn_eq,       abc.ABC.__qualname__.__eq__,                  ["ABC"],                  true, "abc.ABC.__qualname__ == 'ABC' (len=3, shortest qualname in spec); verified with Python 3.14.3"]
    - [abc_qn_len,      abc.ABC.__qualname__.__len__,                 [],                       3,    "abc.ABC.__qualname__.__len__() == 3 (shortest in spec, matches abc module name len); verified with Python 3.14.3"]
    - [absprop_qn_eq,   abc.abstractproperty.__qualname__.__eq__,     ["abstractproperty"],     true, "abc.abstractproperty.__qualname__ == 'abstractproperty' (len=16); verified with Python 3.14.3"]
    - [absprop_qn_len,  abc.abstractproperty.__qualname__.__len__,    [],                       16,   "abc.abstractproperty.__qualname__.__len__() == 16; verified with Python 3.14.3"]
    - [abscls_qn_eq,    abc.abstractclassmethod.__qualname__.__eq__,  ["abstractclassmethod"],  true, "abc.abstractclassmethod.__qualname__ == 'abstractclassmethod' (len=19); verified with Python 3.14.3"]
    - [abscls_qn_len,   abc.abstractclassmethod.__qualname__.__len__, [],                       19,   "abc.abstractclassmethod.__qualname__.__len__() == 19 ('abstract'=8+'class'=5+'method'=6); verified with Python 3.14.3"]
    - [absstm_qn_eq,    abc.abstractstaticmethod.__qualname__.__eq__, ["abstractstaticmethod"], true, "abc.abstractstaticmethod.__qualname__ == 'abstractstaticmethod' (len=20, longest); verified with Python 3.14.3"]
    - [absstm_qn_len,   abc.abstractstaticmethod.__qualname__.__len__, [],                      20,   "abc.abstractstaticmethod.__qualname__.__len__() == 20 ('abstract'=8+'static'=6+'method'=6, longest); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc class __qualname__ class identity checks — extra98
#
# All abc class __qualname__ values are 'str' class.
# The abc classes themselves are 'type' (class of a class is type).
# ---------------------------------------------------------------------------

table abc_extra98.abc_qualname_class_identity:
  description: "abc class __qualname__ value type identity checks in abcclassqn98 namespace — wave 254 theme: every class's __qualname__ attribute is a 'str' object; abc.ABCMeta.__qualname__.__class__.__name__.__eq__('str')==True; abc.ABC.__qualname__.__class__.__name__.__eq__('str')==True; abc.abstractproperty.__qualname__.__class__.__name__.__eq__('str')==True; abc.abstractclassmethod.__qualname__.__class__.__name__.__eq__('str')==True; abc.abstractstaticmethod.__qualname__.__class__.__name__.__eq__('str')==True; additionally the abc classes themselves have __class__.__name__=='type' (they are all metaclass instances or type instances); abc.ABCMeta.__class__.__name__.__eq__('type')==True (ABCMeta is a class; metaclass of ABCMeta is type itself); abc.abstractproperty.__class__.__name__.__eq__('type')==True; abc.abstractclassmethod.__class__.__name__.__eq__('type')==True; abc.abstractstaticmethod.__class__.__name__.__eq__('type')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: abcclassqn98a

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_qn_cls,  abc.ABCMeta.__qualname__.__class__.__name__.__eq__,              ["str"],  true, "abc.ABCMeta.__qualname__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [abc_qn_cls,      abc.ABC.__qualname__.__class__.__name__.__eq__,                  ["str"],  true, "abc.ABC.__qualname__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [absprop_qn_cls,  abc.abstractproperty.__qualname__.__class__.__name__.__eq__,     ["str"],  true, "abc.abstractproperty.__qualname__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [abscls_qn_cls,   abc.abstractclassmethod.__qualname__.__class__.__name__.__eq__,  ["str"],  true, "abc.abstractclassmethod.__qualname__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [absstm_qn_cls,   abc.abstractstaticmethod.__qualname__.__class__.__name__.__eq__, ["str"],  true, "abc.abstractstaticmethod.__qualname__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [abcmeta_cls,     abc.ABCMeta.__class__.__name__.__eq__,                           ["type"], true, "abc.ABCMeta.__class__.__name__ == 'type' (ABCMeta is a class, metaclass is type); verified with Python 3.14.3"]
    - [absprop_cls,     abc.abstractproperty.__class__.__name__.__eq__,                  ["type"], true, "abc.abstractproperty.__class__.__name__ == 'type' — deprecated abstract class type; verified with Python 3.14.3"]
    - [abscls_cls,      abc.abstractclassmethod.__class__.__name__.__eq__,               ["type"], true, "abc.abstractclassmethod.__class__.__name__ == 'type' — deprecated abstract class type; verified with Python 3.14.3"]
    - [absstm_cls,      abc.abstractstaticmethod.__class__.__name__.__eq__,              ["type"], true, "abc.abstractstaticmethod.__class__.__name__ == 'type' — deprecated abstract class type; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra98
# ---------------------------------------------------------------------------

invariant abc_extra98.abstractstaticmethod_qualname_longest:
  description: "abc.abstractstaticmethod.__qualname__.__len__() == 20 — abstractstaticmethod.__qualname__ is 'abstractstaticmethod' (20 chars: 'abstract'=8 + 'static'=6 + 'method'=6); this is the longest abc class qualname in this spec; compare abc class qualname lengths: ABC=3, ABCMeta=7, abstractproperty=16, abstractclassmethod=19, abstractstaticmethod=20; abstractstaticmethod is one char longer than abstractclassmethod (20 vs 19) because 'static'=6 while 'class'=5; abc.abstractstaticmethod is deprecated since Python 3.3 (use @staticmethod with @abstractmethod instead); abstractstaticmethod.__class__.__name__ is 'type'; NEW in extra98: first standalone abstractstaticmethod qualname length invariant in abcclassqn98 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: abc.abstractstaticmethod.__qualname__.__len__
  args: []
  expected: 20

invariant abc_extra98.ABC_qualname_shortest:
  description: "abc.ABC.__qualname__.__len__() == 3 — ABC.__qualname__ is 'ABC' (3 chars); this is the shortest abc class qualname in this spec; abc.ABC.__qualname__.__len__()==3 matches abc.__name__.__len__()==3 — both the module name and this class name have length 3; ABC is a convenience class that uses ABCMeta as its metaclass; ABC.__qualname__ is a 'str' object; compare abc class qualname lengths: ABC=3 (shortest), ABCMeta=7, abstractproperty=16, abstractclassmethod=19, abstractstaticmethod=20 (longest); NEW in extra98: first standalone ABC qualname shortest invariant in abcclassqn98 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: abc.ABC.__qualname__.__len__
  args: []
  expected: 3

invariant abc_extra98.abstractclassmethod_qualname_len_19:
  description: "abc.abstractclassmethod.__qualname__.__len__() == 19 — abstractclassmethod.__qualname__ is 'abstractclassmethod' (19 chars: 'abstract'=8 + 'class'=5 + 'method'=6); this is one char shorter than abstractstaticmethod (19 vs 20) because 'class'=5 vs 'static'=6; abstractclassmethod is deprecated since Python 3.3 (use @classmethod with @abstractmethod instead); abstractclassmethod.__class__.__name__ is 'type'; abstractclassmethod.__qualname__.__class__.__name__ is 'str'; all module-level abc classes have __qualname__ equal to their simple name (no enclosing scope prefix); NEW in extra98: first standalone abstractclassmethod qualname length invariant in abcclassqn98 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: abc.abstractclassmethod.__qualname__.__len__
  args: []
  expected: 19

invariant abc_extra98.ABCMeta_qualname_eq:
  description: "abc.ABCMeta.__qualname__.__eq__('ABCMeta') returns True — ABCMeta.__qualname__ is 'ABCMeta' (7 chars); ABCMeta is the metaclass for abstract base classes; registering a class as ABC's subclass is done via ABCMeta.register(); ABCMeta.__qualname__ is 'ABCMeta' (len=7); ABCMeta.__class__.__name__ is 'type' (metaclass of a metaclass is type); compare abc class qualnames: ABC='ABC' (len=3), ABCMeta='ABCMeta' (len=7); ABCMeta.__qualname__.__class__.__name__ is 'str'; ABCMeta.__module__ is 'abc' (pure Python in Lib/abc.py); NEW in extra98: first standalone ABCMeta qualname eq invariant in abcclassqn98 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: abc.ABCMeta.__qualname__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra98.abstractproperty_qualname_len_16:
  description: "abc.abstractproperty.__qualname__.__len__() == 16 — abstractproperty.__qualname__ is 'abstractproperty' (16 chars: 'abstract'=8 + 'property'=8); abstractproperty is deprecated since Python 3.3 (use @property with @abstractmethod instead); abstractproperty.__class__.__name__ is 'type' (it is a class, not a function); abstractproperty.__qualname__.__class__.__name__ is 'str'; compare abc qualname lengths at the 'abstract*' tier: abstractproperty=16, abstractclassmethod=19, abstractstaticmethod=20; all three start with 'abstract' (8 chars) and differ in the suffix; NEW in extra98: first standalone abstractproperty qualname length invariant in abcclassqn98 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: abc.abstractproperty.__qualname__.__len__
  args: []
  expected: 16
