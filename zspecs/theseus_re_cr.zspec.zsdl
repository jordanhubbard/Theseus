spec: theseus_re_cr
version: ">=3.0"
backend: python_cleanroom(theseus_re_cr)
blocks: re

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "Clean-room re module. Do NOT import re."

error_model: python_exceptions

invariant theseus_re_cr.re2_compile:
  description: "compile() and match() work correctly"
  category: behavior
  kind: python_call_eq
  function: re2_compile
  args: []
  expected: true

invariant theseus_re_cr.re2_findall:
  description: "findall() returns all matches"
  category: behavior
  kind: python_call_eq
  function: re2_findall
  args: []
  expected: true

invariant theseus_re_cr.re2_sub:
  description: "sub() performs substitutions"
  category: behavior
  kind: python_call_eq
  function: re2_sub
  args: []
  expected: true
