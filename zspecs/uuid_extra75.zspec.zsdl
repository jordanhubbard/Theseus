spec: uuid_extra75
version: ">=3.9"
extends: uuid_extra74
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra74.zspec.zsdl — covers UUID property descriptor __qualname__ identity (hex/urn/version/bytes/bytes_le/fields/node/time/time_hi_version/time_low/time_mid/clock_seq_hi_variant/clock_seq_low) and UUID.int member_descriptor __qualname__ (table + invariants)."
    - "uuid_extra73.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 qualname lengths / UUID.__dict__ special method membership (__repr__/__hash__/__eq__/__lt__) / UUID.__dict__ property membership (bytes_le/node/time) and mappingproxy class name (table + invariants)."
    - "uuid_extra72.zspec.zsdl — covers NAMESPACE_DNS/URL/OID/X500 __class__.__name__/__module__/__qualname__ / UUID/__name__/__module__/__qualname__/__bases__[0].__name__ / SafeUUID identity (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra74; it does NOT duplicate invariants present in those files."
    - "Wave 250 theme: uuid SafeUUID enum members identity — __class__.__name__/'SafeUUID', __class__.__qualname__/'SafeUUID', value/__class__/__name__/'int', SafeUUID class __name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__()/__qualname__.__len__()/__name__.__len__()."
    - "uuid.SafeUUID.safe.__class__.__name__ == 'SafeUUID' — safe is a SafeUUID enum member with value 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.unsafe.__class__.__name__ == 'SafeUUID' — unsafe is a SafeUUID enum member with value -1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.unknown.__class__.__name__ == 'SafeUUID' — unknown is a SafeUUID enum member with value None. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.safe.__class__.__qualname__ == 'SafeUUID' — __qualname__ matches the class name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.safe.value.__class__.__name__ == 'int' — the .value of SafeUUID.safe (0) is an int. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.unsafe.value.__class__.__name__ == 'int' — the .value of SafeUUID.unsafe (-1) is an int. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__name__ == 'SafeUUID' — class name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__module__ == 'uuid' — SafeUUID lives in the uuid module. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__qualname__ == 'SafeUUID' — qualified name equals class name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' — SafeUUID directly subclasses Enum. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__mro__.__len__() == 3 — MRO is [SafeUUID, Enum, object]. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__qualname__.__len__() == 8 — 'SafeUUID' is 8 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__name__.__len__() == 8 — 'SafeUUID' is 8 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.SafeUUID.safe/__class__/__name__ / SafeUUID.unsafe/__class__/__name__
# uuid.SafeUUID.unknown/__class__/__name__ / SafeUUID.safe/__class__/__qualname__
#
# Wave 250 theme: SafeUUID enum member __class__.__name__ and __class__.__qualname__.
#
# safe, unsafe, unknown are all SafeUUID enum members.
# Their __class__.__name__ and __class__.__qualname__ both equal 'SafeUUID'.
# No prior uuid spec checks __class__.__name__ or __class__.__qualname__ for
# SafeUUID enum members. uuid_extra72 covers SafeUUID class-level identity
# but not its member-level __class__ attributes.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra75.safeuuid_member_class_names:
  description: "uuid.SafeUUID.safe/__class__/__name__.__eq__('SafeUUID')==True / SafeUUID.unsafe/__class__/__name__.__eq__('SafeUUID')==True / SafeUUID.unknown/__class__/__name__.__eq__('SafeUUID')==True / SafeUUID.safe/__class__/__qualname__.__eq__('SafeUUID')==True — safe/unsafe/unknown are all SafeUUID enum members; their __class__.__name__ and __class__.__qualname__ both equal 'SafeUUID'; no prior uuid spec checks __class__.__name__ or __class__.__qualname__ for SafeUUID enum members; first member-level class identity anchor for uuid.SafeUUID"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra75

  columns: [id, function, args, expected]
  rows:
    - [safeuuid_safe_class_name,     SafeUUID.safe.__class__.__name__.__eq__,     ["SafeUUID"], true]
    - [safeuuid_unsafe_class_name,   SafeUUID.unsafe.__class__.__name__.__eq__,   ["SafeUUID"], true]
    - [safeuuid_unknown_class_name,  SafeUUID.unknown.__class__.__name__.__eq__,  ["SafeUUID"], true]
    - [safeuuid_safe_class_qualname, SafeUUID.safe.__class__.__qualname__.__eq__, ["SafeUUID"], true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.safe/value/__class__/__name__ / SafeUUID.unsafe/value/__class__/__name__
# uuid.SafeUUID.unsafe/__class__/__qualname__ / SafeUUID.unknown/__class__/__qualname__
#
# Wave 250 theme: SafeUUID member value type and __class__.__qualname__ for unsafe/unknown.
#
# SafeUUID.safe.value is 0 (an int); SafeUUID.unsafe.value is -1 (an int).
# SafeUUID.unsafe.__class__.__qualname__ == 'SafeUUID'.
# SafeUUID.unknown.__class__.__qualname__ == 'SafeUUID'.
# No prior uuid spec checks value.__class__.__name__ or __class__.__qualname__
# for SafeUUID enum members. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra75.safeuuid_value_types_and_qualnames:
  description: "uuid.SafeUUID.safe/value/__class__/__name__.__eq__('int')==True / SafeUUID.unsafe/value/__class__/__name__.__eq__('int')==True / SafeUUID.unsafe/__class__/__qualname__.__eq__('SafeUUID')==True / SafeUUID.unknown/__class__/__qualname__.__eq__('SafeUUID')==True — safe.value (0) and unsafe.value (-1) are both int objects; unsafe and unknown also have __class__.__qualname__=='SafeUUID'; no prior uuid spec checks value.__class__.__name__ for SafeUUID members; first value-type and qualname anchor for uuid.SafeUUID members"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra75

  columns: [id, function, args, expected]
  rows:
    - [safeuuid_safe_value_class_int,     SafeUUID.safe.value.__class__.__name__.__eq__,     ["int"],       true]
    - [safeuuid_unsafe_value_class_int,   SafeUUID.unsafe.value.__class__.__name__.__eq__,   ["int"],       true]
    - [safeuuid_unsafe_class_qualname,    SafeUUID.unsafe.__class__.__qualname__.__eq__,     ["SafeUUID"],  true]
    - [safeuuid_unknown_class_qualname,   SafeUUID.unknown.__class__.__qualname__.__eq__,    ["SafeUUID"],  true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID/__name__ / SafeUUID/__module__ / SafeUUID/__qualname__
# uuid.SafeUUID/__bases__[0]/__name__
#
# Wave 250 theme: SafeUUID class-level __name__/__module__/__qualname__/__bases__.
#
# SafeUUID.__name__ == 'SafeUUID', __module__ == 'uuid', __qualname__ == 'SafeUUID'.
# SafeUUID.__bases__[0].__name__ == 'Enum'.
# No prior uuid spec checks __name__/__eq__, __module__/__eq__, __qualname__/__eq__,
# or __bases__[0].__name__.__eq__ for SafeUUID as eq-calls.
# uuid_extra72 covers SafeUUID identity but as table identity columns, not __eq__ calls.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra75.safeuuid_class_attrs_eq:
  description: "uuid.SafeUUID/__name__.__eq__('SafeUUID')==True / SafeUUID/__module__.__eq__('uuid')==True / SafeUUID/__qualname__.__eq__('SafeUUID')==True / SafeUUID/__bases__[0]/__name__.__eq__('Enum')==True — SafeUUID is an Enum subclass living in the uuid module; __name__/__module__/__qualname__ all have canonical values; __bases__[0] is Enum; no prior uuid spec checks these as __eq__ calls for SafeUUID; first __name__/__module__/__qualname__/__bases__ eq-call anchor for uuid.SafeUUID"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra75

  columns: [id, function, args, expected]
  rows:
    - [safeuuid_name_eq,        SafeUUID.__name__.__eq__,                  ["SafeUUID"], true]
    - [safeuuid_module_eq_uuid, SafeUUID.__module__.__eq__,                ["uuid"],     true]
    - [safeuuid_qualname_eq,    SafeUUID.__qualname__.__eq__,              ["SafeUUID"], true]
    - [safeuuid_bases0_enum,    "SafeUUID.__bases__[0].__name__.__eq__",   ["Enum"],     true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID/__mro__/__len__() / SafeUUID/__qualname__/__len__()
# uuid.SafeUUID/__name__/__len__() / SafeUUID/__module__/__len__()
#
# Wave 250 theme: SafeUUID class string length cross-checks.
#
# SafeUUID.__mro__.__len__() == 3 (SafeUUID, Enum, object).
# SafeUUID.__qualname__.__len__() == 8 ('SafeUUID' is 8 chars).
# SafeUUID.__name__.__len__() == 8 ('SafeUUID' is 8 chars).
# SafeUUID.__module__.__len__() == 4 ('uuid' is 4 chars).
# No prior uuid spec checks these __len__() values for SafeUUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra75.safeuuid_lengths:
  description: "uuid.SafeUUID/__mro__/__len__()==3 / SafeUUID/__qualname__/__len__()==8 / SafeUUID/__name__/__len__()==8 / SafeUUID/__module__/__len__()==4 — SafeUUID MRO is [SafeUUID, Enum, object] (3 entries); 'SafeUUID' is 8 characters; 'uuid' module name is 4 characters; no prior uuid spec checks these __len__() values for SafeUUID; first MRO length and string length anchor for uuid.SafeUUID"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra75

  columns: [id, function, args, expected]
  rows:
    - [safeuuid_mro_len_3,        SafeUUID.__mro__.__len__,      [], 3]
    - [safeuuid_qualname_len_8,   SafeUUID.__qualname__.__len__,  [], 8]
    - [safeuuid_name_len_8,       SafeUUID.__name__.__len__,      [], 8]
    - [safeuuid_module_len_4,     SafeUUID.__module__.__len__,    [], 4]

