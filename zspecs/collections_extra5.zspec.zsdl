spec: collections_extra5
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends prior collections specs."
    - "Focus: Counter, defaultdict, OrderedDict, deque, ChainMap behavior."
    - "collections.Counter('aabb').most_common(1) == [('a', 2)] or [('b', 2)] — nondeterministic for equal counts, so we test the structure."
    - "collections.Counter('abc')['a'] == 1."
    - "collections.Counter('aab')['a'] == 2."
    - "collections.defaultdict(list).__class__.__name__ == 'defaultdict'."
    - "collections.defaultdict(int)['missing'] == 0 — default_factory called for missing key."
    - "collections.OrderedDict.__name__ == 'OrderedDict'."
    - "collections.deque([1,2,3]).maxlen is None (default)."
    - "collections.deque([1,2,3], maxlen=5).maxlen == 5."
    - "collections.ChainMap.__name__ == 'ChainMap'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table collections_extra5.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Counter,     Counter.__name__.__eq__,     ["Counter"],     true]
    - [defaultdict, defaultdict.__name__.__eq__, ["defaultdict"], true]
    - [OrderedDict, OrderedDict.__name__.__eq__, ["OrderedDict"], true]
    - [ChainMap,    ChainMap.__name__.__eq__,    ["ChainMap"],    true]
    - [UserDict,    UserDict.__name__.__eq__,    ["UserDict"],    true]
    - [UserList,    UserList.__name__.__eq__,    ["UserList"],    true]
    - [UserString,  UserString.__name__.__eq__,  ["UserString"],  true]

table collections_extra5.class_modules:
  kind: python_call_eq
  category: module
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Counter,     Counter.__module__.__eq__,     ["collections"], true]
    - [defaultdict, defaultdict.__module__.__eq__, ["collections"], true]
    - [OrderedDict, OrderedDict.__module__.__eq__, ["collections"], true]
    - [ChainMap,    ChainMap.__module__.__eq__,    ["collections"], true]
    - [UserDict,    UserDict.__module__.__eq__,    ["collections"], true]

invariant collections_extra5.Counter.single_char:
  description: "collections.Counter('aab')['a'] == 2"
  category: Counter
  kind: python_call_eq
  function: Counter
  args: ["aab"]
  method: __getitem__
  method_args: ["a"]
  expected: 2

invariant collections_extra5.Counter.b_count:
  description: "collections.Counter('aab')['b'] == 1"
  category: Counter
  kind: python_call_eq
  function: Counter
  args: ["aab"]
  method: __getitem__
  method_args: ["b"]
  expected: 1

invariant collections_extra5.Counter.missing_is_zero:
  description: "collections.Counter('aab')['z'] == 0 — missing key returns 0"
  category: Counter
  kind: python_call_eq
  function: Counter
  args: ["aab"]
  method: __getitem__
  method_args: ["z"]
  expected: 0

invariant collections_extra5.Counter.class_name:
  description: "collections.Counter('aab').__class__.__name__ == 'Counter'"
  category: Counter
  kind: python_call_eq
  function: Counter
  args: ["aab"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Counter"]
  expected: true

invariant collections_extra5.deque.class_name:
  description: "collections.deque([1,2,3]).__class__.__name__ == 'deque'"
  category: deque
  kind: python_call_eq
  function: deque
  args: [[1, 2, 3]]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["deque"]
  expected: true

invariant collections_extra5.deque.maxlen_default:
  description: "collections.deque([1,2,3]).maxlen is None"
  category: deque
  kind: python_call_eq
  function: deque
  args: [[1, 2, 3]]
  method: maxlen.__class__
  method_chain: __name__.__eq__
  method_chain_args: ["NoneType"]
  expected: true

invariant collections_extra5.deque.length:
  description: "len(collections.deque([1,2,3])) == 3"
  category: deque
  kind: python_call_eq
  function: deque
  args: [[1, 2, 3]]
  method: __len__
  method_args: []
  expected: 3
