    - [fu1336cp002, functools.cached_property.__eq__.__qualname__.__eq__,               ["object.__eq__"],       true]
    - [fu1336cp003, functools.singledispatchmethod.__hash__.__class__.__name__.__eq__,  ["wrapper_descriptor"],  true]
    - [fu1336cp004, functools.singledispatchmethod.__hash__.__qualname__.__eq__,        ["object.__hash__"],     true]
    - [fu1336cp005, functools.singledispatchmethod.__eq__.__class__.__name__.__eq__,    ["wrapper_descriptor"],  true]
    - [fu1336cp006, functools.singledispatchmethod.__eq__.__qualname__.__eq__,          ["object.__eq__"],       true]

