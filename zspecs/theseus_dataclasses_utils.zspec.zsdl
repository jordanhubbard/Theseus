spec: theseus_dataclasses_utils
version: ">=3.9"
backend: python_cleanroom(theseus_dataclasses_utils)
blocks: dataclasses

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html"
  notes:
    - "Clean-room dataclass decorator. Do NOT import dataclasses."
    - "@dataclass generates __init__, __repr__, __eq__ from class annotations."
    - "dataclass_init(): @dataclass class Point with x, y fields; Point(1, 2).x == 1."
    - "dataclass_repr(): repr(Point(1,2)) contains 'Point' and field values."
    - "dataclass_eq(): Point(1,2) == Point(1,2) and Point(1,2) != Point(3,4)."
    - "Export: dataclass decorator, field(default=..., default_factory=...), asdict(obj)."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_dataclasses_utils.init:
  description: "@dataclass Point(1,2).x == 1"
  category: init
  kind: python_call_eq
  function: dataclass_init
  args: []
  expected: 1

invariant theseus_dataclasses_utils.eq:
  description: "Point(1,2) == Point(1,2)"
  category: eq
  kind: python_call_eq
  function: dataclass_eq
  args: []
  expected: true

invariant theseus_dataclasses_utils.repr:
  description: "repr(Point(1,2)) contains 'Point'"
  category: repr
  kind: python_call_eq
  function: dataclass_repr_has_name
  args: []
  expected: true
