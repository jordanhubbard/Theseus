spec: abc_extra180
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "abc.ABCMeta method name lengths: __new__=7, register=8, __init__=8, _dump_registry=14, __instancecheck__=17, __subclasscheck__=17."
    - "abc.ABCMeta has no _abc_registry attribute; _abc_caches_clear and _abc_registry_clear are available instead."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta is a metaclass inheriting from type."
    - "Length ordering: __new__(7) < register(8)==__init__(8) < _dump_registry(14) < __instancecheck__(17)==__subclasscheck__(17)."
    - "__instancecheck__ and __subclasscheck__ are the longest method names on ABCMeta (both len=17)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABCMeta short method name lengths
#
# abc.ABCMeta.__new__.__name__.__len__() == 7
# abc.ABCMeta.register.__name__.__len__() == 8
# abc.ABCMeta.__init__.__name__.__len__() == 8
# register and __init__ are tied at 8; __new__ is shortest at 7
# ---------------------------------------------------------------------------

table abc_extra180.short_method_name_lengths:
  description: "abc.ABCMeta short method name lengths: __new__=7, register=8, __init__=8; __new__(7) < register(8)==__init__(8); new to abc_extra180"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetamethods180

  columns: [id, function, args, expected, description]
  rows:
    - [new_name_len_7,
       ABCMeta.__new__.__name__.__len__,
       [],
       7,
       "abc.ABCMeta.__new__.__name__.__len__() == 7 — '__new__' has 7 characters: _-_-n-e-w-_-_; shortest method name on ABCMeta; str.__len__() returns 7; new to abc_extra180"]
    - [register_name_len_8,
       ABCMeta.register.__name__.__len__,
       [],
       8,
       "abc.ABCMeta.register.__name__.__len__() == 8 — 'register' has 8 characters: r-e-g-i-s-t-e-r; tied with __init__(8); str.__len__() returns 8; new to abc_extra180"]
    - [init_name_len_8,
       ABCMeta.__init__.__name__.__len__,
       [],
       8,
       "abc.ABCMeta.__init__.__name__.__len__() == 8 — '__init__' has 8 characters: _-_-i-n-i-t-_-_; tied with register(8); str.__len__() returns 8; new to abc_extra180"]
    - [new_name_eq,
       ABCMeta.__new__.__name__.__eq__,
       ["__new__"],
       true,
       "abc.ABCMeta.__new__.__name__.__eq__('__new__') == True — method name is '__new__'; str.__eq__ returns True; new to abc_extra180"]
    - [register_name_eq,
       ABCMeta.register.__name__.__eq__,
       ["register"],
       true,
       "abc.ABCMeta.register.__name__.__eq__('register') == True — method name is 'register'; str.__eq__ returns True; new to abc_extra180"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABCMeta long method name lengths
#
# abc.ABCMeta._dump_registry.__name__.__len__() == 14
# abc.ABCMeta.__instancecheck__.__name__.__len__() == 17
# abc.ABCMeta.__subclasscheck__.__name__.__len__() == 17
# __instancecheck__ and __subclasscheck__ are tied at 17 (longest)
# ---------------------------------------------------------------------------

table abc_extra180.long_method_name_lengths:
  description: "abc.ABCMeta long method name lengths: _dump_registry=14, __instancecheck__=17, __subclasscheck__=17 (tied); new to abc_extra180"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetamethods180

  columns: [id, function, args, expected, description]
  rows:
    - [dump_name_len_14,
       ABCMeta._dump_registry.__name__.__len__,
       [],
       14,
       "abc.ABCMeta._dump_registry.__name__.__len__() == 14 — '_dump_registry' has 14 characters: _-d-u-m-p-_-r-e-g-i-s-t-r-y; str.__len__() returns 14; new to abc_extra180"]
    - [instancecheck_name_len_17,
       ABCMeta.__instancecheck__.__name__.__len__,
       [],
       17,
       "abc.ABCMeta.__instancecheck__.__name__.__len__() == 17 — '__instancecheck__' has 17 characters: _-_-i-n-s-t-a-n-c-e-c-h-e-c-k-_-_; tied with __subclasscheck__; str.__len__() returns 17; new to abc_extra180"]
    - [subclasscheck_name_len_17,
       ABCMeta.__subclasscheck__.__name__.__len__,
       [],
       17,
       "abc.ABCMeta.__subclasscheck__.__name__.__len__() == 17 — '__subclasscheck__' has 17 characters: _-_-s-u-b-c-l-a-s-s-c-h-e-c-k-_-_; tied with __instancecheck__; str.__len__() returns 17; new to abc_extra180"]
    - [instancecheck_name_eq,
       ABCMeta.__instancecheck__.__name__.__eq__,
       ["__instancecheck__"],
       true,
       "abc.ABCMeta.__instancecheck__.__name__.__eq__('__instancecheck__') == True — method name is '__instancecheck__'; str.__eq__ returns True; new to abc_extra180"]
    - [subclasscheck_name_eq,
       ABCMeta.__subclasscheck__.__name__.__eq__,
       ["__subclasscheck__"],
       true,
       "abc.ABCMeta.__subclasscheck__.__name__.__eq__('__subclasscheck__') == True — method name is '__subclasscheck__'; str.__eq__ returns True; new to abc_extra180"]

# ---------------------------------------------------------------------------
# Table 3: abc.ABCMeta name equality checks and ordering validation
#
# Length ordering: __new__(7) < register(8)==__init__(8) < _dump_registry(14) < __instancecheck__(17)==__subclasscheck__(17)
# abc.ABCMeta.__bases__[0].__name__ == 'type'
# ---------------------------------------------------------------------------

table abc_extra180.method_name_eq_and_ordering:
  description: "abc.ABCMeta method name equality checks; ordering: __new__(7)<register(8)==__init__(8)<_dump_registry(14)<__instancecheck__(17)==__subclasscheck__(17); new to abc_extra180"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetamethods180

  columns: [id, function, args, expected, description]
  rows:
    - [dump_name_eq,
       ABCMeta._dump_registry.__name__.__eq__,
       ["_dump_registry"],
       true,
       "abc.ABCMeta._dump_registry.__name__.__eq__('_dump_registry') == True — method name is '_dump_registry'; str.__eq__ returns True; new to abc_extra180"]
    - [init_name_eq,
       ABCMeta.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "abc.ABCMeta.__init__.__name__.__eq__('__init__') == True — method name is '__init__'; str.__eq__ returns True; new to abc_extra180"]
    - [abcmeta_bases0_name_eq,
       "ABCMeta.__bases__[0].__name__.__eq__",
       ["type"],
       true,
       "abc.ABCMeta.__bases__[0].__name__.__eq__('type') == True — ABCMeta is a metaclass inheriting directly from type; str.__eq__ returns True; new to abc_extra180"]
    - [new_name_len_7b,
       ABCMeta.__new__.__name__.__len__,
       [],
       7,
       "abc.ABCMeta.__new__.__name__.__len__() == 7 — ordering anchor: __new__(7) is shortest; new to abc_extra180"]
    - [subclasscheck_len_17b,
       ABCMeta.__subclasscheck__.__name__.__len__,
       [],
       17,
       "abc.ABCMeta.__subclasscheck__.__name__.__len__() == 17 — ordering ceiling: __subclasscheck__(17) tied for longest; new to abc_extra180"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra180
# ---------------------------------------------------------------------------

invariant abc_extra180.new_name_len_7:
  description: "abc.ABCMeta.__new__.__name__.__len__() == 7 — '__new__' has 7 characters; shortest method name on ABCMeta; new to abc_extra180"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__new__.__name__.__len__
  args: []
  expected: 7

invariant abc_extra180.register_name_len_8:
  description: "abc.ABCMeta.register.__name__.__len__() == 8 — 'register' has 8 characters; tied with __init__(8); ordering: __new__(7)<register(8); new to abc_extra180"
  category: identity
  kind: python_call_eq
  function: ABCMeta.register.__name__.__len__
  args: []
  expected: 8

invariant abc_extra180.init_name_len_8:
  description: "abc.ABCMeta.__init__.__name__.__len__() == 8 — '__init__' has 8 characters; tied with register(8); ordering: __new__(7)<__init__(8); new to abc_extra180"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__init__.__name__.__len__
  args: []
  expected: 8

invariant abc_extra180.dump_registry_name_len_14:
  description: "abc.ABCMeta._dump_registry.__name__.__len__() == 14 — '_dump_registry' has 14 characters; ordering: __init__(8)<_dump_registry(14)<__instancecheck__(17); new to abc_extra180"
  category: identity
  kind: python_call_eq
  function: ABCMeta._dump_registry.__name__.__len__
  args: []
  expected: 14

invariant abc_extra180.instancecheck_name_len_17:
  description: "abc.ABCMeta.__instancecheck__.__name__.__len__() == 17 — '__instancecheck__' has 17 characters; tied with __subclasscheck__(17); longest method names; new to abc_extra180"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__name__.__len__
  args: []
  expected: 17

invariant abc_extra180.subclasscheck_name_len_17:
  description: "abc.ABCMeta.__subclasscheck__.__name__.__len__() == 17 — '__subclasscheck__' has 17 characters; tied with __instancecheck__(17); longest method names; new to abc_extra180"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__subclasscheck__.__name__.__len__
  args: []
  expected: 17

invariant abc_extra180.register_name_eq:
  description: "abc.ABCMeta.register.__name__.__eq__('register') == True — method name string identity check; new to abc_extra180"
  category: identity
  kind: python_call_eq
  function: ABCMeta.register.__name__.__eq__
  args: ["register"]
  expected: true

invariant abc_extra180.abcmeta_bases0_type:
  description: "abc.ABCMeta.__bases__[0].__name__.__eq__('type') == True — ABCMeta is a metaclass; its single base is 'type'; new to abc_extra180"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true
