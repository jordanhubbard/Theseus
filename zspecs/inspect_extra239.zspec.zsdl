spec: inspect_extra239
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect.stack, inspect.currentframe, and inspect.getfile function identity."
    - "inspect.stack.__name__ == 'stack' (len=5) — stack is a Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.stack.__module__ == 'inspect' (len=7) — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.currentframe.__name__ == 'currentframe' (len=12) — currentframe is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.currentframe.__module__ == 'inspect' (len=7) — currentframe is a Python function in Lib/inspect.py (wraps sys._getframe). Verified with Python 3.14.3."
    - "inspect.getfile.__name__ == 'getfile' (len=7) — getfile is a Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getfile.__module__ == 'inspect' (len=7) — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.stack function identity contracts
#
# inspect.stack.__name__ == 'stack' (len=5)
# inspect.stack.__module__ == 'inspect' (len=7)
# inspect.stack.__qualname__ == 'stack' (len=5)
# inspect.stack.__class__.__name__ == 'function'
# inspect.stack.__doc__.__contains__('stack') == True
#
# stack is a Python function in Lib/inspect.py. New to extra239.
# ---------------------------------------------------------------------------

table inspect_extra239.insp239fns_stack_identity:
  description: "inspect.stack function identity: name, module, qualname, class, doc; new to extra239"
  kind: python_call_eq
  category: identity
  id_prefix: insp239fns

  columns: [id, function, args, expected, description]
  rows:
    - [stack_name_eq,
       stack.__name__.__eq__,
       ["stack"],
       true,
       "inspect.stack.__name__.__eq__('stack') == True — stack is a Python function in Lib/inspect.py; __name__ is 'stack' (len=5); new to extra239"]
    - [stack_name_len_5,
       stack.__name__.__len__,
       [],
       5,
       "inspect.stack.__name__.__len__() == 5 — 'stack' has exactly 5 characters (s-t-a-c-k); str.__len__() returns 5; new to extra239"]
    - [stack_module_eq,
       stack.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.stack.__module__.__eq__('inspect') == True — stack is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra239"]
    - [stack_module_len_7,
       stack.__module__.__len__,
       [],
       7,
       "inspect.stack.__module__.__len__() == 7 — 'inspect' has exactly 7 characters (i-n-s-p-e-c-t); str.__len__() returns 7; new to extra239"]
    - [stack_class_is_function,
       stack.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.stack.__class__.__name__.__eq__('function') == True — stack is a Python function; its __class__ is the built-in function type; new to extra239"]

# ---------------------------------------------------------------------------
# Table 2: inspect.stack qualname and doc contracts
#
# inspect.stack.__qualname__ == 'stack' (len=5)
# inspect.stack.__doc__.__contains__('stack') == True
# inspect.stack.__doc__.__contains__('frame') == True
# inspect.stack.__doc__.__class__.__name__ == 'str'
# inspect.stack.__qualname__.__len__() == 5
#
# stack docstring describes returning records for the stack above caller's frame. New to extra239.
# ---------------------------------------------------------------------------

table inspect_extra239.insp239fns_stack_doc:
  description: "inspect.stack qualname, doc checks; new to extra239"
  kind: python_call_eq
  category: identity
  id_prefix: insp239fnsdoc

  columns: [id, function, args, expected, description]
  rows:
    - [stack_qualname_eq,
       stack.__qualname__.__eq__,
       ["stack"],
       true,
       "inspect.stack.__qualname__.__eq__('stack') == True — __qualname__ is 'stack' (len=5); same as __name__ for top-level function; new to extra239"]
    - [stack_qualname_len_5,
       stack.__qualname__.__len__,
       [],
       5,
       "inspect.stack.__qualname__.__len__() == 5 — 'stack' has exactly 5 characters; str.__len__() returns 5; new to extra239"]
    - [stack_doc_contains_stack,
       stack.__doc__.__contains__,
       ["stack"],
       true,
       "inspect.stack.__doc__.__contains__('stack') == True — docstring says 'Return a list of records for the stack above the caller\\'s frame'; new to extra239"]
    - [stack_doc_contains_frame,
       stack.__doc__.__contains__,
       ["frame"],
       true,
       "inspect.stack.__doc__.__contains__('frame') == True — docstring mentions frame as the unit of stack records; new to extra239"]
    - [stack_doc_class_is_str,
       stack.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.stack.__doc__.__class__.__name__.__eq__('str') == True — the stack docstring is a plain Python str object; new to extra239"]

# ---------------------------------------------------------------------------
# Table 3: inspect.currentframe function identity contracts
#
# inspect.currentframe.__name__ == 'currentframe' (len=12)
# inspect.currentframe.__module__ == 'inspect' (len=7)
# inspect.currentframe.__qualname__ == 'currentframe' (len=12)
# inspect.currentframe.__class__.__name__ == 'function'
# inspect.currentframe.__qualname__.__len__() == 12
#
# currentframe is a Python function in Lib/inspect.py. New to extra239.
# ---------------------------------------------------------------------------

table inspect_extra239.insp239fns_currentframe_identity:
  description: "inspect.currentframe function identity: name, module, qualname, class; new to extra239"
  kind: python_call_eq
  category: identity
  id_prefix: insp239fnscf

  columns: [id, function, args, expected, description]
  rows:
    - [cf_name_eq,
       currentframe.__name__.__eq__,
       ["currentframe"],
       true,
       "inspect.currentframe.__name__.__eq__('currentframe') == True — currentframe is a Python function in Lib/inspect.py; __name__ is 'currentframe' (len=12); new to extra239"]
    - [cf_name_len_12,
       currentframe.__name__.__len__,
       [],
       12,
       "inspect.currentframe.__name__.__len__() == 12 — 'currentframe' has exactly 12 characters; str.__len__() returns 12; new to extra239"]
    - [cf_module_eq,
       currentframe.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.currentframe.__module__.__eq__('inspect') == True — currentframe is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra239"]
    - [cf_module_len_7,
       currentframe.__module__.__len__,
       [],
       7,
       "inspect.currentframe.__module__.__len__() == 7 — 'inspect' has exactly 7 characters; str.__len__() returns 7; new to extra239"]
    - [cf_class_is_function,
       currentframe.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.currentframe.__class__.__name__.__eq__('function') == True — currentframe is a Python function; its __class__ is the built-in function type; new to extra239"]

# ---------------------------------------------------------------------------
# Table 4: inspect.getfile function identity contracts
#
# inspect.getfile.__name__ == 'getfile' (len=7)
# inspect.getfile.__module__ == 'inspect' (len=7)
# inspect.getfile.__qualname__ == 'getfile' (len=7)
# inspect.getfile.__doc__.__contains__('source') == True
# inspect.getfile.__class__.__name__ == 'function'
#
# getfile is a Python function in Lib/inspect.py. New to extra239.
# ---------------------------------------------------------------------------

table inspect_extra239.insp239fns_getfile_identity:
  description: "inspect.getfile function identity: name, module, qualname, doc, class; new to extra239"
  kind: python_call_eq
  category: identity
  id_prefix: insp239fnsgf

  columns: [id, function, args, expected, description]
  rows:
    - [gf_name_eq,
       getfile.__name__.__eq__,
       ["getfile"],
       true,
       "inspect.getfile.__name__.__eq__('getfile') == True — getfile is a Python function in Lib/inspect.py; __name__ is 'getfile' (len=7); new to extra239"]
    - [gf_name_len_7,
       getfile.__name__.__len__,
       [],
       7,
       "inspect.getfile.__name__.__len__() == 7 — 'getfile' has exactly 7 characters (g-e-t-f-i-l-e); str.__len__() returns 7; new to extra239"]
    - [gf_module_eq,
       getfile.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getfile.__module__.__eq__('inspect') == True — getfile is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra239"]
    - [gf_doc_contains_source,
       getfile.__doc__.__contains__,
       ["source"],
       true,
       "inspect.getfile.__doc__.__contains__('source') == True — docstring says 'Work out which source or compiled file an object was defined in'; new to extra239"]
    - [gf_class_is_function,
       getfile.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getfile.__class__.__name__.__eq__('function') == True — getfile is a Python function; its __class__ is the built-in function type; new to extra239"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra239
# ---------------------------------------------------------------------------

invariant inspect_extra239.stack_name_eq:
  description: "inspect.stack.__name__ == 'stack' (len=5); new to extra239"
  kind: python_call_eq
  function: stack.__name__.__eq__
  args: ["stack"]
  expected: true

invariant inspect_extra239.stack_name_len_5:
  description: "inspect.stack.__name__.__len__() == 5 — 'stack' has 5 characters; new to extra239"
  kind: python_call_eq
  function: stack.__name__.__len__
  args: []
  expected: 5

invariant inspect_extra239.stack_module_eq:
  description: "inspect.stack.__module__ == 'inspect'; new to extra239"
  kind: python_call_eq
  function: stack.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra239.stack_module_len_7:
  description: "inspect.stack.__module__.__len__() == 7 — 'inspect' has 7 characters; new to extra239"
  kind: python_call_eq
  function: stack.__module__.__len__
  args: []
  expected: 7

invariant inspect_extra239.stack_doc_contains_frame:
  description: "inspect.stack.__doc__.__contains__('frame') == True; new to extra239"
  kind: python_call_eq
  function: stack.__doc__.__contains__
  args: ["frame"]
  expected: true

invariant inspect_extra239.cf_name_eq:
  description: "inspect.currentframe.__name__ == 'currentframe' (len=12); new to extra239"
  kind: python_call_eq
  function: currentframe.__name__.__eq__
  args: ["currentframe"]
  expected: true

invariant inspect_extra239.cf_name_len_12:
  description: "inspect.currentframe.__name__.__len__() == 12 — 'currentframe' has 12 characters; new to extra239"
  kind: python_call_eq
  function: currentframe.__name__.__len__
  args: []
  expected: 12

invariant inspect_extra239.cf_module_eq:
  description: "inspect.currentframe.__module__ == 'inspect'; new to extra239"
  kind: python_call_eq
  function: currentframe.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra239.cf_class_is_function:
  description: "inspect.currentframe.__class__.__name__ == 'function'; new to extra239"
  kind: python_call_eq
  function: currentframe.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra239.gf_name_eq:
  description: "inspect.getfile.__name__ == 'getfile' (len=7); new to extra239"
  kind: python_call_eq
  function: getfile.__name__.__eq__
  args: ["getfile"]
  expected: true

invariant inspect_extra239.gf_module_eq:
  description: "inspect.getfile.__module__ == 'inspect'; new to extra239"
  kind: python_call_eq
  function: getfile.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra239.gf_doc_contains_source:
  description: "inspect.getfile.__doc__.__contains__('source') == True; new to extra239"
  kind: python_call_eq
  function: getfile.__doc__.__contains__
  args: ["source"]
  expected: true
