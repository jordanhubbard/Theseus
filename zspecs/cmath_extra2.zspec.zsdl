spec: cmath_extra2
version: ">=3.9"
backend: python_module(cmath)

docs: https://docs.python.org/3/library/cmath.html

provenance:
  derived_from:
    - "Python cmath documentation — https://docs.python.org/3/library/cmath.html"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/cmathmodule.c"
  notes:
    - "This spec extends cmath.zspec.zsdl and cmath_extra.zspec.zsdl."
    - "cmath.zspec.zsdl covers: isfinite/isinf/isnan/isclose predicates (real/float inputs); phase(1.0/−1.0/0.0); polar(5.0)[0],[1]; sqrt/exp/log; constants pi/e/tau."
    - "cmath_extra.zspec.zsdl covers: constant type checks; __name__ for phase/polar/rect/exp/log/sqrt/sin/cos/isinf/isnan/isfinite/isclose (as individual invariants)."
    - "This spec adds: __module__ check for phase; polar(1.0) component-wise; rect(1.0,0.0) real/imag; additional predicate vectors with integer and negative inputs not covered above; isclose with zeros and equal integers; a table cross-checking the seven function __name__ values."
    - "cmath.phase.__module__ == 'cmath' — phase is defined in the cmath module (not covered in prior specs)."
    - "cmath.polar(1.0)[0] == 1.0 and [1] == 0.0 — unit real, distinct from cmath.zspec polar(5.0) vectors."
    - "cmath.rect(1.0, 0.0).real == 1.0 and .imag == 0.0 — neither cmath nor cmath_extra tests rect return values."
    - "cmath.isfinite(2) == True and isfinite(-99) == True — integer inputs not covered by cmath.zspec.zsdl."
    - "cmath.isinf(0) == False and isinf(-1) == False — extend isinf coverage beyond cmath.zspec vectors."
    - "cmath.isnan(0) == False and isnan(-5) == False — extend isnan coverage beyond cmath.zspec vectors."
    - "cmath.isclose(0.0, 0.0) == True and isclose(5, 5) == True — extend isclose coverage."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# function_names table — confirm __name__ for seven predicate/conversion
# functions. cmath_extra covers these as individual invariants; this table
# provides a compact cross-check under a distinct spec label.
# ---------------------------------------------------------------------------

table cmath_extra2.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [phase,    phase.__name__.__eq__,    ["phase"],    true]
    - [polar,    polar.__name__.__eq__,    ["polar"],    true]
    - [rect,     rect.__name__.__eq__,     ["rect"],     true]
    - [isfinite, isfinite.__name__.__eq__, ["isfinite"], true]
    - [isinf,    isinf.__name__.__eq__,    ["isinf"],    true]
    - [isnan,    isnan.__name__.__eq__,    ["isnan"],    true]
    - [isclose,  isclose.__name__.__eq__,  ["isclose"],  true]

# ---------------------------------------------------------------------------
# __module__ check — phase is implemented in the cmath module
# Neither cmath.zspec.zsdl nor cmath_extra.zspec.zsdl checks __module__ on
# any cmath function. This is a new vector.
# ---------------------------------------------------------------------------

invariant cmath_extra2.phase.module:
  description: "cmath.phase.__module__ == 'cmath'"
  category: function_identity
  kind: python_call_eq
  function: phase.__module__.__eq__
  args: ["cmath"]
  expected: true

# ---------------------------------------------------------------------------
# polar(1.0) — unit real; component-wise
# cmath.zspec.zsdl covers polar(5.0)[0] == 5.0 and polar(5.0)[1] == 0.0.
# We add polar(1.0) as a new distinct input value.
# ---------------------------------------------------------------------------

invariant cmath_extra2.polar.unit_real_magnitude:
  description: "cmath.polar(1.0)[0] == 1.0 — magnitude of unit real is 1.0"
  category: polar
  kind: python_call_eq
  function: polar
  args: [1.0]
  method: __getitem__
  method_args: [0]
  expected: 1.0

invariant cmath_extra2.polar.unit_real_phase:
  description: "cmath.polar(1.0)[1] == 0.0 — phase of unit real is 0.0"
  category: polar
  kind: python_call_eq
  function: polar
  args: [1.0]
  method: __getitem__
  method_args: [1]
  expected: 0.0

# ---------------------------------------------------------------------------
# rect(r, phi) — inverse of polar; rect(1.0, 0.0) == 1+0j
# Neither cmath.zspec.zsdl nor cmath_extra tests rect return values at all.
# rect returns a complex number; we test .real and .imag.
# ---------------------------------------------------------------------------

invariant cmath_extra2.rect.unit_real_real:
  description: "cmath.rect(1.0, 0.0).real == 1.0 — rect(1, 0) is a unit real number"
  category: rect
  kind: python_call_eq
  function: rect
  args: [1.0, 0.0]
  method: real
  expected: 1.0

invariant cmath_extra2.rect.unit_real_imag:
  description: "cmath.rect(1.0, 0.0).imag == 0.0 — rect(1, 0) has no imaginary part"
  category: rect
  kind: python_call_eq
  function: rect
  args: [1.0, 0.0]
  method: imag
  expected: 0.0

# ---------------------------------------------------------------------------
# isfinite — additional integer inputs
# cmath.zspec.zsdl covers isfinite(1.0)==True, isfinite(inf)==False,
# isfinite(-inf)==False, isfinite(0.0)==True — all via float/special values.
# We add integer inputs which are also valid (Python cmath accepts int/float/complex).
# ---------------------------------------------------------------------------

invariant cmath_extra2.isfinite.integer_two:
  description: "cmath.isfinite(2) == True — integer 2 is finite"
  category: predicates
  kind: python_call_eq
  function: isfinite
  args: [2]
  expected: true

invariant cmath_extra2.isfinite.negative_integer:
  description: "cmath.isfinite(-99) == True — negative integer is finite"
  category: predicates
  kind: python_call_eq
  function: isfinite
  args: [-99]
  expected: true

# ---------------------------------------------------------------------------
# isinf — additional vectors
# cmath.zspec.zsdl covers isinf(inf)==True, isinf(1.0)==False, isinf(0.0)==False.
# We add integer inputs.
# ---------------------------------------------------------------------------

invariant cmath_extra2.isinf.integer_zero:
  description: "cmath.isinf(0) == False — integer zero is not infinite"
  category: predicates
  kind: python_call_eq
  function: isinf
  args: [0]
  expected: false

invariant cmath_extra2.isinf.negative_integer:
  description: "cmath.isinf(-1) == False — negative integer is not infinite"
  category: predicates
  kind: python_call_eq
  function: isinf
  args: [-1]
  expected: false

# ---------------------------------------------------------------------------
# isnan — additional vectors
# cmath.zspec.zsdl covers isnan(nan)==True, isnan(1.0)==False.
# We add integer inputs.
# ---------------------------------------------------------------------------

invariant cmath_extra2.isnan.integer_zero:
  description: "cmath.isnan(0) == False — integer zero is not NaN"
  category: predicates
  kind: python_call_eq
  function: isnan
  args: [0]
  expected: false

invariant cmath_extra2.isnan.negative_integer:
  description: "cmath.isnan(-5) == False — negative integer is not NaN"
  category: predicates
  kind: python_call_eq
  function: isnan
  args: [-5]
  expected: false

# ---------------------------------------------------------------------------
# isclose — additional vectors
# cmath.zspec.zsdl covers isclose(1.0,1.0)==True and isclose(1.0,1.1)==False.
# We add isclose(0.0,0.0)==True and isclose with equal integers.
# ---------------------------------------------------------------------------

invariant cmath_extra2.isclose.zero_zero:
  description: "cmath.isclose(0.0, 0.0) == True — zero is close to zero"
  category: predicates
  kind: python_call_eq
  function: isclose
  args: [0.0, 0.0]
  expected: true

invariant cmath_extra2.isclose.equal_integers:
  description: "cmath.isclose(5, 5) == True — equal integers are close"
  category: predicates
  kind: python_call_eq
  function: isclose
  args: [5, 5]
  expected: true
