spec: concurrent_futures_extra115
version: ">=3.14"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/interpreter.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra114.zspec.zsdl."
    - "This spec covers: wave 258 theme — concurrent.futures.InterpreterPoolExecutor class identity attributes not previously covered. Prior specs covered: extra88 covered concurrent.futures.__name__/__package__/__spec__.__class__.__name__/__spec__.name equality; extra28 covered __all__.__len__()==14 and __package__.__len__()==18 and __spec__.__class__.__name__.__len__()==10; extra54/extra93 mentioned InterpreterPoolExecutor only in __all__ context. NOT previously covered: InterpreterPoolExecutor.__name__, __module__, __qualname__, __mro__.__len__(), __bases__[0].__name__, __init__ co_argcount/co_qualname. NEW in extra115: InterpreterPoolExecutor.__name__.__eq__('InterpreterPoolExecutor')==True (len=23); InterpreterPoolExecutor.__module__.__eq__('concurrent.futures.interpreter')==True (len=30); InterpreterPoolExecutor.__mro__.__len__()==4; InterpreterPoolExecutor.__bases__[0].__name__.__eq__('ThreadPoolExecutor')==True; InterpreterPoolExecutor.__init__.__code__.co_argcount==5; InterpreterPoolExecutor.__init__.__code__.co_qualname=='InterpreterPoolExecutor.__init__' (len=32). Also: Future.__dict__.__len__()==21; Executor.__dict__.__len__()==11. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.InterpreterPoolExecutor was added in Python 3.14. It runs submitted callables in separate interpreter instances within the same process. __name__='InterpreterPoolExecutor' (23 chars: longest executor class name). __module__='concurrent.futures.interpreter' (30 chars: longest module path among executors). __mro__.__len__()==4: [InterpreterPoolExecutor, ThreadPoolExecutor, Executor, object]. __bases__[0].__name__=='ThreadPoolExecutor'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.__dict__.__len__()==21 (21 entries including __module__, __init__, cancel, cancelled, running, done, result, exception, set_result, set_exception, add_done_callback, _invoke_callbacks, __repr__, set_running_or_notify_cancel, _Future__get_result, __class_getitem__, __static_attributes__, __dict__, __weakref__, __firstlineno__, __doc__). concurrent.futures.Executor.__dict__.__len__()==11 (11 entries: __module__, __firstlineno__, __doc__, submit, map, shutdown, __enter__, __exit__, __static_attributes__, __dict__, __weakref__). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.InterpreterPoolExecutor class identity — extra115
#
# Wave 258 theme: InterpreterPoolExecutor class-level identity attributes (new in Python 3.14).
#
# concurrent.futures.InterpreterPoolExecutor.__name__.__len__()              == 23  (longest executor name)
# concurrent.futures.InterpreterPoolExecutor.__module__.__len__()            == 30  (longest executor module path)
# concurrent.futures.InterpreterPoolExecutor.__mro__.__len__()               == 4   ([IPE, TPE, Executor, object])
# concurrent.futures.InterpreterPoolExecutor.__bases__[0].__name__.__len__() == 18  ('ThreadPoolExecutor')
# ---------------------------------------------------------------------------

table concurrent_futures_extra115.cf_ipe_class_identity:
  description: "concurrent.futures.InterpreterPoolExecutor class identity checks in cfipe115 namespace — wave 258 theme: InterpreterPoolExecutor class-level identity; InterpreterPoolExecutor.__name__.__eq__('InterpreterPoolExecutor')==True (len=23: longest executor class name in the module; compare ThreadPoolExecutor=18, ProcessPoolExecutor=19, Executor=8); InterpreterPoolExecutor.__name__.__len__()==23; InterpreterPoolExecutor.__qualname__.__eq__('InterpreterPoolExecutor')==True (__qualname__==__name__ for top-level class); InterpreterPoolExecutor.__qualname__.__len__()==23; InterpreterPoolExecutor.__module__.__eq__('concurrent.futures.interpreter')==True (len=30: defined in the interpreter submodule, the longest module path among all concurrent.futures executors; ThreadPoolExecutor.__module__=='concurrent.futures.thread' len=26; ProcessPoolExecutor.__module__=='concurrent.futures.process' len=27); InterpreterPoolExecutor.__module__.__len__()==30; InterpreterPoolExecutor.__mro__.__len__()==4 (the deepest executor MRO: [InterpreterPoolExecutor, ThreadPoolExecutor, Executor, object]; compare ThreadPoolExecutor/__mro__.__len__()==3, ProcessPoolExecutor/__mro__.__len__()==3); InterpreterPoolExecutor.__bases__[0].__name__.__eq__('ThreadPoolExecutor')==True (single direct base class ThreadPoolExecutor; IPE reuses threads from TPE but runs callables in separate subinterpreters); InterpreterPoolExecutor.__bases__[0].__name__.__len__()==18; compare class name lengths: Executor=8 < ThreadPoolExecutor=18 == __bases__[0] len < ProcessPoolExecutor=19 < InterpreterPoolExecutor=23 (longest); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfipe115

  columns: [id, function, args, expected, description]
  rows:
    - [ipe_name_eq,    InterpreterPoolExecutor.__name__.__eq__,                ["InterpreterPoolExecutor"], true, "IPE.__name__ == 'InterpreterPoolExecutor' (len=23, longest executor name); verified with Python 3.14.3"]
    - [ipe_name_len,   InterpreterPoolExecutor.__name__.__len__,               [],                          23,   "IPE.__name__.__len__() == 23 (longer than ProcessPoolExecutor=19, ThreadPoolExecutor=18); verified with Python 3.14.3"]
    - [ipe_qn_eq,      InterpreterPoolExecutor.__qualname__.__eq__,            ["InterpreterPoolExecutor"], true, "IPE.__qualname__ == 'InterpreterPoolExecutor' (__qualname__==__name__ for top-level class); verified with Python 3.14.3"]
    - [ipe_qn_len,     InterpreterPoolExecutor.__qualname__.__len__,           [],                          23,   "IPE.__qualname__.__len__() == 23 (tied with __name__ len=23); verified with Python 3.14.3"]
    - [ipe_mod_eq,     InterpreterPoolExecutor.__module__.__eq__,              ["concurrent.futures.interpreter"], true, "IPE.__module__ == 'concurrent.futures.interpreter' (len=30, longest executor module path); verified with Python 3.14.3"]
    - [ipe_mod_len,    InterpreterPoolExecutor.__module__.__len__,             [],                          30,   "IPE.__module__.__len__() == 30 ('concurrent.futures.interpreter'=30, longest); verified with Python 3.14.3"]
    - [ipe_mro_len,    InterpreterPoolExecutor.__mro__.__len__,                [],                          4,    "IPE.__mro__.__len__() == 4 ([IPE, ThreadPoolExecutor, Executor, object]; deepest executor MRO); verified with Python 3.14.3"]
    - [ipe_base_eq,    "InterpreterPoolExecutor.__bases__[0].__name__.__eq__", ["ThreadPoolExecutor"],      true, "IPE.__bases__[0].__name__ == 'ThreadPoolExecutor' (IPE inherits from TPE); verified with Python 3.14.3"]
    - [ipe_base_len,   "InterpreterPoolExecutor.__bases__[0].__name__.__len__", [],                         18,   "IPE.__bases__[0].__name__.__len__() == 18 ('ThreadPoolExecutor'=18); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.InterpreterPoolExecutor.__init__ code attrs — extra115
#
# Wave 258 theme: IPE.__init__ co_qualname and co_argcount.
#
# concurrent.futures.InterpreterPoolExecutor.__init__.__code__.co_qualname  == 'InterpreterPoolExecutor.__init__' (len=32)
# concurrent.futures.InterpreterPoolExecutor.__init__.__code__.co_argcount  == 5
# ---------------------------------------------------------------------------

table concurrent_futures_extra115.cf_ipe_init_code_attrs:
  description: "concurrent.futures.InterpreterPoolExecutor.__init__ code attribute checks in cfipe115 namespace — wave 258 theme: IPE.__init__ is a Python-defined method (unlike C-extension executors); InterpreterPoolExecutor.__init__.__code__.co_qualname.__eq__('InterpreterPoolExecutor.__init__')==True (len=32: 'InterpreterPoolExecutor.'=24+'__init__'=8=32; this is the longest co_qualname in this spec; compare: Executor.__enter__ co_qualname len=18, ThreadPoolExecutor has submit co_qualname len=25); InterpreterPoolExecutor.__init__.__code__.co_qualname.__len__()==32; InterpreterPoolExecutor.__init__.__code__.co_argcount.__eq__(5)==True (5 positional params: self, max_workers, thread_name_prefix, initializer, initargs; same co_argcount as multiprocessing.Pool.__code__.co_argcount); InterpreterPoolExecutor.__init__.__code__.co_argcount.__eq__(5)==True; compare co_argcount: Executor.__enter__ co_argcount=1 (simplest) < Executor.map co_argcount=2 < Executor.__exit__ co_argcount=4 < IPE.__init__ co_argcount=5 (most in this spec); 'InterpreterPoolExecutor.__init__'=32 chars: 'InterpreterPoolExecutor.'=24+'__init__'=8=32; the prefix 'InterpreterPoolExecutor.'=24 is the longest class prefix among concurrent.futures executors in any co_qualname; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfipe115a

  columns: [id, function, args, expected, description]
  rows:
    - [ipe_coq_eq,  InterpreterPoolExecutor.__init__.__code__.co_qualname.__eq__,  ["InterpreterPoolExecutor.__init__"], true, "IPE.__init__.__code__.co_qualname == 'InterpreterPoolExecutor.__init__' (len=32); verified with Python 3.14.3"]
    - [ipe_coq_len, InterpreterPoolExecutor.__init__.__code__.co_qualname.__len__, [],                                   32,   "IPE.__init__ co_qualname.__len__() == 32 ('InterpreterPoolExecutor.__init__'=32); verified with Python 3.14.3"]
    - [ipe_argc,    InterpreterPoolExecutor.__init__.__code__.co_argcount.__eq__,  [5],                                  true, "IPE.__init__.__code__.co_argcount == 5 (self, max_workers, thread_name_prefix, initializer, initargs); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Future and Executor __dict__ length — extra115
#
# Wave 258 theme: Future.__dict__.__len__() and Executor.__dict__.__len__() not previously covered.
#
# concurrent.futures.Future.__dict__.__len__()   == 21
# concurrent.futures.Executor.__dict__.__len__() == 11
# ---------------------------------------------------------------------------

table concurrent_futures_extra115.cf_class_dict_len:
  description: "concurrent.futures.Future and Executor __dict__ length checks in cfipe115 namespace — wave 258 theme: Future.__dict__.__len__()==21 (21 entries: the Future class has 21 distinct entries in its class dict including __module__, __firstlineno__, __doc__, __init__, _invoke_callbacks, __repr__, cancel, cancelled, running, done, _Future__get_result, add_done_callback, result, exception, set_running_or_notify_cancel, set_result, set_exception, __class_getitem__, __static_attributes__, __dict__, __weakref__; a rich class with both query methods and mutation methods); concurrent.futures.Future.__dict__.__len__()==21; Executor.__dict__.__len__()==11 (11 entries: __module__, __firstlineno__, __doc__, submit, map, shutdown, __enter__, __exit__, __static_attributes__, __dict__, __weakref__; Executor is an abstract base class with minimal entries — no concrete implementations); Executor.__dict__.__len__()==11; compare: Future.__dict__.__len__()==21 > Executor.__dict__.__len__()==11 (Future has 10 more entries than Executor; Future is fully implemented while Executor only defines the interface); InterpreterPoolExecutor.__name__.__len__()==23 (longest executor name); IPE.__mro__.__len__()==4 (deepest MRO, includes both Future subclassing chain and Executor chain); Future.__mro__.__len__()==2; Executor.__mro__.__len__()==2; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfipe115b

  columns: [id, function, args, expected, description]
  rows:
    - [future_dict_len,   concurrent.futures.Future.__dict__.__len__,   [], 21, "Future.__dict__.__len__() == 21 (21 class entries; full implementation); verified with Python 3.14.3"]
    - [executor_dict_len, concurrent.futures.Executor.__dict__.__len__, [], 11, "Executor.__dict__.__len__() == 11 (11 entries; abstract base class, minimal); verified with Python 3.14.3"]
    - [ipe_name_23,       InterpreterPoolExecutor.__name__.__len__,     [], 23, "InterpreterPoolExecutor.__name__.__len__() == 23 (cross-check: longest executor name); verified with Python 3.14.3"]
    - [ipe_mro_4,         InterpreterPoolExecutor.__mro__.__len__,      [], 4,  "IPE.__mro__.__len__() == 4 (cross-check: deepest executor MRO); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra115
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra115.ipe_name_len_23:
  description: "concurrent.futures.InterpreterPoolExecutor.__name__.__len__() == 23 — 'InterpreterPoolExecutor'=23 chars: 'Interpreter'=11+'Pool'=4+'Executor'=8=23; this is the longest executor class name in the concurrent.futures module; compare: ProcessPoolExecutor.__name__.__len__()==19 ('Process'=7+'Pool'=4+'Executor'=8=19), ThreadPoolExecutor.__name__.__len__()==18 ('Thread'=6+'Pool'=4+'Executor'=8=18), Executor.__name__.__len__()==8 (shortest, 15 less than IPE); InterpreterPoolExecutor.__name__.__eq__('InterpreterPoolExecutor')==True; InterpreterPoolExecutor.__qualname__.__len__()==23 (tied with __name__: top-level class); InterpreterPoolExecutor.__module__=='concurrent.futures.interpreter' (len=30); InterpreterPoolExecutor.__mro__.__len__()==4 (deepest executor MRO); InterpreterPoolExecutor runs callables in separate interpreter subprocesses within the same OS process (multiple interpreters, one process); added in Python 3.14; first standalone IPE __name__ length invariant in cfipe115 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: InterpreterPoolExecutor.__name__.__len__
  args: []
  expected: 23

invariant concurrent_futures_extra115.ipe_module_len_30:
  description: "concurrent.futures.InterpreterPoolExecutor.__module__.__len__() == 30 — 'concurrent.futures.interpreter' = 'concurrent.'=11+'futures.'=8+'interpreter'=11=30; this is the longest __module__ path of any class in the concurrent.futures package; compare: ProcessPoolExecutor.__module__=='concurrent.futures.process' (len=27; 3 shorter than IPE), ThreadPoolExecutor.__module__=='concurrent.futures.thread' (len=26; 4 shorter); the 'interpreter' submodule name (11 chars) is longer than 'process' (7 chars) or 'thread' (6 chars); InterpreterPoolExecutor.__module__.__eq__('concurrent.futures.interpreter')==True; InterpreterPoolExecutor.__name__.__len__()==23 (longer module name than class name by 7: 30-23=7); InterpreterPoolExecutor.__mro__.__len__()==4; first standalone IPE __module__ length invariant in cfipe115 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: InterpreterPoolExecutor.__module__.__len__
  args: []
  expected: 30

invariant concurrent_futures_extra115.ipe_mro_len_4:
  description: "concurrent.futures.InterpreterPoolExecutor.__mro__.__len__() == 4 — the MRO is [InterpreterPoolExecutor, ThreadPoolExecutor, Executor, object]: 4 entries; this is the deepest executor MRO in the concurrent.futures module; compare: ThreadPoolExecutor.__mro__.__len__()==3 ([TPE, Executor, object]), ProcessPoolExecutor.__mro__.__len__()==3 ([PPE, Executor, object]); IPE's MRO is 1 deeper than TPE/PPE because IPE inherits from TPE which itself inherits from Executor; IPE.__bases__[0].__name__=='ThreadPoolExecutor' (direct parent); IPE reuses the thread pool implementation from ThreadPoolExecutor but runs each callable in an isolated subinterpreter (full isolation without process overhead); IPE.__name__.__len__()==23; IPE.__module__.__len__()==30; first standalone IPE __mro__ length invariant in cfipe115 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: InterpreterPoolExecutor.__mro__.__len__
  args: []
  expected: 4

invariant concurrent_futures_extra115.ipe_init_co_qualname_len_32:
  description: "concurrent.futures.InterpreterPoolExecutor.__init__.__code__.co_qualname.__len__() == 32 — 'InterpreterPoolExecutor.__init__' = 'InterpreterPoolExecutor.'=24+'__init__'=8=32; this is the longest executor __init__ co_qualname in the concurrent.futures module; compare: ThreadPoolExecutor.__init__ co_qualname len=27 ('ThreadPoolExecutor.__init__'=27; 5 shorter than IPE), ProcessPoolExecutor.__init__ co_qualname len=28 ('ProcessPoolExecutor.__init__'=28; 4 shorter than IPE); InterpreterPoolExecutor.__init__.__code__.co_qualname.__eq__('InterpreterPoolExecutor.__init__')==True; IPE.__init__.__code__.co_argcount==5 (self, max_workers, thread_name_prefix, initializer, initargs); the 24-char prefix 'InterpreterPoolExecutor.' is the longest class prefix in any concurrent.futures method co_qualname; first standalone IPE __init__ co_qualname length invariant in cfipe115 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: InterpreterPoolExecutor.__init__.__code__.co_qualname.__len__
  args: []
  expected: 32

invariant concurrent_futures_extra115.future_dict_len_21:
  description: "concurrent.futures.Future.__dict__.__len__() == 21 — the Future class has 21 entries in its class __dict__: __module__, __firstlineno__, __doc__, __init__, _invoke_callbacks, __repr__, cancel, cancelled, running, done, _Future__get_result, add_done_callback, result, exception, set_running_or_notify_cancel, set_result, set_exception, __class_getitem__, __static_attributes__, __dict__, __weakref__; count=21 reflects the full state-machine implementation including both public query methods (cancel/cancelled/running/done/result/exception/add_done_callback) and public mutation methods (set_result/set_exception/set_running_or_notify_cancel); compare: Executor.__dict__.__len__()==11 (10 fewer: Executor is abstract with only submit/map/shutdown/__enter__/__exit__ plus boilerplate); Future.__mro__.__len__()==2; Future.__module__=='concurrent.futures._base' (len=24); first standalone Future.__dict__ length invariant in cfipe115 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__len__
  args: []
  expected: 21

