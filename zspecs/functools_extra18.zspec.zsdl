spec: functools_extra18
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools.zspec.zsdl and prior extras through functools_extra17.zspec.zsdl."
    - "functools_extra17 covers: wraps/singledispatch/cached_property/cmp_to_key/lru_cache __name__.__eq__; reduce(mul,[1..4])==24; reduce(mul,[1..5])==120; WRAPPER_ASSIGNMENTS indices 0,1,2; WRAPPER_ASSIGNMENTS.__contains__ for __module__ and __doc__."
    - "functools_extra16 covers: reduce(max,seq); reduce(min,seq); partial call behaviors."
    - "functools_extra15 covers: partialmethod __name__/__qualname__; total_ordering.__qualname__; WRAPPER_ASSIGNMENTS[5]=='__type_params__'; WRAPPER_UPDATES.__contains__('__dict__')==True."
    - "functools_extra14 covers: __qualname__.__len__() for cmp_to_key/total_ordering/singledispatch/singledispatchmethod."
    - "functools_extra13 covers: reduce/__qualname__.__len__(); partial/__qualname__.__len__(); wraps/__qualname__.__eq__; cached_property/__qualname__.__eq__."
    - "NOT yet covered: partial.__qualname__.__eq__('partial') as standalone; lru_cache.__qualname__.__eq__('lru_cache'); cache.__qualname__.__eq__('cache'); reduce.__qualname__.__eq__('reduce'); singledispatch.__qualname__.__eq__('singledispatch'); singledispatchmethod.__qualname__.__eq__('singledispatchmethod'); WRAPPER_ASSIGNMENTS[3]=='__doc__'; WRAPPER_ASSIGNMENTS[4]=='__annotate__'."
    - "functools.partial.__qualname__ == 'partial' — top-level C type, qualname equals name."
    - "functools.lru_cache.__qualname__ == 'lru_cache' — top-level function, qualname equals name."
    - "functools.cache.__qualname__ == 'cache' — added in Python 3.9."
    - "functools.reduce.__qualname__ == 'reduce' — top-level C function."
    - "functools.singledispatch.__qualname__ == 'singledispatch' — top-level decorator function."
    - "functools.singledispatchmethod.__qualname__ == 'singledispatchmethod' — top-level class."
    - "functools.WRAPPER_ASSIGNMENTS[3] == '__doc__' — fourth element, stable across 3.9+."
    - "functools.WRAPPER_ASSIGNMENTS[4] == '__annotate__' — fifth element on Python 3.12+ (was '__annotations__' on earlier versions)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ equality for partial, lru_cache, cache, reduce,
# singledispatch, singledispatchmethod
#
# functools_extra13 covers __qualname__.__eq__ for wraps and cached_property.
# functools_extra15 covers total_ordering.__qualname__.__eq__.
# functools_extra13 covers __qualname__.__len__() for reduce and partial.
# functools_extra14 covers __qualname__.__len__() for singledispatch and singledispatchmethod.
# None of these has a standalone __qualname__.__eq__ invariant yet:
# partial, lru_cache, cache, reduce, singledispatch, singledispatchmethod.
# ---------------------------------------------------------------------------

invariant functools_extra18.partial.qualname_eq:
  description: "functools.partial.__qualname__ == 'partial' — C type at module scope, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: partial.__qualname__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra18.lru_cache.qualname_eq:
  description: "functools.lru_cache.__qualname__ == 'lru_cache' — top-level function, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: lru_cache.__qualname__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra18.cache.qualname_eq:
  description: "functools.cache.__qualname__ == 'cache' — added in Python 3.9, top-level function"
  category: qualnames
  kind: python_call_eq
  function: cache.__qualname__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra18.reduce.qualname_eq:
  description: "functools.reduce.__qualname__ == 'reduce' — top-level C function, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: reduce.__qualname__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra18.singledispatch.qualname_eq:
  description: "functools.singledispatch.__qualname__ == 'singledispatch' — top-level decorator"
  category: qualnames
  kind: python_call_eq
  function: singledispatch.__qualname__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra18.singledispatchmethod.qualname_eq:
  description: "functools.singledispatchmethod.__qualname__ == 'singledispatchmethod' — top-level class"
  category: qualnames
  kind: python_call_eq
  function: singledispatchmethod.__qualname__.__eq__
  args: ["singledispatchmethod"]
  expected: true

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS elements at indices 3 and 4
#
# functools_extra17 covers indices 0 ('__module__'), 1 ('__name__'),
# and 2 ('__qualname__'). functools_extra15 covers index 5 ('__type_params__').
# No prior spec asserts index 3 ('__doc__') or index 4 as standalone invariants.
# On Python 3.12+, index 4 is '__annotate__'; on 3.9-3.11 it is '__annotations__'.
# We assert index 3 only (stable across all supported versions).
# ---------------------------------------------------------------------------

invariant functools_extra18.WRAPPER_ASSIGNMENTS.index3:
  description: "WRAPPER_ASSIGNMENTS[3] == '__doc__' — fourth element, stable across 3.9+"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__getitem__
  args: [3]
  expected: "__doc__"

invariant functools_extra18.WRAPPER_ASSIGNMENTS.contains_qualname:
  description: "WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — present since 3.3+"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__qualname__"]
  expected: true

invariant functools_extra18.WRAPPER_ASSIGNMENTS.contains_name:
  description: "WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — present in all versions"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__name__"]
  expected: true

# ---------------------------------------------------------------------------
# functools.cache — qualname length check and __name__ equality
#
# functools.cache was added in Python 3.9. No prior spec covers
# cache.__name__.__eq__ or cache.__qualname__.__len__().
# cache.__name__ == 'cache' and len('cache') == 5.
# ---------------------------------------------------------------------------

invariant functools_extra18.cache.name_eq:
  description: "functools.cache.__name__ == 'cache' — top-level function name"
  category: function_names
  kind: python_call_eq
  function: cache.__name__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra18.cache.qualname_len:
  description: "functools.cache.__qualname__.__len__() == 5 — len('cache')"
  category: qualname_lengths
  kind: python_call_eq
  function: cache.__qualname__.__len__
  args: []
  expected: 5

invariant functools_extra18.singledispatchmethod.qualname_len:
  description: "functools.singledispatchmethod.__qualname__.__len__() == 20 — len('singledispatchmethod')"
  category: qualname_lengths
  kind: python_call_eq
  function: singledispatchmethod.__qualname__.__len__
  args: []
  expected: 20
