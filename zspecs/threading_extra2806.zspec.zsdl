spec: threading_extra2806
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "any proprietary source"
  notes:
    - "Wave 634 (_extra2806): __ilshift__, __irshift__, and __ipow__ dict-presence checks (in-place left-shift <<=, right-shift >>=, power **=)."
    - "threading.Thread does NOT define __ilshift__, __irshift__, or __ipow__ — thread lifecycle management has no numeric shift or power semantics."
    - "threading.Lock (alias for _thread.lock) does NOT define these operators — it is a mutex primitive with acquire/release only."
    - "threading.Event does NOT define these operators — it is a flag-based synchronization primitive."
    - "threading.Condition does NOT define these operators — it is a monitor-style synchronization primitive."
    - "threading.Semaphore does NOT define these operators — it is a counting semaphore, not a numeric type."
    - "threading.BoundedSemaphore does NOT define these operators — same rationale as Semaphore."
    - "threading.Timer does NOT define these operators — it is a Thread subclass for delayed execution."
    - "threading.Barrier does NOT define these operators — it is a phase synchronization barrier."
    - "threading.local does NOT define these operators — it provides thread-local storage, not numeric values."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __ilshift__ dict-presence (in-place left-shift <<=)
#
# threading.Thread, Lock, Event, Condition, Semaphore — none define __ilshift__.
# Synchronization primitives have no numeric shift semantics.
# ---------------------------------------------------------------------------

table threading_extra2806.ilshift_protocol:
  description: "threading types __ilshift__ dict-presence checks — all False (no in-place left-shift protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2806
  columns: [id, function, args, expected]
  rows:
    - ["th2806001", "threading.Thread.__dict__.__contains__",           ["__ilshift__"], false]
    - ["th2806002", "threading.Lock.__dict__.__contains__",             ["__ilshift__"], false]
    - ["th2806003", "threading.Event.__dict__.__contains__",            ["__ilshift__"], false]
    - ["th2806004", "threading.Condition.__dict__.__contains__",        ["__ilshift__"], false]
    - ["th2806005", "threading.Semaphore.__dict__.__contains__",        ["__ilshift__"], false]
    - ["th2806006", "threading.BoundedSemaphore.__dict__.__contains__", ["__ilshift__"], false]
    - ["th2806007", "threading.Timer.__dict__.__contains__",            ["__ilshift__"], false]
    - ["th2806008", "threading.Barrier.__dict__.__contains__",          ["__ilshift__"], false]
    - ["th2806009", "threading.local.__dict__.__contains__",            ["__ilshift__"], false]

# ---------------------------------------------------------------------------
