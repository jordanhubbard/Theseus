    - ["th2806035", "threading.Semaphore.__dict__.__contains__",        ["__irshift__"], false]
    - ["th2806036", "threading.Semaphore.__dict__.__contains__",        ["__ipow__"],    false]
    - ["th2806037", "threading.Barrier.__dict__.__contains__",          ["__ilshift__"], false]
    - ["th2806038", "threading.Barrier.__dict__.__contains__",          ["__irshift__"], false]
    - ["th2806039", "threading.Barrier.__dict__.__contains__",          ["__ipow__"],    false]
    - ["th2806040", "threading.local.__dict__.__contains__",            ["__ilshift__"], false]
