    - ["th2806027", "threading.local.__dict__.__contains__",            ["__ipow__"], false]

# ---------------------------------------------------------------------------
# Table 4: combined in-place shift/power operator absence — all types, all ops
#
# Cross-check: each threading type lacks all three in-place shift/power operators.
# Confirms that the threading API is a synchronization surface only — mutual
# exclusion, signaling, and phase barriers have no numeric shift or power protocol.
# ---------------------------------------------------------------------------

table threading_extra2806.inplace_shift_pow_absent:
  description: "threading types full __ilshift__/__irshift__/__ipow__ absence cross-check — all False"
