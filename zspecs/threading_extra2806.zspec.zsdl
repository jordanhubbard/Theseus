# ---------------------------------------------------------------------------
# Table 3: __ipow__ dict-presence (in-place power **=)
#
# None of the threading types define __ipow__ — exponentiation has no
# meaning for thread synchronization or thread-local storage objects.
# ---------------------------------------------------------------------------

table threading_extra2806.ipow_protocol:
  description: "threading types __ipow__ dict-presence checks — all False (no in-place power protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2806
  columns: [id, function, args, expected]
  rows:
    - ["th2806019", "threading.Thread.__dict__.__contains__",           ["__ipow__"], false]
    - ["th2806020", "threading.Lock.__dict__.__contains__",             ["__ipow__"], false]
    - ["th2806021", "threading.Event.__dict__.__contains__",            ["__ipow__"], false]
    - ["th2806022", "threading.Condition.__dict__.__contains__",        ["__ipow__"], false]
    - ["th2806023", "threading.Semaphore.__dict__.__contains__",        ["__ipow__"], false]
    - ["th2806024", "threading.BoundedSemaphore.__dict__.__contains__", ["__ipow__"], false]
    - ["th2806025", "threading.Timer.__dict__.__contains__",            ["__ipow__"], false]
