spec: asynchat
version: ">=3.3,<3.12"
backend: python_module(asynchat)

docs: https://docs.python.org/3.11/library/asynchat.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3.11/library/asynchat.html"
    - "Test vectors verified with Python 3.11 on macOS/Darwin 25.4.0, 2026-04-09"
    - "asynchat source: Lib/asynchat.py (PSF; structural inspection only)"
  not_derived_from:
    - "asynchat source: network I/O internals"
  notes:
    - "asynchat was deprecated in Python 3.6 and removed in Python 3.12."
    - "asynchat.async_chat is the primary class; it inherits from asyncore.dispatcher."
    - "async_chat provides push()/push_with_producer() to queue outbound data and a terminator-based read protocol."
    - "simple_producer wraps a data buffer for use with push_with_producer()."
    - "async_chat.__bases__[0].__name__ == 'dispatcher' — inherits from asyncore.dispatcher."
    - "simple_producer.__name__ == 'simple_producer'; simple_producer.__module__ == 'asynchat'."
    - "Key methods on async_chat: handle_read, handle_write, collect_incoming_data, found_terminator, push, push_with_producer, close_when_done."
    - "collect_incoming_data and found_terminator are abstract; subclasses must override them."
    - "All expected values verified by running Python 3.11 asynchat module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "asynchat raises no module-specific exception class; network errors propagate from asyncore.dispatcher."
  stderr: "null"
  stickiness: "N/A — class-level structural checks only."
  codes: {}

# ---------------------------------------------------------------------------
# async_chat class — name and module
# ---------------------------------------------------------------------------

invariant asynchat.async_chat_name:
  description: "async_chat.__name__ == 'async_chat'"
  category: classnames
  kind: python_call_eq
  function: async_chat.__name__.__eq__
  args: ["async_chat"]
  expected: true

invariant asynchat.async_chat_module:
  description: "async_chat.__module__ == 'asynchat'"
  category: classnames
  kind: python_call_eq
  function: async_chat.__module__.__eq__
  args: ["asynchat"]
  expected: true

invariant asynchat.async_chat_base:
  description: "async_chat.__bases__[0].__name__ == 'dispatcher' — inherits from asyncore.dispatcher"
  category: classnames
  kind: python_call_eq
  function: async_chat.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "dispatcher"

# ---------------------------------------------------------------------------
# simple_producer class — name and module
# ---------------------------------------------------------------------------

invariant asynchat.simple_producer_name:
  description: "simple_producer.__name__ == 'simple_producer'"
  category: classnames
  kind: python_call_eq
  function: simple_producer.__name__.__eq__
  args: ["simple_producer"]
  expected: true

invariant asynchat.simple_producer_module:
  description: "simple_producer.__module__ == 'asynchat'"
  category: classnames
  kind: python_call_eq
  function: simple_producer.__module__.__eq__
  args: ["asynchat"]
  expected: true

invariant asynchat.simple_producer_base:
  description: "simple_producer.__bases__[0].__name__ == 'object'"
  category: classnames
  kind: python_call_eq
  function: simple_producer.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# async_chat methods — presence checks via __name__
# ---------------------------------------------------------------------------

invariant asynchat.async_chat_handle_read_name:
  description: "async_chat.handle_read.__name__ == 'handle_read'"
  category: methods
  kind: python_call_eq
  function: async_chat.handle_read.__name__.__eq__
  args: ["handle_read"]
  expected: true

invariant asynchat.async_chat_handle_write_name:
  description: "async_chat.handle_write.__name__ == 'handle_write'"
  category: methods
  kind: python_call_eq
  function: async_chat.handle_write.__name__.__eq__
  args: ["handle_write"]
  expected: true

invariant asynchat.async_chat_push_name:
  description: "async_chat.push.__name__ == 'push'"
  category: methods
  kind: python_call_eq
  function: async_chat.push.__name__.__eq__
  args: ["push"]
  expected: true

invariant asynchat.async_chat_close_when_done_name:
  description: "async_chat.close_when_done.__name__ == 'close_when_done'"
  category: methods
  kind: python_call_eq
  function: async_chat.close_when_done.__name__.__eq__
  args: ["close_when_done"]
  expected: true

invariant asynchat.async_chat_found_terminator_name:
  description: "async_chat.found_terminator.__name__ == 'found_terminator'"
  category: methods
  kind: python_call_eq
  function: async_chat.found_terminator.__name__.__eq__
  args: ["found_terminator"]
  expected: true
