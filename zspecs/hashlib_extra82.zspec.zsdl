spec: hashlib_extra82
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra81.zspec.zsdl — covers sha256/__name__/__qualname__/__module__ / md5/__name__/__qualname__/__module__ / new/__class__/__name__/__module__/__qualname__ / algorithms_available/__class__/__name__ / sha512/__name__ (table + invariants)."
    - "hashlib_extra80.zspec.zsdl — covers blake2b/blake2s class-level size constants and hexdigest/__class__/__name__ (table + invariants)."
    - "hashlib_extra79.zspec.zsdl — covers blake2b/blake2s method __class__/__name__ (table + invariants)."
    - "hashlib_extra77.zspec.zsdl — covers blake2b/blake2s/__name__/__module__/__bases__[0]/__mro__.__len__() (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra81; it does NOT duplicate invariants present in those files."
    - "Wave 246 theme: hashlib sha1/sha224/sha384/sha512/sha3_224/sha3_384/sha3_512/shake_128/shake_256 function identity."
    - "hashlib.sha1.__name__ == 'openssl_sha1' — sha1 is the openssl_sha1 C type from _hashlib. No prior hashlib spec checks sha1.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__qualname__ == 'openssl_sha1' — same as __name__ for C extension types. No prior hashlib spec checks sha1.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__module__ == '_hashlib' — sha1 is defined in the C extension _hashlib. No prior hashlib spec checks sha1.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__class__.__name__ == 'builtin_function_or_method' — sha1 is a C-level callable. No prior hashlib spec checks sha1.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__name__ == 'openssl_sha224' — sha224 is the openssl_sha224 C type. No prior hashlib spec checks sha224.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__module__ == '_hashlib' — sha224 is from the C extension. No prior hashlib spec checks sha224.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__name__ == 'openssl_sha384' — sha384 is the openssl_sha384 C type. No prior hashlib spec checks sha384.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__module__ == '_hashlib' — sha384 is from the C extension. No prior hashlib spec checks sha384.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__name__ == 'openssl_sha3_224' — sha3_224 is from the C extension. No prior hashlib spec checks sha3_224.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__module__ == '_hashlib' — sha3_224 is from the C extension. No prior hashlib spec checks sha3_224.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__name__ == 'openssl_sha3_384' — sha3_384 is from the C extension. No prior hashlib spec checks sha3_384.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__name__ == 'openssl_sha3_512' — sha3_512 is from the C extension. No prior hashlib spec checks sha3_512.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__name__ == 'openssl_shake_128' — shake_128 is from the C extension. No prior hashlib spec checks shake_128.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__name__ == 'openssl_shake_256' — shake_256 is from the C extension. No prior hashlib spec checks shake_256.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha1.__name__, __qualname__, and __module__ identity
#
# Wave 246 theme: hashlib sha1 constructor name/qualname/module.
#
# hashlib.sha1 is actually the openssl_sha1 C extension builtin from _hashlib.
# Its __name__ and __qualname__ are both 'openssl_sha1' and its __module__ is
# '_hashlib'. No prior hashlib spec checks sha1.__name__, sha1.__qualname__,
# or sha1.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra82.sha1_name_qualname_module:
  description: "hashlib.sha1/__name__.__eq__('openssl_sha1')==True / sha1/__qualname__.__eq__('openssl_sha1')==True / sha1/__module__.__eq__('_hashlib')==True — sha1 is the openssl_sha1 C builtin from _hashlib; no prior hashlib spec checks sha1.__name__/__qualname__/__module__; first __name__/__qualname__/__module__ anchor for hashlib.sha1"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra82

  columns: [id, function, args, expected]
  rows:
    - [sha1_name_openssl_sha1,     sha1.__name__.__eq__,     ["openssl_sha1"], true]
    - [sha1_qualname_openssl_sha1, sha1.__qualname__.__eq__,  ["openssl_sha1"], true]
    - [sha1_module_hashlib,        sha1.__module__.__eq__,    ["_hashlib"],     true]

# ---------------------------------------------------------------------------
# hashlib.sha1.__class__.__name__ and hashlib.sha224.__name__/__module__
#
# Wave 246 theme: sha1 class type identity and sha224 constructor identity.
#
# hashlib.sha1.__class__.__name__ is 'builtin_function_or_method' — sha1 is a
# C-level callable. hashlib.sha224.__name__ is 'openssl_sha224' and its
# __module__ is '_hashlib'. No prior hashlib spec checks sha1.__class__.__name__
# or sha224.__name__/__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra82.sha1_class_sha224_name_module:
  description: "hashlib.sha1/__class__/__name__.__eq__('builtin_function_or_method')==True / sha224/__name__.__eq__('openssl_sha224')==True / sha224/__module__.__eq__('_hashlib')==True — sha1 is a C builtin; sha224 is the openssl_sha224 C type from _hashlib; no prior hashlib spec checks sha1.__class__.__name__ or sha224.__name__/__module__; first class-name and sha224 identity anchor"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra82

  columns: [id, function, args, expected]
  rows:
    - [sha1_class_name_builtin,   sha1.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [sha224_name_openssl_sha224, sha224.__name__.__eq__,          ["openssl_sha224"],             true]
    - [sha224_module_hashlib,      sha224.__module__.__eq__,         ["_hashlib"],                   true]

# ---------------------------------------------------------------------------
# hashlib.sha384.__name__/__module__ and sha3_224.__name__/__module__
#
# Wave 246 theme: sha384 and sha3_224 constructor identity.
#
# hashlib.sha384.__name__ == 'openssl_sha384' and __module__ == '_hashlib'.
# hashlib.sha3_224.__name__ == 'openssl_sha3_224' and __module__ == '_hashlib'.
# No prior hashlib spec checks sha384.__name__, sha384.__module__,
# sha3_224.__name__, or sha3_224.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra82.sha384_sha3_224_name_module:
  description: "hashlib.sha384/__name__.__eq__('openssl_sha384')==True / sha384/__module__.__eq__('_hashlib')==True / sha3_224/__name__.__eq__('openssl_sha3_224')==True / sha3_224/__module__.__eq__('_hashlib')==True — sha384 and sha3_224 are C types from _hashlib; no prior hashlib spec checks sha384.__name__/__module__ or sha3_224.__name__/__module__; first identity anchor for sha384 and sha3_224"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra82

  columns: [id, function, args, expected]
  rows:
    - [sha384_name_openssl_sha384,       sha384.__name__.__eq__,       ["openssl_sha384"],    true]
    - [sha384_module_hashlib,             sha384.__module__.__eq__,      ["_hashlib"],          true]
    - [sha3_224_name_openssl_sha3_224,   sha3_224.__name__.__eq__,      ["openssl_sha3_224"], true]
    - [sha3_224_module_hashlib,           sha3_224.__module__.__eq__,    ["_hashlib"],          true]

# ---------------------------------------------------------------------------
# hashlib.sha3_384/__name__, sha3_512/__name__, shake_128/__name__, shake_256/__name__
#
# Wave 246 theme: sha3/shake family constructor name identity.
#
# hashlib.sha3_384.__name__ == 'openssl_sha3_384'.
# hashlib.sha3_512.__name__ == 'openssl_sha3_512'.
# hashlib.shake_128.__name__ == 'openssl_shake_128'.
# hashlib.shake_256.__name__ == 'openssl_shake_256'.
# No prior hashlib spec checks any of these __name__ values.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra82.sha3_shake_names:
  description: "hashlib.sha3_384/__name__.__eq__('openssl_sha3_384')==True / sha3_512/__name__.__eq__('openssl_sha3_512')==True / shake_128/__name__.__eq__('openssl_shake_128')==True / shake_256/__name__.__eq__('openssl_shake_256')==True — sha3/shake family are all C types from _hashlib; no prior hashlib spec checks sha3_384/sha3_512/shake_128/shake_256 __name__; first __name__ anchor for sha3/shake family"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra82

  columns: [id, function, args, expected]
  rows:
    - [sha3_384_name_openssl_sha3_384, sha3_384.__name__.__eq__,  ["openssl_sha3_384"],  true]
    - [sha3_512_name_openssl_sha3_512, sha3_512.__name__.__eq__,  ["openssl_sha3_512"],  true]
    - [shake_128_name_openssl_shake_128, shake_128.__name__.__eq__, ["openssl_shake_128"], true]
    - [shake_256_name_openssl_shake_256, shake_256.__name__.__eq__, ["openssl_shake_256"], true]

# ---------------------------------------------------------------------------
# hashlib.sha1.__name__.__eq__('openssl_sha1') — standalone
#
# sha1 is the openssl_sha1 C builtin. No prior hashlib spec checks sha1.__name__.
# First __name__ standalone for hashlib.sha1.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra82.sha1_name_openssl_sha1:
  description: "hashlib.sha1.__name__.__eq__('openssl_sha1') == True — sha1 is the openssl_sha1 C extension builtin from _hashlib; no prior hashlib spec checks sha1.__name__; first __name__ standalone for hashlib.sha1"
  category: class_attrs
  kind: python_call_eq
  function: sha1.__name__.__eq__
  args: ["openssl_sha1"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha1.__module__.__eq__('_hashlib') — standalone
#
# sha1.__module__ is '_hashlib' (the C extension). No prior hashlib spec checks
# sha1.__module__. First __module__ standalone for hashlib.sha1.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra82.sha1_module_hashlib:
  description: "hashlib.sha1.__module__.__eq__('_hashlib') == True — sha1 is defined in the _hashlib C extension; no prior hashlib spec checks sha1.__module__; first __module__ standalone for hashlib.sha1"
  category: class_attrs
  kind: python_call_eq
  function: sha1.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_224.__name__.__eq__('openssl_sha3_224') — standalone
#
# sha3_224 is the openssl_sha3_224 C extension type. No prior hashlib spec checks
# sha3_224.__name__. First __name__ standalone for hashlib.sha3_224.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra82.sha3_224_name_openssl_sha3_224:
  description: "hashlib.sha3_224.__name__.__eq__('openssl_sha3_224') == True — sha3_224 is the openssl_sha3_224 C extension type from _hashlib; no prior hashlib spec checks sha3_224.__name__; first __name__ standalone for hashlib.sha3_224"
  category: class_attrs
  kind: python_call_eq
  function: sha3_224.__name__.__eq__
  args: ["openssl_sha3_224"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.shake_128.__name__.__eq__('openssl_shake_128') — standalone
#
# shake_128 is the openssl_shake_128 C extension type. No prior hashlib spec
# checks shake_128.__name__. First __name__ standalone for hashlib.shake_128.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra82.shake_128_name_openssl_shake_128:
  description: "hashlib.shake_128.__name__.__eq__('openssl_shake_128') == True — shake_128 is the openssl_shake_128 C extension type from _hashlib; no prior hashlib spec checks shake_128.__name__; first __name__ standalone for hashlib.shake_128"
  category: class_attrs
  kind: python_call_eq
  function: shake_128.__name__.__eq__
  args: ["openssl_shake_128"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.shake_256.__name__.__eq__('openssl_shake_256') — standalone
#
# shake_256 is the openssl_shake_256 C extension type. No prior hashlib spec
# checks shake_256.__name__. First __name__ standalone for hashlib.shake_256.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra82.shake_256_name_openssl_shake_256:
  description: "hashlib.shake_256.__name__.__eq__('openssl_shake_256') == True — shake_256 is the openssl_shake_256 C extension type from _hashlib; no prior hashlib spec checks shake_256.__name__; first __name__ standalone for hashlib.shake_256"
  category: class_attrs
  kind: python_call_eq
  function: shake_256.__name__.__eq__
  args: ["openssl_shake_256"]
  expected: true
