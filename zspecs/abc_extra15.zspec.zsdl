spec: abc_extra15
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc.zspec.zsdl through abc_extra14.zspec.zsdl."
    - "abc_extra14 covers: abstractmethod/__qualname__/ABC/__qualname__/ABCMeta/__qualname__ standalone; ABC/__mro__.__len__ and __mro__[1].__name__; ABCMeta/__mro__.__len__/__mro__[1].__name__/__mro__[2].__name__; get_cache_token/__qualname__ and returns_ge_zero; abstractmethod/__doc__.__class__.__name__; ABC/__doc__.__class__.__name__."
    - "abc_extra12 covers: abstractclassmethod/__qualname__/__module__; abstractstaticmethod/__qualname__/__module__; abstractproperty/__qualname__/__module__."
    - "abc_extra10 covers: ABCMeta.__doc__.__len__() (length of docstring)."
    - "Focus of this spec: (1) combined __mro__.__len__ table for abstractclassmethod/abstractstaticmethod/abstractproperty (all == 3); (2) combined __bases__.__len__ table for the same three (all == 1); (3) combined __bases__[0].__name__ table showing inheritance from classmethod/staticmethod/property; (4) ABCMeta.__doc__.__class__.__name__ == 'str' standalone."
    - "NOT yet covered (entering this spec): abstractclassmethod/__mro__.__len__() == 3; abstractstaticmethod/__mro__.__len__() == 3; abstractproperty/__mro__.__len__() == 3; abstractclassmethod/__bases__.__len__() == 1; abstractstaticmethod/__bases__.__len__() == 1; abstractproperty/__bases__.__len__() == 1; abstractclassmethod/__bases__[0].__name__ == 'classmethod'; abstractstaticmethod/__bases__[0].__name__ == 'staticmethod'; abstractproperty/__bases__[0].__name__ == 'property'; ABCMeta/__doc__.__class__.__name__ == 'str'."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for abstractclassmethod, abstractstaticmethod, abstractproperty
#
# All three deprecated decorators have MRO of length 3:
#   abstractclassmethod: [abstractclassmethod, classmethod, object]
#   abstractstaticmethod: [abstractstaticmethod, staticmethod, object]
#   abstractproperty: [abstractproperty, property, object]
# No prior spec covers __mro__.__len__() for any of these three.
# ---------------------------------------------------------------------------

table abc_extra15.deprecated_mro_lengths:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mro_len

  columns: [id, function, args, expected]
  rows:
    - [abstractclassmethod,  abstractclassmethod.__mro__.__len__,  [], 3]
    - [abstractstaticmethod, abstractstaticmethod.__mro__.__len__, [], 3]
    - [abstractproperty,     abstractproperty.__mro__.__len__,     [], 3]

# ---------------------------------------------------------------------------
# __bases__.__len__() for abstractclassmethod, abstractstaticmethod, abstractproperty
#
# Each deprecated decorator has exactly one direct base class.
# No prior spec covers __bases__.__len__() for any of these three.
# ---------------------------------------------------------------------------

table abc_extra15.deprecated_bases_lengths:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: bases_len

  columns: [id, function, args, expected]
  rows:
    - [abstractclassmethod,  abstractclassmethod.__bases__.__len__,  [], 1]
    - [abstractstaticmethod, abstractstaticmethod.__bases__.__len__, [], 1]
    - [abstractproperty,     abstractproperty.__bases__.__len__,     [], 1]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ for abstractclassmethod, abstractstaticmethod, abstractproperty
#
# Each inherits from the corresponding non-abstract built-in:
#   abstractclassmethod  -> classmethod
#   abstractstaticmethod -> staticmethod
#   abstractproperty     -> property
# No prior spec accesses __bases__[0].__name__ for any of these three.
# ---------------------------------------------------------------------------

table abc_extra15.deprecated_bases_names:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base0_name

  columns: [id, function, args, expected]
  rows:
    - [abstractclassmethod,  abstractclassmethod.__bases__.__getitem__(0).__name__.__eq__,  ["classmethod"],  true]
    - [abstractstaticmethod, abstractstaticmethod.__bases__.__getitem__(0).__name__.__eq__, ["staticmethod"], true]
    - [abstractproperty,     abstractproperty.__bases__.__getitem__(0).__name__.__eq__,     ["property"],     true]

# ---------------------------------------------------------------------------
# ABCMeta.__doc__.__class__.__name__ standalone
#
# abc_extra10 covers ABCMeta.__doc__.__len__() (the length of the docstring).
# abc_extra14 covers abstractmethod/__doc__.__class__.__name__ and ABC/__doc__.__class__.__name__.
# No prior spec checks ABCMeta.__doc__.__class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

invariant abc_extra15.ABCMeta.doc_is_str:
  description: "abc.ABCMeta.__doc__.__class__.__name__ == 'str' — ABCMeta has a string docstring"
  category: docstrings
  kind: python_call_eq
  function: ABCMeta.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
