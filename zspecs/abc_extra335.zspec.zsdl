spec: abc_extra335
version: ">=3.3"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "collections.abc.Sequence.__abstractmethods__ is a frozenset on Python 3.14."
    - "Sequence requires __getitem__ and __len__ as abstract methods."
    - "Mapping requires __getitem__, __len__, and __iter__ as abstract methods."
    - "Iterable requires __iter__; Iterator requires __next__ as abstract methods."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Sequence abstract methods
# ---------------------------------------------------------------------------

invariant abc_extra335.sequence.abstractmethods_is_frozenset:
  description: "Sequence.__abstractmethods__.__class__.__name__ == 'frozenset'"
  category: sequence
  kind: python_call_eq
  function: Sequence.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

invariant abc_extra335.sequence.requires_getitem:
  description: "Sequence.__abstractmethods__ contains '__getitem__'"
  category: sequence
  kind: python_call_eq
  function: Sequence.__abstractmethods__.__contains__
  args: ["__getitem__"]
  expected: true

invariant abc_extra335.sequence.requires_len:
  description: "Sequence.__abstractmethods__ contains '__len__'"
  category: sequence
  kind: python_call_eq
  function: Sequence.__abstractmethods__.__contains__
  args: ["__len__"]
  expected: true

# ---------------------------------------------------------------------------
# Mapping abstract methods
# ---------------------------------------------------------------------------

invariant abc_extra335.mapping.requires_getitem:
  description: "Mapping.__abstractmethods__ contains '__getitem__'"
  category: mapping
  kind: python_call_eq
  function: Mapping.__abstractmethods__.__contains__
  args: ["__getitem__"]
  expected: true

invariant abc_extra335.mapping.requires_len:
  description: "Mapping.__abstractmethods__ contains '__len__'"
  category: mapping
  kind: python_call_eq
  function: Mapping.__abstractmethods__.__contains__
  args: ["__len__"]
  expected: true

invariant abc_extra335.mapping.requires_iter:
  description: "Mapping.__abstractmethods__ contains '__iter__'"
  category: mapping
  kind: python_call_eq
  function: Mapping.__abstractmethods__.__contains__
  args: ["__iter__"]
  expected: true

# ---------------------------------------------------------------------------
# Iterable abstract methods
# ---------------------------------------------------------------------------

invariant abc_extra335.iterable.requires_iter:
  description: "Iterable.__abstractmethods__ contains '__iter__'"
  category: iterable
  kind: python_call_eq
  function: Iterable.__abstractmethods__.__contains__
  args: ["__iter__"]
  expected: true

# ---------------------------------------------------------------------------
# Iterator abstract methods
# ---------------------------------------------------------------------------

invariant abc_extra335.iterator.requires_next:
  description: "Iterator.__abstractmethods__ contains '__next__'"
  category: iterator
  kind: python_call_eq
  function: Iterator.__abstractmethods__.__contains__
  args: ["__next__"]
  expected: true
