spec: string_extra16
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra15.zspec.zsdl."
    - "string_extra14 covers: Template.substitute with dict; Template.template attribute; Template base class."
    - "string_extra13 covers: capwords five words; ascii_lowercase[0]; ascii_uppercase[-1]."
    - "No prior spec covers Template.__qualname__, Template.__module__, or Template.__bases__.__getitem__(0).__name__."
    - "No prior spec covers Formatter.__qualname__, Formatter.__module__, or Formatter.__bases__.__getitem__(0).__name__."
    - "string_extra13 covers capwords('HELLO WORLD') => 'Hello World' (five-word input); no prior spec covers single-word 'HELLO' or 'hello world' (two words) or '  hello  ' (padded)."
    - "string.Template.__qualname__ == 'Template' — qualname equals name for a top-level class."
    - "string.Template.__module__ == 'string' — Template is defined in the string module."
    - "string.Template.__bases__.__getitem__(0).__name__ == 'object' — Template directly inherits from object."
    - "string.Formatter.__qualname__ == 'Formatter' — qualname equals name for a top-level class."
    - "string.Formatter.__module__ == 'string' — Formatter is defined in the string module."
    - "string.Formatter.__bases__.__getitem__(0).__name__ == 'object' — Formatter directly inherits from object."
    - "string.capwords('hello world') == 'Hello World' — two-word input capitalised."
    - "string.capwords('  hello  ') == 'Hello' — padded input: split drops empty strings, joins with single word."
    - "string.capwords('HELLO') == 'Hello' — single all-caps word capitalised."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Template — class identity attributes
#
# string_extra14 covers Template base class (bases[0].__name__ == 'object') via
# the method field on Template.__bases__.__getitem__ in an invariant.
# No prior spec covers Template.__qualname__ or Template.__module__.
# ---------------------------------------------------------------------------

invariant string_extra16.Template.qualname:
  description: "string.Template.__qualname__ == 'Template' — top-level class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: Template.__qualname__.__eq__
  args: ["Template"]
  expected: true

invariant string_extra16.Template.module:
  description: "string.Template.__module__ == 'string' — Template is defined in the string module"
  category: class_attrs
  kind: python_call_eq
  function: Template.__module__.__eq__
  args: ["string"]
  expected: true

invariant string_extra16.Template.base_is_object:
  description: "string.Template.__bases__.__getitem__(0).__name__ == 'object' — Template inherits directly from object"
  category: class_attrs
  kind: python_call_eq
  function: Template.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Formatter — class identity attributes
#
# No prior spec covers Formatter.__qualname__, Formatter.__module__, or
# Formatter.__bases__.__getitem__(0).__name__. Formatter is a pure-Python class
# in Lib/string.py that inherits directly from object.
# ---------------------------------------------------------------------------

invariant string_extra16.Formatter.qualname:
  description: "string.Formatter.__qualname__ == 'Formatter' — top-level class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: Formatter.__qualname__.__eq__
  args: ["Formatter"]
  expected: true

invariant string_extra16.Formatter.module:
  description: "string.Formatter.__module__ == 'string' — Formatter is defined in the string module"
  category: class_attrs
  kind: python_call_eq
  function: Formatter.__module__.__eq__
  args: ["string"]
  expected: true

invariant string_extra16.Formatter.base_is_object:
  description: "string.Formatter.__bases__.__getitem__(0).__name__ == 'object' — Formatter inherits directly from object"
  category: class_attrs
  kind: python_call_eq
  function: Formatter.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Table: string.capwords — new input vectors
#
# string_extra13 covers capwords with a five-word sentence ('hello world foo bar baz').
# No prior spec covers capwords('hello world') (two words), capwords('  hello  ')
# (whitespace-padded), or capwords('HELLO') (single all-caps word).
# capwords splits on whitespace, capitalises each token, and joins with a single
# space; empty tokens from leading/trailing whitespace are dropped.
# ---------------------------------------------------------------------------

table string_extra16.capwords_vectors:
  description: "string.capwords new input vectors — two words, padded, single all-caps"
  kind: python_call_eq
  category: capwords
  id_prefix: cw16
  function: capwords

  columns: [id, args, expected]
  rows:
    - [two_words,   ["hello world"], "Hello World"]
    - [padded,      ["  hello  "],   "Hello"]
    - [all_caps,    ["HELLO"],       "Hello"]
