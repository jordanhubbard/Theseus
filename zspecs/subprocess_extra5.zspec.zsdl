spec: subprocess_extra5
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
  notes:
    - "This spec extends prior subprocess specs."
    - "Focus: class names and constants not yet covered."
    - "subprocess.PIPE == -1."
    - "subprocess.STDOUT == -2."
    - "subprocess.DEVNULL == -3."
    - "subprocess.CompletedProcess.__name__ == 'CompletedProcess'."
    - "subprocess.CalledProcessError.__name__ == 'CalledProcessError'."
    - "subprocess.TimeoutExpired.__name__ == 'TimeoutExpired'."
    - "subprocess.SubprocessError.__name__ == 'SubprocessError'."
    - "subprocess.Popen.__name__ == 'Popen'."
    - "subprocess.run.__name__ == 'run'."
    - "subprocess.call.__name__ == 'call'."
    - "subprocess.check_call.__name__ == 'check_call'."
    - "subprocess.check_output.__name__ == 'check_output'."
    - "subprocess.CalledProcessError.__bases__[0].__name__ == 'SubprocessError'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table subprocess_extra5.pipe_constants:
  kind: python_call_eq
  category: constants
  id_prefix: pipe

  columns: [id, function, args, expected]
  rows:
    - [PIPE,    PIPE.__eq__,    [-1], true]
    - [STDOUT,  STDOUT.__eq__,  [-2], true]
    - [DEVNULL, DEVNULL.__eq__, [-3], true]

table subprocess_extra5.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [CompletedProcess,   CompletedProcess.__name__.__eq__,   ["CompletedProcess"],   true]
    - [CalledProcessError, CalledProcessError.__name__.__eq__, ["CalledProcessError"], true]
    - [TimeoutExpired,     TimeoutExpired.__name__.__eq__,     ["TimeoutExpired"],     true]
    - [SubprocessError,    SubprocessError.__name__.__eq__,    ["SubprocessError"],    true]
    - [Popen,              Popen.__name__.__eq__,              ["Popen"],              true]

table subprocess_extra5.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [run,             run.__name__.__eq__,             ["run"],             true]
    - [call,            call.__name__.__eq__,            ["call"],            true]
    - [check_call,      check_call.__name__.__eq__,      ["check_call"],      true]
    - [check_output,    check_output.__name__.__eq__,    ["check_output"],    true]
    - [getoutput,       getoutput.__name__.__eq__,       ["getoutput"],       true]
    - [getstatusoutput, getstatusoutput.__name__.__eq__, ["getstatusoutput"], true]

invariant subprocess_extra5.CalledProcessError.base:
  description: "subprocess.CalledProcessError.__bases__[0].__name__ == 'SubprocessError'"
  category: exceptions
  kind: python_call_eq
  function: CalledProcessError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "SubprocessError"

invariant subprocess_extra5.TimeoutExpired.base:
  description: "subprocess.TimeoutExpired.__bases__[0].__name__ == 'SubprocessError'"
  category: exceptions
  kind: python_call_eq
  function: TimeoutExpired.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "SubprocessError"

invariant subprocess_extra5.SubprocessError.base:
  description: "subprocess.SubprocessError.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: SubprocessError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant subprocess_extra5.Popen.module:
  description: "subprocess.Popen.__module__ == 'subprocess'"
  category: module
  kind: python_call_eq
  function: Popen.__module__.__eq__
  args: ["subprocess"]
  expected: true
