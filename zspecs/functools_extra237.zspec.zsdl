spec: functools_extra237
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools.partial keyword and positional args storage contracts via the class-level slot descriptors."
    - "functools.partial.keywords is a C-level member_descriptor slot for storing keyword arguments passed at construction time. Verified with Python 3.14.3."
    - "functools.partial.args is a C-level member_descriptor slot for storing positional arguments passed at construction time. Verified with Python 3.14.3."
    - "functools.partial.func is a C-level member_descriptor slot for storing the wrapped callable. Verified with Python 3.14.3."
    - "functools.partial.keywords.__name__ == 'keywords' (len=8) — the slot descriptor's __name__ is the attribute name 'keywords'. Verified with Python 3.14.3."
    - "functools.partial.args.__name__ == 'args' (len=4) — the slot descriptor's __name__ is the attribute name 'args'. Verified with Python 3.14.3."
    - "functools.partial.func.__name__ == 'func' (len=4) — the slot descriptor's __name__ is the attribute name 'func'. Verified with Python 3.14.3."
    - "functools.partial.keywords.__class__.__name__ == 'member_descriptor' (len=17) — keywords slot is exposed as a member_descriptor on the class. Verified with Python 3.14.3."
    - "functools.partial.args.__class__.__name__ == 'member_descriptor' (len=17) — args slot is exposed as a member_descriptor on the class. Verified with Python 3.14.3."
    - "functools.partial.func.__class__.__name__ == 'member_descriptor' (len=17) — func slot is exposed as a member_descriptor on the class. Verified with Python 3.14.3."
    - "functools.partial.__name__ == 'partial' — the class __name__ is 'partial'. Verified with Python 3.14.3."
    - "functools.partial.__qualname__ == 'partial' — top-level class with unqualified qualname. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial slot descriptor __name__ contracts
#
# partial.keywords.__name__ == 'keywords' (len=8)
# partial.args.__name__ == 'args' (len=4)
# partial.func.__name__ == 'func' (len=4)
#
# The member_descriptor __name__ reflects the attribute name for each storage
# slot of the partial object. New to extra237.
# ---------------------------------------------------------------------------

table functools_extra237.partial_slot_names:
  description: "functools.partial slot descriptor __name__ contracts: keywords/'keywords'(len=8), args/'args'(len=4), func/'func'(len=4); new to extra237"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra237slotnamesid

  columns: [id, function, args, expected, description]
  rows:
    - [keywords_slot_name_eq,
       partial.keywords.__name__.__eq__,
       ["keywords"],
       true,
       "functools.partial.keywords.__name__.__eq__('keywords') == True — the keywords slot descriptor's __name__ is 'keywords', the name of the attribute that stores keyword arguments supplied to partial(); str.__eq__('keywords') returns True; new to extra237"]
    - [keywords_slot_name_len_8,
       partial.keywords.__name__.__len__,
       [],
       8,
       "functools.partial.keywords.__name__.__len__() == 8 — 'keywords' has exactly 8 characters (k-e-y-w-o-r-d-s); str.__len__() returns 8; new to extra237"]
    - [args_slot_name_eq,
       partial.args.__name__.__eq__,
       ["args"],
       true,
       "functools.partial.args.__name__.__eq__('args') == True — the args slot descriptor's __name__ is 'args', the name of the attribute that stores positional arguments supplied to partial(); str.__eq__('args') returns True; new to extra237"]
    - [args_slot_name_len_4,
       partial.args.__name__.__len__,
       [],
       4,
       "functools.partial.args.__name__.__len__() == 4 — 'args' has exactly 4 characters (a-r-g-s); str.__len__() returns 4; new to extra237"]
    - [func_slot_name_eq,
       partial.func.__name__.__eq__,
       ["func"],
       true,
       "functools.partial.func.__name__.__eq__('func') == True — the func slot descriptor's __name__ is 'func', the name of the attribute that stores the wrapped callable; str.__eq__('func') returns True; new to extra237"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial slot descriptor __class__.__name__ contracts
#
# partial.keywords.__class__.__name__ == 'member_descriptor' (len=17)
# partial.args.__class__.__name__ == 'member_descriptor' (len=17)
# partial.func.__class__.__name__ == 'member_descriptor' (len=17)
#
# All three storage slots are C-level member_descriptors. New to extra237.
# ---------------------------------------------------------------------------

table functools_extra237.partial_slot_class_names:
  description: "functools.partial slot descriptor __class__.__name__ contracts: keywords/args/func are all member_descriptor; new to extra237"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra237slotclassid

  columns: [id, function, args, expected, description]
  rows:
    - [keywords_class_name_eq,
       partial.keywords.__class__.__name__.__eq__,
       ["member_descriptor"],
       true,
       "functools.partial.keywords.__class__.__name__.__eq__('member_descriptor') == True — keywords is a C-level slot member; accessing it on the class returns a member_descriptor; its __class__.__name__ is 'member_descriptor' (len=17); new to extra237"]
    - [keywords_class_name_len_17,
       partial.keywords.__class__.__name__.__len__,
       [],
       17,
       "functools.partial.keywords.__class__.__name__.__len__() == 17 — 'member_descriptor' has exactly 17 characters; str.__len__() returns 17; new to extra237"]
    - [args_class_name_eq,
       partial.args.__class__.__name__.__eq__,
       ["member_descriptor"],
       true,
       "functools.partial.args.__class__.__name__.__eq__('member_descriptor') == True — args is a C-level slot member; accessing it on the class returns a member_descriptor; its __class__.__name__ is 'member_descriptor' (len=17); new to extra237"]
    - [func_class_name_eq,
       partial.func.__class__.__name__.__eq__,
       ["member_descriptor"],
       true,
       "functools.partial.func.__class__.__name__.__eq__('member_descriptor') == True — func is a C-level slot member; accessing it on the class returns a member_descriptor; its __class__.__name__ is 'member_descriptor' (len=17); new to extra237"]
    - [func_slot_name_len_4,
       partial.func.__name__.__len__,
       [],
       4,
       "functools.partial.func.__name__.__len__() == 4 — 'func' has exactly 4 characters (f-u-n-c); str.__len__() returns 4; new to extra237"]

# ---------------------------------------------------------------------------
# Table 3: functools.partial class __name__ and __qualname__ contracts
#
# functools.partial.__name__ == 'partial'
# functools.partial.__qualname__ == 'partial'
# functools.partial.__name__.__len__() == 7
# functools.partial.__qualname__.__len__() == 7
# functools.partial.__class__.__name__ == 'type'
#
# New to extra237.
# ---------------------------------------------------------------------------

table functools_extra237.partial_class_identity:
  description: "functools.partial class __name__, __qualname__, __class__.__name__ contracts; new to extra237"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra237classid

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_eq,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial is a C extension type for storing partial function application; its class __name__ is 'partial'; str.__eq__('partial') returns True; new to extra237"]
    - [partial_qualname_eq,
       partial.__qualname__.__eq__,
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — partial is a top-level class with unqualified qualname 'partial'; str.__eq__('partial') returns True; new to extra237"]
    - [partial_name_len_7,
       partial.__name__.__len__,
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — 'partial' has exactly 7 characters (p-a-r-t-i-a-l); str.__len__() returns 7; new to extra237"]
    - [partial_qualname_len_7,
       partial.__qualname__.__len__,
       [],
       7,
       "functools.partial.__qualname__.__len__() == 7 — qualname 'partial' has exactly 7 characters; str.__len__() returns 7; new to extra237"]
    - [partial_class_is_type,
       partial.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is a C extension type; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra237"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra237
# ---------------------------------------------------------------------------

invariant functools_extra237.keywords_slot_name_eq:
  description: "functools.partial.keywords.__name__ == 'keywords' — slot descriptor name for keyword args storage; new to extra237"
  kind: python_call_eq
  function: partial.keywords.__name__.__eq__
  args: ["keywords"]
  expected: true

invariant functools_extra237.keywords_slot_name_len_8:
  description: "functools.partial.keywords.__name__.__len__() == 8 — 'keywords' has 8 characters; new to extra237"
  kind: python_call_eq
  function: partial.keywords.__name__.__len__
  args: []
  expected: 8

invariant functools_extra237.args_slot_name_eq:
  description: "functools.partial.args.__name__ == 'args' — slot descriptor name for positional args storage; new to extra237"
  kind: python_call_eq
  function: partial.args.__name__.__eq__
  args: ["args"]
  expected: true

invariant functools_extra237.args_slot_name_len_4:
  description: "functools.partial.args.__name__.__len__() == 4 — 'args' has 4 characters; new to extra237"
  kind: python_call_eq
  function: partial.args.__name__.__len__
  args: []
  expected: 4

invariant functools_extra237.func_slot_name_eq:
  description: "functools.partial.func.__name__ == 'func' — slot descriptor name for wrapped callable storage; new to extra237"
  kind: python_call_eq
  function: partial.func.__name__.__eq__
  args: ["func"]
  expected: true

invariant functools_extra237.keywords_class_name_eq:
  description: "functools.partial.keywords.__class__.__name__ == 'member_descriptor' — keywords slot is a C-level member_descriptor; new to extra237"
  kind: python_call_eq
  function: partial.keywords.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant functools_extra237.args_class_name_eq:
  description: "functools.partial.args.__class__.__name__ == 'member_descriptor' — args slot is a C-level member_descriptor; new to extra237"
  kind: python_call_eq
  function: partial.args.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant functools_extra237.func_class_name_eq:
  description: "functools.partial.func.__class__.__name__ == 'member_descriptor' — func slot is a C-level member_descriptor; new to extra237"
  kind: python_call_eq
  function: partial.func.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant functools_extra237.partial_name_eq:
  description: "functools.partial.__name__ == 'partial' — class name of the partial type; new to extra237"
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra237.partial_qualname_eq:
  description: "functools.partial.__qualname__ == 'partial' — unqualified top-level class qualname; new to extra237"
  kind: python_call_eq
  function: partial.__qualname__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra237.partial_class_is_type:
  description: "functools.partial.__class__.__name__ == 'type' — partial is a C extension type; new to extra237"
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true
