spec: pathlib_extra105
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra104

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra104.zspec.zsdl."
    - "This spec covers: pathlib.PurePosixPath and pathlib.PureWindowsPath class identity and method class names."
    - "pathlib.PurePosixPath.__class__.__name__ = 'type' — PurePosixPath uses the standard type metaclass (not ABCMeta like io.IOBase)."
    - "pathlib.PurePosixPath.__module__ = 'pathlib' — defined in the public pathlib package."
    - "pathlib.PurePosixPath.__bases__[0].__name__ = 'PurePath' — PurePosixPath directly extends PurePath."
    - "pathlib.PurePosixPath.__mro__.__len__() = 3 — MRO is [PurePosixPath, PurePath, object]."
    - "pathlib.PurePosixPath.__qualname__ = 'PurePosixPath' (length 13)."
    - "pathlib.PureWindowsPath.__class__.__name__ = 'type' — same metaclass as PurePosixPath."
    - "pathlib.PureWindowsPath.__module__ = 'pathlib' — same module."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ = 'PurePath' — same parent."
    - "pathlib.PureWindowsPath.__mro__.__len__() = 3 — same depth."
    - "pathlib.PureWindowsPath.__qualname__ = 'PureWindowsPath' (length 15)."
    - "PurePosixPath has no methods of its own in its __dict__; all methods (with_name, with_suffix, relative_to, etc.) are inherited from PurePath."
    - "PurePath methods (with_name, with_suffix, with_stem, relative_to, is_relative_to, joinpath) are all pure Python 'function' objects."
    - "PurePath properties (parts, parent, name, suffix, stem, anchor, drive, root, suffixes, parents) are all 'property' objects."
    - "pathlib.PurePath.with_name.__qualname__ = 'PurePath.with_name' (length 18)."
    - "pathlib.PurePath.relative_to.__qualname__ = 'PurePath.relative_to' (length 20)."
    - "pathlib.PurePath.is_relative_to.__qualname__ = 'PurePath.is_relative_to' (length 23)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath class identity
# PurePosixPath uses the standard 'type' metaclass (unlike io.IOBase which
# uses ABCMeta). It has no methods of its own; all are inherited from PurePath.
# MRO length == 3 (PurePosixPath, PurePath, object).
# ---------------------------------------------------------------------------

table pathlib_extra105.PurePosixPath_class_identity:
  description: "pathlib.PurePosixPath class identity: __class__.__name__, __module__, __name__, __qualname__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibpureclsid105

  columns: [id, function, args, expected, description]
  rows:
    - [ppp_meta_eq,       PurePosixPath.__class__.__name__.__eq__,           ["type"],          true,  "PurePosixPath.__class__.__name__ == 'type' (uses the standard type metaclass, not ABCMeta)"]
    - [ppp_module_eq,     PurePosixPath.__module__.__eq__,                   ["pathlib"],       true,  "PurePosixPath.__module__ == 'pathlib'"]
    - [ppp_name_eq,       PurePosixPath.__name__.__eq__,                     ["PurePosixPath"], true,  "PurePosixPath.__name__ == 'PurePosixPath' (bare class name)"]
    - [ppp_qualname_eq,   PurePosixPath.__qualname__.__eq__,                 ["PurePosixPath"], true,  "PurePosixPath.__qualname__ == 'PurePosixPath' (no enclosing class)"]
    - [ppp_qualname_len,  PurePosixPath.__qualname__.__len__,                [],                13,    "PurePosixPath.__qualname__.__len__() == 13 ('PurePosixPath' has 13 characters)"]
    - [ppp_base_eq,       "PurePosixPath.__bases__[0].__name__.__eq__",        ["PurePath"],      true,  "PurePosixPath.__bases__[0].__name__ == 'PurePath' (directly extends PurePath)"]
    - [ppp_mro_len,       PurePosixPath.__mro__.__len__,                     [],                3,     "PurePosixPath.__mro__.__len__() == 3 (MRO is [PurePosixPath, PurePath, object])"]
    - [ppp_meta_not_abc,  PurePosixPath.__class__.__name__.__eq__,           ["ABCMeta"],       false, "PurePosixPath.__class__.__name__ is NOT 'ABCMeta' (pathlib pure path classes use plain 'type', unlike io abstract base classes)"]

# ---------------------------------------------------------------------------
# pathlib.PureWindowsPath class identity
# PureWindowsPath mirrors PurePosixPath: same metaclass, same MRO depth,
# same parent (PurePath). Only differs in name and parser attribute.
# ---------------------------------------------------------------------------

table pathlib_extra105.PureWindowsPath_class_identity:
  description: "pathlib.PureWindowsPath class identity: __class__.__name__, __module__, __name__, __qualname__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibpureclsid105

  columns: [id, function, args, expected, description]
  rows:
    - [pwp_meta_eq,       PureWindowsPath.__class__.__name__.__eq__,          ["type"],            true,  "PureWindowsPath.__class__.__name__ == 'type' (standard metaclass)"]
    - [pwp_module_eq,     PureWindowsPath.__module__.__eq__,                  ["pathlib"],         true,  "PureWindowsPath.__module__ == 'pathlib'"]
    - [pwp_name_eq,       PureWindowsPath.__name__.__eq__,                    ["PureWindowsPath"], true,  "PureWindowsPath.__name__ == 'PureWindowsPath' (bare class name)"]
    - [pwp_qualname_eq,   PureWindowsPath.__qualname__.__eq__,                ["PureWindowsPath"], true,  "PureWindowsPath.__qualname__ == 'PureWindowsPath'"]
    - [pwp_qualname_len,  PureWindowsPath.__qualname__.__len__,               [],                  15,    "PureWindowsPath.__qualname__.__len__() == 15 ('PureWindowsPath' has 15 characters)"]
    - [pwp_base_eq,       "PureWindowsPath.__bases__[0].__name__.__eq__",       ["PurePath"],        true,  "PureWindowsPath.__bases__[0].__name__ == 'PurePath' (directly extends PurePath)"]
    - [pwp_mro_len,       PureWindowsPath.__mro__.__len__,                    [],                  3,     "PureWindowsPath.__mro__.__len__() == 3 (MRO is [PureWindowsPath, PurePath, object])"]
    - [pwp_mro_not_5,     PureWindowsPath.__mro__.__len__.__eq__,             [5],                 false, "PureWindowsPath.__mro__.__len__() is NOT 5 (PureWindowsPath is a pure-path type with depth 3; only PosixPath/WindowsPath reach depth 5)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath method and property class names
# All PurePath methods are pure Python 'function' objects;
# PurePath 'properties' (parts, parent, name, suffix, stem, etc.) are 'property'.
# PurePosixPath and PureWindowsPath inherit all of these from PurePath.
# ---------------------------------------------------------------------------

table pathlib_extra105.PurePath_method_and_property_class_names:
  description: "pathlib.PurePath methods are 'function'; PurePath properties (parts, parent, name, suffix, stem, anchor, drive, root) are 'property'"
  kind: python_call_eq
  category: method_class_names
  id_prefix: pathlibpureclsid105

  columns: [id, function, args, expected, description]
  rows:
    - [pp_with_name_cls,      PurePath.with_name.__class__.__name__.__eq__,      ["function"],  true,  "PurePath.with_name is a pure Python function"]
    - [pp_with_suffix_cls,    PurePath.with_suffix.__class__.__name__.__eq__,    ["function"],  true,  "PurePath.with_suffix is a pure Python function"]
    - [pp_with_stem_cls,      PurePath.with_stem.__class__.__name__.__eq__,      ["function"],  true,  "PurePath.with_stem is a pure Python function"]
    - [pp_relative_to_cls,    PurePath.relative_to.__class__.__name__.__eq__,    ["function"],  true,  "PurePath.relative_to is a pure Python function"]
    - [pp_is_relative_to_cls, PurePath.is_relative_to.__class__.__name__.__eq__, ["function"],  true,  "PurePath.is_relative_to is a pure Python function"]
    - [pp_joinpath_cls,       PurePath.joinpath.__class__.__name__.__eq__,       ["function"],  true,  "PurePath.joinpath is a pure Python function"]
    - [pp_parts_cls,          PurePath.parts.__class__.__name__.__eq__,          ["property"],  true,  "PurePath.parts is a 'property' descriptor (not a regular function)"]
    - [pp_parent_cls,         PurePath.parent.__class__.__name__.__eq__,         ["property"],  true,  "PurePath.parent is a 'property' descriptor"]
    - [pp_name_cls,           PurePath.name.__class__.__name__.__eq__,           ["property"],  true,  "PurePath.name is a 'property' descriptor"]
    - [pp_suffix_cls,         PurePath.suffix.__class__.__name__.__eq__,         ["property"],  true,  "PurePath.suffix is a 'property' descriptor"]
    - [pp_stem_cls,           PurePath.stem.__class__.__name__.__eq__,           ["property"],  true,  "PurePath.stem is a 'property' descriptor"]
    - [pp_with_name_qn_len,   PurePath.with_name.__qualname__.__len__,           [],            18,    "PurePath.with_name.__qualname__ is 'PurePath.with_name' (18 chars)"]
    - [pp_relative_to_qn_len, PurePath.relative_to.__qualname__.__len__,         [],            20,    "PurePath.relative_to.__qualname__ is 'PurePath.relative_to' (20 chars)"]
    - [pp_is_rel_qn_len,      PurePath.is_relative_to.__qualname__.__len__,      [],            23,    "PurePath.is_relative_to.__qualname__ is 'PurePath.is_relative_to' (23 chars)"]
    - [pp_joinpath_qn_len,    PurePath.joinpath.__qualname__.__len__,            [],            17,    "PurePath.joinpath.__qualname__ is 'PurePath.joinpath' (17 chars)"]
    - [pp_parts_not_fn,       PurePath.parts.__class__.__name__.__eq__,          ["function"],  false, "PurePath.parts is NOT a 'function' (path components like parts, parent, name are property descriptors, not plain methods)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra105.PurePosixPath.metaclass_is_type:
  description: "pathlib.PurePosixPath.__class__.__name__ == 'type' (PurePosixPath uses the standard type metaclass; unlike io's abstract base classes which use ABCMeta, pathlib's pure path classes are plain types)"
  category: class_identity
  kind: python_call_eq
  function: PurePosixPath.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant pathlib_extra105.PurePosixPath.base_is_PurePath:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' (PurePosixPath directly extends PurePath, which is the root of the pathlib class hierarchy)"
  category: class_identity
  kind: python_call_eq
  function: PurePosixPath.__bases__[0].__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra105.PureWindowsPath.mro_len_3:
  description: "pathlib.PureWindowsPath.__mro__.__len__() == 3 (the MRO of PureWindowsPath is [PureWindowsPath, PurePath, object]; it shares the same depth as PurePosixPath)"
  category: class_identity
  kind: python_call_eq
  function: PureWindowsPath.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra105.PurePath.with_name_is_function:
  description: "pathlib.PurePath.with_name.__class__.__name__ == 'function' (all PurePath manipulation methods are pure Python functions defined in pathlib; they are inherited by both PurePosixPath and PureWindowsPath)"
  category: method_class_names
  kind: python_call_eq
  function: PurePath.with_name.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra105.PurePath.parts_is_property:
  description: "pathlib.PurePath.parts.__class__.__name__ == 'property' (path component accessors like parts, parent, name, suffix, and stem are Python property descriptors, not plain functions; they compute their values lazily on access)"
  category: method_class_names
  kind: python_call_eq
  function: PurePath.parts.__class__.__name__.__eq__
  args: ["property"]
  expected: true
