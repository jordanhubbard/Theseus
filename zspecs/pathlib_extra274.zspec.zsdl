spec: pathlib_extra274
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "pathlib.PurePath methods (joinpath, relative_to, is_relative_to, with_name, with_suffix, with_stem, as_posix, as_uri) are plain Python functions."
    - "All PurePath method __class__.__name__ == 'function'."
    - "PurePath method qualnames follow 'PurePath.<method_name>' pattern."
    - "pathlib.Path.glob, rglob, iterdir are also plain Python functions with qualnames 'Path.<method_name>'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: PurePath method __name__ identity
# ---------------------------------------------------------------------------

table pathlib_extra274.purepath_method_names:
  description: "pathlib.PurePath method __name__ for joinpath, relative_to, is_relative_to, with_name, with_suffix, with_stem, as_posix, as_uri"
  kind: python_call_eq
  category: identity
  id_prefix: nm

  columns: [id, function, args, expected, description]
  rows:
    - [joinpath_name,      PurePath.joinpath.__name__.__eq__,      ["joinpath"],      true, "pathlib.PurePath.joinpath.__name__ == 'joinpath'"]
    - [relative_to_name,   PurePath.relative_to.__name__.__eq__,   ["relative_to"],   true, "pathlib.PurePath.relative_to.__name__ == 'relative_to'"]
    - [is_relative_name,   PurePath.is_relative_to.__name__.__eq__, ["is_relative_to"], true, "pathlib.PurePath.is_relative_to.__name__ == 'is_relative_to'"]
    - [with_name_name,     PurePath.with_name.__name__.__eq__,     ["with_name"],     true, "pathlib.PurePath.with_name.__name__ == 'with_name'"]
    - [with_suffix_name,   PurePath.with_suffix.__name__.__eq__,   ["with_suffix"],   true, "pathlib.PurePath.with_suffix.__name__ == 'with_suffix'"]
    - [with_stem_name,     PurePath.with_stem.__name__.__eq__,     ["with_stem"],     true, "pathlib.PurePath.with_stem.__name__ == 'with_stem'"]
    - [as_posix_name,      PurePath.as_posix.__name__.__eq__,      ["as_posix"],      true, "pathlib.PurePath.as_posix.__name__ == 'as_posix'"]
    - [as_uri_name,        PurePath.as_uri.__name__.__eq__,        ["as_uri"],        true, "pathlib.PurePath.as_uri.__name__ == 'as_uri'"]

# ---------------------------------------------------------------------------
# Table: PurePath method __class__.__name__ (all 'function')
# ---------------------------------------------------------------------------

table pathlib_extra274.purepath_method_classes:
  description: "pathlib.PurePath method __class__.__name__ for joinpath, relative_to, is_relative_to, with_name, with_suffix, with_stem, as_posix, as_uri"
  kind: python_call_eq
  category: identity
  id_prefix: cls

  columns: [id, function, args, expected, description]
  rows:
    - [joinpath_class,    PurePath.joinpath.__class__.__name__.__eq__,      ["function"], true, "pathlib.PurePath.joinpath.__class__.__name__ == 'function'"]
    - [relative_to_class, PurePath.relative_to.__class__.__name__.__eq__,   ["function"], true, "pathlib.PurePath.relative_to.__class__.__name__ == 'function'"]
    - [is_relative_class, PurePath.is_relative_to.__class__.__name__.__eq__, ["function"], true, "pathlib.PurePath.is_relative_to.__class__.__name__ == 'function'"]
    - [with_name_class,   PurePath.with_name.__class__.__name__.__eq__,     ["function"], true, "pathlib.PurePath.with_name.__class__.__name__ == 'function'"]
    - [with_suffix_class, PurePath.with_suffix.__class__.__name__.__eq__,   ["function"], true, "pathlib.PurePath.with_suffix.__class__.__name__ == 'function'"]
    - [with_stem_class,   PurePath.with_stem.__class__.__name__.__eq__,     ["function"], true, "pathlib.PurePath.with_stem.__class__.__name__ == 'function'"]
    - [as_posix_class,    PurePath.as_posix.__class__.__name__.__eq__,      ["function"], true, "pathlib.PurePath.as_posix.__class__.__name__ == 'function'"]
    - [as_uri_class,      PurePath.as_uri.__class__.__name__.__eq__,        ["function"], true, "pathlib.PurePath.as_uri.__class__.__name__ == 'function'"]

# ---------------------------------------------------------------------------
# Standalone invariants: PurePath qualnames and Path-specific methods
# ---------------------------------------------------------------------------

invariant pathlib_extra274.PurePath.joinpath.qualname:
  description: "pathlib.PurePath.joinpath.__qualname__ == 'PurePath.joinpath'"
  category: identity
  kind: python_call_eq
  function: PurePath.joinpath.__qualname__.__eq__
  args: ["PurePath.joinpath"]
  expected: true

invariant pathlib_extra274.PurePath.relative_to.qualname:
  description: "pathlib.PurePath.relative_to.__qualname__ == 'PurePath.relative_to'"
  category: identity
  kind: python_call_eq
  function: PurePath.relative_to.__qualname__.__eq__
  args: ["PurePath.relative_to"]
  expected: true

invariant pathlib_extra274.Path.glob.name:
  description: "pathlib.Path.glob.__name__ == 'glob'"
  category: identity
  kind: python_call_eq
  function: Path.glob.__name__.__eq__
  args: ["glob"]
  expected: true

invariant pathlib_extra274.Path.rglob.name:
  description: "pathlib.Path.rglob.__name__ == 'rglob'"
  category: identity
  kind: python_call_eq
  function: Path.rglob.__name__.__eq__
  args: ["rglob"]
  expected: true

invariant pathlib_extra274.Path.iterdir.name:
  description: "pathlib.Path.iterdir.__name__ == 'iterdir'"
  category: identity
  kind: python_call_eq
  function: Path.iterdir.__name__.__eq__
  args: ["iterdir"]
  expected: true

invariant pathlib_extra274.Path.glob.is_function:
  description: "pathlib.Path.glob is a plain Python function"
  category: identity
  kind: python_call_eq
  function: Path.glob.__class__.__name__.__eq__
  args: ["function"]
  expected: true
