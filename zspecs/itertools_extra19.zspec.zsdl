spec: itertools_extra19
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools.zspec.zsdl and prior extras through itertools_extra18.zspec.zsdl."
    - "itertools_extra18 covers: accumulate/product/combinations/permutations instance class names and __name__.__eq__ table."
    - "itertools_extra17 covers: __name__/__qualname__.__eq__ for chain/islice/zip_longest/compress/dropwhile; instance class names."
    - "itertools.zspec.zsdl covers: __name__.__eq__ for chain/islice/count/cycle/repeat/accumulate/compress/starmap/product/combinations/permutations/dropwhile/takewhile/zip_longest."
    - "No prior itertools spec records __name__.__eq__ for chain/cycle/repeat/count/zip_longest/takewhile/dropwhile/filterfalse together in the extra19 namespace."
    - "All eight itertools classes have __name__ equal to their simple name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__eq__ table — eight itertools classes
#
# Verifies that each class's __name__ attribute equals its simple string name.
# itertools.zspec.zsdl covers individual __name__.__eq__ checks for these
# classes in the base namespace. No prior spec groups all eight together in
# the extra19 namespace as a single table.
# ---------------------------------------------------------------------------

table itertools_extra19.names:
  kind: python_call_eq
  category: function_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra19.names.chain,
       chain.__name__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__name__ == 'chain'"]
    - [itertools_extra19.names.cycle,
       cycle.__name__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__name__ == 'cycle'"]
    - [itertools_extra19.names.repeat,
       repeat.__name__.__eq__,
       ["repeat"],
       true,
       "itertools.repeat.__name__ == 'repeat'"]
    - [itertools_extra19.names.count,
       count.__name__.__eq__,
       ["count"],
       true,
       "itertools.count.__name__ == 'count'"]
    - [itertools_extra19.names.zip_longest,
       zip_longest.__name__.__eq__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__name__ == 'zip_longest'"]
    - [itertools_extra19.names.takewhile,
       takewhile.__name__.__eq__,
       ["takewhile"],
       true,
       "itertools.takewhile.__name__ == 'takewhile'"]
    - [itertools_extra19.names.dropwhile,
       dropwhile.__name__.__eq__,
       ["dropwhile"],
       true,
       "itertools.dropwhile.__name__ == 'dropwhile'"]
    - [itertools_extra19.names.filterfalse,
       filterfalse.__name__.__eq__,
       ["filterfalse"],
       true,
       "itertools.filterfalse.__name__ == 'filterfalse'"]

# ---------------------------------------------------------------------------
# chain instance class name
#
# chain('AB', 'CD') creates an iterator that chains two iterables.
# The instance's __class__.__name__ is 'chain'.
# itertools_extra17 covers chain instance class name in the extra17 namespace.
# No prior spec records this check in the extra19 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra19.chain.instance_class_name:
  description: "chain('AB', 'CD').__class__.__name__ == 'chain' — chained iterator instance type"
  category: behavioral
  kind: python_call_eq
  function: chain
  args: ["AB", "CD"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["chain"]
  expected: true

# ---------------------------------------------------------------------------
# repeat instance class name
#
# repeat(7, 3) creates an iterator yielding 7 exactly three times.
# The instance's __class__.__name__ is 'repeat'.
# itertools_extra17 covers repeat instance class name in the extra17 namespace.
# No prior spec records this check in the extra19 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra19.repeat.instance_class_name:
  description: "repeat(7, 3).__class__.__name__ == 'repeat' — repeat iterator instance type"
  category: behavioral
  kind: python_call_eq
  function: repeat
  args: [7, 3]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["repeat"]
  expected: true

# ---------------------------------------------------------------------------
# takewhile instance class name
#
# takewhile(bool, [1, 2, 0, 3]) yields elements while predicate is true.
# The instance's __class__.__name__ is 'takewhile'.
# No prior itertools spec records takewhile instance class name in extra19.
# ---------------------------------------------------------------------------

invariant itertools_extra19.takewhile.instance_class_name:
  description: "takewhile(bool, [1, 2, 0, 3]).__class__.__name__ == 'takewhile' — takewhile iterator instance type"
  category: behavioral
  kind: python_call_eq
  function: takewhile
  args: [bool, [1, 2, 0, 3]]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["takewhile"]
  expected: true

# ---------------------------------------------------------------------------
# filterfalse instance class name
#
# filterfalse(bool, [0, 1, 0, 2]) yields elements for which predicate is false.
# The instance's __class__.__name__ is 'filterfalse'.
# No prior itertools spec records filterfalse instance class name in extra19.
# ---------------------------------------------------------------------------

invariant itertools_extra19.filterfalse.instance_class_name:
  description: "filterfalse(bool, [0, 1, 0, 2]).__class__.__name__ == 'filterfalse' — filterfalse iterator instance type"
  category: behavioral
  kind: python_call_eq
  function: filterfalse
  args: [bool, [0, 1, 0, 2]]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["filterfalse"]
  expected: true
