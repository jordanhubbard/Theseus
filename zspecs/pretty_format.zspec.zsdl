spec: pretty_format
version: ">=29.0.0"
backend: node(pretty-format)

docs: https://github.com/jestjs/jest/tree/main/packages/pretty-format

provenance:
  derived_from:
    - "pretty-format README — https://github.com/jestjs/jest/tree/main/packages/pretty-format"
    - "Test vectors verified with pretty-format via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "pretty-format source"
  notes:
    - "pretty-format is Jest's serializer — produces minimal, equality-friendly output for snapshots and assertion diffs."
    - "Install: npm install pretty-format"
    - "format(value, options?) returns a string; deterministic given the same input/options."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on any input (including circular references with default plugins)."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table pretty_format.format:
  kind: node_module_call_eq
  category: format
  function: format
  id_prefix: format

  columns: [id, args, expected]
  rows:
    - [primitive_number,    [42],                         "42"]
    - [primitive_string,    ["hello"],                    "\"hello\""]
    - [primitive_true,      [true],                        "true"]
    - [primitive_false,     [false],                       "false"]
    - [primitive_null,      [~],                            "null"]
    - [empty_object,        [{}],                           "Object {}"]
    - [empty_array,         [[]],                            "Array []"]
    - [single_pair_object,
       [{a: 1}],
       "Object {\n  \"a\": 1,\n}"]

    - [array_three,
       [[1, 2, 3]],
       "Array [\n  1,\n  2,\n  3,\n]"]

    - [nested_object,
       [{a: {b: 1}}],
       "Object {\n  \"a\": Object {\n    \"b\": 1,\n  },\n}"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:50:56Z
  iterations: 1
  pass_count: 10
  fail_count: 0
  total_invariants: 10
  notes: Synthesis succeeded in 1 iteration(s). 10 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
