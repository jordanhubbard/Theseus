spec: functools_extra209
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools_extra.zspec.zsdl — covers __name__ and __module__ checks for reduce, partial, cached_property, cmp_to_key, total_ordering, singledispatch"
    - "functools_extra191.zspec.zsdl — covers partial slot descriptor types, __doc__/__class__ identity, __module__ checks for partial and partialmethod"
  notes:
    - "functools.__all__ exists and is a list; confirmed with Python 3.14.3."
    - "functools.__all__.__class__.__name__ == 'list' — the __all__ export list is a plain Python list."
    - "functools.__all__.__len__() == 15 — there are exactly 15 public exports in Python 3.14.3 (includes Placeholder added in 3.14)."
    - "functools.__all__.__contains__('reduce') == True — reduce is a public export."
    - "functools.__all__.__contains__('lru_cache') == True — lru_cache is a public export."
    - "functools.__all__.__contains__('partial') == True — partial is a public export."
    - "functools.__all__.__contains__('wraps') == True — wraps is a public export."
    - "functools.__all__.__contains__('cache') == True — cache was added in Python 3.9."
    - "functools.__all__.__contains__('total_ordering') == True — total_ordering is a public export."
    - "functools.__all__.__contains__('singledispatch') == True — singledispatch is a public export."
    - "functools.__all__.__contains__('update_wrapper') == True — update_wrapper is a public export."
    - "functools.__all__.__contains__('cached_property') == True — cached_property is a public export."
    - "functools.__all__.__contains__('missing_func') == False — a nonexistent name is not in __all__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.__all__ class identity and length
#
# functools.__all__.__class__.__name__ == 'list'
# functools.__all__.__len__() == 15
#
# The __all__ attribute of functools is a plain Python list containing exactly
# 15 entries in Python 3.14.3 (includes 'Placeholder' added in 3.14).
# ---------------------------------------------------------------------------

table functools_extra209.all_identity:
  description: "functools.__all__ is a list with exactly 15 entries; class name and length checks; new to extra209"
  kind: python_call_eq
  category: all_list
  id_prefix: functall209

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_name_eq,
       "__all__.__class__.__name__.__eq__",
       ["list"],
       true,
       "functools.__all__.__class__.__name__.__eq__('list') == True — __all__ is a plain Python list; verified with Python 3.14.3; new to extra209"]
    - [all_len_15,
       "__all__.__len__",
       [],
       15,
       "functools.__all__.__len__() == 15 — there are exactly 15 public exports listed in functools.__all__ in Python 3.14.3; verified with Python 3.14.3; new to extra209"]
    - [all_contains_reduce,
       "__all__.__contains__",
       ["reduce"],
       true,
       "functools.__all__.__contains__('reduce') == True — 'reduce' is listed as a public export in functools.__all__; verified with Python 3.14.3; new to extra209"]
    - [all_contains_lru_cache,
       "__all__.__contains__",
       ["lru_cache"],
       true,
       "functools.__all__.__contains__('lru_cache') == True — 'lru_cache' is listed as a public export in functools.__all__; verified with Python 3.14.3; new to extra209"]

# ---------------------------------------------------------------------------
# Table 2: functools.__all__ membership — core decorator exports
#
# Checks that wraps, partial, cache, update_wrapper are in __all__.
# cache was added in Python 3.9 so the spec requires version >=3.9.
# ---------------------------------------------------------------------------

table functools_extra209.all_core_exports:
  description: "functools.__all__ contains wraps, partial, cache (>=3.9), and update_wrapper; membership checks; new to extra209"
  kind: python_call_eq
  category: all_list
  id_prefix: functall209

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_wraps,
       "__all__.__contains__",
       ["wraps"],
       true,
       "functools.__all__.__contains__('wraps') == True — 'wraps' is a public export; verified with Python 3.14.3; new to extra209"]
    - [all_contains_partial,
       "__all__.__contains__",
       ["partial"],
       true,
       "functools.__all__.__contains__('partial') == True — 'partial' is a public export; verified with Python 3.14.3; new to extra209"]
    - [all_contains_cache,
       "__all__.__contains__",
       ["cache"],
       true,
       "functools.__all__.__contains__('cache') == True — 'cache' (a simple unbounded alias for lru_cache(maxsize=None)) was added in Python 3.9 and is a public export; verified with Python 3.14.3; new to extra209"]
    - [all_contains_update_wrapper,
       "__all__.__contains__",
       ["update_wrapper"],
       true,
       "functools.__all__.__contains__('update_wrapper') == True — 'update_wrapper' is a public export; verified with Python 3.14.3; new to extra209"]

# ---------------------------------------------------------------------------
# Table 3: functools.__all__ membership — class/dispatch exports and negation
#
# Checks that total_ordering, singledispatch, cached_property are in __all__,
# and that a nonexistent name 'missing_func' is not in __all__.
# ---------------------------------------------------------------------------

table functools_extra209.all_dispatch_exports:
  description: "functools.__all__ contains total_ordering, singledispatch, cached_property and does not contain 'missing_func'; new to extra209"
  kind: python_call_eq
  category: all_list
  id_prefix: functall209

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_total_ordering,
       "__all__.__contains__",
       ["total_ordering"],
       true,
       "functools.__all__.__contains__('total_ordering') == True — 'total_ordering' is a public export; verified with Python 3.14.3; new to extra209"]
    - [all_contains_singledispatch,
       "__all__.__contains__",
       ["singledispatch"],
       true,
       "functools.__all__.__contains__('singledispatch') == True — 'singledispatch' is a public export; verified with Python 3.14.3; new to extra209"]
    - [all_contains_cached_property,
       "__all__.__contains__",
       ["cached_property"],
       true,
       "functools.__all__.__contains__('cached_property') == True — 'cached_property' is a public export; verified with Python 3.14.3; new to extra209"]
    - [all_not_contains_missing_func,
       "__all__.__contains__",
       ["missing_func"],
       false,
       "functools.__all__.__contains__('missing_func') == False — 'missing_func' is not a name in functools and is absent from __all__; verified with Python 3.14.3; new to extra209"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra209
# ---------------------------------------------------------------------------

invariant functools_extra209.all_is_list:
  description: "functools.__all__.__class__.__name__ == 'list' — the module's public export list is a plain Python list; verified with Python 3.14.3; new to extra209"
  category: all_list
  kind: python_call_eq
  function: "__all__.__class__.__name__.__eq__"
  args: ["list"]
  expected: true

invariant functools_extra209.all_len_is_15:
  description: "functools.__all__.__len__() == 15 — exactly 15 names are listed in functools.__all__ in Python 3.14.3; verified with Python 3.14.3; new to extra209"
  category: all_list
  kind: python_call_eq
  function: "__all__.__len__"
  args: []
  expected: 15

invariant functools_extra209.all_has_reduce:
  description: "functools.__all__.__contains__('reduce') == True — 'reduce' is a public functools export; verified with Python 3.14.3; new to extra209"
  category: all_list
  kind: python_call_eq
  function: "__all__.__contains__"
  args: ["reduce"]
  expected: true

invariant functools_extra209.all_has_lru_cache:
  description: "functools.__all__.__contains__('lru_cache') == True — 'lru_cache' is a public functools export; verified with Python 3.14.3; new to extra209"
  category: all_list
  kind: python_call_eq
  function: "__all__.__contains__"
  args: ["lru_cache"]
  expected: true

invariant functools_extra209.all_has_partial:
  description: "functools.__all__.__contains__('partial') == True — 'partial' is a public functools export; verified with Python 3.14.3; new to extra209"
  category: all_list
  kind: python_call_eq
  function: "__all__.__contains__"
  args: ["partial"]
  expected: true

invariant functools_extra209.all_has_wraps:
  description: "functools.__all__.__contains__('wraps') == True — 'wraps' is a public functools export; verified with Python 3.14.3; new to extra209"
  category: all_list
  kind: python_call_eq
  function: "__all__.__contains__"
  args: ["wraps"]
  expected: true

invariant functools_extra209.all_has_cache:
  description: "functools.__all__.__contains__('cache') == True — 'cache' (added in Python 3.9) is a public functools export; verified with Python 3.14.3; new to extra209"
  category: all_list
