spec: hashlib
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified by running Python 3.14.3 hashlib and cross-checking with openssl dgst and sha256sum on macOS/Darwin 25.3.0, 2026-03-30"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/_sha512module.c"
    - "CPython source: Modules/md5module.c"
    - "OpenSSL source: crypto/sha/sha256.c"
  notes:
    - "SHA-256('abc') verified value: ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad. This was verified against Python 3.14.3, openssl dgst -sha256, and sha256sum; all three tools agreed. Some published references cite a different value; this spec uses only the machine-verified value."
    - "SHA-256('') = e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855 — this matches the FIPS 180-4 reference."
    - "MD5 and SHA-1 are algorithmically broken for cryptographic use but are behaviorally specified here for completeness and legacy compatibility."
  created_at: "2026-03-30T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Known vectors: SHA-256 (all have FIPS 180-4 rfc)
# ---------------------------------------------------------------------------

table hashlib.sha256.known_vectors:
  kind: hash_known_vector
  category: known_vector
  algorithm: sha256
  id_prefix: sha256

  columns: [id, data_b64, expected_hex, rfc]
  rows:
    - [empty,        "",       "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855", "FIPS 180-4"]
    - [abc,          "YWJj",   "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad", "FIPS 180-4"]
    - [fips_message2,"YWJjZGJjZGVjZGVmZGVmZ2VmZ2hmZ2hpZ2hpamhpamtpamtsamtsbWtsbW5sbW5vbW5vcG5vcHE=",
       "248d6a61d20638b8e5c026930c3e6039a33ce45964ff2167f6ecedd419db06c1", "FIPS 180-4 Appendix B"]

# ---------------------------------------------------------------------------
# Known vectors: SHA-1 (all have FIPS 180-4 rfc)
# ---------------------------------------------------------------------------

table hashlib.sha1.known_vectors:
  kind: hash_known_vector
  category: known_vector
  algorithm: sha1
  id_prefix: sha1

  columns: [id, data_b64, expected_hex, rfc]
  rows:
    - [empty, "",     "da39a3ee5e6b4b0d3255bfef95601890afd80709", "FIPS 180-4"]
    - [abc,   "YWJj", "a9993e364706816aba3e25717850c26c9cd0d89d", "FIPS 180-4"]

# ---------------------------------------------------------------------------
# Known vectors: MD5 (empty/abc have rfc, quick_brown_fox does not)
# ---------------------------------------------------------------------------

table hashlib.md5.rfc_vectors:
  kind: hash_known_vector
  category: known_vector
  algorithm: md5
  id_prefix: md5

  columns: [id, data_b64, expected_hex, rfc]
  rows:
    - [empty, "",     "d41d8cd98f00b204e9800998ecf8427e", "RFC 1321 A.5"]
    - [abc,   "YWJj", "900150983cd24fb0d6963f7d28e17f72", "RFC 1321 A.5"]

invariant hashlib.md5.quick_brown_fox:
  description: "MD5 of the quick-brown-fox test string — widely cited reference vector"
  category: known_vector
  kind: hash_known_vector
  algorithm: md5
  data_b64: "VGhlIHF1aWNrIGJyb3duIGZveCBqdW1wcyBvdmVyIHRoZSBsYXp5IGRvZw=="
  expected_hex: "9e107d9d372bb6826bd81d3542a419d6"

# ---------------------------------------------------------------------------
# Known vectors: SHA-512 (all have FIPS 180-4 rfc)
# ---------------------------------------------------------------------------

table hashlib.sha512.known_vectors:
  kind: hash_known_vector
  category: known_vector
  algorithm: sha512
  id_prefix: sha512

  columns: [id, data_b64, expected_hex, rfc]
  rows:
    - [empty, "", "cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e",
       "FIPS 180-4"]
    - [abc,   "YWJj", "ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f",
       "FIPS 180-4"]

# ---------------------------------------------------------------------------
# Known vectors: SHA3-256 (empty/abc have FIPS 202 rfc, quick_brown_fox does not)
# ---------------------------------------------------------------------------

table hashlib.sha3_256.rfc_vectors:
  kind: hash_known_vector
  category: known_vector
  algorithm: sha3_256
  id_prefix: sha3_256

  columns: [id, data_b64, expected_hex, rfc]
  rows:
    - [empty, "",     "a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a", "FIPS 202"]
    - [abc,   "YWJj", "3a985da74fe225b2045c172d6bd390bd855f086e3e9d525b46bfe24511431532", "FIPS 202"]

invariant hashlib.sha3_256.quick_brown_fox:
  description: "SHA3-256 of 'The quick brown fox jumps over the lazy dog'"
  category: known_vector
  kind: hash_known_vector
  algorithm: sha3_256
  data_b64: "VGhlIHF1aWNrIGJyb3duIGZveCBqdW1wcyBvdmVyIHRoZSBsYXp5IGRvZw=="
  expected_hex: "69070dda01975c8c120c3aada1b282394e7f032fa9cf32f4cb2259a0897dfc04"

# ---------------------------------------------------------------------------
# Known vectors: SHA3-512
# ---------------------------------------------------------------------------

invariant hashlib.sha3_512.abc:
  description: "SHA3-512 of b'abc' — verified against Python 3.14.3"
  category: known_vector
  kind: hash_known_vector
  rfc: "FIPS 202"
  algorithm: sha3_512
  data_b64: "YWJj"
  expected_hex: "b751850b1a57168a5693cd924b6b096e08f621827444f70d884f5d0240d2712e10e116e9192af3c91a7ec57647e3934057340b4cf408d5a56592f8274eec53f0"

# ---------------------------------------------------------------------------
# Known vectors: BLAKE2b (all have RFC 7693)
# ---------------------------------------------------------------------------

table hashlib.blake2b.known_vectors:
  kind: hash_known_vector
  category: known_vector
  algorithm: blake2b
  id_prefix: blake2b

  columns: [id, data_b64, expected_hex, rfc]
  rows:
    - [empty, "", "786a02f742015903c6c6fd852552d272912f4740e15847618a86e217f71f5419d25e1031afee585313896444934eb04b903a685b1448b755d56f701afe9be2ce",
       "RFC 7693"]
    - [abc,   "YWJj", "ba80a53f981c4d0d6a2797b69f12f6e94c212f14685ac4b74b12bb6fdbffa2d17d87c5392aab792dc252d5de4533cc9518d38aa8dbf1925ab92386edd4009923",
       "RFC 7693"]

# ---------------------------------------------------------------------------
# Known vectors: BLAKE2s (all have RFC 7693)
# ---------------------------------------------------------------------------

table hashlib.blake2s.known_vectors:
  kind: hash_known_vector
  category: known_vector
  algorithm: blake2s
  id_prefix: blake2s

  columns: [id, data_b64, expected_hex, rfc]
  rows:
    - [empty, "", "69217a3079908094e11121d042354a7c1f55b6482ca1a51e1b250dfd1ed0eef9", "RFC 7693"]
    - [abc,   "YWJj", "508c5e8c327c14e2e1a72ba34eeb452f37458b209ed63a294d999b4c86675982", "RFC 7693"]

# ---------------------------------------------------------------------------
# Incremental update (no rfc_reference on any)
# ---------------------------------------------------------------------------

table hashlib.incremental:
  kind: hash_incremental
  category: incremental

  columns: [id, algorithm, chunks, full_data_b64]
  rows:
    - [sha256.incremental,   sha256,   [SGVs, "bG8="], "SGVsbG8="]
    - [sha1.incremental,     sha1,     [SGVs, "bG8="], "SGVsbG8="]
    - [md5.incremental,      md5,      [SGVs, "bG8="], "SGVsbG8="]
    - [sha3_256.incremental, sha3_256, [SGVs, "bG8="], "SGVsbG8="]
    - [blake2b.incremental,  blake2b,  [SGVs, "bG8="], "SGVsbG8="]

# ---------------------------------------------------------------------------
# Hash object attributes: SHA-256 (with FIPS 180-4 rfc)
# ---------------------------------------------------------------------------

table hashlib.sha256.attrs:
  kind: hash_object_attr
  category: properties
  algorithm: sha256
  rfc: "FIPS 180-4 Section 1"
  id_prefix: sha256

  columns: [id, attr, expected]
  rows:
    - [digest_size, digest_size, 32]
    - [block_size,  block_size,  64]

# ---------------------------------------------------------------------------
# Hash object attributes: no-rfc group
# ---------------------------------------------------------------------------

table hashlib.attrs_no_rfc:
  kind: hash_object_attr
  category: properties

  columns: [id, algorithm, attr, expected]
  rows:
    - [sha1.digest_size,   sha1,   digest_size, 20]
    - [md5.digest_size,    md5,    digest_size, 16]
    - [sha512.digest_size, sha512, digest_size, 64]

invariant hashlib.sha256.name_attr:
  description: "SHA-256 hash object .name must be 'sha256'"
  category: properties
  kind: hash_object_attr
  algorithm: sha256
  attr: name
  expected: "sha256"

# ---------------------------------------------------------------------------
# Hash object attributes: SHA3-256 (with FIPS 202 rfc)
# ---------------------------------------------------------------------------

table hashlib.sha3_256.attrs:
  kind: hash_object_attr
  category: properties
  algorithm: sha3_256
  rfc: "FIPS 202"
  id_prefix: sha3_256

  columns: [id, attr, expected]
  rows:
    - [digest_size, digest_size, 32]
    - [block_size,  block_size,  136]

# ---------------------------------------------------------------------------
# Hash object attributes: SHA3-512, BLAKE2b, BLAKE2s
# ---------------------------------------------------------------------------

invariant hashlib.sha3_512.digest_size:
  description: "SHA3-512 digest_size must be 64 bytes (512 bits)"
  category: properties
  kind: hash_object_attr
  algorithm: sha3_512
  attr: digest_size
  expected: 64

table hashlib.blake2b.attrs:
  kind: hash_object_attr
  category: properties
  algorithm: blake2b
  rfc: "RFC 7693"
  id_prefix: blake2b

  columns: [id, attr, expected]
  rows:
    - [digest_size, digest_size, 64]
    - [block_size,  block_size,  128]

table hashlib.blake2s.attrs_no_rfc:
  kind: hash_object_attr
  category: properties
  algorithm: blake2s
  id_prefix: blake2s

  columns: [id, attr, expected]
  rows:
    - [digest_size, digest_size, 32]
    - [block_size,  block_size,  64]

# ---------------------------------------------------------------------------
# algorithms_guaranteed membership
# ---------------------------------------------------------------------------

invariant hashlib.algorithms_guaranteed.core_set:
  description: "algorithms_guaranteed must contain the five algorithms required by PEP 247 and universally present: sha1, sha224, sha256, sha384, sha512, md5"
  category: algorithms
  kind: python_set_contains
  attribute: algorithms_guaranteed
  must_contain: [sha1, sha224, sha256, sha384, sha512, md5]

invariant hashlib.algorithms_guaranteed.sha3:
  description: "algorithms_guaranteed must contain sha3_256 and sha3_512 (required since Python 3.6)"
  category: algorithms
  kind: python_set_contains
  attribute: algorithms_guaranteed
  must_contain: [sha3_256, sha3_512, blake2b, blake2s]

# ---------------------------------------------------------------------------
# Digest consistency, copy independence, API equivalence
# ---------------------------------------------------------------------------

invariant hashlib.sha256.digest_consistency:
  description: "h.digest() must equal bytes.fromhex(h.hexdigest()) — both representations of the same hash value"
  category: consistency
  kind: hash_digest_consistency
  algorithm: sha256
  data_b64: "SGVsbG8gV29ybGQ="

invariant hashlib.sha256.copy_independence:
  description: "h.copy() must produce an independent object; updating the copy must not change the original's digest"
  category: copy_semantics
  kind: hash_copy_independence
  algorithm: sha256
  initial_data_b64: "SGVs"
  extra_data_b64: "bG8="

invariant hashlib.sha256.new_equals_constructor:
  description: "hashlib.new('sha256', data) must produce same digest as hashlib.sha256(data)"
  category: api_equivalence
  kind: hash_api_equivalence
  algorithm: sha256
  data_b64: "SGVsbG8gV29ybGQ="

