# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal unary conversion method __name__ values
# __int__ (len=7), __float__ (len=9), __str__ (len=7), __repr__ (len=8)
# ---------------------------------------------------------------------------

table decimal_extra182.conversion_method_names:
  description: "decimal.Decimal conversion method __name__ values: __int__(7), __float__(9), __str__(7), __repr__(8)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalconvert182

  columns: [id, function, args, expected, description]
  rows:
    - [int_name,     Decimal.__int__.__name__.__eq__,    ["__int__"],   true, "decimal.Decimal.__int__.__name__ == '__int__' — converts Decimal to int via truncation; confirmed Python 3.14.3 macOS"]
    - [int_name_len, Decimal.__int__.__name__.__len__,   [],            7,    "decimal.Decimal.__int__.__name__.__len__() == 7 — _(1)_(2)i(3)n(4)t(5)_(6)_(7); confirmed Python 3.14.3 macOS"]
    - [float_name,   Decimal.__float__.__name__.__eq__,  ["__float__"], true, "decimal.Decimal.__float__.__name__ == '__float__' — converts Decimal to float; confirmed Python 3.14.3 macOS"]
    - [float_name_len, Decimal.__float__.__name__.__len__, [],          9,    "decimal.Decimal.__float__.__name__.__len__() == 9 — _(1)_(2)f(3)l(4)o(5)a(6)t(7)_(8)_(9); confirmed Python 3.14.3 macOS"]
    - [str_name,     Decimal.__str__.__name__.__eq__,    ["__str__"],   true, "decimal.Decimal.__str__.__name__ == '__str__' — converts Decimal to human-readable string; confirmed Python 3.14.3 macOS"]

