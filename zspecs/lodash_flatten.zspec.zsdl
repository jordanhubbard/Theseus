spec: lodash_flatten
version: ">=4.0.0"
backend: node(lodash.flatten)

docs: https://lodash.com/docs/#flatten

provenance:
  derived_from:
    - "lodash.flatten README — https://www.npmjs.com/package/lodash.flatten"
    - "Test vectors verified with lodash.flatten@4.4.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.flatten exports the _.flatten function directly as module.exports."
    - "flatten(array) flattens one level deep (not recursive)."
    - "Nested arrays at depth > 1 remain nested after a single flatten."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new flat array. No errors for array inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_flatten.flatten:
  kind: node_module_call_eq
  function: ~
  category: flatten
  id_prefix: lfl

  columns: [id, args, expected]
  rows:
    - [simple,    [[1, [2, 3], 4]],           [1, 2, 3, 4]]
    - [nested,    [[[1, 2], [3, [4]]]],        [1, 2, 3, [4]]]
    - [strings,   [["a", ["b", "c"]]],         ["a", "b", "c"]]
