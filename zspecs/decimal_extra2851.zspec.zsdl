spec: dc2851
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/decimal_extra2836.zspec.zsdl — wave 636 predecessor (covered __rtruediv__, __rfloordiv__, __rmod__)"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "Wave 637 theme: __rlshift__, __rrshift__, and __rpow__ dict-presence checks (reflected left-shift, right-shift, and power operators)."
    - "decimal.Decimal is a full numeric type: it DOES define __rpow__ to support expressions like '2 ** Decimal(10)' via the reflected power protocol."
    - "decimal.Decimal does NOT define __rlshift__ or __rrshift__ — Decimal numbers do not support bitwise shift operations."
    - "decimal.Context is a configuration object, not a numeric value — it does NOT define __rlshift__, __rrshift__, or __rpow__."
    - "decimal exception hierarchy classes (DecimalException and subclasses) do NOT define any reflected shift or power operators."
    - "The asymmetry for __rpow__ (Decimal: true, all others: false) mirrors the prior-wave pattern but for exponentiation rather than division."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __rlshift__ dict-presence
# Absent from Decimal (no bitwise ops), Context, and all exception classes
# ---------------------------------------------------------------------------

table dc2851.rlshift_protocol:
  description: "__rlshift__ is absent from all decimal types — Decimal arithmetic does not include bitwise left-shift"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2851

  columns: [id, function, args, expected]
  rows:
    - ["dc2851001", "decimal.Decimal.__dict__.__contains__",          ["__rlshift__"], false]
    - ["dc2851002", "decimal.Context.__dict__.__contains__",          ["__rlshift__"], false]
    - ["dc2851003", "decimal.DecimalException.__dict__.__contains__", ["__rlshift__"], false]
    - ["dc2851004", "decimal.InvalidOperation.__dict__.__contains__", ["__rlshift__"], false]
    - ["dc2851005", "decimal.DivisionByZero.__dict__.__contains__",   ["__rlshift__"], false]
    - ["dc2851006", "decimal.Overflow.__dict__.__contains__",         ["__rlshift__"], false]

# ---------------------------------------------------------------------------
# Table: __rrshift__ dict-presence
# Absent from Decimal (no bitwise ops), Context, and all exception classes
# ---------------------------------------------------------------------------

table dc2851.rrshift_protocol:
  description: "__rrshift__ is absent from all decimal types — Decimal arithmetic does not include bitwise right-shift"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2851

  columns: [id, function, args, expected]
  rows:
    - ["dc2851007", "decimal.Decimal.__dict__.__contains__",          ["__rrshift__"], false]
    - ["dc2851008", "decimal.Context.__dict__.__contains__",          ["__rrshift__"], false]
    - ["dc2851009", "decimal.DecimalException.__dict__.__contains__", ["__rrshift__"], false]
    - ["dc2851010", "decimal.InvalidOperation.__dict__.__contains__", ["__rrshift__"], false]
    - ["dc2851011", "decimal.DivisionByZero.__dict__.__contains__",   ["__rrshift__"], false]
    - ["dc2851012", "decimal.Overflow.__dict__.__contains__",         ["__rrshift__"], false]

# ---------------------------------------------------------------------------
# Table: __rpow__ dict-presence
# Decimal defines __rpow__ for reflected exponentiation; all others absent
# ---------------------------------------------------------------------------

table dc2851.rpow_protocol:
  description: "__rpow__ is present in decimal.Decimal.__dict__ (full numeric type) but absent from Context and exception classes"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2851

  columns: [id, function, args, expected]
  rows:
    - ["dc2851013", "decimal.Decimal.__dict__.__contains__",          ["__rpow__"], true]
    - ["dc2851014", "decimal.Context.__dict__.__contains__",          ["__rpow__"], false]
    - ["dc2851015", "decimal.DecimalException.__dict__.__contains__", ["__rpow__"], false]
    - ["dc2851016", "decimal.InvalidOperation.__dict__.__contains__", ["__rpow__"], false]
    - ["dc2851017", "decimal.DivisionByZero.__dict__.__contains__",   ["__rpow__"], false]
    - ["dc2851018", "decimal.Overflow.__dict__.__contains__",         ["__rpow__"], false]

# ---------------------------------------------------------------------------
# Table: Decimal reflected operator profile — shift absent, power present
# Confirms the exact boundary: Decimal participates in __rpow__ but NOT in
# the reflected bitwise-shift protocol, unlike integer types that define all three
# ---------------------------------------------------------------------------

table dc2851.decimal_reflected_shift_pow_profile:
  description: "decimal.Decimal defines __rpow__ but NOT __rlshift__ or __rrshift__ — selective reflected operator support"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2851

  columns: [id, function, args, expected]
  rows:
    - ["dc2851019", "decimal.Decimal.__dict__.__contains__", ["__rlshift__"], false]
    - ["dc2851020", "decimal.Decimal.__dict__.__contains__", ["__rrshift__"], false]
    - ["dc2851021", "decimal.Decimal.__dict__.__contains__", ["__rpow__"],    true]
    - ["dc2851022", "decimal.Clamped.__dict__.__contains__",   ["__rpow__"],  false]
    - ["dc2851023", "decimal.Inexact.__dict__.__contains__",   ["__rpow__"],  false]
    - ["dc2851024", "decimal.Rounded.__dict__.__contains__",   ["__rpow__"],  false]
    - ["dc2851025", "decimal.Subnormal.__dict__.__contains__", ["__rpow__"],  false]
    - ["dc2851026", "decimal.Underflow.__dict__.__contains__", ["__rpow__"],  false]
