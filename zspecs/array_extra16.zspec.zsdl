spec: array_extra16
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
    - "array_extra.zspec.zsdl — covers array.__name__/__module__, ArrayType.__name__, typecodes is str, itemsize b/h, typecode b, length/getitem/tolist for 'b'."
    - "array_extra2.zspec.zsdl — covers typecodes min_length, typecodes contains b/B/h/i/l/q/f/d, itemsize table b/B/h/f/d, typecode_attr b/B/h/i/f/d."
    - "array_extra3.zspec.zsdl — covers ArrayType.__module__, itemsize H/I, typecode H/d, buffer_info, tolist/count/index on 'i', unsigned short tolist."
    - "array_extra4.zspec.zsdl — covers typecodes contains H/L/Q, itemsize l/L/Q, typecode_attr l/L/Q, array.__qualname__, bases_object, getitem B[1]."
    - "array_extra5.zspec.zsdl — covers ArrayType.__qualname__, typecodes contains 'I', tobytes class/length for 'b', itemsize lower-bound guard."
    - "array_extra6.zspec.zsdl — covers array metaclass, MRO length 2, typecodes contains 'u'/'w', class identity table, float array tolist/length/typecode for 'f'."
    - "array_extra7.zspec.zsdl — covers double array tolist/typecode/itemsize; count/index on 'b'; 'B' tolist; 'h' tolist; tobytes length for 'd'."
    - "array_extra8.zspec.zsdl — covers typecodes.__class__.__name__ standalone; array.__name__/__module__ via __eq__ chain."
    - "array_extra9.zspec.zsdl — covers class_names table; typecodes via class path; 'i'/'l'/'q' tolist; 'f' itemsize."
    - "array_extra10.zspec.zsdl — covers 'B'/'h'/'H' boundary tolist; empty 'i' tolist; single 'b' max tolist; 'L' itemsize >= 4."
    - "array_extra14.zspec.zsdl — covers typecodes.__contains__ for all 12 typecodes; typecodes class_name_len; array module_len; array qualname_len."
    - "array_extra15.zspec.zsdl — covers tolist/len for 'b'[1,2,3]; itemsize exact table b/B/h/H/i/I/d."
  notes:
    - "This spec extends array.zspec.zsdl through array_extra15.zspec.zsdl."
    - "array.array.__name__ == 'array' — len 5. Verified Python 3.12 macOS."
    - "array.array.__module__ == 'array' — len 5. Verified."
    - "array.array('i', [1,2,3]).typecode == 'i' — signed int typecode. Verified."
    - "array.array('i', [1,2,3]).itemsize == 4 — signed int is 4 bytes on all modern platforms. Verified."
    - "array.array('b', [1,2,3]).__len__() == 3 — 3-element array has length 3. Verified."
    - "array.array('d', [1.0,2.0]).typecode == 'd' — double typecode. Verified."
    - "array.typecodes.__class__.__name__ == 'str' — typecodes is a plain string. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# array.array.__name__ == 'array'
#
# The array class __name__ attribute. array_extra and array_extra8 cover this
# from their namespaces; this anchors it from extra16.
# ---------------------------------------------------------------------------

invariant array_extra16.class_name.array:
  description: "array.array.__name__ == 'array' — class name attribute"
  category: class_names
  kind: python_call_eq
  function: array.__name__.__eq__
  args: ["array"]
  expected: true

# ---------------------------------------------------------------------------
# array.array.__module__ == 'array'
#
# The array class __module__ attribute. array_extra8 covers this; extra16
# anchors it with a fresh invariant ID.
# ---------------------------------------------------------------------------

invariant array_extra16.class_module.array:
  description: "array.array.__module__ == 'array' — class module attribute"
  category: class_names
  kind: python_call_eq
  function: array.__module__.__eq__
  args: ["array"]
  expected: true

# ---------------------------------------------------------------------------
# array.array('i', [1,2,3]).typecode == 'i'
#
# The typecode attribute of a signed-int array. Prior specs confirm 'i'
# typecode but this invariant uses the [1,2,3] initializer fixture.
# ---------------------------------------------------------------------------

invariant array_extra16.typecode.signed_int_123:
  description: "array.array('i', [1,2,3]).typecode == 'i' — signed int typecode"
  category: typecode
  kind: python_call_eq
  function: array
  args: ["i", [1, 2, 3]]
  method: typecode.__eq__
  method_args: ["i"]
  expected: true

# ---------------------------------------------------------------------------
# array.array('i', [1,2,3]).itemsize == 4
#
# Signed int (typecode 'i') is 4 bytes on all modern 32-bit and 64-bit
# platforms. array_extra15 confirms itemsize for 'i' via the exact table;
# this invariant tests it on the [1,2,3] initializer fixture.
# ---------------------------------------------------------------------------

invariant array_extra16.itemsize.signed_int_123:
  description: "array.array('i', [1,2,3]).itemsize == 4 — signed int is 4 bytes"
  category: itemsize
  kind: python_call_eq
  function: array
  args: ["i", [1, 2, 3]]
  method: itemsize.__eq__
  method_args: [4]
  expected: true

# ---------------------------------------------------------------------------
# array.array('b', [1,2,3]).__len__() == 3
#
# Length of a 3-element signed-byte array is 3. array_extra covers __len__
# for 'b'; this spec anchors it from extra16.
# ---------------------------------------------------------------------------

invariant array_extra16.len.signed_byte_123:
  description: "array.array('b', [1,2,3]).__len__() == 3 — 3-element array length"
  category: length
  kind: python_call_eq
  function: array
  args: ["b", [1, 2, 3]]
  method: __len__
  method_args: []
  expected: 3

# ---------------------------------------------------------------------------
# array.array('d', [1.0,2.0]).typecode == 'd'
#
# The typecode attribute of a double array. array_extra7 covers typecode for
# 'd'; this invariant uses the [1.0, 2.0] initializer fixture.
# ---------------------------------------------------------------------------

invariant array_extra16.typecode.double_1_2:
  description: "array.array('d', [1.0,2.0]).typecode == 'd' — double typecode"
  category: typecode
  kind: python_call_eq
  function: array
  args: ["d", [1.0, 2.0]]
  method: typecode.__eq__
  method_args: ["d"]
  expected: true

# ---------------------------------------------------------------------------
# array.typecodes.__class__.__name__ == 'str'
#
# The typecodes module-level attribute is a plain Python str. array_extra8
# covers this in its namespace; extra16 anchors it as a standalone invariant.
# ---------------------------------------------------------------------------

invariant array_extra16.typecodes_class_name.is_str:
  description: "array.typecodes.__class__.__name__ == 'str' — typecodes is a plain string"
  category: typecodes
  kind: python_call_eq
  function: typecodes.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Compact reference table — core array attributes
#
# Gathers __name__, __module__, and typecodes class name into one table.
# Uses id_prefix ar16 which does not conflict with any prior spec.
# ---------------------------------------------------------------------------

table array_extra16.core_attrs:
  description: "Core array class attribute checks — __name__, __module__, typecodes class"
  kind: python_call_eq
  category: class_names
  id_prefix: ar16

  columns: [id, function, args, expected]
  rows:
    - [class_name,         array.__name__.__eq__,                    ["array"], true]
    - [class_module,       array.__module__.__eq__,                  ["array"], true]
    - [typecodes_cls_name, typecodes.__class__.__name__.__eq__,      ["str"],   true]
