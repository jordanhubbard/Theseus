spec: sk3001
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket: Low-level networking interface"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 647 (sk3001): __getitem__, __setitem__, __delitem__ dict-presence checks for socket types."
    - "socket.socket is a networking file descriptor wrapper — not a mapping or sequence type; no item access protocol is defined."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; socket.AddressInfo and socket.MsgFlag are IntFlag subclasses — integral enum types do not expose item access in their own __dict__."
    - "socket.error, socket.herror, socket.gaierror, and socket.timeout are exception classes — none are mappings or sequences."
    - "None of the socket types define __getitem__, __setitem__, or __delitem__ in their own __dict__."
    - "Verified types: socket.socket, socket.AddressFamily, socket.SocketKind, socket.AddressInfo, socket.MsgFlag, socket.error, socket.herror, socket.gaierror, socket.timeout."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk3001.getitem:
  description: "socket types __getitem__ dict-presence checks; wave 647"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk3001
  columns: [id, function, args, expected]
  rows:
    - ["sk3001001", operator.contains, [socket.socket.__dict__,        "__getitem__"], false]
    - ["sk3001002", operator.contains, [socket.AddressFamily.__dict__, "__getitem__"], false]
    - ["sk3001003", operator.contains, [socket.SocketKind.__dict__,    "__getitem__"], false]
    - ["sk3001004", operator.contains, [socket.AddressInfo.__dict__,   "__getitem__"], false]
    - ["sk3001005", operator.contains, [socket.MsgFlag.__dict__,       "__getitem__"], false]
    - ["sk3001006", operator.contains, [socket.error.__dict__,         "__getitem__"], false]
    - ["sk3001007", operator.contains, [socket.herror.__dict__,        "__getitem__"], false]
    - ["sk3001008", operator.contains, [socket.gaierror.__dict__,      "__getitem__"], false]
    - ["sk3001009", operator.contains, [socket.timeout.__dict__,       "__getitem__"], false]

