spec: decimal_extra179
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/decimal.py"
  notes:
    - "decimal.InvalidOperation.__name__=='InvalidOperation' (len=16); __module__=='decimal'; __bases__[0].__name__=='DecimalException'."
    - "decimal.DivisionByZero.__name__=='DivisionByZero' (len=14); __bases__[0].__name__=='DecimalException'."
    - "decimal.Overflow.__name__=='Overflow' (len=8); decimal.Underflow.__name__=='Underflow' (len=9)."
    - "decimal.DecimalException.__bases__[0].__name__=='ArithmeticError' — root of the decimal exception hierarchy."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.InvalidOperation class identity
# __name__=='InvalidOperation' (len=16); __module__=='decimal'; __bases__[0].__name__=='DecimalException'
# ---------------------------------------------------------------------------

table decimal_extra179.invalid_operation_identity:
  description: "decimal.InvalidOperation class identity: __name__=='InvalidOperation' (len=16); __module__=='decimal'; __bases__[0].__name__=='DecimalException'"
  kind: python_call_eq
  category: identity
  id_prefix: decimalexc179

  columns: [id, function, args, expected, description]
  rows:
    - [invop_name,    InvalidOperation.__name__.__eq__,    ["InvalidOperation"],  true,   "decimal.InvalidOperation.__name__ == 'InvalidOperation' — raised for invalid decimal operations; confirmed Python 3.14.3 macOS"]
    - [invop_len,     InvalidOperation.__name__.__len__,   [],                    16,     "decimal.InvalidOperation.__name__.__len__() == 16 — 'InvalidOperation': I(1)n(2)v(3)a(4)l(5)i(6)d(7)O(8)p(9)e(10)r(11)a(12)t(13)i(14)o(15)n(16); confirmed Python 3.14.3 macOS"]
    - [invop_module,  InvalidOperation.__module__.__eq__,  ["decimal"],           true,   "decimal.InvalidOperation.__module__ == 'decimal' — belongs to the decimal module; confirmed Python 3.14.3 macOS"]
    - [invop_base,    "InvalidOperation.__bases__[0].__name__.__eq__",  ["DecimalException"],  true,   "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' — inherits from DecimalException; confirmed Python 3.14.3 macOS"]
    - [invop_ne_arith, InvalidOperation.__name__.__eq__,  ["ArithmeticError"],   false,  "decimal.InvalidOperation.__name__.__eq__('ArithmeticError') == False — class is 'InvalidOperation', not its ancestor 'ArithmeticError'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal.DivisionByZero and decimal.DecimalException class identity
# DivisionByZero (len=14); DecimalException.__bases__[0].__name__=='ArithmeticError'
# ---------------------------------------------------------------------------

table decimal_extra179.division_and_root_identity:
  description: "decimal.DivisionByZero class identity (len=14); decimal.DecimalException.__bases__[0].__name__=='ArithmeticError' — root of decimal exception hierarchy"
  kind: python_call_eq
  category: identity
  id_prefix: decimalexc179

  columns: [id, function, args, expected, description]
  rows:
    - [divzero_name,    DivisionByZero.__name__.__eq__,    ["DivisionByZero"],     true,   "decimal.DivisionByZero.__name__ == 'DivisionByZero' — raised on division by zero; confirmed Python 3.14.3 macOS"]
    - [divzero_len,     DivisionByZero.__name__.__len__,   [],                     14,     "decimal.DivisionByZero.__name__.__len__() == 14 — 'DivisionByZero': D(1)i(2)v(3)i(4)s(5)i(6)o(7)n(8)B(9)y(10)Z(11)e(12)r(13)o(14); confirmed Python 3.14.3 macOS"]
    - [divzero_base,    "DivisionByZero.__bases__[0].__name__.__eq__",   ["DecimalException"],  true,   "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException' — inherits from DecimalException; confirmed Python 3.14.3 macOS"]
    - [decexc_base,     "DecimalException.__bases__[0].__name__.__eq__", ["ArithmeticError"],   true,   "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — root decimal exception inherits from ArithmeticError; confirmed Python 3.14.3 macOS"]
    - [divzero_ne_exc,  DivisionByZero.__name__.__eq__,    ["DecimalException"],   false,  "decimal.DivisionByZero.__name__.__eq__('DecimalException') == False — class is 'DivisionByZero', not its parent 'DecimalException'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal.Overflow and decimal.Underflow class identity
# Overflow (len=8), Underflow (len=9)
# ---------------------------------------------------------------------------

table decimal_extra179.overflow_underflow_identity:
  description: "decimal.Overflow and decimal.Underflow class identity: Overflow.__name__=='Overflow' (len=8); Underflow.__name__=='Underflow' (len=9); both inherit from DecimalException"
  kind: python_call_eq
  category: identity
  id_prefix: decimalexc179

  columns: [id, function, args, expected, description]
  rows:
    - [overflow_name,   Overflow.__name__.__eq__,    ["Overflow"],          true,   "decimal.Overflow.__name__ == 'Overflow' — raised when result exceeds representable range; confirmed Python 3.14.3 macOS"]
    - [overflow_len,    Overflow.__name__.__len__,   [],                    8,      "decimal.Overflow.__name__.__len__() == 8 — 'Overflow': O(1)v(2)e(3)r(4)f(5)l(6)o(7)w(8); confirmed Python 3.14.3 macOS"]
    - [underflow_name,  Underflow.__name__.__eq__,   ["Underflow"],         true,   "decimal.Underflow.__name__ == 'Underflow' — raised when result is subnormal with loss of precision; confirmed Python 3.14.3 macOS"]
    - [underflow_len,   Underflow.__name__.__len__,  [],                    9,      "decimal.Underflow.__name__.__len__() == 9 — 'Underflow': U(1)n(2)d(3)e(4)r(5)f(6)l(7)o(8)w(9); confirmed Python 3.14.3 macOS"]
    - [overflow_ne_under, Overflow.__name__.__eq__,  ["Underflow"],         false,  "decimal.Overflow.__name__.__eq__('Underflow') == False — Overflow and Underflow are distinct exception classes; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra179.invalid_operation_name_eq:
  description: "decimal.InvalidOperation.__name__ == 'InvalidOperation' — raised for invalid decimal operations; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: InvalidOperation.__name__.__eq__
  args: ["InvalidOperation"]
  expected: true

invariant decimal_extra179.invalid_operation_name_len_16:
  description: "decimal.InvalidOperation.__name__.__len__() == 16 — 'InvalidOperation' has 16 characters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: InvalidOperation.__name__.__len__
  args: []
  expected: 16

invariant decimal_extra179.invalid_operation_module_eq:
  description: "decimal.InvalidOperation.__module__ == 'decimal' — belongs to the decimal module; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: InvalidOperation.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra179.invalid_operation_base_eq:
  description: "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' — inherits from DecimalException; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "InvalidOperation.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra179.division_by_zero_name_eq:
  description: "decimal.DivisionByZero.__name__ == 'DivisionByZero' — raised on division by zero in decimal arithmetic; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: DivisionByZero.__name__.__eq__
  args: ["DivisionByZero"]
  expected: true

invariant decimal_extra179.division_by_zero_name_len_14:
  description: "decimal.DivisionByZero.__name__.__len__() == 14 — 'DivisionByZero' has 14 characters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: DivisionByZero.__name__.__len__
  args: []
  expected: 14

invariant decimal_extra179.overflow_name_eq:
  description: "decimal.Overflow.__name__ == 'Overflow' — raised when result exceeds the representable range; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Overflow.__name__.__eq__
  args: ["Overflow"]
  expected: true

invariant decimal_extra179.underflow_name_eq:
  description: "decimal.Underflow.__name__ == 'Underflow' — raised when result is subnormal with loss of precision; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Underflow.__name__.__eq__
  args: ["Underflow"]
  expected: true

invariant decimal_extra179.underflow_name_len_9:
  description: "decimal.Underflow.__name__.__len__() == 9 — 'Underflow' has 9 characters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Underflow.__name__.__len__
  args: []
  expected: 9

invariant decimal_extra179.decimal_exception_base_eq:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — root decimal exception inherits from ArithmeticError; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "DecimalException.__bases__[0].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true
