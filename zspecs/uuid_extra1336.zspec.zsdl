spec: uuid_extra1336
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — UUID objects according to RFC 4122"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 536 (_extra1336): focuses on __hash__ and __eq__ method class checks for uuid types."
    - "uuid.UUID defines both __hash__ and __eq__ as pure-Python functions in Lib/uuid.py."
    - "UUID.__hash__.__qualname__ == 'UUID.__hash__' and __class__.__name__ == 'function'."
    - "UUID.__eq__.__qualname__ == 'UUID.__eq__' and __class__.__name__ == 'function'."
    - "uuid.SafeUUID is an Enum subclass; it inherits __hash__ from Enum (a Python function)."
    - "SafeUUID.__hash__.__qualname__ == 'Enum.__hash__' — inherited Enum hash, not redefined."
    - "SafeUUID.__eq__ inherits from object: __qualname__ == 'object.__eq__', class 'wrapper_descriptor'."
    - "This contrast shows UUID explicitly defines __eq__ while SafeUUID relies on object's C-level __eq__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table uuid_extra1336.UUID_hash_eq_qualnames:
  description: "uuid.UUID __hash__ and __eq__ are pure-Python functions defined in Lib/uuid.py: qualname and class name checks"
  kind: python_call_eq
  category: hash_eq_class_checks
  id_prefix: uu1336hq
  columns: [id, function, args, expected]
  rows:
    - [uu1336hq001, uuid.UUID.__hash__.__qualname__.__eq__,       ["UUID.__hash__"],  true]
    - [uu1336hq002, uuid.UUID.__hash__.__class__.__name__.__eq__, ["function"],       true]
    - [uu1336hq003, uuid.UUID.__eq__.__qualname__.__eq__,         ["UUID.__eq__"],    true]
    - [uu1336hq004, uuid.UUID.__eq__.__class__.__name__.__eq__,   ["function"],       true]
    - [uu1336hq005, uuid.UUID.__hash__.__qualname__.__eq__,       ["UUID.__hash__"],  true]
    - [uu1336hq006, uuid.UUID.__eq__.__qualname__.__eq__,         ["UUID.__eq__"],    true]

table uuid_extra1336.SafeUUID_hash_eq_checks:
  description: "uuid.SafeUUID inherits __hash__ from Enum (Python function) and __eq__ from object (wrapper_descriptor)"
  kind: python_call_eq
  category: hash_eq_class_checks
  id_prefix: uu1336sq
  columns: [id, function, args, expected]
  rows:
    - [uu1336sq001, uuid.SafeUUID.__hash__.__qualname__.__eq__,       ["Enum.__hash__"],     true]
    - [uu1336sq002, uuid.SafeUUID.__hash__.__class__.__name__.__eq__, ["function"],          true]
    - [uu1336sq003, uuid.SafeUUID.__eq__.__qualname__.__eq__,         ["object.__eq__"],     true]
    - [uu1336sq004, uuid.SafeUUID.__eq__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [uu1336sq005, uuid.SafeUUID.__hash__.__qualname__.__eq__,       ["Enum.__hash__"],     true]
    - [uu1336sq006, uuid.SafeUUID.__eq__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]

table uuid_extra1336.UUID_vs_SafeUUID_hash_eq_contrast:
  description: "Contrast UUID (defines own __hash__ and __eq__ as Python functions) vs SafeUUID (inherits from Enum and object)"
  kind: python_call_eq
  category: hash_eq_class_checks
  id_prefix: uu1336cv
  columns: [id, function, args, expected]
  rows:
    - [uu1336cv001, uuid.UUID.__hash__.__class__.__name__.__eq__,     ["function"],          true]
    - [uu1336cv002, uuid.UUID.__eq__.__class__.__name__.__eq__,       ["function"],          true]
    - [uu1336cv003, uuid.SafeUUID.__hash__.__class__.__name__.__eq__, ["function"],          true]
    - [uu1336cv004, uuid.SafeUUID.__eq__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [uu1336cv005, uuid.UUID.__hash__.__qualname__.__eq__,           ["UUID.__hash__"],     true]
    - [uu1336cv006, uuid.SafeUUID.__hash__.__qualname__.__eq__,       ["Enum.__hash__"],     true]
