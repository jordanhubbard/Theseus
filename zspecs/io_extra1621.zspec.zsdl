spec: io_extra1621
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __weakref__ and weak reference protocol"
    - "io stream classes are C extension types (from _io); C types manage weakref support at the C level via tp_weaklistoffset"
    - "C extension types that do not set tp_weaklistoffset do not expose __weakref__ in their class dict"
    - "io.StringIO, io.BytesIO, io.TextIOWrapper, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.FileIO are C types with no __weakref__ in their class dict"
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase are Python ABCs; being Python classes they do not expose __weakref__ in their own class dict (their instances may or may not be weakly referenceable)"
    - "io.UnsupportedOperation is a pure Python class defined in Lib/io.py; Python type machinery adds __weakref__ to its class dict at class creation"
    - "io.UnsupportedOperation inherits from OSError and ValueError; its own class dict contains __weakref__ because it is a leaf Python class with no __slots__"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: Concrete stream C extension types — no __weakref__ in class dict
# ---------------------------------------------------------------------------

table io_extra1621.stream_c_types_no_weakref:
  description: "io.StringIO, BytesIO, TextIOWrapper, BufferedReader, BufferedWriter, BufferedRandom, FileIO are C extension types — none expose __weakref__ in their own class dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1621sc

  columns: [id, function, args, expected]
  rows:
    - ["io1621sc001", io.StringIO.__dict__.__contains__,       ["__weakref__"], false]
    - ["io1621sc002", io.BytesIO.__dict__.__contains__,        ["__weakref__"], false]
    - ["io1621sc003", io.TextIOWrapper.__dict__.__contains__,  ["__weakref__"], false]
    - ["io1621sc004", io.BufferedReader.__dict__.__contains__,  ["__weakref__"], false]
    - ["io1621sc005", io.BufferedWriter.__dict__.__contains__,  ["__weakref__"], false]
    - ["io1621sc006", io.BufferedRandom.__dict__.__contains__,  ["__weakref__"], false]
    - ["io1621sc007", io.FileIO.__dict__.__contains__,          ["__weakref__"], false]
    - ["io1621sc008", io.StringIO.__dict__.__contains__,       ["__slots__"],   false]
    - ["io1621sc009", io.BytesIO.__dict__.__contains__,        ["__slots__"],   false]
    - ["io1621sc010", io.TextIOWrapper.__dict__.__contains__,  ["__slots__"],   false]
    - ["io1621sc011", io.BufferedReader.__dict__.__contains__,  ["__slots__"],   false]
    - ["io1621sc012", io.BufferedWriter.__dict__.__contains__,  ["__slots__"],   false]
    - ["io1621sc013", io.BufferedRandom.__dict__.__contains__,  ["__slots__"],   false]
    - ["io1621sc014", io.FileIO.__dict__.__contains__,          ["__slots__"],   false]
    - ["io1621sc015", io.StringIO.__dict__.__contains__,       ["__dict__"],    false]
    - ["io1621sc016", io.BytesIO.__dict__.__contains__,        ["__dict__"],    false]
    - ["io1621sc017", io.TextIOWrapper.__dict__.__contains__,  ["__dict__"],    false]
    - ["io1621sc018", io.BufferedReader.__dict__.__contains__,  ["__dict__"],    false]
    - ["io1621sc019", io.BufferedWriter.__dict__.__contains__,  ["__dict__"],    false]
    - ["io1621sc020", io.BufferedRandom.__dict__.__contains__,  ["__dict__"],    false]
    - ["io1621sc021", io.FileIO.__dict__.__contains__,          ["__dict__"],    false]
    - ["io1621sc022", io.StringIO.__dict__.__contains__,       ["read"],        true]
    - ["io1621sc023", io.BytesIO.__dict__.__contains__,        ["read"],        true]
    - ["io1621sc024", io.TextIOWrapper.__dict__.__contains__,  ["read"],        true]
    - ["io1621sc025", io.BufferedReader.__dict__.__contains__,  ["read"],        true]
    - ["io1621sc026", io.FileIO.__dict__.__contains__,          ["read"],        true]
    - ["io1621sc027", io.BufferedRandom.__dict__.__contains__,  ["read"],        true]
    - ["io1621sc028", io.StringIO.__dict__.__contains__,       ["write"],       true]
    - ["io1621sc029", io.BytesIO.__dict__.__contains__,        ["write"],       true]
    - ["io1621sc030", io.TextIOWrapper.__dict__.__contains__,  ["write"],       true]

# ---------------------------------------------------------------------------
# Table 2: Abstract base C types and UnsupportedOperation (Python class)
# ---------------------------------------------------------------------------

table io_extra1621.base_c_types_no_weakref:
  description: "io.IOBase, RawIOBase, BufferedIOBase, TextIOBase are C-backed ABCs with no __weakref__ in class dict; io.UnsupportedOperation is a Python class and has __weakref__ in its own class dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1621bc

  columns: [id, function, args, expected]
  rows:
    - ["io1621bc001", io.IOBase.__dict__.__contains__,        ["__weakref__"], false]
    - ["io1621bc002", io.RawIOBase.__dict__.__contains__,     ["__weakref__"], false]
    - ["io1621bc003", io.BufferedIOBase.__dict__.__contains__, ["__weakref__"], false]
    - ["io1621bc004", io.TextIOBase.__dict__.__contains__,    ["__weakref__"], false]
    - ["io1621bc005", io.IOBase.__dict__.__contains__,        ["__slots__"],   false]
    - ["io1621bc006", io.RawIOBase.__dict__.__contains__,     ["__slots__"],   false]
    - ["io1621bc007", io.BufferedIOBase.__dict__.__contains__, ["__slots__"],   false]
    - ["io1621bc008", io.TextIOBase.__dict__.__contains__,    ["__slots__"],   false]
    - ["io1621bc009", io.IOBase.__dict__.__contains__,        ["__dict__"],    false]
    - ["io1621bc010", io.RawIOBase.__dict__.__contains__,     ["__dict__"],    false]
    - ["io1621bc011", io.BufferedIOBase.__dict__.__contains__, ["__dict__"],    false]
    - ["io1621bc012", io.TextIOBase.__dict__.__contains__,    ["__dict__"],    false]
    - ["io1621bc013", io.UnsupportedOperation.__dict__.__contains__, ["__weakref__"], true]
    - ["io1621bc014", io.UnsupportedOperation.__dict__.__contains__, ["__slots__"],   false]
    - ["io1621bc015", io.UnsupportedOperation.__dict__.__contains__, ["__dict__"],    false]
    - ["io1621bc016", io.UnsupportedOperation.__dict__.__contains__, ["__module__"],  true]
    - ["io1621bc017", io.UnsupportedOperation.__dict__.__contains__, ["__doc__"],     true]
    - ["io1621bc018", io.IOBase.__dict__.__contains__,        ["__module__"],  true]
    - ["io1621bc019", io.RawIOBase.__dict__.__contains__,     ["__module__"],  true]
    - ["io1621bc020", io.BufferedIOBase.__dict__.__contains__, ["__module__"],  true]
    - ["io1621bc021", io.TextIOBase.__dict__.__contains__,    ["__module__"],  true]
    - ["io1621bc022", io.IOBase.__dict__.__contains__,        ["read"],        false]
    - ["io1621bc023", io.IOBase.__dict__.__contains__,        ["close"],       true]
    - ["io1621bc024", io.IOBase.__dict__.__contains__,        ["flush"],       true]
    - ["io1621bc025", io.IOBase.__dict__.__contains__,        ["readable"],    true]
    - ["io1621bc026", io.IOBase.__dict__.__contains__,        ["writable"],    true]
    - ["io1621bc027", io.IOBase.__dict__.__contains__,        ["seekable"],    true]
    - ["io1621bc028", io.RawIOBase.__dict__.__contains__,     ["read"],        true]
    - ["io1621bc029", io.BufferedIOBase.__dict__.__contains__, ["read"],        true]
    - ["io1621bc030", io.TextIOBase.__dict__.__contains__,    ["read"],        true]
