spec: os_extra8
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "CPython source: Lib/os.py"
  notes:
    - "This spec extends os.zspec.zsdl, os_environ.zspec.zsdl, os_extra.zspec.zsdl, os_extra2.zspec.zsdl, os_extra3.zspec.zsdl, os_extra4.zspec.zsdl, os_extra5.zspec.zsdl, os_extra6.zspec.zsdl, os_extra7.zspec.zsdl."
    - "os_extra6 covers: sep=='/' (POSIX), linesep=='\\n', devnull=='/dev/null', curdir=='.', pardir=='..', extsep=='.'."
    - "os_extra7 covers: sep.__class__.__name__=='str', linesep.__class__.__name__=='str', urandom/__name__, cpu_count/__name__, get_terminal_size/__name__."
    - "os_extra2 covers: devnull.__class__.__name__=='str', altsep is NoneType."
    - "os_environ covers: environ.__class__.__name__=='_Environ'."
    - "os.zspec.zsdl and os_extra5 cover __name__ for getpid, getuid, getcwd as table rows."
    - "This spec adds __qualname__ checks for os functions — not covered by any prior spec."
    - "os.getpid.__qualname__ == 'getpid' — __qualname__ equals __name__ for module-level functions."
    - "os.getuid.__qualname__ == 'getuid' — POSIX-only; available on macOS/Linux/FreeBSD."
    - "os.getcwd.__qualname__ == 'getcwd' — __qualname__ equals __name__ for module-level functions."
    - "os.listdir.__qualname__ == 'listdir' — directory listing function."
    - "os.makedirs.__qualname__ == 'makedirs' — recursive directory creation."
    - "os.scandir.__qualname__ == 'scandir' — iterator-based directory listing."
    - "os.environ.__class__.__qualname__ == '_Environ' — not covered by any prior spec."
    - "os.environ.__class__.__module__ == 'os' — _Environ is defined in the os module; not covered by any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for os module-level functions
#
# No prior spec covers __qualname__ for any os function.  For module-level
# functions __qualname__ equals __name__ (no enclosing class scope).
# ---------------------------------------------------------------------------

table os_extra8.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [getpid,   getpid.__qualname__.__eq__,   ["getpid"],   true]
    - [getuid,   getuid.__qualname__.__eq__,   ["getuid"],   true]
    - [getcwd,   getcwd.__qualname__.__eq__,   ["getcwd"],   true]
    - [listdir,  listdir.__qualname__.__eq__,  ["listdir"],  true]
    - [makedirs, makedirs.__qualname__.__eq__, ["makedirs"], true]
    - [scandir,  scandir.__qualname__.__eq__,  ["scandir"],  true]
    - [getenv,   getenv.__qualname__.__eq__,   ["getenv"],   true]
    - [strerror, strerror.__qualname__.__eq__, ["strerror"], true]

# ---------------------------------------------------------------------------
# environ — class metadata
#
# os_environ.zspec.zsdl covers environ.__class__.__name__ == '_Environ'.
# This spec adds environ.__class__.__module__ == 'os' (not previously covered)
# and environ.__class__.__qualname__ == '_Environ' (not previously covered).
# ---------------------------------------------------------------------------

invariant os_extra8.environ.class_qualname:
  description: "os.environ.__class__.__qualname__ == '_Environ'"
  category: environ
  kind: python_call_eq
  function: environ.__class__.__qualname__.__eq__
  args: ["_Environ"]
  expected: true

invariant os_extra8.environ.module_is_os:
  description: "os.environ.__class__.__module__ == 'os' — _Environ is defined in the os module"
  category: environ
  kind: python_call_eq
  function: environ.__class__.__module__.__eq__
  args: ["os"]
  expected: true

# ---------------------------------------------------------------------------
# urandom — __qualname__ check
#
# os_extra7 covers urandom.__name__ == 'urandom'; this adds __qualname__.
# ---------------------------------------------------------------------------

invariant os_extra8.urandom.qualname:
  description: "os.urandom.__qualname__ == 'urandom'"
  category: qualnames
  kind: python_call_eq
  function: urandom.__qualname__.__eq__
  args: ["urandom"]
  expected: true

# ---------------------------------------------------------------------------
# cpu_count — __qualname__ check
#
# os_extra7 covers cpu_count.__name__ == 'cpu_count'; this adds __qualname__.
# ---------------------------------------------------------------------------

invariant os_extra8.cpu_count.qualname:
  description: "os.cpu_count.__qualname__ == 'cpu_count'"
  category: qualnames
  kind: python_call_eq
  function: cpu_count.__qualname__.__eq__
  args: ["cpu_count"]
  expected: true
