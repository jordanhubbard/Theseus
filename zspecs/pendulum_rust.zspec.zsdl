spec: pendulum_rust
version: ">=3.9"
backend: rust_module(pendulum_rust)

docs: https://pendulum.eustace.io/

provenance:
  derived_from:
    - "https://pendulum.eustace.io/ — pendulum datetime library"
  notes:
    - "pendulum provides better datetime handling."
    - "pendulum.now() returns a DateTime object."
    - "pendulum.datetime(2023, 1, 1).year == 2023."
    - "pendulum.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pendulum_rust.datetime_year:
  description: "pendulum.datetime(2023, 1, 1).year == 2023"
  category: datetime
  kind: python_call_eq
  function: pendulum_datetime_year
  args: [2023, 1, 1]
  expected: 2023

invariant pendulum_rust.has_now:
  description: "pendulum.now is callable"
  category: presence
  kind: python_call_eq
  function: pendulum_has_now
  args: []
  expected: true

invariant pendulum_rust.version_nonempty:
  description: "pendulum.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pendulum_version_nonempty
  args: []
  expected: true

