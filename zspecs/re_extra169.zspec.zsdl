spec: re_extra169
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.RegexFlag class identity (__name__, __module__, __bases__[0].__name__, __bases__[0].__module__) and specific RegexFlag member integer values (NOFLAG, DEBUG, ASCII, LOCALE)."
    - "re.RegexFlag.__name__ == 'RegexFlag' (len=9: 'Regex'(5)+'Flag'(4)=9)."
    - "re.RegexFlag.__module__ == 're' (len=2)."
    - "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (len=7: 'Int'(3)+'Flag'(4)=7)."
    - "re.RegexFlag.__bases__[0].__module__ == 'enum' (len=4)."
    - "re.NOFLAG.__eq__(0) == True — NOFLAG has integer value 0 (the null/empty flag)."
    - "re.DEBUG.__eq__(128) == True — DEBUG has integer value 128 = 2**7."
    - "re.ASCII.__eq__(256) == True — ASCII has integer value 256 = 2**8."
    - "re.LOCALE.__eq__(4) == True — LOCALE has integer value 4 = 2**2."
    - "All RegexFlag members are IntFlag instances: re.NOFLAG.__class__.__name__ == 'RegexFlag'."
    - "NOFLAG (0) < LOCALE (4) < DEBUG (128) < ASCII (256): ascending sequence with unequal gaps."
    - "The flag values are powers of two (except NOFLAG=0): LOCALE=2**2, DEBUG=2**7, ASCII=2**8."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.RegexFlag class identity
# __name__ == 'RegexFlag' (len=9), __module__ == 're' (len=2)
# __bases__[0].__name__ == 'IntFlag' (len=7), __bases__[0].__module__ == 'enum' (len=4)
# ---------------------------------------------------------------------------

table re_extra169.RegexFlag_class_identity:
  description: "re.RegexFlag class identity: __name__=='RegexFlag' (len=9), __module__=='re' (len=2), __bases__[0].__name__=='IntFlag' (len=7), __bases__[0].__module__=='enum' (len=4); RegexFlag is an IntFlag enum subclass; 'RegexFlag' = 'Regex'(5)+'Flag'(4)=9"
  kind: python_call_eq
  category: identity
  id_prefix: rfid169

  columns: [id, function, args, expected, description]
  rows:
    - [rf_name,      re.RegexFlag.__name__.__eq__,                    ["RegexFlag"],  true, "re.RegexFlag.__name__ == 'RegexFlag' — RegexFlag is the enum class containing all re module flag constants; 'RegexFlag' has 9 characters: 'Regex' (5) + 'Flag' (4) = 9; RegexFlag.__name__ (9 chars) > PatternError.__name__ (12 chars)? No: 9 < 12 — RegexFlag (9) < PatternError (12) by 3; RegexFlag (9) > Pattern (7) by 2; RegexFlag (9) > Match (5) by 4; the name 'RegexFlag' combines 'Regex' (the common abbreviation for regular expression) with 'Flag' (denoting bit-flag enum membership); all re module flag constants (IGNORECASE, MULTILINE, DOTALL, etc.) are members of RegexFlag; confirmed Python 3.14.3 macOS"]
    - [rf_module,    re.RegexFlag.__module__.__eq__,                  ["re"],         true, "re.RegexFlag.__module__ == 're' — RegexFlag is exported from the public 're' module; 're' has 2 characters; RegexFlag.__module__ (2: 're') == Pattern.__module__ (2: 're') == Match.__module__ (2: 're'): the three primary re module types share the same 2-character module name; RegexFlag.__module__ (2 chars) < RegexFlag.__name__ (9 chars) by 7 — the module name is much shorter than the class name; 're' (2 chars) is tied with 'io' (2 chars) as one of the shortest standard library module names; confirmed Python 3.14.3 macOS"]
    - [rf_base_name, "re.RegexFlag.__bases__[0].__name__.__eq__",     ["IntFlag"],    true, "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits directly from IntFlag (the integer-valued flag enum base class in the 'enum' module); 'IntFlag' has 7 characters: 'Int' (3) + 'Flag' (4) = 7; IntFlag is a subclass of both int and Flag, giving RegexFlag members their integer values and bitwise-OR combination semantics; RegexFlag.__bases__[0].__name__ (7: 'IntFlag') < RegexFlag.__name__ (9: 'RegexFlag') by 2 — the base class name is 2 characters shorter than the derived class name; 'IntFlag' (7 chars) and 'Pattern' (7 chars) are both 7-character strings in the re module class family; confirmed Python 3.14.3 macOS"]
    - [rf_base_mod,  "re.RegexFlag.__bases__[0].__module__.__eq__",   ["enum"],       true, "re.RegexFlag.__bases__[0].__module__ == 'enum' — IntFlag (RegexFlag's base class) lives in the 'enum' module; 'enum' has 4 characters: 'e-n-u-m'; RegexFlag's base class module ('enum', 4 chars) is different from RegexFlag's own module ('re', 2 chars); 'enum' (4 chars) > 're' (2 chars) by 2: the base class module name is twice as long as the derived class module name; 'enum' (4 chars) < 'RegexFlag' (9 chars) by 5; the fact that RegexFlag's base IntFlag comes from 'enum' reflects Python's use of the standard enum module to implement regex flag constants since Python 3.6; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.NOFLAG and re.LOCALE integer values via __eq__
# NOFLAG == 0 (the empty flag, no flags set)
# LOCALE == 4 == 2**2 (make \w, \b, \s locale-dependent)
# ---------------------------------------------------------------------------

table re_extra169.NOFLAG_LOCALE_values:
  description: "re.NOFLAG.__eq__(0)==True (the empty flag, integer value 0); re.LOCALE.__eq__(4)==True (locale-dependent matching, 2**2=4); both are RegexFlag members; NOFLAG (0) < LOCALE (4) in flag value ordering"
  kind: python_call_eq
  category: identity
  id_prefix: rfval169

  columns: [id, function, args, expected, description]
  rows:
    - [noflag_eq_0,     re.NOFLAG.__eq__,                         [0],     true,  "re.NOFLAG.__eq__(0) == True — NOFLAG is the RegexFlag member with integer value 0, representing no flags set; NOFLAG (0) is the identity element for flag combination: flag | NOFLAG == flag for any flag; NOFLAG (0) is the only falsy RegexFlag member — all other flag values are non-zero (truthy); NOFLAG was added in Python 3.11 as an explicit 'no flags' constant to replace the magic literal 0; re.compile(pattern, re.NOFLAG) is equivalent to re.compile(pattern, 0) — no special matching behavior; NOFLAG (0) < LOCALE (4) < DEBUG (128) < ASCII (256) in the ascending integer flag value sequence among the four flags in this spec; confirmed Python 3.14.3 macOS"]
    - [noflag_cls_name, re.NOFLAG.__class__.__name__.__eq__,      ["RegexFlag"], true, "re.NOFLAG.__class__.__name__ == 'RegexFlag' — NOFLAG is an instance of the RegexFlag IntFlag enum, not a plain int; 'RegexFlag' has 9 characters; re.NOFLAG.__class__.__name__ (9: 'RegexFlag') contrasts with io.SEEK_SET.__class__.__name__ (3: 'int') — io constants are plain ints while re flags are RegexFlag enum members; NOFLAG's class name 'RegexFlag' (9 chars) > NOFLAG's module name 're' (2 chars) by 7; all re flag constants (NOFLAG, LOCALE, DEBUG, ASCII, IGNORECASE, etc.) share __class__.__name__ == 'RegexFlag' (9 chars); confirmed Python 3.14.3 macOS"]
    - [locale_eq_4,     re.LOCALE.__eq__,                         [4],     true,  "re.LOCALE.__eq__(4) == True — LOCALE is the RegexFlag member with integer value 4 = 2**2; re.LOCALE (or re.L) makes \\w, \\W, \\b, \\B, \\s, \\S dependent on the current locale setting; LOCALE (4) is the smallest non-zero flag value among the four flags in this spec (NOFLAG=0, LOCALE=4, DEBUG=128, ASCII=256); LOCALE (4) == 2**2: bit 2 is set; LOCALE (4) < DEBUG (128 = 2**7) by 124; LOCALE (4) is 4 times larger than NOFLAG (0)? No — 0 is zero, so any ratio with 0 is undefined; LOCALE and ASCII are mutually exclusive flags: using both raises ValueError; confirmed Python 3.14.3 macOS"]
    - [locale_ne_0,     re.LOCALE.__eq__,                         [0],     false, "re.LOCALE.__eq__(0) == False — LOCALE (4) is not equal to NOFLAG (0); LOCALE (4) != NOFLAG (0): LOCALE sets bit 2 (value 4 = 2**2) while NOFLAG sets no bits (value 0); LOCALE (4) > NOFLAG (0) by 4; the distinction between LOCALE (4) and NOFLAG (0) is critical for locale-sensitive regex matching: NOFLAG gives ASCII-only matching while LOCALE enables locale-dependent character class matching; re.LOCALE.__eq__(0) is False because 4 != 0; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.DEBUG and re.ASCII integer values via __eq__
# DEBUG == 128 == 2**7, ASCII == 256 == 2**8
# ASCII (256) > DEBUG (128) by 128 (factor of 2)
# ---------------------------------------------------------------------------

table re_extra169.DEBUG_ASCII_values:
  description: "re.DEBUG.__eq__(128)==True (display debug info, 2**7=128); re.ASCII.__eq__(256)==True (ASCII-only matching, 2**8=256); ASCII (256) is exactly double DEBUG (128); both are RegexFlag members with power-of-two values"
  kind: python_call_eq
  category: identity
  id_prefix: rfval169

  columns: [id, function, args, expected, description]
  rows:
    - [debug_eq_128,  re.DEBUG.__eq__,   [128],  true,  "re.DEBUG.__eq__(128) == True — DEBUG is the RegexFlag member with integer value 128 = 2**7; re.DEBUG (or re.debug lowercase is an alias too) causes the compiled regex to display a debug parse tree when used; DEBUG (128) == 2**7: bit 7 is set; DEBUG (128) > LOCALE (4) by 124; DEBUG (128) < ASCII (256) by 128 — ASCII is exactly double DEBUG; DEBUG (128) is a non-mutually-exclusive flag that can be combined with any other flag: re.compile(pattern, re.DEBUG | re.IGNORECASE) will compile with case-insensitive matching and print debug output; 128 in binary is 10000000 (1 followed by 7 zeros); confirmed Python 3.14.3 macOS"]
    - [debug_ne_256,  re.DEBUG.__eq__,   [256],  false, "re.DEBUG.__eq__(256) == False — DEBUG (128) is not equal to ASCII (256); DEBUG (128) != ASCII (256): they are consecutive powers of two (2**7 and 2**8) but distinct flag values; DEBUG (128) < ASCII (256) by 128 — ASCII is double DEBUG; DEBUG (128) in binary is 10000000 (bit 7 set); ASCII (256) in binary is 100000000 (bit 8 set); the two flags occupy adjacent bits and can be combined: re.DEBUG | re.ASCII == 128 | 256 == 384; re.DEBUG.__eq__(256) is False because 128 != 256; confirmed Python 3.14.3 macOS"]
    - [ascii_eq_256,  re.ASCII.__eq__,   [256],  true,  "re.ASCII.__eq__(256) == True — ASCII is the RegexFlag member with integer value 256 = 2**8; re.ASCII (or re.A) restricts \\w, \\W, \\b, \\B, \\d, \\D, \\s, \\S to ASCII-only matching (equivalent to Python 2 behavior for byte strings); ASCII (256) == 2**8: bit 8 is set; ASCII (256) > DEBUG (128) by 128 — ASCII is exactly double DEBUG; ASCII (256) > LOCALE (4) by 252; ASCII (256) > NOFLAG (0) by 256; ASCII (256) is the largest of the four flag values in this spec: NOFLAG(0) < LOCALE(4) < DEBUG(128) < ASCII(256); 256 in binary is 100000000 (1 followed by 8 zeros); confirmed Python 3.14.3 macOS"]
    - [ascii_ne_128,  re.ASCII.__eq__,   [128],  false, "re.ASCII.__eq__(128) == False — ASCII (256) is not equal to DEBUG (128); ASCII (256) > DEBUG (128) by a factor of 2: ASCII == DEBUG * 2; the two flags differ by exactly 128 and by 1 bit position (bit 8 vs bit 7); ASCII (256) and DEBUG (128) can be combined: re.ASCII | re.DEBUG == 256 | 128 == 384; re.ASCII.__eq__(128) is False because 256 != 128; ASCII (256) is the highest-value flag in this spec and DEBUG (128) is the second highest; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# RegexFlag name and module lengths compared to member class name
# RegexFlag (9) > IntFlag (7) > 're' (2) in lengths
# 'enum' (4) as base module
# ---------------------------------------------------------------------------

table re_extra169.RegexFlag_name_length_comparisons:
  description: "re.RegexFlag name length comparisons: RegexFlag (9) > IntFlag (7) > 're' (2) in class/module name lengths; 'enum' (4) for base module; RegexFlag (9) in the re class name family: Match(5) < Pattern(7)=IntFlag(7) < RegexFlag(9) < PatternError(12)"
  kind: python_call_eq
  category: identity
  id_prefix: rflen169

  columns: [id, function, args, expected, description]
  rows:
    - [rf_name_len,      re.RegexFlag.__name__.__len__,                [],  9, "re.RegexFlag.__name__.__len__() == 9 — 'RegexFlag' has 9 characters: 'Regex' (5) + 'Flag' (4) = 9; RegexFlag (9) places in the ascending re module class name length sequence: Match(5) < Pattern(7) < RegexFlag(9) < PatternError(12); the gap from Pattern (7) to RegexFlag (9) is 2 — the same as the gap from Match (5) to Pattern (7): a uniform 2-character step at the lower end; RegexFlag (9) > Pattern (7) by 2; the 5-character 'Regex' component of 'RegexFlag' is a common abbreviation: 'Regex' (5) == len('Posix') (5) — a coincidental tie; confirmed Python 3.14.3 macOS"]
    - [rf_base_name_len, "re.RegexFlag.__bases__[0].__name__.__len__", [],  7, "re.RegexFlag.__bases__[0].__name__.__len__() == 7 — 'IntFlag' has 7 characters: 'Int' (3) + 'Flag' (4) = 7; IntFlag (7) == Pattern (7) and compile (7 chars) in string length — a coincidental 3-way tie at 7 in the re module name family; IntFlag (7) < RegexFlag (9) by 2: the derived enum class name is 2 characters longer than its base; the 'Flag' suffix (4 chars) is shared between 'IntFlag' (7) and 'RegexFlag' (9) — both end in 'Flag'; IntFlag's 'Int' prefix (3 chars) signals integer-valued flags while RegexFlag's 'Regex' prefix (5 chars) signals regex-specific flags; confirmed Python 3.14.3 macOS"]
    - [rf_mod_len,       re.RegexFlag.__module__.__len__,               [],  2, "re.RegexFlag.__module__.__len__() == 2 — 're' has 2 characters; RegexFlag.__module__ (2: 're') == Pattern.__module__ (2: 're') == Match.__module__ (2: 're') == error.__module__ (2: 're') — all four primary re module types share the same 2-character module name 're'; the module name 're' (2 chars) is the minimum string length across all module and class names in the re module family; RegexFlag (9) / re (2) = 4.5: the class name is 4.5 times longer than the module name; confirmed Python 3.14.3 macOS"]
    - [rf_base_mod_len,  "re.RegexFlag.__bases__[0].__module__.__len__", [], 4, "re.RegexFlag.__bases__[0].__module__.__len__() == 4 — 'enum' has 4 characters: 'e-n-u-m'; 'enum' (4 chars) > 're' (2 chars) by 2: the base class module name is double the derived class module name in length; 'enum' (4 chars) < 'IntFlag' (7 chars): the module name is shorter than the class it contains; 'enum' (4 chars) == len('NOFLAG') / ... wait: len('enum') = 4; 'enum' (4) < 'RegexFlag' (9) by 5; the 'enum' module (4 chars) hosts IntFlag, which is the foundation for all Python integer-valued flag enums including re.RegexFlag; confirmed Python 3.14.3 macOS"]
    - [flag_sum_check,   re.ASCII.__eq__,                               [256], true, "re.ASCII.__eq__(256) == True — ASCII (256 = 2**8) is the largest flag value in this spec; the four flag values form a subset of the RegexFlag power-of-two sequence: NOFLAG(0), LOCALE(4=2**2), DEBUG(128=2**7), ASCII(256=2**8); each non-zero flag value is a distinct power of two, enabling bitwise combination: LOCALE | DEBUG | ASCII == 4 | 128 | 256 == 388; flags can be combined with |: re.compile(pattern, re.ASCII | re.MULTILINE) is valid; ASCII (256) is also known by its single-character alias re.A; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra169.RegexFlag_name_is_RegexFlag:
  description: "re.RegexFlag.__name__ == 'RegexFlag' — RegexFlag is the IntFlag enum class containing all re module flag constants; 'RegexFlag' has 9 characters: 'Regex' (5) + 'Flag' (4) = 9; RegexFlag (9) places between Pattern (7) and PatternError (12) in the re class name length sequence: Match(5) < Pattern(7) < RegexFlag(9) < PatternError(12); the gap from Pattern (7) to RegexFlag (9) is 2 — the same as the Match-to-Pattern gap; all re flag constants (IGNORECASE, MULTILINE, DOTALL, VERBOSE, ASCII, LOCALE, UNICODE, DEBUG, NOFLAG) are RegexFlag members; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.RegexFlag.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra169.RegexFlag_module_is_re:
  description: "re.RegexFlag.__module__ == 're' — RegexFlag is exported from the public 're' module; 're' has 2 characters; RegexFlag.__module__ (2 chars) == Pattern.__module__ (2 chars) == Match.__module__ (2 chars): the three primary re module types share the 2-character module name 're'; the uniform module name means all re module objects (patterns, matches, flags, errors) share the same module attribution; 're' (2 chars) is the minimum module name length in the re module family; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.RegexFlag.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra169.RegexFlag_base_is_IntFlag:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits from IntFlag (7 chars), the integer-valued flag enum base in the 'enum' module; 'IntFlag' has 7 characters: 'Int' (3) + 'Flag' (4) = 7; IntFlag (7) < RegexFlag (9) by 2 — the base class name is 2 characters shorter; the 'Flag' suffix (4 chars) is shared by both 'IntFlag' and 'RegexFlag'; IntFlag gives RegexFlag members their integer-compatible semantics: isinstance(re.ASCII, int) is True because IntFlag subclasses int; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.RegexFlag.__bases__[0].__name__.__eq__"
  args: ["IntFlag"]
  expected: true

invariant re_extra169.RegexFlag_base_module_is_enum:
  description: "re.RegexFlag.__bases__[0].__module__ == 'enum' — IntFlag (RegexFlag's base class) lives in the 'enum' module; 'enum' has 4 characters; 'enum' (4 chars) > 're' (2 chars) by 2: the base class's module name is longer than the derived class's module name; RegexFlag (in 're') inherits from IntFlag (in 'enum'): a cross-module class hierarchy; this design allows the re module to leverage Python's standard enum infrastructure for bitwise flag operations; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.RegexFlag.__bases__[0].__module__.__eq__"
  args: ["enum"]
  expected: true

invariant re_extra169.NOFLAG_is_0:
  description: "re.NOFLAG.__eq__(0) == True — NOFLAG is the RegexFlag member with integer value 0, representing no flags; NOFLAG (0) is the additive identity for flag combination: any_flag | NOFLAG == any_flag; NOFLAG (0) is the only falsy RegexFlag member; NOFLAG was added in Python 3.11 as an explicit constant for the 'no flags' state; NOFLAG (0) < LOCALE (4) < DEBUG (128) < ASCII (256): the four flag values form an ascending sequence; re.NOFLAG.__class__.__name__ == 'RegexFlag' — even the zero-valued flag is a proper RegexFlag enum member; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.NOFLAG.__eq__
  args: [0]
  expected: true

invariant re_extra169.DEBUG_is_128:
  description: "re.DEBUG.__eq__(128) == True — DEBUG is the RegexFlag member with integer value 128 = 2**7; re.DEBUG causes the compiled regex engine to print a debug parse tree showing the compiled pattern structure; DEBUG (128) < ASCII (256) by 128: ASCII is exactly double DEBUG in integer value; DEBUG (128) > LOCALE (4) by 124; DEBUG, LOCALE, and ASCII are all distinct powers of two (enabling bitwise combination), while NOFLAG is 0; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.DEBUG.__eq__
  args: [128]
  expected: true

invariant re_extra169.ASCII_is_256:
  description: "re.ASCII.__eq__(256) == True — ASCII is the RegexFlag member with integer value 256 = 2**8; re.ASCII (alias re.A) restricts \\w, \\W, \\b, \\B, \\d, \\D, \\s, \\S to ASCII-only matching; ASCII (256) is the largest flag value among the four flags in this spec: NOFLAG(0) < LOCALE(4) < DEBUG(128) < ASCII(256); ASCII (256) = DEBUG (128) * 2 — consecutive powers of two at bits 7 and 8; ASCII and LOCALE are mutually exclusive: using both raises ValueError; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.ASCII.__eq__
  args: [256]
  expected: true

invariant re_extra169.LOCALE_is_4:
  description: "re.LOCALE.__eq__(4) == True — LOCALE is the RegexFlag member with integer value 4 = 2**2; re.LOCALE (alias re.L) makes \\w, \\W, \\b, \\B, \\s, \\S depend on the current locale; LOCALE (4) is the smallest non-zero flag value among the four flags in this spec; 4 = 2**2 means bit 2 is set; LOCALE (4) > NOFLAG (0); LOCALE (4) < DEBUG (128) by 124; LOCALE and ASCII are mutually exclusive flags; re.LOCALE.__class__.__name__ == 'RegexFlag' — LOCALE is a proper RegexFlag enum member; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.LOCALE.__eq__
  args: [4]
  expected: true
