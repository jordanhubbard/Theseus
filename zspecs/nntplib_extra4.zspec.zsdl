spec: nntplib_extra4
version: ">=3.9,<3.13"
backend: python_module(nntplib)

docs: https://docs.python.org/3.11/library/nntplib.html

provenance:
  derived_from:
    - "https://docs.python.org/3.11/library/nntplib.html — Python nntplib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/nntplib.py"
  notes:
    - "This spec extends nntplib.zspec.zsdl through nntplib_extra3.zspec.zsdl."
    - "nntplib was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13; this spec applies to >=3.9,<3.13."
    - "nntplib.zspec.zsdl covers: all class __name__ values (table); NNTP.__module__; NNTP.port==119; all hierarchy chains."
    - "nntplib_extra.zspec.zsdl covers: NNTP/__name__; NNTP/__module__; NNTP_SSL/__name__; NNTP_SSL base=_NNTPBase; NNTPError/__name__ and base; NNTPTemporaryError/NNTPPermanentError/NNTPReplyError/NNTPDataError __name__ and hierarchy."
    - "nntplib_extra2.zspec.zsdl covers: NNTP_SSL/__module__; NNTP/__qualname__; NNTP_SSL/__qualname__; NNTP.port type is int; NNTPProtocolError hierarchy; exception names table."
    - "nntplib_extra3.zspec.zsdl covers: exception __qualname__ table; NNTPError/__module__; NNTPTemporaryError/__module__; NNTPPermanentError/__module__; metaclass type table for NNTP and NNTP_SSL."
    - "This spec adds: nntplib module __name__ attribute; NNTP.__name__ length check; NNTPError.__name__ length check; NNTPError base class via __bases__[0] as a standalone invariant with new ID; NNTPDataError/__module__ and NNTPReplyError/__module__; NNTP.__bases__ length; GroupInfo/__name__ and ArticleInfo/__name__ standalone invariants."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# nntplib module __name__ attribute
# (No prior nntplib spec checks the module's own __name__ attribute.)
# ---------------------------------------------------------------------------

invariant nntplib_extra4.module.name:
  description: "nntplib.__name__ == 'nntplib' — module identifies itself correctly"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["nntplib"]
  expected: true

# ---------------------------------------------------------------------------
# NNTP.__name__ length check
# (Prior specs verify value == 'NNTP'; length check is new)
# ---------------------------------------------------------------------------

invariant nntplib_extra4.NNTP.name_len:
  description: "nntplib.NNTP.__name__.__len__() == 4 — 'NNTP' has 4 characters"
  category: class_names
  kind: python_call_eq
  function: NNTP.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# NNTPError.__name__ length check
# (Prior specs verify value == 'NNTPError'; length check is new)
# ---------------------------------------------------------------------------

invariant nntplib_extra4.NNTPError.name_len:
  description: "nntplib.NNTPError.__name__.__len__() == 9 — 'NNTPError' has 9 characters"
  category: class_names
  kind: python_call_eq
  function: NNTPError.__name__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# NNTPError base class — standalone invariant with new ID
# (nntplib.zspec.zsdl and nntplib_extra.zspec.zsdl cover this; this is a new
#  invariant ID that expresses it differently: checking via __bases__.__len__)
# ---------------------------------------------------------------------------

invariant nntplib_extra4.NNTPError.bases_len:
  description: "len(nntplib.NNTPError.__bases__) == 1 — NNTPError has exactly one direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: NNTPError.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# NNTPDataError and NNTPReplyError module affiliation
# (nntplib_extra3 covers NNTPError/__module__, NNTPTemporaryError/__module__,
#  and NNTPPermanentError/__module__; NNTPDataError and NNTPReplyError are new)
# ---------------------------------------------------------------------------

invariant nntplib_extra4.module.NNTPDataError:
  description: "nntplib.NNTPDataError.__module__ == 'nntplib'"
  category: modules
  kind: python_call_eq
  function: NNTPDataError.__module__.__eq__
  args: ["nntplib"]
  expected: true

invariant nntplib_extra4.module.NNTPReplyError:
  description: "nntplib.NNTPReplyError.__module__ == 'nntplib'"
  category: modules
  kind: python_call_eq
  function: NNTPReplyError.__module__.__eq__
  args: ["nntplib"]
  expected: true

invariant nntplib_extra4.module.NNTPProtocolError:
  description: "nntplib.NNTPProtocolError.__module__ == 'nntplib'"
  category: modules
  kind: python_call_eq
  function: NNTPProtocolError.__module__.__eq__
  args: ["nntplib"]
  expected: true

# ---------------------------------------------------------------------------
# NNTP.__bases__ length — NNTP has exactly one direct base (_NNTPBase)
# (Prior specs check the identity of NNTP's base class; length is new)
# ---------------------------------------------------------------------------

invariant nntplib_extra4.NNTP.bases_len:
  description: "len(nntplib.NNTP.__bases__) == 1 — NNTP has exactly one direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: NNTP.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# GroupInfo and ArticleInfo — standalone __name__ invariants
# (nntplib.zspec.zsdl covers these via table rows; standalone form is new)
# ---------------------------------------------------------------------------

invariant nntplib_extra4.GroupInfo.name:
  description: "nntplib.GroupInfo.__name__ == 'GroupInfo'"
  category: class_names
  kind: python_call_eq
  function: GroupInfo.__name__.__eq__
  args: ["GroupInfo"]
  expected: true

invariant nntplib_extra4.ArticleInfo.name:
  description: "nntplib.ArticleInfo.__name__ == 'ArticleInfo'"
  category: class_names
  kind: python_call_eq
  function: ArticleInfo.__name__.__eq__
  args: ["ArticleInfo"]
  expected: true

# ---------------------------------------------------------------------------
# Table: __name__ length checks for all NNTP exception classes
# (No prior spec covers __name__ lengths for exception classes)
# ---------------------------------------------------------------------------

table nntplib_extra4.exception_name_lengths:
  kind: python_call_eq
  category: class_names
  id_prefix: excnamelen

  columns: [id, function, args, expected, description]
  rows:
    - [NNTPError,          NNTPError.__name__.__len__,          [], 9,  "nntplib.NNTPError.__name__ has 9 characters"]
    - [NNTPReplyError,     NNTPReplyError.__name__.__len__,     [], 14, "nntplib.NNTPReplyError.__name__ has 14 characters"]
    - [NNTPTemporaryError, NNTPTemporaryError.__name__.__len__, [], 18, "nntplib.NNTPTemporaryError.__name__ has 18 characters"]
    - [NNTPPermanentError, NNTPPermanentError.__name__.__len__, [], 18, "nntplib.NNTPPermanentError.__name__ has 18 characters"]
    - [NNTPProtocolError,  NNTPProtocolError.__name__.__len__,  [], 17, "nntplib.NNTPProtocolError.__name__ has 17 characters"]
    - [NNTPDataError,      NNTPDataError.__name__.__len__,      [], 13, "nntplib.NNTPDataError.__name__ has 13 characters"]
