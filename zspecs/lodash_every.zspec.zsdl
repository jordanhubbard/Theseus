spec: lodash_every
version: ">=4.0.0"
backend: node(lodash.every)

docs: https://lodash.com/docs/#every

provenance:
  derived_from:
    - "lodash.every README — https://www.npmjs.com/package/lodash.every"
    - "Test vectors verified with lodash.every@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.every exports the _.every function directly as module.exports."
    - "every(collection) with no iteratee checks direct truthiness of each element."
    - "every(collection, key) uses property key as the iteratee."
    - "Returns true for empty collection (vacuous truth)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_every.every:
  kind: node_module_call_eq
  function: ~
  category: every
  id_prefix: levery

  columns: [id, args, expected]
  rows:
    - [all_true,     [[true, true, true]],              true]
    - [one_false,    [[true, false, true]],             false]
    - [empty,        [[]],                              true]
    - [prop_all,     [[{"v": true}, {"v": true}], "v"], true]
    - [prop_one_no,  [[{"v": true}, {"v": false}], "v"], false]
