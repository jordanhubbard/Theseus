spec: concurrent_futures_extra251
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py (Future, Executor base definitions)"
    - "CPython source: Lib/concurrent/futures/thread.py (ThreadPoolExecutor)"
    - "CPython source: Lib/concurrent/futures/process.py (ProcessPoolExecutor)"
  notes:
    - "concurrent.futures.__name__ == 'concurrent.futures' (len=18); __package__ == 'concurrent.futures' (len=18) — name and package are identical strings."
    - "concurrent.futures.__all__ has 14 items including 'Future', 'Executor', 'ThreadPoolExecutor', 'ProcessPoolExecutor', 'InterpreterPoolExecutor', 'as_completed', 'wait', and the wait constants."
    - "concurrent.futures._base.__name__ == 'concurrent.futures._base' (len=24); thread.__name__ == 'concurrent.futures.thread' (len=25); process.__name__ == 'concurrent.futures.process' (len=26) — sub-module names grow by 1 character each."
    - "InterpreterPoolExecutor(len=23) was added in Python 3.14; it appears in __all__ on Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures sub-module __name__ identity
#
# concurrent.futures.__name__ == 'concurrent.futures' (len=18)
# concurrent.futures._base.__name__ == 'concurrent.futures._base' (len=24)
# concurrent.futures.thread.__name__ == 'concurrent.futures.thread' (len=25)
# concurrent.futures.process.__name__ == 'concurrent.futures.process' (len=26)
# ---------------------------------------------------------------------------

table concurrent_futures_extra251.submodule_name_identity:
  description: "concurrent.futures sub-module __name__ identity — top-level module name is 'concurrent.futures'(len=18); _base(len=24), thread(len=25), and process(len=26) sub-modules form an ascending sequence of lengths; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfe251mod

  columns: [id, function, args, expected, description]
  rows:
    - [cf_name_eq,      __name__.__eq__,                   ["concurrent.futures"],         true, "concurrent.futures.__name__ == 'concurrent.futures'; verified with Python 3.14.3"]
    - [cf_name_len,     __name__.__len__,                  [],                             18,   "concurrent.futures.__name__.__len__() == 18; verified with Python 3.14.3"]
    - [cf_pkg_eq,       __package__.__eq__,                ["concurrent.futures"],         true, "concurrent.futures.__package__ == 'concurrent.futures'; verified with Python 3.14.3"]
    - [base_name_eq,    _base.__name__.__eq__,             ["concurrent.futures._base"],   true, "concurrent.futures._base.__name__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [base_name_len,   _base.__name__.__len__,            [],                             24,   "concurrent.futures._base.__name__.__len__() == 24; verified with Python 3.14.3"]
    - [thread_name_eq,  thread.__name__.__eq__,            ["concurrent.futures.thread"],  true, "concurrent.futures.thread.__name__ == 'concurrent.futures.thread'; verified with Python 3.14.3"]
    - [thread_name_len, thread.__name__.__len__,           [],                             25,   "concurrent.futures.thread.__name__.__len__() == 25; verified with Python 3.14.3"]
    - [proc_name_eq,    process.__name__.__eq__,           ["concurrent.futures.process"], true, "concurrent.futures.process.__name__ == 'concurrent.futures.process'; verified with Python 3.14.3"]
    - [proc_name_len,   process.__name__.__len__,          [],                             26,   "concurrent.futures.process.__name__.__len__() == 26; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.__all__ membership
#
# __all__ contains: 'Future', 'Executor', 'ThreadPoolExecutor',
#   'ProcessPoolExecutor', 'InterpreterPoolExecutor', 'as_completed', 'wait'
# Total __all__ length: 14
# ---------------------------------------------------------------------------

table concurrent_futures_extra251.all_membership:
  description: "concurrent.futures.__all__ membership — __all__ has 14 items including Future(len=6), Executor(len=8), ThreadPoolExecutor(len=18), ProcessPoolExecutor(len=19), InterpreterPoolExecutor(len=23), as_completed(len=12), and wait(len=4); InterpreterPoolExecutor added in Python 3.14; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfe251all

  columns: [id, function, args, expected, description]
  rows:
    - [all_len,        __all__.__len__,                   [],                        14,   "concurrent.futures.__all__ has 14 items; verified with Python 3.14.3"]
    - [all_future,     __all__.__contains__,              ["Future"],                true, "concurrent.futures.__all__.__contains__('Future') == True; verified with Python 3.14.3"]
    - [all_executor,   __all__.__contains__,              ["Executor"],              true, "concurrent.futures.__all__.__contains__('Executor') == True; verified with Python 3.14.3"]
    - [all_thread,     __all__.__contains__,              ["ThreadPoolExecutor"],    true, "concurrent.futures.__all__.__contains__('ThreadPoolExecutor') == True; verified with Python 3.14.3"]
    - [all_process,    __all__.__contains__,              ["ProcessPoolExecutor"],   true, "concurrent.futures.__all__.__contains__('ProcessPoolExecutor') == True; verified with Python 3.14.3"]
    - [all_interp,     __all__.__contains__,              ["InterpreterPoolExecutor"], true, "concurrent.futures.__all__.__contains__('InterpreterPoolExecutor') == True (Python 3.14+); verified with Python 3.14.3"]
    - [all_completed,  __all__.__contains__,              ["as_completed"],          true, "concurrent.futures.__all__.__contains__('as_completed') == True; verified with Python 3.14.3"]
    - [all_wait,       __all__.__contains__,              ["wait"],                  true, "concurrent.futures.__all__.__contains__('wait') == True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra251
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra251.name_equals_package:
  description: "concurrent.futures.__name__.__eq__(concurrent.futures.__package__) — both __name__ and __package__ equal 'concurrent.futures'(len=18); the top-level package name is identical to its __name__, a characteristic of namespace packages; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra251.process_submodule_name:
  description: "concurrent.futures.process.__name__.__eq__('concurrent.futures.process') returns True — process sub-module has the longest __name__ (len=26) among the three sub-modules (_base=24, thread=25, process=26); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: process.__name__.__eq__
  args: ["concurrent.futures.process"]
  expected: true
