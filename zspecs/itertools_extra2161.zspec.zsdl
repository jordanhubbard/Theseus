spec: itertools_extra2161
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
    - "itertools_extra1936.zspec.zsdl — covers __get__/__set__/__delete__/__set_name__ dict-presence, class name checks for count/cycle/chain/islice/zip_longest/product/combinations/permutations"
  notes:
    - "Wave 2161 (_extra2161): descriptor protocol dict-presence theme — fget/fset/fdel (property attrs), __objclass__ and __func__ (method wrapper attrs)."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All itertools C-extension types (count, cycle, chain, islice, zip_longest, product, combinations, permutations, combinations_with_replacement, accumulate, compress, dropwhile, takewhile, filterfalse, starmap, groupby, pairwise, repeat) do NOT define fget, fset, fdel, __objclass__, or __func__ in their own __dict__."
    - "itertools C types are pure iterator types; they are not descriptors and do not define property-related attributes."
    - "No itertools type carries __get__, __set__, __delete__, __set_name__, fget, fset, fdel, __objclass__, or __func__ in its class __dict__."
  created_at: "2026-04-12"
error_model: python_exceptions

table itertools_extra2161.fget_fset_fdel_core:
  description: "itertools core C-type fget/fset/fdel dict-presence checks — all false"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2161
  columns: [id, function, args, expected]
  rows:
    - ["it2161001", "itertools.count.__dict__.__contains__",        ["fget"],  false]
    - ["it2161002", "itertools.count.__dict__.__contains__",        ["fset"],  false]
    - ["it2161003", "itertools.count.__dict__.__contains__",        ["fdel"],  false]
