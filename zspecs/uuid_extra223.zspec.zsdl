spec: uuid_extra223
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.UUID.__lt__.__name__ == '__lt__' — comparison operator name is '__lt__' (6 characters)."
    - "uuid.UUID.__le__.__name__ == '__le__' — comparison operator name is '__le__' (6 characters)."
    - "uuid.UUID.__gt__.__name__ == '__gt__' — comparison operator name is '__gt__' (6 characters)."
    - "uuid.UUID.__ge__.__name__ == '__ge__' — comparison operator name is '__ge__' (6 characters)."
    - "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__' — qualname includes the UUID class prefix."
    - "uuid.UUID.__le__.__qualname__ == 'UUID.__le__' — qualname includes the UUID class prefix."
    - "uuid.UUID.__gt__.__qualname__ == 'UUID.__gt__' — qualname includes the UUID class prefix."
    - "uuid.UUID.__ge__.__qualname__ == 'UUID.__ge__' — qualname includes the UUID class prefix."
    - "uuid.UUID.__lt__.__module__ == 'uuid' — comparison operators defined in the uuid Python module."
    - "len('UUID.__lt__') == 11 — all four comparison operator qualnames have 11 characters."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID comparison operator name contracts
#
# uuid.UUID.__lt__.__name__ == '__lt__'
# uuid.UUID.__le__.__name__ == '__le__'
# uuid.UUID.__gt__.__name__ == '__gt__'
# uuid.UUID.__ge__.__name__ == '__ge__'
#
# UUID comparison operators are defined in Lib/uuid.py. They compare UUIDs
# by their integer field (the 128-bit integer value). __lt__ is less-than,
# __le__ is less-than-or-equal, __gt__ is greater-than, __ge__ is
# greater-than-or-equal. All four operator names have 6 characters.
# ---------------------------------------------------------------------------

table uuid_extra223.uuid_comparison_op_names:
  description: "UUID.__lt__.__name__=='__lt__'; __le__.__name__=='__le__'; __gt__.__name__=='__gt__'; __ge__.__name__=='__ge__'; comparison operator name contracts; new to extra223"
  kind: python_call_eq
  category: identity
  id_prefix: uuid223

  columns: [id, function, args, expected, description]
  rows:
    - [lt_name_eq,
       "UUID.__lt__.__name__.__eq__",
       ["__lt__"],
       true,
       "uuid.UUID.__lt__.__name__.__eq__('__lt__') == True — UUID.__lt__ compares two UUIDs for less-than ordering by integer value; __name__ is '__lt__' (6 characters); new anchor in extra223 namespace; verified Python 3.14.3"]
    - [le_name_eq,
       "UUID.__le__.__name__.__eq__",
       ["__le__"],
       true,
       "uuid.UUID.__le__.__name__.__eq__('__le__') == True — UUID.__le__ compares two UUIDs for less-than-or-equal ordering by integer value; __name__ is '__le__' (6 characters); same length as __lt__; new anchor in extra223 namespace; verified Python 3.14.3"]
    - [gt_name_eq,
       "UUID.__gt__.__name__.__eq__",
       ["__gt__"],
       true,
       "uuid.UUID.__gt__.__name__.__eq__('__gt__') == True — UUID.__gt__ compares two UUIDs for greater-than ordering by integer value; __name__ is '__gt__' (6 characters); same length as __lt__ and __le__; new anchor in extra223 namespace; verified Python 3.14.3"]
    - [ge_name_eq,
       "UUID.__ge__.__name__.__eq__",
       ["__ge__"],
       true,
       "uuid.UUID.__ge__.__name__.__eq__('__ge__') == True — UUID.__ge__ compares two UUIDs for greater-than-or-equal ordering by integer value; __name__ is '__ge__' (6 characters); all four ordering operators share the same 6-character name length; new anchor in extra223 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid.UUID comparison operator qualname contracts
#
# uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__'
# uuid.UUID.__le__.__qualname__ == 'UUID.__le__'
# uuid.UUID.__gt__.__qualname__ == 'UUID.__gt__'
# uuid.UUID.__ge__.__qualname__ == 'UUID.__ge__'
#
# Qualnames for UUID methods include the 'UUID.' class prefix. All four
# comparison operator qualnames have 11 characters: 'UUID.' (5) + '__XX__' (6).
# ---------------------------------------------------------------------------

table uuid_extra223.uuid_comparison_op_qualnames:
  description: "UUID.__lt__.__qualname__=='UUID.__lt__'; __le__.__qualname__=='UUID.__le__'; __gt__.__qualname__=='UUID.__gt__'; __ge__.__qualname__=='UUID.__ge__'; comparison operator qualname contracts; new to extra223"
  kind: python_call_eq
  category: identity
  id_prefix: uuid223a

  columns: [id, function, args, expected, description]
  rows:
    - [lt_qualname_eq,
       "UUID.__lt__.__qualname__.__eq__",
       ["UUID.__lt__"],
       true,
       "uuid.UUID.__lt__.__qualname__.__eq__('UUID.__lt__') == True — __qualname__ includes the 'UUID.' class prefix; 'UUID.__lt__' is 11 characters; new anchor in extra223 namespace; verified Python 3.14.3"]
    - [le_qualname_eq,
       "UUID.__le__.__qualname__.__eq__",
       ["UUID.__le__"],
       true,
       "uuid.UUID.__le__.__qualname__.__eq__('UUID.__le__') == True — __qualname__ is 'UUID.__le__' (11 characters); same length as UUID.__lt__; new anchor in extra223 namespace; verified Python 3.14.3"]
    - [gt_qualname_eq,
       "UUID.__gt__.__qualname__.__eq__",
       ["UUID.__gt__"],
       true,
       "uuid.UUID.__gt__.__qualname__.__eq__('UUID.__gt__') == True — __qualname__ is 'UUID.__gt__' (11 characters); same length as UUID.__lt__ and UUID.__le__; new anchor in extra223 namespace; verified Python 3.14.3"]
    - [ge_qualname_eq,
       "UUID.__ge__.__qualname__.__eq__",
       ["UUID.__ge__"],
       true,
       "uuid.UUID.__ge__.__qualname__.__eq__('UUID.__ge__') == True — __qualname__ is 'UUID.__ge__' (11 characters); all four ordering operator qualnames share this length; new anchor in extra223 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid.UUID comparison operator module contracts
#
# uuid.UUID.__lt__.__module__ == 'uuid'
# uuid.UUID.__le__.__module__ == 'uuid'
# uuid.UUID.__gt__.__module__ == 'uuid'
# uuid.UUID.__ge__.__module__ == 'uuid'
#
# All comparison operators are defined in the pure Python uuid module
# (Lib/uuid.py). The __module__ attribute is 'uuid' for all of them.
# ---------------------------------------------------------------------------

table uuid_extra223.uuid_comparison_op_modules:
  description: "UUID.__lt__.__module__=='uuid'; __le__.__module__=='uuid'; __gt__.__module__=='uuid'; __ge__.__module__=='uuid'; comparison operator module contracts; new to extra223"
  kind: python_call_eq
  category: identity
  id_prefix: uuid223b

  columns: [id, function, args, expected, description]
  rows:
    - [lt_module_eq,
       "UUID.__lt__.__module__.__eq__",
       ["uuid"],
       true,
       "uuid.UUID.__lt__.__module__.__eq__('uuid') == True — UUID.__lt__ is defined in the pure Python uuid module; __module__ is 'uuid' (4 characters); new anchor in extra223 namespace; verified Python 3.14.3"]
    - [le_module_eq,
       "UUID.__le__.__module__.__eq__",
       ["uuid"],
       true,
       "uuid.UUID.__le__.__module__.__eq__('uuid') == True — UUID.__le__ is defined in the pure Python uuid module; __module__ is 'uuid'; new anchor in extra223 namespace; verified Python 3.14.3"]
    - [gt_module_eq,
       "UUID.__gt__.__module__.__eq__",
       ["uuid"],
       true,
       "uuid.UUID.__gt__.__module__.__eq__('uuid') == True — UUID.__gt__ is defined in the pure Python uuid module; __module__ is 'uuid'; new anchor in extra223 namespace; verified Python 3.14.3"]
    - [ge_module_eq,
       "UUID.__ge__.__module__.__eq__",
       ["uuid"],
       true,
       "uuid.UUID.__ge__.__module__.__eq__('uuid') == True — UUID.__ge__ is defined in the pure Python uuid module; __module__ is 'uuid'; all four ordering operators share this module; new anchor in extra223 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuid_extra223.lt_name_eq:
  description: "uuid.UUID.__lt__.__name__.__eq__('__lt__') == True — UUID.__lt__ implements the less-than comparison operator for UUID objects; it compares two UUIDs by their 128-bit integer representation; __name__ is '__lt__' (6 characters: two leading underscores, 'lt', two trailing underscores); UUID ordering operators allow UUIDs to be sorted with sorted() or used in bisect operations; all four ordering operators (__lt__, __le__, __gt__, __ge__) have the same 6-character __name__; extra223 is the first namespace to anchor UUID.__lt__.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "UUID.__lt__.__name__.__eq__"
  args: ["__lt__"]
  expected: true

invariant uuid_extra223.gt_qualname_eq:
  description: "uuid.UUID.__gt__.__qualname__.__eq__('UUID.__gt__') == True — UUID.__gt__ is the greater-than comparison operator; its __qualname__ is 'UUID.__gt__' (11 characters), composed of the 'UUID.' class prefix (5 characters) followed by the method name '__gt__' (6 characters); all four ordering operator qualnames have the same 11-character length; they are defined in Lib/uuid.py as regular Python methods; extra223 is the first namespace to anchor UUID.__gt__.__qualname__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "UUID.__gt__.__qualname__.__eq__"
  args: ["UUID.__gt__"]
  expected: true

invariant uuid_extra223.lt_qualname_len_11:
  description: "uuid.UUID.__lt__.__qualname__.__len__() == 11 — the qualname 'UUID.__lt__' has 11 characters: 'UUID.' (5) + '__lt__' (6); all four UUID comparison operator qualnames share this 11-character length because the operator names (__lt__, __le__, __gt__, __ge__) are each 6 characters and the 'UUID.' prefix is always 5 characters; this is a portable length anchor that confirms the qualname format; extra223 is the first namespace to anchor this length; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "UUID.__lt__.__qualname__.__len__"
  args: []
  expected: 11
