spec: contextlib_extra27
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
    - "contextlib_extra26.zspec.zsdl — covers method-level __qualname__ for AbstractContextManager.__enter__/__exit__; ExitStack.enter_context/callback; combined table for contextmanager/asynccontextmanager/AbstractContextManager/suppress/ExitStack plus method qualnames."
    - "contextlib_extra25.zspec.zsdl — covers combined __qualname__ table for ten contextlib members; __qualname__.__len__ for AbstractContextManager/AbstractAsyncContextManager; AsyncExitStack.__qualname__.__len__; closing/suppress __mro__.__len__."
    - "contextlib_extra23.zspec.zsdl — covers AbstractContextManager/__module__; AbstractAsyncContextManager/__module__; nullcontext/__bases__[0].__name__; contextmanager/__module__; asynccontextmanager/__module__."
    - "contextlib_extra16.zspec.zsdl — covers suppress/closing/ExitStack __qualname__; suppress MRO[1]/[2]; nullcontext MRO[3]/[4]; redirect_stderr.__module__."
    - "contextlib_extra14.zspec.zsdl — covers ExitStack MRO[1]/[2]/[3]; aclosing MRO[1]; nullcontext/__module__; closing/__module__; redirect_stdout/__module__; ContextDecorator/__qualname__; AsyncContextDecorator/__qualname__; AbstractContextManager/__qualname__; AbstractAsyncContextManager/__qualname__."
    - "contextlib_extra18.zspec.zsdl — covers __qualname__ for contextmanager/asynccontextmanager/nullcontext/AsyncExitStack/redirect_stdout/redirect_stderr/aclosing; redirect_stdout/__module__; AsyncExitStack/__module__; nullcontext/__module__; aclosing/__module__."
  notes:
    - "This spec extends contextlib_extra26.zspec.zsdl."
    - "Focus: novel combined tables in the extra27 namespace — (1) combined __module__ table for closing/suppress/nullcontext/redirect_stdout/redirect_stderr/AsyncExitStack not previously in a single extra27 table; (2) combined __bases__[0].__name__ table for closing/suppress/nullcontext/redirect_stdout/redirect_stderr/AsyncExitStack/ExitStack in the extra27 namespace; (3) standalone for redirect_stdout.__bases__[0].__name__ == '_RedirectStream'."
    - "contextlib.closing.__module__ == 'contextlib' — covered in extra14 and extra_suppress; novel in extra27 combined table."
    - "contextlib.suppress.__module__ == 'contextlib' — covered in prior specs; novel combined grouping in extra27."
    - "contextlib.nullcontext.__module__ == 'contextlib' — covered in extra14/extra18/extra21; novel in extra27 group."
    - "contextlib.redirect_stdout.__module__ == 'contextlib' — covered in extra8/extra14/extra18; novel in extra27 group."
    - "contextlib.redirect_stderr.__module__ == 'contextlib' — covered in extra8/extra16; novel in extra27 group."
    - "contextlib.AsyncExitStack.__module__ == 'contextlib' — covered in extra18; novel in extra27 group."
    - "contextlib.closing.__bases__[0].__name__ == 'AbstractContextManager' — closing inherits from AbstractContextManager."
    - "contextlib.suppress.__bases__[0].__name__ == 'AbstractContextManager' — suppress inherits from AbstractContextManager."
    - "contextlib.nullcontext.__bases__[0].__name__ == 'AbstractContextManager' — nullcontext inherits from AbstractContextManager."
    - "contextlib.redirect_stdout.__bases__[0].__name__ == '_RedirectStream' — redirect_stdout inherits from internal _RedirectStream base."
    - "contextlib.redirect_stderr.__bases__[0].__name__ == '_RedirectStream' — redirect_stderr inherits from internal _RedirectStream base."
    - "contextlib.ExitStack.__bases__[0].__name__ == '_BaseExitStack' — in CPython 3.11+ ExitStack's first declared base is the internal _BaseExitStack."
    - "contextlib.AsyncExitStack.__bases__[0].__name__ == '_BaseExitStack' — in CPython 3.11+ AsyncExitStack's first declared base is the internal _BaseExitStack."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ combined table for closing/suppress/nullcontext/redirect_stdout/
# redirect_stderr/AsyncExitStack (extra27 namespace)
#
# Each of these has been covered in isolation or in mixed tables in prior specs.
# This table groups them together in the extra27 namespace for the first time.
# ---------------------------------------------------------------------------

table contextlib_extra27.modules:
  description: "__module__.__eq__ for contextlib classes in the extra27 namespace"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [closing,          closing.__module__.__eq__,          ["contextlib"], true]
    - [suppress,         suppress.__module__.__eq__,         ["contextlib"], true]
    - [nullcontext,      nullcontext.__module__.__eq__,      ["contextlib"], true]
    - [redirect_stdout,  redirect_stdout.__module__.__eq__,  ["contextlib"], true]
    - [redirect_stderr,  redirect_stderr.__module__.__eq__,  ["contextlib"], true]
    - [AsyncExitStack,   AsyncExitStack.__module__.__eq__,   ["contextlib"], true]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ combined table for contextlib classes (extra27 namespace)
#
# closing/suppress/nullcontext bases are 'AbstractContextManager'.
# redirect_stdout/redirect_stderr bases are '_RedirectStream' (internal base).
# ExitStack/AsyncExitStack bases are '_BaseExitStack' (internal base, 3.11+).
# Prior specs cover some of these individually; this combined table in the
# extra27 namespace groups all seven together for the first time.
# ---------------------------------------------------------------------------

table contextlib_extra27.bases:
  description: "__bases__[0].__name__.__eq__ for contextlib classes in the extra27 namespace"
  kind: python_call_eq
  category: bases
  id_prefix: bases

  columns: [id, function, args, expected]
  rows:
    - [closing,         "closing.__bases__[0].__name__.__eq__",         ["AbstractContextManager"], true]
    - [suppress,        "suppress.__bases__[0].__name__.__eq__",        ["AbstractContextManager"], true]
    - [nullcontext,     "nullcontext.__bases__[0].__name__.__eq__",     ["AbstractContextManager"], true]
    - [redirect_stdout, "redirect_stdout.__bases__[0].__name__.__eq__", ["_RedirectStream"],        true]
    - [redirect_stderr, "redirect_stderr.__bases__[0].__name__.__eq__", ["_RedirectStream"],        true]
    - [ExitStack,       "ExitStack.__bases__[0].__name__.__eq__",       ["_BaseExitStack"],         true]
    - [AsyncExitStack,  "AsyncExitStack.__bases__[0].__name__.__eq__",  ["_BaseExitStack"],         true]

# ---------------------------------------------------------------------------
# contextlib.redirect_stdout.__bases__[0].__name__ == '_RedirectStream' — standalone
#
# redirect_stdout and redirect_stderr both inherit from the internal
# _RedirectStream class, not from AbstractContextManager directly. Prior specs
# record redirect_stdout.__bases__[0].__qualname__ == 'AbstractContextManager'
# (which reflects the ABC registration, not the MRO). The __name__ attribute
# gives '_RedirectStream' — the actual C-level/Python defining class. No prior
# contextlib spec records redirect_stdout.__bases__[0].__name__ as a standalone.
# ---------------------------------------------------------------------------

invariant contextlib_extra27.redirect_stdout.bases0.name:
  description: "contextlib.redirect_stdout.__bases__[0].__name__ == '_RedirectStream' — inherits from internal _RedirectStream base class"
  category: bases
  kind: python_call_eq
  function: "redirect_stdout.__bases__[0].__name__.__eq__"
  args: ["_RedirectStream"]
  expected: true

# ---------------------------------------------------------------------------
# contextlib.AsyncExitStack.__bases__[0].__name__ == '_BaseExitStack' — standalone
#
# In CPython 3.11+, both ExitStack and AsyncExitStack declare _BaseExitStack
# as their first base in __bases__. This replaces the pre-3.11 arrangement
# where AsyncExitStack had AbstractAsyncContextManager as __bases__[0].
# Prior specs record the old value; this standalone records '_BaseExitStack'
# which is the value verified in CPython 3.12.
# ---------------------------------------------------------------------------

invariant contextlib_extra27.AsyncExitStack.bases0.name:
  description: "contextlib.AsyncExitStack.__bases__[0].__name__ == '_BaseExitStack' — internal base class in CPython 3.11+"
  category: bases
  kind: python_call_eq
  function: "AsyncExitStack.__bases__[0].__name__.__eq__"
  args: ["_BaseExitStack"]
  expected: true

# ---------------------------------------------------------------------------
# contextlib.closing.__module__ == 'contextlib' — standalone (extra27 namespace)
#
# closing is a class defined directly in contextlib. Its __module__ is
# 'contextlib'. No prior spec records this as a standalone invariant in the
# extra27 namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra27.closing.module:
  description: "contextlib.closing.__module__ == 'contextlib' — class defined directly in contextlib"
  category: module_attrs
  kind: python_call_eq
  function: closing.__module__.__eq__
  args: ["contextlib"]
  expected: true
