spec: hashlib_extra132
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s class identity and __module__=='_blake2' and __qualname__ / new.__class__.__name__=='function' / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership for sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512/sha3_224/sha3_384/blake2b/blake2s/shake_128/shake_256 / algorithms_available membership / new/__qualname__/__len__() (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ (table + invariants)."
    - "hashlib_extra94.zspec.zsdl — covers hashlib.algorithms_available/algorithms_guaranteed set class identity and membership / sha256/sha512/sha1/md5 constructor __class__.__name__=='builtin_function_or_method' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in prior hashlib spec files."
    - "Wave 272 theme: hashlib.__all__ tuple membership — pbkdf2_hmac/new/file_digest/algorithms_guaranteed/sha256/md5/sha512/sha1/sha224/sha384/blake2b/blake2s/sha3_256/shake_128 presence / pbkdf2_hmac function identity (name/qualname/module/class)."
    - "hashlib.__all__ is a tuple with 19 entries. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'pbkdf2_hmac' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'new' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'file_digest' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'algorithms_guaranteed' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha256' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'md5' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha512' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha1' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha224' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha384' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'blake2b' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'blake2s' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha3_256' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'shake_128' in hashlib.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.__all__ is a tuple (not list). extra98 first anchors class name ('tuple') and length (19); this spec anchors membership of specific named entries — not covered by prior hashlib specs."
    - "Note: pbkdf2_hmac is a C-level builtin from _hashlib (not a pure-Python function). Its __module__ is '_hashlib', not 'hashlib', distinguishing it from file_digest (which is pure Python with __module__=='hashlib')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.__all__.__contains__('pbkdf2_hmac')
# hashlib.__all__.__contains__('new')
# hashlib.__all__.__contains__('file_digest')
# hashlib.__all__.__contains__('algorithms_guaranteed')
# hashlib.__all__.__contains__('sha256')
#
# Wave 272 theme: hashlib.__all__ tuple membership for function/constant names.
#
# hashlib.__all__ is a 19-entry tuple. extra98 first anchors its class name
# ('tuple') and length (19). This table anchors membership of specific named
# entries: pbkdf2_hmac, new, file_digest, algorithms_guaranteed, sha256.
# pbkdf2_hmac is a C-level PBKDF2 builtin from _hashlib (PKCS #5 v2.0).
# file_digest (added 3.11) is the pure-Python file hashing helper.
# algorithms_guaranteed is a frozenset-like constant (actually a set).
# new is the unified constructor wrapper. sha256 is the SHA-256 constructor.
# No prior hashlib spec anchors any __all__.__contains__ calls under hashlibpbkdf132.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra132.all_membership_functions:
  description: "hashlib.__all__.__contains__('pbkdf2_hmac')==True / __contains__('new')==True / __contains__('file_digest')==True / __contains__('algorithms_guaranteed')==True / __contains__('sha256')==True — __all__ is a 19-entry tuple; extra98 anchors class name and length; this table anchors membership of pbkdf2_hmac/new/file_digest/algorithms_guaranteed/sha256; first hashlibpbkdf132 anchor for __all__ membership"
  kind: python_call_eq
  category: module_all
  id_prefix: hashlibpbkdf132

  columns: [id, function, args, expected]
  rows:
    - [all_contains_pbkdf2_hmac,         __all__.__contains__, ["pbkdf2_hmac"],         true]
    - [all_contains_new,                 __all__.__contains__, ["new"],                 true]
    - [all_contains_file_digest,         __all__.__contains__, ["file_digest"],         true]
    - [all_contains_algorithms_guaranteed, __all__.__contains__, ["algorithms_guaranteed"], true]
    - [all_contains_sha256,              __all__.__contains__, ["sha256"],              true]

# ---------------------------------------------------------------------------
# hashlib.__all__.__contains__('md5')
# hashlib.__all__.__contains__('sha512')
# hashlib.__all__.__contains__('sha1')
# hashlib.__all__.__contains__('blake2b')
# hashlib.__all__.__contains__('sha3_256')
# hashlib.__all__.__contains__('shake_128')
#
# Wave 272 theme: hashlib.__all__ tuple membership for algorithm constructor names.
#
# md5, sha512, sha1 are core OpenSSL-backed constructors in _hashlib.
# blake2b is a C-extension type from _blake2. sha3_256 is a SHA-3 constructor.
# shake_128 is an XOF (extendable-output function). All six are listed in
# hashlib.__all__, confirming their public API membership. This table extends
# the membership checks to the algorithm constructor names not covered in
# hashlibpbkdf132.all_membership_functions. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra132.all_membership_algorithms:
  description: "hashlib.__all__.__contains__('md5')==True / __contains__('sha512')==True / __contains__('sha1')==True / __contains__('blake2b')==True / __contains__('sha3_256')==True / __contains__('shake_128')==True — all six are in the 19-entry __all__ tuple; md5/sha512/sha1 are OpenSSL-backed builtins; blake2b is a _blake2 type; sha3_256 and shake_128 are OpenSSL SHA-3/XOF builtins; first hashlibpbkdf132 anchor for algorithm constructor __all__ membership"
  kind: python_call_eq
  category: module_all
  id_prefix: hashlibpbkdf132

  columns: [id, function, args, expected]
  rows:
    - [all_contains_md5,      __all__.__contains__, ["md5"],      true]
    - [all_contains_sha512,   __all__.__contains__, ["sha512"],   true]
    - [all_contains_sha1,     __all__.__contains__, ["sha1"],     true]
    - [all_contains_blake2b,  __all__.__contains__, ["blake2b"],  true]
    - [all_contains_sha3_256, __all__.__contains__, ["sha3_256"], true]
    - [all_contains_shake_128, __all__.__contains__, ["shake_128"], true]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac')
# hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac')
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib')
# hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 272 theme: hashlib.pbkdf2_hmac function identity.
#
# pbkdf2_hmac (Password-Based Key Derivation Function 2, PKCS #5 v2.0) is a
# C-level builtin from the _hashlib extension module. Unlike file_digest (a
# pure-Python function with __module__=='hashlib'), pbkdf2_hmac lives in _hashlib
# and has __class__.__name__=='builtin_function_or_method'. Its __name__ and
# __qualname__ are both 'pbkdf2_hmac' (top-level C builtin, no class prefix).
# No prior hashlib spec anchors pbkdf2_hmac identity under hashlibpbkdf132.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra132.pbkdf2_hmac_identity:
  description: "hashlib.pbkdf2_hmac/__name__.__eq__('pbkdf2_hmac')==True / __qualname__.__eq__('pbkdf2_hmac')==True / __module__.__eq__('_hashlib')==True / __class__.__name__.__eq__('builtin_function_or_method')==True — pbkdf2_hmac is a PKCS#5 v2.0 PBKDF2 C builtin from _hashlib; __module__=='_hashlib' (not 'hashlib') distinguishing it from pure-Python file_digest; __name__==__qualname__=='pbkdf2_hmac' (top-level, no class prefix); first hashlibpbkdf132 anchor for pbkdf2_hmac identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibpbkdf132

  columns: [id, function, args, expected]
  rows:
    - [pbkdf2_name,    pbkdf2_hmac.__name__.__eq__,              ["pbkdf2_hmac"],               true]
    - [pbkdf2_qualname, pbkdf2_hmac.__qualname__.__eq__,         ["pbkdf2_hmac"],               true]
    - [pbkdf2_module,   pbkdf2_hmac.__module__.__eq__,           ["_hashlib"],                  true]
    - [pbkdf2_class,    pbkdf2_hmac.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# hashlib.__all__.__contains__('pbkdf2_hmac') — standalone
#
# hashlib.__all__ contains 'pbkdf2_hmac'. pbkdf2_hmac is part of hashlib's
# public API surface (listed in the 19-entry __all__ tuple). PBKDF2-HMAC is a
# widely used key-stretching algorithm for password hashing. Its presence in
# __all__ is verified here as a standalone anchor. extra98 anchors __all__ class
# name ('tuple') and length (19); this spec first anchors __all__ membership for
# individual named entries under hashlibpbkdf132.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra132.all_contains_pbkdf2_hmac:
  description: "hashlib.__all__.__contains__('pbkdf2_hmac') == True — pbkdf2_hmac is part of hashlib's 19-entry __all__ tuple (public API); PBKDF2-HMAC is a PKCS#5 v2.0 key-stretching algorithm for password hashing; extra98 anchors __all__ class name and length; first standalone for __all__ membership under hashlibpbkdf132"
  category: module_all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["pbkdf2_hmac"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') — standalone
#
# hashlib.pbkdf2_hmac.__module__ is '_hashlib'. pbkdf2_hmac is a C-level
# builtin from the _hashlib extension, not a pure-Python function in Lib/hashlib.py.
# This contrasts with hashlib.file_digest, which is pure Python with
# __module__=='hashlib'. pbkdf2_hmac is the C-accelerated PBKDF2 implementation
# that uses _hashlib's OpenSSL-backed HMAC. No prior hashlib spec anchors
# pbkdf2_hmac.__module__.__eq__ as a standalone under hashlibpbkdf132.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra132.pbkdf2_module_hashlib:
  description: "hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') == True — pbkdf2_hmac is a C-level builtin from _hashlib (not Lib/hashlib.py); contrasts with file_digest (__module__=='hashlib', pure Python); no prior hashlib spec anchors pbkdf2_hmac.__module__ as a standalone; first standalone under hashlibpbkdf132"
  category: type_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__all__.__contains__('blake2b') — standalone
#
# hashlib.__all__ contains 'blake2b'. blake2b is a C-extension class from the
# _blake2 module (not _hashlib), but it is listed in hashlib.__all__ because
# hashlib re-exports it as part of the public API. The 19-entry __all__ tuple
# includes both the OpenSSL-backed constructors and the _blake2 class types.
# No prior hashlib spec anchors __all__.__contains__('blake2b') as a standalone
# under hashlibpbkdf132. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra132.all_contains_blake2b:
  description: "hashlib.__all__.__contains__('blake2b') == True — blake2b is a _blake2 C-extension class re-exported through hashlib's 19-entry __all__ tuple; the public API includes both OpenSSL-backed builtins and _blake2 type objects; no prior hashlib spec anchors __all__.__contains__('blake2b') as standalone; first standalone under hashlibpbkdf132"
  category: module_all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__all__.__contains__('shake_128') — standalone
#
# hashlib.__all__ contains 'shake_128'. shake_128 is the SHAKE128 XOF
# (extendable-output function) from the SHA-3 family, backed by OpenSSL and
# listed in hashlib.__all__ alongside the fixed-output hash constructors.
# Its presence in __all__ confirms it is part of the hashlib public API,
# accessible via both hashlib.shake_128 and hashlib.new('shake_128').
# No prior hashlib spec anchors __all__.__contains__('shake_128') as a standalone
# under hashlibpbkdf132. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra132.all_contains_shake_128:
  description: "hashlib.__all__.__contains__('shake_128') == True — shake_128 (SHAKE128 XOF from SHA-3 family) is in hashlib's 19-entry __all__ tuple confirming its public API status; accessible as hashlib.shake_128 and hashlib.new('shake_128'); no prior hashlib spec anchors __all__.__contains__('shake_128') as standalone; first standalone under hashlibpbkdf132"
  category: module_all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["shake_128"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.pbkdf2_hmac.__class__.__name__ is 'builtin_function_or_method'.
# pbkdf2_hmac is implemented as a C builtin in the _hashlib extension (not
# as a Python function). This distinguishes it from hashlib.file_digest (class
# 'function', pure Python) and from blake2b/blake2s (class 'type', C-extension
# type objects). No prior hashlib spec anchors pbkdf2_hmac.__class__.__name__
# as a standalone under hashlibpbkdf132.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra132.pbkdf2_class_builtin:
  description: "hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method') == True — pbkdf2_hmac is a C builtin from _hashlib; class is 'builtin_function_or_method' (not 'function' like file_digest, not 'type' like blake2b); no prior hashlib spec anchors pbkdf2_hmac class name as standalone; first standalone under hashlibpbkdf132"
  category: type_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

