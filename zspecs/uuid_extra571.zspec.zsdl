spec: uuid_extra571
version: ">=3.9"
backend: python_module(uuid)
docs: "https://docs.python.org/3/library/uuid.html"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers UUID class and module-level function identity for the uuid module"
  created_at: "2026-04-12T00:00:00Z"

table uuid_extra571.class_identity:
  description: "uuid.UUID and module-level function __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: uxe571ci
  columns: [id, function, args, expected]
  rows:
    - [uxe571ci001, uuid.UUID.__class__.__name__.__eq__, ["type"], true]
    - [uxe571ci002, uuid.uuid1.__class__.__name__.__eq__, ["function"], true]
    - [uxe571ci003, uuid.uuid3.__class__.__name__.__eq__, ["function"], true]
    - [uxe571ci004, uuid.uuid4.__class__.__name__.__eq__, ["function"], true]
    - [uxe571ci005, uuid.uuid5.__class__.__name__.__eq__, ["function"], true]
table uuid_extra571.qualname_identity:
  description: "uuid.UUID qualname, module, and method qualname identity"
  kind: python_call_eq
  category: identity
  id_prefix: uxe571qi
  columns: [id, function, args, expected]
  rows:
    - [uxe571qi001, uuid.UUID.__qualname__.__eq__, ["UUID"], true]
    - [uxe571qi002, uuid.UUID.__module__.__eq__, ["uuid"], true]
    - [uxe571qi003, uuid.UUID.__init__.__qualname__.__eq__, ["UUID.__init__"], true]
    - [uxe571qi004, uuid.UUID.__str__.__qualname__.__eq__, ["UUID.__str__"], true]
    - [uxe571qi005, uuid.UUID.__repr__.__qualname__.__eq__, ["UUID.__repr__"], true]
    - [uxe571qi006, uuid.UUID.__eq__.__qualname__.__eq__, ["UUID.__eq__"], true]
    - [uxe571qi007, uuid.UUID.__hash__.__qualname__.__eq__, ["UUID.__hash__"], true]