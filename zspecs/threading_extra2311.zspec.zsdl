spec: threading_extra2311
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 601 (_extra2311): __abstractmethods__ content and absence checks."
    - "threading.Thread: designed for subclassing (override run()), but not abstract — no ABC base, no abstract methods."
    - "threading.Event, Condition, Semaphore, Barrier, local: all concrete, non-abstract."
    - "threading.RLock: built-in factory function returning a C type; not abstract."
    - "threading.BoundedSemaphore, Timer: Python subclasses of Semaphore/Thread; not abstract."
    - "None of these classes carry __abstractmethods__ in their class dict."
    - "threading.Thread.run() is a concrete no-op method, not declared abstract, so __abstractmethods__ is absent (not even an empty frozenset)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __abstractmethods__ absence from __dict__ — core threading classes
#
# threading.Thread, Event, Condition, Semaphore, Barrier, local are all
# concrete Python classes. None register __abstractmethods__ in their
# class dict. All checks expected False.
# ---------------------------------------------------------------------------

table threading_extra2311.abstract_absence_core:
  description: "core threading classes have no __abstractmethods__ in class dict — all False — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2311

  columns: [id, function, args, expected]
  rows:
    - ["th2311001", "threading.Thread.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["th2311002", "threading.Event.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["th2311003", "threading.Condition.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["th2311004", "threading.Semaphore.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["th2311005", "threading.Barrier.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["th2311006", "threading.local.__dict__.__contains__", ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 2: __abstractmethods__ absence from __dict__ — derived threading classes
#
# threading.BoundedSemaphore and threading.Timer are Python-level subclasses.
# They also carry no __abstractmethods__ entry in their own class dicts.
# ---------------------------------------------------------------------------

table threading_extra2311.abstract_absence_derived:
  description: "derived threading classes have no __abstractmethods__ in class dict — all False — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2311

  columns: [id, function, args, expected]
  rows:
    - ["th2311007", "threading.BoundedSemaphore.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["th2311008", "threading.Timer.__dict__.__contains__", ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 3: __abstractmethods__ direct access raises AttributeError
#
# threading.Thread is explicitly designed for subclassing via run(), but run()
# is a concrete no-op — not declared abstract. Therefore __abstractmethods__
# is absent entirely (not even an empty frozenset) and raises AttributeError.
# Same for all other threading synchronization primitives.
# ---------------------------------------------------------------------------

table threading_extra2311.abstract_attr_error:
  description: "threading classes raise AttributeError on __abstractmethods__ access — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: th2311

  columns: [id, function, args, expected]
  rows:
    - ["th2311009", "threading.Thread.__abstractmethods__.__len__", [], "AttributeError"]
    - ["th2311010", "threading.Event.__abstractmethods__.__len__", [], "AttributeError"]
    - ["th2311011", "threading.Condition.__abstractmethods__.__len__", [], "AttributeError"]
    - ["th2311012", "threading.Semaphore.__abstractmethods__.__len__", [], "AttributeError"]
    - ["th2311013", "threading.Barrier.__abstractmethods__.__len__", [], "AttributeError"]
    - ["th2311014", "threading.local.__abstractmethods__.__len__", [], "AttributeError"]

# ---------------------------------------------------------------------------
# Table 4: __abstractmethods__.__contains__ chained access raises AttributeError
#
# threading.Thread.run is not abstract; __abstractmethods__.__contains__("run")
# raises AttributeError because __abstractmethods__ does not exist at all.
# Same pattern for other plausible method names across other threading types.
# ---------------------------------------------------------------------------

table threading_extra2311.abstract_contains_error:
  description: "threading __abstractmethods__.__contains__ raises AttributeError — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: th2311

  columns: [id, function, args, expected]
  rows:
    - ["th2311015", "threading.Thread.__abstractmethods__.__contains__", ["run"], "AttributeError"]
    - ["th2311016", "threading.Thread.__abstractmethods__.__contains__", ["start"], "AttributeError"]
    - ["th2311017", "threading.Event.__abstractmethods__.__contains__", ["wait"], "AttributeError"]
    - ["th2311018", "threading.Condition.__abstractmethods__.__contains__", ["acquire"], "AttributeError"]
    - ["th2311019", "threading.Semaphore.__abstractmethods__.__contains__", ["acquire"], "AttributeError"]
    - ["th2311020", "threading.Barrier.__abstractmethods__.__contains__", ["wait"], "AttributeError"]

# ---------------------------------------------------------------------------
# Table 5: BoundedSemaphore and Timer attr-error and contains-error
#
# Derived classes also have no __abstractmethods__. Confirms that subclassing
# a concrete class (Semaphore, Thread) does not introduce __abstractmethods__
# unless the subclass itself declares abstract methods.
# ---------------------------------------------------------------------------

table threading_extra2311.derived_abstract_error:
  description: "threading derived classes raise AttributeError on __abstractmethods__ — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: th2311

  columns: [id, function, args, expected]
  rows:
    - ["th2311021", "threading.BoundedSemaphore.__abstractmethods__.__len__", [], "AttributeError"]
    - ["th2311022", "threading.Timer.__abstractmethods__.__len__", [], "AttributeError"]
    - ["th2311023", "threading.BoundedSemaphore.__abstractmethods__.__contains__", ["acquire"], "AttributeError"]
    - ["th2311024", "threading.Timer.__abstractmethods__.__contains__", ["run"], "AttributeError"]
