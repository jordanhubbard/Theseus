spec: abc_extra4
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Extends abc.zspec.zsdl, abc_extra.zspec.zsdl, abc_extra2.zspec.zsdl, abc_extra3.zspec.zsdl."
    - "Previous specs cover: class/function __name__ attributes, __module__ for ABC/ABCMeta/abstractmethod, get_cache_token type and module, ABC/ABCMeta __bases__ structure, abstractmethod.__isabstractmethod__, ABC.__dict__ keys, ABC/__abstractmethods__ frozenset."
    - "abc.abstractmethod.__module__ == 'abc' — the decorator function is defined in the abc module."
    - "abc.abstractclassmethod.__module__ == 'abc' — deprecated class defined in the abc module (<3.13)."
    - "abc.abstractstaticmethod.__module__ == 'abc' — deprecated class defined in the abc module (<3.13)."
    - "abc.abstractproperty.__module__ == 'abc' — deprecated class defined in the abc module (<3.13)."
    - "abc.get_cache_token.__module__ == '_abc' — implemented in the C extension _abc."
    - "abc.ABC.__module__ == 'abc' — ABC base class is defined in abc."
    - "abc.ABCMeta.__module__ == 'abc' — ABCMeta metaclass is defined in abc."
    - "abc.ABCMeta.__name__ == 'ABCMeta' — orthogonal cross-check of the metaclass name."
    - "abc.abstractmethod.__class__.__name__ == 'function' — abstractmethod is a plain function."
    - "abc.abstractclassmethod.__class__.__name__ == 'type' — it is a class, not a plain function (<3.13)."
    - "abc.abstractstaticmethod.__class__.__name__ == 'type' — it is a class, not a plain function (<3.13)."
    - "abc.abstractproperty.__class__.__name__ == 'type' — it is a class (<3.13)."
    - "abc.ABC.__class__.__name__ == 'ABCMeta' — ABC's metaclass is ABCMeta."
    - "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' — C-level function."
    - "abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset' — already in abc_extra3, confirmed here via module path."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module affiliation — core abc names
#
# The principal public names in the abc module must all report __module__
# equal to 'abc' (except get_cache_token, which lives in the _abc C extension).
# ---------------------------------------------------------------------------

invariant abc_extra4.abstractmethod.module:
  description: "abc.abstractmethod.__module__ == 'abc'"
  category: module
  kind: python_call_eq
  function: abstractmethod.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra4.ABC.module:
  description: "abc.ABC.__module__ == 'abc'"
  category: module
  kind: python_call_eq
  function: ABC.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra4.ABCMeta.module:
  description: "abc.ABCMeta.__module__ == 'abc'"
  category: module
  kind: python_call_eq
  function: ABCMeta.__module__.__eq__
  args: ["abc"]
  expected: true

# ---------------------------------------------------------------------------
# Deprecated abc names — module affiliation (Python 3.9–3.12)
#
# abstractclassmethod, abstractstaticmethod, and abstractproperty were
# deprecated in Python 3.3 and removed in Python 3.13. When present their
# __module__ is 'abc'.
# ---------------------------------------------------------------------------

invariant abc_extra4.abstractclassmethod.module:
  description: "abc.abstractclassmethod.__module__ == 'abc' (deprecated, present <3.13)"
  category: module
  version: ">=3.9,<3.13"
  kind: python_call_eq
  function: abstractclassmethod.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra4.abstractstaticmethod.module:
  description: "abc.abstractstaticmethod.__module__ == 'abc' (deprecated, present <3.13)"
  category: module
  version: ">=3.9,<3.13"
  kind: python_call_eq
  function: abstractstaticmethod.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra4.abstractproperty.module:
  description: "abc.abstractproperty.__module__ == 'abc' (deprecated, present <3.13)"
  category: module
  version: ">=3.9,<3.13"
  kind: python_call_eq
  function: abstractproperty.__module__.__eq__
  args: ["abc"]
  expected: true

# ---------------------------------------------------------------------------
# get_cache_token — module is '_abc' (C extension)
#
# abc.get_cache_token is implemented in the _abc C extension. Its __module__
# attribute equals '_abc', not 'abc'. We test for that exact string.
# ---------------------------------------------------------------------------

invariant abc_extra4.get_cache_token.module_is_abc_c:
  description: "abc.get_cache_token.__module__ == '_abc' — implemented in the C extension"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

# ---------------------------------------------------------------------------
# __class__.__name__ — kind of each abc public object
#
# abstractmethod is a function decorated at module level; its class is
# 'function'. The deprecated abstractclassmethod/abstractstaticmethod/
# abstractproperty are all classes, so their class is 'type'.
# ABC's metaclass is ABCMeta. get_cache_token is a C builtin.
# ---------------------------------------------------------------------------

invariant abc_extra4.abstractmethod.class_name:
  description: "abc.abstractmethod.__class__.__name__ == 'function'"
  category: class_of_object
  kind: python_call_eq
  function: abstractmethod.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant abc_extra4.abstractclassmethod.class_name:
  description: "abc.abstractclassmethod.__class__.__name__ == 'type' (deprecated, present <3.13)"
  category: class_of_object
  version: ">=3.9,<3.13"
  kind: python_call_eq
  function: abstractclassmethod.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra4.abstractstaticmethod.class_name:
  description: "abc.abstractstaticmethod.__class__.__name__ == 'type' (deprecated, present <3.13)"
  category: class_of_object
  version: ">=3.9,<3.13"
  kind: python_call_eq
  function: abstractstaticmethod.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra4.abstractproperty.class_name:
  description: "abc.abstractproperty.__class__.__name__ == 'type' (deprecated, present <3.13)"
  category: class_of_object
  version: ">=3.9,<3.13"
  kind: python_call_eq
  function: abstractproperty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra4.ABC.class_name:
  description: "abc.ABC.__class__.__name__ == 'ABCMeta' — ABC's metaclass is ABCMeta"
  category: class_of_object
  kind: python_call_eq
  function: ABC.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra4.get_cache_token.class_name:
  description: "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method'"
  category: class_of_object
  kind: python_call_eq
  function: get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# ABCMeta.__name__ — cross-check
#
# Orthogonal to abc_extra3 which read the name via __bases__ traversal; here
# we access __name__ directly on ABCMeta for a cleaner cross-check.
# ---------------------------------------------------------------------------

invariant abc_extra4.ABCMeta.name:
  description: "abc.ABCMeta.__name__ == 'ABCMeta'"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

# ---------------------------------------------------------------------------
# ABC.__abstractmethods__ — class name is frozenset
#
# Confirmed here via the module-level __module__ path as an orthogonal check.
# abc.ABC has no abstract methods so its __abstractmethods__ is an empty
# frozenset.
# ---------------------------------------------------------------------------

invariant abc_extra4.ABC.abstractmethods_class_name:
  description: "abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset'"
  category: abc_class
  kind: python_call_eq
  function: ABC.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true
