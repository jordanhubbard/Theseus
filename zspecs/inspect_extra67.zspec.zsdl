spec: inspect_extra67
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra66.zspec.zsdl."
    - "Wave 233 theme: __defaults__ values for inspect functions."
    - "isfunction.__defaults__ is None (no positional defaults: def isfunction(object)) → __defaults__.__class__.__name__ == 'NoneType'. Verified with Python 3.14.3."
    - "isclass.__defaults__ is None (def isclass(object)) → 'NoneType'. Verified with Python 3.14.3."
    - "ismodule.__defaults__ is None (def ismodule(object)) → 'NoneType'. Verified with Python 3.14.3."
    - "signature.__defaults__ is None (def signature(obj, *, follow_wrapped=True, globals=None, locals=None, eval_str=False) — all keyword-only args, no positional defaults) → 'NoneType'. Verified with Python 3.14.3."
    - "getmembers.__defaults__.__class__.__name__ == 'tuple' — def getmembers(object, predicate=None) has one positional default (predicate=None); __defaults__ == (None,) is a 1-element tuple. Verified with Python 3.14.3."
    - "getmembers.__defaults__.__len__() == 1 — one positional default. Verified with Python 3.14.3."
    - "getmembers.__defaults__[0].__class__.__name__ == 'NoneType' — the default value None has __class__.__name__ == 'NoneType'. Verified with Python 3.14.3."
    - "isbuiltin.__defaults__ is None (def isbuiltin(object)) → 'NoneType'. Verified with Python 3.14.3."
    - "getfile.__defaults__ is None (def getfile(object)) → 'NoneType'. Verified with Python 3.14.3."
    - "getdoc.__defaults__ is None (def getdoc(object)) → 'NoneType'. Verified with Python 3.14.3."
    - "Prior inspect specs did not check __defaults__ for any inspect function. All checks in this spec are new to extra67."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect functions with no positional defaults — extra67
#
# Wave 233 theme: __defaults__ is None for single-argument inspect functions.
#
# Python functions with no positional defaults have __defaults__ == None
# (not a tuple at all — the attribute exists but is None). For these inspect
# functions, None.__class__.__name__ == 'NoneType'.
#
# isfunction(object)  — no defaults → __defaults__ is None
# isclass(object)     — no defaults → __defaults__ is None
# ismodule(object)    — no defaults → __defaults__ is None
# signature(obj, *, ...) — keyword-only defaults only → __defaults__ is None
#
# No prior inspect spec checks __defaults__.__class__.__name__ for any inspect
# function. New to extra67.
# ---------------------------------------------------------------------------

table inspect_extra67.none_defaults_class_name:
  description: "inspect single-argument functions __defaults__.__class__.__name__.__eq__('NoneType')==true — no positional defaults so __defaults__ is None; wave 233 __defaults__ checks; new to extra67"
  kind: python_call_eq
  category: defaults_type
  id_prefix: inspdef67

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_defaults_class_name_eq_NoneType,
       isfunction.__defaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "inspect.isfunction.__defaults__.__class__.__name__.__eq__('NoneType') == True — isfunction is a pure-Python function (Lib/inspect.py) with signature isfunction(object); it has a single positional parameter 'object' with no default value; therefore __defaults__ is None (not a tuple); None.__class__ is the NoneType type and NoneType.__name__ == 'NoneType' (8 chars); __eq__ returns True; no prior inspect spec checks __defaults__.__class__.__name__ for isfunction; new to extra67"]
    - [isclass_defaults_class_name_eq_NoneType,
       isclass.__defaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "inspect.isclass.__defaults__.__class__.__name__.__eq__('NoneType') == True — isclass is a pure-Python function (Lib/inspect.py) with signature isclass(object); no positional defaults so __defaults__ is None; None.__class__.__name__ == 'NoneType'; __eq__ returns True; no prior inspect spec checks __defaults__.__class__.__name__ for isclass; new to extra67"]
    - [ismodule_defaults_class_name_eq_NoneType,
       ismodule.__defaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "inspect.ismodule.__defaults__.__class__.__name__.__eq__('NoneType') == True — ismodule is a pure-Python function (Lib/inspect.py) with signature ismodule(object); no positional defaults so __defaults__ is None; None.__class__.__name__ == 'NoneType'; __eq__ returns True; no prior inspect spec checks __defaults__.__class__.__name__ for ismodule; new to extra67"]
    - [signature_defaults_class_name_eq_NoneType,
       signature.__defaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "inspect.signature.__defaults__.__class__.__name__.__eq__('NoneType') == True — signature is a pure-Python function (Lib/inspect.py) with signature signature(obj, *, follow_wrapped=True, globals=None, locals=None, eval_str=False); all non-obj parameters are keyword-only (after the bare *); __defaults__ only covers positional defaults, not keyword-only defaults (those are in __kwdefaults__); since 'obj' has no default, __defaults__ is None; None.__class__.__name__ == 'NoneType'; __eq__ returns True; no prior inspect spec checks __defaults__.__class__.__name__ for signature; new to extra67"]

# ---------------------------------------------------------------------------
# getmembers.__defaults__ — extra67
#
# Wave 233 theme: getmembers has one positional default.
#
# inspect.getmembers is a pure-Python function (Lib/inspect.py) with:
#   def getmembers(object, predicate=None)
# The parameter 'predicate' has a default value of None.
# Therefore:
#   getmembers.__defaults__.__class__.__name__ == 'tuple'  (1-element tuple)
#   getmembers.__defaults__.__len__() == 1
#
# No prior inspect spec checks getmembers.__defaults__. New to extra67.
# ---------------------------------------------------------------------------

table inspect_extra67.getmembers_defaults:
  description: "getmembers.__defaults__ is a 1-element tuple (predicate=None); __class__.__name__=='tuple', __len__()==1; wave 233 __defaults__ checks; new to extra67"
  kind: python_call_eq
  category: defaults_type
  id_prefix: inspdef67

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_defaults_class_name_eq_tuple,
       getmembers.__defaults__.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "inspect.getmembers.__defaults__.__class__.__name__.__eq__('tuple') == True — getmembers is a pure-Python function (Lib/inspect.py) with signature getmembers(object, predicate=None); the parameter 'predicate' has a positional default value of None; __defaults__ is therefore a 1-element tuple (None,); tuple.__name__ == 'tuple' (5 chars); __eq__ returns True; no prior inspect spec checks getmembers.__defaults__.__class__.__name__; new to extra67"]
    - [getmembers_defaults_len_eq_1,
       getmembers.__defaults__.__len__,
       [],
       1,
       "inspect.getmembers.__defaults__.__len__() == 1 — getmembers(object, predicate=None) has exactly one positional default (predicate=None); __defaults__ == (None,), a 1-element tuple; tuple.__len__() returns 1; no prior inspect spec checks getmembers.__defaults__.__len__(); new to extra67"]

# ---------------------------------------------------------------------------
# getmembers.__defaults__[0] element type — extra67
#
# Wave 233 theme: getmembers.__defaults__[0] is None → 'NoneType'.
#
# getmembers.__defaults__ == (None,)
# getmembers.__defaults__[0] is None → __class__.__name__ == 'NoneType'
#
# Function values containing '[' MUST be double-quoted in table rows.
# No prior inspect spec checks getmembers.__defaults__[0]. New to extra67.
# ---------------------------------------------------------------------------

table inspect_extra67.getmembers_defaults_first:
  description: "getmembers.__defaults__[0].__class__.__name__=='NoneType' — the single default value is None; wave 233 __defaults__ element check; function with '[' is double-quoted; new to extra67"
  kind: python_call_eq
  category: defaults_element_type
  id_prefix: inspdef67

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_defaults_0_class_name_eq_NoneType,
       "getmembers.__defaults__[0].__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "inspect.getmembers.__defaults__[0].__class__.__name__.__eq__('NoneType') == True — getmembers(object, predicate=None) has __defaults__ == (None,); the first (and only) element __defaults__[0] is the Python singleton None; None.__class__ is the NoneType type; NoneType.__name__ == 'NoneType' (8 chars); __eq__ returns True; function value contains '[' so it is double-quoted in the table row; no prior inspect spec checks getmembers.__defaults__[0].__class__.__name__; new to extra67"]

# ---------------------------------------------------------------------------
# More inspect functions with no positional defaults — extra67
#
# Wave 233 theme: additional inspect functions whose __defaults__ is None.
#
# isbuiltin(object)  — def isbuiltin(object) → no defaults → __defaults__ is None
# getfile(object)    — def getfile(object) → no defaults → __defaults__ is None
# getdoc(object)     — def getdoc(object) → no defaults → __defaults__ is None
#
# All three are pure-Python functions in Lib/inspect.py with a single
# positional argument and no default values.
#
# No prior inspect spec checks __defaults__ for isbuiltin, getfile, or getdoc.
# New to extra67.
# ---------------------------------------------------------------------------

table inspect_extra67.inspect_more_none_defaults:
  description: "isbuiltin/getfile/getdoc.__defaults__.__class__.__name__=='NoneType' — single-argument functions with no positional defaults; wave 233 __defaults__ checks; new to extra67"
  kind: python_call_eq
  category: defaults_type
  id_prefix: inspdef67

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_defaults_class_name_eq_NoneType,
       isbuiltin.__defaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "inspect.isbuiltin.__defaults__.__class__.__name__.__eq__('NoneType') == True — isbuiltin is a pure-Python function (Lib/inspect.py) with signature isbuiltin(object); it has a single positional parameter 'object' with no default value; therefore __defaults__ is None; None.__class__.__name__ == 'NoneType'; __eq__ returns True; no prior inspect spec checks __defaults__.__class__.__name__ for isbuiltin; new to extra67"]
    - [getfile_defaults_class_name_eq_NoneType,
       getfile.__defaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "inspect.getfile.__defaults__.__class__.__name__.__eq__('NoneType') == True — getfile is a pure-Python function (Lib/inspect.py) with signature getfile(object); it has a single positional parameter 'object' with no default value; therefore __defaults__ is None; None.__class__.__name__ == 'NoneType'; __eq__ returns True; no prior inspect spec checks __defaults__.__class__.__name__ for getfile; new to extra67"]
    - [getdoc_defaults_class_name_eq_NoneType,
       getdoc.__defaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "inspect.getdoc.__defaults__.__class__.__name__.__eq__('NoneType') == True — getdoc is a pure-Python function (Lib/inspect.py) with signature getdoc(object); it has a single positional parameter 'object' with no default value; therefore __defaults__ is None; None.__class__.__name__ == 'NoneType'; __eq__ returns True; no prior inspect spec checks __defaults__.__class__.__name__ for getdoc; new to extra67"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra67
# ---------------------------------------------------------------------------

invariant inspect_extra67.isfunction_defaults_None_type:
  description: "inspect.isfunction.__defaults__.__class__.__name__.__eq__('NoneType') == True — isfunction(object) has no positional defaults; __defaults__ is None; wave 233 __defaults__ checks; new to extra67"
  kind: python_call_eq
  function: isfunction.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant inspect_extra67.getmembers_defaults_tuple:
  description: "inspect.getmembers.__defaults__.__class__.__name__.__eq__('tuple') == True — getmembers(object, predicate=None) has one positional default; __defaults__ is a tuple; wave 233 __defaults__ checks; new to extra67"
  kind: python_call_eq
  function: getmembers.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra67.getmembers_defaults_len_1:
  description: "inspect.getmembers.__defaults__.__len__() == 1 — getmembers has exactly 1 positional default (predicate=None); wave 233 __defaults__ length; new to extra67"
  kind: python_call_eq
  function: getmembers.__defaults__.__len__
  args: []
  expected: 1

invariant inspect_extra67.getmembers_defaults_first_NoneType:
  description: "inspect.getmembers.__defaults__[0].__class__.__name__.__eq__('NoneType') == True — the single default value is None; wave 233 __defaults__ element check; new to extra67"
  kind: python_call_eq
  function: "getmembers.__defaults__[0].__class__.__name__.__eq__"
  args: ["NoneType"]
  expected: true

invariant inspect_extra67.signature_defaults_None_type:
  description: "inspect.signature.__defaults__.__class__.__name__.__eq__('NoneType') == True — signature(obj, *, ...) has only keyword-only defaults; __defaults__ is None; wave 233 __defaults__ checks; new to extra67"
  kind: python_call_eq
  function: signature.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true
