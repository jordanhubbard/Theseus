# ---------------------------------------------------------------------------
# Table 4: Executor base class __trunc__/__floor__/__ceil__ checks
#
# Wave 629 theme: concurrent.futures.Executor is the abstract base class for
# ThreadPoolExecutor and ProcessPoolExecutor. It also does not define any
# rounding or truncation operator protocol in its own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2731.executor_base_rounding:
  description: "concurrent.futures.Executor __trunc__/__floor__/__ceil__ dict-presence checks — abstract base class also defines none"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2731

  columns: [id, function, args, expected]
  rows:
    - ["cf2731010", "concurrent.futures.Executor.__dict__.__contains__", ["__trunc__"], false]
    - ["cf2731011", "concurrent.futures.Executor.__dict__.__contains__", ["__floor__"], false]
    - ["cf2731012", "concurrent.futures.Executor.__dict__.__contains__", ["__ceil__"],  false]
