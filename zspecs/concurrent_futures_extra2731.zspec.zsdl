spec: concurrent_futures_extra2731
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 629 (_extra2731): __trunc__, __floor__, __ceil__ dict-presence checks (rounding/truncation operators)."
    - "concurrent.futures types (Future, ThreadPoolExecutor, ProcessPoolExecutor) are concurrency primitives, not numeric types."
    - "None of these types define truncation, floor, or ceiling rounding protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __trunc__ dict-presence checks
#
# Wave 629 theme: concurrent.futures executor and future types do not
# implement the truncation operator. __trunc__ does not appear in any of
# these classes' own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2731.trunc_protocol:
  description: "concurrent.futures types __trunc__ dict-presence checks — none define truncation in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2731

  columns: [id, function, args, expected]
  rows:
    - ["cf2731001", "concurrent.futures.Future.__dict__.__contains__",              ["__trunc__"], false]
    - ["cf2731002", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__trunc__"], false]
    - ["cf2731003", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__trunc__"], false]

