spec: importlib_extra8
version: ">=3.9"
backend: python_module(importlib)

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.html — Python importlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
    - "CPython source: Lib/importlib/_bootstrap.py"
    - "importlib_util.zspec.zsdl — covers importlib.util functions via python_module(importlib.util) backend"
    - "importlib_abc.zspec.zsdl — covers importlib.abc classes via python_module(importlib.abc) backend"
    - "importlib_machinery.zspec.zsdl — covers importlib.machinery classes via python_module(importlib.machinery) backend"
  notes:
    - "This spec extends importlib.zspec.zsdl through importlib_extra7.zspec.zsdl."
    - "importlib_extra7 covers: __loader__.__class__.__name__; __spec__.name; __file__ class/endswith; util.LazyLoader name/module/qualname/__bases__; util.decode_source name/module/qualname."
    - "No prior spec covers importlib.__spec__.__class__.__name__ ('ModuleSpec')."
    - "No prior spec covers importlib.__spec__.origin (endswith __init__.py) or importlib.__spec__.has_location."
    - "No prior spec covers importlib.__spec__.submodule_search_locations class name."
    - "No prior spec covers importlib.machinery submodule __name__ or __package__."
    - "No prior spec covers importlib.machinery.SOURCE_SUFFIXES or BYTECODE_SUFFIXES class names."
    - "No prior spec covers importlib.util.source_hash or importlib.util.resolve_name function attrs."
    - "No prior spec covers importlib.util.cache_from_source name/module/qualname."
    - "importlib.__spec__.__class__.__name__ == 'ModuleSpec' — module spec objects are instances of importlib.machinery.ModuleSpec."
    - "importlib.__spec__.origin.endswith('__init__.py') == True — importlib is a package; origin is its __init__.py."
    - "importlib.__spec__.has_location == True — importlib is loaded from a file on disk."
    - "importlib.__spec__.submodule_search_locations.__class__.__name__ == 'list' — package search paths are a list."
    - "importlib.machinery.__name__ == 'importlib.machinery' — the machinery submodule's fully-qualified name."
    - "importlib.machinery.__package__ == 'importlib' — machinery is part of the importlib package."
    - "importlib.machinery.SOURCE_SUFFIXES.__class__.__name__ == 'list' — suffixes are stored as a list."
    - "importlib.machinery.BYTECODE_SUFFIXES.__class__.__name__ == 'list' — bytecode suffixes are a list."
    - "importlib.util.source_hash.__name__ == 'source_hash', __module__ == 'importlib.util', __qualname__ == 'source_hash'."
    - "importlib.util.resolve_name.__name__ == 'resolve_name', __module__ == 'importlib.util', __qualname__ == 'resolve_name'."
    - "importlib.util.cache_from_source.__module__ == '_frozen_importlib_external' — defined in the frozen external bootstrap."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# importlib.__spec__ — ModuleSpec class identity and key fields
#
# importlib_extra7 covers __spec__.name == 'importlib'.
# No prior spec covers __spec__.__class__.__name__, __spec__.origin,
# __spec__.has_location, or __spec__.submodule_search_locations.
# ---------------------------------------------------------------------------

invariant importlib_extra8.spec_class_name:
  description: "importlib.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant importlib_extra8.spec_origin_endswith_init:
  description: "importlib.__spec__.origin.endswith('__init__.py') == True — importlib package origin is its __init__.py"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.origin.endswith
  args: ["__init__.py"]
  expected: true

invariant importlib_extra8.spec_has_location:
  description: "importlib.__spec__.has_location == True — importlib is loaded from a file on disk"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true

invariant importlib_extra8.spec_submodule_search_locations_is_list:
  description: "importlib.__spec__.submodule_search_locations.__class__.__name__ == 'list'"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.machinery submodule — name and package
#
# importlib_machinery.zspec.zsdl tests machinery via python_module(importlib.machinery).
# No prior importlib.zspec.zsdl or importlib_extra*.zspec.zsdl tests machinery
# as a dotted attribute of the importlib module object.
# ---------------------------------------------------------------------------

invariant importlib_extra8.machinery_name:
  description: "importlib.machinery.__name__ == 'importlib.machinery'"
  category: submodules
  kind: python_call_eq
  function: machinery.__name__.__eq__
  args: ["importlib.machinery"]
  expected: true

invariant importlib_extra8.machinery_package:
  description: "importlib.machinery.__package__ == 'importlib'"
  category: submodules
  kind: python_call_eq
  function: machinery.__package__.__eq__
  args: ["importlib"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.machinery.SOURCE_SUFFIXES and BYTECODE_SUFFIXES — class names
#
# No prior importlib spec (with python_module(importlib) backend) covers
# the suffix list constants in the machinery submodule.
# ---------------------------------------------------------------------------

invariant importlib_extra8.machinery_SOURCE_SUFFIXES_is_list:
  description: "importlib.machinery.SOURCE_SUFFIXES.__class__.__name__ == 'list'"
  category: machinery_attrs
  kind: python_call_eq
  function: machinery.SOURCE_SUFFIXES.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant importlib_extra8.machinery_BYTECODE_SUFFIXES_is_list:
  description: "importlib.machinery.BYTECODE_SUFFIXES.__class__.__name__ == 'list'"
  category: machinery_attrs
  kind: python_call_eq
  function: machinery.BYTECODE_SUFFIXES.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# importlib.util.source_hash — name, module, qualname
#
# No prior importlib spec covers util.source_hash. It is a pure-Python
# function defined in importlib.util for hashing source bytes.
# ---------------------------------------------------------------------------

table importlib_extra8.util_source_hash_attrs:
  kind: python_call_eq
  category: function_attrs
  id_prefix: src_hash

  columns: [id, function, args, expected]
  rows:
    - [name,    util.source_hash.__name__.__eq__,    ["source_hash"],   true]
    - [module,  util.source_hash.__module__.__eq__,  ["importlib.util"], true]
    - [qualname, util.source_hash.__qualname__.__eq__, ["source_hash"],  true]

# ---------------------------------------------------------------------------
# importlib.util.resolve_name — name, module, qualname
#
# No prior importlib spec covers util.resolve_name. It is a pure-Python
# function in importlib.util that resolves a relative module name to an
# absolute name.
# ---------------------------------------------------------------------------

table importlib_extra8.util_resolve_name_attrs:
  kind: python_call_eq
  category: function_attrs
  id_prefix: res_name

  columns: [id, function, args, expected]
  rows:
    - [name,    util.resolve_name.__name__.__eq__,    ["resolve_name"],   true]
    - [module,  util.resolve_name.__module__.__eq__,  ["importlib.util"], true]
    - [qualname, util.resolve_name.__qualname__.__eq__, ["resolve_name"], true]

# ---------------------------------------------------------------------------
# importlib.util.cache_from_source — module check
#
# No prior importlib spec covers util.cache_from_source. It is defined in
# the frozen external bootstrap (_frozen_importlib_external), not in
# importlib.util proper.
# ---------------------------------------------------------------------------

invariant importlib_extra8.util_cache_from_source.module:
  description: "importlib.util.cache_from_source.__module__ == '_frozen_importlib_external'"
  category: function_attrs
  kind: python_call_eq
  function: util.cache_from_source.__module__.__eq__
  args: ["_frozen_importlib_external"]
  expected: true

invariant importlib_extra8.util_cache_from_source.name:
  description: "importlib.util.cache_from_source.__name__ == 'cache_from_source'"
  category: function_attrs
  kind: python_call_eq
  function: util.cache_from_source.__name__.__eq__
  args: ["cache_from_source"]
  expected: true
