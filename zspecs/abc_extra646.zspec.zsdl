spec: abc_extra646
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module: ABCMeta, ABC, abstractclassmethod, abstractstaticmethod, abstractproperty"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __bases__ tuple identity and method qualname checks for abc module classes; abstractclassmethod, abstractstaticmethod, and abstractproperty are deprecated since 3.3 but still present"
  created_at: "2026-04-12T00:00:00Z"

table abc_extra646.bases_identity:
  description: "Identity checks that __bases__ attributes are tuples for abc classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: ab646bm
  columns: [id, function, args, expected]
  rows:
    - [ab646bm001, abc.ABCMeta.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [ab646bm002, abc.ABC.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [ab646bm003, abc.abstractclassmethod.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [ab646bm004, abc.abstractstaticmethod.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [ab646bm005, abc.abstractproperty.__bases__.__class__.__name__.__eq__, ["tuple"], true]

table abc_extra646.method_qualname_identity:
  description: "Identity checks for abc class method qualnames and module membership"
  kind: python_call_eq
  category: method_identity
  id_prefix: ab646am
  columns: [id, function, args, expected]
  rows:
    - [ab646am001, abc.ABC.__subclasshook__.__qualname__.__eq__, ["ABC.__subclasshook__"], true]
    - [ab646am002, abc.ABCMeta.__subclasshook__.__qualname__.__eq__, ["ABCMeta.__subclasshook__"], true]
    - [ab646am003, abc.abstractclassmethod.__init__.__qualname__.__eq__, ["abstractclassmethod.__init__"], true]
    - [ab646am004, abc.abstractstaticmethod.__init__.__qualname__.__eq__, ["abstractstaticmethod.__init__"], true]
    - [ab646am005, abc.abstractproperty.__init__.__qualname__.__eq__, ["abstractproperty.__init__"], true]
    - [ab646am006, abc.ABCMeta.__init__.__qualname__.__eq__, ["ABCMeta.__init__"], true]
    - [ab646am007, abc.ABCMeta.__init__.__module__.__eq__, ["abc"], true]
