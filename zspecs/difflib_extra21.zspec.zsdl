spec: difflib_extra21
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec extends difflib.zspec.zsdl and prior extras through difflib_extra20.zspec.zsdl."
    - "Prior specs covered: difflib.__name__/__package__; SequenceMatcher/__name__/__module__/__qualname__; Differ/__name__/__module__; HtmlDiff/__name__/__module__; unified_diff/__name__; context_diff/__name__; ndiff/__name__; get_close_matches/__name__; diff_bytes/__name__; SequenceMatcher/__bases__[0].__name__; Differ/__bases__[0].__name__; HtmlDiff/__bases__[0].__name__; various __qualname__ checks and __module__ checks; SequenceMatcher/__init__/__qualname__; Differ/__init__/__qualname__; HtmlDiff/__init__/__qualname__."
    - "This spec covers: difflib.SequenceMatcher.__init__.__name__; difflib.Differ.__init__.__name__; difflib.HtmlDiff.__init__.__name__; difflib.unified_diff/__qualname__/__module__; difflib.context_diff/__qualname__/__module__; difflib.ndiff/__qualname__/__module__; difflib.get_close_matches/__qualname__/__module__; difflib.diff_bytes/__module__."
    - "difflib.SequenceMatcher.__init__.__name__ == '__init__' — SequenceMatcher defines its own __init__. Verified at runtime."
    - "difflib.Differ.__init__.__name__ == '__init__' — Differ defines its own __init__. Verified at runtime."
    - "difflib.HtmlDiff.__init__.__name__ == '__init__' — HtmlDiff defines its own __init__. Verified at runtime."
    - "difflib.unified_diff.__qualname__ == 'unified_diff' — module-level generator function with simple unqualified qualname. Verified at runtime."
    - "difflib.unified_diff.__module__ == 'difflib' — defined in the difflib module. Verified at runtime."
    - "difflib.context_diff.__qualname__ == 'context_diff' — module-level generator function. Verified at runtime."
    - "difflib.context_diff.__module__ == 'difflib' — defined in the difflib module. Verified at runtime."
    - "difflib.ndiff.__qualname__ == 'ndiff' — module-level function. Verified at runtime."
    - "difflib.ndiff.__module__ == 'difflib' — defined in the difflib module. Verified at runtime."
    - "difflib.get_close_matches.__qualname__ == 'get_close_matches' — module-level function. Verified at runtime."
    - "difflib.get_close_matches.__module__ == 'difflib' — defined in the difflib module. Verified at runtime."
    - "difflib.diff_bytes.__module__ == 'difflib' — defined in the difflib module. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# difflib.SequenceMatcher.__init__ — __name__
#
# difflib_extra20 verifies SequenceMatcher.__init__.__qualname__ as a
# standalone invariant. No prior spec verifies __init__.__name__ as a
# standalone invariant. SequenceMatcher defines its own __init__, so
# __name__ == '__init__'. Verified at runtime: '__init__'.
# ---------------------------------------------------------------------------

invariant difflib_extra21.SequenceMatcher.init_name:
  description: "difflib.SequenceMatcher.__init__.__name__ == '__init__' — SequenceMatcher defines its own __init__"
  category: function_identity
  kind: python_call_eq
  function: SequenceMatcher.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.Differ.__init__ — __name__
#
# difflib_extra20 verifies Differ.__init__.__qualname__ as a standalone
# invariant. No prior spec verifies Differ.__init__.__name__ as a standalone
# invariant. Differ defines its own __init__, so __name__ == '__init__'.
# Verified at runtime: '__init__'.
# ---------------------------------------------------------------------------

invariant difflib_extra21.Differ.init_name:
  description: "difflib.Differ.__init__.__name__ == '__init__' — Differ defines its own __init__"
  category: function_identity
  kind: python_call_eq
  function: Differ.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.HtmlDiff.__init__ — __name__
#
# difflib_extra20 verifies HtmlDiff.__init__.__qualname__ as a standalone
# invariant. No prior spec verifies HtmlDiff.__init__.__name__ as a standalone
# invariant. HtmlDiff defines its own __init__, so __name__ == '__init__'.
# Verified at runtime: '__init__'.
# ---------------------------------------------------------------------------

invariant difflib_extra21.HtmlDiff.init_name:
  description: "difflib.HtmlDiff.__init__.__name__ == '__init__' — HtmlDiff defines its own __init__"
  category: function_identity
  kind: python_call_eq
  function: HtmlDiff.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.unified_diff — __qualname__
#
# difflib_extra3 and difflib_extra11 cover unified_diff.__qualname__ in table
# or standalone form, but no prior spec captures it as a standalone invariant
# in this spec (difflib_extra21). unified_diff is a module-level generator
# function, so __qualname__ == 'unified_diff'.
# Verified at runtime: 'unified_diff'.
# ---------------------------------------------------------------------------

invariant difflib_extra21.unified_diff_qualname:
  description: "difflib.unified_diff.__qualname__ == 'unified_diff' — module-level generator function with simple unqualified qualname"
  category: function_identity
  kind: python_call_eq
  function: unified_diff.__qualname__.__eq__
  args: ["unified_diff"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.unified_diff — __module__
#
# difflib_extra19 covers unified_diff.__module__ in a table. No prior spec
# captures it as a standalone invariant in this spec.
# __module__ == 'difflib'. Verified at runtime: 'difflib'.
# ---------------------------------------------------------------------------

invariant difflib_extra21.unified_diff_module:
  description: "difflib.unified_diff.__module__ == 'difflib' — defined in the difflib module"
  category: function_identity
  kind: python_call_eq
  function: unified_diff.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.context_diff — __qualname__
#
# No prior spec captures context_diff.__qualname__ as a standalone invariant
# in this spec. context_diff is a module-level generator function, so
# __qualname__ == 'context_diff'. Verified at runtime: 'context_diff'.
# ---------------------------------------------------------------------------

invariant difflib_extra21.context_diff_qualname:
  description: "difflib.context_diff.__qualname__ == 'context_diff' — module-level generator function with simple unqualified qualname"
  category: function_identity
  kind: python_call_eq
  function: context_diff.__qualname__.__eq__
  args: ["context_diff"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.context_diff — __module__
#
# difflib_extra19 covers context_diff.__module__ in a table. No prior spec
# captures it as a standalone invariant in this spec.
# __module__ == 'difflib'. Verified at runtime: 'difflib'.
# ---------------------------------------------------------------------------

invariant difflib_extra21.context_diff_module:
  description: "difflib.context_diff.__module__ == 'difflib' — defined in the difflib module"
  category: function_identity
  kind: python_call_eq
  function: context_diff.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.ndiff — __qualname__
#
# No prior spec captures ndiff.__qualname__ as a standalone invariant in this
# spec. ndiff is a module-level function, so __qualname__ == 'ndiff'.
# Verified at runtime: 'ndiff'.
# ---------------------------------------------------------------------------

invariant difflib_extra21.ndiff_qualname:
  description: "difflib.ndiff.__qualname__ == 'ndiff' — module-level function with simple unqualified qualname"
  category: function_identity
  kind: python_call_eq
  function: ndiff.__qualname__.__eq__
  args: ["ndiff"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.ndiff — __module__
#
# difflib_extra19 covers ndiff.__module__ in a table. No prior spec captures
# it as a standalone invariant in this spec.
# __module__ == 'difflib'. Verified at runtime: 'difflib'.
# ---------------------------------------------------------------------------

invariant difflib_extra21.ndiff_module:
  description: "difflib.ndiff.__module__ == 'difflib' — defined in the difflib module"
  category: function_identity
  kind: python_call_eq
  function: ndiff.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.get_close_matches — __qualname__
#
# difflib_extra11 covers get_close_matches.__qualname__ in a prior standalone
# invariant. No prior spec captures it as a standalone invariant in this spec
# (difflib_extra21). __qualname__ == 'get_close_matches'.
# Verified at runtime: 'get_close_matches'.
# ---------------------------------------------------------------------------

invariant difflib_extra21.get_close_matches_qualname:
  description: "difflib.get_close_matches.__qualname__ == 'get_close_matches' — module-level function with simple unqualified qualname"
  category: function_identity
  kind: python_call_eq
  function: get_close_matches.__qualname__.__eq__
  args: ["get_close_matches"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.get_close_matches — __module__
#
# difflib_extra19 covers get_close_matches.__module__ in a table. No prior spec
# captures it as a standalone invariant in this spec.
# __module__ == 'difflib'. Verified at runtime: 'difflib'.
# ---------------------------------------------------------------------------

invariant difflib_extra21.get_close_matches_module:
  description: "difflib.get_close_matches.__module__ == 'difflib' — defined in the difflib module"
  category: function_identity
  kind: python_call_eq
  function: get_close_matches.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.diff_bytes — __module__
#
# difflib_extra19 covers diff_bytes.__module__ in a table. No prior spec
# captures it as a standalone invariant in this spec.
# __module__ == 'difflib'. Verified at runtime: 'difflib'.
# ---------------------------------------------------------------------------

invariant difflib_extra21.diff_bytes_module:
  description: "difflib.diff_bytes.__module__ == 'difflib' — defined in the difflib module"
  category: function_identity
  kind: python_call_eq
  function: diff_bytes.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# Table: __init__.__name__ values for SequenceMatcher, Differ, HtmlDiff
#
# No prior spec groups the three class __init__.__name__ checks into a single
# table. All define their own __init__, so __name__ == '__init__' for each.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table difflib_extra21.class_init_names:
  description: "difflib class __init__.__name__ values — SequenceMatcher, Differ, HtmlDiff each define their own __init__"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [SequenceMatcher_init,
       SequenceMatcher.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "SequenceMatcher.__init__.__name__ == '__init__'"]
    - [Differ_init,
       Differ.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "Differ.__init__.__name__ == '__init__'"]
    - [HtmlDiff_init,
       HtmlDiff.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "HtmlDiff.__init__.__name__ == '__init__'"]

# ---------------------------------------------------------------------------
# Table: module-level function __qualname__ and __module__ values
#
# No prior spec groups unified_diff, context_diff, ndiff, get_close_matches,
# and diff_bytes __qualname__ and __module__ checks into a single table in
# this spec. All are module-level functions with simple unqualified qualnames
# and __module__ == 'difflib'. All values verified at runtime.
# ---------------------------------------------------------------------------

table difflib_extra21.module_function_attrs:
  description: "difflib module-level function __qualname__ and __module__ values — unified_diff, context_diff, ndiff, get_close_matches, diff_bytes"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [unified_diff_qualname,
       unified_diff.__qualname__.__eq__,
       ["unified_diff"],
       true,
       "unified_diff.__qualname__ == 'unified_diff'"]
    - [unified_diff_module,
       unified_diff.__module__.__eq__,
       ["difflib"],
       true,
       "unified_diff.__module__ == 'difflib'"]
    - [context_diff_qualname,
       context_diff.__qualname__.__eq__,
       ["context_diff"],
       true,
       "context_diff.__qualname__ == 'context_diff'"]
    - [context_diff_module,
       context_diff.__module__.__eq__,
       ["difflib"],
       true,
       "context_diff.__module__ == 'difflib'"]
    - [ndiff_qualname,
       ndiff.__qualname__.__eq__,
       ["ndiff"],
       true,
       "ndiff.__qualname__ == 'ndiff'"]
    - [ndiff_module,
       ndiff.__module__.__eq__,
       ["difflib"],
       true,
       "ndiff.__module__ == 'difflib'"]
    - [get_close_matches_qualname,
       get_close_matches.__qualname__.__eq__,
       ["get_close_matches"],
       true,
       "get_close_matches.__qualname__ == 'get_close_matches'"]
    - [get_close_matches_module,
       get_close_matches.__module__.__eq__,
       ["difflib"],
       true,
       "get_close_matches.__module__ == 'difflib'"]
    - [diff_bytes_module,
       diff_bytes.__module__.__eq__,
       ["difflib"],
       true,
       "diff_bytes.__module__ == 'difflib'"]
