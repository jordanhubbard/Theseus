spec: multiprocessing_extra1126
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module __name__/__spec__.name identity, multiprocessing.pool.Pool class module/qualname/name/method qualnames, multiprocessing.synchronize.Lock/RLock/Semaphore/Condition class module/qualname/name identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing.__name__/__spec__.name/__spec__ class, multiprocessing.pool.Pool module/qualname/name/method qualnames, multiprocessing.synchronize.Lock/RLock/Semaphore/Condition module/qualname/name — behaviors not covered by extra1096 or extra1111"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1126.module_identity:
  description: "multiprocessing module __name__, __spec__.name, and __spec__ class identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: mp1126mi
  columns: [id, function, args, expected]
  rows:
    - [mp1126mi001, multiprocessing.__name__.__eq__,                      ["multiprocessing"],          true]
    - [mp1126mi002, multiprocessing.__spec__.name.__eq__,                  ["multiprocessing"],          true]
    - [mp1126mi003, multiprocessing.__spec__.__class__.__name__.__eq__,    ["ModuleSpec"],               true]
    - [mp1126mi004, multiprocessing.process.__name__.__eq__,               ["multiprocessing.process"],  true]
    - [mp1126mi005, multiprocessing.process.__spec__.name.__eq__,          ["multiprocessing.process"],  true]
    - [mp1126mi006, multiprocessing.pool.__name__.__eq__,                  ["multiprocessing.pool"],     true]
    - [mp1126mi007, multiprocessing.synchronize.__name__.__eq__,           ["multiprocessing.synchronize"], true]

table multiprocessing_extra1126.pool_class_and_method_qualnames:
  description: "multiprocessing.pool.Pool class module, qualname, name, and method qualname identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp1126pl
  columns: [id, function, args, expected]
  rows:
    - [mp1126pl001, multiprocessing.pool.Pool.__module__.__eq__,          ["multiprocessing.pool"],  true]
    - [mp1126pl002, multiprocessing.pool.Pool.__qualname__.__eq__,        ["Pool"],                  true]
    - [mp1126pl003, multiprocessing.pool.Pool.__name__.__eq__,            ["Pool"],                  true]
    - [mp1126pl004, multiprocessing.pool.Pool.__class__.__name__.__eq__,  ["type"],                  true]
    - [mp1126pl005, multiprocessing.pool.Pool.__doc__.__class__.__name__.__eq__, ["str"],            true]
    - [mp1126pl006, multiprocessing.pool.Pool.__init__.__qualname__.__eq__, ["Pool.__init__"],       true]
    - [mp1126pl007, multiprocessing.pool.Pool.__init__.__module__.__eq__, ["multiprocessing.pool"], true]
    - [mp1126pl008, multiprocessing.pool.Pool.map.__qualname__.__eq__,    ["Pool.map"],              true]
    - [mp1126pl009, multiprocessing.pool.Pool.apply.__qualname__.__eq__,  ["Pool.apply"],            true]
    - [mp1126pl010, multiprocessing.pool.Pool.close.__qualname__.__eq__,  ["Pool.close"],            true]
    - [mp1126pl011, multiprocessing.pool.Pool.terminate.__qualname__.__eq__, ["Pool.terminate"],     true]
    - [mp1126pl012, multiprocessing.pool.Pool.join.__qualname__.__eq__,   ["Pool.join"],             true]
    - [mp1126pl013, multiprocessing.pool.Pool.starmap.__qualname__.__eq__, ["Pool.starmap"],         true]
    - [mp1126pl014, multiprocessing.pool.Pool.imap.__qualname__.__eq__,   ["Pool.imap"],             true]

