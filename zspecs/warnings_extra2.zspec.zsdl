spec: warnings_extra2
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "Python 3 warnings documentation — https://docs.python.org/3/library/warnings.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Modules/_warnings.c"
    - "warnings.zspec.zsdl — covers function names (warn, warn_explicit, showwarning, formatwarning, filterwarnings, simplefilter, resetwarnings, catch_warnings), class names (WarningMessage, catch_warnings)"
    - "warnings_extra.zspec.zsdl — covers warn.__module__, filterwarnings/__name__, simplefilter/__name__, resetwarnings/__name__, catch_warnings/__name__/__module__, WarningMessage/__name__/__module__/__bases__[0].__name__"
  notes:
    - "This spec extends warnings.zspec.zsdl and warnings_extra.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "warnings.warn.__name__ == 'warn' — the C-level builtin has __name__ == 'warn'."
    - "warnings.showwarning.__name__ == 'showwarning' — defined in the warnings module."
    - "warnings.formatwarning.__name__ == 'formatwarning' — pure-Python function in warnings."
    - "warnings.warn_explicit.__name__ == 'warn_explicit' — C extension function re-exported in warnings."
    - "warnings.showwarning.__module__ == 'warnings' — defined in the Python warnings module."
    - "warnings.formatwarning.__module__ == 'warnings' — defined in the Python warnings module."
    - "warnings.warn_explicit.__module__ == '_warnings' — the C extension module."
    - "warnings.DeprecationWarning is the builtin class re-exported via the warnings namespace."
    - "warnings.filters is a list (may be empty or contain filter tuples)."
    - "warnings.defaultaction is a str with value 'default' in a fresh interpreter."
    - "warnings._filters_mutated is an internal C-level function; __name__ == '_filters_mutated'."
    - "warnings.catch_warnings.__bases__[0].__name__ == 'object' — catch_warnings directly subclasses object."
    - "warnings._formatwarnmsg_impl is an internal Python-level function; __name__ == '_formatwarnmsg_impl'."
    - "warnings.formatwarning('msg', UserWarning, 'f.py', 1) returns a str."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks — new coverage not in warnings_extra.zspec.zsdl
#
# warnings_extra covers: warn, warn_explicit, filterwarnings, simplefilter,
# resetwarnings.  New here: showwarning, formatwarning.
# ---------------------------------------------------------------------------

invariant warnings_extra2.function_names.warn:
  description: "warnings.warn.__name__ == 'warn'"
  category: function_names
  kind: python_call_eq
  function: warn.__name__.__eq__
  args: ["warn"]
  expected: true

invariant warnings_extra2.function_names.showwarning:
  description: "warnings.showwarning.__name__ == 'showwarning'"
  category: function_names
  kind: python_call_eq
  function: showwarning.__name__.__eq__
  args: ["showwarning"]
  expected: true

invariant warnings_extra2.function_names.formatwarning:
  description: "warnings.formatwarning.__name__ == 'formatwarning'"
  category: function_names
  kind: python_call_eq
  function: formatwarning.__name__.__eq__
  args: ["formatwarning"]
  expected: true

invariant warnings_extra2.function_names.warn_explicit:
  description: "warnings.warn_explicit.__name__ == 'warn_explicit'"
  category: function_names
  kind: python_call_eq
  function: warn_explicit.__name__.__eq__
  args: ["warn_explicit"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ checks — showwarning and formatwarning live in 'warnings'
# ---------------------------------------------------------------------------

invariant warnings_extra2.function_modules.showwarning:
  description: "warnings.showwarning.__module__ == 'warnings' — defined in the Python warnings module"
  category: function_modules
  kind: python_call_eq
  function: showwarning.__module__.__eq__
  args: ["warnings"]
  expected: true

invariant warnings_extra2.function_modules.formatwarning:
  description: "warnings.formatwarning.__module__ == 'warnings' — defined in the Python warnings module"
  category: function_modules
  kind: python_call_eq
  function: formatwarning.__module__.__eq__
  args: ["warnings"]
  expected: true

invariant warnings_extra2.function_modules.warn_explicit:
  description: "warnings.warn_explicit.__module__ == '_warnings' — C extension re-exported in warnings"
  category: function_modules
  kind: python_call_eq
  function: warn_explicit.__module__.__eq__
  args: ["_warnings"]
  expected: true

# ---------------------------------------------------------------------------
# DeprecationWarning — accessible via warnings namespace
# ---------------------------------------------------------------------------

invariant warnings_extra2.DeprecationWarning.name:
  description: "warnings.DeprecationWarning.__name__ == 'DeprecationWarning'"
  category: class_names
  kind: python_call_eq
  function: DeprecationWarning.__name__.__eq__
  args: ["DeprecationWarning"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level attribute type checks
# ---------------------------------------------------------------------------

invariant warnings_extra2.constants.filters_is_list:
  description: "warnings.filters.__class__.__name__ == 'list'"
  category: constants
  kind: python_call_eq
  function: filters.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant warnings_extra2.constants.defaultaction_is_str:
  description: "warnings.defaultaction.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: defaultaction.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Internal function __name__ checks
# ---------------------------------------------------------------------------

invariant warnings_extra2.internal._filters_mutated_name:
  description: "warnings._filters_mutated.__name__ == '_filters_mutated'"
  category: internal
  kind: python_call_eq
  function: _filters_mutated.__name__.__eq__
  args: ["_filters_mutated"]
  expected: true

invariant warnings_extra2.internal._formatwarnmsg_impl_name:
  description: "warnings._formatwarnmsg_impl.__name__ == '_formatwarnmsg_impl'"
  category: internal
  kind: python_call_eq
  function: _formatwarnmsg_impl.__name__.__eq__
  args: ["_formatwarnmsg_impl"]
  expected: true

# ---------------------------------------------------------------------------
# catch_warnings base class
# ---------------------------------------------------------------------------

invariant warnings_extra2.catch_warnings.base_name:
  description: "warnings.catch_warnings.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: catch_warnings.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# formatwarning return type
# ---------------------------------------------------------------------------

invariant warnings_extra2.formatwarning.return_type:
  description: "warnings.formatwarning('msg', UserWarning, 'f.py', 1).__class__.__name__ == 'str'"
  category: behavior
  kind: python_call_eq
  function: formatwarning
  args: ["msg", UserWarning, "f.py", 1]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true
