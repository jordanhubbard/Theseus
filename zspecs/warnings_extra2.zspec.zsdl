spec: warnings_extra2
version: ">=3.2"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "Python 3 warnings documentation — https://docs.python.org/3/library/warnings.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Modules/_warnings.c"
  notes:
    - "Complements warnings_extra.zspec.zsdl."
    - "warnings.simplefilter, warnings.filterwarnings, and warnings.resetwarnings are defined in _py_warnings; their __module__ is '_py_warnings'."
    - "warnings.warn is implemented in the _warnings C extension; warn.__module__ is '_warnings'."
    - "warnings.catch_warnings.__module__ is '_py_warnings'."
    - "UserWarning.__bases__[0].__name__ is 'Warning' — direct base is Warning."
    - "FutureWarning.__bases__[0].__name__ is 'Warning' — direct base is Warning."
    - "DeprecationWarning.__name__ is 'DeprecationWarning'; it is a builtin, not on the warnings module object."
    - "UserWarning.__name__ is 'UserWarning'; FutureWarning.__name__ is 'FutureWarning'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks
#
# warn, simplefilter, filterwarnings, resetwarnings, and catch_warnings are
# all accessible from the warnings module. Their __name__ equals their
# identifier string.
# ---------------------------------------------------------------------------

table warnings_extra2.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [warn,           warn.__name__.__eq__,           ["warn"],           true]
    - [simplefilter,   simplefilter.__name__.__eq__,   ["simplefilter"],   true]
    - [filterwarnings, filterwarnings.__name__.__eq__,  ["filterwarnings"], true]
    - [resetwarnings,  resetwarnings.__name__.__eq__,  ["resetwarnings"],  true]
    - [catch_warnings, catch_warnings.__name__.__eq__,  ["catch_warnings"], true]

# ---------------------------------------------------------------------------
# Warning category __name__ checks
#
# DeprecationWarning, UserWarning, and FutureWarning are builtin exception
# subclasses accessible from the warnings module namespace.
# ---------------------------------------------------------------------------

table warnings_extra2.warning_class_names:
  kind: python_call_eq
  category: warning_class_names
  id_prefix: wname

  columns: [id, function, args, expected]
  rows:
    - [deprecationwarning, DeprecationWarning.__name__.__eq__, ["DeprecationWarning"], true]
    - [userwarning,        UserWarning.__name__.__eq__,        ["UserWarning"],        true]
    - [futurewarning,      FutureWarning.__name__.__eq__,      ["FutureWarning"],      true]

# ---------------------------------------------------------------------------
# Warning category base class checks
#
# UserWarning and FutureWarning both directly subclass Warning.
# ---------------------------------------------------------------------------

invariant warnings_extra2.bases.userwarning:
  description: "UserWarning.__bases__[0].__name__ == 'Warning'"
  category: bases
  kind: python_call_eq
  function: UserWarning.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Warning"

invariant warnings_extra2.bases.futurewarning:
  description: "FutureWarning.__bases__[0].__name__ == 'Warning'"
  category: bases
  kind: python_call_eq
  function: FutureWarning.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Warning"
