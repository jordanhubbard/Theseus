spec: threading_extra254
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading.Thread method identity (start, run, join, is_alive, getName, setName, isDaemon __name__ and __qualname__), and threading.Thread property identity (daemon, name) behavioral contracts."
    - "threading.Thread.start.__name__ == 'start' — Thread.start is a regular Python function; __name__ is 'start'. Verified with Python 3.14.3."
    - "threading.Thread.start.__qualname__ == 'Thread.start' — qualname reflects that start is defined on the Thread class. Verified with Python 3.14.3."
    - "threading.Thread.run.__name__ == 'run' — Thread.run is a regular Python function; __name__ is 'run'. Verified with Python 3.14.3."
    - "threading.Thread.run.__qualname__ == 'Thread.run' — qualname reflects that run is defined on the Thread class. Verified with Python 3.14.3."
    - "threading.Thread.join.__name__ == 'join' — Thread.join is a regular Python function; __name__ is 'join'. Verified with Python 3.14.3."
    - "threading.Thread.join.__qualname__ == 'Thread.join' — qualname reflects that join is defined on the Thread class. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__name__ == 'is_alive' — Thread.is_alive is a regular Python function; __name__ is 'is_alive'. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__qualname__ == 'Thread.is_alive' — qualname reflects that is_alive is defined on the Thread class. Verified with Python 3.14.3."
    - "threading.Thread.getName.__name__ == 'getName' — Thread.getName is a deprecated method; __name__ is 'getName'. Verified with Python 3.14.3."
    - "threading.Thread.getName.__qualname__ == 'Thread.getName' — qualname reflects that getName is defined on the Thread class. Verified with Python 3.14.3."
    - "threading.Thread.setName.__name__ == 'setName' — Thread.setName is a deprecated method; __name__ is 'setName'. Verified with Python 3.14.3."
    - "threading.Thread.isDaemon.__name__ == 'isDaemon' — Thread.isDaemon is a deprecated method; __name__ is 'isDaemon'. Verified with Python 3.14.3."
    - "type(threading.Thread.daemon).__name__ == 'property' — Thread.daemon is a Python property descriptor. Verified with Python 3.14.3."
    - "type(threading.Thread.name).__name__ == 'property' — Thread.name is a Python property descriptor. Verified with Python 3.14.3."
    - "All Thread methods are __class__.__name__ == 'function' — all listed Thread methods are pure Python function objects. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread.start and .run method name and qualname identity
#
# threading.Thread.start.__name__ == 'start'
# threading.Thread.start.__qualname__ == 'Thread.start'
# threading.Thread.run.__name__ == 'run'
# threading.Thread.run.__qualname__ == 'Thread.run'
# threading.Thread.start.__class__.__name__ == 'function'
#
# start and run are core Thread lifecycle methods; both are pure Python
# function objects defined directly on the Thread class. New to extra254.
# ---------------------------------------------------------------------------

table threading_extra254.thread_start_run_identity:
  description: "threading.Thread.start and .run __name__, __qualname__, __class__.__name__ identity contracts; new to extra254"
  kind: python_call_eq
  category: identity
  id_prefix: thdstartrun254

  columns: [id, function, args, expected, description]
  rows:
    - [thread_start_name_eq,
       Thread.start.__name__.__eq__,
       ["start"],
       true,
       "threading.Thread.start.__name__.__eq__('start') == True — Thread.start is a pure Python function initiating thread execution; __name__ is 'start'; new to extra254"]
    - [thread_start_qualname_eq,
       Thread.start.__qualname__.__eq__,
       ["Thread.start"],
       true,
       "threading.Thread.start.__qualname__.__eq__('Thread.start') == True — qualname reflects that start is defined on the Thread class; new to extra254"]
    - [thread_start_class_eq,
       Thread.start.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Thread.start.__class__.__name__.__eq__('function') == True — Thread.start is a regular Python function; __class__.__name__ is 'function'; new to extra254"]
    - [thread_run_name_eq,
       Thread.run.__name__.__eq__,
       ["run"],
       true,
       "threading.Thread.run.__name__.__eq__('run') == True — Thread.run is a pure Python function containing the thread activity; __name__ is 'run'; new to extra254"]
    - [thread_run_qualname_eq,
       Thread.run.__qualname__.__eq__,
       ["Thread.run"],
       true,
       "threading.Thread.run.__qualname__.__eq__('Thread.run') == True — qualname reflects that run is defined on the Thread class; new to extra254"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread.join and .is_alive method identity
#
# threading.Thread.join.__name__ == 'join'
# threading.Thread.join.__qualname__ == 'Thread.join'
# threading.Thread.is_alive.__name__ == 'is_alive'
# threading.Thread.is_alive.__qualname__ == 'Thread.is_alive'
# threading.Thread.join.__class__.__name__ == 'function'
#
# join and is_alive are core Thread synchronization methods; both are
# pure Python function objects. New to extra254.
# ---------------------------------------------------------------------------

table threading_extra254.thread_join_isalive_identity:
  description: "threading.Thread.join and .is_alive __name__, __qualname__, __class__.__name__ identity contracts; new to extra254"
  kind: python_call_eq
  category: identity
  id_prefix: thdjoinalive254

  columns: [id, function, args, expected, description]
  rows:
    - [thread_join_name_eq,
       Thread.join.__name__.__eq__,
       ["join"],
       true,
       "threading.Thread.join.__name__.__eq__('join') == True — Thread.join is a pure Python function blocking until the thread terminates; __name__ is 'join'; new to extra254"]
    - [thread_join_qualname_eq,
       Thread.join.__qualname__.__eq__,
       ["Thread.join"],
       true,
       "threading.Thread.join.__qualname__.__eq__('Thread.join') == True — qualname reflects that join is defined on the Thread class; new to extra254"]
    - [thread_join_class_eq,
       Thread.join.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Thread.join.__class__.__name__.__eq__('function') == True — Thread.join is a regular Python function; __class__.__name__ is 'function'; new to extra254"]
    - [thread_is_alive_name_eq,
       Thread.is_alive.__name__.__eq__,
       ["is_alive"],
       true,
       "threading.Thread.is_alive.__name__.__eq__('is_alive') == True — Thread.is_alive is a pure Python function returning True if the thread is executing; __name__ is 'is_alive'; new to extra254"]
    - [thread_is_alive_qualname_eq,
       Thread.is_alive.__qualname__.__eq__,
       ["Thread.is_alive"],
       true,
       "threading.Thread.is_alive.__qualname__.__eq__('Thread.is_alive') == True — qualname reflects that is_alive is defined on the Thread class; new to extra254"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread deprecated methods: getName, setName, isDaemon
#
# threading.Thread.getName.__name__ == 'getName'
# threading.Thread.getName.__qualname__ == 'Thread.getName'
# threading.Thread.setName.__name__ == 'setName'
# threading.Thread.setName.__qualname__ == 'Thread.setName'
# threading.Thread.isDaemon.__name__ == 'isDaemon'
#
# getName, setName, and isDaemon are deprecated Thread methods retained for
# backward compatibility. All are pure Python function objects. New to extra254.
# ---------------------------------------------------------------------------

table threading_extra254.thread_deprecated_methods_identity:
  description: "threading.Thread.getName, .setName, .isDaemon deprecated method __name__, __qualname__ identity contracts; new to extra254"
  kind: python_call_eq
  category: identity
  id_prefix: thddeprecated254

  columns: [id, function, args, expected, description]
  rows:
    - [thread_getname_name_eq,
       Thread.getName.__name__.__eq__,
       ["getName"],
       true,
       "threading.Thread.getName.__name__.__eq__('getName') == True — Thread.getName is a deprecated method returning the thread name; __name__ is 'getName'; new to extra254"]
    - [thread_getname_qualname_eq,
       Thread.getName.__qualname__.__eq__,
       ["Thread.getName"],
       true,
       "threading.Thread.getName.__qualname__.__eq__('Thread.getName') == True — qualname reflects that getName is defined on the Thread class; new to extra254"]
    - [thread_setname_name_eq,
       Thread.setName.__name__.__eq__,
       ["setName"],
       true,
       "threading.Thread.setName.__name__.__eq__('setName') == True — Thread.setName is a deprecated method setting the thread name; __name__ is 'setName'; new to extra254"]
    - [thread_setname_qualname_eq,
       Thread.setName.__qualname__.__eq__,
       ["Thread.setName"],
       true,
       "threading.Thread.setName.__qualname__.__eq__('Thread.setName') == True — qualname reflects that setName is defined on the Thread class; new to extra254"]
    - [thread_isdaemon_name_eq,
       Thread.isDaemon.__name__.__eq__,
       ["isDaemon"],
       true,
       "threading.Thread.isDaemon.__name__.__eq__('isDaemon') == True — Thread.isDaemon is a deprecated method returning the daemon flag; __name__ is 'isDaemon'; new to extra254"]

# ---------------------------------------------------------------------------
# Table 4: threading.Thread.daemon and .name property identity
#
# type(threading.Thread.daemon).__name__ == 'property'
# type(threading.Thread.name).__name__ == 'property'
#
# Thread.daemon and Thread.name are Python property descriptors defined on
# the Thread class. New to extra254.
# ---------------------------------------------------------------------------

table threading_extra254.thread_property_identity:
  description: "threading.Thread.daemon and .name property descriptor __class__.__name__ identity contracts; new to extra254"
  kind: python_call_eq
  category: identity
  id_prefix: thdprop254

  columns: [id, function, args, expected, description]
  rows:
    - [thread_daemon_prop_class_eq,
       Thread.daemon.__class__.__name__.__eq__,
       ["property"],
       true,
       "threading.Thread.daemon.__class__.__name__.__eq__('property') == True — Thread.daemon is a Python property descriptor controlling whether the thread is a daemon; new to extra254"]
    - [thread_name_prop_class_eq,
       Thread.name.__class__.__name__.__eq__,
       ["property"],
       true,
       "threading.Thread.name.__class__.__name__.__eq__('property') == True — Thread.name is a Python property descriptor for the thread's name; new to extra254"]
    - [thread_isDaemon_qualname_eq,
       Thread.isDaemon.__qualname__.__eq__,
       ["Thread.isDaemon"],
       true,
       "threading.Thread.isDaemon.__qualname__.__eq__('Thread.isDaemon') == True — qualname reflects that isDaemon is defined on the Thread class; new to extra254"]
    - [thread_is_alive_class_eq,
       Thread.is_alive.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Thread.is_alive.__class__.__name__.__eq__('function') == True — Thread.is_alive is a regular Python function; __class__.__name__ is 'function'; new to extra254"]
    - [thread_run_class_eq,
       Thread.run.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Thread.run.__class__.__name__.__eq__('function') == True — Thread.run is a regular Python function; __class__.__name__ is 'function'; new to extra254"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra254
# ---------------------------------------------------------------------------

invariant threading_extra254.Thread.start.name_eq:
  description: "threading.Thread.start.__name__ == 'start' — pure Python method initiating thread execution; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.start.__name__.__eq__
  args: ["start"]
  expected: true

invariant threading_extra254.Thread.start.qualname_eq:
  description: "threading.Thread.start.__qualname__ == 'Thread.start' — qualname shows definition on the Thread class; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.start.__qualname__.__eq__
  args: ["Thread.start"]
  expected: true

invariant threading_extra254.Thread.start.class_is_function:
  description: "threading.Thread.start.__class__.__name__ == 'function' — Thread.start is a regular Python function; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.start.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra254.Thread.run.name_eq:
  description: "threading.Thread.run.__name__ == 'run' — pure Python method containing the thread's activity; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.run.__name__.__eq__
  args: ["run"]
  expected: true

invariant threading_extra254.Thread.run.qualname_eq:
  description: "threading.Thread.run.__qualname__ == 'Thread.run' — qualname shows definition on the Thread class; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.run.__qualname__.__eq__
  args: ["Thread.run"]
  expected: true

invariant threading_extra254.Thread.join.name_eq:
  description: "threading.Thread.join.__name__ == 'join' — pure Python method blocking until thread terminates; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.join.__name__.__eq__
  args: ["join"]
  expected: true

invariant threading_extra254.Thread.join.qualname_eq:
  description: "threading.Thread.join.__qualname__ == 'Thread.join' — qualname shows definition on the Thread class; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.join.__qualname__.__eq__
  args: ["Thread.join"]
  expected: true

invariant threading_extra254.Thread.is_alive.name_eq:
  description: "threading.Thread.is_alive.__name__ == 'is_alive' — pure Python method returning True if thread is executing; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.is_alive.__name__.__eq__
  args: ["is_alive"]
  expected: true

invariant threading_extra254.Thread.is_alive.qualname_eq:
  description: "threading.Thread.is_alive.__qualname__ == 'Thread.is_alive' — qualname shows definition on the Thread class; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.is_alive.__qualname__.__eq__
  args: ["Thread.is_alive"]
  expected: true

invariant threading_extra254.Thread.getName.name_eq:
  description: "threading.Thread.getName.__name__ == 'getName' — deprecated pure Python method returning the thread name; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.getName.__name__.__eq__
  args: ["getName"]
  expected: true

invariant threading_extra254.Thread.getName.qualname_eq:
  description: "threading.Thread.getName.__qualname__ == 'Thread.getName' — qualname shows definition on the Thread class; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.getName.__qualname__.__eq__
  args: ["Thread.getName"]
  expected: true

invariant threading_extra254.Thread.setName.name_eq:
  description: "threading.Thread.setName.__name__ == 'setName' — deprecated pure Python method setting the thread name; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.setName.__name__.__eq__
  args: ["setName"]
  expected: true

invariant threading_extra254.Thread.setName.qualname_eq:
  description: "threading.Thread.setName.__qualname__ == 'Thread.setName' — qualname shows definition on the Thread class; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.setName.__qualname__.__eq__
  args: ["Thread.setName"]
  expected: true

invariant threading_extra254.Thread.isDaemon.name_eq:
  description: "threading.Thread.isDaemon.__name__ == 'isDaemon' — deprecated pure Python method returning the daemon flag; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.isDaemon.__name__.__eq__
  args: ["isDaemon"]
  expected: true

invariant threading_extra254.Thread.isDaemon.qualname_eq:
  description: "threading.Thread.isDaemon.__qualname__ == 'Thread.isDaemon' — qualname shows definition on the Thread class; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.isDaemon.__qualname__.__eq__
  args: ["Thread.isDaemon"]
  expected: true

invariant threading_extra254.Thread.daemon.class_is_property:
  description: "threading.Thread.daemon.__class__.__name__ == 'property' — Thread.daemon is a Python property descriptor controlling daemon status; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.daemon.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra254.Thread.name.class_is_property:
  description: "threading.Thread.name.__class__.__name__ == 'property' — Thread.name is a Python property descriptor for the thread name; new to extra254"
  category: identity
  kind: python_call_eq
  function: Thread.name.__class__.__name__.__eq__
  args: ["property"]
  expected: true
