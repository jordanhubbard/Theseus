spec: uuid_extra281
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — UUID objects according to RFC 4122"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "uuid.UUID has no __class_getitem__ in Python 3.9+"
    - "uuid.UUID has no __bytes__ method; .bytes is a property"
    - "All public uuid functions (uuid1, uuid3, uuid4, uuid5, getnode) have __class__.__name__ == 'function'"
    - "uuid.UUID('not-a-valid-uuid-string-xyz') raises ValueError with 'badly formed hexadecimal UUID string'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table uuid_extra281.function_qualnames:
  description: "qualnames for uuid module-level functions: getnode, uuid1, uuid3, uuid4, uuid5"
  kind: python_call_eq
  category: identity
  id_prefix: ux281q

  columns: [id, function, args, expected, description]
  rows:
    - [ux281q001, uuid.getnode.__qualname__.__eq__, ["getnode"], true, "getnode.__qualname__ == 'getnode'"]
    - [ux281q002, uuid.getnode.__name__.__eq__, ["getnode"], true, "getnode.__name__ == 'getnode'"]
    - [ux281q003, uuid.getnode.__module__.__eq__, ["uuid"], true, "getnode.__module__ == 'uuid'"]
    - [ux281q004, uuid.uuid1.__qualname__.__eq__, ["uuid1"], true, "uuid1.__qualname__ == 'uuid1'"]
    - [ux281q005, uuid.uuid3.__qualname__.__eq__, ["uuid3"], true, "uuid3.__qualname__ == 'uuid3'"]
    - [ux281q006, uuid.uuid4.__qualname__.__eq__, ["uuid4"], true, "uuid4.__qualname__ == 'uuid4'"]
    - [ux281q007, uuid.uuid5.__qualname__.__eq__, ["uuid5"], true, "uuid5.__qualname__ == 'uuid5'"]

table uuid_extra281.function_class_names:
  description: "__class__.__name__ for uuid module-level functions (all 'function')"
  kind: python_call_eq
  category: identity
  id_prefix: ux281f

  columns: [id, function, args, expected, description]
  rows:
    - [ux281f001, uuid.getnode.__class__.__name__.__eq__, ["function"], true, "getnode is a function"]
    - [ux281f002, uuid.uuid1.__class__.__name__.__eq__, ["function"], true, "uuid1 is a function"]
    - [ux281f003, uuid.uuid3.__class__.__name__.__eq__, ["function"], true, "uuid3 is a function"]
    - [ux281f004, uuid.uuid4.__class__.__name__.__eq__, ["function"], true, "uuid4 is a function"]
    - [ux281f005, uuid.uuid5.__class__.__name__.__eq__, ["function"], true, "uuid5 is a function"]

invariant uuid_extra281.invalid_uuid_raises_value_error:
  description: "uuid.UUID with a non-hex invalid string raises ValueError"
  category: errors
  kind: python_call_raises
  function: uuid.UUID
  args: ["not-a-valid-uuid-string-xyz"]
  raises: ValueError

invariant uuid_extra281.getnode_module:
  description: "uuid.getnode.__module__ == 'uuid'"
  category: identity
  kind: python_call_eq
  function: uuid.getnode.__module__.__eq__
  args: ["uuid"]
  expected: true
