spec: socket_extra410
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "socket.socket.setsockopt.__name__ == 'setsockopt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockopt.__name__ == 'getsockopt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__name__ == 'settimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.gettimeout.__name__ == 'gettimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setblocking.__name__ == 'setblocking'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getpeername.__name__ == 'getpeername'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockname.__name__ == 'getsockname'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket methods (setsockopt, getsockopt, settimeout, gettimeout, setblocking, getpeername, getsockname) are C-level slot/wrapper methods. Accessed on the class, they are method_wrapper or wrapper_descriptor objects. Each method's __name__ is the bare method name without any class prefix."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket option and timeout method __name__ values
#
# Wave 410 theme: socket.socket socket-option and timeout method identity.
#
# socket.socket is a C extension type. Its methods for getting and setting
# socket options, timeouts, and blocking mode are implemented in C.
# Accessed on the class, each method is a C-level descriptor whose
# __name__ is the bare method name (identical to the attribute name used
# to access it).
#
# Covered methods:
#   setsockopt  — set a socket option value
#   getsockopt  — retrieve a socket option value
#   settimeout  — set the socket timeout in seconds
#   gettimeout  — retrieve the current socket timeout
#   setblocking — set the socket to blocking or non-blocking mode
#   getpeername — return the remote address of the connection
#   getsockname — return the socket's own address
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra410.socket_method_names:
  description: "socket.socket setsockopt, getsockopt, settimeout, gettimeout, setblocking, getpeername, getsockname method __name__ values — each C-level method's __name__ is the bare method name; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: socketmn410

  columns: [id, function, args, expected]
  rows:
    - [setsockopt_name,   socket.setsockopt.__name__.__eq__,   ["setsockopt"],   true]
    - [getsockopt_name,   socket.getsockopt.__name__.__eq__,   ["getsockopt"],   true]
    - [settimeout_name,   socket.settimeout.__name__.__eq__,   ["settimeout"],   true]
    - [gettimeout_name,   socket.gettimeout.__name__.__eq__,   ["gettimeout"],   true]
    - [setblocking_name,  socket.setblocking.__name__.__eq__,  ["setblocking"],  true]
    - [getpeername_name,  socket.getpeername.__name__.__eq__,  ["getpeername"],  true]
    - [getsockname_name,  socket.getsockname.__name__.__eq__,  ["getsockname"],  true]
