spec: struct_extra1066
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.Struct method class names, module-level function class names, and python_call_raises for bad format strings"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1066.struct_method_class_names:
  description: "struct.Struct method __class__.__name__ identity"
  kind: python_call_eq
  category: struct_method_classnames
  id_prefix: st1066mc
  columns: [id, function, args, expected]
  rows:
    - [st1066mc001, struct.Struct.pack.__class__.__name__.__eq__,        ["slot_wrapper"],  true]
    - [st1066mc002, struct.Struct.unpack.__class__.__name__.__eq__,      ["slot_wrapper"],  true]
    - [st1066mc003, struct.Struct.pack_into.__class__.__name__.__eq__,   ["slot_wrapper"],  true]
    - [st1066mc004, struct.Struct.unpack_from.__class__.__name__.__eq__, ["slot_wrapper"],  true]
    - [st1066mc005, struct.Struct.iter_unpack.__class__.__name__.__eq__, ["slot_wrapper"],  true]
    - [st1066mc006, struct.Struct.pack.__qualname__.__class__.__name__.__eq__,        ["str"], true]
    - [st1066mc007, struct.Struct.unpack.__qualname__.__class__.__name__.__eq__,      ["str"], true]
    - [st1066mc008, struct.Struct.pack_into.__qualname__.__class__.__name__.__eq__,   ["str"], true]
    - [st1066mc009, struct.Struct.unpack_from.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [st1066mc010, struct.Struct.iter_unpack.__qualname__.__class__.__name__.__eq__, ["str"], true]

table struct_extra1066.module_function_class_names:
  description: "struct module-level function __class__.__name__ identity"
  kind: python_call_eq
  category: module_function_classnames
  id_prefix: st1066fc
  columns: [id, function, args, expected]
  rows:
    - [st1066fc001, struct.pack.__class__.__name__.__eq__,        ["builtin_function_or_method"], true]
    - [st1066fc002, struct.unpack.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [st1066fc003, struct.pack_into.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [st1066fc004, struct.unpack_from.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [st1066fc005, struct.iter_unpack.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [st1066fc006, struct.calcsize.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [st1066fc007, struct.pack.__module__.__eq__,                ["struct"],  true]
    - [st1066fc008, struct.calcsize.__module__.__eq__,            ["struct"],  true]

table struct_extra1066.raises_bad_format:
  description: "struct.pack and struct.calcsize raise struct.error for bad format strings"
  kind: python_call_raises
  category: bad_format_raises
  id_prefix: st1066rb
  columns: [id, function, args, exception]
  rows:
    - [st1066rb001, struct.calcsize, ["Q!"],      "struct.error"]
    - [st1066rb002, struct.calcsize, ["notaformat"], "struct.error"]
    - [st1066rb003, struct.calcsize, ["~"],        "struct.error"]
    - [st1066rb004, struct.calcsize, ["%"],        "struct.error"]
    - [st1066rb005, struct.calcsize, ["9999999Z"], "struct.error"]
    - [st1066rb006, struct.calcsize, ["A"],        "struct.error"]
