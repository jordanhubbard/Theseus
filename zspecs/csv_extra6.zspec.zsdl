spec: csv_extra6
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl, csv_extra.zspec.zsdl, csv_extra2.zspec.zsdl, csv_extra3.zspec.zsdl, csv_extra4.zspec.zsdl, and csv_extra5.zspec.zsdl."
    - "Focus: __qualname__ checks for dialect classes (excel, excel_tab, unix_dialect); remaining QUOTE_* __class__.__name__ checks; csv.excel.__module__; csv.Dialect base class."
    - "csv_extra5 covers __qualname__ for DictReader, DictWriter, Dialect, Sniffer, Error, reader, writer, field_size_limit, get_dialect, list_dialects, register_dialect, unregister_dialect."
    - "csv_extra5 covers QUOTE_ALL.__class__.__name__ and QUOTE_MINIMAL.__class__.__name__ only; this spec adds QUOTE_NONNUMERIC and QUOTE_NONE."
    - "csv.excel.__qualname__ == 'excel' — excel is a top-level class so __qualname__ equals __name__."
    - "csv.excel_tab.__qualname__ == 'excel_tab' — similarly a top-level dialect class."
    - "csv.unix_dialect.__qualname__ == 'unix_dialect' — top-level dialect, uses LF line terminator."
    - "csv.excel.__module__ == 'csv' — the excel dialect class is defined in the csv module."
    - "csv.Dialect.__bases__[0].__name__ == 'object' — Dialect inherits directly from object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for dialect classes
# These are top-level classes so __qualname__ == __name__ for each.
# csv_extra5 already covers DictReader/DictWriter/Dialect/Sniffer/Error qualnames.
# ---------------------------------------------------------------------------

table csv_extra6.dialect_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [excel,       excel.__qualname__.__eq__,       ["excel"],       true]
    - [excel_tab,   excel_tab.__qualname__.__eq__,   ["excel_tab"],   true]
    - [unix_dialect, unix_dialect.__qualname__.__eq__, ["unix_dialect"], true]

# ---------------------------------------------------------------------------
# QUOTE_* constants — remaining __class__.__name__ checks
# csv_extra5 covers QUOTE_ALL and QUOTE_MINIMAL; this spec adds the other two.
# ---------------------------------------------------------------------------

table csv_extra6.quote_class_names:
  kind: python_call_eq
  category: constants
  id_prefix: quote_class

  columns: [id, function, args, expected]
  rows:
    - [QUOTE_NONNUMERIC, QUOTE_NONNUMERIC.__class__.__name__.__eq__, ["int"], true]
    - [QUOTE_NONE,       QUOTE_NONE.__class__.__name__.__eq__,       ["int"], true]

# ---------------------------------------------------------------------------
# csv.excel.__module__ — the excel dialect is defined in the csv module
# ---------------------------------------------------------------------------

invariant csv_extra6.excel.module:
  description: "csv.excel.__module__ == 'csv'"
  category: modules
  kind: python_call_eq
  function: excel.__module__.__eq__
  args: ["csv"]
  expected: true

# ---------------------------------------------------------------------------
# csv.Dialect base class
# Dialect inherits directly from object (no intermediate base).
# ---------------------------------------------------------------------------

invariant csv_extra6.Dialect.base_is_object:
  description: "csv.Dialect.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: Dialect.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
