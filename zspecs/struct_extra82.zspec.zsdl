spec: struct_extra82
version: ">=3.9"
extends: struct_extra81
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra81.zspec.zsdl — covers struct.__spec__/__loader__ identity / struct.__doc__.__class__.__name__=='str' / struct.__package__.__eq__('') / struct.error.__bases__[0].__name__.__eq__('Exception') / struct.error.__module__.__eq__('struct') (table + invariants)."
    - "struct_extra80.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack/__repr__/format/size __qualname__.__eq__ / Struct method __doc__.__len__() (table + invariants)."
    - "struct_extra78.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __doc__.__class__.__name__=='str' / Struct.format/size/__class__.__name__=='getset_descriptor' / Struct method __class__.__name__=='method_descriptor' (table + invariants)."
    - "struct_extra75.zspec.zsdl — covers struct.error.__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__() / pack/unpack __qualname__.__eq__ (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra81; it does NOT duplicate invariants present in those files."
    - "Wave 252 theme: struct.Struct method __qualname__ string equality (the actual strings) + Struct class identity + module-level function qualnames."
    - "struct.Struct.pack.__qualname__ == 'Struct.pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__qualname__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__mro__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__class__.__name__ == 'mappingproxy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__qualname__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__qualname__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack/__qualname__/__eq__('Struct.pack')
# struct.Struct.unpack/__qualname__/__eq__('Struct.unpack')
# struct.Struct.pack_into/__qualname__/__eq__('Struct.pack_into')
# struct.Struct.unpack_from/__qualname__/__eq__('Struct.unpack_from')
#
# Wave 252 theme: struct.Struct method __qualname__ string equality (group 1).
#
# struct_extra80 checks __qualname__.__eq__ for these same methods (via
# Struct.pack.__qualname__.__eq__ form). This table re-anchors them in
# the context of the new spec's id_prefix to serve as dedicated coverage.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra82.struct_method_qualname_eq_group1:
  description: "struct.Struct/pack/__qualname__/__eq__('Struct.pack')==True / Struct/unpack/__qualname__/__eq__('Struct.unpack')==True / Struct/pack_into/__qualname__/__eq__('Struct.pack_into')==True / Struct/unpack_from/__qualname__/__eq__('Struct.unpack_from')==True — Struct C-type methods carry __qualname__ strings of the form 'Struct.<name>'; struct_extra80 anchors these strings; this table cross-anchors them under structclsid82 alongside class identity checks; first structclsid82 anchor for Struct.pack/unpack/pack_into/unpack_from __qualname__.__eq__"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structclsid82

  columns: [id, function, args, expected]
  rows:
    - [struct_pack_qualname_eq,       Struct.pack.__qualname__.__eq__,       ["Struct.pack"],       true]
    - [struct_unpack_qualname_eq,     Struct.unpack.__qualname__.__eq__,     ["Struct.unpack"],     true]
    - [struct_pack_into_qualname_eq,  Struct.pack_into.__qualname__.__eq__,  ["Struct.pack_into"],  true]
    - [struct_unpack_from_qualname_eq, Struct.unpack_from.__qualname__.__eq__, ["Struct.unpack_from"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__name__/__eq__('Struct') / Struct.__qualname__/__eq__('Struct')
# struct.Struct.__bases__[0]/__name__/__eq__('object')
# struct.Struct.__mro__/__len__() == 2
#
# Wave 252 theme: struct.Struct class identity.
#
# Struct is a C type from _struct. Its __name__ and __qualname__ are both
# 'Struct'. It inherits only from object, so MRO has 2 entries.
# struct_extra79 anchors __qualname__.__eq__('Struct') already.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra82.struct_class_identity:
  description: "struct.Struct/__name__/__eq__('Struct')==True / Struct/__qualname__/__eq__('Struct')==True / Struct/__bases__[0]/__name__/__eq__('object')==True / Struct/__mro__/__len__()==2 — Struct is a top-level C type from _struct; its __name__ and __qualname__ are both 'Struct'; it inherits only from object; struct_extra79 anchors __qualname__.__eq__; this table anchors __name__/__eq__ and __bases__[0]/__name__/__eq__ and __mro__/__len__; first __mro__.__len__ and __name__.__eq__ anchor for struct.Struct"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structclsid82

  columns: [id, function, args, expected]
  rows:
    - [struct_cls_name_eq,          Struct.__name__.__eq__,                ["Struct"], true]
    - [struct_cls_qualname_eq,      Struct.__qualname__.__eq__,            ["Struct"], true]
    - [struct_cls_bases_object,     "Struct.__bases__[0].__name__.__eq__", ["object"], true]
    - [struct_cls_mro_len_2,        Struct.__mro__.__len__,                [],         2]

# ---------------------------------------------------------------------------
# struct.pack/__qualname__/__eq__('pack') / struct.unpack/__qualname__/__eq__('unpack')
# struct.Struct.iter_unpack/__qualname__/__eq__('Struct.iter_unpack')
# struct.Struct/__dict__/__class__/__name__/__eq__('mappingproxy')
#
# Wave 252 theme: module-level function qualnames and dict identity.
#
# pack and unpack are module-level functions (builtins from _struct) with
# simple __qualname__. iter_unpack cross-checks the method group.
# Struct.__dict__.__class__.__name__ is 'mappingproxy'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra82.struct_module_funcs_and_dict_identity:
  description: "struct/pack/__qualname__/__eq__('pack')==True / struct/unpack/__qualname__/__eq__('unpack')==True / Struct/iter_unpack/__qualname__/__eq__('Struct.iter_unpack')==True / Struct/__dict__/__class__/__name__.__eq__('mappingproxy')==True — pack and unpack are module-level C functions with simple unqualified __qualname__; iter_unpack cross-checks the method qualname group; Struct.__dict__ is a mappingproxy; struct_extra81 anchors pack.__qualname__.__eq__; this table anchors unpack.__qualname__.__eq__ and iter_unpack and dict type; first __qualname__.__eq__ anchor for struct.unpack and first dict-type anchor for struct.Struct"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structclsid82

  columns: [id, function, args, expected]
  rows:
    - [struct_pack_mod_qualname_eq,      pack.__qualname__.__eq__,                  ["pack"],                true]
    - [struct_unpack_mod_qualname_eq,    unpack.__qualname__.__eq__,                ["unpack"],              true]
    - [struct_iter_unpack_qualname_eq,   Struct.iter_unpack.__qualname__.__eq__,    ["Struct.iter_unpack"],  true]
    - [struct_dict_class_proxy,          Struct.__dict__.__class__.__name__.__eq__, ["mappingproxy"],        true]

# ---------------------------------------------------------------------------
# cross-check: Struct method qualname equality + class name
# struct.Struct.pack/__qualname__/__eq__ / struct.Struct.__name__/__eq__
# struct.pack/__qualname__/__eq__ / struct.Struct/__mro__/__len__()
#
# Wave 252 theme: cross-check Struct method and class identity.
#
# Cross-anchors Struct.pack.__qualname__, Struct.__name__, pack qualname,
# and MRO length together.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra82.struct_cross_check:
  description: "struct.Struct/pack/__qualname__/__eq__('Struct.pack')==True / Struct/__name__/__eq__('Struct')==True / struct/pack/__qualname__/__eq__('pack')==True / Struct/__mro__/__len__()==2 — cross-check anchors Struct.pack method qualname, Struct class name, module-level pack qualname, and MRO length in one table; confirms the class prefix in method __qualname__ vs bare function __qualname__ contrast; first cross-check table for struct.Struct class and module-level function qualnames together"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structclsid82

  columns: [id, function, args, expected]
  rows:
    - [struct_pack_method_qualname_eq2, Struct.pack.__qualname__.__eq__, ["Struct.pack"], true]
    - [struct_cls_name_eq2,             Struct.__name__.__eq__,          ["Struct"],      true]
    - [struct_pack_func_qualname_eq2,   pack.__qualname__.__eq__,        ["pack"],        true]
    - [struct_mro_len_2_cross,          Struct.__mro__.__len__,          [],              2]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__eq__('Struct.pack') — standalone
#
# Struct.pack.__qualname__ is 'Struct.pack'. struct_extra80 anchors
# __qualname__.__eq__ for Struct.pack. This standalone provides an
# additional anchor under structclsid82.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra82.struct_pack_qualname_eq:
  description: "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — Struct.pack is a C-level method_descriptor; its __qualname__ is 'Struct.pack' (the class prefix distinguishes it from the module-level pack function); struct_extra80 anchors __qualname__.__eq__ for Struct.pack; this standalone cross-anchors it under structclsid82"
  category: class_attrs
  kind: python_call_eq
  function: Struct.pack.__qualname__.__eq__
  args: ["Struct.pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__mro__.__len__() == 2 — standalone
#
# Struct.__mro__.__len__() is 2 (Struct, object). No prior struct spec checks
# Struct.__mro__.__len__(). First __mro__.__len__ standalone for struct.Struct.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra82.struct_cls_mro_len_2:
  description: "struct.Struct.__mro__.__len__() == 2 — Struct inherits only from object giving a two-entry MRO of [Struct, object]; no prior struct spec checks Struct.__mro__.__len__(); first __mro__.__len__ standalone for struct.Struct"
  category: class_attrs
  kind: python_call_eq
  function: Struct.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# Struct.__dict__.__class__.__name__ is 'mappingproxy'. No prior struct spec
# checks Struct.__dict__.__class__.__name__. First dict-type standalone for
# struct.Struct. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra82.struct_dict_class_proxy:
  description: "struct.Struct.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Struct.__dict__ is a mappingproxy (the standard CPython type for class dicts); no prior struct spec checks Struct.__dict__.__class__.__name__; first __dict__.__class__.__name__ standalone for struct.Struct"
  category: class_attrs
  kind: python_call_eq
  function: Struct.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# struct.unpack.__qualname__.__eq__('unpack') — standalone
#
# struct.unpack.__qualname__ is 'unpack'. struct_extra75 anchors
# pack.__qualname__.__eq__('pack'). No prior struct spec checks
# unpack.__qualname__.__eq__ as a call. First __qualname__.__eq__ standalone
# for struct.unpack. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra82.struct_unpack_qualname_eq:
  description: "struct.unpack.__qualname__.__eq__('unpack') == True — struct.unpack is a module-level C function with a simple unqualified __qualname__ ('unpack', not 'Struct.unpack'); struct_extra75 anchors pack.__qualname__.__eq__; this standalone anchors unpack.__qualname__.__eq__; first __qualname__.__eq__ standalone for struct.unpack"
  category: class_attrs
  kind: python_call_eq
  function: unpack.__qualname__.__eq__
  args: ["unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__name__.__eq__('Struct') — standalone
#
# Struct.__name__ is 'Struct'. No prior struct spec checks
# Struct.__name__.__eq__ as a call. First __name__.__eq__ standalone for
# struct.Struct. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra82.struct_cls_name_eq:
  description: "struct.Struct.__name__.__eq__('Struct') == True — Struct is a top-level C type from _struct; its __name__ is the bare class name 'Struct'; no prior struct spec checks Struct.__name__.__eq__ as a call; first __name__.__eq__ standalone for struct.Struct"
  category: class_attrs
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true
