spec: concurrent_futures_extra1906
version: ">=3.9"
backend: python_module(concurrent.futures)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 574 (_extra1906): __reversed__ reverse iteration protocol; __missing__ dict protocol; __match_args__ structural pattern matching (3.10+); __qualname__ values."
    - "concurrent.futures.Future is a Python class; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "concurrent.futures.Executor is a Python abstract base class; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "concurrent.futures.ThreadPoolExecutor is a Python class; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "concurrent.futures.ProcessPoolExecutor is a Python class; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "concurrent.futures exception types (CancelledError, TimeoutError, BrokenExecutor) do not define __match_args__ in their own __dict__."
    - "concurrent.futures.Future.__qualname__ == 'Future' — top-level Python class."
    - "concurrent.futures.Executor.__qualname__ == 'Executor' — top-level Python abstract class."
    - "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' — top-level Python class."
    - "concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' — top-level Python class."
    - "concurrent.futures.CancelledError.__qualname__ == 'CancelledError' — top-level exception class."
    - "concurrent.futures.TimeoutError.__qualname__ == 'TimeoutError' — top-level exception class."
    - "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor' — top-level exception class."
    - "concurrent.futures.Future.__dict__ contains __init__, __repr__, __class_getitem__, __dict__, __weakref__, __firstlineno__, __static_attributes__."
    - "concurrent.futures.Executor.__dict__ contains __enter__ and __exit__ (context manager protocol)."
    - "concurrent.futures.ThreadPoolExecutor.__dict__ contains __init__ but not __enter__ or __exit__ (inherited from Executor)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

