spec: reverse_string
version: ">=0.0.6"
backend: node(reverse-string)

docs: https://www.npmjs.com/package/reverse-string

provenance:
  derived_from:
    - "reverse-string README — https://www.npmjs.com/package/reverse-string"
    - "Test vectors verified with reverse-string via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "reverse-string source"
  notes:
    - "reverse-string is an npm package. Install: npm install reverse-string"
    - "Reverses the characters of a string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table reverse_string.reverse:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: revstr

  columns: [id, args, expected]
  rows:
    - [hello,     ["hello"],       "olleh"]
    - [phrase,    ["hello world"], "dlrow olleh"]
    - [palindrome, ["racecar"],    "racecar"]
    - [single,    ["a"],           "a"]
