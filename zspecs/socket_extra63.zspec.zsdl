spec: socket_extra63
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra62.zspec.zsdl — covers socket.socket.accept.__defaults__.__class__.__name__.__eq__('NoneType') / makefile.__defaults__.__class__.__name__.__eq__('tuple') / accept.__code__.__class__.__name__.__eq__('code') / makefile.__code__.__class__.__name__.__eq__('code') / gethostname.__doc__.__contains__('host') (table + invariants)."
    - "socket_extra61.zspec.zsdl — covers socket.socket.accept/close/detach/makefile __annotations__.__class__.__name__.__eq__('dict') / __annotations__.__len__()==0 / getfqdn.__annotations__.__class__.__name__.__eq__('dict') / socket module __doc__.__class__.__name__.__eq__('str') / __doc__.__len__()==2021 / socket.socket.__doc__.__contains__('socket') / __contains__('makefile') (table + invariants)."
    - "socket_extra60.zspec.zsdl — covers socket.socket recv_into/recvfrom_into/getblocking/get_inheritable/set_inheritable __qualname__.__eq__ string values (table + invariants)."
    - "socket_extra59.zspec.zsdl — covers socket.__spec__.origin.__class__.__name__.__eq__('str') / submodule_search_locations.__class__.__name__.__eq__('NoneType') / has_location==True / __loader__.__class__.__name__.__len__()==16 (table + invariants)."
    - "socket_extra58.zspec.zsdl — covers socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "socket_extra50.zspec.zsdl — covers socket.socket.connect/bind/listen/accept/send/recv/close __qualname__.__eq__ string values."
    - "socket_extra49.zspec.zsdl — covers socket.gethostname/__doc__.__class__.__name__.__eq__('str') (type identity axis for gethostname docstring); no prior socket spec checks gethostname.__doc__.__contains__ for any keyword."
    - "socket_extra42.zspec.zsdl — covers socket.socket shutdown/sendall/recvfrom/sendto/connect_ex/dup/makefile/detach __qualname__.__eq__ string values."
    - "socket_extra22.zspec.zsdl — covers socket.socket connect/bind/listen/accept/close/recv/send __qualname__.__eq__ string values."
    - "socket_extra8.zspec.zsdl — covers gethostname/gethostbyname/getaddrinfo/getfqdn/create_connection __qualname__.__eq__ string values (module-level functions)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra62; it does NOT duplicate invariants present in those files."
    - "Wave 230 theme: __code__ deep chains for Python functions + docstring content for C extension types."
    - "socket.socket.accept.__code__.co_name == 'accept' — accept is a pure Python function in Lib/socket.py defined as 'def accept(self):'. The code object co_name matches the definition name exactly. socket_extra62 checks accept.__code__.__class__.__name__.__eq__('code') (code class identity axis). No prior socket spec checks accept.__code__.co_name in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__code__.co_name == 'makefile' — makefile is a pure Python function in Lib/socket.py defined as 'def makefile(self, mode, buffering, ...)'. The code object co_name matches the definition name. socket_extra62 checks makefile.__code__.__class__.__name__.__eq__('code') (code class identity axis). No prior socket spec checks makefile.__code__.co_name in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__code__.co_argcount == 1 — accept(self) takes only self. co_argcount counts positional-or-keyword parameters including self, so co_argcount is 1. No prior socket spec checks accept.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__code__.co_argcount == 3 — makefile(self, mode='r', buffering=None, ...) has self plus 'mode' and 'buffering' as positional-with-default parameters. co_argcount counts positional-or-keyword parameters (with or without defaults), giving 3. No prior socket spec checks makefile.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__doc__ contains 'host' — the docstring is 'gethostbyname(host) -> address\\n\\nReturn the IP address (a string of the form \\'255.255.255.255\\') for a host.' The word 'host' appears in the parameter name in the signature and again at the end of the description. socket_extra62 checks gethostname.__doc__.__contains__('host') (wave 229); no prior socket spec checks gethostbyname.__doc__.__contains__ for any keyword. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__doc__ contains 'hostname' — the getfqdn docstring begins 'Get fully qualified domain name from name.' and later references 'hostname' multiple times (e.g. 'hostname returned by gethostbyaddr()'). No prior socket spec checks getfqdn.__doc__.__contains__ for any keyword. socket_extra8 checks getfqdn.__qualname__.__eq__ (qualname axis, not docstring content). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.accept and makefile __code__.co_name deep chain
#
# Wave 230 theme: __code__ deep chains for Python functions.
#
# socket.socket.accept and socket.socket.makefile are pure Python functions
# in Lib/socket.py. Their code objects have co_name matching the definition
# names exactly: 'accept' and 'makefile'. socket_extra62 checks the
# __code__.__class__.__name__ axis for both methods. No prior socket spec
# checks __code__.co_name for any socket.socket method.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra63.socket_method_code_co_name:
  description: "socket.socket.accept.__code__.co_name.__eq__('accept') and makefile.__code__.co_name.__eq__('makefile') — both are pure Python functions in Lib/socket.py whose co_name matches the definition name exactly; socket_extra62 checks __code__.__class__.__name__.__eq__('code') axis for both; no prior socket spec checks __code__.co_name for any socket.socket method; first co_name anchor for socket.socket"
  kind: python_call_eq
  category: code_objects
  id_prefix: socketcode2_63

  columns: [id, function, args, expected]
  rows:
    - [accept_code_co_name_eq,   socket.accept.__code__.co_name.__eq__,   ["accept"],   true]
    - [makefile_code_co_name_eq, socket.makefile.__code__.co_name.__eq__, ["makefile"], true]

# ---------------------------------------------------------------------------
# socket.socket.accept and makefile __code__.co_argcount deep chain
#
# Wave 230 theme: __code__ deep chains for Python functions.
#
# socket.socket.accept(self): co_argcount is 1 (self only).
# socket.socket.makefile(self, mode='r', buffering=None, ...): co_argcount
# is 3 (self + mode + buffering, all positional-or-keyword).
#
# No prior socket spec checks __code__.co_argcount for any socket.socket
# method. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra63.socket_method_code_co_argcount:
  description: "socket.socket.accept.__code__.co_argcount==1 and makefile.__code__.co_argcount==3 — accept(self) has 1 positional-or-keyword param (self); makefile(self, mode='r', buffering=None) has 3 positional-or-keyword params (self + mode + buffering); no prior socket spec checks __code__.co_argcount for any socket.socket method; first co_argcount anchor for socket.socket"
  kind: python_call_eq
  category: code_objects
  id_prefix: socketcode2_63

  columns: [id, function, args, expected]
  rows:
    - [accept_code_co_argcount_eq,   socket.accept.__code__.co_argcount.__eq__,   [1], true]
    - [makefile_code_co_argcount_eq, socket.makefile.__code__.co_argcount.__eq__, [3], true]

# ---------------------------------------------------------------------------
# socket.gethostbyname and getfqdn __doc__ content checks
#
# Wave 230 theme: docstring content for C extension types / module-level funcs.
#
# socket.gethostbyname.__doc__ == 'gethostbyname(host) -> address\n\nReturn
# the IP address (a string of the form \'255.255.255.255\') for a host.'
# The word 'host' appears in the signature and at the end of the description.
# socket_extra62 checks gethostname.__doc__.__contains__('host') (wave 229)
# but NOT gethostbyname. No prior socket spec checks gethostbyname.__doc__
# content.
#
# socket.getfqdn.__doc__ begins 'Get fully qualified domain name from name.'
# The word 'hostname' appears multiple times in the body. socket_extra8 checks
# getfqdn.__qualname__.__eq__ (qualname axis). No prior socket spec checks
# getfqdn.__doc__.__contains__ for any keyword. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table socket_extra63.gethostbyname_getfqdn_doc_contains:
  description: "socket.gethostbyname.__doc__.__contains__('host') and getfqdn.__doc__.__contains__('hostname') — gethostbyname docstring is 'gethostbyname(host) -> address\\n\\n...for a host.'; 'host' appears in the signature and description; getfqdn docstring contains 'hostname' in references to gethostbyaddr(); socket_extra62 checks gethostname.__doc__.__contains__('host') but not gethostbyname or getfqdn; socket_extra8 checks getfqdn.__qualname__.__eq__ (qualname axis); no prior socket spec checks __doc__.__contains__ for gethostbyname or getfqdn"
  kind: python_call_eq
  category: docstrings
  id_prefix: socketcode2_63

  columns: [id, function, args, expected]
  rows:
    - [gethostbyname_doc_contains_host,     gethostbyname.__doc__.__contains__, ["host"],     true]
    - [getfqdn_doc_contains_hostname,        getfqdn.__doc__.__contains__,       ["hostname"], true]

# ---------------------------------------------------------------------------
# socket.socket.accept.__code__.co_name.__eq__('accept') — standalone
#
# socket.socket.accept is defined as 'def accept(self):' in Lib/socket.py.
# The code object's co_name captures the definition name 'accept'. This
# confirms that accept is a genuine Python function definition (not a lambda
# or renamed alias). socket_extra62 checks accept.__code__.__class__.__name__
# (class identity axis) and accept.__defaults__.__class__.__name__ (defaults
# axis). No prior socket spec checks accept.__code__.co_name. First co_name
# anchor for any socket.socket method. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant socket_extra63.accept_code_co_name_accept:
  description: "socket.socket.accept.__code__.co_name.__eq__('accept') == True — accept is defined as 'def accept(self):' in Lib/socket.py; co_name matches the definition name 'accept' exactly; socket_extra62 checks __code__.__class__.__name__ (class identity axis) and __defaults__.__class__.__name__ (defaults axis); no prior socket spec checks accept.__code__.co_name; first co_name anchor for any socket.socket method"
  category: code_objects
  kind: python_call_eq
  function: socket.accept.__code__.co_name.__eq__
  args: ["accept"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gethostbyname.__doc__.__contains__('host') — standalone
#
# socket.gethostbyname is a C function from socketmodule.c. Its docstring is
# 'gethostbyname(host) -> address\n\nReturn the IP address (a string of the
# form \'255.255.255.255\') for a host.' The word 'host' appears both as the
# parameter name in the signature and at the end of the description ('for a
# host.'). socket_extra62 checks gethostname.__doc__.__contains__('host')
# (wave 229) but not gethostbyname. socket_extra8 covers gethostbyname
# __qualname__.__eq__ (qualname axis only). No prior socket spec checks
# gethostbyname.__doc__.__contains__ for any keyword. First docstring content
# anchor for gethostbyname. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra63.gethostbyname_doc_contains_host:
  description: "socket.gethostbyname.__doc__.__contains__('host') == True — C function docstring is 'gethostbyname(host) -> address\\n\\nReturn the IP address...for a host.'; 'host' appears in the parameter signature and in the description body; socket_extra62 checks gethostname.__doc__.__contains__('host') (wave 229, a different function); socket_extra8 checks gethostbyname.__qualname__.__eq__ (qualname axis only); no prior socket spec checks gethostbyname.__doc__.__contains__ for any keyword; first docstring content anchor for gethostbyname"
  category: docstrings
  kind: python_call_eq
  function: gethostbyname.__doc__.__contains__
  args: ["host"]
  expected: true
