spec: abc_extra130
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py, Modules/_abc.c"
  notes:
    - "This spec covers: wave 258 theme — abc.ABC.__dict__ and abc.ABCMeta.__dict__ class and length checks. NEW in extra130: abc.ABC.__dict__.__class__.__name__=='mappingproxy' (len=12); abc.ABC.__dict__.__len__()==7; abc.ABCMeta.__dict__.__class__.__name__=='mappingproxy' (same class); abc.ABCMeta.__dict__.__len__()==11; abc.ABC.__dict__ keys are ['__module__', '__firstlineno__', '__doc__', '__slots__', '__static_attributes__', '__abstractmethods__', '_abc_impl']; abc.ABCMeta.__dict__ keys are ['__module__', '__firstlineno__', '__doc__', '__new__', 'register', '__instancecheck__', '__subclasscheck__', '_dump_registry', '_abc_registry_clear', '_abc_caches_clear', '__static_attributes__']. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy'. Class __dict__ attributes are always of type mappingproxy (read-only dictionary proxy) rather than plain dict. This applies to both ABC and ABCMeta. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__dict__.__len__() == 7. The 7 keys are: '__module__', '__firstlineno__', '__doc__', '__slots__', '__static_attributes__', '__abstractmethods__', '_abc_impl'. Note that '__slots__' and '_abc_impl' are ABC-specific keys not found in ordinary classes. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__dict__.__len__() == 11. The 11 keys are: '__module__', '__firstlineno__', '__doc__', '__new__', 'register', '__instancecheck__', '__subclasscheck__', '_dump_registry', '_abc_registry_clear', '_abc_caches_clear', '__static_attributes__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC.__dict__ class name and length — extra130
#
# Wave 258 theme: abc.ABC.__dict__ and abc.ABCMeta.__dict__ mappingproxy checks.
#
# abc.ABC.__dict__.__class__.__name__  == 'mappingproxy' (len=12)
# abc.ABC.__dict__.__len__()           == 7
# abc.ABC.__dict__.__contains__('__module__')  == True
# abc.ABC.__dict__.__contains__('_abc_impl')   == True
# abc.ABC.__dict__.__contains__('__slots__')   == True
# ---------------------------------------------------------------------------

table abc_extra130.abc_abc_dict_checks:
  description: "abc.ABC.__dict__ class name and key membership checks in abcdict130 namespace — wave 258 theme: ABC.__dict__ mappingproxy; ABC.__dict__ is a mappingproxy (read-only dict proxy) with 7 keys: ['__module__', '__firstlineno__', '__doc__', '__slots__', '__static_attributes__', '__abstractmethods__', '_abc_impl']; ABC.__dict__.__class__.__name__.__eq__('mappingproxy')==True (len=12: 'mappingproxy'=12); ABC.__dict__.__len__()==7; __contains__('__module__')==True; __contains__('_abc_impl')==True (_abc_impl holds the internal ABCMeta registry for ABC); __contains__('__slots__')==True (ABC defines __slots__ = () to avoid instance __dict__); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdict130

  columns: [id, function, args, expected, description]
  rows:
    - [dict_cls_name_eq,    abc.ABC.__dict__.__class__.__name__.__eq__,    ["mappingproxy"], true, "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]
    - [dict_cls_name_len,   abc.ABC.__dict__.__class__.__name__.__len__,   [],               12,   "abc.ABC.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy'=12); verified with Python 3.14.3"]
    - [dict_len,            abc.ABC.__dict__.__len__,                      [],               7,    "abc.ABC.__dict__.__len__() == 7 (7 keys in ABC's class dict); verified with Python 3.14.3"]
    - [dict_has_module,     abc.ABC.__dict__.__contains__,                 ["__module__"],   true, "abc.ABC.__dict__.__contains__('__module__') == True; verified with Python 3.14.3"]
    - [dict_has_abc_impl,   abc.ABC.__dict__.__contains__,                 ["_abc_impl"],    true, "abc.ABC.__dict__.__contains__('_abc_impl') == True (internal ABCMeta registry); verified with Python 3.14.3"]
    - [dict_has_slots,      abc.ABC.__dict__.__contains__,                 ["__slots__"],    true, "abc.ABC.__dict__.__contains__('__slots__') == True (ABC defines __slots__ = ()); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__dict__ class name and length — extra130
#
# abc.ABCMeta.__dict__.__class__.__name__  == 'mappingproxy' (len=12)
# abc.ABCMeta.__dict__.__len__()           == 11
# abc.ABCMeta.__dict__.__contains__('register')           == True
# abc.ABCMeta.__dict__.__contains__('__instancecheck__')  == True
# abc.ABCMeta.__dict__.__contains__('__subclasscheck__')  == True
# abc.ABCMeta.__dict__.__contains__('__new__')            == True
# ---------------------------------------------------------------------------

table abc_extra130.abc_abcmeta_dict_checks:
  description: "abc.ABCMeta.__dict__ class name, length, and key membership checks in abcdict130 namespace — wave 258 theme: ABCMeta.__dict__ mappingproxy; ABCMeta.__dict__ is a mappingproxy with 11 keys: ['__module__', '__firstlineno__', '__doc__', '__new__', 'register', '__instancecheck__', '__subclasscheck__', '_dump_registry', '_abc_registry_clear', '_abc_caches_clear', '__static_attributes__']; ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy')==True (same class as ABC.__dict__); ABCMeta.__dict__.__len__()==11 (4 more entries than ABC's 7); __contains__('register')==True (register() lets classes be registered as virtual subclasses); __contains__('__instancecheck__')==True (enables isinstance() support); __contains__('__subclasscheck__')==True (enables issubclass() support); __contains__('__new__')==True (ABCMeta.__new__ customizes class creation); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdict130a

  columns: [id, function, args, expected, description]
  rows:
    - [meta_dict_cls_eq,      abc.ABCMeta.__dict__.__class__.__name__.__eq__,   ["mappingproxy"],    true, "abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]
    - [meta_dict_cls_len,     abc.ABCMeta.__dict__.__class__.__name__.__len__,  [],                  12,   "abc.ABCMeta.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy'=12); verified with Python 3.14.3"]
    - [meta_dict_len,         abc.ABCMeta.__dict__.__len__,                     [],                  11,   "abc.ABCMeta.__dict__.__len__() == 11 (11 keys in ABCMeta's class dict); verified with Python 3.14.3"]
    - [meta_dict_has_register, abc.ABCMeta.__dict__.__contains__,               ["register"],        true, "abc.ABCMeta.__dict__.__contains__('register') == True; verified with Python 3.14.3"]
    - [meta_dict_has_instance, abc.ABCMeta.__dict__.__contains__,               ["__instancecheck__"], true, "abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True; verified with Python 3.14.3"]
    - [meta_dict_has_subclass, abc.ABCMeta.__dict__.__contains__,               ["__subclasscheck__"], true, "abc.ABCMeta.__dict__.__contains__('__subclasscheck__') == True; verified with Python 3.14.3"]
    - [meta_dict_has_new,     abc.ABCMeta.__dict__.__contains__,                ["__new__"],          true, "abc.ABCMeta.__dict__.__contains__('__new__') == True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC and abc.ABCMeta __dict__ cross-comparison — extra130
#
# Both dict class names == 'mappingproxy'
# abc.ABC.__dict__.__len__()     == 7
# abc.ABCMeta.__dict__.__len__() == 11
# difference == 4
# abc.ABC.__dict__.__class__.__name__ == abc.ABCMeta.__dict__.__class__.__name__
# 'mappingproxy'.__len__() == 12
# ---------------------------------------------------------------------------

table abc_extra130.abc_dict_cross_comparison:
  description: "Cross-comparison checks between abc.ABC.__dict__ and abc.ABCMeta.__dict__ in abcdict130 namespace — wave 258 theme: both class dicts are mappingproxy instances; ABC.__dict__.__len__()==7 while ABCMeta.__dict__.__len__()==11; the 'mappingproxy' class name has length 12; ABC dict does NOT contain 'register' (that is an ABCMeta-specific method); ABCMeta dict does NOT contain '_abc_impl' (that is an ABC instance-level registry attribute); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdict130b

  columns: [id, function, args, expected, description]
  rows:
    - [abc_dict_len_7,      abc.ABC.__dict__.__len__,                      [],           7,    "abc.ABC.__dict__.__len__() == 7 (7 keys: __module__, __firstlineno__, __doc__, __slots__, __static_attributes__, __abstractmethods__, _abc_impl); verified with Python 3.14.3"]
    - [meta_dict_len_11,    abc.ABCMeta.__dict__.__len__,                  [],           11,   "abc.ABCMeta.__dict__.__len__() == 11 (11 keys: 4 more than ABC's 7); verified with Python 3.14.3"]
    - [proxy_name_len_12,   abc.ABC.__dict__.__class__.__name__.__len__,   [],           12,   "abc.ABC.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy'=12); verified with Python 3.14.3"]
    - [abc_no_register,     abc.ABC.__dict__.__contains__,                 ["register"], false, "abc.ABC.__dict__.__contains__('register') == False (register is ABCMeta-only); verified with Python 3.14.3"]
    - [meta_no_abc_impl,    abc.ABCMeta.__dict__.__contains__,             ["_abc_impl"], false, "abc.ABCMeta.__dict__.__contains__('_abc_impl') == False (_abc_impl is in ABC, not ABCMeta itself); verified with Python 3.14.3"]
    - [meta_has_doc,        abc.ABCMeta.__dict__.__contains__,             ["__doc__"],  true,  "abc.ABCMeta.__dict__.__contains__('__doc__') == True (present in both ABC and ABCMeta dicts); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra130
# ---------------------------------------------------------------------------

invariant abc_extra130.ABC_dict_len_7:
  description: "abc.ABC.__dict__.__len__() == 7 — abc.ABC's class __dict__ contains exactly 7 keys: '__module__', '__firstlineno__', '__doc__', '__slots__', '__static_attributes__', '__abstractmethods__', '_abc_impl'; '__slots__' is present because ABC defines __slots__ = () to prevent instance __dict__ creation on ABC itself; '_abc_impl' holds the internal registry used by ABCMeta; '__abstractmethods__' is a frozenset that is empty for ABC itself; abc.ABC.__dict__.__class__.__name__ is 'mappingproxy' (len=12); abc.ABCMeta.__dict__.__len__() is 11 (4 more keys than ABC); NEW in extra130: first standalone ABC.__dict__ length invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__len__
  args: []
  expected: 7

invariant abc_extra130.ABCMeta_dict_len_11:
  description: "abc.ABCMeta.__dict__.__len__() == 11 — abc.ABCMeta's class __dict__ contains exactly 11 keys: '__module__', '__firstlineno__', '__doc__', '__new__', 'register', '__instancecheck__', '__subclasscheck__', '_dump_registry', '_abc_registry_clear', '_abc_caches_clear', '__static_attributes__'; ABCMeta defines 4 more keys than ABC (7): it adds '__new__', 'register', '__instancecheck__', '__subclasscheck__' plus utility methods; abc.ABCMeta.__dict__.__class__.__name__ is 'mappingproxy' (len=12, same as ABC.__dict__.__class__.__name__); NEW in extra130: first standalone ABCMeta.__dict__ length invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__len__
  args: []
  expected: 11

invariant abc_extra130.ABC_dict_class_name_mappingproxy:
  description: "abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — all class __dict__ attributes in CPython are instances of mappingproxy, a read-only dictionary proxy that prevents direct assignment to class attributes bypassing the descriptor protocol; abc.ABC.__dict__.__class__.__name__ is 'mappingproxy' (12 chars: 'mapping'=7 + 'proxy'=5 = 12); abc.ABCMeta.__dict__.__class__.__name__ is also 'mappingproxy' (same type); abc.ABC.__dict__.__len__() is 7; abc.ABCMeta.__dict__.__len__() is 11; NEW in extra130: first standalone ABC.__dict__ class name invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra130.ABCMeta_dict_class_name_mappingproxy:
  description: "abc.ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — abc.ABCMeta.__dict__ is also a mappingproxy instance, the same type as abc.ABC.__dict__; both class dicts share the same __class__.__name__ of 'mappingproxy' (len=12); the mappingproxy type is defined in CPython's Objects/descrobject.c; ABCMeta is a metaclass (its metaclass is type) yet its __dict__ is still a mappingproxy just like any other class; abc.ABCMeta.__dict__.__len__() is 11; abc.ABCMeta.__dict__.__contains__('register') is True; NEW in extra130: first standalone ABCMeta.__dict__ class name invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra130.ABC_dict_has_abc_impl:
  description: "abc.ABC.__dict__.__contains__('_abc_impl') returns True — '_abc_impl' is present in abc.ABC's class __dict__ because ABC uses ABCMeta as its metaclass, which stores its internal abstract base class registry in this attribute; '_abc_impl' holds a C-level _abc_data object (from Modules/_abc.c) that tracks registered virtual subclasses and caches; abc.ABCMeta.__dict__.__contains__('_abc_impl') is False — '_abc_impl' lives on instances of ABCMeta (i.e., classes using ABCMeta as metaclass), not on ABCMeta itself; abc.ABC.__dict__.__len__() is 7; abc.ABC.__dict__.__class__.__name__ is 'mappingproxy' (len=12); NEW in extra130: first standalone ABC._abc_impl membership invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__contains__
  args: ["_abc_impl"]
  expected: true

