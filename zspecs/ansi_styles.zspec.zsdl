spec: ansi_styles
version: ">=6.0.0"
backend: node(ansi-styles)
esm: true

docs: https://github.com/chalk/ansi-styles#readme

provenance:
  derived_from:
    - "ansi-styles README — https://github.com/chalk/ansi-styles#readme"
    - "ANSI escape sequences — ECMA-48 / ISO/IEC 6429"
    - "Test vectors verified with ansi-styles via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "ansi-styles source"
  notes:
    - "Underlying ANSI code map used by chalk — exposes {open, close} pairs for each color/style and groups them under .color, .bgColor, .modifier."
    - "Install: npm install ansi-styles"
    - "v6 ESM only; named-export object."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure data + a few helpers; never throws."
  stderr: "null"
  stickiness: "N/A — table of constants."
  codes: {}

invariant ansi_styles.red_open_code:
  description: "red.open is \\u001b[31m"
  category: codes
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.red.open"}
  expected: "\x1b[31m"

invariant ansi_styles.red_close_code:
  description: "red.close is \\u001b[39m (default foreground)"
  category: codes
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.red.close"}
  expected: "\x1b[39m"

invariant ansi_styles.bold_open_code:
  description: "bold.open is \\u001b[1m"
  category: codes
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.bold.open"}
  expected: "\x1b[1m"

invariant ansi_styles.bold_close_code:
  description: "bold.close is \\u001b[22m"
  category: codes
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.bold.close"}
  expected: "\x1b[22m"

invariant ansi_styles.reset_open_code:
  description: "reset.open is \\u001b[0m"
  category: codes
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.reset.open"}
  expected: "\x1b[0m"

invariant ansi_styles.has_color_namespace:
  description: ".color namespace exists with named foreground colors"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.color.red.open"}
  expected: "\x1b[31m"

invariant ansi_styles.has_bgColor_namespace:
  description: ".bgColor namespace exists; bgRed.open is \\u001b[41m"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.bgColor.bgRed.open"}
  expected: "\x1b[41m"

invariant ansi_styles.has_modifier_namespace:
  description: ".modifier namespace exists; bold.open is \\u001b[1m"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.modifier.bold.open"}
  expected: "\x1b[1m"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:32:46Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
