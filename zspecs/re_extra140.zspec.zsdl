spec: re_extra140
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec covers: re.Pattern method descriptor __qualname__, __class__.__name__, and __objclass__.__name__ for match, search, findall, finditer, sub, split, fullmatch, subn."
    - "re.Pattern is a C extension type; all its methods are method_descriptor instances with __objclass__.__name__ == 'Pattern'."
    - "Pattern.match.__qualname__ == 'Pattern.match' (length 13)."
    - "Pattern.search.__qualname__ == 'Pattern.search' (length 14)."
    - "Pattern.findall.__qualname__ == 'Pattern.findall' (length 15)."
    - "Pattern.finditer.__qualname__ == 'Pattern.finditer' (length 16)."
    - "Pattern.sub.__qualname__ == 'Pattern.sub' (length 11)."
    - "Pattern.split.__qualname__ == 'Pattern.split' (length 13)."
    - "Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch' (length 17)."
    - "Pattern.subn.__qualname__ == 'Pattern.subn' (length 12)."
    - "re.Pattern.__name__ == 'Pattern' (length 7); __module__ == 're' (length 2); __class__.__name__ == 'type'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern class identity
# Pattern is a C extension type defined in _sre, exposed via re.
# __name__ == 'Pattern' (7), __module__ == 're' (2), __qualname__ == 'Pattern' (7).
# __class__.__name__ == 'type' (plain C type, not ABCMeta).
# ---------------------------------------------------------------------------

table re_extra140.Pattern_class_identity:
  description: "re.Pattern class identity: __name__='Pattern' (7), __module__='re' (2), __qualname__='Pattern' (7), __class__.__name__='type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: repat140

  columns: [id, function, args, expected]
  rows:
    - [pat_name_eq,      Pattern.__name__.__eq__,          ["Pattern"], true]
    - [pat_name_len,     Pattern.__name__.__len__,         [],          7]
    - [pat_module_eq,    Pattern.__module__.__eq__,        ["re"],      true]
    - [pat_module_len,   Pattern.__module__.__len__,       [],          2]
    - [pat_qualname_eq,  Pattern.__qualname__.__eq__,      ["Pattern"], true]
    - [pat_qualname_len, Pattern.__qualname__.__len__,     [],          7]
    - [pat_cls_eq,       Pattern.__class__.__name__.__eq__, ["type"],   true]

# ---------------------------------------------------------------------------
# re.Pattern core search method descriptor __qualname__ values
# match: 'Pattern.match' (13), search: 'Pattern.search' (14),
# findall: 'Pattern.findall' (15), finditer: 'Pattern.finditer' (16).
# All are method_descriptor instances with __objclass__.__name__ == 'Pattern'.
# ---------------------------------------------------------------------------

table re_extra140.Pattern_search_method_qualnames:
  description: "re.Pattern search method descriptor __qualname__ values: match=13, search=14, findall=15, finditer=16; all method_descriptor with __objclass__.__name__='Pattern'"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: repat140

  columns: [id, function, args, expected]
  rows:
    - [match_cls_eq,      Pattern.match.__class__.__name__.__eq__,      ["method_descriptor"],    true]
    - [search_cls_eq,     Pattern.search.__class__.__name__.__eq__,     ["method_descriptor"],    true]
    - [findall_cls_eq,    Pattern.findall.__class__.__name__.__eq__,    ["method_descriptor"],    true]
    - [finditer_cls_eq,   Pattern.finditer.__class__.__name__.__eq__,   ["method_descriptor"],    true]
    - [match_qn_eq,       Pattern.match.__qualname__.__eq__,            ["Pattern.match"],        true]
    - [match_qn_len,      Pattern.match.__qualname__.__len__,           [],                       13]
    - [search_qn_eq,      Pattern.search.__qualname__.__eq__,           ["Pattern.search"],       true]
    - [search_qn_len,     Pattern.search.__qualname__.__len__,          [],                       14]
    - [findall_qn_eq,     Pattern.findall.__qualname__.__eq__,          ["Pattern.findall"],      true]
    - [findall_qn_len,    Pattern.findall.__qualname__.__len__,         [],                       15]
    - [finditer_qn_eq,    Pattern.finditer.__qualname__.__eq__,         ["Pattern.finditer"],     true]
    - [finditer_qn_len,   Pattern.finditer.__qualname__.__len__,        [],                       16]

# ---------------------------------------------------------------------------
# re.Pattern substitution and split method descriptor __qualname__ values
# sub: 'Pattern.sub' (11), split: 'Pattern.split' (13),
# subn: 'Pattern.subn' (12), fullmatch: 'Pattern.fullmatch' (17).
# All are method_descriptor instances.
# ---------------------------------------------------------------------------

table re_extra140.Pattern_sub_split_method_qualnames:
  description: "re.Pattern sub/split method descriptor __qualname__ values: sub=11, split=13, subn=12, fullmatch=17; all method_descriptor"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: repat140

  columns: [id, function, args, expected]
  rows:
    - [sub_cls_eq,        Pattern.sub.__class__.__name__.__eq__,        ["method_descriptor"],    true]
    - [split_cls_eq,      Pattern.split.__class__.__name__.__eq__,      ["method_descriptor"],    true]
    - [subn_cls_eq,       Pattern.subn.__class__.__name__.__eq__,       ["method_descriptor"],    true]
    - [fullmatch_cls_eq,  Pattern.fullmatch.__class__.__name__.__eq__,  ["method_descriptor"],    true]
    - [sub_qn_eq,         Pattern.sub.__qualname__.__eq__,              ["Pattern.sub"],          true]
    - [sub_qn_len,        Pattern.sub.__qualname__.__len__,             [],                       11]
    - [split_qn_eq,       Pattern.split.__qualname__.__eq__,            ["Pattern.split"],        true]
    - [split_qn_len,      Pattern.split.__qualname__.__len__,           [],                       13]
    - [subn_qn_eq,        Pattern.subn.__qualname__.__eq__,             ["Pattern.subn"],         true]
    - [subn_qn_len,       Pattern.subn.__qualname__.__len__,            [],                       12]
    - [fullmatch_qn_eq,   Pattern.fullmatch.__qualname__.__eq__,        ["Pattern.fullmatch"],    true]
    - [fullmatch_qn_len,  Pattern.fullmatch.__qualname__.__len__,       [],                       17]

# ---------------------------------------------------------------------------
# re.Pattern method descriptor __objclass__.__name__
# All Pattern methods have __objclass__.__name__ == 'Pattern'.
# Covers: match, search, findall, finditer, sub, split, subn, fullmatch.
# ---------------------------------------------------------------------------

table re_extra140.Pattern_method_objclass:
  description: "re.Pattern method descriptor __objclass__.__name__ == 'Pattern' for all search/transform methods: match, search, findall, finditer, sub, split, subn, fullmatch"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: repat140

  columns: [id, function, args, expected]
  rows:
    - [match_obj_eq,      Pattern.match.__objclass__.__name__.__eq__,      ["Pattern"], true]
    - [search_obj_eq,     Pattern.search.__objclass__.__name__.__eq__,     ["Pattern"], true]
    - [findall_obj_eq,    Pattern.findall.__objclass__.__name__.__eq__,    ["Pattern"], true]
    - [finditer_obj_eq,   Pattern.finditer.__objclass__.__name__.__eq__,   ["Pattern"], true]
    - [sub_obj_eq,        Pattern.sub.__objclass__.__name__.__eq__,        ["Pattern"], true]
    - [split_obj_eq,      Pattern.split.__objclass__.__name__.__eq__,      ["Pattern"], true]
    - [subn_obj_eq,       Pattern.subn.__objclass__.__name__.__eq__,       ["Pattern"], true]
    - [fullmatch_obj_eq,  Pattern.fullmatch.__objclass__.__name__.__eq__,  ["Pattern"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra140.Pattern.match_qualname_eq:
  description: "re.Pattern.match.__qualname__ == 'Pattern.match' (length 13; match is a method_descriptor on the C Pattern type, qualname has no module prefix)"
  category: method_descriptor
  kind: python_call_eq
  function: Pattern.match.__qualname__.__eq__
  args: ["Pattern.match"]
  expected: true

invariant re_extra140.Pattern.finditer_qualname_len_16:
  description: "re.Pattern.finditer.__qualname__.__len__() == 16 ('Pattern.finditer' has 16 characters; the longest of the primary search method qualnames)"
  category: method_descriptor
  kind: python_call_eq
  function: Pattern.finditer.__qualname__.__len__
  args: []
  expected: 16

invariant re_extra140.Pattern.sub_qualname_len_11:
  description: "re.Pattern.sub.__qualname__.__len__() == 11 ('Pattern.sub' has 11 characters; the shortest of the Pattern method qualnames in this spec)"
  category: method_descriptor
  kind: python_call_eq
  function: Pattern.sub.__qualname__.__len__
  args: []
  expected: 11

invariant re_extra140.Pattern.fullmatch_qualname_len_17:
  description: "re.Pattern.fullmatch.__qualname__.__len__() == 17 ('Pattern.fullmatch' has 17 characters; fullmatch requires the entire string to match, unlike match which anchors only at the start)"
  category: method_descriptor
  kind: python_call_eq
  function: Pattern.fullmatch.__qualname__.__len__
  args: []
  expected: 17

invariant re_extra140.Pattern.search_objclass_is_Pattern:
  description: "re.Pattern.search.__objclass__.__name__ == 'Pattern' (length 7; the owning type for all Pattern method descriptors is Pattern itself)"
  category: method_descriptor
  kind: python_call_eq
  function: Pattern.search.__objclass__.__name__.__eq__
  args: ["Pattern"]
  expected: true
