spec: pretty_error
version: ">=4.0.0"
backend: node(pretty-error)

docs: https://github.com/AriaMinaei/pretty-error#readme

provenance:
  derived_from:
    - "pretty-error README — https://github.com/AriaMinaei/pretty-error#readme"
    - "Test vectors verified with pretty-error via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "pretty-error source"
  notes:
    - "Format Error stack traces with terminal colors and elision of internal frames."
    - "Install: npm install pretty-error"
    - "v4 CJS; module export IS the PrettyError class. Instances expose .render(err), .skip(...) , .filter(...), etc."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure transformation; never throws on Error input."
  stderr: "null"
  stickiness: "Filters/skip lists are per-instance state."
  codes: {}

invariant pretty_error.module_is_class:
  description: "Module export is a class (Function)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant pretty_error.module_name_is_PrettyError:
  description: "Class name is 'PrettyError'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: name}
  expected: "PrettyError"

invariant pretty_error.prototype_has_render:
  description: "PrettyError.prototype.render is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.render.constructor.name"}
  expected: "Function"

invariant pretty_error.prototype_has_start:
  description: "PrettyError.prototype.start is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.start.constructor.name"}
  expected: "Function"

invariant pretty_error.prototype_has_stop:
  description: "PrettyError.prototype.stop is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.stop.constructor.name"}
  expected: "Function"

invariant pretty_error.prototype_has_skip:
  description: "PrettyError.prototype.skip is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.skip.constructor.name"}
  expected: "Function"

invariant pretty_error.prototype_has_unskip:
  description: "PrettyError.prototype.unskip is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.unskip.constructor.name"}
  expected: "Function"

invariant pretty_error.prototype_has_skipNodeFiles:
  description: "PrettyError.prototype.skipNodeFiles is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.skipNodeFiles.constructor.name"}
  expected: "Function"

