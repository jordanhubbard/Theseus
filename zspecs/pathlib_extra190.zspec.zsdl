invariant pathlib_extra190.pureposixpath_name_eq:
  description: "pathlib.PurePosixPath.__name__ == 'PurePosixPath' — POSIX-flavour pure path class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PurePosixPath.__name__.__eq__
  args: ["PurePosixPath"]
  expected: true

invariant pathlib_extra190.pureposixpath_name_len_13:
  description: "pathlib.PurePosixPath.__name__.__len__() == 13 — 'PurePosixPath' has 13 characters; confirmed Python 3.14.3 macOS"
  category: identity
