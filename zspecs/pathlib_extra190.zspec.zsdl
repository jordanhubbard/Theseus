# ---------------------------------------------------------------------------
# Table 3: cross-class identity distinguishing PurePosixPath from PureWindowsPath
# ---------------------------------------------------------------------------

table pathlib_extra190.purepath_cross_identity:
  description: "PurePosixPath and PureWindowsPath are distinct classes sharing the PurePath base — cross-identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpurepath190

  columns: [id, function, args, expected, description]
  rows:
    - [ppp_ne_pwp,   PurePosixPath.__name__.__eq__,    ["PureWindowsPath"], false,  "pathlib.PurePosixPath.__name__.__eq__('PureWindowsPath') == False — PurePosixPath and PureWindowsPath are distinct; confirmed Python 3.14.3 macOS"]
    - [pwp_ne_ppp,   PureWindowsPath.__name__.__eq__,  ["PurePosixPath"],   false,  "pathlib.PureWindowsPath.__name__.__eq__('PurePosixPath') == False — distinct class names; confirmed Python 3.14.3 macOS"]
    - [ppp_base_eq,  "PurePosixPath.__bases__[0].__name__.__eq__",   ["PurePath"], true, "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — both pure path variants inherit from PurePath; confirmed Python 3.14.3 macOS"]
    - [pwp_base_eq,  "PureWindowsPath.__bases__[0].__name__.__eq__", ["PurePath"], true, "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — both pure path variants inherit from PurePath; confirmed Python 3.14.3 macOS"]
    - [ppp_mod_eq,   PurePosixPath.__module__.__eq__,   ["pathlib"],        true,   "pathlib.PurePosixPath.__module__ == 'pathlib' — both classes live in the same pathlib module; confirmed Python 3.14.3 macOS"]

