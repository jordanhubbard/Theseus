spec: pathlib_extra190
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
  notes:
    - "pathlib.PurePosixPath.__name__=='PurePosixPath' (len=13); __module__=='pathlib'; __qualname__=='PurePosixPath'."
    - "pathlib.PurePosixPath.__bases__[0].__name__=='PurePath' — PurePosixPath inherits directly from PurePath."
    - "pathlib.PureWindowsPath.__name__=='PureWindowsPath' (len=15); __module__=='pathlib'; __qualname__=='PureWindowsPath'."
    - "pathlib.PureWindowsPath.__bases__[0].__name__=='PurePath' — PureWindowsPath inherits directly from PurePath."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

