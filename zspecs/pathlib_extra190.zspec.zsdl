table pathlib_extra190.pureposixpath_identity:
  description: "pathlib.PurePosixPath class identity: __name__=='PurePosixPath' (len=13); __module__=='pathlib'; __qualname__=='PurePosixPath'; __bases__[0].__name__=='PurePath'"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpurepath190

  columns: [id, function, args, expected, description]
  rows:
    - [ppp_name,     PurePosixPath.__name__.__eq__,     ["PurePosixPath"],  true,  "pathlib.PurePosixPath.__name__ == 'PurePosixPath' — POSIX-flavour pure path; confirmed Python 3.14.3 macOS"]
    - [ppp_name_len, PurePosixPath.__name__.__len__,    [],                 13,    "pathlib.PurePosixPath.__name__.__len__() == 13 — P(1)u(2)r(3)e(4)P(5)o(6)s(7)i(8)x(9)P(10)a(11)t(12)h(13); confirmed Python 3.14.3 macOS"]
    - [ppp_module,   PurePosixPath.__module__.__eq__,   ["pathlib"],        true,  "pathlib.PurePosixPath.__module__ == 'pathlib' — defined in the pathlib standard library module; confirmed Python 3.14.3 macOS"]
    - [ppp_qualname, PurePosixPath.__qualname__.__eq__, ["PurePosixPath"],  true,  "pathlib.PurePosixPath.__qualname__ == 'PurePosixPath' — simple unqualified class name; confirmed Python 3.14.3 macOS"]
    - [ppp_base,     "PurePosixPath.__bases__[0].__name__.__eq__", ["PurePath"], true, "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — inherits directly from PurePath; confirmed Python 3.14.3 macOS"]

