spec: _pickle
version: ">=3.3"
backend: python_module(_pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "_pickle source: Modules/_pickle.c (CPython C accelerator for pickle)"
  not_derived_from:
    - "CPython source: Lib/pickle.py (pure-Python fallback)"
  notes:
    - "_pickle is the C accelerator backend for the pickle module. It exposes Pickler, Unpickler, and the PickleError exception hierarchy directly."
    - "PickleError is the base exception class for all pickle-related errors; it inherits from Exception."
    - "PicklingError is raised when an object cannot be pickled; it inherits from PickleError."
    - "UnpicklingError is raised when there is a problem unpickling data; it inherits from PickleError."
    - "Pickler and Unpickler are the core classes for serialization and deserialization respectively."
    - "Pickler.__module__ and Unpickler.__module__ are '_pickle', confirming they come from the C extension."
    - "All class-name and hierarchy invariants verified by running Python 3.12 _pickle module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "PicklingError is raised when an object cannot be serialized. UnpicklingError is raised for malformed or untrusted pickle data. Both are subclasses of PickleError which is itself a subclass of Exception."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant _pickle.Pickler_name:
  description: "Pickler.__name__ == 'Pickler'"
  category: classnames
  kind: python_call_eq
  function: Pickler.__name__.__eq__
  args: ["Pickler"]
  expected: true

invariant _pickle.Unpickler_name:
  description: "Unpickler.__name__ == 'Unpickler'"
  category: classnames
  kind: python_call_eq
  function: Unpickler.__name__.__eq__
  args: ["Unpickler"]
  expected: true

invariant _pickle.PickleError_name:
  description: "PickleError.__name__ == 'PickleError'"
  category: classnames
  kind: python_call_eq
  function: PickleError.__name__.__eq__
  args: ["PickleError"]
  expected: true

invariant _pickle.PicklingError_name:
  description: "PicklingError.__name__ == 'PicklingError'"
  category: classnames
  kind: python_call_eq
  function: PicklingError.__name__.__eq__
  args: ["PicklingError"]
  expected: true

invariant _pickle.UnpicklingError_name:
  description: "UnpicklingError.__name__ == 'UnpicklingError'"
  category: classnames
  kind: python_call_eq
  function: UnpicklingError.__name__.__eq__
  args: ["UnpicklingError"]
  expected: true

# ---------------------------------------------------------------------------
# Module membership checks
# ---------------------------------------------------------------------------

invariant _pickle.Pickler_module:
  description: "Pickler.__module__ == '_pickle' — comes from C extension"
  category: classnames
  kind: python_call_eq
  function: Pickler.__module__.__eq__
  args: ["_pickle"]
  expected: true

invariant _pickle.Unpickler_module:
  description: "Unpickler.__module__ == '_pickle' — comes from C extension"
  category: classnames
  kind: python_call_eq
  function: Unpickler.__module__.__eq__
  args: ["_pickle"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy checks
# ---------------------------------------------------------------------------

invariant _pickle.PickleError_base:
  description: "PickleError.__bases__[0].__name__ == 'Exception'"
  category: classnames
  kind: python_call_eq
  function: PickleError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

invariant _pickle.PicklingError_base:
  description: "PicklingError.__bases__[0].__name__ == 'PickleError'"
  category: classnames
  kind: python_call_eq
  function: PicklingError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "PickleError"

invariant _pickle.UnpicklingError_base:
  description: "UnpicklingError.__bases__[0].__name__ == 'PickleError'"
  category: classnames
  kind: python_call_eq
  function: UnpicklingError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "PickleError"

