spec: abc_extra410
version: ">=3.9"
backend: python_module(collections.abc)
docs: https://docs.python.org/3/library/collections.abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "collections.abc.ABCMeta.__instancecheck__.__name__ == '__instancecheck__'"
    - "collections.abc.ABCMeta.__instancecheck__.__module__ == 'abc'"
    - "All of Hashable, Sized, Container, Iterable, Iterator, Callable use ABCMeta as their metaclass"
    - "type(collections.abc.Hashable).__instancecheck__ is collections.abc.ABCMeta.__instancecheck__ -- same object"
    - "The __instancecheck__ method is defined once on ABCMeta and shared by all ABC subclasses"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra410.instancecheck_name:
  description: "Verify __name__ of collections.abc.ABCMeta.__instancecheck__ (the metaclass method used for isinstance checks on all ABCs)"
  kind: python_call_eq
  category: identity
  id_prefix: abc410in

  columns: [id, function, args, expected]
  rows:
    - [abc410in001, collections.abc.ABCMeta.__instancecheck__.__name__.__eq__, ["__instancecheck__"], true]

table abc_extra410.instancecheck_module:
  description: "Verify __module__ of collections.abc.ABCMeta.__instancecheck__ (defined in the abc module)"
  kind: python_call_eq
  category: identity
  id_prefix: abc410im

  columns: [id, function, args, expected]
  rows:
    - [abc410im001, collections.abc.ABCMeta.__instancecheck__.__module__.__eq__, ["abc"], true]
