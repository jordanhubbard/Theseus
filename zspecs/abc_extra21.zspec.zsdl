spec: abc_extra21
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra20.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, abc.__name__/__package__, ABC/__bases__[0].__name__, ABCMeta/__bases__[0].__name__, abstractmethod/__bases__[0].__name__, get_cache_token/__name__, ABC/__init_subclass__/__name__, abstractproperty/__name__, abstractclassmethod/__name__, abstractstaticmethod/__name__, register/__name__, various __qualname__ checks for inner methods."
    - "This spec covers: abc.ABC.__init__.__name__, abc.ABCMeta.__init__.__name__, abc.abstractmethod.__init__.__name__, abc.abstractmethod.__call__.__name__, abc.ABC.__module__.__len__(), abc.ABCMeta.__module__.__len__(), abc.abstractmethod.__module__.__len__(), abc.get_cache_token.__module__, abc.get_cache_token.__qualname__, abc.ABC.__subclasshook__.__name__."
    - "abc.ABC.__init__.__name__ == '__init__' — ABC does not override __init__; the slot resolves to object.__init__ whose __name__ is '__init__'."
    - "abc.ABCMeta.__init__.__name__ == '__init__' — ABCMeta does not override __init__ separately; resolves to type.__init__ whose __name__ is '__init__'."
    - "abc.abstractmethod.__init__.__name__ == '__init__' — abstractmethod does not override __init__; resolves to object.__init__."
    - "abc.abstractmethod.__call__.__name__ == '__call__' — the slot is the C-level function.__call__ wrapper; __name__ is '__call__'."
    - "abc.ABC.__module__.__len__() == 3 — 'abc' has length 3."
    - "abc.ABCMeta.__module__.__len__() == 3 — 'abc' has length 3."
    - "abc.abstractmethod.__module__.__len__() == 3 — 'abc' has length 3."
    - "abc.get_cache_token.__module__ == '_abc' — get_cache_token is implemented in the C extension _abc."
    - "abc.get_cache_token.__qualname__ == 'get_cache_token' — top-level C function; __qualname__ equals its simple name."
    - "abc.ABC.__subclasshook__.__name__ == '__subclasshook__' — the classmethod's underlying function __name__ is '__subclasshook__'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __init__.__name__ combined table for ABC/ABCMeta/abstractmethod (extra21 namespace)
#
# None of the prior abc specs record __init__.__name__ for these three classes.
# ABC and abstractmethod resolve to object.__init__; ABCMeta resolves to
# type.__init__. In all three cases __name__ is '__init__'.
# ---------------------------------------------------------------------------

table abc_extra21.init_names:
  description: "__init__.__name__.__eq__ for abc classes in the extra21 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: init_name

  columns: [id, function, args, expected]
  rows:
    - [ABC,            "ABC.__init__.__name__.__eq__",            ["__init__"], true]
    - [ABCMeta,        "ABCMeta.__init__.__name__.__eq__",        ["__init__"], true]
    - [abstractmethod, "abstractmethod.__init__.__name__.__eq__", ["__init__"], true]

# ---------------------------------------------------------------------------
# __module__.__len__() combined table for ABC/ABCMeta/abstractmethod (extra21 namespace)
#
# All three have __module__ == 'abc', which has length 3. No prior abc spec
# records __module__.__len__ for these types. This table exercises the string
# method call path on the __module__ attribute.
# ---------------------------------------------------------------------------

table abc_extra21.module_lens:
  description: "__module__.__len__() for abc core classes — all have module name 'abc' (length 3)"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [ABC,            ABC.__module__.__len__,            [], 3]
    - [ABCMeta,        ABCMeta.__module__.__len__,        [], 3]
    - [abstractmethod, abstractmethod.__module__.__len__, [], 3]

# ---------------------------------------------------------------------------
# get_cache_token combined table: __module__ and __qualname__ (extra21 namespace)
#
# get_cache_token is implemented in the C extension _abc. Its __module__ is
# '_abc' (not 'abc') and its __qualname__ equals its simple name
# 'get_cache_token'. Prior specs record __name__ in isolation; this table
# combines __module__ and __qualname__ in the extra21 namespace for the first time.
# ---------------------------------------------------------------------------

table abc_extra21.get_cache_token_attrs:
  description: "__module__ and __qualname__ for abc.get_cache_token in the extra21 namespace"
  kind: python_call_eq
  category: func_attrs
  id_prefix: gct

  columns: [id, function, args, expected]
  rows:
    - [module,   get_cache_token.__module__.__eq__,   ["_abc"],            true]
    - [qualname, get_cache_token.__qualname__.__eq__,  ["get_cache_token"], true]

# ---------------------------------------------------------------------------
# abc.abstractmethod.__call__.__name__ == '__call__' — standalone (extra21 namespace)
#
# abstractmethod.__call__ is the C-level function.__call__ slot. Its __name__
# attribute is '__call__'. No prior abc spec records this as a standalone
# invariant in the extra21 namespace.
# ---------------------------------------------------------------------------

invariant abc_extra21.abstractmethod.call.name:
  description: "abc.abstractmethod.__call__.__name__ == '__call__' — C-level function slot; __name__ is '__call__'"
  category: method_names
  kind: python_call_eq
  function: "abstractmethod.__call__.__name__.__eq__"
  args: ["__call__"]
  expected: true

# ---------------------------------------------------------------------------
# abc.ABC.__subclasshook__.__name__ == '__subclasshook__' — standalone (extra21 namespace)
#
# ABC.__subclasshook__ is a classmethod. Accessing __name__ on the classmethod
# descriptor yields '__subclasshook__'. Prior specs (abc_extra10, abc_extra20)
# record __qualname__ for this method. This standalone records __name__ in the
# extra21 namespace for the first time.
# ---------------------------------------------------------------------------

invariant abc_extra21.ABC.subclasshook.name:
  description: "abc.ABC.__subclasshook__.__name__ == '__subclasshook__' — classmethod __name__ attribute"
  category: method_names
  kind: python_call_eq
  function: "ABC.__subclasshook__.__name__.__eq__"
  args: ["__subclasshook__"]
  expected: true

# ---------------------------------------------------------------------------
# abc.get_cache_token.__module__ == '_abc' — standalone (extra21 namespace)
#
# get_cache_token is implemented in the C extension _abc, so its __module__
# is '_abc' rather than 'abc'. Length of '_abc' is 4. Re-anchored here as a
# standalone invariant in the extra21 namespace.
# ---------------------------------------------------------------------------

invariant abc_extra21.get_cache_token.module:
  description: "abc.get_cache_token.__module__ == '_abc' — C extension function; module is '_abc' not 'abc'"
  category: module_attrs
  kind: python_call_eq
  function: get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true
