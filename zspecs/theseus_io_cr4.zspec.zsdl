spec: theseus_io_cr4
version: ">=3.9"
backend: python_cleanroom(theseus_io_cr4)
blocks: io

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html"
  notes:
    - "Clean-room extended io utilities. Do NOT import io."
    - "StringIO: in-memory text stream supporting read/write/seek/tell."
    - "BytesIO: in-memory binary stream supporting read/write/seek/tell."
    - "readline: read one line at a time from StringIO."
    - "io4_stringio_readline(): s=StringIO('a\\nb\\n'); s.readline() == 'a\\n'."
    - "io4_bytesio_getvalue(): b=BytesIO(); b.write(b'hi'); b.getvalue() == b'hi'."
    - "io4_stringio_seek(): s=StringIO('hello'); s.read(); s.seek(0); s.read() == 'hello'."
    - "Zero-arg invariant signatures — def io4_stringio_readline(): return hardcoded_result"
    - "StringIO: internal buffer is str; readline reads up to and including next newline."
    - "BytesIO: internal buffer is bytes; write appends; getvalue() returns all written bytes."
    - "seek(0): rewind to beginning of stream."
    - "Export: StringIO, BytesIO, TextIOWrapper, IOBase, RawIOBase, BufferedIOBase, TextIOBase."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_io_cr4.stringio_readline:
  description: "StringIO('a\\nb\\n').readline() == 'a\\n'"
  category: StringIO
  kind: python_call_eq
  function: io4_stringio_readline
  args: []
  expected: "a\n"

invariant theseus_io_cr4.bytesio_getvalue:
  description: "BytesIO().write(b'hi'); getvalue() == b'hi' — returns True"
  category: BytesIO
  kind: python_call_eq
  function: io4_bytesio_getvalue
  args: []
  expected: true

invariant theseus_io_cr4.stringio_seek:
  description: "StringIO seek(0) allows re-reading from start"
  category: StringIO
  kind: python_call_eq
  function: io4_stringio_seek
  args: []
  expected: "hello"
