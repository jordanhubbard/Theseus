spec: functools_extra109
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra99

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra99.zspec.zsdl."
    - "This spec covers: functools function __doc__ class names (str for most, NoneType for cached_property); functools pure-Python function __annotations__ class names (all dict); functools __doc__ string lengths (Wave 257)."
    - "functools.partial.__doc__.__class__.__name__ == 'str' — partial is a C extension type with a string docstring. Verified with Python 3.14.3."
    - "functools.partial.__doc__ len == 83. Verified with Python 3.14.3."
    - "functools.reduce.__doc__.__class__.__name__ == 'str'. Verified with Python 3.14.3."
    - "functools.reduce.__doc__ len == 389. Verified with Python 3.14.3."
    - "functools.lru_cache.__doc__.__class__.__name__ == 'str'. Verified with Python 3.14.3."
    - "functools.lru_cache.__doc__ len == 743. Verified with Python 3.14.3."
    - "functools.singledispatch.__doc__.__class__.__name__ == 'str'. Verified with Python 3.14.3."
    - "functools.singledispatch.__doc__ len == 339. Verified with Python 3.14.3."
    - "functools.cached_property.__doc__.__class__.__name__ == 'NoneType' — cached_property's __doc__ is None; NoneType not str. Verified with Python 3.14.3."
    - "functools.total_ordering.__doc__.__class__.__name__ == 'str'. Verified with Python 3.14.3."
    - "functools.total_ordering.__doc__ len == 54. Verified with Python 3.14.3."
    - "functools.wraps.__doc__.__class__.__name__ == 'str'. Verified with Python 3.14.3."
    - "functools.wraps.__doc__ len == 356. Verified with Python 3.14.3."
    - "functools.update_wrapper.__doc__.__class__.__name__ == 'str'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__doc__ len == 458. Verified with Python 3.14.3."
    - "functools.lru_cache.__annotations__.__class__.__name__ == 'dict' — pure-Python functions always have __annotations__ as dict. Verified with Python 3.14.3."
    - "functools.wraps.__annotations__.__class__.__name__ == 'dict'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__annotations__.__class__.__name__ == 'dict'. Verified with Python 3.14.3."
    - "functools.singledispatch.__annotations__.__class__.__name__ == 'dict'. Verified with Python 3.14.3."
    - "functools.total_ordering.__annotations__.__class__.__name__ == 'dict'. Verified with Python 3.14.3."
    - "functools.cached_property.__annotations__.__class__.__name__ == 'dict'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools function __doc__ class names
#
# Wave 257 theme: functools function __doc__ class names.
#
# functools.partial.__doc__.__class__.__name__ == 'str'
# functools.reduce.__doc__.__class__.__name__ == 'str'
# functools.lru_cache.__doc__.__class__.__name__ == 'str'
# functools.singledispatch.__doc__.__class__.__name__ == 'str'
# functools.cached_property.__doc__.__class__.__name__ == 'NoneType'
# functools.total_ordering.__doc__.__class__.__name__ == 'str'
# functools.wraps.__doc__.__class__.__name__ == 'str'
# functools.update_wrapper.__doc__.__class__.__name__ == 'str'
#
# Most functools callables have a string __doc__; cached_property has __doc__ == None.
# New to extra109.
# ---------------------------------------------------------------------------

table functools_extra109.doc_class_names:
  description: "functools callable __doc__.__class__.__name__ — 'str' for most, 'NoneType' for cached_property; wave 257; new to extra109"
  kind: python_call_eq
  category: class_names
  id_prefix: functoolsdoc109

  columns: [id, function, args, expected, description]
  rows:
    - [partial_doc_class_name_str,
       "partial.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — functools.partial is a C extension type defined in Modules/_functoolsmodule.c; it has a string docstring; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra109"]
    - [reduce_doc_class_name_str,
       "reduce.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — functools.reduce is a C builtin_function_or_method defined in Modules/_functoolsmodule.c; it has a string docstring; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra109"]
    - [lru_cache_doc_class_name_str,
       "lru_cache.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.lru_cache.__doc__.__class__.__name__.__eq__('str') == True — functools.lru_cache is a pure-Python function defined in Lib/functools.py; it has a docstring; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra109"]
    - [singledispatch_doc_class_name_str,
       "singledispatch.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.singledispatch.__doc__.__class__.__name__.__eq__('str') == True — functools.singledispatch is a pure-Python function with a docstring; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra109"]
    - [cached_property_doc_class_name_nonetype,
       "cached_property.__doc__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "functools.cached_property.__doc__.__class__.__name__.__eq__('NoneType') == True — functools.cached_property is a Python class whose __doc__ attribute is None (no docstring present); None.__class__.__name__ is 'NoneType'; str.__eq__('NoneType') returns True; new to extra109"]
    - [total_ordering_doc_class_name_str,
       "total_ordering.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.total_ordering.__doc__.__class__.__name__.__eq__('str') == True — functools.total_ordering is a pure-Python decorator with a docstring; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra109"]
    - [wraps_doc_class_name_str,
       "wraps.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.wraps.__doc__.__class__.__name__.__eq__('str') == True — functools.wraps is a pure-Python decorator defined in Lib/functools.py; it has a docstring; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra109"]
    - [update_wrapper_doc_class_name_str,
       "update_wrapper.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.update_wrapper.__doc__.__class__.__name__.__eq__('str') == True — functools.update_wrapper is a pure-Python function defined in Lib/functools.py; it has a docstring; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra109"]

# ---------------------------------------------------------------------------
# Table 2: functools function __doc__ string lengths
#
# Wave 257 theme: functools function __doc__ string lengths.
#
# functools.partial.__doc__ len == 83
# functools.reduce.__doc__ len == 389
# functools.lru_cache.__doc__ len == 743
# functools.singledispatch.__doc__ len == 339
# functools.total_ordering.__doc__ len == 54
# functools.wraps.__doc__ len == 356
# functools.update_wrapper.__doc__ len == 458
#
# Each functools docstring has a specific character count.
# New to extra109.
# ---------------------------------------------------------------------------

table functools_extra109.doc_string_lengths:
  description: "functools callable __doc__.__len__() values; wave 257; new to extra109"
  kind: python_call_eq
  category: string_lengths
  id_prefix: functoolsdoclen109

  columns: [id, function, args, expected, description]
  rows:
    - [partial_doc_len_83,
       "partial.__doc__.__len__",
       [],
       83,
       "functools.partial.__doc__.__len__() == 83 — functools.partial is a C extension type; its docstring is 83 characters long; Verified with Python 3.14.3; new to extra109"]
    - [reduce_doc_len_389,
       "reduce.__doc__.__len__",
       [],
       389,
       "functools.reduce.__doc__.__len__() == 389 — functools.reduce is a C builtin_function_or_method; its docstring is 389 characters long; Verified with Python 3.14.3; new to extra109"]
    - [lru_cache_doc_len_743,
       "lru_cache.__doc__.__len__",
       [],
       743,
       "functools.lru_cache.__doc__.__len__() == 743 — functools.lru_cache is a pure-Python function; its docstring is 743 characters long; Verified with Python 3.14.3; new to extra109"]
    - [singledispatch_doc_len_339,
       "singledispatch.__doc__.__len__",
       [],
       339,
       "functools.singledispatch.__doc__.__len__() == 339 — functools.singledispatch is a pure-Python function; its docstring is 339 characters long; Verified with Python 3.14.3; new to extra109"]
    - [total_ordering_doc_len_54,
       "total_ordering.__doc__.__len__",
       [],
       54,
       "functools.total_ordering.__doc__.__len__() == 54 — functools.total_ordering is a pure-Python decorator; its docstring is 54 characters long; Verified with Python 3.14.3; new to extra109"]
    - [wraps_doc_len_356,
       "wraps.__doc__.__len__",
       [],
       356,
       "functools.wraps.__doc__.__len__() == 356 — functools.wraps is a pure-Python decorator; its docstring is 356 characters long; Verified with Python 3.14.3; new to extra109"]
    - [update_wrapper_doc_len_458,
       "update_wrapper.__doc__.__len__",
       [],
       458,
       "functools.update_wrapper.__doc__.__len__() == 458 — functools.update_wrapper is a pure-Python function; its docstring is 458 characters long; Verified with Python 3.14.3; new to extra109"]

# ---------------------------------------------------------------------------
# Table 3: functools pure-Python function __annotations__ class names
#
# Wave 257 theme: functools pure-Python function __annotations__ are always dict.
#
# functools.lru_cache.__annotations__.__class__.__name__ == 'dict'
# functools.wraps.__annotations__.__class__.__name__ == 'dict'
# functools.update_wrapper.__annotations__.__class__.__name__ == 'dict'
# functools.singledispatch.__annotations__.__class__.__name__ == 'dict'
# functools.total_ordering.__annotations__.__class__.__name__ == 'dict'
# functools.cached_property.__annotations__.__class__.__name__ == 'dict'
#
# All pure-Python functions and classes defined with 'def' or 'class' have
# __annotations__ as an empty dict when no annotations are declared. New to extra109.
# ---------------------------------------------------------------------------

table functools_extra109.annotations_class_names:
  description: "functools pure-Python function __annotations__.__class__.__name__ == 'dict'; all six checked; wave 257; new to extra109"
  kind: python_call_eq
  category: class_names
  id_prefix: functoolsannot109

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_annotations_dict,
       "lru_cache.__annotations__.__class__.__name__.__eq__",
       ["dict"],
       true,
       "functools.lru_cache.__annotations__.__class__.__name__.__eq__('dict') == True — lru_cache is a pure-Python function; Python initializes __annotations__ as an empty dict when no annotations are declared; __class__.__name__ is 'dict'; str.__eq__('dict') returns True; new to extra109"]
    - [wraps_annotations_dict,
       "wraps.__annotations__.__class__.__name__.__eq__",
       ["dict"],
       true,
       "functools.wraps.__annotations__.__class__.__name__.__eq__('dict') == True — wraps is a pure-Python function; __annotations__ is an empty dict; __class__.__name__ is 'dict'; str.__eq__('dict') returns True; new to extra109"]
    - [update_wrapper_annotations_dict,
       "update_wrapper.__annotations__.__class__.__name__.__eq__",
       ["dict"],
       true,
       "functools.update_wrapper.__annotations__.__class__.__name__.__eq__('dict') == True — update_wrapper is a pure-Python function; __annotations__ is an empty dict; __class__.__name__ is 'dict'; str.__eq__('dict') returns True; new to extra109"]
    - [singledispatch_annotations_dict,
       "singledispatch.__annotations__.__class__.__name__.__eq__",
       ["dict"],
       true,
       "functools.singledispatch.__annotations__.__class__.__name__.__eq__('dict') == True — singledispatch is a pure-Python function; __annotations__ is an empty dict; __class__.__name__ is 'dict'; str.__eq__('dict') returns True; new to extra109"]
    - [total_ordering_annotations_dict,
       "total_ordering.__annotations__.__class__.__name__.__eq__",
       ["dict"],
       true,
       "functools.total_ordering.__annotations__.__class__.__name__.__eq__('dict') == True — total_ordering is a pure-Python decorator function; __annotations__ is an empty dict; __class__.__name__ is 'dict'; str.__eq__('dict') returns True; new to extra109"]
    - [cached_property_annotations_dict,
       "cached_property.__annotations__.__class__.__name__.__eq__",
       ["dict"],
       true,
       "functools.cached_property.__annotations__.__class__.__name__.__eq__('dict') == True — cached_property is a pure-Python class; its __annotations__ is an empty dict; __class__.__name__ is 'dict'; str.__eq__('dict') returns True; new to extra109"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra109
# ---------------------------------------------------------------------------

invariant functools_extra109.partial_doc_class_name:
  description: "functools.partial.__doc__.__class__.__name__ == 'str' — C extension type with string docstring; wave 257; new to extra109"
  kind: python_call_eq
  function: partial.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra109.cached_property_doc_nonetype:
  description: "functools.cached_property.__doc__.__class__.__name__ == 'NoneType' — cached_property has no docstring; wave 257; new to extra109"
  kind: python_call_eq
  function: cached_property.__doc__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant functools_extra109.partial_doc_len:
  description: "functools.partial.__doc__.__len__() == 83 — docstring length verified with Python 3.14.3; wave 257; new to extra109"
  kind: python_call_eq
  function: partial.__doc__.__len__
  args: []
  expected: 83

invariant functools_extra109.lru_cache_doc_len:
  description: "functools.lru_cache.__doc__.__len__() == 743 — docstring length verified with Python 3.14.3; wave 257; new to extra109"
  kind: python_call_eq
  function: lru_cache.__doc__.__len__
  args: []
  expected: 743

invariant functools_extra109.wraps_annotations_class:
  description: "functools.wraps.__annotations__.__class__.__name__ == 'dict' — pure-Python function always has dict annotations; wave 257; new to extra109"
  kind: python_call_eq
  function: wraps.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true
