spec: socket_extra946
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket address family and socket kind enum identities, and module identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra946.module_identity:
  description: "socket module-level identity attributes"
  kind: python_call_eq
  category: module_identity
  id_prefix: sk946mi
  columns: [id, function, args, expected]
  rows:
    - [sk946mi001, socket.__name__.__eq__,       ["socket"], true]
    - [sk946mi002, socket.__spec__.name.__eq__,  ["socket"], true]
    - [sk946mi003, socket.__name__.__class__.__name__.__eq__, ["str"], true]
    - [sk946mi004, socket.__spec__.name.__class__.__name__.__eq__, ["str"], true]
    - [sk946mi005, socket.__package__.__class__.__name__.__eq__, ["str"], true]

table socket_extra946.address_families:
  description: "socket.AF_* enum member class identity"
  kind: python_call_eq
  category: address_families
  id_prefix: sk946af
  columns: [id, function, args, expected]
  rows:
    - [sk946af001, socket.AF_INET.__class__.__name__.__eq__,   ["AddressFamily"], true]
    - [sk946af002, socket.AF_INET6.__class__.__name__.__eq__,  ["AddressFamily"], true]
    - [sk946af003, socket.AF_UNIX.__class__.__name__.__eq__,   ["AddressFamily"], true]
    - [sk946af004, socket.AF_INET.__class__.__module__.__eq__, ["socket"],        true]
    - [sk946af005, socket.AF_INET6.__class__.__module__.__eq__,["socket"],        true]
    - [sk946af006, socket.AF_UNIX.__class__.__module__.__eq__, ["socket"],        true]
    - [sk946af007, socket.AF_INET.__class__.__qualname__.__eq__,["AddressFamily"], true]

table socket_extra946.socket_kinds:
  description: "socket.SOCK_* enum member class identity"
  kind: python_call_eq
  category: socket_kinds
  id_prefix: sk946sk
  columns: [id, function, args, expected]
  rows:
    - [sk946sk001, socket.SOCK_STREAM.__class__.__name__.__eq__,   ["SocketKind"], true]
    - [sk946sk002, socket.SOCK_DGRAM.__class__.__name__.__eq__,    ["SocketKind"], true]
    - [sk946sk003, socket.SOCK_RAW.__class__.__name__.__eq__,      ["SocketKind"], true]
    - [sk946sk004, socket.SOCK_STREAM.__class__.__module__.__eq__, ["socket"],     true]
    - [sk946sk005, socket.SOCK_DGRAM.__class__.__module__.__eq__,  ["socket"],     true]
