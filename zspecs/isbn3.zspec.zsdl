       {"group": "3", "publisher": "16", "article": "148410", "check": "0",
        "source": "978-3-16-148410-0", "prefix": "978",
        "isIsbn13": true, "isIsbn10": false,
        "groupname": "German language",
        "check10": "X", "check13": "0",
        "isbn13": "9783161484100", "isbn13h": "978-3-16-148410-0",
        "isbn10": "316148410X", "isbn10h": "3-16-148410-X",
        "isValid": true}]

