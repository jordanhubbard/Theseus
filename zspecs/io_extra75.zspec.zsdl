spec: io_extra75
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/"
    - "io_extra74.zspec.zsdl — covers open/__class__.__name__=='builtin_function_or_method'; open/__module__.__eq__('io'); open/__doc__.__contains__('mode'); SEEK_SET/SEEK_CUR/SEEK_END __class__.__name__=='int' and __eq__ values; UnsupportedOperation/__class__.__name__=='type'; UnsupportedOperation/__module__.__contains__('io'); UnsupportedOperation/__bases__[0].__name__=='OSError'."
    - "io_extra73.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__.__eq__; FileIO/BytesIO/StringIO/TextIOWrapper __name__.__eq__; IOBase/RawIOBase/BufferedIOBase/TextIOBase __module__.__contains__('io'); IOBase/FileIO/BytesIO/StringIO __qualname__.__eq__."
    - "io_extra72.zspec.zsdl — covers RawIOBase/BufferedIOBase/TextIOBase __bases__[0].__name__.__eq__('IOBase'); FileIO/__bases__[0].__name__.__eq__('RawIOBase'); BufferedReader/__bases__[0].__name__.__eq__('BufferedIOBase'); TextIOWrapper/__bases__[0].__name__.__eq__('TextIOBase'); RawIOBase/BufferedIOBase/TextIOBase __mro__.__len__()==3; FileIO/BufferedReader/TextIOWrapper __mro__.__len__()==4."
  notes:
    - "This spec extends io_extra74.zspec.zsdl."
    - "Theme: io.UnsupportedOperation extended hierarchy — __name__, __mro__.__len__, __bases__.__len__; concrete io class __qualname__ for TextIOWrapper/BufferedReader/BufferedWriter; abstract io class __qualname__ for RawIOBase/BufferedIOBase/TextIOBase; concrete io class __module__.__contains__ for TextIOWrapper/BufferedReader/BufferedWriter/FileIO."
    - "io.UnsupportedOperation.__name__ == 'UnsupportedOperation' — the simple class name. No prior io spec checks UnsupportedOperation.__name__.__eq__('UnsupportedOperation') in ioid75 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.UnsupportedOperation.__mro__.__len__() == 6 — UnsupportedOperation inherits from both OSError and ValueError (multiple inheritance). C3 MRO: [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object] = 6 entries. No prior io spec checks UnsupportedOperation.__mro__.__len__() in ioid75 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.UnsupportedOperation.__bases__.__len__() == 2 — __bases__ is the tuple (OSError, ValueError); UnsupportedOperation uses multiple inheritance from exactly two direct bases. No prior io spec checks UnsupportedOperation.__bases__.__len__() in ioid75 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — top-level class, qualname equals simple name. io_extra73 covered IOBase/FileIO/BytesIO/StringIO __qualname__ but NOT TextIOWrapper, BufferedReader, or BufferedWriter. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.BufferedReader.__qualname__ == 'BufferedReader' — top-level class. Not covered in io_extra73. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.BufferedWriter.__qualname__ == 'BufferedWriter' — top-level class. No prior io spec checks BufferedWriter.__qualname__ in ioid75 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.RawIOBase/__qualname__ == 'RawIOBase'; io.BufferedIOBase/__qualname__ == 'BufferedIOBase'; io.TextIOBase/__qualname__ == 'TextIOBase' — abstract io base classes; top-level so qualname equals simple name. io_extra73 covered only IOBase.__qualname__. Novel anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "TextIOWrapper/BufferedReader/BufferedWriter/FileIO __module__.__contains__('io') — concrete io classes defined in the C extension; __module__ is '_io' or 'io'; both contain 'io'. io_extra73 covered IOBase/RawIOBase/BufferedIOBase/TextIOBase module contains but NOT TextIOWrapper/BufferedReader/BufferedWriter. Novel anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Table row function values containing '[' must be double-quoted per ZSDL rules."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.UnsupportedOperation extended hierarchy:
#   __name__, __mro__.__len__, __bases__.__len__
#
# UnsupportedOperation is defined in the io module and inherits from both
# OSError and ValueError (multiple inheritance):
#   UnsupportedOperation.__name__           == 'UnsupportedOperation'
#   UnsupportedOperation.__mro__.__len__()  == 6
#     (MRO: UnsupportedOperation, OSError, ValueError, Exception,
#      BaseException, object)
#   UnsupportedOperation.__bases__.__len__() == 2  (OSError and ValueError)
#
# io_extra74 covered __class__.__name__=='type', __module__.__contains__('io'),
# and __bases__[0].__name__=='OSError' but NOT __name__, __mro__.__len__, or
# __bases__.__len__. All three are novel in ioid75 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra75.UnsupportedOperation_extended:
  description: "UnsupportedOperation/__name__.__eq__('UnsupportedOperation')==True; UnsupportedOperation/__mro__.__len__()==6; UnsupportedOperation/__bases__.__len__()==2 — io.UnsupportedOperation inherits from both OSError and ValueError; MRO is [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object] with 6 entries; __bases__ is a 2-element tuple; io_extra74 covered class/module/bases[0] but NOT __name__/__mro__/__bases__ lengths; novel hierarchy anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: ioid75unsupported

  columns: [id, function, args, expected]
  rows:
    - [unsupported_name_eq,       UnsupportedOperation.__name__.__eq__,           ["UnsupportedOperation"], true]
    - [unsupported_mro_len_6,     UnsupportedOperation.__mro__.__len__,           [],                       6]
    - [unsupported_bases_len_2,   UnsupportedOperation.__bases__.__len__,         [],                       2]

# ---------------------------------------------------------------------------
# Concrete io classes: __qualname__.__eq__ for TextIOWrapper/BufferedReader/BufferedWriter
#
# io_extra73 covered IOBase/FileIO/BytesIO/StringIO __qualname__ but did NOT
# cover TextIOWrapper, BufferedReader, or BufferedWriter. All three are
# top-level classes so __qualname__ equals __name__:
#   TextIOWrapper.__qualname__  == 'TextIOWrapper'
#   BufferedReader.__qualname__ == 'BufferedReader'
#   BufferedWriter.__qualname__ == 'BufferedWriter'
#   StringIO.__qualname__       == 'StringIO'  (covered in io_extra73)
#   BytesIO.__qualname__        == 'BytesIO'   (covered in io_extra73)
#
# No prior io spec checks TextIOWrapper/BufferedReader/BufferedWriter
# __qualname__.__eq__ in ioid75 namespace. Novel qualname anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra75.concrete_io_qualnames:
  description: "TextIOWrapper/BufferedReader/BufferedWriter __qualname__.__eq__ — all are top-level concrete io classes so __qualname__ equals __name__; io_extra73 covered IOBase/FileIO/BytesIO/StringIO qualnames but NOT TextIOWrapper/BufferedReader/BufferedWriter; novel qualname identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioid75concretequal

  columns: [id, function, args, expected]
  rows:
    - [textiowrapper_qualname,   TextIOWrapper.__qualname__.__eq__,   ["TextIOWrapper"],   true]
    - [bufferedreader_qualname,  BufferedReader.__qualname__.__eq__,  ["BufferedReader"],  true]
    - [bufferedwriter_qualname,  BufferedWriter.__qualname__.__eq__,  ["BufferedWriter"],  true]

# ---------------------------------------------------------------------------
# Abstract io base classes: __qualname__.__eq__ for RawIOBase/BufferedIOBase/TextIOBase
#
# io_extra73 covered only IOBase.__qualname__. The other three abstract base
# classes — RawIOBase, BufferedIOBase, TextIOBase — were not covered in the
# abstract_qualnames table. All three are top-level so __qualname__ == __name__:
#   RawIOBase.__qualname__      == 'RawIOBase'
#   BufferedIOBase.__qualname__ == 'BufferedIOBase'
#   TextIOBase.__qualname__     == 'TextIOBase'
#
# No prior io spec checks these in ioid75 namespace. Novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra75.abstract_io_qualnames:
  description: "RawIOBase/BufferedIOBase/TextIOBase __qualname__.__eq__ — abstract io base classes; all top-level so __qualname__ equals simple name; io_extra73 covered only IOBase.__qualname__ in its abstract_qualnames table; no prior io spec checks RawIOBase/BufferedIOBase/TextIOBase __qualname__.__eq__ in ioid75 namespace; novel qualname identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioid75abstractqual

  columns: [id, function, args, expected]
  rows:
    - [rawiobase_qualname,      RawIOBase.__qualname__.__eq__,       ["RawIOBase"],      true]
    - [bufferediobase_qualname, BufferedIOBase.__qualname__.__eq__,  ["BufferedIOBase"], true]
    - [textiobase_qualname,     TextIOBase.__qualname__.__eq__,      ["TextIOBase"],     true]

# ---------------------------------------------------------------------------
# Concrete io classes: __module__.__contains__('io') for TextIOWrapper/BufferedReader/BufferedWriter/FileIO
#
# io_extra73 covered IOBase/RawIOBase/BufferedIOBase/TextIOBase
# __module__.__contains__('io'). The concrete classes TextIOWrapper,
# BufferedReader, and BufferedWriter were NOT included in that table.
# FileIO was also not included there (only in the concrete_class_names table
# without a __module__ check). All four are defined in the C extension '_io'
# whose module name contains 'io':
#   TextIOWrapper.__module__.__contains__('io')  == True
#   BufferedReader.__module__.__contains__('io') == True
#   BufferedWriter.__module__.__contains__('io') == True
#   FileIO.__module__.__contains__('io')         == True  (was in io_extra73 note but not table)
#
# Wait — io_extra73 note line 30 says FileIO.__module__.__contains__('io')
# is checked in ionames73 namespace. Let me use only the three not in table.
# Actually io_extra73 abstract_module_contains_io table only has 4 abstract rows.
# FileIO __module__ was mentioned in notes as "Novel anchor. Verified" but
# only in a note, not in a table row or invariant. Use all four to be safe.
#
# No prior io spec adds TextIOWrapper/BufferedReader/BufferedWriter/FileIO
# __module__.__contains__('io') as TABLE ROWS in ioid75 namespace.
# Novel module identity anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra75.concrete_io_modules:
  description: "TextIOWrapper/BufferedReader/BufferedWriter/FileIO __module__.__contains__('io')==True — concrete io classes defined in C extension '_io'; __module__ is '_io'; '_io'.__contains__('io') is True; io_extra73 abstract_module_contains_io table covered only the four abstract base classes; no prior io spec checks TextIOWrapper/BufferedReader/BufferedWriter __module__.__contains__('io') as table rows in ioid75 namespace; novel module identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioid75concretemod

  columns: [id, function, args, expected]
  rows:
    - [textiowrapper_module_io,   TextIOWrapper.__module__.__contains__,   ["io"], true]
    - [bufferedreader_module_io,  BufferedReader.__module__.__contains__,  ["io"], true]
    - [bufferedwriter_module_io,  BufferedWriter.__module__.__contains__,  ["io"], true]
    - [fileio_module_io,          FileIO.__module__.__contains__,          ["io"], true]

invariant io_extra75.UnsupportedOperation_name:
  description: "UnsupportedOperation.__name__.__eq__('UnsupportedOperation') == True — io.UnsupportedOperation is an exception class; its simple class name is 'UnsupportedOperation' (19 chars); io_extra74 covered __class__.__name__=='type' and __module__/__bases__[0] but not __name__.__eq__; no prior io spec checks UnsupportedOperation.__name__.__eq__('UnsupportedOperation') in ioid75 namespace; novel class name identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: exception_hierarchy
  kind: python_call_eq
  function: UnsupportedOperation.__name__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

invariant io_extra75.UnsupportedOperation_mro_6:
  description: "UnsupportedOperation.__mro__.__len__() == 6 — io.UnsupportedOperation uses multiple inheritance from OSError and ValueError; C3 MRO is [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object] with 6 entries; no prior io spec checks UnsupportedOperation.__mro__.__len__() in ioid75 namespace; novel MRO length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: exception_hierarchy
  kind: python_call_eq
  function: UnsupportedOperation.__mro__.__len__
  args: []
  expected: 6

invariant io_extra75.UnsupportedOperation_bases_len_2:
  description: "UnsupportedOperation.__bases__.__len__() == 2 — io.UnsupportedOperation inherits from both OSError and ValueError; __bases__ is the 2-element tuple (OSError, ValueError); no prior io spec checks UnsupportedOperation.__bases__.__len__() in ioid75 namespace; novel multiple-inheritance bases count anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: exception_hierarchy
  kind: python_call_eq
  function: UnsupportedOperation.__bases__.__len__
  args: []
  expected: 2

invariant io_extra75.BufferedReader_qualname:
  description: "BufferedReader.__qualname__.__eq__('BufferedReader') == True — io.BufferedReader is a top-level concrete buffered reader class; __qualname__ equals __name__ for non-nested classes; io_extra73 covered IOBase/FileIO/BytesIO/StringIO but not BufferedReader; no prior io spec checks BufferedReader.__qualname__.__eq__('BufferedReader') in ioid75 namespace; novel qualname identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__qualname__.__eq__
  args: ["BufferedReader"]
  expected: true

invariant io_extra75.TextIOWrapper_qualname:
  description: "TextIOWrapper.__qualname__.__eq__('TextIOWrapper') == True — io.TextIOWrapper is a top-level concrete text I/O wrapper class; __qualname__ equals __name__ for non-nested classes; io_extra73 covered IOBase/FileIO/BytesIO/StringIO but not TextIOWrapper; no prior io spec checks TextIOWrapper.__qualname__.__eq__('TextIOWrapper') in ioid75 namespace; novel qualname identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__qualname__.__eq__
  args: ["TextIOWrapper"]
  expected: true
