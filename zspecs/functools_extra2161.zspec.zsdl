spec: functools_extra2161
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
    - "functools_extra1936.zspec.zsdl — covers __get__/__set__/__delete__/__set_name__ dict-presence, qualnames, class names"
  notes:
    - "Wave 2161 (_extra2161): descriptor protocol dict-presence theme — fget/fset/fdel (property attrs), __objclass__ and __func__ (method wrapper attrs), plus __get__/__set__/__delete__/__set_name__ extended checks."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "functools.partial.__get__ is a wrapper_descriptor; it carries __objclass__ == functools.partial."
    - "functools.cached_property and functools.partialmethod define __get__ as plain Python functions, so they do NOT carry __objclass__."
    - "functools.cached_property.__class_getitem__ and functools.partialmethod.__class_getitem__ are classmethod objects; classmethod carries __func__ but not fget/fset/fdel or __objclass__."
    - "None of functools.partial, functools.partialmethod, or functools.cached_property define fget, fset, fdel, or __func__ in their own __dict__."
    - "functools.cached_property defines __get__ and __set_name__ but NOT __set__ or __delete__."
    - "functools.partial.__dict__.__contains__('__objclass__') is False — __objclass__ lives on the wrapper_descriptor object, not in the class __dict__ as a key."
  created_at: "2026-04-12"
error_model: python_exceptions

table functools_extra2161.fget_fset_fdel_presence:
  description: "functools types fget/fset/fdel dict-presence checks — none define these property attrs"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2161
  columns: [id, function, args, expected]
  rows:
    - ["ft2161001", "functools.partial.__dict__.__contains__",           ["fget"],  false]
    - ["ft2161002", "functools.partial.__dict__.__contains__",           ["fset"],  false]
    - ["ft2161003", "functools.partial.__dict__.__contains__",           ["fdel"],  false]
    - ["ft2161004", "functools.partialmethod.__dict__.__contains__",     ["fget"],  false]
    - ["ft2161005", "functools.partialmethod.__dict__.__contains__",     ["fset"],  false]
    - ["ft2161006", "functools.partialmethod.__dict__.__contains__",     ["fdel"],  false]
    - ["ft2161007", "functools.cached_property.__dict__.__contains__",   ["fget"],  false]
    - ["ft2161008", "functools.cached_property.__dict__.__contains__",   ["fset"],  false]
    - ["ft2161009", "functools.cached_property.__dict__.__contains__",   ["fdel"],  false]

table functools_extra2161.objclass_func_presence:
  description: "functools types __objclass__ and __func__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2161
  columns: [id, function, args, expected]
  rows:
    - ["ft2161010", "functools.partial.__dict__.__contains__",           ["__objclass__"], false]
    - ["ft2161011", "functools.partial.__dict__.__contains__",           ["__func__"],     false]
    - ["ft2161012", "functools.partialmethod.__dict__.__contains__",     ["__objclass__"], false]
    - ["ft2161013", "functools.partialmethod.__dict__.__contains__",     ["__func__"],     false]
    - ["ft2161014", "functools.cached_property.__dict__.__contains__",   ["__objclass__"], false]
    - ["ft2161015", "functools.cached_property.__dict__.__contains__",   ["__func__"],     false]

table functools_extra2161.descriptor_presence_recap:
  description: "functools types __get__/__set__/__delete__/__set_name__ dict-presence recap for 2161 theme"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2161
  columns: [id, function, args, expected]
  rows:
    - ["ft2161016", "functools.cached_property.__dict__.__contains__",   ["__get__"],      true]
    - ["ft2161017", "functools.cached_property.__dict__.__contains__",   ["__set__"],      false]
    - ["ft2161018", "functools.cached_property.__dict__.__contains__",   ["__delete__"],   false]
    - ["ft2161019", "functools.cached_property.__dict__.__contains__",   ["__set_name__"], true]
    - ["ft2161020", "functools.partialmethod.__dict__.__contains__",     ["__get__"],      true]
    - ["ft2161021", "functools.partialmethod.__dict__.__contains__",     ["__set_name__"], false]
    - ["ft2161022", "functools.partial.__dict__.__contains__",           ["__get__"],      true]
    - ["ft2161023", "functools.partial.__dict__.__contains__",           ["__set_name__"], false]

table functools_extra2161.partial_get_objclass:
  description: "functools.partial.__get__ is a wrapper_descriptor carrying __objclass__"
  kind: python_call_eq
  category: objclass
  id_prefix: ft2161
  columns: [id, function, args, expected]
  rows:
    - ["ft2161024", "functools.partial.__get__.__objclass__.__name__.__eq__",   ["partial"],   true]
    - ["ft2161025", "functools.partial.__get__.__class__.__name__.__eq__",      ["wrapper_descriptor"], true]
    - ["ft2161026", "functools.partial.__reduce__.__objclass__.__name__.__eq__", ["partial"],  true]
    - ["ft2161027", "functools.partial.__call__.__objclass__.__name__.__eq__",  ["partial"],   true]

table functools_extra2161.classmethod_func_presence:
  description: "functools classmethod objects carry __func__ (not fget/fset/fdel or __objclass__)"
  kind: python_call_eq
  category: func_attr
  id_prefix: ft2161
  columns: [id, function, args, expected]
  rows:
    - ["ft2161028", "functools.cached_property.__class_getitem__.__func__.__class__.__name__.__eq__", ["function"], true]
    - ["ft2161029", "functools.partialmethod.__class_getitem__.__func__.__class__.__name__.__eq__",   ["function"], true]
    - ["ft2161030", "functools.cached_property.__class_getitem__.__class__.__name__.__eq__",          ["classmethod"], true]
    - ["ft2161031", "functools.partialmethod.__class_getitem__.__class__.__name__.__eq__",            ["classmethod"], true]

table functools_extra2161.partial_fget_fset_fdel_false:
  description: "Additional fget/fset/fdel checks on partial C-level attrs and lru_cache"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2161
  columns: [id, function, args, expected]
  rows:
    - ["ft2161032", "functools.partial.func.__class__.__name__.__eq__",          ["member_descriptor"], true]
    - ["ft2161033", "functools.partial.args.__class__.__name__.__eq__",          ["member_descriptor"], true]
    - ["ft2161034", "functools.partial.keywords.__class__.__name__.__eq__",      ["member_descriptor"], true]
    - ["ft2161035", "functools.partial.__module__.__eq__",                       ["functools"],         true]
    - ["ft2161036", "functools.partialmethod.__module__.__eq__",                 ["functools"],         true]
    - ["ft2161037", "functools.cached_property.__module__.__eq__",               ["functools"],         true]
