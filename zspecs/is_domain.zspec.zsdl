spec: is_domain
version: ">=0.0.1"
backend: node(is-domain)

docs: https://www.npmjs.com/package/is-domain

provenance:
  derived_from:
    - "is-domain README — https://www.npmjs.com/package/is-domain"
    - "Test vectors verified with is-domain via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-domain source"
  notes:
    - "is-domain is an npm package. Install: npm install is-domain"
    - "Returns true if the string looks like a valid domain name."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_domain.check:
  kind: node_module_call_eq
  function: ~
  category: validation
  id_prefix: isdom

  columns: [id, args, expected]
  rows:
    - [valid,   ["example.com"],    true]
    - [invalid, ["not a domain"],   false]
    - [sub,     ["sub.domain.io"],  true]
