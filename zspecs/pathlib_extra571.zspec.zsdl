spec: pathlib_extra571
version: ">=3.9"
backend: python_module(pathlib)
docs: "Cover pathlib class identity and method qualnames"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib class hierarchy and method documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Checks that pathlib path classes are proper types and that method qualnames match expected dotted forms"
  created_at: "2026-04-12T00:00:00Z"

table pathlib_extra571.class_name_identity:
  description: "Verify that pathlib path classes have __class__.__name__ == 'type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: PLEX571CN
  columns: [id, function, args, expected]
  rows:
    - [PLEX571CN001, pathlib.Path.__class__.__name__.__eq__, ["type"], true]
    - [PLEX571CN002, pathlib.PurePath.__class__.__name__.__eq__, ["type"], true]
    - [PLEX571CN003, pathlib.PosixPath.__class__.__name__.__eq__, ["type"], true]
    - [PLEX571CN004, pathlib.WindowsPath.__class__.__name__.__eq__, ["type"], true]
    - [PLEX571CN005, pathlib.PurePosixPath.__class__.__name__.__eq__, ["type"], true]
    - [PLEX571CN006, pathlib.PureWindowsPath.__class__.__name__.__eq__, ["type"], true]
table pathlib_extra571.method_qualname_identity:
  description: "Verify that pathlib.Path methods have correct __qualname__ values"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: PLEX571QN
  columns: [id, function, args, expected]
  rows:
    - [PLEX571QN001, pathlib.Path.__init__.__qualname__.__eq__, ["Path.__init__"], true]
    - [PLEX571QN002, pathlib.Path.open.__qualname__.__eq__, ["Path.open"], true]
    - [PLEX571QN003, pathlib.Path.read_text.__qualname__.__eq__, ["Path.read_text"], true]
    - [PLEX571QN004, pathlib.Path.write_text.__qualname__.__eq__, ["Path.write_text"], true]
    - [PLEX571QN005, pathlib.Path.mkdir.__qualname__.__eq__, ["Path.mkdir"], true]
    - [PLEX571QN006, pathlib.Path.exists.__qualname__.__eq__, ["Path.exists"], true]
    - [PLEX571QN007, pathlib.Path.is_file.__qualname__.__eq__, ["Path.is_file"], true]
    - [PLEX571QN008, pathlib.Path.is_dir.__qualname__.__eq__, ["Path.is_dir"], true]