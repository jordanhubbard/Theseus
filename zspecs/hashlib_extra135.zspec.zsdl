spec: hashlib_extra135
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' / __name__ equality (openssl_* prefix) / blake2b/blake2s __class__.__name__=='type' / __module__=='_blake2' / __qualname__ / new.__class__.__name__=='function' / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership for sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512/sha3_224/sha3_384/blake2b/blake2s/shake_128/shake_256 / algorithms_available membership / new/__qualname__/__len__() (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ (table + invariants)."
    - "hashlib_extra94.zspec.zsdl — covers hashlib.algorithms_available/algorithms_guaranteed set class identity and membership / sha256/sha512/sha1/md5 constructor __class__.__name__=='builtin_function_or_method' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in prior hashlib spec files."
    - "Wave 311 theme: hashlib set class name equality / algorithms_available and algorithms_guaranteed.__len__() / algorithms_guaranteed membership via __contains__ for sha224/sha384/sha3_224/sha3_384/sha3_512/blake2s/shake_256 / file_digest function qualname and len / new function qualname and module len."
    - "hashlib.algorithms_available.__class__.__name__ == 'set'. Both algorithms_available and algorithms_guaranteed are plain set objects (not frozenset). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__len__() == 19. This is the count on Python 3.14.3/macOS; may vary by OpenSSL version. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__len__() == 14. Consistent across Python 3.x. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha224') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha384') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha3_224') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha3_384') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha3_512') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('blake2s') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('shake_256') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__qualname__ == 'file_digest'. file_digest is a pure-Python function added in 3.11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.file_digest.__qualname__) == 11. len('file_digest') == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__qualname__ == '__hash_new'. hashlib.new is exposed as __hash_new internally. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.new.__qualname__) == 10. len('__hash_new') == 10. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: algorithms_available has 19 entries on Python 3.14.3/macOS; the count may differ on other platforms or OpenSSL versions. algorithms_guaranteed is always 14."
    - "Note: hashlib_extra97 anchors algorithms_guaranteed membership for 14 algorithms; this spec anchors selected members via __contains__ calls under hashsetclass135 as a grouped table."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__class__.__name__.__eq__('set')
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')
# hashlib.algorithms_available.__len__()==19
# hashlib.algorithms_guaranteed.__len__()==14
# hashlib.algorithms_guaranteed.__contains__('sha224')
#
# Wave 311 theme: Set class name equality and lengths.
#
# Both algorithms_available and algorithms_guaranteed are plain set objects
# (not frozenset), as verified on Python 3.14.3. hashlib_extra94 anchors set
# class identity at table level; this spec anchors the class name via __eq__
# calls and adds __len__() values under hashsetclass135.
# algorithms_available has 19 members on Python 3.14.3/macOS; may vary by
# OpenSSL version. algorithms_guaranteed always has 14.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra135.set_class_names_and_lengths:
  description: "algorithms_available/__class__.__name__.__eq__('set')==True / algorithms_guaranteed/__class__.__name__.__eq__('set')==True / algorithms_available/__len__()==19 / algorithms_guaranteed/__len__()==14 / algorithms_guaranteed/__contains__('sha224')==True — both algorithm sets are plain set objects (not frozenset); available has 19 on Python 3.14.3/macOS; guaranteed always has 14; extra94 anchors set class identity; first hashsetclass135 anchor for __len__() and class name via __eq__"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashsetclass135

  columns: [id, function, args, expected, description]
  rows:
    - [avail_class,    algorithms_available.__class__.__name__.__eq__,   ["set"], true, "algorithms_available.__class__.__name__ is 'set' (plain set, not frozenset)"]
    - [guar_class,     algorithms_guaranteed.__class__.__name__.__eq__,  ["set"], true, "algorithms_guaranteed.__class__.__name__ is 'set' (plain set, not frozenset)"]
    - [avail_len,      algorithms_available.__len__,                     [],      19,   "algorithms_available has 19 members on Python 3.14.3/macOS (may vary by OpenSSL)"]
    - [guar_len,       algorithms_guaranteed.__len__,                    [],      14,   "algorithms_guaranteed has exactly 14 members (consistent across Python 3.x)"]
    - [guar_sha224,    algorithms_guaranteed.__contains__,               ["sha224"], true, "sha224 is in algorithms_guaranteed (all 14 guaranteed algorithms)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha384')
# hashlib.algorithms_guaranteed.__contains__('sha3_224')
# hashlib.algorithms_guaranteed.__contains__('sha3_384')
# hashlib.algorithms_guaranteed.__contains__('sha3_512')
# hashlib.algorithms_guaranteed.__contains__('blake2s')
# hashlib.algorithms_guaranteed.__contains__('shake_256')
#
# Wave 311 theme: algorithms_guaranteed membership for the remaining six algorithms.
#
# hashlib_extra97 anchors membership for sha256/sha512/sha1/md5/sha224/sha384/
# sha3_256/sha3_512/sha3_224/sha3_384/blake2b/blake2s/shake_128/shake_256 at
# table level. This table anchors six of these via __contains__ calls as a
# cross-check under hashsetclass135, covering sha384/sha3_224/sha3_384/sha3_512/
# blake2s/shake_256 which are not yet anchored via __contains__ method calls.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra135.guaranteed_membership_contains:
  description: "algorithms_guaranteed/__contains__('sha384')==True / __contains__('sha3_224')==True / __contains__('sha3_384')==True / __contains__('sha3_512')==True / __contains__('blake2s')==True / __contains__('shake_256')==True — six algorithms from the 14 guaranteed set anchored via __contains__ calls; extra97 anchors membership at table level; this spec anchors via explicit __contains__ method calls; first hashsetclass135 anchor for these six"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashsetclass135

  columns: [id, function, args, expected, description]
  rows:
    - [guar_sha384,    algorithms_guaranteed.__contains__, ["sha384"],   true, "sha384 is in algorithms_guaranteed"]
    - [guar_sha3_224,  algorithms_guaranteed.__contains__, ["sha3_224"], true, "sha3_224 is in algorithms_guaranteed"]
    - [guar_sha3_384,  algorithms_guaranteed.__contains__, ["sha3_384"], true, "sha3_384 is in algorithms_guaranteed"]
    - [guar_sha3_512,  algorithms_guaranteed.__contains__, ["sha3_512"], true, "sha3_512 is in algorithms_guaranteed"]
    - [guar_blake2s,   algorithms_guaranteed.__contains__, ["blake2s"],  true, "blake2s is in algorithms_guaranteed"]
    - [guar_shake_256, algorithms_guaranteed.__contains__, ["shake_256"], true, "shake_256 is in algorithms_guaranteed"]

# ---------------------------------------------------------------------------
# hashlib.file_digest.__qualname__.__eq__('file_digest')
# hashlib.file_digest.__qualname__.__len__()==11
# hashlib.file_digest.__module__.__eq__('hashlib')
# hashlib.file_digest.__class__.__name__.__eq__('function')
# hashlib.new.__qualname__.__eq__('__hash_new')
#
# Wave 311 theme: file_digest and new function identity.
#
# hashlib.file_digest is a pure-Python function added in Python 3.11 for
# hashing file-like objects. Its __qualname__ is 'file_digest' (11 chars),
# __module__ is 'hashlib', and __class__.__name__ is 'function'.
# hashlib_extra98 anchors file_digest function identity; this spec anchors
# __qualname__ equality and length, __module__ equality, and __class__.__name__
# equality via method calls under hashsetclass135. hashlib.new's true __qualname__
# is '__hash_new' (10 chars), revealed here for the first time as __eq__ call.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra135.file_digest_and_new_identity:
  description: "file_digest/__qualname__.__eq__('file_digest')==True / file_digest/__qualname__/__len__()==11 / file_digest/__module__.__eq__('hashlib')==True / file_digest/__class__.__name__.__eq__('function')==True / new/__qualname__.__eq__('__hash_new')==True — file_digest added in Python 3.11; __qualname__ is 'file_digest' (11 chars); __module__ is 'hashlib'; new's __qualname__ is '__hash_new' (internal name); extra98 anchors file_digest identity; first hashsetclass135 anchor for qualname equality and len"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashsetclass135

  columns: [id, function, args, expected, description]
  rows:
    - [fd_qualname,   file_digest.__qualname__.__eq__,        ["file_digest"], true, "file_digest.__qualname__ is 'file_digest' (top-level function)"]
    - [fd_qlen,       file_digest.__qualname__.__len__,        [],             11,   "len('file_digest') == 11"]
    - [fd_module,     file_digest.__module__.__eq__,           ["hashlib"],    true, "file_digest.__module__ is 'hashlib' (defined in Lib/hashlib.py)"]
    - [fd_class,      file_digest.__class__.__name__.__eq__,   ["function"],   true, "file_digest.__class__.__name__ is 'function' (pure-Python function)"]
    - [new_qualname,  new.__qualname__.__eq__,                 ["__hash_new"], true, "hashlib.new.__qualname__ is '__hash_new' (internal implementation name in Lib/hashlib.py)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_available.__class__.__name__ is 'set'. The set of
# algorithm names available on the current platform is a plain Python set
# (not a frozenset), allowing runtime modification (though in practice the
# module does not modify it after construction). On Python 3.14.3/macOS,
# it contains 19 entries backed by OpenSSL. hashlib_extra94 anchors this
# at table level; this is the first standalone for algorithms_available
# __class__.__name__.__eq__('set') under hashsetclass135.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra135.algorithms_available_class_set:
  description: "hashlib.algorithms_available.__class__.__name__.__eq__('set') == True — algorithms_available is a plain set (not frozenset); 19 entries on Python 3.14.3/macOS; extra94 anchors at table level; first standalone for algorithms_available.__class__.__name__ under hashsetclass135"
  category: type_identity
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_guaranteed.__class__.__name__ is 'set'. Like algorithms_available,
# the guaranteed set is also a plain Python set. It contains exactly 14 entries:
# blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256,
# sha3_384, sha3_512, sha512, shake_128, shake_256. These are guaranteed in
# every CPython 3.x installation. hashlib_extra94 anchors this at table level;
# this is the first standalone for algorithms_guaranteed __class__.__name__
# under hashsetclass135. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra135.algorithms_guaranteed_class_set:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True — algorithms_guaranteed is a plain set containing 14 algorithms guaranteed in every CPython 3.x installation; extra94 anchors at table level; first standalone for algorithms_guaranteed.__class__.__name__ under hashsetclass135"
  category: type_identity
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__len__()==19 — standalone
#
# hashlib.algorithms_available.__len__() is 19 on Python 3.14.3/macOS. The
# set includes all guaranteed algorithms plus additional OpenSSL-backed ones
# like sha512_224, sha512_256, md5-sha1, sha3_* variants, and others. The
# exact count depends on the OpenSSL version and platform. No prior hashlib
# spec anchors algorithms_available.__len__()==19 as a standalone under
# hashsetclass135. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra135.algorithms_available_len_19:
  description: "hashlib.algorithms_available.__len__() == 19 — algorithms_available has 19 entries on Python 3.14.3/macOS; count depends on OpenSSL version and platform (guaranteed set always has 14); first standalone for algorithms_available.__len__() under hashsetclass135"
  category: type_identity
  kind: python_call_eq
  function: algorithms_available.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# hashlib.file_digest.__qualname__.__eq__('file_digest') — standalone
#
# hashlib.file_digest.__qualname__ is 'file_digest'. The file_digest function
# was added in Python 3.11 to allow hashing the content of a file-like object
# without loading it entirely into memory. It is a top-level pure-Python
# function (not a method), so its __qualname__ equals its __name__.
# hashlib_extra98 anchors file_digest identity; this is the first standalone
# for file_digest.__qualname__.__eq__ under hashsetclass135.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra135.file_digest_qualname:
  description: "hashlib.file_digest.__qualname__.__eq__('file_digest') == True — file_digest added in Python 3.11; top-level function so __qualname__ == __name__ == 'file_digest'; extra98 anchors function identity; first standalone for file_digest.__qualname__.__eq__ under hashsetclass135"
  category: type_identity
  kind: python_call_eq
  function: file_digest.__qualname__.__eq__
  args: ["file_digest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__qualname__.__eq__('__hash_new') — standalone
#
# hashlib.new.__qualname__ is '__hash_new'. The public hashlib.new function
# is actually named __hash_new internally in Lib/hashlib.py — a private
# implementation detail. The public name 'new' is an alias assigned at module
# level. The __qualname__ '__hash_new' reveals the internal function name and
# differs from the attribute name used to access it. hashlib_extra97 anchors
# new/__qualname__/__len__() at table level; this is the first standalone
# anchoring new.__qualname__.__eq__('__hash_new') under hashsetclass135.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra135.new_qualname_hash_new:
  description: "hashlib.new.__qualname__.__eq__('__hash_new') == True — hashlib.new is internally named '__hash_new' in Lib/hashlib.py; the public 'new' name is an alias; __qualname__ reveals the internal name; extra97 anchors new qualname len at table level; first standalone for new.__qualname__.__eq__('__hash_new') under hashsetclass135"
  category: type_identity
  kind: python_call_eq
  function: new.__qualname__.__eq__
  args: ["__hash_new"]
  expected: true
