spec: iconv_lite
version: ">=0.6.0"
backend: node(iconv-lite)

docs: https://github.com/ashtuchkin/iconv-lite#readme

provenance:
  derived_from:
    - "iconv-lite README — https://github.com/ashtuchkin/iconv-lite#readme"
    - "Test vectors verified with iconv-lite@0.7.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "iconv-lite source: lib/index.js"
  notes:
    - "iconv-lite exports an object with encode(), decode(), and encodingExists() methods."
    - "encode(str, encoding) returns a Buffer."
    - "JSON.stringify(Buffer) produces {type:'Buffer',data:[...]} format."
    - "decode(buffer, encoding) returns a string."
    - "encodingExists(encoding) returns boolean."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "encode returns Buffer; decode returns string; encodingExists returns boolean. No errors for valid inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table iconv_lite.encode:
  kind: node_module_call_eq
  function: encode
  category: encode
  id_prefix: iconv_enc

  columns: [id, args, expected]
  rows:
    - [utf8_hello,  ["hello", "utf8"],  {"type": "Buffer", "data": [104, 101, 108, 108, 111]}]

table iconv_lite.encodingExists:
  kind: node_module_call_eq
  function: encodingExists
  category: encodingExists
  id_prefix: iconv_enc_exists

  columns: [id, args, expected]
  rows:
    - [utf8_exists,    ["utf8"],     true]
    - [latin1_exists,  ["latin1"],   true]
    - [bogus,          ["bogus123"], false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:13:34Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
