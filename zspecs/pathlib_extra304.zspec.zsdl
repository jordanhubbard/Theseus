spec: pathlib_extra304
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All pathlib classes report __module__ == 'pathlib'."
    - "PurePath.__bases__[0].__name__ == 'object' — PurePath is the root of the pathlib hierarchy."
    - "Path.__bases__[0].__name__ == 'PurePath' — Path adds concrete filesystem access to PurePath."
    - "PosixPath.__bases__[0].__name__ == 'Path' — PosixPath is the POSIX-specific concrete path."
    - "PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath is the POSIX-specific pure path."
    - "PureWindowsPath.__bases__[0].__name__ == 'PurePath' — PureWindowsPath is the Windows-specific pure path."
    - "WindowsPath.__bases__: [Path, PureWindowsPath] — multiple inheritance; __bases__[0].__name__ == 'Path'."
    - "pathlib has no __version__ attribute — verified with Python 3.14.4."
    - "All class identity values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks — all major pathlib classes
# ---------------------------------------------------------------------------

table pathlib_extra304.class_names:
  description: "__name__ for pathlib classes — each class's __name__ matches its declared name"
  kind: python_call_eq
  category: class_names

  columns: [id, function, args, expected]
  rows:
    - [PurePath,        PurePath.__name__.__eq__,        ["PurePath"],        true]
    - [PurePosixPath,   PurePosixPath.__name__.__eq__,   ["PurePosixPath"],   true]
    - [PureWindowsPath, PureWindowsPath.__name__.__eq__,  ["PureWindowsPath"],  true]
    - [Path,            Path.__name__.__eq__,            ["Path"],            true]
    - [PosixPath,       PosixPath.__name__.__eq__,       ["PosixPath"],       true]
    - [WindowsPath,     WindowsPath.__name__.__eq__,     ["WindowsPath"],     true]

# ---------------------------------------------------------------------------
# __module__ checks — all pathlib classes report 'pathlib'
# ---------------------------------------------------------------------------

table pathlib_extra304.class_modules:
  description: "__module__ for pathlib classes — all report 'pathlib'"
  kind: python_call_eq
  category: class_modules

  columns: [id, function, args, expected]
  rows:
    - [PurePath,        PurePath.__module__.__eq__,        ["pathlib"], true]
    - [PurePosixPath,   PurePosixPath.__module__.__eq__,   ["pathlib"], true]
    - [PureWindowsPath, PureWindowsPath.__module__.__eq__,  ["pathlib"], true]
    - [Path,            Path.__module__.__eq__,            ["pathlib"], true]
    - [PosixPath,       PosixPath.__module__.__eq__,       ["pathlib"], true]
    - [WindowsPath,     WindowsPath.__module__.__eq__,     ["pathlib"], true]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ checks — direct base class identity
# ---------------------------------------------------------------------------

invariant pathlib_extra304.PurePath.base0_name:
  description: "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath is the root of the pathlib class hierarchy"
  category: base_classes
  kind: python_call_eq
  function: PurePath.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant pathlib_extra304.PurePosixPath.base0_name:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath is the POSIX pure-path subclass"
  category: base_classes
  kind: python_call_eq
  function: PurePosixPath.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["PurePath"]
  expected: true

invariant pathlib_extra304.PureWindowsPath.base0_name:
  description: "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — PureWindowsPath is the Windows pure-path subclass"
  category: base_classes
  kind: python_call_eq
  function: PureWindowsPath.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["PurePath"]
  expected: true

invariant pathlib_extra304.Path.base0_name:
  description: "pathlib.Path.__bases__[0].__name__ == 'PurePath' — Path adds concrete filesystem access to PurePath"
  category: base_classes
  kind: python_call_eq
  function: Path.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["PurePath"]
  expected: true

invariant pathlib_extra304.PosixPath.base0_name:
  description: "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — PosixPath is the POSIX-specific concrete path"
  category: base_classes
  kind: python_call_eq
  function: PosixPath.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Path"]
  expected: true

invariant pathlib_extra304.WindowsPath.base0_name:
  description: "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' — WindowsPath uses multiple inheritance; first base is Path"
  category: base_classes
  kind: python_call_eq
  function: WindowsPath.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Path"]
  expected: true
