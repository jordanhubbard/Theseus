spec: asyncio_extra165
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-stream.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-stream.html — Python asyncio streams documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/streams.py"
  notes:
    - "This spec covers: asyncio.StreamWriter method qualnames and class name identity. asyncio.StreamWriter.__name__=='StreamWriter' (len=12: 'Stream'=6+'Writer'=6=12); asyncio.StreamWriter.write.__qualname__=='StreamWriter.write' (len=18: 'StreamWriter'=12+'.'=1+'write'=5=18); asyncio.StreamWriter.drain.__qualname__=='StreamWriter.drain' (len=18: 'StreamWriter'=12+'.'=1+'drain'=5=18); asyncio.StreamWriter.close.__qualname__=='StreamWriter.close' (len=18: 'StreamWriter'=12+'.'=1+'close'=5=18); asyncio.StreamWriter.wait_closed.__qualname__=='StreamWriter.wait_closed' (len=24: 'StreamWriter'=12+'.'=1+'wait_closed'=11=24); KEY FINDING: write, drain, close all share the same qualname length of 18 because 'write'=5=='drain'=5=='close'=5 (all 5-char method names); wait_closed(24) is the longest qualname because 'wait_closed'=11='wait'=4+'_'=1+'closed'=6=11; qualname length ordering: write(18)==drain(18)==close(18) < wait_closed(24). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.StreamWriter.__name__=='StreamWriter' (len=12: 'Stream'=6+'Writer'=6=12) — StreamWriter is the asyncio write-side stream class; it is always used in conjunction with StreamReader (established in extra164); StreamWriter.write(data) is a non-blocking method that buffers data for writing; StreamWriter.drain() is a coroutine that waits until the write buffer is flushed to the transport; StreamWriter.close() closes the stream; StreamWriter.wait_closed() is a coroutine that waits until the stream is closed; the four methods form the complete write lifecycle: write -> drain -> close -> wait_closed; StreamWriter.__module__=='asyncio.streams' (len=15: 'asyncio'=7+'.'=1+'streams'=7=15; same module as StreamReader established in extra164). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "StreamWriter method name lengths: 'write'=5=='drain'=5=='close'=5 (all three share the same length 5); 'wait_closed'=11='wait'=4+'_'=1+'closed'=6=11; qualname prefix 'StreamWriter.'=13 (12+1=13) is constant; write(5+13=18) == drain(5+13=18) == close(5+13=18); wait_closed(11+13=24); compare: StreamReader.read qualname=17 (extra164: 'read'=4; 'StreamReader.'=13; 13+4=17) vs StreamWriter.write qualname=18 (write=5; 13+5=18); StreamWriter method qualnames are 1 char longer than StreamReader.read qualname because 'write'=5 > 'read'=4 by 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.StreamWriter.__name__ identity — extra165
#
# asyncio.StreamWriter.__name__.__eq__('StreamWriter')  == True
# asyncio.StreamWriter.__name__.__len__()               == 12
# asyncio.StreamWriter.__module__.__eq__('asyncio.streams') == True
# asyncio.StreamWriter.__module__.__len__()             == 15
# ---------------------------------------------------------------------------

table asyncio_extra165.asyncio_stream_writer_identity:
  description: "asyncio.StreamWriter class name identity checks in asynciosw165 namespace — asyncio.StreamWriter.__name__=='StreamWriter' (len=12: 'Stream'=6+'Writer'=6=12; StreamWriter is the asyncio coroutine-based stream writer class; it is paired with StreamReader and returned as the second element of the tuple from asyncio.open_connection(); StreamWriter wraps an asyncio transport and provides write(), drain(), close(), and wait_closed() for sending data to a network peer); asyncio.StreamWriter.__module__=='asyncio.streams' (len=15: 'asyncio'=7+'.'=1+'streams'=7=15; same module as StreamReader established in extra164; 'streams'=7 is 1 char longer than 'events'=6 and 'queues'=6); asyncio.StreamWriter.__name__.__len__()==12 ('StreamWriter'=12: 'Stream'=6+'Writer'=6=12; same length as asyncio.StreamReader.__name__.__len__()==12 established in extra164 — both are 12-char class names combining 'Stream'=6 with a 6-char suffix); the 'StreamWriter.'=13 qualname prefix (12+1=13) is shared by all four write method qualnames covered in this spec; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosw165

  columns: [id, function, args, expected, description]
  rows:
    - [sw_name_eq,  asyncio.StreamWriter.__name__.__eq__,    ["StreamWriter"],    true,   "asyncio.StreamWriter.__name__ == 'StreamWriter' (len=12: 'Stream'=6+'Writer'=6=12); verified with Python 3.14.3"]
    - [sw_name_len, asyncio.StreamWriter.__name__.__len__,   [],                  12,     "asyncio.StreamWriter.__name__.__len__() == 12 ('StreamWriter'; 'Stream'=6+'Writer'=6=12); verified with Python 3.14.3"]
    - [sw_mod_eq,   asyncio.StreamWriter.__module__.__eq__,  ["asyncio.streams"], true,   "asyncio.StreamWriter.__module__ == 'asyncio.streams' (len=15; same module as StreamReader); verified with Python 3.14.3"]
    - [sw_mod_len,  asyncio.StreamWriter.__module__.__len__, [],                  15,     "asyncio.StreamWriter.__module__.__len__() == 15 ('asyncio.streams'; 'streams'=7 > 'events'=6 by 1); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.StreamWriter method qualnames — extra165
#
# asyncio.StreamWriter.write.__qualname__.__eq__('StreamWriter.write')           == True
# asyncio.StreamWriter.drain.__qualname__.__eq__('StreamWriter.drain')           == True
# asyncio.StreamWriter.close.__qualname__.__eq__('StreamWriter.close')           == True
# asyncio.StreamWriter.wait_closed.__qualname__.__eq__('StreamWriter.wait_closed') == True
# ---------------------------------------------------------------------------

table asyncio_extra165.asyncio_stream_writer_method_qualnames:
  description: "asyncio.StreamWriter method qualname checks in asyncioswmq165 namespace — asyncio.StreamWriter.write.__qualname__=='StreamWriter.write' (len=18: 'StreamWriter'=12+'.'=1+'write'=5=18; write(data) writes data bytes to the stream buffer; it is NOT a coroutine — it is a regular method that buffers data for the transport; should be followed by drain() to flush); asyncio.StreamWriter.drain.__qualname__=='StreamWriter.drain' (len=18: 'StreamWriter'=12+'.'=1+'drain'=5=18; drain() is a coroutine that waits until the write buffer is flushed; 'drain'=5=='write'=5 so drain qualname(18) == write qualname(18)); asyncio.StreamWriter.close.__qualname__=='StreamWriter.close' (len=18: 'StreamWriter'=12+'.'=1+'close'=5=18; close() closes the underlying transport; 'close'=5=='write'=5=='drain'=5 so all three have qualname len=18); asyncio.StreamWriter.wait_closed.__qualname__=='StreamWriter.wait_closed' (len=24: 'StreamWriter'=12+'.'=1+'wait_closed'=11=24; wait_closed() is a coroutine that blocks until close() completes; 'wait_closed'=11='wait'=4+'_'=1+'closed'=6=11; wait_closed qualname(24) is the longest — 6 chars longer than write/drain/close(18)); KEY: write(18)==drain(18)==close(18) < wait_closed(24); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioswmq165

  columns: [id, function, args, expected, description]
  rows:
    - [sw_write_qn,       asyncio.StreamWriter.write.__qualname__.__eq__,       ["StreamWriter.write"],       true,  "StreamWriter.write.__qualname__ == 'StreamWriter.write' (len=18; 'write'=5); verified with Python 3.14.3"]
    - [sw_drain_qn,       asyncio.StreamWriter.drain.__qualname__.__eq__,       ["StreamWriter.drain"],       true,  "StreamWriter.drain.__qualname__ == 'StreamWriter.drain' (len=18; 'drain'=5 == 'write'=5; same length); verified with Python 3.14.3"]
    - [sw_close_qn,       asyncio.StreamWriter.close.__qualname__.__eq__,       ["StreamWriter.close"],       true,  "StreamWriter.close.__qualname__ == 'StreamWriter.close' (len=18; 'close'=5; same as write and drain); verified with Python 3.14.3"]
    - [sw_wait_closed_qn, asyncio.StreamWriter.wait_closed.__qualname__.__eq__, ["StreamWriter.wait_closed"], true,  "StreamWriter.wait_closed.__qualname__ == 'StreamWriter.wait_closed' (len=24; 'wait_closed'=11; longest); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.StreamWriter method qualname lengths — extra165
#
# write(18) == drain(18) == close(18) < wait_closed(24)
# ---------------------------------------------------------------------------

table asyncio_extra165.asyncio_stream_writer_qualname_lengths:
  description: "asyncio.StreamWriter method qualname length cross-comparison in asyncioswql165 namespace — write qualname len==18 ('StreamWriter.write'=18: 'StreamWriter'=12+'.'=1+'write'=5=18; 'write'=5 is 1 char longer than 'read'=4 from StreamReader methods in extra164 so write qualname(18) is 1 longer than StreamReader.read qualname(17)); drain qualname len==18 ('StreamWriter.drain'=18: 'drain'=5=='write'=5; same length as write because method names are equal length); close qualname len==18 ('StreamWriter.close'=18: 'close'=5=='write'=5=='drain'=5; all three share qualname len=18 — a tie among three methods); wait_closed qualname len==24 ('StreamWriter.wait_closed'=24: 'wait_closed'=11='wait'=4+'_'=1+'closed'=6=11; 24-18=6; wait_closed qualname is 6 longer than write/drain/close qualnames because 'wait_closed'=11 is 6 chars longer than 'write'=5); KEY: write(18)==drain(18)==close(18) < wait_closed(24); compare: StreamReader qualnames from extra164: read(17) < readline(21) < readuntil(22) < readexactly(24); StreamWriter.wait_closed(24) == StreamReader.readexactly(24) in qualname length; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioswql165

  columns: [id, function, args, expected, description]
  rows:
    - [sw_write_qn_len,       asyncio.StreamWriter.write.__qualname__.__len__,       [],  18,  "StreamWriter.write qualname len==18 ('write'=5; 1 longer than StreamReader.read=17); verified with Python 3.14.3"]
    - [sw_drain_qn_len,       asyncio.StreamWriter.drain.__qualname__.__len__,       [],  18,  "StreamWriter.drain qualname len==18 ('drain'=5 == 'write'=5; tied with write=18); verified with Python 3.14.3"]
    - [sw_close_qn_len,       asyncio.StreamWriter.close.__qualname__.__len__,       [],  18,  "StreamWriter.close qualname len==18 ('close'=5; all three write/drain/close tied at 18); verified with Python 3.14.3"]
    - [sw_wait_closed_qn_len, asyncio.StreamWriter.wait_closed.__qualname__.__len__, [],  24,  "StreamWriter.wait_closed qualname len==24 ('wait_closed'=11; 6 longer than write/drain/close=18); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra165
# ---------------------------------------------------------------------------

invariant asyncio_extra165.asyncio_StreamWriter_name_eq:
  description: "asyncio.StreamWriter.__name__.__eq__('StreamWriter') returns True — asyncio.StreamWriter is the write-side stream class for asyncio I/O; StreamWriter.__name__=='StreamWriter' (len=12: 'Stream'=6+'Writer'=6=12); StreamWriter is created by asyncio.open_connection() as the second element of the (reader, writer) tuple; it wraps an asyncio transport and exposes a high-level coroutine API; StreamWriter.write(data) buffers data synchronously; StreamWriter.drain() is a coroutine that yields control until the transport is ready to accept more data; StreamWriter.close() closes the underlying transport; StreamWriter.wait_closed() is a coroutine that awaits transport closure; StreamWriter.__module__=='asyncio.streams' (len=15: same module as StreamReader from extra164); compare: asyncio.StreamReader.__name__=='StreamReader' (len=12; same length as StreamWriter=12 — both use the 'Stream'=6 prefix with a 6-char suffix: 'Reader'=6 and 'Writer'=6); NEW in extra165: first standalone asyncio.StreamWriter.__name__ identity invariant in asynciosw165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.StreamWriter.__name__.__eq__
  args: ["StreamWriter"]
  expected: true

invariant asyncio_extra165.asyncio_StreamWriter_write_qualname_eq:
  description: "asyncio.StreamWriter.write.__qualname__.__eq__('StreamWriter.write') returns True — asyncio.StreamWriter.write is the core data-writing method; write.__qualname__=='StreamWriter.write' (len=18: 'StreamWriter'=12+'.'=1+'write'=5=18); StreamWriter.write(data) accepts a bytes-like object and buffers it to the underlying transport; write() is NOT a coroutine — it returns immediately after buffering; callers should follow write() with await writer.drain() to ensure the buffer is flushed to the transport before sending more data; 'write'=5 is 1 char longer than 'read'=4 (StreamReader.read from extra164) so write qualname(18) > StreamReader.read qualname(17) by 1 char; KEY: write qualname(18) == drain qualname(18) == close qualname(18) because 'write'=5=='drain'=5=='close'=5 — all three share the same 5-char method name length; wait_closed qualname(24) is the outlier with 'wait_closed'=11; NEW in extra165: first standalone StreamWriter.write.__qualname__ invariant in asyncioswmq165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.StreamWriter.write.__qualname__.__eq__
  args: ["StreamWriter.write"]
  expected: true

invariant asyncio_extra165.asyncio_StreamWriter_drain_qualname_eq:
  description: "asyncio.StreamWriter.drain.__qualname__.__eq__('StreamWriter.drain') returns True — asyncio.StreamWriter.drain is the flow-control coroutine; drain.__qualname__=='StreamWriter.drain' (len=18: 'StreamWriter'=12+'.'=1+'drain'=5=18); drain() is a coroutine that should be awaited after write() calls to flush the write buffer; it pauses the coroutine when the underlying transport's buffer is above the high-water mark and resumes when it drops below the low-water mark; 'drain'=5=='write'=5 so drain qualname(18) == write qualname(18) — they are tied in length; the pattern of calling write() then await drain() is the standard asyncio write idiom; compare: StreamReader.readline qualname(21) > StreamWriter.drain qualname(18) by 3 chars because 'readline'=8 > 'drain'=5 by 3; NEW in extra165: first standalone StreamWriter.drain.__qualname__ invariant in asyncioswmq165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.StreamWriter.drain.__qualname__.__eq__
  args: ["StreamWriter.drain"]
  expected: true

invariant asyncio_extra165.asyncio_StreamWriter_close_qualname_eq:
  description: "asyncio.StreamWriter.close.__qualname__.__eq__('StreamWriter.close') returns True — asyncio.StreamWriter.close closes the underlying transport; close.__qualname__=='StreamWriter.close' (len=18: 'StreamWriter'=12+'.'=1+'close'=5=18); close() is NOT a coroutine — it schedules the transport for closure and returns immediately; after calling close(), callers should await wait_closed() to ensure the transport is fully closed before continuing; 'close'=5 == 'write'=5 == 'drain'=5 so close qualname(18) == write qualname(18) == drain qualname(18) — all three share qualname length 18; wait_closed qualname(24) is the longest at 24 because 'wait_closed'=11 is 6 chars longer than 'close'=5; compare: in Python 3.8+ it is recommended to call close() and then await wait_closed() rather than just close() alone; NEW in extra165: first standalone StreamWriter.close.__qualname__ invariant in asyncioswmq165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.StreamWriter.close.__qualname__.__eq__
  args: ["StreamWriter.close"]
  expected: true

invariant asyncio_extra165.asyncio_StreamWriter_wait_closed_qualname_eq:
  description: "asyncio.StreamWriter.wait_closed.__qualname__.__eq__('StreamWriter.wait_closed') returns True — asyncio.StreamWriter.wait_closed is the coroutine that waits until the transport is fully closed; wait_closed.__qualname__=='StreamWriter.wait_closed' (len=24: 'StreamWriter'=12+'.'=1+'wait_closed'=11=24); 'wait_closed'=11='wait'=4+'_'=1+'closed'=6=11; wait_closed qualname(24) is the longest among the four StreamWriter method qualnames: write(18)==drain(18)==close(18) < wait_closed(24); the gap is 24-18=6 chars because 'wait_closed'=11 is 6 chars longer than 'write'=5/'drain'=5/'close'=5; wait_closed() must be called after close() to ensure connection cleanup; compare: asyncio.StreamReader.readexactly qualname length == 24 (established in extra164) — StreamWriter.wait_closed qualname(24) ties with StreamReader.readexactly qualname(24); NEW in extra165: first standalone StreamWriter.wait_closed.__qualname__ invariant in asyncioswmq165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.StreamWriter.wait_closed.__qualname__.__eq__
  args: ["StreamWriter.wait_closed"]
  expected: true

