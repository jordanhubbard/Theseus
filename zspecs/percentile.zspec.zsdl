spec: percentile
version: ">=1.6.0"
backend: node(percentile)

docs: https://www.npmjs.com/package/percentile

provenance:
  derived_from:
    - "percentile README — https://www.npmjs.com/package/percentile"
    - "Test vectors verified with percentile via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "percentile source"
  notes:
    - "percentile is an npm package. Install: npm install percentile"
    - "Returns the value at the given percentile of a sorted array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table percentile.calculate:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: pctile

  columns: [id, args, expected]
  rows:
    - [p50,   [50, [1, 2, 3, 4, 5]],   3]
    - [p25,   [25, [1, 2, 3, 4, 5]],   2]
    - [p100,  [100, [1, 2, 3, 4, 5]],  5]
