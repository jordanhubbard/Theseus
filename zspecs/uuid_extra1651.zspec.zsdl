spec: uuid_extra1651
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
    - "CPython source: Lib/uuid.py"
  notes:
    - "behavioral invariants for __init_subclass__, __set_name__, and __class_getitem__ class creation and parameterization protocol"
    - "uuid.UUID is a plain Python class defined in Lib/uuid.py; it does not define __init_subclass__ in its own __dict__ — the hook is inherited from object."
    - "uuid.SafeUUID is an IntEnum subclass; its own __dict__ also lacks __init_subclass__."
    - "Neither uuid.UUID nor uuid.SafeUUID defines __set_name__ — they are not descriptors."
    - "uuid.UUID does not define __class_getitem__ in its own __dict__ — UUID is not a generic container type."
    - "uuid.SafeUUID does not define __class_getitem__ either — IntEnum subclasses do not get PEP 585 generic support."
    - "object.__init_subclass__ is always present as the universal no-op fallback hook."
    - "uuid.UUID.__dict__ contains __init__, __str__, __eq__, __lt__, __hash__, hex, bytes, fields, version as expected."
    - "uuid module exports UUID, SafeUUID, uuid1/3/4/5, NAMESPACE_* constants, and variant/version constants."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: uuid.UUID and uuid.SafeUUID do not define __init_subclass__,
# __set_name__, or __class_getitem__ in their own __dict__.
#
# uuid.UUID is a plain Python class; __init_subclass__ would appear in its
# __dict__ only if uuid.UUID explicitly defined it. Since it does not, the
# hook is looked up via the MRO and found on object. uuid.SafeUUID is an
# IntEnum subclass; same reasoning applies.
# ---------------------------------------------------------------------------

table uuid_extra1651.no_init_subclass:
  description: "uuid.UUID and uuid.SafeUUID do not define __init_subclass__, __set_name__, or __class_getitem__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1651

  columns: [id, function, args, expected]
  rows:
    - ["uu1651001", "UUID.__dict__.__contains__",     ["__init_subclass__"], false]
    - ["uu1651002", "SafeUUID.__dict__.__contains__", ["__init_subclass__"], false]
    - ["uu1651003", "UUID.__dict__.__contains__",     ["__class_getitem__"], false]
    - ["uu1651004", "SafeUUID.__dict__.__contains__", ["__class_getitem__"], false]
    - ["uu1651005", "UUID.__dict__.__contains__",     ["__set_name__"],      false]
    - ["uu1651006", "SafeUUID.__dict__.__contains__", ["__set_name__"],      false]
    - ["uu1651007", "object.__dict__.__contains__",   ["__init_subclass__"], true]
    - ["uu1651008", "object.__dict__.__contains__",   ["__class_getitem__"], false]
    - ["uu1651009", "object.__dict__.__contains__",   ["__set_name__"],      false]
    - ["uu1651010", "UUID.__dict__.__contains__",     ["__subclasshook__"],  false]
    - ["uu1651011", "UUID.__dict__.__contains__",     ["__instancecheck__"], false]
    - ["uu1651012", "SafeUUID.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["uu1651013", "UUID.__dict__.__contains__",     ["__init__"],          true]
    - ["uu1651014", "UUID.__dict__.__contains__",     ["__str__"],           true]
    - ["uu1651015", "UUID.__dict__.__contains__",     ["__eq__"],            true]
    - ["uu1651016", "UUID.__dict__.__contains__",     ["__hash__"],          true]
    - ["uu1651017", "UUID.__dict__.__contains__",     ["__repr__"],          true]
    - ["uu1651018", "UUID.__dict__.__contains__",     ["__int__"],           true]
    - ["uu1651019", "UUID.__dict__.__contains__",     ["__lt__"],            true]
    - ["uu1651020", "UUID.__dict__.__contains__",     ["hex"],               true]
    - ["uu1651021", "UUID.__dict__.__contains__",     ["bytes"],             true]
    - ["uu1651022", "UUID.__dict__.__contains__",     ["fields"],            true]
    - ["uu1651023", "UUID.__dict__.__contains__",     ["version"],           true]
    - ["uu1651024", "SafeUUID.__dict__.__contains__", ["safe"],              true]
    - ["uu1651025", "SafeUUID.__dict__.__contains__", ["unsafe"],            true]

# ---------------------------------------------------------------------------
# Table 2: uuid module-level attribute presence
#
# The uuid module exports its public API as top-level module attributes.
# We verify presence of classes, factory functions, namespace constants,
# and variant/reservation constants via __dict__.__contains__.
# ---------------------------------------------------------------------------

table uuid_extra1651.module_attr_presence:
  description: "uuid module-level attributes are present in uuid.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1651

  columns: [id, function, args, expected]
  rows:
    - ["uu1651026", "__dict__.__contains__", ["UUID"],              true]
    - ["uu1651027", "__dict__.__contains__", ["SafeUUID"],          true]
    - ["uu1651028", "__dict__.__contains__", ["uuid1"],             true]
    - ["uu1651029", "__dict__.__contains__", ["uuid3"],             true]
    - ["uu1651030", "__dict__.__contains__", ["uuid4"],             true]
    - ["uu1651031", "__dict__.__contains__", ["uuid5"],             true]
    - ["uu1651032", "__dict__.__contains__", ["NAMESPACE_DNS"],     true]
    - ["uu1651033", "__dict__.__contains__", ["NAMESPACE_URL"],     true]
    - ["uu1651034", "__dict__.__contains__", ["NAMESPACE_OID"],     true]
    - ["uu1651035", "__dict__.__contains__", ["NAMESPACE_X500"],    true]
    - ["uu1651036", "__dict__.__contains__", ["RESERVED_NCS"],      true]
    - ["uu1651037", "__dict__.__contains__", ["RFC_4122"],          true]
    - ["uu1651038", "__dict__.__contains__", ["RESERVED_MICROSOFT"], true]
    - ["uu1651039", "__dict__.__contains__", ["RESERVED_FUTURE"],   true]
    - ["uu1651040", "__dict__.__contains__", ["__name__"],          true]
    - ["uu1651041", "__dict__.__contains__", ["__doc__"],           true]
    - ["uu1651042", "__dict__.__contains__", ["__init_subclass__"], false]
    - ["uu1651043", "__dict__.__contains__", ["__set_name__"],      false]
    - ["uu1651044", "__dict__.__contains__", ["__class_getitem__"], false]
    - ["uu1651045", "__dict__.__contains__", ["getnode"],           true]
    - ["uu1651046", "__dict__.__contains__", ["uuid2"],             false]
    - ["uu1651047", "__dict__.__contains__", ["uuid6"],             false]
    - ["uu1651048", "__dict__.__contains__", ["NAMESPACE_DNS"],     true]
    - ["uu1651049", "__dict__.__contains__", ["int"],               false]
    - ["uu1651050", "__dict__.__contains__", ["UUID"],              true]

# ---------------------------------------------------------------------------
# Table 3: uuid.UUID instance method and property presence
#
# uuid.UUID defines its protocol entirely in __dict__: __init__, string
# conversion (__repr__, __str__), comparison (__eq__, __lt__, __hash__),
# integer conversion (__int__), and properties (hex, bytes, fields, version).
# None of the class-creation protocol hooks (__init_subclass__, __set_name__,
# __class_getitem__) appear in UUID.__dict__.
# ---------------------------------------------------------------------------

table uuid_extra1651.uuid_method_presence:
  description: "uuid.UUID.__dict__ contains the expected instance methods and properties; lacks class-creation hooks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1651

  columns: [id, function, args, expected]
  rows:
    - ["uu1651051", "UUID.__dict__.__contains__", ["__init__"],          true]
    - ["uu1651052", "UUID.__dict__.__contains__", ["__int__"],           true]
    - ["uu1651053", "UUID.__dict__.__contains__", ["__repr__"],          true]
    - ["uu1651054", "UUID.__dict__.__contains__", ["__str__"],           true]
    - ["uu1651055", "UUID.__dict__.__contains__", ["__eq__"],            true]
    - ["uu1651056", "UUID.__dict__.__contains__", ["__lt__"],            true]
    - ["uu1651057", "UUID.__dict__.__contains__", ["__hash__"],          true]
    - ["uu1651058", "UUID.__dict__.__contains__", ["hex"],               true]
    - ["uu1651059", "UUID.__dict__.__contains__", ["bytes"],             true]
    - ["uu1651060", "UUID.__dict__.__contains__", ["fields"],            true]
    - ["uu1651061", "UUID.__dict__.__contains__", ["version"],           true]
    - ["uu1651062", "UUID.__dict__.__contains__", ["__init_subclass__"], false]
    - ["uu1651063", "UUID.__dict__.__contains__", ["__set_name__"],      false]
    - ["uu1651064", "UUID.__dict__.__contains__", ["__class_getitem__"], false]
    - ["uu1651065", "UUID.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["uu1651066", "UUID.__dict__.__contains__", ["__instancecheck__"], false]
    - ["uu1651067", "UUID.__dict__.__contains__", ["int"],               true]
    - ["uu1651068", "UUID.__dict__.__contains__", ["bytes_le"],          true]
    - ["uu1651069", "UUID.__dict__.__contains__", ["time"],              true]
    - ["uu1651070", "UUID.__dict__.__contains__", ["clock_seq"],         true]
    - ["uu1651071", "UUID.__dict__.__contains__", ["node"],              true]
    - ["uu1651072", "UUID.__dict__.__contains__", ["urn"],               true]
    - ["uu1651073", "UUID.__dict__.__contains__", ["variant"],           true]
    - ["uu1651074", "UUID.__name__.__eq__",        ["UUID"],             true]
    - ["uu1651075", "UUID.__module__.__eq__",       ["uuid"],            true]
