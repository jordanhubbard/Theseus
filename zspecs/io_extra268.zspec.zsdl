invariant io_extra268.BufferedReader.readline.qualname:
  description: "io.BufferedReader.readline.__qualname__ == 'BufferedReader.readline'"
  category: identity
  kind: python_call_eq
  function: BufferedReader.readline.__qualname__.__eq__
  args: ["BufferedReader.readline"]
  expected: true

invariant io_extra268.BufferedReader.readlines.qualname:
  description: "io.BufferedReader.readlines.__qualname__ == '_IOBase.readlines' — inherited from _IOBase"
  category: identity
  kind: python_call_eq
  function: BufferedReader.readlines.__qualname__.__eq__
  args: ["_IOBase.readlines"]
  expected: true

invariant io_extra268.BufferedReader.seek.qualname:
  description: "io.BufferedReader.seek.__qualname__ == 'BufferedReader.seek'"
  category: identity
  kind: python_call_eq
  function: BufferedReader.seek.__qualname__.__eq__
  args: ["BufferedReader.seek"]
  expected: true

invariant io_extra268.BufferedReader.tell.qualname:
  description: "io.BufferedReader.tell.__qualname__ == 'BufferedReader.tell'"
  category: identity
  kind: python_call_eq
  function: BufferedReader.tell.__qualname__.__eq__
  args: ["BufferedReader.tell"]
  expected: true

invariant io_extra268.BufferedReader.close.qualname:
  description: "io.BufferedReader.close.__qualname__ == 'BufferedReader.close'"
  category: identity
  kind: python_call_eq
  function: BufferedReader.close.__qualname__.__eq__
  args: ["BufferedReader.close"]
  expected: true

invariant io_extra268.BufferedReader.read.class_name:
  description: "io.BufferedReader.read.__class__.__name__ == 'method_descriptor' — C-level descriptor"
  category: identity
  kind: python_call_eq
  function: BufferedReader.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

