spec: io_extra268
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "io.BufferedReader.__module__ == '_io' — the class is implemented in the C extension _io, not the io wrapper."
    - "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — the direct C-level base class."
    - "io.BufferedReader.readlines is inherited from _IOBase; its __qualname__ == '_IOBase.readlines'."
    - "io.BufferedReader.read.__class__.__name__ == 'method_descriptor' — C-level method descriptor."
    - "io.BufferedWriter.__module__ == '_io' and __bases__[0].__name__ == '_BufferedIOBase' — same pattern as BufferedReader."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedReader — class identity
# ---------------------------------------------------------------------------

invariant io_extra268.BufferedReader.name:
  description: "io.BufferedReader.__name__ == 'BufferedReader'"
  category: identity
  kind: python_call_eq
  function: BufferedReader.__name__.__eq__
  args: ["BufferedReader"]
  expected: true

invariant io_extra268.BufferedReader.module:
  description: "io.BufferedReader.__module__ == '_io' — defined in the C extension"
  category: identity
  kind: python_call_eq
  function: BufferedReader.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra268.BufferedReader.base:
  description: "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase'"
  category: identity
  kind: python_call_eq
  function: BufferedReader.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_BufferedIOBase"

# ---------------------------------------------------------------------------
# io.BufferedReader — method qualnames
# ---------------------------------------------------------------------------

invariant io_extra268.BufferedReader.read.qualname:
  description: "io.BufferedReader.read.__qualname__ == 'BufferedReader.read'"
  category: identity
  kind: python_call_eq
  function: BufferedReader.read.__qualname__.__eq__
  args: ["BufferedReader.read"]
  expected: true

invariant io_extra268.BufferedReader.read1.qualname:
  description: "io.BufferedReader.read1.__qualname__ == 'BufferedReader.read1'"
  category: identity
  kind: python_call_eq
  function: BufferedReader.read1.__qualname__.__eq__
  args: ["BufferedReader.read1"]
  expected: true

invariant io_extra268.BufferedReader.peek.qualname:
  description: "io.BufferedReader.peek.__qualname__ == 'BufferedReader.peek'"
  category: identity
  kind: python_call_eq
