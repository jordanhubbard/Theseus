spec: threading_extra2251
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "Wave extra2251: callable protocol and function-attribute dict-presence checks — __call__, __code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__ in threading class __dict__."
    - "threading.Thread, threading.Lock, threading.RLock, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Barrier, threading.Timer, threading.local — none define __call__ in their class __dict__."
    - "None of these threading synchronization or thread management types define __call__; they are not callable instances in the sense that their instances cannot be called like functions."
    - "__code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__ are function-object attributes; none of the threading types define them in their class __dict__."
    - "threading.Lock is a factory function returning a _thread.lock instance; threading.RLock returns a _thread.RLock instance. Both _thread.lock and _thread.RLock also do not define __call__ in their class __dict__."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table threading_extra2251.call_protocol_thread_lock_event:
  description: "threading.Thread, threading.Lock, threading.RLock, threading.Event do NOT define __call__ in their __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2251

  columns: [id, function, args, expected]
  rows:
    - ["th2251001", "threading.Thread.__dict__.__contains__", ["__call__"], false]
    - ["th2251002", "threading.Lock.__dict__.__contains__", ["__call__"], false]
    - ["th2251003", "threading.RLock.__dict__.__contains__", ["__call__"], false]
    - ["th2251004", "threading.Event.__dict__.__contains__", ["__call__"], false]

