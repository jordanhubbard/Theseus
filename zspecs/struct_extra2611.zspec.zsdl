spec: struct_extra2611
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 621 theme: __init_subclass__, __subclasshook__, and __class_getitem__ dict-presence checks."
    - "struct.Struct does NOT define __init_subclass__ in its own __dict__ — inherits from object."
    - "struct.Struct does NOT define __subclasshook__ in its own __dict__ — not an ABC; hook not defined."
    - "struct.Struct does NOT define __class_getitem__ in its own __dict__ — no PEP 585 generic alias support."
    - "struct.error is a plain exception subclass; it likewise does NOT define any of the three dunder methods in its own __dict__."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# struct.Struct — __init_subclass__, __subclasshook__, __class_getitem__
# ---------------------------------------------------------------------------

table struct_extra2611.struct_class_init_subclass:
  description: "__init_subclass__ is absent from struct.Struct.__dict__ — inherited from object, not defined on Struct itself"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2611

  columns: [id, function, args, expected]
  rows:
    - ["st2611001", "struct.Struct.__dict__.__contains__", ["__init_subclass__"], false]

table struct_extra2611.struct_class_subclasshook:
  description: "__subclasshook__ is absent from struct.Struct.__dict__ — Struct is not an ABC; hook not defined"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2611

  columns: [id, function, args, expected]
  rows:
    - ["st2611002", "struct.Struct.__dict__.__contains__", ["__subclasshook__"], false]

table struct_extra2611.struct_class_class_getitem:
  description: "__class_getitem__ is absent from struct.Struct.__dict__ — no PEP 585 generic alias support on Struct"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2611

  columns: [id, function, args, expected]
  rows:
    - ["st2611003", "struct.Struct.__dict__.__contains__", ["__class_getitem__"], false]

table struct_extra2611.struct_error_dict_presence:
  description: "struct.error (exception subclass) does not define __init_subclass__, __subclasshook__, or __class_getitem__ in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2611

  columns: [id, function, args, expected]
  rows:
    - ["st2611004", "struct.error.__dict__.__contains__", ["__init_subclass__"],  false]
    - ["st2611005", "struct.error.__dict__.__contains__", ["__subclasshook__"],   false]
    - ["st2611006", "struct.error.__dict__.__contains__", ["__class_getitem__"],  false]
