spec: markupsafe_rust
version: ">=3.9"
backend: rust_module(markupsafe_rust)

docs: https://markupsafe.palletsprojects.com/en/stable/

provenance:
  derived_from:
    - "https://markupsafe.palletsprojects.com/ — MarkupSafe documentation"
  not_derived_from:
    - "MarkupSafe source: src/markupsafe/__init__.py"
  notes:
    - "MarkupSafe provides safe HTML string escaping."
    - "escape(s) converts &, <, >, \", ' to HTML entities and returns a Markup object."
    - "escape('<b>hello</b>') == '&lt;b&gt;hello&lt;/b&gt;'."
    - "escape('plain text') == 'plain text' — no escaping needed."
    - "escape('a & b') == 'a &amp; b'."
    - "double-quote escaping: '\"' → '&#34;', single-quote: \"'\" → '&#39;'."
    - "Markup('<b>hello</b>').striptags() == 'hello' — removes all HTML tags."
    - "Markup('<p>Hello <em>world</em>!</p>').striptags() == 'Hello world!'."
    - "Markup returns a string subclass; equality comparison works with plain str."
    - "All test vectors verified against MarkupSafe 3.0.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# escape — HTML-encode special characters
table markupsafe_rust.escape.vectors:
  kind: python_call_eq
  category: escape
  id_prefix: ms_esc
  function: escape

  columns: [id, args, expected]
  rows:
    - [plain,      ["plain text"],           "plain text"]
    - [tags,       ["<b>hello</b>"],         "&lt;b&gt;hello&lt;/b&gt;"]
    - [ampersand,  ["a & b"],                "a &amp; b"]
    - [dquote,     ["say \"hi\""],           "say &#34;hi&#34;"]
    - [squote,     ["it's fine"],            "it&#39;s fine"]
    - [empty,      [""],                     ""]
    - [script,     ["<script>xss</script>"], "&lt;script&gt;xss&lt;/script&gt;"]

# Markup.striptags — remove HTML tags leaving plain text
table markupsafe_rust.striptags.vectors:
  kind: python_call_eq
  category: striptags
  id_prefix: ms_st
  function: Markup
  method: striptags
  method_args: []

  columns: [id, args, expected]
  rows:
    - [bold,    ["<b>hello</b>"],                        "hello"]
    - [para,    ["<p>Hello <em>world</em>!</p>"],        "Hello world!"]
    - [plain,   ["just text"],                           "just text"]
    - [nested,  ["<div><span>inner</span></div>"],       "inner"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T23:00:04Z
  iterations: 1
  pass_count: 11
  fail_count: 0
  total_invariants: 11
  notes: Synthesis succeeded in 1 iteration(s). 11 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
