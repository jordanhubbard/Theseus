provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid: UUID objects according to RFC 4122"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 644 (uu2956): __invert__, __round__, __trunc__ dict-presence checks for uuid types."
    - "uuid.UUID is an immutable identifier class; uuid.SafeUUID is an IntEnum — neither defines bitwise invert, round, or truncate operators in its own __dict__."
    - "Verified types: uuid.UUID, uuid.SafeUUID."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table uu2956.invert:
