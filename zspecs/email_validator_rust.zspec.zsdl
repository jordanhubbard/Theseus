spec: email_validator_rust
version: ">=3.9"
backend: rust_module(email_validator_rust)

docs: https://github.com/JoshData/python-email-validator

provenance:
  derived_from:
    - "https://github.com/JoshData/python-email-validator — email-validator"
  notes:
    - "email-validator validates email addresses."
    - "email_validator.validate_email('test@example.com') does not raise."
    - "email_validator.EmailNotValidError is a class."
    - "email_validator.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant email_validator_rust.has_validate_email:
  description: "email_validator.validate_email is callable"
  category: presence
  kind: python_call_eq
  function: email_validator_has_validate
  args: []
  expected: true

invariant email_validator_rust.has_error_class:
  description: "email_validator.EmailNotValidError is a class"
  category: presence
  kind: python_call_eq
  function: email_validator_has_error_class
  args: []
  expected: true

invariant email_validator_rust.version_nonempty:
  description: "email_validator.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: email_validator_version_nonempty
  args: []
  expected: true

