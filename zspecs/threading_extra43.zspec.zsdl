spec: threading_extra43
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra42.zspec.zsdl."
    - "Prior specs covered: Thread/__name__/__qualname__.__len__()==6; Thread method __qualname__.__len__() for start/run/join/is_alive/__init__/__repr__/getName/setName; Event method __qualname__.__len__(); Condition method __qualname__.__len__() for wait/notify/notify_all/__enter__; Semaphore/__name__/__qualname__.__len__()==9; Barrier/__name__/__qualname__.__len__()==7; Timer/__name__/__qualname__.__len__()==5; threading.local/__name__/__qualname__.__len__()==6; Lock/__name__.__len__()==4; RLock/__dict__.__class__.__name__.__len__()==12; current_thread/__name__/main_thread/__name__; threading.__all__.__len__()==28; TIMEOUT_MAX; active_count/enumerate/settrace/setprofile/stack_size __name__ lengths; Thread property __class__.__name__.__len__() for daemon/name/ident/native_id; pure-Python class __module__.__len__()==9; Barrier/__name__/__module__=='Barrier'/'threading'; Condition/__name__/__module__=='Condition'/'threading'; Semaphore/__name__/__module__=='Semaphore'/'threading'; RLock/__name__/__module__=='RLock'/'threading'; Timer/__name__/__module__=='Timer'/'threading'; Timer/__bases__[0].__name__=='Thread'; BoundedSemaphore/__name__/__module__=='BoundedSemaphore'/'threading'; BoundedSemaphore/__bases__[0].__name__=='Semaphore'; local/__name__=='_local'; TIMEOUT_MAX==9223372036.0; excepthook/__name__=='_excepthook'."
    - "This spec covers: threading.Thread.__bases__[0].__name__ == 'object'; threading.Thread.__mro__.__len__() == 2; threading.Event.__bases__[0].__name__ == 'object'; threading.Event.__mro__.__len__() == 2; threading.Lock.__name__ == 'lock' (NOT 'Lock' — Lock is the C-extension type _thread.lock re-exported; its internal C name is lowercase 'lock'); threading.RLock.__qualname__ == 'RLock'; threading.main_thread.__name__ == 'main_thread'; threading.current_thread.__name__ == 'current_thread'; threading.active_count.__name__ == 'active_count'."
    - "Key findings: threading.Thread.__bases__[0].__name__ is 'object' — Thread is a pure-Python class defined in Lib/threading.py that inherits directly from object; single base class. threading.Thread.__mro__.__len__() == 2 — MRO is (Thread, object), depth 2 reflecting single-level inheritance. threading.Event.__bases__[0].__name__ is 'object' — Event is also a pure-Python class inheriting directly from object; MRO depth 2. CRITICAL: threading.Lock.__name__ is 'lock' (lowercase, NOT 'Lock') — threading.Lock is actually the C-extension type _thread.lock re-exported via the threading module attribute 'Lock'; the type's internal C name is lowercase 'lock' (4 chars). This parallels threading.local.__name__ == '_local' (extra42). threading.RLock.__qualname__ is 'RLock' — RLock is the pure-Python recursive lock class defined in Lib/threading.py; __qualname__ == __name__ because it is a top-level class. threading.main_thread.__name__ is 'main_thread' (11 chars), threading.current_thread.__name__ is 'current_thread' (14 chars), and threading.active_count.__name__ is 'active_count' (12 chars) — all pure-Python functions in Lib/threading.py with __module__ == 'threading'. Prior specs recorded __len__() for main_thread and current_thread but not string equality; active_count __len__() was recorded but not equality; RLock.__qualname__ is new; Thread/Event bases and MRO depth are entirely new."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Thread __bases__ and __mro__ — extra43 namespace
#
# threading.Thread.__bases__[0].__name__ is 'object' and
# threading.Thread.__mro__.__len__() is 2. Thread is a pure-Python class
# defined in Lib/threading.py with no intermediate base class; its MRO is
# (Thread, object), giving a depth of 2. Prior specs recorded
# Thread/__name__.__len__()==6 and various method __qualname__ lengths, but
# not __bases__[0].__name__ or __mro__.__len__(). These two invariants are new.
# ---------------------------------------------------------------------------

invariant threading_extra43.Thread_bases_name:
  description: "threading.Thread.__bases__[0].__name__ == 'object' — pure-Python class; inherits directly from object; single base class; no intermediate threading base"
  category: class_hierarchy
  kind: python_call_eq
  function: "Thread.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra43.Thread_mro_len:
  description: "len(threading.Thread.__mro__) == 2 — MRO is (Thread, object); depth 2 reflects single-level inheritance from object; no mixin or intermediate base class"
  category: class_hierarchy
  kind: python_call_eq
  function: Thread.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# threading.Event __bases__ and __mro__ — extra43 namespace
#
# threading.Event.__bases__[0].__name__ is 'object' and
# threading.Event.__mro__.__len__() is 2. Event is a pure-Python class
# defined in Lib/threading.py that inherits directly from object; its MRO is
# (Event, object), depth 2. This mirrors Thread's single-level inheritance.
# Prior specs recorded Event method __qualname__ lengths but not
# __bases__[0].__name__ or __mro__.__len__(). These two invariants are new.
# ---------------------------------------------------------------------------

invariant threading_extra43.Event_bases_name:
  description: "threading.Event.__bases__[0].__name__ == 'object' — pure-Python class; inherits directly from object; single base class; same inheritance depth as Thread"
  category: class_hierarchy
  kind: python_call_eq
  function: "Event.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra43.Event_mro_len:
  description: "len(threading.Event.__mro__) == 2 — MRO is (Event, object); depth 2 reflects single-level inheritance from object; same MRO depth as Thread"
  category: class_hierarchy
  kind: python_call_eq
  function: Event.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# threading.Lock __name__ — extra43 namespace
#
# threading.Lock.__name__ is 'lock' (lowercase, 4 chars) — NOT 'Lock'.
# threading.Lock is actually the C-extension type _thread.lock re-exported
# via the threading module as the attribute 'Lock' (uppercase). The type's
# internal C name is lowercase 'lock' (4 chars without underscore prefix).
# This parallels threading.local.__name__ == '_local' (extra42): the public
# attribute name (threading.Lock) differs from the type's __name__ ('lock').
# Prior specs recorded Lock/__name__.__len__()==4 but not the string equality.
# This equality invariant is new to the extra43 namespace.
# ---------------------------------------------------------------------------

invariant threading_extra43.Lock_name:
  description: "threading.Lock.__name__ == 'lock' — NOT 'Lock'; Lock is the C-extension type _thread.lock re-exported; internal C name is lowercase 4-char 'lock'; public attribute is uppercase 'Lock'"
  category: identity
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["lock"]
  expected: true

# ---------------------------------------------------------------------------
# threading.RLock __qualname__ — extra43 namespace
#
# threading.RLock.__qualname__ is 'RLock' (5 chars) — same as __name__.
# RLock is a pure-Python recursive lock class defined at module level in
# Lib/threading.py; as a top-level class __qualname__ == __name__. Prior
# specs recorded RLock/__name__ == 'RLock' and RLock/__module__ == 'threading'
# (extra41) and RLock/__dict__.__class__.__name__.__len__()==12 (extra40)
# but not the __qualname__ string equality invariant. This is new to extra43.
# ---------------------------------------------------------------------------

invariant threading_extra43.RLock_qualname:
  description: "threading.RLock.__qualname__ == 'RLock' — pure-Python recursive lock class; module-level definition; __qualname__ == __name__ (no enclosing class scope); 5 chars"
  category: identity
  kind: python_call_eq
  function: RLock.__qualname__.__eq__
  args: ["RLock"]
  expected: true

# ---------------------------------------------------------------------------
# threading utility function names — extra43 namespace
#
# threading.main_thread.__name__ is 'main_thread' (11 chars),
# threading.current_thread.__name__ is 'current_thread' (14 chars), and
# threading.active_count.__name__ is 'active_count' (12 chars). All are
# pure-Python functions defined in Lib/threading.py. Prior specs recorded
# current_thread/__name__ and main_thread/__name__ as raw strings in notes
# and __len__() values for active_count, but did not record string equality
# invariants for any of these in a formal invariant block.
# These three equality invariants are new to the extra43 namespace.
# ---------------------------------------------------------------------------

table threading_extra43.utility_function_names:
  description: "threading.main_thread, current_thread, and active_count __name__ string equality — all pure-Python functions in Lib/threading.py"
  kind: python_call_eq
  category: identity
  id_prefix: ufname43

  columns: [id, function, args, expected, description]
  rows:
    - [main_thread_name,
       main_thread.__name__.__eq__,
       ["main_thread"],
       true,
       "threading.main_thread.__name__ == 'main_thread' — pure-Python function; 11-char name; returns the MainThread object; same length as active_count.__name__ minus 1"]
    - [current_thread_name,
       current_thread.__name__.__eq__,
       ["current_thread"],
       true,
       "threading.current_thread.__name__ == 'current_thread' — pure-Python function; 14-char name; returns the currently executing Thread object; longest of the three utility function names"]
    - [active_count_name,
       active_count.__name__.__eq__,
       ["active_count"],
       true,
       "threading.active_count.__name__ == 'active_count' — pure-Python function; 12-char name; returns the count of Thread objects currently alive"]
