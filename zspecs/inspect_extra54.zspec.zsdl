spec: inspect_extra54
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html â€” Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra53.zspec.zsdl."
    - "Prior specs covered for inspect functions: __qualname__.__eq__ for getmembers/getfile/getsource/getmodule/stack/signature/ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/getsourcelines/getfullargspec (various extra10..extra53); __module__.__class__.__name__.__eq__('str') for isfunction/isbuiltin/isclass/ismodule/signature/getmembers (extra52); __module__.__class__.__name__.__eq__('str') for Parameter/Signature/BoundArguments/FrameInfo/FullArgSpec (extra53)."
    - "No prior inspect spec records __name__.__class__.__name__.__eq__('str') for any inspect function or class."
    - "No prior inspect spec records __qualname__.__class__.__name__.__eq__('str') for any inspect function or class."
    - "This spec covers: inspect.isfunction.__name__.__class__.__name__.__eq__('str')==true; inspect.isbuiltin.__name__.__class__.__name__.__eq__('str')==true; inspect.isclass.__name__.__class__.__name__.__eq__('str')==true; inspect.ismodule.__name__.__class__.__name__.__eq__('str')==true; inspect.signature.__name__.__class__.__name__.__eq__('str')==true; inspect.getmembers.__name__.__class__.__name__.__eq__('str')==true; inspect.Parameter.__qualname__.__class__.__name__.__eq__('str')==true; inspect.Signature.__qualname__.__class__.__name__.__eq__('str')==true."
    - "Key findings: inspect is a pure-Python module in Lib/inspect.py. All inspect module-level functions store their __name__ as a Python str object (the function name as a string literal). Since __name__ is a Python str, its __class__ is the str built-in type and str.__name__ == 'str' (3 chars). Prior extra52 established __module__.__class__.__name__.__eq__('str') for the same six functions, but no prior spec records __name__.__class__.__name__.__eq__('str') for any inspect function. Similarly, Parameter and Signature store their __qualname__ as Python str objects; their __qualname__.__class__.__name__ is therefore 'str'. These are new dimensions not covered in extra52 or extra53. All eight invariants are new to extra54."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect function __name__.__class__.__name__ == 'str' â€” extra54
#
# All inspect module-level functions are pure-Python function objects defined
# in Lib/inspect.py. Their __name__ attribute is set to the function name as a
# Python string literal (e.g., 'isfunction', 'getmembers'). Since __name__ is
# a Python str object, its __class__ is the str built-in type, and
# str.__name__ == 'str' (3 chars). Prior extra52 established that the same
# functions' __module__.__class__.__name__ == 'str' (measuring the type of the
# __module__ string), but no prior inspect spec measures __name__.__class__
# .__name__ (the type of the __name__ string). All six checks below are new
# to extra54.
# ---------------------------------------------------------------------------

table inspect_extra54.function_name_class_name:
  description: "inspect function __name__.__class__.__name__ == 'str' â€” function __name__ is a Python str object; str.__name__ == 'str' (3 chars); extra52 covered __module__.__class__.__name__ for the same functions; __name__.__class__.__name__ is a new dimension; new to extra54"
  kind: python_call_eq
  category: identity
  id_prefix: inspqual54

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_name_class_name,
       isfunction.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.isfunction.__name__.__class__.__name__ == 'str' â€” isfunction is a pure-Python function in Lib/inspect.py that returns True if the object is a Python function object; __name__ is the Python string 'isfunction' (10 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra19 confirmed isfunction.__qualname__.__eq__('isfunction') and extra52 confirmed isfunction.__module__.__class__.__name__.__eq__('str'); this is the first __name__.__class__.__name__ check for isfunction; new to extra54"]
    - [isbuiltin_name_class_name,
       isbuiltin.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.isbuiltin.__name__.__class__.__name__ == 'str' â€” isbuiltin is a pure-Python function in Lib/inspect.py that returns True if the object is a built-in function or bound built-in method; __name__ is the Python string 'isbuiltin' (9 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra52 confirmed isbuiltin.__module__.__class__.__name__.__eq__('str'); this is the first __name__.__class__.__name__ check for isbuiltin; new to extra54"]
    - [isclass_name_class_name,
       isclass.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.isclass.__name__.__class__.__name__ == 'str' â€” isclass is a pure-Python function in Lib/inspect.py that returns True if the object is a class; __name__ is the Python string 'isclass' (7 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra52 confirmed isclass.__module__.__class__.__name__.__eq__('str'); this is the first __name__.__class__.__name__ check for isclass; new to extra54"]
    - [ismodule_name_class_name,
       ismodule.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.ismodule.__name__.__class__.__name__ == 'str' â€” ismodule is a pure-Python function in Lib/inspect.py that returns True if the object is a module; __name__ is the Python string 'ismodule' (8 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra52 confirmed ismodule.__module__.__class__.__name__.__eq__('str'); this is the first __name__.__class__.__name__ check for ismodule; new to extra54"]
    - [signature_name_class_name,
       signature.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.signature.__name__.__class__.__name__ == 'str' â€” signature is a pure-Python function in Lib/inspect.py that returns a Signature object for the given callable; __name__ is the Python string 'signature' (9 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra52 confirmed signature.__module__.__class__.__name__.__eq__('str'); this is the first __name__.__class__.__name__ check for signature; new to extra54"]
    - [getmembers_name_class_name,
       getmembers.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.getmembers.__name__.__class__.__name__ == 'str' â€” getmembers is a pure-Python function in Lib/inspect.py that returns all the members of an object in a list of (name, value) pairs; __name__ is the Python string 'getmembers' (10 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra52 confirmed getmembers.__module__.__class__.__name__.__eq__('str'); this is the first __name__.__class__.__name__ check for getmembers; new to extra54"]

# ---------------------------------------------------------------------------
# inspect class __qualname__.__class__.__name__ == 'str' â€” extra54
#
# inspect.Parameter and inspect.Signature store their __qualname__ as Python
# str objects (the class qualified name string). Since __qualname__ is a Python
# str object, its __class__ is the str built-in type and str.__name__ == 'str'
# (3 chars). Prior specs confirmed Parameter.__qualname__.__eq__('Parameter')
# and Signature.__qualname__.__eq__('Signature') (extra7/extra12), and extra53
# confirmed Parameter.__module__.__class__.__qualname__.__eq__('str') and
# Signature.__module__.__class__.__qualname__.__eq__('str'). But no prior spec
# records __qualname__.__class__.__name__.__eq__('str') for any inspect class.
# Both checks below are new to extra54.
# ---------------------------------------------------------------------------

table inspect_extra54.class_qualname_class_name:
  description: "inspect class __qualname__.__class__.__name__ == 'str' â€” class __qualname__ is a Python str object; str.__name__ == 'str' (3 chars); extra53 covered __module__.__class__.__qualname__ form; __qualname__.__class__.__name__ is a new dimension; new to extra54"
  kind: python_call_eq
  category: identity
  id_prefix: inspqual54

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_qualname_class_name,
       Parameter.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.Parameter.__qualname__.__class__.__name__ == 'str' â€” Parameter is a pure-Python class in Lib/inspect.py representing a parameter in a function signature; __qualname__ is the Python string 'Parameter' (9 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra7/extra12 confirmed Parameter.__qualname__.__eq__('Parameter') and extra53 confirmed Parameter.__module__.__class__.__qualname__.__eq__('str'); this is the first __qualname__.__class__.__name__ check for Parameter; new to extra54"]
    - [Signature_qualname_class_name,
       Signature.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.Signature.__qualname__.__class__.__name__ == 'str' â€” Signature is a pure-Python class in Lib/inspect.py representing the signature of a callable; __qualname__ is the Python string 'Signature' (9 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra7/extra12 confirmed Signature.__qualname__.__eq__('Signature') and extra53 confirmed Signature.__module__.__class__.__qualname__.__eq__('str'); this is the first __qualname__.__class__.__name__ check for Signature; new to extra54"]
