spec: zoneinfo_extra7
version: ">=3.9"
backend: python_module(zoneinfo)

docs: https://docs.python.org/3/library/zoneinfo.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zoneinfo.html — Python zoneinfo module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zoneinfo/_common.py, Lib/zoneinfo/_tzpath.py"
    - "tzdata package — https://pypi.org/project/tzdata/"
    - "zoneinfo_extra2.zspec.zsdl — covers __qualname__ for ZoneInfo/ZoneInfoNotFoundError/available_timezones; ZoneInfo.__bases__[0].__name__=='tzinfo'; ZoneInfoNotFoundError/__module__; available_timezones/__module__"
    - "zoneinfo_extra4.zspec.zsdl — covers ZoneInfoNotFoundError.__bases__[0].__name__=='KeyError'; MRO lengths"
    - "zoneinfo_extra5.zspec.zsdl — covers ZoneInfo/__qualname__/__module__; ZoneInfoNotFoundError/__qualname__; ZoneInfoNotFoundError base KeyError; available_timezones __name__/returns_set/min_count"
    - "zoneinfo_extra6.zspec.zsdl — covers ZoneInfo/__name__/__module__; ZoneInfoNotFoundError/__name__/__base_name__; available_timezones/__name__/returns_set/min_count"
  notes:
    - "This spec extends zoneinfo.zspec.zsdl and prior extras through zoneinfo_extra6.zspec.zsdl."
    - "NEW in extra7 — Axis 1: class/function attribute table for __name__ and __qualname__ side-by-side — ZoneInfo, ZoneInfoNotFoundError, available_timezones."
    - "NEW in extra7 — Axis 2: ZoneInfo.__bases__[0].__name__ == 'tzinfo' as standalone extra7-namespace invariant."
    - "NEW in extra7 — Axis 3: ZoneInfoNotFoundError.__bases__[0].__name__ == 'KeyError' as standalone extra7-namespace invariant."
    - "NEW in extra7 — Axis 4: ZoneInfo.__qualname__ == 'ZoneInfo' as standalone extra7-namespace invariant."
    - "zoneinfo.ZoneInfo.__name__ == 'ZoneInfo' — verified Python 3.12."
    - "zoneinfo.ZoneInfo.__qualname__ == 'ZoneInfo' — verified Python 3.12."
    - "zoneinfo.ZoneInfoNotFoundError.__name__ == 'ZoneInfoNotFoundError' — verified Python 3.12."
    - "zoneinfo.ZoneInfoNotFoundError.__qualname__ == 'ZoneInfoNotFoundError' — verified Python 3.12."
    - "zoneinfo.available_timezones.__name__ == 'available_timezones' — verified Python 3.12."
    - "zoneinfo.available_timezones.__qualname__ == 'available_timezones' — verified Python 3.12."
    - "zoneinfo.ZoneInfo.__bases__[0].__name__ == 'tzinfo' — verified Python 3.12."
    - "zoneinfo.ZoneInfoNotFoundError.__bases__[0].__name__ == 'KeyError' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ for ZoneInfo, ZoneInfoNotFoundError, available_timezones
#
# Prior specs cover __name__ for these individually. This spec consolidates
# all three in a single table in the extra7 namespace.
# ---------------------------------------------------------------------------

table zoneinfo_extra7.names:
  kind: python_call_eq
  category: class_names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [ZoneInfo,               ZoneInfo.__name__.__eq__,               ["ZoneInfo"],               true]
    - [ZoneInfoNotFoundError,  ZoneInfoNotFoundError.__name__.__eq__,  ["ZoneInfoNotFoundError"],   true]
    - [available_timezones,    available_timezones.__name__.__eq__,    ["available_timezones"],     true]

# ---------------------------------------------------------------------------
# ZoneInfo.__bases__[0].__name__ == 'tzinfo'
#
# zoneinfo_extra2 covers this check. This spec re-anchors it as a standalone
# invariant in the extra7 namespace, using the __bases__.__getitem__ form.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra7.ZoneInfo.base_name:
  description: "zoneinfo.ZoneInfo.__bases__[0].__name__ == 'tzinfo' — ZoneInfo directly subclasses tzinfo"
  category: class_hierarchy
  kind: python_call_eq
  function: ZoneInfo.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["tzinfo"]
  expected: true

# ---------------------------------------------------------------------------
# ZoneInfoNotFoundError.__bases__[0].__name__ == 'KeyError'
#
# zoneinfo_extra4 and zoneinfo_extra5 cover this check. This spec re-anchors
# it as a standalone invariant in the extra7 namespace.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra7.ZoneInfoNotFoundError.base_name:
  description: "zoneinfo.ZoneInfoNotFoundError.__bases__[0].__name__ == 'KeyError' — direct parent is KeyError"
  category: class_hierarchy
  kind: python_call_eq
  function: ZoneInfoNotFoundError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["KeyError"]
  expected: true

# ---------------------------------------------------------------------------
# ZoneInfo.__qualname__ == 'ZoneInfo'
#
# zoneinfo_extra2 and zoneinfo_extra5 cover ZoneInfo.__qualname__. This spec
# re-anchors it as a standalone invariant in the extra7 namespace.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra7.ZoneInfo.qualname:
  description: "zoneinfo.ZoneInfo.__qualname__ == 'ZoneInfo'"
  category: class_qualnames
  kind: python_call_eq
  function: ZoneInfo.__qualname__.__eq__
  args: ["ZoneInfo"]
  expected: true

# ---------------------------------------------------------------------------
# ZoneInfoNotFoundError.__qualname__ == 'ZoneInfoNotFoundError'
#
# zoneinfo_extra2 and zoneinfo_extra5 cover ZoneInfoNotFoundError.__qualname__.
# This spec re-anchors it as a standalone invariant in the extra7 namespace.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra7.ZoneInfoNotFoundError.qualname:
  description: "zoneinfo.ZoneInfoNotFoundError.__qualname__ == 'ZoneInfoNotFoundError'"
  category: class_qualnames
  kind: python_call_eq
  function: ZoneInfoNotFoundError.__qualname__.__eq__
  args: ["ZoneInfoNotFoundError"]
  expected: true
