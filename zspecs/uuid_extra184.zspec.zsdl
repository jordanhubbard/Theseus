spec: uuid_extra184
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "uuid.uuid4, uuid.uuid1, and uuid.uuid5 are module-level functions defined in uuid.py."
    - "uuid.uuid4.__class__.__name__ == 'function' — these are plain Python functions, not builtin_function_or_method."
    - "uuid.uuid4.__module__ == 'uuid' and uuid.uuid4.__name__ == 'uuid4' — the function's __name__ matches its string name."
    - "uuid.uuid4.__qualname__ == 'uuid4' — no class nesting, so qualname equals name."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid4 function identity — name, module, class
# ---------------------------------------------------------------------------

table uuidfuncs184.uuid4.identity:
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidfuncs184

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_name,       uuid4.__name__.__eq__,          ["uuid4"],    true, "uuid.uuid4.__name__ == 'uuid4'"]
    - [uuid4_module,     uuid4.__module__.__eq__,         ["uuid"],     true, "uuid.uuid4.__module__ == 'uuid'"]
    - [uuid4_class_name, uuid4.__class__.__name__.__eq__, ["function"], true, "uuid.uuid4.__class__.__name__ == 'function'"]

# ---------------------------------------------------------------------------
# uuid1 and uuid5 function identity — name and module
# ---------------------------------------------------------------------------

table uuidfuncs184.uuid1_uuid5.identity:
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidfuncs184

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_name,   uuid1.__name__.__eq__,   ["uuid1"], true, "uuid.uuid1.__name__ == 'uuid1'"]
    - [uuid1_module, uuid1.__module__.__eq__,  ["uuid"],  true, "uuid.uuid1.__module__ == 'uuid'"]
    - [uuid5_name,   uuid5.__name__.__eq__,   ["uuid5"], true, "uuid.uuid5.__name__ == 'uuid5'"]
    - [uuid5_module, uuid5.__module__.__eq__,  ["uuid"],  true, "uuid.uuid5.__module__ == 'uuid'"]

# ---------------------------------------------------------------------------
# uuid4 qualname
# ---------------------------------------------------------------------------

table uuidfuncs184.uuid4.qualname:
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidfuncs184

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_qualname, uuid4.__qualname__.__eq__, ["uuid4"], true, "uuid.uuid4.__qualname__ == 'uuid4' (no class nesting)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuidfuncs184.uuid4.name:
  description: "uuid.uuid4.__name__ == 'uuid4'"
  category: function_identity
  kind: python_call_eq
  function: uuid4.__name__.__eq__
  args: ["uuid4"]
  expected: true

invariant uuidfuncs184.uuid4.module:
  description: "uuid.uuid4.__module__ == 'uuid'"
  category: function_identity
  kind: python_call_eq
  function: uuid4.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuidfuncs184.uuid4.class_name:
  description: "uuid.uuid4.__class__.__name__ == 'function' — uuid4 is a plain Python function"
  category: function_identity
  kind: python_call_eq
  function: uuid4.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant uuidfuncs184.uuid1.name:
  description: "uuid.uuid1.__name__ == 'uuid1'"
  category: function_identity
  kind: python_call_eq
  function: uuid1.__name__.__eq__
  args: ["uuid1"]
  expected: true

invariant uuidfuncs184.uuid1.module:
  description: "uuid.uuid1.__module__ == 'uuid'"
  category: function_identity
  kind: python_call_eq
  function: uuid1.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuidfuncs184.uuid5.name:
  description: "uuid.uuid5.__name__ == 'uuid5'"
  category: function_identity
  kind: python_call_eq
  function: uuid5.__name__.__eq__
  args: ["uuid5"]
  expected: true

invariant uuidfuncs184.uuid5.module:
  description: "uuid.uuid5.__module__ == 'uuid'"
  category: function_identity
  kind: python_call_eq
  function: uuid5.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuidfuncs184.uuid4.qualname:
  description: "uuid.uuid4.__qualname__ == 'uuid4' — no class nesting, qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: uuid4.__qualname__.__eq__
  args: ["uuid4"]
  expected: true

