spec: concurrent_futures_extra1051
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks concurrent.futures.Future, ThreadPoolExecutor, CancelledError, TimeoutError, BrokenExecutor class identity and __init_subclass__ qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra1051.init_subclass_qualnames:
  description: "concurrent.futures class __init_subclass__ qualname identity (should match object.__init_subclass__)"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: cf1051is
  columns: [id, function, args, expected]
  rows:
    - [cf1051is001, concurrent.futures.Future.__init_subclass__.__qualname__.__eq__,           ["object.__init_subclass__"], true]
    - [cf1051is002, concurrent.futures.ThreadPoolExecutor.__init_subclass__.__qualname__.__eq__, ["object.__init_subclass__"], true]
    - [cf1051is003, concurrent.futures.ProcessPoolExecutor.__init_subclass__.__qualname__.__eq__, ["object.__init_subclass__"], true]
    - [cf1051is004, concurrent.futures.Executor.__init_subclass__.__qualname__.__eq__,         ["object.__init_subclass__"], true]
    - [cf1051is005, concurrent.futures.CancelledError.__init_subclass__.__qualname__.__eq__,   ["object.__init_subclass__"], true]

table concurrent_futures_extra1051.exception_module_identity:
  description: "concurrent.futures exception class __module__ identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: cf1051em
  columns: [id, function, args, expected]
  rows:
    - [cf1051em001, concurrent.futures.CancelledError.__module__.__eq__,   ["concurrent.futures._base"], true]
    - [cf1051em002, concurrent.futures.TimeoutError.__module__.__eq__,     ["concurrent.futures._base"], true]
    - [cf1051em003, concurrent.futures.BrokenExecutor.__module__.__eq__,   ["concurrent.futures._base"], true]
    - [cf1051em004, concurrent.futures.CancelledError.__qualname__.__eq__, ["CancelledError"],            true]
    - [cf1051em005, concurrent.futures.TimeoutError.__qualname__.__eq__,   ["TimeoutError"],              true]
    - [cf1051em006, concurrent.futures.BrokenExecutor.__qualname__.__eq__, ["BrokenExecutor"],            true]

table concurrent_futures_extra1051.module_doc_identity:
  description: "concurrent.futures module __doc__ class identity and Future class_getitem qualname"
  kind: python_call_eq
  category: module_identity
  id_prefix: cf1051md
  columns: [id, function, args, expected]
  rows:
    - [cf1051md001, concurrent.futures.__doc__.__class__.__name__.__eq__,                    ["str"],                       true]
    - [cf1051md002, concurrent.futures.__name__.__eq__,                                      ["concurrent.futures"],        true]
    - [cf1051md003, concurrent.futures.Future.__class__.__name__.__eq__,                     ["type"],                      true]
    - [cf1051md004, concurrent.futures.Future.__class_getitem__.__qualname__.__eq__,         ["object.__class_getitem__"],  true]
    - [cf1051md005, concurrent.futures.ThreadPoolExecutor.__class_getitem__.__qualname__.__eq__, ["object.__class_getitem__"], true]
