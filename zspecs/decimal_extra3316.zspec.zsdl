spec: dc3316
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 668 (dc3316): __ipow__, __ilshift__, __irshift__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "Theme: __ipow__, __ilshift__, __irshift__ dict-presence (in-place **=, <<=, >>=)."
    - "KEY FINDING: decimal.Decimal does NOT define __ipow__ in its own __dict__: Decimal is immutable; augmented assignment (d **= x) rebinds the variable to a new Decimal via __pow__, not __ipow__. This holds even though __pow__ and __rpow__ were True in waves 660/664."
    - "decimal.Decimal does NOT define __ilshift__ in its own __dict__: false. Decimal is a decimal floating-point numeric type; bitwise shift is not defined for arbitrary-precision decimal arithmetic."
    - "decimal.Decimal does NOT define __irshift__ in its own __dict__: false. Same reason; bitwise right-shift has no meaning for decimal.Decimal values."
    - "decimal.Context does NOT define __ipow__, __ilshift__, or __irshift__ in its own __dict__: Context is a precision/rounding configuration object, not a numeric operand."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow are exception subclasses with no arithmetic protocol defined in their own __dict__."
    - "Consistent with wave 666 (dc3286: __iadd__, __isub__, __imul__ all false) and wave 667 (dc3301: __itruediv__, __ifloordiv__, __imod__ all false): the complete set of in-place augmented assignment operators is absent from decimal.Decimal.__dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __ipow__ dict-presence — operator.contains(Cls.__dict__, '__ipow__')
#
# decimal.Decimal does NOT define __ipow__ in its own __dict__: false.
# Decimal is immutable; d **= x rebinds d via __pow__, not __ipow__.
# Decimal defines __pow__, __rpow__ (waves 660/664) but deliberately omits
# __ipow__, confirming immutability. All decimal classes: false.
# ---------------------------------------------------------------------------

table dc3316.ipow:
  description: "decimal types __ipow__ dict-presence checks; wave 668"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3316

  columns: [id, function, args, expected]
  rows:
    - ["dc3316001", operator.contains, [decimal.Decimal.__dict__,          "__ipow__"], false]
    - ["dc3316002", operator.contains, [decimal.Context.__dict__,           "__ipow__"], false]
    - ["dc3316003", operator.contains, [decimal.DecimalException.__dict__,  "__ipow__"], false]
    - ["dc3316004", operator.contains, [decimal.InvalidOperation.__dict__,  "__ipow__"], false]
    - ["dc3316005", operator.contains, [decimal.Overflow.__dict__,          "__ipow__"], false]
    - ["dc3316006", operator.contains, [decimal.Underflow.__dict__,         "__ipow__"], false]

# ---------------------------------------------------------------------------
# __ilshift__ dict-presence — operator.contains(Cls.__dict__, '__ilshift__')
#
# decimal.Decimal does NOT define __ilshift__ in its own __dict__: false.
# Bitwise left-shift is not defined for decimal floating-point arithmetic;
# Decimal neither defines __lshift__ nor __ilshift__.
# All decimal classes: false.
# ---------------------------------------------------------------------------

