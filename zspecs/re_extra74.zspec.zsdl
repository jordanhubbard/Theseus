spec: re_extra74
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra73."
    - "Prior specs covered: Pattern/Match class identity (__name__/__module__/__qualname__); Pattern/Match __class__.__name__ == 'type'; Pattern/Match __dict__ membership (match, search, group, span); compile __class__.__name__."
    - "re_extra73 covers re.Pattern and re.Match type identity and __dict__ membership."
    - "This spec covers: Pattern method __class__.__name__ == 'method_descriptor' for match/search/findall/sub; Match method __class__.__name__ for group/groups/span; re flag __class__.__name__ == 'RegexFlag' for IGNORECASE/MULTILINE/DOTALL."
    - "re.Pattern.match.__class__.__name__ == 'method_descriptor' — C type method on Pattern."
    - "re.Pattern.search.__class__.__name__ == 'method_descriptor' — C type method on Pattern."
    - "re.Pattern.findall.__class__.__name__ == 'method_descriptor' — C type method on Pattern."
    - "re.Pattern.sub.__class__.__name__ == 'method_descriptor' — C type method on Pattern."
    - "re.Match.group.__class__.__name__ == 'method_descriptor' — C type method on Match."
    - "re.Match.groups.__class__.__name__ == 'method_descriptor' — C type method on Match."
    - "re.Match.span.__class__.__name__ == 'method_descriptor' — C type method on Match."
    - "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — IntFlag enum member."
    - "re.MULTILINE.__class__.__name__ == 'RegexFlag' — IntFlag enum member."
    - "re.DOTALL.__class__.__name__ == 'RegexFlag' — IntFlag enum member."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pattern method descriptor identity — match, search, findall, sub
# Pattern is a C type; its methods are C method_descriptors.
# re_extra73 checks __dict__ membership; this spec checks __class__.__name__.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra74.Pattern_method_classes:
  description: "re.Pattern C methods have __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: method_descriptors
  id_prefix: remore74

  columns: [id, function, args, expected]
  rows:
    - [match_class,   Pattern.match.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [search_class,  Pattern.search.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [findall_class, Pattern.findall.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [sub_class,     Pattern.sub.__class__.__name__.__eq__,     ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# Match method descriptor identity — group, groups, span
# Match is a C type; its methods are C method_descriptors.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra74.Match_method_classes:
  description: "re.Match C methods have __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: method_descriptors
  id_prefix: remore74

  columns: [id, function, args, expected]
  rows:
    - [group_class,  Match.group.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [groups_class, Match.groups.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [span_class,   Match.span.__class__.__name__.__eq__,   ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# re flag __class__.__name__ == 'RegexFlag'
# IGNORECASE, MULTILINE, DOTALL are IntFlag enum members.
# Their __class__.__name__ is 'RegexFlag', not 'int'.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra74.flag_class_names:
  description: "re flags IGNORECASE, MULTILINE, DOTALL are RegexFlag enum members"
  kind: python_call_eq
  category: constants
  id_prefix: remore74

  columns: [id, function, args, expected]
  rows:
    - [ignorecase_class, IGNORECASE.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [multiline_class,  MULTILINE.__class__.__name__.__eq__,  ["RegexFlag"], true]
    - [dotall_class,     DOTALL.__class__.__name__.__eq__,     ["RegexFlag"], true]

# ---------------------------------------------------------------------------
# Pattern and Match __dict__ membership for method_descriptor methods
# Confirming that findall and sub are present alongside match/search (re_extra73)
# and groups is present alongside group/span (re_extra73).
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra74.Pattern_Match_dict_extra:
  description: "re.Pattern and re.Match __dict__ contain additional C method implementations"
  kind: python_call_eq
  category: class_dict
  id_prefix: remore74

  columns: [id, function, args, expected]
  rows:
    - [pattern_findall, "Pattern.__dict__.__contains__", ["findall"], true]
    - [pattern_sub,     "Pattern.__dict__.__contains__", ["sub"],     true]
    - [match_groups,    "Match.__dict__.__contains__",   ["groups"],  true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra74.Pattern_match.method_descriptor:
  description: "re.Pattern.match.__class__.__name__ == 'method_descriptor'"
  category: method_descriptors
  kind: python_call_eq
  function: Pattern.match.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant re_extra74.Pattern_findall.method_descriptor:
  description: "re.Pattern.findall.__class__.__name__ == 'method_descriptor'"
  category: method_descriptors
  kind: python_call_eq
  function: Pattern.findall.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant re_extra74.Match_group.method_descriptor:
  description: "re.Match.group.__class__.__name__ == 'method_descriptor'"
  category: method_descriptors
  kind: python_call_eq
  function: Match.group.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant re_extra74.IGNORECASE.RegexFlag:
  description: "re.IGNORECASE.__class__.__name__ == 'RegexFlag'"
  category: constants
  kind: python_call_eq
  function: IGNORECASE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra74.DOTALL.RegexFlag:
  description: "re.DOTALL.__class__.__name__ == 'RegexFlag'"
  category: constants
  kind: python_call_eq
  function: DOTALL.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true
