spec: re_extra520
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re module top-level functions have __qualname__ equal to their simple name"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra520.function_qualnames:
  description: "re module function __qualname__ identity — all top-level re functions have qualname equal to simple name"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: re520fq

  columns: [id, function, args, expected]
  rows:
    - [re520fq001, compile.__qualname__.__eq__,   ["compile"],   true]
    - [re520fq002, match.__qualname__.__eq__,     ["match"],     true]
    - [re520fq003, search.__qualname__.__eq__,    ["search"],    true]
    - [re520fq004, fullmatch.__qualname__.__eq__, ["fullmatch"], true]
    - [re520fq005, findall.__qualname__.__eq__,   ["findall"],   true]
    - [re520fq006, finditer.__qualname__.__eq__,  ["finditer"],  true]
    - [re520fq007, sub.__qualname__.__eq__,       ["sub"],       true]
    - [re520fq008, subn.__qualname__.__eq__,      ["subn"],      true]
    - [re520fq009, split.__qualname__.__eq__,     ["split"],     true]
    - [re520fq010, escape.__qualname__.__eq__,    ["escape"],    true]
    - [re520fq011, purge.__qualname__.__eq__,     ["purge"],     true]
