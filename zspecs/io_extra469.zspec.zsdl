spec: io_extra469
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module constants, open function, and exception class identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "DEFAULT_BUFFER_SIZE is documented as 8192 and has been stable across Python versions"
    - "open_code was added in Python 3.8 for auditing hooks support"
    - "UnsupportedOperation inherits from both OSError and io.UnsupportedOperation base"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra469.constants:
  description: "io module seek constants and DEFAULT_BUFFER_SIZE identity"
  kind: python_call_eq
  category: constants
  id_prefix: IOC

  columns: [id, function, args, expected]
  rows:
    - [IOC001, io.DEFAULT_BUFFER_SIZE.__eq__, [8192], true]
    - [IOC002, io.SEEK_SET.__eq__, [0], true]
    - [IOC003, io.SEEK_CUR.__eq__, [1], true]
    - [IOC004, io.SEEK_END.__eq__, [2], true]

table io_extra469.open_identity:
  description: "io.open and io.open_code function name and module identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: IOO

  columns: [id, function, args, expected]
  rows:
    - [IOO001, io.open.__name__.__eq__, ["open"], true]
    - [IOO002, io.open.__module__.__eq__, ["io"], true]
    - [IOO003, io.open_code.__name__.__eq__, ["open_code"], true]

table io_extra469.unsupported_operation:
  description: "io.UnsupportedOperation exception class identity and inheritance"
  kind: python_call_eq
  category: exception_identity
  id_prefix: IOU

  columns: [id, function, args, expected]
  rows:
    - [IOU001, io.UnsupportedOperation.__name__.__eq__, ["UnsupportedOperation"], true]
    - [IOU002, io.UnsupportedOperation.__module__.__eq__, ["io"], true]
    - [IOU003, "io.UnsupportedOperation.__bases__[0].__name__.__eq__", ["OSError"], true]
