  rows:
    - ["uu2281004", "uuid.SafeUUID.__mro__.__len__", [], 3]
    - ["uu2281005", "uuid.SafeUUID.__bases__.__len__", [], 1]
    - ["uu2281006", "uuid.SafeUUID.__dict__.__len__", [], 19]

