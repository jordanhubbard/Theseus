spec: uuid_extra2281
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 599 (_extra2281): class hierarchy metrics — MRO depth, base count, dict size."
    - "Covers uuid.UUID (pure-Python slotted class) and uuid.SafeUUID (Enum subclass)."
    - "uuid.UUID inherits directly from object (MRO length 2, bases length 1)."
    - "uuid.SafeUUID extends enum.Enum giving MRO: SafeUUID -> Enum -> object (length 3)."
    - "Neither class carries __abstractmethods__; accessing it raises AttributeError."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra2281.uuid_mro:
  description: "uuid.UUID MRO depth, base count, and dict size"
  kind: python_call_eq
  category: mro_depth
  id_prefix: uu2281

  columns: [id, function, args, expected]
  rows:
    - ["uu2281001", "uuid.UUID.__mro__.__len__", [], 2]
    - ["uu2281002", "uuid.UUID.__bases__.__len__", [], 1]
    - ["uu2281003", "uuid.UUID.__dict__.__len__", [], 37]

table uuid_extra2281.safeuuid_mro:
  description: "uuid.SafeUUID MRO depth, base count, and dict size"
  kind: python_call_eq
