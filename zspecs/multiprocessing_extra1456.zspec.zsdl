spec: multiprocessing_extra1456
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
    - "multiprocessing_extra1441.zspec.zsdl — covers __subclasshook__ and __instancecheck__ for multiprocessing classes"
  notes:
    - "Wave 544 (_extra1456): focuses on __contains__, __iter__, and __next__ method presence and type checks for multiprocessing classes."
    - "multiprocessing.Process, multiprocessing.pool.Pool, multiprocessing.queues.Queue, and multiprocessing.queues.SimpleQueue do NOT define __contains__ in their own __dict__."
    - "multiprocessing.Process, multiprocessing.pool.Pool, multiprocessing.queues.Queue, and multiprocessing.queues.SimpleQueue do NOT define __iter__ in their own __dict__."
    - "multiprocessing.Process, multiprocessing.pool.Pool, multiprocessing.queues.Queue, and multiprocessing.queues.SimpleQueue do NOT define __next__ in their own __dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra1456.contains_not_in_dict:
  description: "multiprocessing.__dict__ membership for __contains__ — Process, pool.Pool, queues.Queue, and queues.SimpleQueue do not define __contains__ in their own __dict__; all return False; verified with Python 3.14.3"
  kind: python_call_eq
  category: contains_dict_membership
  id_prefix: mp1456cd
  columns: [id, function, args, expected]
  rows:
    - [mp1456cd001, multiprocessing.Process.__dict__.__contains__,              ["__contains__"], false]
    - [mp1456cd002, multiprocessing.pool.Pool.__dict__.__contains__,            ["__contains__"], false]
    - [mp1456cd003, multiprocessing.queues.Queue.__dict__.__contains__,         ["__contains__"], false]
    - [mp1456cd004, multiprocessing.queues.SimpleQueue.__dict__.__contains__,   ["__contains__"], false]
    - [mp1456cd005, multiprocessing.Process.__dict__.__contains__,              ["__contains__"], false]
    - [mp1456cd006, multiprocessing.pool.Pool.__dict__.__contains__,            ["__contains__"], false]

