spec: in3226
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 662 (in3226): __radd__, __rsub__, __rmul__ dict-presence checks for inspect types."
    - "Theme: __radd__, __rsub__, __rmul__ dict-presence (reflected arithmetic operators)."
    - "Reflected operators are called when the left operand doesn't support the operation."
    - "All values False — these types have no reflected arithmetic protocol."
    - "No inspect type defines __radd__, __rsub__, or __rmul__ in its own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "None of these types implement reflected arithmetic protocols directly."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3226.radd:
  description: "inspect types __radd__ dict-presence checks; wave 662"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3226
  columns: [id, function, args, expected]
  rows:
    - ["in3226001", operator.contains, [inspect.Parameter.__dict__,           "__radd__"], false]
    - ["in3226002", operator.contains, [inspect.Signature.__dict__,           "__radd__"], false]
    - ["in3226003", operator.contains, [inspect.BoundArguments.__dict__,      "__radd__"], false]
    - ["in3226004", operator.contains, [inspect.FrameInfo.__dict__,           "__radd__"], false]
    - ["in3226005", operator.contains, [inspect.ArgInfo.__dict__,             "__radd__"], false]
    - ["in3226006", operator.contains, [inspect.FullArgSpec.__dict__,         "__radd__"], false]
    - ["in3226007", operator.contains, [inspect.Attribute.__dict__,           "__radd__"], false]
    - ["in3226008", operator.contains, [inspect.ClassFoundException.__dict__, "__radd__"], false]
    - ["in3226009", operator.contains, [inspect.EndOfBlock.__dict__,          "__radd__"], false]

