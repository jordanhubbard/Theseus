spec: concurrent_futures_extra214
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "Executor.submit.__qualname__ == 'Executor.submit'."
    - "Future.result.__qualname__ == 'Future.result'."
    - "Both Executor and Future methods have __module__ == 'concurrent.futures._base'."
    - "verified with Python 3.14.3."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures Executor method __name__ checks — extra214 namespace
#
# Executor defines submit, map, and shutdown as the three primary public
# methods; all have predictable __name__ values.
# ---------------------------------------------------------------------------

table concurrent_futures_extra214.executor_method_names:
  description: "Executor method __name__ checks in extra214 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cfe214exename

  columns: [id, function, args, expected, description]
  rows:
    - [submit_name,   Executor.submit.__name__.__eq__,   ["submit"],   true, "Executor.submit.__name__ == 'submit'"]
    - [map_name,      Executor.map.__name__.__eq__,      ["map"],      true, "Executor.map.__name__ == 'map'"]
    - [shutdown_name, Executor.shutdown.__name__.__eq__, ["shutdown"], true, "Executor.shutdown.__name__ == 'shutdown'"]

# ---------------------------------------------------------------------------
# concurrent.futures Executor method __qualname__ checks — extra214 namespace
# ---------------------------------------------------------------------------

table concurrent_futures_extra214.executor_method_qualnames:
  description: "Executor method __qualname__ checks in extra214 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cfe214exequal

  columns: [id, function, args, expected, description]
  rows:
    - [submit_qualname,   Executor.submit.__qualname__.__eq__,   ["Executor.submit"],   true, "Executor.submit.__qualname__ == 'Executor.submit'"]
    - [map_qualname,      Executor.map.__qualname__.__eq__,      ["Executor.map"],      true, "Executor.map.__qualname__ == 'Executor.map'"]
    - [shutdown_qualname, Executor.shutdown.__qualname__.__eq__, ["Executor.shutdown"], true, "Executor.shutdown.__qualname__ == 'Executor.shutdown'"]

# ---------------------------------------------------------------------------
# concurrent.futures Future method __name__ checks — extra214 namespace
#
# Future exposes result, cancel, done, cancelled, running, and
# add_done_callback as its primary public interface.
# ---------------------------------------------------------------------------

table concurrent_futures_extra214.future_method_names:
  description: "Future method __name__ checks in extra214 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cfe214futname

  columns: [id, function, args, expected, description]
  rows:
    - [result_name,            Future.result.__name__.__eq__,            ["result"],            true, "Future.result.__name__ == 'result'"]
    - [cancel_name,            Future.cancel.__name__.__eq__,            ["cancel"],            true, "Future.cancel.__name__ == 'cancel'"]
    - [done_name,              Future.done.__name__.__eq__,              ["done"],              true, "Future.done.__name__ == 'done'"]
    - [cancelled_name,         Future.cancelled.__name__.__eq__,         ["cancelled"],         true, "Future.cancelled.__name__ == 'cancelled'"]
    - [running_name,           Future.running.__name__.__eq__,           ["running"],           true, "Future.running.__name__ == 'running'"]
    - [add_done_callback_name, Future.add_done_callback.__name__.__eq__, ["add_done_callback"], true, "Future.add_done_callback.__name__ == 'add_done_callback'"]

# ---------------------------------------------------------------------------
# concurrent.futures Future method __qualname__ checks — extra214 namespace
# ---------------------------------------------------------------------------

table concurrent_futures_extra214.future_method_qualnames:
  description: "Future method __qualname__ checks in extra214 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cfe214futqual

  columns: [id, function, args, expected, description]
  rows:
    - [result_qualname, Future.result.__qualname__.__eq__, ["Future.result"], true, "Future.result.__qualname__ == 'Future.result'"]
    - [cancel_qualname, Future.cancel.__qualname__.__eq__, ["Future.cancel"], true, "Future.cancel.__qualname__ == 'Future.cancel'"]
    - [done_qualname,   Future.done.__qualname__.__eq__,   ["Future.done"],   true, "Future.done.__qualname__ == 'Future.done'"]

# ---------------------------------------------------------------------------
# concurrent.futures method __module__ checks — extra214 namespace
#
# Both Executor and Future methods resolve to concurrent.futures._base,
# the private implementation module.
# ---------------------------------------------------------------------------

table concurrent_futures_extra214.method_modules:
  description: "Executor and Future method __module__ checks in extra214 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cfe214mod

  columns: [id, function, args, expected, description]
  rows:
    - [executor_submit_module, Executor.submit.__module__.__eq__, ["concurrent.futures._base"], true, "Executor.submit.__module__ == 'concurrent.futures._base'"]
    - [future_result_module,   Future.result.__module__.__eq__,   ["concurrent.futures._base"], true, "Future.result.__module__ == 'concurrent.futures._base'"]

# ---------------------------------------------------------------------------
# Executor.submit __name__ standalone — extra214 namespace
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra214.executor_submit_name:
  description: "Executor.submit.__name__ == 'submit'"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.submit.__name__.__eq__
  args: ["submit"]
  expected: true

# ---------------------------------------------------------------------------
# Future.result __qualname__ standalone — extra214 namespace
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra214.future_result_qualname:
  description: "Future.result.__qualname__ == 'Future.result'"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.result.__qualname__.__eq__
  args: ["Future.result"]
  expected: true

# ---------------------------------------------------------------------------
# Future.add_done_callback __name__ standalone — extra214 namespace
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra214.future_add_done_callback_name:
  description: "Future.add_done_callback.__name__ == 'add_done_callback'"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.add_done_callback.__name__.__eq__
  args: ["add_done_callback"]
  expected: true
