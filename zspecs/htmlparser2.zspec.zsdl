spec: htmlparser2
version: ">=9.0.0"
backend: node(htmlparser2)

docs: https://github.com/fb55/htmlparser2#readme

provenance:
  derived_from:
    - "htmlparser2 README — https://github.com/fb55/htmlparser2#readme"
    - "WHATWG HTML parsing algorithm"
    - "Test vectors verified with htmlparser2 via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "htmlparser2 source"
  notes:
    - "Forgiving HTML/XML parser used by cheerio, marked, and other tools needing fast permissive parsing."
    - "Install: npm install htmlparser2"
    - "parseDocument(html) returns a Document with .children — array of Node objects."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure, error-tolerant parser; never throws."
  stderr: "null"
  stickiness: "N/A — each parse independent."
  codes: {}

invariant htmlparser2.parse_document_one_top_child:
  description: "parseDocument('<p>hi</p>') has 1 top-level child"
  category: parse_document
  kind: node_chain_eq
  entry: named
  function: parseDocument
  entry_args: ["<p>hi</p>"]
  chain:
    - {get: children}
    - {get: length}
  expected: 1

invariant htmlparser2.first_child_type_tag:
  description: "Top child of '<p>hi</p>' has type 'tag'"
  category: parse_document
  kind: node_chain_eq
  entry: named
  function: parseDocument
  entry_args: ["<p>hi</p>"]
  chain:
    - {get: children}
    - {method: at, args: [0]}
    - {get: type}
  expected: "tag"

invariant htmlparser2.first_child_name_p:
  description: "Top child name is 'p'"
  category: parse_document
  kind: node_chain_eq
  entry: named
  function: parseDocument
  entry_args: ["<p>hi</p>"]
  chain:
    - {get: children}
    - {method: at, args: [0]}
    - {get: name}
  expected: "p"

invariant htmlparser2.two_top_children:
  description: "'<p>1</p><p>2</p>' has 2 top-level children"
  category: parse_document
  kind: node_chain_eq
  entry: named
  function: parseDocument
  entry_args: ["<p>1</p><p>2</p>"]
  chain:
    - {get: children}
    - {get: length}
  expected: 2

invariant htmlparser2.empty_input_zero_children:
  description: "Empty input yields Document with 0 children"
  category: parse_document
  kind: node_chain_eq
  entry: named
  function: parseDocument
  entry_args: [""]
  chain:
    - {get: children}
    - {get: length}
  expected: 0

invariant htmlparser2.text_node_data:
  description: "Text content is exposed via the inner text node's data"
  category: parse_document
  kind: node_chain_eq
  entry: named
  function: parseDocument
  entry_args: ["<p>hello</p>"]
  chain:
    - {get: children}
    - {method: at, args: [0]}
    - {get: children}
    - {method: at, args: [0]}
    - {get: data}
  expected: "hello"

# parseDocument options — xmlMode
invariant htmlparser2.xml_mode_preserves_self_closing:
  description: "xmlMode parses '<a/>' as self-closing tag with no children"
  category: parse_document
  kind: node_chain_eq
  entry: named
  function: parseDocument
  entry_args: ["<a/>", {xmlMode: true}]
  chain:
    - {get: children}
    - {method: at, args: [0]}
    - {get: name}
  expected: "a"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:01:24Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
