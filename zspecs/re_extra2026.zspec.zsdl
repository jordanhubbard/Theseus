spec: re_extra2026
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 582 (_extra2026): __truediv__, __rtruediv__, __itruediv__, __floordiv__, __rfloordiv__, __ifloordiv__, __mod__, __rmod__, __imod__, __pow__, __rpow__, __divmod__, __rdivmod__ dict-presence checks."
    - "re.Pattern, re.Match, re.error, re.RegexFlag are regex types; none defines division, modulo, exponentiation, or divmod operators in its own __dict__."
    - "re.Pattern and re.Match are C types from _sre; their __dict__ contains only string-matching methods."
    - "re.error is a Python exception subclass; no arithmetic operators are defined in its own __dict__."
    - "re.RegexFlag is an IntFlag enum subclass; IntFlag arithmetic is inherited from int, not defined in RegexFlag.__dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __truediv__ / __rtruediv__ / __itruediv__ — true division dict-presence
# ---------------------------------------------------------------------------

table re_extra2026.truediv_protocol:
  description: "re types __truediv__/__rtruediv__/__itruediv__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2026

  columns: [id, function, args, expected]
  rows:
    - ["re2026001", "re.Pattern.__dict__.__contains__",   ["__truediv__"],  false]
    - ["re2026002", "re.Pattern.__dict__.__contains__",   ["__rtruediv__"], false]
    - ["re2026003", "re.Pattern.__dict__.__contains__",   ["__itruediv__"], false]
    - ["re2026004", "re.Match.__dict__.__contains__",     ["__truediv__"],  false]
    - ["re2026005", "re.Match.__dict__.__contains__",     ["__rtruediv__"], false]
    - ["re2026006", "re.Match.__dict__.__contains__",     ["__itruediv__"], false]
    - ["re2026007", "re.error.__dict__.__contains__",     ["__truediv__"],  false]
    - ["re2026008", "re.error.__dict__.__contains__",     ["__rtruediv__"], false]
    - ["re2026009", "re.error.__dict__.__contains__",     ["__itruediv__"], false]
    - ["re2026010", "re.RegexFlag.__dict__.__contains__", ["__truediv__"],  false]
    - ["re2026011", "re.RegexFlag.__dict__.__contains__", ["__rtruediv__"], false]
    - ["re2026012", "re.RegexFlag.__dict__.__contains__", ["__itruediv__"], false]

