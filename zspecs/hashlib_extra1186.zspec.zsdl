spec: hashlib_extra1186
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks type(hashlib).__name__/qualname/module (module type identity), hashlib.__dict__.__class__.__name__ (dict for module __dict__), hashlib.md5/__class__/__name__ (builtin_function_or_method), HASH instance digest_size for md5/sha256/sha512/sha384, and algorithms_guaranteed __contains__ for sha3_256/blake2b/sha3_512"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1186.module_type_identity:
  description: "type(hashlib).__name__/__qualname__/__module__ confirming hashlib is a module object"
  kind: python_call_eq
  category: module_type_identity
  id_prefix: hl1186mt
  columns: [id, function, args, expected]
  rows:
    - [hl1186mt001, type(hashlib).__name__.__eq__,                                ["module"],    true]
    - [hl1186mt002, type(hashlib).__qualname__.__eq__,                            ["module"],    true]
    - [hl1186mt003, type(hashlib).__module__.__eq__,                              ["builtins"],  true]
    - [hl1186mt004, type(hashlib).__name__.__class__.__name__.__eq__,             ["str"],       true]
    - [hl1186mt005, type(hashlib).__module__.__class__.__name__.__eq__,           ["str"],       true]
    - [hl1186mt006, hashlib.__dict__.__class__.__name__.__eq__,                   ["dict"],      true]
    - [hl1186mt007, hashlib.__dict__.__class__.__qualname__.__eq__,               ["dict"],      true]
    - [hl1186mt008, hashlib.__dict__.__class__.__module__.__eq__,                 ["builtins"],  true]
    - [hl1186mt009, hashlib.__dict__.__class__.__name__.__class__.__name__.__eq__, ["str"],      true]

table hashlib_extra1186.constructor_class_name:
  description: "hashlib.md5/sha1/sha256/sha512 __class__.__name__ and __module__ confirming they are builtin_function_or_method"
  kind: python_call_eq
  category: constructor_class_name
  id_prefix: hl1186cc
  columns: [id, function, args, expected]
  rows:
    - [hl1186cc001, hashlib.md5.__class__.__name__.__eq__,                        ["builtin_function_or_method"],  true]
    - [hl1186cc002, hashlib.sha1.__class__.__name__.__eq__,                       ["builtin_function_or_method"],  true]
    - [hl1186cc003, hashlib.sha256.__class__.__name__.__eq__,                     ["builtin_function_or_method"],  true]
    - [hl1186cc004, hashlib.sha512.__class__.__name__.__eq__,                     ["builtin_function_or_method"],  true]
    - [hl1186cc005, hashlib.sha224.__class__.__name__.__eq__,                     ["builtin_function_or_method"],  true]
    - [hl1186cc006, hashlib.sha384.__class__.__name__.__eq__,                     ["builtin_function_or_method"],  true]
    - [hl1186cc007, hashlib.md5.__class__.__module__.__eq__,                      ["builtins"],                    true]
    - [hl1186cc008, hashlib.sha256.__class__.__module__.__eq__,                   ["builtins"],                    true]
    - [hl1186cc009, hashlib.sha512.__class__.__module__.__eq__,                   ["builtins"],                    true]
    - [hl1186cc010, hashlib.md5.__class__.__name__.__class__.__name__.__eq__,     ["str"],                         true]

table hashlib_extra1186.hash_digest_size_values:
  description: "HASH instance digest_size values for md5/sha256/sha512/sha384 and algorithms_guaranteed membership for sha3_256/blake2b/sha3_512"
  kind: python_call_eq
  category: hash_digest_size_algorithms_guaranteed
  id_prefix: hl1186ds
  columns: [id, function, args, expected]
  rows:
    - [hl1186ds001, hashlib.md5().digest_size.__eq__,                             [16],          true]
    - [hl1186ds002, hashlib.sha256().digest_size.__eq__,                          [32],          true]
    - [hl1186ds003, hashlib.sha512().digest_size.__eq__,                          [64],          true]
    - [hl1186ds004, hashlib.sha384().digest_size.__eq__,                          [48],          true]
    - [hl1186ds005, hashlib.md5().digest_size.__class__.__name__.__eq__,          ["int"],       true]
    - [hl1186ds006, hashlib.sha256().digest_size.__class__.__name__.__eq__,       ["int"],       true]
    - [hl1186ds007, hashlib.sha512().digest_size.__class__.__module__.__eq__,     ["builtins"],  true]
    - [hl1186ds008, hashlib.algorithms_guaranteed.__contains__,                   ["sha3_256"],  true]
    - [hl1186ds009, hashlib.algorithms_guaranteed.__contains__,                   ["blake2b"],   true]
    - [hl1186ds010, hashlib.algorithms_guaranteed.__contains__,                   ["sha3_512"],  true]
    - [hl1186ds011, hashlib.algorithms_guaranteed.__contains__,                   ["sha256"],    true]
    - [hl1186ds012, hashlib.algorithms_guaranteed.__len__,                        [],            14]
