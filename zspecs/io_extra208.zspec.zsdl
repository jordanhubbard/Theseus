spec: io_extra208
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra207.zspec.zsdl — covers io class __class__.__name__ metaclass identity"
  notes:
    - "This spec covers io module-level dunder attributes: __name__, __package__, __spec__.name, __loader__.__class__.__name__, __doc__.__class__.__name__."
    - "io.__name__ == 'io'; the module name is the bare string 'io'; confirmed Python 3.14.3 macOS."
    - "io.__package__ == ''; io is a top-level module with no parent package; package is empty string; confirmed Python 3.14.3 macOS."
    - "io.__spec__.name == 'io'; the ModuleSpec name matches the module __name__; confirmed Python 3.14.3 macOS."
    - "io.__loader__.__class__.__name__ == 'type'; io's loader is the built-in BuiltinImporter-adjacent object whose class is 'type'; confirmed Python 3.14.3 macOS."
    - "io.__doc__.__class__.__name__ == 'str'; the module docstring is a str object; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io module __name__ identity
# __name__ == 'io', length == 2
# ---------------------------------------------------------------------------

table io_extra208.module_name:
  description: "io module __name__ attribute identity: value, equality, and length"
  kind: python_call_eq
  category: module_identity
  id_prefix: iomod208

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,         io.__name__.__eq__,    ["io"], true,  "io.__name__ == 'io'; the module name is the bare string 'io'; confirmed Python 3.14.3 macOS"]
    - [name_len,        io.__name__.__len__,   [],     2,     "io.__name__.__len__() == 2; 'io' has i(1)o(2); confirmed Python 3.14.3 macOS"]
    - [name_not_io2,    io.__name__.__eq__,    ["_io"], false, "io.__name__ != '_io'; the public wrapper module name differs from the C accelerator name; confirmed Python 3.14.3 macOS"]
    - [name_not_empty,  io.__name__.__eq__,    [""],   false,  "io.__name__ is not empty string; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io module __package__ and __spec__.name identity
# __package__ == '', __spec__.name == 'io'
# ---------------------------------------------------------------------------

table io_extra208.module_package_and_spec:
  description: "io module __package__ and __spec__.name attribute identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: iomod208

  columns: [id, function, args, expected, description]
  rows:
    - [package_eq,       io.__package__.__eq__,      [""],    true,  "io.__package__ == ''; io is a top-level module with no parent package; confirmed Python 3.14.3 macOS"]
    - [package_len,      io.__package__.__len__,     [],      0,     "io.__package__.__len__() == 0; empty string has length zero; confirmed Python 3.14.3 macOS"]
    - [spec_name_eq,     io.__spec__.name.__eq__,    ["io"],  true,  "io.__spec__.name == 'io'; the ModuleSpec name matches the module __name__; confirmed Python 3.14.3 macOS"]
    - [spec_name_len,    io.__spec__.name.__len__,   [],      2,     "io.__spec__.name.__len__() == 2; 'io' has i(1)o(2); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io module __loader__ and __doc__ class names
# __loader__.__class__.__name__ == 'type', __doc__.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table io_extra208.module_loader_and_doc:
  description: "io module __loader__.__class__.__name__ and __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: iomod208

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_eq,      io.__loader__.__class__.__name__.__eq__,    ["type"], true,  "io.__loader__.__class__.__name__ == 'type'; io's loader object has class name 'type'; confirmed Python 3.14.3 macOS"]
    - [loader_class_len,     io.__loader__.__class__.__name__.__len__,   [],       4,     "io.__loader__.__class__.__name__.__len__() == 4; 'type' has t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]
    - [doc_class_eq,         io.__doc__.__class__.__name__.__eq__,       ["str"],  true,  "io.__doc__.__class__.__name__ == 'str'; the module docstring is a str object; confirmed Python 3.14.3 macOS"]
    - [doc_class_len,        io.__doc__.__class__.__name__.__len__,      [],       3,     "io.__doc__.__class__.__name__.__len__() == 3; 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra208.name_eq:
  description: "io.__name__ == 'io' — the module name is the bare string 'io'; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: io.__name__.__eq__
  args: ["io"]
  expected: true

invariant io_extra208.name_len:
  description: "io.__name__.__len__() == 2 — 'io' has two characters i and o; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: io.__name__.__len__
  args: []
  expected: 2

invariant io_extra208.package_eq:
  description: "io.__package__ == '' — io is a top-level module with no parent package; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: io.__package__.__eq__
  args: [""]
  expected: true

invariant io_extra208.package_len:
  description: "io.__package__.__len__() == 0 — empty package string has length zero; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: io.__package__.__len__
  args: []
  expected: 0

invariant io_extra208.spec_name_eq:
  description: "io.__spec__.name == 'io' — the ModuleSpec name matches the module __name__; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: io.__spec__.name.__eq__
  args: ["io"]
  expected: true

invariant io_extra208.spec_name_len:
  description: "io.__spec__.name.__len__() == 2 — 'io' has i(1)o(2); confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: io.__spec__.name.__len__
  args: []
  expected: 2

invariant io_extra208.loader_class_name_eq:
  description: "io.__loader__.__class__.__name__ == 'type' — io's loader object has class name 'type'; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: io.__loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra208.doc_class_name_eq:
  description: "io.__doc__.__class__.__name__ == 'str' — the module docstring is a str object; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: io.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

