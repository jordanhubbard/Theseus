# HASH.__doc__.__len__()==442; no prior hashlib spec anchors HASH.__name__/__module__/
# __qualname__ equality strings as a table under hashdoc150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra150.HASH_class_identity:
  description: "hashlib._hashlib.HASH.__name__.__eq__('HASH')==True / __name__.__len__()==4 / HASH.__module__.__eq__('_hashlib')==True / HASH.__qualname__.__eq__('HASH')==True — HASH is the C-level hash object class; __name__ and __qualname__ are both 'HASH' (4 chars); __module__ is '_hashlib' (8 chars); extra144 anchors HASH.__doc__ length; first hashdoc150 anchor for HASH name/module/qualname equality strings"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc150

  columns: [id, function, args, expected, description]
  rows:
    - [hash_name_eq,     _hashlib.HASH.__name__.__eq__,     ["HASH"],     true, "hashlib._hashlib.HASH.__name__ == 'HASH' (4 chars; C-level hash object class name)"]
    - [hash_name_len,    _hashlib.HASH.__name__.__len__,    [],           4,    "hashlib._hashlib.HASH.__name__.__len__() is 4 ('HASH' = 4 chars)"]
    - [hash_module_eq,   _hashlib.HASH.__module__.__eq__,   ["_hashlib"], true, "hashlib._hashlib.HASH.__module__ == '_hashlib' (8 chars; same as the C extension module name)"]
    - [hash_qualname_eq, _hashlib.HASH.__qualname__.__eq__, ["HASH"],     true, "hashlib._hashlib.HASH.__qualname__ == 'HASH' (4 chars; same as __name__ for C extension type)"]

# ---------------------------------------------------------------------------
# hashlib._hashlib.__name__.__eq__('_hashlib') — standalone
#
# hashlib._hashlib.__name__ is '_hashlib' (8 chars). The underscore-prefixed private
# module name '_hashlib' is the naming convention used by CPython for C extension
# modules that back a public Python module: the public module 'hashlib' (7 chars)
# imports from the private '_hashlib' (8 chars, 1 extra char for the underscore).
# This pattern appears across CPython stdlib: struct/_struct, json/_json,
# pickle/_pickle, etc. The 8-char name '_hashlib' was established when the C
# extension was extracted from the pure-Python implementation. No prior hashlib spec
# anchors _hashlib.__name__.__eq__('_hashlib') as a standalone under hashdoc150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra150.chashlib_name_eq:
  description: "hashlib._hashlib.__name__.__eq__('_hashlib') == True — '_hashlib' (8 chars; underscore-prefixed private C extension name); CPython naming convention: private C extension 'underscore + public name'; parallels _struct/_json/_pickle pattern; 1 char longer than public 'hashlib' (7 chars); no prior hashlib spec anchors this as a standalone; first standalone under hashdoc150"
  category: identity
  kind: python_call_eq
  function: _hashlib.__name__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib._hashlib.__loader__.__class__.__name__.__eq__('ExtensionFileLoader') — standalone
#
# hashlib._hashlib.__loader__.__class__.__name__ is 'ExtensionFileLoader' (19 chars).
# The ExtensionFileLoader is used by CPython's import system to load C extension modules
# (.so files on Linux, .dylib or .so files on macOS, .pyd on Windows). Contrasting with
# SourceFileLoader (16 chars, used for .py files), ExtensionFileLoader (19 chars) is
# 3 chars longer. The _hashlib extension file is a .cpython-314-darwin.so file on macOS.
# No prior hashlib spec anchors _hashlib.__loader__.__class__.__name__ ==
# 'ExtensionFileLoader' as a standalone under hashdoc150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra150.chashlib_loader_ExtensionFileLoader:
  description: "hashlib._hashlib.__loader__.__class__.__name__.__eq__('ExtensionFileLoader') == True — 'ExtensionFileLoader' (19 chars); loads compiled .so C extension; 3 chars longer than SourceFileLoader (16 chars) used for .py files; the _hashlib .so file is named _hashlib.cpython-314-darwin.so on macOS; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc150"
  category: identity
  kind: python_call_eq
  function: _hashlib.__loader__.__class__.__name__.__eq__
  args: ["ExtensionFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.__module__.__eq__('_hashlib') — standalone
#
# hashlib._hashlib.HASH.__module__ is '_hashlib' (8 chars). The HASH class reports
# its __module__ as '_hashlib' (the C extension module) rather than 'hashlib' (the
# public Python module). This is because HASH is defined in the C extension code
# (Modules/_hashlib.c) and is not re-exported with a different module attribution.
# Comparing HASH.__module__ ('_hashlib', 8 chars) with file_digest.__module__
# ('hashlib', 7 chars, no underscore): HASH is a C-level type reporting the private
# name; file_digest is a Python-level function reporting the public name. No prior
# hashlib spec anchors _hashlib.HASH.__module__.__eq__('_hashlib') as a standalone
# under hashdoc150. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra150.HASH_module_eq:
  description: "hashlib._hashlib.HASH.__module__.__eq__('_hashlib') == True — '_hashlib' (8 chars); HASH reports the private C extension module name; contrasts with file_digest.__module__ == 'hashlib' (7 chars, no underscore; Python-level function reports public name); no prior hashlib spec anchors this as a standalone; first standalone under hashdoc150"
  category: identity
  kind: python_call_eq
  function: _hashlib.HASH.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# hashlib.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars). The public
# hashlib module (Lib/hashlib.py) is loaded as Python source by SourceFileLoader.
# This is consistent with uuid.__loader__.__class__.__name__ (also 'SourceFileLoader',
# 16 chars, anchored in uuid_extra138) and struct.__loader__.__class__.__name__ (also
# 'SourceFileLoader', 16 chars, anchored in struct_extra142). All three are pure-Python
# stdlib modules that happen to wrap C extensions. No prior hashlib spec anchors
# hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') as a standalone
# under hashdoc150. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra150.hashlib_loader_SourceFileLoader:
  description: "hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — 'SourceFileLoader' (16 chars); pure-Python Lib/hashlib.py wrapper loaded as Python source; same loader class as uuid (uuid_extra138) and struct (struct_extra142); all three are pure-Python wrappers around C extensions; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc150"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__package__.__eq__('') — standalone
#
# hashlib.__package__ is '' (empty string, len 0). An empty string is the standard
# __package__ value for top-level stdlib modules that are not sub-packages. This
# contrasts with sub-package modules that would have a non-empty __package__ naming
# their parent package. hashlib.__package__ ('') matches _hashlib.__package__ (''),
# uuid.__package__ (''), struct.__package__ (''), and socket.__package__ ('') — all
# five modules in the spec series have empty-string __package__ values, confirming
# they are all top-level modules. No prior hashlib spec anchors hashlib.__package__
# == '' as a standalone under hashdoc150. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra150.hashlib_package_empty:
  description: "hashlib.__package__.__eq__('') == True — empty string (len 0); standard __package__ for top-level stdlib modules (not sub-packages); matches _hashlib.__package__/uuid.__package__/struct.__package__/socket.__package__ (all empty string); no prior hashlib spec anchors this as a standalone; first standalone under hashdoc150"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

