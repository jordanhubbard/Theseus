spec: hashlib_extra150
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra149.zspec.zsdl — covers hashlib.__all__.__class__.__name__.__eq__('tuple') / __all__.__len__()==19 / __all__.__contains__('md5'/'sha256'/'new'/'file_digest'/'algorithms_guaranteed'/'blake2b'/'pbkdf2_hmac'/'sha3_256'/'algorithms_available') (table + invariants)."
    - "hashlib_extra148.zspec.zsdl — covers hashlib.file_digest/__qualname__.__eq__('file_digest') / __module__.__eq__('hashlib') / __class__.__name__.__eq__('function') / __code__.co_argcount==2 / __code__.co_name equality / hashlib.__spec__.name.__eq__('hashlib') / hashlib.__doc__.__len__()==2098 (table + invariants)."
    - "hashlib_extra147.zspec.zsdl — covers hashlib.sha3_256/sha3_512/sha3_224/sha3_384 __name__ equality strings / shake_128/shake_256 __name__ equality (table + invariants)."
    - "hashlib_extra146.zspec.zsdl — covers hashlib.pbkdf2_hmac and hashlib.scrypt function identity / blake2b/__module__.__eq__('_blake2') / blake2s/__module__.__eq__('_blake2') (table + invariants)."
    - "hashlib_extra145.zspec.zsdl — covers hashlib.algorithms_guaranteed/__class__.__name__.__eq__('set') / algorithms_available/__class__.__name__.__eq__('set') (table + invariants)."
    - "hashlib_extra144.zspec.zsdl — covers hashlib._hashlib.HASH/__doc__/__len__()==442 / HASH method qualname lengths (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ equality / algorithms_guaranteed.__len__()==14."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra149."
    - "Wave 316 theme: hashlib._hashlib C extension backing module identity — _hashlib.__name__.__eq__('_hashlib') (len 8) / _hashlib.__spec__.name.__eq__('_hashlib') (len 8) / _hashlib.__loader__.__class__.__name__.__eq__('ExtensionFileLoader') (len 19) / _hashlib.__package__.__eq__('') / _hashlib.HASH.__name__.__eq__('HASH') (len 4) / _hashlib.HASH.__module__.__eq__('_hashlib') / _hashlib.HASH.__qualname__.__eq__('HASH') / hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') (len 16) / hashlib.__package__.__eq__('')."
    - "hashlib._hashlib.__name__ == '_hashlib' (len 8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.__spec__.name == '_hashlib' (len 8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.__loader__.__class__.__name__ == 'ExtensionFileLoader' (len 19). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.__package__ == '' (empty string). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.__name__ == 'HASH' (len 4). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.__module__ == '_hashlib' (len 8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.__qualname__ == 'HASH' (len 4). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' (len 16). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__package__ == '' (empty string, len 0). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib._hashlib is the C extension module backing the hashlib public module. Its __name__ is '_hashlib' (8 chars, with underscore prefix) — the private name contrasting with hashlib's public name 'hashlib' (7 chars, no underscore). The _hashlib loader is ExtensionFileLoader (19 chars), since it is a compiled .so/.dylib C extension. The public hashlib module uses SourceFileLoader (16 chars) since Lib/hashlib.py is a pure-Python wrapper."
    - "Note: hashlib._hashlib.HASH is the C-level hash object class. Its __name__ and __qualname__ are both 'HASH' (4 chars), and its __module__ is '_hashlib' (8 chars). extra144 anchors HASH.__doc__.__len__()==442; this spec anchors HASH.__name__/__module__/__qualname__ equality strings for the first time under hashdoc150."
    - "Note: The contrast between hashlib (SourceFileLoader, 16 chars) and _hashlib (ExtensionFileLoader, 19 chars) is significant: the public 'hashlib' module is a pure-Python wrapper in Lib/hashlib.py, loaded as Python source. The private '_hashlib' C extension is loaded as a compiled binary (.so). The 3-char difference (19 - 16 = 3) mirrors the loader type difference."
    - "Note: hashlib.__package__ == '' (empty string, len 0). An empty string for __package__ is the standard value for top-level stdlib modules that are not sub-packages. This matches _hashlib.__package__ (also ''), uuid.__package__ (also ''), struct.__package__ (also ''), and socket.__package__ (also '')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib._hashlib.__name__.__eq__('_hashlib')
# hashlib._hashlib.__name__.__len__()==8
# hashlib._hashlib.__spec__.name.__eq__('_hashlib')
# hashlib._hashlib.__spec__.name.__len__()==8
#
# Wave 316 theme: hashlib._hashlib C extension __name__ and __spec__.name.
#
# _hashlib.__name__ is '_hashlib' (8 chars) — the private C extension name with
# underscore prefix. Its __spec__.name also returns '_hashlib' (8 chars), confirming
# consistency between __name__ and __spec__.name for the C extension module.
# The public hashlib module has __name__ 'hashlib' (7 chars), so the C extension
# adds 1 char (the underscore prefix). No prior hashlib spec anchors _hashlib.__name__
# equality string or __spec__.name equality string as a table under hashdoc150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra150.hashlib_c_extension_name_and_spec:
  description: "hashlib._hashlib.__name__.__eq__('_hashlib')==True / __name__.__len__()==8 / _hashlib.__spec__.name.__eq__('_hashlib')==True / __spec__.name.__len__()==8 — '_hashlib' (8 chars) is the private C extension name; 1 char longer than public 'hashlib' (7 chars) due to underscore prefix; __name__ and __spec__.name are both '_hashlib'; no prior hashlib spec anchors these under hashdoc150"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc150

  columns: [id, function, args, expected, description]
  rows:
    - [chashlib_name_eq,      _hashlib.__name__.__eq__,        ["_hashlib"], true, "hashlib._hashlib.__name__ == '_hashlib' (8 chars; private C extension name with underscore prefix)"]
    - [chashlib_name_len,     _hashlib.__name__.__len__,       [],           8,    "hashlib._hashlib.__name__.__len__() is 8 ('_hashlib' = underscore + 7-char 'hashlib')"]
    - [chashlib_spec_name_eq, _hashlib.__spec__.name.__eq__,   ["_hashlib"], true, "hashlib._hashlib.__spec__.name == '_hashlib' (8 chars; same as __name__ for C extension)"]
    - [chashlib_spec_name_len, _hashlib.__spec__.name.__len__, [],           8,    "hashlib._hashlib.__spec__.name.__len__() is 8 (consistent with __name__ length)"]

# ---------------------------------------------------------------------------
# hashlib._hashlib.__loader__.__class__.__name__.__eq__('ExtensionFileLoader')
# hashlib._hashlib.__loader__.__class__.__name__.__len__()==19
# hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader')
# hashlib.__loader__.__class__.__name__.__len__()==16
#
# Wave 316 theme: loader class name contrast between _hashlib (C extension) and hashlib
# (pure-Python wrapper).
#
# _hashlib uses ExtensionFileLoader (19 chars) because it is a compiled C extension.
# hashlib uses SourceFileLoader (16 chars) because Lib/hashlib.py is pure Python.
# The 3-char difference (19 - 16 = 3) between loader class names reflects the type
# difference between C extension and Python source loading. No prior hashlib spec
# anchors _hashlib.__loader__.__class__.__name__ or the contrast as a table under
# hashdoc150. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra150.loader_class_contrast:
  description: "hashlib._hashlib.__loader__/__class__.__name__.__eq__('ExtensionFileLoader')==True / __class__.__name__.__len__()==19 / hashlib.__loader__/__class__.__name__.__eq__('SourceFileLoader')==True / __class__.__name__.__len__()==16 — _hashlib (C extension) uses ExtensionFileLoader (19 chars); hashlib (pure-Python wrapper) uses SourceFileLoader (16 chars); 3-char difference reflects loader type; no prior hashlib spec anchors the contrast under hashdoc150"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc150

  columns: [id, function, args, expected, description]
  rows:
    - [chashlib_loader_ExtensionFileLoader, _hashlib.__loader__.__class__.__name__.__eq__,  ["ExtensionFileLoader"], true, "hashlib._hashlib.__loader__.__class__.__name__ == 'ExtensionFileLoader' (19 chars; C extension loader)"]
    - [chashlib_loader_len_19,              _hashlib.__loader__.__class__.__name__.__len__, [],                     19,   "hashlib._hashlib.__loader__.__class__.__name__.__len__() is 19 ('ExtensionFileLoader' = 19 chars)"]
    - [hashlib_loader_SourceFileLoader,     __loader__.__class__.__name__.__eq__,           ["SourceFileLoader"],   true, "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' (16 chars; pure-Python source loader)"]
    - [hashlib_loader_len_16,               __loader__.__class__.__name__.__len__,          [],                     16,   "hashlib.__loader__.__class__.__name__.__len__() is 16 ('SourceFileLoader' = 16 chars; 3 shorter than ExtensionFileLoader)"]

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.__name__.__eq__('HASH')
# hashlib._hashlib.HASH.__name__.__len__()==4
# hashlib._hashlib.HASH.__module__.__eq__('_hashlib')
