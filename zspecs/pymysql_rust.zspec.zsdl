spec: pymysql_rust
version: ">=3.9"
backend: rust_module(pymysql_rust)

docs: https://pymysql.readthedocs.io/

provenance:
  derived_from:
    - "https://pymysql.readthedocs.io/ — PyMySQL library"
  notes:
    - "PyMySQL is a pure-Python MySQL client."
    - "pymysql.connect is callable."
    - "pymysql.Connection is a class."
    - "pymysql.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pymysql_rust.has_connect:
  description: "pymysql.connect is callable"
  category: presence
  kind: python_call_eq
  function: pymysql_has_connect
  args: []
  expected: true

invariant pymysql_rust.has_connection_class:
  description: "pymysql.Connection is a class"
  category: presence
  kind: python_call_eq
  function: pymysql_has_connection_class
  args: []
  expected: true

invariant pymysql_rust.version_nonempty:
  description: "pymysql.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pymysql_version_nonempty
  args: []
  expected: true

