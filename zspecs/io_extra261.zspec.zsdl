spec: io_extra261
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers io.IncrementalNewlineDecoder, io.text_encoding, and io.BlockingIOError identity."
    - "io.IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder' — helper class for newline translation."
    - "io.IncrementalNewlineDecoder.__module__ == '_io' — the class is implemented in the C extension _io."
    - "io.IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' — directly inherits from object."
    - "io.text_encoding.__name__ == 'text_encoding' — function that normalises a text encoding argument."
    - "io.text_encoding.__module__ == '_io' — implemented in the C extension _io."
    - "io.text_encoding.__class__.__name__ == 'builtin_function_or_method' — a C-level builtin function."
    - "io.open_code.__name__ == 'open_code' — function for opening files for reading their code."
    - "io.open_code.__module__ == '_io' — implemented in the C extension _io."
    - "io.open_code.__class__.__name__ == 'builtin_function_or_method' — a C-level builtin function."
    - "io.BlockingIOError.__name__ == 'BlockingIOError' — re-export of the built-in BlockingIOError."
    - "io.BlockingIOError.__module__ == 'builtins' — defined in the builtins module, not io."
    - "io.BlockingIOError.__bases__[0].__name__ == 'OSError' — inherits from OSError."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.IncrementalNewlineDecoder class identity
#
# IncrementalNewlineDecoder is a C-level class (module == '_io') that directly
# inherits from object. It is used internally by TextIOWrapper for newline
# translation. Its __name__, __module__, base class, and class kind are checked.
# ---------------------------------------------------------------------------

table io_extra261.incremental_newline_decoder_identity:
  description: "io.IncrementalNewlineDecoder class identity — __name__, __module__, base class, and is_type; new to extra261"
  kind: python_call_eq
  category: identity
  id_prefix: ioxind261

  columns: [id, function, args, expected, description]
  rows:
    - [class_name,
       "IncrementalNewlineDecoder.__name__.__eq__",
       ["IncrementalNewlineDecoder"],
       true,
       "io.IncrementalNewlineDecoder.__name__.__eq__('IncrementalNewlineDecoder') == True — the helper class name is 'IncrementalNewlineDecoder'; it translates newline sequences incrementally for TextIOWrapper; str.__eq__('IncrementalNewlineDecoder') returns True; new to extra261"]
    - [class_module,
       "IncrementalNewlineDecoder.__module__.__eq__",
       ["_io"],
       true,
       "io.IncrementalNewlineDecoder.__module__.__eq__('_io') == True — the class is defined in the _io C extension, not the pure-Python io wrapper; str.__eq__('_io') returns True; new to extra261"]
    - [base_class_name,
       "IncrementalNewlineDecoder.__bases__.__getitem__",
       [0],
       "object",
       "io.IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' — IncrementalNewlineDecoder inherits directly from object; __getitem__(0).__name__ is 'object'; new to extra261"]
    - [is_type,
       "IncrementalNewlineDecoder.__class__.__name__.__eq__",
       ["type"],
       true,
       "io.IncrementalNewlineDecoder.__class__.__name__.__eq__('type') == True — IncrementalNewlineDecoder is a class object; its __class__ is the metaclass 'type'; str.__eq__('type') returns True; new to extra261"]

# ---------------------------------------------------------------------------
# Table 2: io.text_encoding and io.open_code function identity
#
# Both text_encoding and open_code are C-level builtin functions exported
# from the io module. Their __name__, __module__, and __class__.__name__
# are verified here.
# ---------------------------------------------------------------------------

table io_extra261.builtin_function_identity:
  description: "io.text_encoding and io.open_code builtin function identity — __name__, __module__, and class kind; new to extra261"
  kind: python_call_eq
  category: identity
  id_prefix: ioxbfi261

  columns: [id, function, args, expected, description]
  rows:
    - [text_encoding_name,
       "text_encoding.__name__.__eq__",
       ["text_encoding"],
       true,
       "io.text_encoding.__name__.__eq__('text_encoding') == True — text_encoding normalises a text encoding argument (e.g., None -> 'locale'); its __name__ is 'text_encoding'; str.__eq__('text_encoding') returns True; new to extra261"]
    - [text_encoding_module,
       "text_encoding.__module__.__eq__",
       ["_io"],
       true,
       "io.text_encoding.__module__.__eq__('_io') == True — text_encoding is implemented in the _io C extension; its __module__ is '_io'; str.__eq__('_io') returns True; new to extra261"]
    - [text_encoding_class,
       "text_encoding.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "io.text_encoding.__class__.__name__.__eq__('builtin_function_or_method') == True — text_encoding is a C-level function; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra261"]
    - [open_code_name,
       "open_code.__name__.__eq__",
       ["open_code"],
       true,
       "io.open_code.__name__.__eq__('open_code') == True — open_code opens a file for reading its code, honouring any registered code path hooks; its __name__ is 'open_code'; str.__eq__('open_code') returns True; new to extra261"]
    - [open_code_module,
       "open_code.__module__.__eq__",
       ["_io"],
       true,
       "io.open_code.__module__.__eq__('_io') == True — open_code is implemented in the _io C extension; its __module__ is '_io'; str.__eq__('_io') returns True; new to extra261"]
    - [open_code_class,
       "open_code.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "io.open_code.__class__.__name__.__eq__('builtin_function_or_method') == True — open_code is a C-level function; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra261"]

# ---------------------------------------------------------------------------
# Table 3: io.BlockingIOError class identity
#
# io.BlockingIOError is a re-export of the built-in BlockingIOError exception.
# Its __module__ is 'builtins' (not 'io'), and it inherits from OSError.
# ---------------------------------------------------------------------------

table io_extra261.blocking_io_error_identity:
  description: "io.BlockingIOError class identity — __name__, __module__, base class, and is_type; new to extra261"
  kind: python_call_eq
  category: identity
  id_prefix: ioxbie261

  columns: [id, function, args, expected, description]
  rows:
    - [class_name,
       "BlockingIOError.__name__.__eq__",
       ["BlockingIOError"],
       true,
       "io.BlockingIOError.__name__.__eq__('BlockingIOError') == True — BlockingIOError is the exception raised for non-blocking I/O operations that would block; its __name__ is 'BlockingIOError'; str.__eq__('BlockingIOError') returns True; new to extra261"]
    - [class_module,
       "BlockingIOError.__module__.__eq__",
       ["builtins"],
       true,
       "io.BlockingIOError.__module__.__eq__('builtins') == True — BlockingIOError is a built-in exception re-exported by io; its __module__ is 'builtins', not 'io'; str.__eq__('builtins') returns True; new to extra261"]
    - [base_class_name,
       "BlockingIOError.__bases__.__getitem__",
       [0],
       "OSError",
       "io.BlockingIOError.__bases__[0].__name__ == 'OSError' — BlockingIOError inherits directly from OSError; __getitem__(0).__name__ is 'OSError'; new to extra261"]
    - [is_type,
       "BlockingIOError.__class__.__name__.__eq__",
       ["type"],
       true,
       "io.BlockingIOError.__class__.__name__.__eq__('type') == True — BlockingIOError is a class object; its __class__ is the metaclass 'type'; str.__eq__('type') returns True; new to extra261"]

# ---------------------------------------------------------------------------
# Standalone invariants — io_extra261
# ---------------------------------------------------------------------------

invariant io_extra261.incremental_newline_decoder_name:
  description: "io.IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder' — the newline translation helper class; new to extra261"
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__name__.__eq__
  args: ["IncrementalNewlineDecoder"]
  expected: true

invariant io_extra261.incremental_newline_decoder_module:
  description: "io.IncrementalNewlineDecoder.__module__ == '_io' — the class is defined in the _io C extension; new to extra261"
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra261.incremental_newline_decoder_base_is_object:
  description: "io.IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' — IncrementalNewlineDecoder inherits directly from object; new to extra261"
  kind: python_call_eq
  function: "IncrementalNewlineDecoder.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant io_extra261.incremental_newline_decoder_is_type:
  description: "io.IncrementalNewlineDecoder.__class__.__name__ == 'type' — IncrementalNewlineDecoder is a class object; new to extra261"
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra261.text_encoding_name:
  description: "io.text_encoding.__name__ == 'text_encoding' — the builtin function that normalises a text encoding argument; new to extra261"
  kind: python_call_eq
  function: text_encoding.__name__.__eq__
  args: ["text_encoding"]
  expected: true

invariant io_extra261.text_encoding_module:
  description: "io.text_encoding.__module__ == '_io' — text_encoding is implemented in the _io C extension; new to extra261"
  kind: python_call_eq
  function: text_encoding.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra261.text_encoding_is_builtin:
  description: "io.text_encoding.__class__.__name__ == 'builtin_function_or_method' — text_encoding is a C-level builtin; new to extra261"
  kind: python_call_eq
  function: text_encoding.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant io_extra261.open_code_name:
  description: "io.open_code.__name__ == 'open_code' — the builtin function for opening source code files; new to extra261"
  kind: python_call_eq
  function: open_code.__name__.__eq__
  args: ["open_code"]
  expected: true

invariant io_extra261.open_code_module:
  description: "io.open_code.__module__ == '_io' — open_code is implemented in the _io C extension; new to extra261"
  kind: python_call_eq
  function: open_code.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra261.open_code_is_builtin:
  description: "io.open_code.__class__.__name__ == 'builtin_function_or_method' — open_code is a C-level builtin; new to extra261"
  kind: python_call_eq
  function: open_code.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant io_extra261.blocking_io_error_name:
  description: "io.BlockingIOError.__name__ == 'BlockingIOError' — the exception for blocking I/O operations; new to extra261"
  kind: python_call_eq
  function: BlockingIOError.__name__.__eq__
  args: ["BlockingIOError"]
  expected: true

invariant io_extra261.blocking_io_error_module:
  description: "io.BlockingIOError.__module__ == 'builtins' — BlockingIOError is a re-exported built-in; its __module__ is 'builtins'; new to extra261"
  kind: python_call_eq
  function: BlockingIOError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant io_extra261.blocking_io_error_base_is_oserror:
  description: "io.BlockingIOError.__bases__[0].__name__ == 'OSError' — BlockingIOError inherits from OSError; new to extra261"
  kind: python_call_eq
  function: "BlockingIOError.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

invariant io_extra261.blocking_io_error_is_type:
  description: "io.BlockingIOError.__class__.__name__ == 'type' — BlockingIOError is a class object; new to extra261"
  kind: python_call_eq
  function: BlockingIOError.__class__.__name__.__eq__
  args: ["type"]
  expected: true
