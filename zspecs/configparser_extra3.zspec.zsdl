spec: configparser_extra3
version: ">=3.9"
backend: python_module(configparser)

docs: https://docs.python.org/3/library/configparser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/configparser.html — Python configparser module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/configparser.py"
  notes:
    - "This spec extends prior configparser specs."
    - "Focus: class names and exception names not yet covered."
    - "configparser.ConfigParser.__name__ == 'ConfigParser'."
    - "configparser.RawConfigParser.__name__ == 'RawConfigParser'."
    - "configparser.SafeConfigParser.__name__ == 'SafeConfigParser' (deprecated alias for ConfigParser)."
    - "configparser.Error.__name__ == 'Error'."
    - "configparser.NoSectionError.__name__ == 'NoSectionError'."
    - "configparser.NoOptionError.__name__ == 'NoOptionError'."
    - "configparser.DuplicateSectionError.__name__ == 'DuplicateSectionError'."
    - "configparser.DuplicateOptionError.__name__ == 'DuplicateOptionError'."
    - "configparser.MissingSectionHeaderError.__name__ == 'MissingSectionHeaderError'."
    - "configparser.ParsingError.__name__ == 'ParsingError'."
    - "configparser.DEFAULTSECT == 'DEFAULT'."
    - "configparser.MAX_INTERPOLATION_DEPTH == 10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table configparser_extra3.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [ConfigParser,    ConfigParser.__name__.__eq__,    ["ConfigParser"],    true]
    - [RawConfigParser, RawConfigParser.__name__.__eq__, ["RawConfigParser"], true]

table configparser_extra3.exception_names:
  kind: python_call_eq
  category: exceptions
  id_prefix: exc

  columns: [id, function, args, expected]
  rows:
    - [Error,                     Error.__name__.__eq__,                     ["Error"],                     true]
    - [NoSectionError,            NoSectionError.__name__.__eq__,            ["NoSectionError"],            true]
    - [NoOptionError,             NoOptionError.__name__.__eq__,             ["NoOptionError"],             true]
    - [DuplicateSectionError,     DuplicateSectionError.__name__.__eq__,     ["DuplicateSectionError"],     true]
    - [DuplicateOptionError,      DuplicateOptionError.__name__.__eq__,      ["DuplicateOptionError"],      true]
    - [MissingSectionHeaderError, MissingSectionHeaderError.__name__.__eq__, ["MissingSectionHeaderError"], true]
    - [ParsingError,              ParsingError.__name__.__eq__,              ["ParsingError"],              true]

invariant configparser_extra3.DEFAULTSECT.value:
  description: "configparser.DEFAULTSECT == 'DEFAULT'"
  category: constants
  kind: python_call_eq
  function: DEFAULTSECT.__eq__
  args: ["DEFAULT"]
  expected: true

invariant configparser_extra3.MAX_INTERPOLATION_DEPTH.value:
  description: "configparser.MAX_INTERPOLATION_DEPTH == 10"
  category: constants
  kind: python_call_eq
  function: MAX_INTERPOLATION_DEPTH.__eq__
  args: [10]
  expected: true

invariant configparser_extra3.Error.base:
  description: "configparser.Error.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant configparser_extra3.NoSectionError.base:
  description: "configparser.NoSectionError.__bases__[0].__name__ == 'Error'"
  category: exceptions
  kind: python_call_eq
  function: NoSectionError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"

invariant configparser_extra3.ConfigParser.instance_class:
  description: "configparser.ConfigParser().__class__.__name__ == 'ConfigParser'"
  category: ConfigParser
  kind: python_call_eq
  function: ConfigParser
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["ConfigParser"]
  expected: true

invariant configparser_extra3.ConfigParser.module:
  description: "configparser.ConfigParser.__module__ == 'configparser'"
  category: module
  kind: python_call_eq
  function: ConfigParser.__module__.__eq__
  args: ["configparser"]
  expected: true

invariant configparser_extra3.RawConfigParser.base:
  description: "configparser.RawConfigParser.__bases__[0].__name__ == 'MutableMapping'"
  category: hierarchy
  kind: python_call_eq
  function: RawConfigParser.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "MutableMapping"
