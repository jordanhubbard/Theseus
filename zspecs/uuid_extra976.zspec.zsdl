spec: uuid_extra976
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid.UUID method __qualname__ attributes and class identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra976.uuid_dunder_method_qualnames:
  description: "uuid.UUID dunder method __qualname__ identity"
  kind: python_call_eq
  category: dunder_qualnames
  id_prefix: uu976dq
  columns: [id, function, args, expected]
  rows:
    - [uu976dq001, uuid.UUID.__str__.__qualname__.__eq__,      ["UUID.__str__"],      true]
    - [uu976dq002, uuid.UUID.__repr__.__qualname__.__eq__,     ["UUID.__repr__"],     true]
    - [uu976dq003, uuid.UUID.__hash__.__qualname__.__eq__,     ["UUID.__hash__"],     true]
    - [uu976dq004, uuid.UUID.__eq__.__qualname__.__eq__,       ["UUID.__eq__"],       true]
    - [uu976dq005, uuid.UUID.__lt__.__qualname__.__eq__,       ["UUID.__lt__"],       true]
    - [uu976dq006, uuid.UUID.__int__.__qualname__.__eq__,      ["UUID.__int__"],      true]
    - [uu976dq007, uuid.UUID.__bytes__.__qualname__.__eq__,    ["UUID.__bytes__"],    true]
    - [uu976dq008, uuid.UUID.__getattr__.__qualname__.__eq__,  ["UUID.__getattr__"],  true]

table uuid_extra976.uuid_init_and_class_qualnames:
  description: "uuid.UUID constructor and class-level qualname checks"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: uu976cq
  columns: [id, function, args, expected]
  rows:
    - [uu976cq001, uuid.UUID.__init__.__qualname__.__eq__,     ["UUID.__init__"],     true]
    - [uu976cq002, uuid.UUID.__class__.__name__.__eq__,        ["type"],              true]
    - [uu976cq003, uuid.UUID.__module__.__eq__,                ["uuid"],              true]
    - [uu976cq004, uuid.UUID.__qualname__.__eq__,              ["UUID"],              true]
    - [uu976cq005, uuid.UUID.__setattr__.__qualname__.__eq__,  ["UUID.__setattr__"],  true]

table uuid_extra976.uuid_generator_function_qualnames:
  description: "uuid module generator function __qualname__ checks"
  kind: python_call_eq
  category: generator_qualnames
  id_prefix: uu976gq
  columns: [id, function, args, expected]
  rows:
    - [uu976gq001, uuid.uuid1.__qualname__.__eq__,   ["uuid1"],   true]
    - [uu976gq002, uuid.uuid3.__qualname__.__eq__,   ["uuid3"],   true]
    - [uu976gq003, uuid.uuid4.__qualname__.__eq__,   ["uuid4"],   true]
    - [uu976gq004, uuid.uuid5.__qualname__.__eq__,   ["uuid5"],   true]
    - [uu976gq005, uuid.uuid1.__class__.__name__.__eq__, ["function"], true]
    - [uu976gq006, uuid.uuid4.__class__.__name__.__eq__, ["function"], true]
