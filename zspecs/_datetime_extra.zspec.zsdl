spec: _datetime_extra
version: ">=3.9"
backend: python_module(_datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
  notes:
    - "This spec extends datetime.zspec.zsdl, datetime_extra.zspec.zsdl, datetime_extra2.zspec.zsdl, and datetime_timedelta.zspec.zsdl."
    - "_datetime is the C accelerator for the datetime stdlib module."
    - "_datetime.datetime.__module__ == 'datetime' (the public module name), not '_datetime' — CPython deliberately sets the module attribute to the public name so that instances pickle/repr correctly."
    - "_datetime.date.__module__ == 'datetime' — same public-name convention applies to all five datetime types."
    - "_datetime.time.__module__ == 'datetime' — the time class (not the time module)."
    - "_datetime.timedelta.__module__ == 'datetime'."
    - "_datetime.timezone.__module__ == 'datetime'."
    - "All five types expose __name__ matching their public Python names: 'datetime', 'date', 'time', 'timedelta', 'timezone'."
    - "_datetime.datetime.__class__.__name__ == 'type' — the C type is a class object (metatype: type)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ checks — all five _datetime types
# ---------------------------------------------------------------------------

invariant _datetime_extra.datetime.name:
  description: "_datetime.datetime.__name__ == 'datetime'"
  category: classnames
  kind: python_call_eq
  function: datetime.__name__.__eq__
  args: ["datetime"]
  expected: true

invariant _datetime_extra.date.name:
  description: "_datetime.date.__name__ == 'date'"
  category: classnames
  kind: python_call_eq
  function: date.__name__.__eq__
  args: ["date"]
  expected: true

invariant _datetime_extra.time.name:
  description: "_datetime.time.__name__ == 'time'"
  category: classnames
  kind: python_call_eq
  function: time.__name__.__eq__
  args: ["time"]
  expected: true

invariant _datetime_extra.timedelta.name:
  description: "_datetime.timedelta.__name__ == 'timedelta'"
  category: classnames
  kind: python_call_eq
  function: timedelta.__name__.__eq__
  args: ["timedelta"]
  expected: true

invariant _datetime_extra.timezone.name:
  description: "_datetime.timezone.__name__ == 'timezone'"
  category: classnames
  kind: python_call_eq
  function: timezone.__name__.__eq__
  args: ["timezone"]
  expected: true

# ---------------------------------------------------------------------------
# Class __module__ checks — all five types report 'datetime', not '_datetime'
# ---------------------------------------------------------------------------

table _datetime_extra.class_modules:
  kind: python_call_eq
  category: classnames
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [datetime,  datetime.__module__.__eq__,  ["datetime"], true]
    - [date,      date.__module__.__eq__,      ["datetime"], true]
    - [time,      time.__module__.__eq__,      ["datetime"], true]
    - [timedelta, timedelta.__module__.__eq__, ["datetime"], true]
    - [timezone,  timezone.__module__.__eq__,  ["datetime"], true]

# ---------------------------------------------------------------------------
# Metatype — all five types are class objects (type instances)
# ---------------------------------------------------------------------------

table _datetime_extra.class_metatypes:
  kind: python_call_eq
  category: classnames
  id_prefix: metatype

  columns: [id, function, args, expected]
  rows:
    - [datetime,  datetime.__class__.__name__.__eq__,  ["type"], true]
    - [date,      date.__class__.__name__.__eq__,      ["type"], true]
    - [time,      time.__class__.__name__.__eq__,      ["type"], true]
    - [timedelta, timedelta.__class__.__name__.__eq__, ["type"], true]
    - [timezone,  timezone.__class__.__name__.__eq__,  ["type"], true]

# ---------------------------------------------------------------------------
# timezone.utc — module attribute and class name
# timezone.utc is the UTC singleton; it must report __class__.__name__ == 'timezone'
# and belong to the 'datetime' module namespace.
# ---------------------------------------------------------------------------

invariant _datetime_extra.timezone.utc.class_name:
  description: "_datetime.timezone.utc.__class__.__name__ == 'timezone'"
  category: timezone_utc
  kind: python_call_eq
  function: timezone.utc.__class__.__name__.__eq__
  args: ["timezone"]
  expected: true

invariant _datetime_extra.timezone.utc.module:
  description: "_datetime.timezone.utc.__class__.__module__ == 'datetime'"
  category: timezone_utc
  kind: python_call_eq
  function: timezone.utc.__class__.__module__.__eq__
  args: ["datetime"]
  expected: true

# ---------------------------------------------------------------------------
# datetime inherits from date — class hierarchy
# ---------------------------------------------------------------------------

invariant _datetime_extra.datetime.base_is_date:
  description: "_datetime.datetime.__bases__[0].__name__ == 'date' — datetime subclasses date"
  category: hierarchy
  kind: python_call_eq
  function: datetime.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "date"
