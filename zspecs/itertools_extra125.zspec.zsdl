spec: itertools_extra125
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.product class slot qualnames and class identity (Wave 257)."
    - "itertools.product.__iter__.__qualname__ == 'product.__iter__' (len 16) — wrapper_descriptor. Verified with Python 3.14.3."
    - "itertools.product.__next__.__qualname__ == 'product.__next__' (len 16) — wrapper_descriptor. Verified with Python 3.14.3."
    - "itertools.product.__new__.__qualname__ == 'product.__new__' (len 15) — builtin_function_or_method. Verified with Python 3.14.3."
    - "itertools.product.__class__.__name__ == 'type' — product is a C extension type. Verified with Python 3.14.3."
    - "itertools.product.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.product.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.3."
    - "len(itertools.product.__mro__) == 2 — MRO is [product, object]. Verified with Python 3.14.3."
    - "itertools.product.__qualname__ == 'product' (len 7). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.product class identity and MRO
#
# Wave 257 theme: itertools.product C extension type identity.
#
# itertools.product.__class__.__name__ == 'type'
# itertools.product.__module__ == 'itertools'
# itertools.product.__qualname__ == 'product'
# len(itertools.product.__mro__) == 2
# itertools.product.__bases__[0].__name__ == 'object'
#
# product is a C extension type defined in Modules/itertoolsmodule.c;
# its metaclass is 'type'; it inherits directly from object; MRO length is 2.
# New to extra125.
# ---------------------------------------------------------------------------

table itertools_extra125.product_type_identity:
  description: "itertools.product C extension type identity: __class__.__name__, __module__, __qualname__, MRO len, __bases__[0]; wave 257; new to extra125"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsproduct125

  columns: [id, function, args, expected, description]
  rows:
    - [product_class_name_eq_type,
       "product.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.product.__class__.__name__.__eq__('type') == True — product is a C extension type defined in Modules/itertoolsmodule.c; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra125"]
    - [product_module_eq_itertools,
       "product.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — product is a C extension type defined in Modules/itertoolsmodule.c; the module initializer sets __module__ to 'itertools'; str.__eq__('itertools') returns True; new to extra125"]
    - [product_qualname_eq_product,
       "product.__qualname__.__eq__",
       ["product"],
       true,
       "itertools.product.__qualname__.__eq__('product') == True — product is defined at module scope in the C extension; its __qualname__ is the simple type name 'product'; str.__eq__('product') returns True; new to extra125"]
    - [product_qualname_len_eq_7,
       "product.__qualname__.__len__",
       [],
       7,
       "itertools.product.__qualname__.__len__() == 7 — __qualname__ is 'product' which has exactly 7 characters; len('product') == 7; new to extra125"]
    - [product_mro_len_eq_2,
       "product.__mro__.__len__",
       [],
       2,
       "itertools.product.__mro__.__len__() == 2 — product inherits directly from object with no intermediate bases; MRO is [product, object]; len(__mro__) is 2; new to extra125"]
    - [product_bases_first_eq_object,
       "product.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.product.__bases__[0].__name__.__eq__('object') == True — product inherits directly from object; its only base class is the built-in object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra125"]

# ---------------------------------------------------------------------------
# Table 2: itertools.product __iter__ and __next__ slot qualnames
#
# Wave 257 theme: itertools.product iterator protocol slot qualnames.
#
# itertools.product.__iter__.__qualname__ == 'product.__iter__' (len 16)
# itertools.product.__iter__.__class__.__name__ == 'wrapper_descriptor'
# itertools.product.__next__.__qualname__ == 'product.__next__' (len 16)
# itertools.product.__next__.__class__.__name__ == 'wrapper_descriptor'
#
# product implements the iterator protocol via __iter__ and __next__;
# when accessed on the type, these are wrapper_descriptor objects.
# New to extra125.
# ---------------------------------------------------------------------------

table itertools_extra125.product_iter_next_qualnames:
  description: "itertools.product __iter__ and __next__ qualnames and class names; iterator protocol wrapper_descriptors; wave 257; new to extra125"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsproduct125

  columns: [id, function, args, expected, description]
  rows:
    - [product_iter_qualname_eq,
       "product.__iter__.__qualname__.__eq__",
       ["product.__iter__"],
       true,
       "itertools.product.__iter__.__qualname__.__eq__('product.__iter__') == True — the __iter__ slot method on the product C extension type follows the 'typename.method' qualname convention; str.__eq__('product.__iter__') returns True; new to extra125"]
    - [product_iter_qualname_len_eq_16,
       "product.__iter__.__qualname__.__len__",
       [],
       16,
       "itertools.product.__iter__.__qualname__.__len__() == 16 — 'product.__iter__' has exactly 16 characters (7 + 1 + 8); len('product.__iter__') == 16; new to extra125"]
    - [product_iter_class_name_eq_wrapper_descriptor,
       "product.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.product.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — when accessed on the type, the __iter__ slot of a C extension type is exposed as a wrapper_descriptor; __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra125"]
    - [product_next_qualname_eq,
       "product.__next__.__qualname__.__eq__",
       ["product.__next__"],
       true,
       "itertools.product.__next__.__qualname__.__eq__('product.__next__') == True — the __next__ slot method on product follows the 'typename.method' qualname pattern; str.__eq__('product.__next__') returns True; new to extra125"]
    - [product_next_qualname_len_eq_16,
       "product.__next__.__qualname__.__len__",
       [],
       16,
       "itertools.product.__next__.__qualname__.__len__() == 16 — 'product.__next__' has exactly 16 characters (7 + 1 + 8); len('product.__next__') == 16; new to extra125"]
    - [product_next_class_name_eq_wrapper_descriptor,
       "product.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.product.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — __next__ on a C iterator type is a wrapper_descriptor when accessed on the type; __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra125"]

# ---------------------------------------------------------------------------
# Table 3: itertools.product __new__ qualname and class name
#
# Wave 257 theme: itertools.product __new__ builtin_function_or_method identity.
#
# itertools.product.__new__.__qualname__ == 'product.__new__' (len 15)
# itertools.product.__new__.__class__.__name__ == 'builtin_function_or_method'
#
# __new__ on C extension types is a builtin_function_or_method (unlike __call__
# and __next__ which are wrapper_descriptors). New to extra125.
# ---------------------------------------------------------------------------

table itertools_extra125.product_new_qualname:
  description: "itertools.product __new__ qualname and class name; builtin_function_or_method; wave 257; new to extra125"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsproduct125

  columns: [id, function, args, expected, description]
  rows:
    - [product_new_qualname_eq,
       "product.__new__.__qualname__.__eq__",
       ["product.__new__"],
       true,
       "itertools.product.__new__.__qualname__.__eq__('product.__new__') == True — the __new__ method on the product C extension type has qualname 'product.__new__'; str.__eq__('product.__new__') returns True; new to extra125"]
    - [product_new_qualname_len_eq_15,
       "product.__new__.__qualname__.__len__",
       [],
       15,
       "itertools.product.__new__.__qualname__.__len__() == 15 — 'product.__new__' has exactly 15 characters (7 + 1 + 7); len('product.__new__') == 15; new to extra125"]
    - [product_new_class_name_eq_builtin_function_or_method,
       "product.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.product.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — __new__ on C extension types is a builtin_function_or_method (unlike slot wrappers such as __iter__ which are wrapper_descriptors); __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra125"]
    - [product_name_eq_product,
       "product.__name__.__eq__",
       ["product"],
       true,
       "itertools.product.__name__.__eq__('product') == True — the __name__ attribute of the product C extension type is 'product', matching the PyTypeObject tp_name; str.__eq__('product') returns True; new to extra125"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra125
# ---------------------------------------------------------------------------

invariant itertools_extra125.product_class_name:
  description: "itertools.product.__class__.__name__ == 'type' — C extension type; metaclass is type; wave 257; new to extra125"
  kind: python_call_eq
  function: product.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra125.product_module:
  description: "itertools.product.__module__ == 'itertools' — C extension type from itertoolsmodule.c; wave 257; new to extra125"
  kind: python_call_eq
  function: product.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra125.product_mro_len:
  description: "len(itertools.product.__mro__) == 2 — MRO is [product, object]; inherits directly from object; wave 257; new to extra125"
  kind: python_call_eq
  function: product.__mro__.__len__
  args: []
  expected: 2

invariant itertools_extra125.product_iter_qualname_len:
  description: "len(itertools.product.__iter__.__qualname__) == 16 — 'product.__iter__' has 16 chars; wave 257; new to extra125"
  kind: python_call_eq
  function: product.__iter__.__qualname__.__len__
  args: []
  expected: 16

invariant itertools_extra125.product_new_class_name:
  description: "itertools.product.__new__.__class__.__name__ == 'builtin_function_or_method' — __new__ differs from wrapper_descriptor slots; wave 257; new to extra125"
  kind: python_call_eq
  function: product.__new__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
