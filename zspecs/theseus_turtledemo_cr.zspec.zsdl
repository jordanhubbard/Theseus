spec: theseus_turtledemo_cr
version: ">=3.0"
backend: python_cleanroom(theseus_turtledemo_cr)
blocks: turtledemo

docs: https://docs.python.org/3/library/turtledemo.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/turtledemo.html"
  not_derived_from:
    - "CPython source: Lib/turtledemo/__init__.py"
  notes:
    - "Clean-room turtledemo namespace stub. Do NOT import turtledemo."

error_model: python_exceptions

invariant theseus_turtledemo_cr.turtledemo2_package:
  description: "turtledemo is importable as a namespace"
  category: behavior
  kind: python_call_eq
  function: turtledemo2_package
  args: []
  expected: true

invariant theseus_turtledemo_cr.turtledemo2_name:
  description: "turtledemo has correct __name__"
  category: behavior
  kind: python_call_eq
  function: turtledemo2_name
  args: []
  expected: true

invariant theseus_turtledemo_cr.turtledemo2_path:
  description: "turtledemo has __path__ (is a package)"
  category: behavior
  kind: python_call_eq
  function: turtledemo2_path
  args: []
  expected: true
