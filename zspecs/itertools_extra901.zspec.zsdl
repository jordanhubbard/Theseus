provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks class __name__ for chain, product, combinations, permutations, groupby, islice iterator types"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra901.chain_product_class_names:
  description: "itertools.chain and itertools.product __class__.__name__ identity"
  kind: python_call_eq
  category: chain_product_class_names
  id_prefix: it901cp
  columns: [id, function, args, expected]
  rows:
    - [it901cp001, itertools.chain.__class__.__name__.__eq__,           ["type"],                    true]
    - [it901cp002, itertools.chain.__qualname__.__eq__,                 ["chain"],                   true]
    - [it901cp003, itertools.chain.__module__.__eq__,                   ["itertools"],               true]
    - [it901cp004, itertools.product.__class__.__name__.__eq__,         ["type"],                    true]
    - [it901cp005, itertools.product.__qualname__.__eq__,               ["product"],                 true]
    - [it901cp006, itertools.product.__module__.__eq__,                 ["itertools"],               true]

