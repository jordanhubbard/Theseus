spec: hashlib_extra2431
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "https://docs.python.org/3/library/hashlib.html#hashlib.blake2b — blake2b class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "CPython source: Modules/_hashopenssl.c (HMAC)"
  notes:
    - "Theme: __aiter__ and __anext__ async iteration protocol dict-presence for hashlib types."
    - "hashlib.blake2b and hashlib.blake2s are class objects directly accessible in the hashlib namespace."
    - "hashlib._hashlib.HASH, hashlib._hashlib.HASHXOF, and hashlib._hashlib.HMAC are C-extension classes accessible via the private _hashlib submodule."
    - "None of the hashlib hash classes define __aiter__ or __anext__ — all are synchronous C-extension types."
    - "blake2b and blake2s define update() and digest() as sync methods but have no async protocol."
    - "HASH and HASHXOF define update() as a sync method but have no async protocol."
    - "HMAC defines update() and digest() as sync methods but has no async protocol."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ===
# Table 1: __aiter__ in class __dict__ — blake2b and blake2s
# ===

table hashlib_extra2431.aiter_in_dict_blake2:
  description: "__aiter__ dict-presence for hashlib.blake2b and hashlib.blake2s — neither defines async iteration"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2431

  columns: [id, function, args, expected]
  rows:
    - ["hl2431001", "hashlib.blake2b.__dict__.__contains__", ["__aiter__"], false]
    - ["hl2431002", "hashlib.blake2b.__dict__.__contains__", ["__anext__"], false]
    - ["hl2431003", "hashlib.blake2s.__dict__.__contains__", ["__aiter__"], false]
    - ["hl2431004", "hashlib.blake2s.__dict__.__contains__", ["__anext__"], false]

# ===
# Table 2: __aiter__ and __anext__ in class __dict__ — _hashlib C-extension types
# ===

table hashlib_extra2431.aiter_in_dict_hashlib_internal:
  description: "__aiter__ and __anext__ dict-presence for hashlib._hashlib.HASH, HASHXOF, HMAC — none define async iteration"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2431

  columns: [id, function, args, expected]
  rows:
    - ["hl2431005", "hashlib._hashlib.HASH.__dict__.__contains__",    ["__aiter__"], false]
    - ["hl2431006", "hashlib._hashlib.HASH.__dict__.__contains__",    ["__anext__"], false]
    - ["hl2431007", "hashlib._hashlib.HASHXOF.__dict__.__contains__", ["__aiter__"], false]
    - ["hl2431008", "hashlib._hashlib.HASHXOF.__dict__.__contains__", ["__anext__"], false]
    - ["hl2431009", "hashlib._hashlib.HMAC.__dict__.__contains__",    ["__aiter__"], false]
    - ["hl2431010", "hashlib._hashlib.HMAC.__dict__.__contains__",    ["__anext__"], false]

# ===
# Table 3: Contrast — sync methods present in class __dict__
# ===

table hashlib_extra2431.sync_methods_present:
  description: "hashlib hash types DO define sync methods (update, digest) but NOT async protocol methods"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2431

  columns: [id, function, args, expected]
  rows:
    - ["hl2431011", "hashlib.blake2b.__dict__.__contains__",          ["update"],   true]
    - ["hl2431012", "hashlib.blake2b.__dict__.__contains__",          ["digest"],   true]
    - ["hl2431013", "hashlib.blake2b.__dict__.__contains__",          ["__aiter__"], false]
    - ["hl2431014", "hashlib.blake2s.__dict__.__contains__",          ["update"],   true]
    - ["hl2431015", "hashlib.blake2s.__dict__.__contains__",          ["digest"],   true]
    - ["hl2431016", "hashlib.blake2s.__dict__.__contains__",          ["__aiter__"], false]
    - ["hl2431017", "hashlib._hashlib.HASH.__dict__.__contains__",    ["update"],   true]
    - ["hl2431018", "hashlib._hashlib.HASH.__dict__.__contains__",    ["__aiter__"], false]
    - ["hl2431019", "hashlib._hashlib.HMAC.__dict__.__contains__",    ["update"],   true]
    - ["hl2431020", "hashlib._hashlib.HMAC.__dict__.__contains__",    ["digest"],   true]
    - ["hl2431021", "hashlib._hashlib.HMAC.__dict__.__contains__",    ["__aiter__"], false]
