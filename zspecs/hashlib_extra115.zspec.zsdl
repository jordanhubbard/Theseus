spec: hashlib_extra115
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra114.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__all__/__loader__ module-level dunder attributes (table + invariants)."
    - "hashlib_extra113.zspec.zsdl — covers HASH class-level descriptor types (name/block_size/digest_size are getset_descriptors) / HASH descriptor qualnames and __objclass__ (table + invariants)."
    - "hashlib_extra112.zspec.zsdl — covers md5/sha1/sha256/sha512 function __qualname__ string equality / sha224/sha384/sha3_512/blake2s qualname equality / qualname length groupings (table + invariants)."
    - "hashlib_extra111.zspec.zsdl — covers sha3_256/__qualname__ and blake2b qualname / blake2b is a type not a function (table + invariants)."
    - "hashlib_extra108.zspec.zsdl — covers sha224/sha384/sha3_256/sha3_512 digest_size and block_size / blake2b/blake2s digest_size and block_size (table + invariants)."
    - "hashlib_extra107.zspec.zsdl — covers HASH type identity (__name__=='HASH', __module__=='_hashlib', __mro__.__len__()==2) (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' / algorithms_guaranteed.__len__()==14 (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra114; it does NOT duplicate invariants present in those files."
    - "Wave 272 theme: hash object .name attribute string equality and lengths across six algorithms; HASH class __doc__ type; hashlib.new and hashlib.pbkdf2_hmac identity attributes."
    - "hashlib.sha256().name == 'sha256' (6 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().name == 'md5' (3 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1().name == 'sha1' (4 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512().name == 'sha512' (6 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224().name == 'sha224' (6 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256().name == 'sha3_256' (8 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.sha256().__class__.__doc__).__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__name__ == '__hash_new' (10 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hash object .name attribute returns the algorithm name as a lowercase string. sha256=6 chars, sha512=6 chars, sha224=6 chars, sha384=6 chars (these are equal in length); md5=3 chars (shortest); sha1=4 chars; sha3_256=8 chars (longest among common algorithms). hashlib_extra107 anchors HASH class identity; this spec anchors the .name string equality and lengths for the first time as a grouped table."
    - "Note: hashlib.new is the Python-level wrapper function with internal name '__hash_new' (the public API is hashlib.new but the function __name__ attribute is '__hash_new'). hashlib.pbkdf2_hmac is a C-level builtin_function_or_method from _hashlib. hashlib_extra114 anchors hashlib.__all__[-1]=='pbkdf2_hmac'; this spec anchors the pbkdf2_hmac function identity attributes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha256().name.__eq__('sha256')
# hashlib.md5().name.__eq__('md5')
# hashlib.sha1().name.__eq__('sha1')
# hashlib.sha512().name.__eq__('sha512')
# hashlib.sha224().name.__eq__('sha224')
#
# Wave 272 theme: Hash object .name attribute equality for five common algorithms.
#
# Each hash object has a .name attribute returning the algorithm name as a
# lowercase string. sha256/sha512/sha224 all have 6-char names; sha1 has 4
# chars; md5 has 3 chars (shortest). hashlib_extra107 anchors the HASH class
# identity (__name__=='HASH', __module__=='_hashlib'); hashlib.sha256.name_attr
# in the base hashlib spec anchors sha256 name=='sha256'. This spec anchors
# all five as a grouped equality table for the first time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra115.hash_object_name_attr_equality:
  description: "sha256().name.__eq__('sha256')==True / md5().name.__eq__('md5')==True / sha1().name.__eq__('sha1')==True / sha512().name.__eq__('sha512')==True / sha224().name.__eq__('sha224')==True — name attribute returns lowercase algorithm name string; sha256/sha512/sha224 each 6 chars; sha1 is 4 chars; md5 is 3 chars (shortest); first hashalgo115 anchor"
  kind: python_call_eq
  category: hash_object_attr
  id_prefix: hashalgo115

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_name_eq, "sha256().name.__eq__",  ["sha256"],  true, "hashlib.sha256().name is 'sha256' (6 chars; lowercase algorithm name; HASH object attribute)"]
    - [md5_name_eq,    "md5().name.__eq__",     ["md5"],     true, "hashlib.md5().name is 'md5' (3 chars; shortest among common algorithms)"]
    - [sha1_name_eq,   "sha1().name.__eq__",    ["sha1"],    true, "hashlib.sha1().name is 'sha1' (4 chars; lowercase SHA-1 algorithm name)"]
    - [sha512_name_eq, "sha512().name.__eq__",  ["sha512"],  true, "hashlib.sha512().name is 'sha512' (6 chars; same length as sha256 and sha224)"]
    - [sha224_name_eq, "sha224().name.__eq__",  ["sha224"],  true, "hashlib.sha224().name is 'sha224' (6 chars; truncated SHA-256 variant)"]

# ---------------------------------------------------------------------------
# hashlib.sha256().name.__len__() == 6
# hashlib.md5().name.__len__() == 3
# hashlib.sha1().name.__len__() == 4
# hashlib.sha3_256().name.__eq__('sha3_256')
# hashlib.sha3_256().name.__len__() == 8
#
# Wave 272 theme: Hash object .name attribute lengths and sha3_256 name equality.
#
# The .name attribute length varies by algorithm: md5=3, sha1=4, sha256=6,
# sha512=6, sha224=6, sha384=6, sha3_256=8 (longest — includes the '3_' infix).
# sha3_256 has an 8-char name because SHA-3 algorithm names use the 'sha3_'
# prefix followed by the bit count. This is the only algorithm in this group
# with a name length over 6 chars. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra115.hash_object_name_attr_lengths_and_sha3:
  description: "sha256().name.__len__()==6 / md5().name.__len__()==3 / sha1().name.__len__()==4 / sha3_256().name.__eq__('sha3_256')==True / sha3_256().name.__len__()==8 — md5 is shortest (3); sha1 is 4; sha256/sha512/sha224 are 6; sha3_256 is longest (8; includes '3_' infix); first hashalgo115 anchor"
  kind: python_call_eq
  category: hash_object_attr
  id_prefix: hashalgo115

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_name_len,     "sha256().name.__len__",         [], 6,    "hashlib.sha256().name.__len__() is 6 ('sha256': s-h-a-2-5-6)"]
    - [md5_name_len,        "md5().name.__len__",            [], 3,    "hashlib.md5().name.__len__() is 3 ('md5': m-d-5; shortest among common algorithms)"]
    - [sha1_name_len,       "sha1().name.__len__",           [], 4,    "hashlib.sha1().name.__len__() is 4 ('sha1': s-h-a-1)"]
    - [sha3_256_name_eq,    "sha3_256().name.__eq__",        ["sha3_256"], true, "hashlib.sha3_256().name is 'sha3_256' (8 chars; SHA-3 algorithm with 256-bit output)"]
    - [sha3_256_name_len,   "sha3_256().name.__len__",       [], 8,    "hashlib.sha3_256().name.__len__() is 8 ('sha3_256': includes '3_' infix; longest among common algorithms)"]

# ---------------------------------------------------------------------------
# hashlib.new.__name__.__eq__('__hash_new')
# hashlib.new.__module__.__eq__('hashlib')
# hashlib.new.__class__.__name__.__eq__('function')
# hashlib.new.__code__.co_argcount == 1
# hashlib.sha256().__class__.__doc__.__class__.__name__.__eq__('str')
#
# Wave 272 theme: hashlib.new function identity and HASH class __doc__ type.
#
# hashlib.new is the public API for creating hash objects by name, but
# internally the function __name__ is '__hash_new' (10 chars; prefixed with
# double underscore to avoid shadowing the built-in new). It is a Python
# function (type 'function'), defined in hashlib.py (__module__=='hashlib'),
# with co_argcount==1 (the 'name' parameter). HASH.__doc__ is a str.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra115.hashlib_new_function_and_hash_doc_identity:
  description: "new.__name__.__eq__('__hash_new')==True / new.__module__.__eq__('hashlib')==True / new.__class__.__name__.__eq__('function')==True / new.__code__.co_argcount==1 / sha256().__class__.__doc__.__class__.__name__.__eq__('str')==True — hashlib.new internal name is '__hash_new' (10 chars; double-underscore prefix); __module__ is 'hashlib'; type is 'function'; co_argcount==1 (the name param); HASH.__doc__ is str; first hashalgo115 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashalgo115

  columns: [id, function, args, expected, description]
  rows:
    - [new_name_eq,         "new.__name__.__eq__",                              ["__hash_new"], true, "hashlib.new.__name__ is '__hash_new' (10 chars; double-underscore prefix avoids shadowing built-in new)"]
    - [new_module_eq,       "new.__module__.__eq__",                            ["hashlib"],    true, "hashlib.new.__module__ is 'hashlib' (defined in Lib/hashlib.py; Python source module)"]
    - [new_type_eq,         "new.__class__.__name__.__eq__",                    ["function"],   true, "type(hashlib.new) is 'function' (Python function; not a C builtin_function_or_method)"]
    - [new_co_argcount,     "new.__code__.co_argcount",                         [],             1,    "hashlib.new.__code__.co_argcount is 1 (one positional argument: 'name'; the algorithm name string)"]
    - [hash_doc_type_str,   "sha256().__class__.__doc__.__class__.__name__.__eq__", ["str"],   true, "type(HASH.__doc__) is 'str' (the HASH class has a docstring; it is a Python str)"]

# ---------------------------------------------------------------------------
# hashlib.sha256().name.__eq__('sha256') — standalone
#
# hashlib.sha256().name is 'sha256'. The hash object .name attribute returns
# the canonical lowercase algorithm name as registered with OpenSSL or the
# built-in hash module. For sha256, the name is 'sha256' (6 chars: s-h-a-2-5-6).
# This is the same string used to create a hash object via hashlib.new('sha256').
# The base hashlib spec anchors the sha256 name attr via hash_object_attr
# kind; this spec anchors it as a python_call_eq standalone (__eq__ method
# call) for the first time under hashalgo115.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra115.sha256_name_attr_eq:
  description: "hashlib.sha256().name.__eq__('sha256') == True — name attribute is 'sha256' (6 chars; s-h-a-2-5-6); canonical lowercase algorithm name; same string used with hashlib.new('sha256'); base spec anchors via hash_object_attr kind; this spec anchors via python_call_eq as standalone; first standalone under hashalgo115"
  category: hash_object_attr
  kind: python_call_eq
  function: "sha256().name.__eq__"
  args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().name.__eq__('md5') — standalone
#
# hashlib.md5().name is 'md5'. MD5 (Message Digest 5) has the shortest name
# among the common hash algorithms (3 chars: m-d-5). Although MD5 is
# cryptographically broken (collision attacks are feasible), it remains
# widely used for checksums and legacy compatibility. The .name attribute
# consistently returns lowercase 'md5' regardless of how the hash object
# was constructed (hashlib.md5() or hashlib.new('md5') both yield name=='md5').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra115.md5_name_attr_eq:
  description: "hashlib.md5().name.__eq__('md5') == True — name is 'md5' (3 chars; m-d-5; shortest name among common hash algorithms); MD5 is cryptographically broken but behaviorally specified for legacy compatibility; .name is consistently lowercase; same string used with hashlib.new('md5'); first standalone under hashalgo115"
  category: hash_object_attr
  kind: python_call_eq
  function: "md5().name.__eq__"
  args: ["md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__name__.__eq__('__hash_new') — standalone
#
# hashlib.new.__name__ is '__hash_new'. The public hashlib.new() function
# is internally implemented as a Python function named '__hash_new' (10 chars:
# double-underscore + 'hash_new'). The double-underscore prefix is a CPython
# convention to avoid shadowing the built-in 'new' name and to indicate that
# the function is an implementation detail. Despite the internal name, the
# public API name is 'hashlib.new'. This is the first spec to anchor
# hashlib.new.__name__ equality as a standalone under hashalgo115.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra115.new_internal_name_eq:
  description: "hashlib.new.__name__.__eq__('__hash_new') == True — internal function name is '__hash_new' (10 chars; double-underscore prefix is CPython convention to avoid shadowing built-in 'new'); public API is hashlib.new but __name__ attr is '__hash_new'; type is 'function'; defined in hashlib.py; first standalone under hashalgo115"
  category: function_identity
  kind: python_call_eq
  function: "new.__name__.__eq__"
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.pbkdf2_hmac is a C-level function (type 'builtin_function_or_method')
# implemented in _hashlib (Modules/_hashlib.c). It differs from hashlib.new
# (which is a Python function). pbkdf2_hmac implements PBKDF2 (Password-Based
# Key Derivation Function 2) using HMAC as the pseudo-random function.
# hashlib.__all__[-1] in hashlib_extra114 confirms 'pbkdf2_hmac' is the last
# exported name; this spec anchors the pbkdf2_hmac function type as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra115.pbkdf2_hmac_type_eq:
  description: "hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method') == True — pbkdf2_hmac is a C-level function in _hashlib (distinct from hashlib.new which is a Python function); implements PBKDF2 key derivation using HMAC; extra114 anchors it as last __all__ element; first standalone for type identity under hashalgo115"
  category: function_identity
  kind: python_call_eq
  function: "pbkdf2_hmac.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') — standalone
#
# hashlib.pbkdf2_hmac.__module__ is '_hashlib'. pbkdf2_hmac is defined in the
# _hashlib C extension (Modules/_hashlib.c), not in hashlib.py. The module
# attribute '_hashlib' (8 chars: underscore + 'hashlib') identifies the C
# extension module. This contrasts with hashlib.new whose __module__ is 'hashlib'
# (the Python wrapper). The leading underscore in '_hashlib' is a CPython
# convention indicating a private C extension that is not intended for direct
# import (users should import hashlib, not _hashlib directly).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra115.pbkdf2_hmac_module_eq:
  description: "hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') == True — __module__ is '_hashlib' (8 chars; C extension module; leading underscore is CPython convention for private C extension); contrast with hashlib.new.__module__=='hashlib' (Python wrapper); pbkdf2_hmac is defined in Modules/_hashlib.c; first standalone under hashalgo115"
  category: function_identity
  kind: python_call_eq
  function: "pbkdf2_hmac.__module__.__eq__"
  args: ["_hashlib"]
  expected: true
