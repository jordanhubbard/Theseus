spec: redis_py_rust
version: ">=3.9"
backend: rust_module(redis_py_rust)

docs: https://redis-py.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://redis-py.readthedocs.io/en/stable/ — redis-py documentation"
  not_derived_from:
    - "redis-py source: redis/client.py"
  notes:
    - "redis-py is the Python client for Redis."
    - "redis.Redis is available as a class."
    - "redis.StrictRedis is available as a class."
    - "redis.ConnectionPool is available."
    - "redis.__version__ is a non-empty string."
    - "redis.Redis.__name__ == 'Redis'."
    - "Expose redis_client_name() -> str: redis.Redis.__name__."
    - "Expose redis_has_connection_pool() -> bool: hasattr(redis, 'ConnectionPool')."
    - "Expose redis_version_nonempty() -> bool: len(redis.__version__) > 0."
    - "All test vectors verified against redis 5.2.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# redis_client_name — Redis class name
invariant redis_py_rust.client.class_name:
  description: "redis.Redis.__name__ == 'Redis'"
  category: client_name
  kind: python_call_eq
  function: redis_client_name
  args: []
  expected: "Redis"

# redis_has_connection_pool — ConnectionPool available
invariant redis_py_rust.pool.has_connection_pool:
  description: "redis.ConnectionPool is available"
  category: connection_pool
  kind: python_call_eq
  function: redis_has_connection_pool
  args: []
  expected: true

# redis_version_nonempty — version string non-empty
invariant redis_py_rust.version.nonempty:
  description: "redis.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: redis_version_nonempty
  args: []
  expected: true

# redis class availability
table redis_py_rust.classes.present:
  kind: python_call_eq
  category: class_presence
  id_prefix: rds_cls
  function: redis_has_class

  columns: [id, args, expected]
  rows:
    - [redis,       ["Redis"],       true]
    - [strict,      ["StrictRedis"], true]
    - [pool,        ["ConnectionPool"], true]

