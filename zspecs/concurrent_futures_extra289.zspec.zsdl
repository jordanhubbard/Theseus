spec: concurrent_futures_extra289
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures executor and future class identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (not 'concurrent.futures')"
    - "ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (not 'concurrent.futures')"
    - "Executor.__module__ == 'concurrent.futures._base'"
    - "Future.__module__ == 'concurrent.futures._base'"
    - "Future.__bases__[0].__name__ == 'object' — Future inherits directly from object"
    - "Both ThreadPoolExecutor and ProcessPoolExecutor have Executor as their direct base class"
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table concurrent_futures_extra289.executor_class_identity:
  description: "ThreadPoolExecutor, ProcessPoolExecutor, and Executor class name, module, and base class identity"
  kind: python_call_eq
  category: identity
  id_prefix: cf289a

  columns: [id, function, args, expected, description]
  rows:
    - [cf289a001, concurrent.futures.ThreadPoolExecutor.__name__.__eq__, ["ThreadPoolExecutor"], true, "ThreadPoolExecutor.__name__ is 'ThreadPoolExecutor'"]
    - [cf289a002, concurrent.futures.ThreadPoolExecutor.__module__.__eq__, ["concurrent.futures.thread"], true, "ThreadPoolExecutor.__module__ is 'concurrent.futures.thread'"]
    - [cf289a003, "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"], true, "ThreadPoolExecutor base class is Executor"]
    - [cf289a004, concurrent.futures.ProcessPoolExecutor.__name__.__eq__, ["ProcessPoolExecutor"], true, "ProcessPoolExecutor.__name__ is 'ProcessPoolExecutor'"]
    - [cf289a005, concurrent.futures.ProcessPoolExecutor.__module__.__eq__, ["concurrent.futures.process"], true, "ProcessPoolExecutor.__module__ is 'concurrent.futures.process'"]
    - [cf289a006, "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"], true, "ProcessPoolExecutor base class is Executor"]
    - [cf289a007, concurrent.futures.Executor.__name__.__eq__, ["Executor"], true, "Executor.__name__ is 'Executor'"]
    - [cf289a008, concurrent.futures.Executor.__module__.__eq__, ["concurrent.futures._base"], true, "Executor.__module__ is 'concurrent.futures._base'"]

table concurrent_futures_extra289.future_class_identity:
  description: "concurrent.futures.Future class name, module, and base class identity"
  kind: python_call_eq
  category: identity
  id_prefix: cf289b

  columns: [id, function, args, expected, description]
  rows:
    - [cf289b001, concurrent.futures.Future.__name__.__eq__, ["Future"], true, "Future.__name__ is 'Future'"]
    - [cf289b002, concurrent.futures.Future.__module__.__eq__, ["concurrent.futures._base"], true, "Future.__module__ is 'concurrent.futures._base'"]
    - [cf289b003, "concurrent.futures.Future.__bases__[0].__name__.__eq__", ["object"], true, "Future base class is object"]

invariant concurrent_futures_extra289.thread_pool_executor_base:
  description: "ThreadPoolExecutor inherits directly from Executor"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra289.process_pool_executor_base:
  description: "ProcessPoolExecutor inherits directly from Executor"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra289.future_base_is_object:
  description: "concurrent.futures.Future inherits directly from object"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant concurrent_futures_extra289.thread_pool_module:
  description: "ThreadPoolExecutor.__module__ is the submodule 'concurrent.futures.thread', not the top-level package"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true
