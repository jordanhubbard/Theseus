spec: striptags
version: ">=3.0.0"
backend: node(striptags)

docs: https://www.npmjs.com/package/striptags

provenance:
  derived_from:
    - "striptags README — https://www.npmjs.com/package/striptags"
    - "Test vectors verified with striptags via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "striptags source"
  notes:
    - "striptags is an npm package. Install: npm install striptags"
    - "striptags(html, allowedTags) strips HTML tags from a string."
    - "Optional allowedTags array specifies which tags to keep."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns plain text with HTML tags stripped."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table striptags.strip:
  kind: node_module_call_eq
  function: ~
  category: strip
  id_prefix: st

  columns: [id, args, expected]
  rows:
    - [simple,   ["<b>hello</b>"],                               "hello"]
    - [nested,   ["<div><p>text</p></div>"],                     "text"]
    - [empty,    ["<br/>"],                                      ""]
    - [no_tags,  ["no tags here"],                               "no tags here"]
    - [allowed,  ["<b>bold</b> and <i>italic</i>", ["b"]],       "<b>bold</b> and italic"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:26:14Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
