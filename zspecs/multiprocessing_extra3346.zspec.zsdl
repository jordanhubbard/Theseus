spec: mp3346
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 670 (mp3346): __neg__, __pos__, __abs__ dict-presence (unary -x, +x, abs(x)) for multiprocessing types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: multiprocessing.Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.BaseListProxy, managers._BaseDictProxy, managers._BaseSetProxy."
    - "Key finding (__neg__): all 8 multiprocessing classes return false for __neg__. Unary negation (__neg__, -x) belongs to the numeric data model. None of the 8 multiprocessing types model a numeric magnitude. multiprocessing.Process is a subprocess lifecycle manager; -process is not a defined Python expression. pool.Pool/AsyncResult/MapResult: work-dispatch and result-handle types; no numeric data model. managers.SyncManager: server process manager; -manager is undefined. managers.BaseListProxy: proxies list — list defines no __neg__. managers._BaseDictProxy: proxies dict — dict defines no __neg__. managers._BaseSetProxy: proxies set — set defines no __neg__; set arithmetic uses & | ^ ^ operators, not unary operators."
    - "Key finding (__pos__): all 8 multiprocessing classes return false for __pos__. Unary plus (__pos__, +x) mirrors __neg__ in the numeric data model. multiprocessing types define no arithmetic protocol — confirmed false across waves 658–669. managers._BaseSetProxy key note: set defines no __pos__; set does not model a numeric magnitude. +proxy is not a valid Python expression for any of the proxy types. managers.BaseListProxy: list defines no __pos__. managers._BaseDictProxy: dict defines no __pos__. Process/Pool/AsyncResult/MapResult/SyncManager: no unary plus defined for any of these process-management types."
    - "Key finding (__abs__): all 8 multiprocessing classes return false for __abs__. The abs() built-in delegates to __abs__, part of the numeric data model. None of the 8 multiprocessing types implement numeric magnitude. managers._BaseSetProxy key note: set defines no __abs__; set cardinality is obtained via len(), not abs(). managers._BaseDictProxy: dict defines no __abs__; dict size is obtained via len(). managers.BaseListProxy: list defines no __abs__; list length is obtained via len(). multiprocessing.Process/pool.Pool/pool.AsyncResult/pool.MapResult/managers.SyncManager: process-management types with no numeric magnitude semantics whatsoever."
    - "All 24 values in this wave are false. multiprocessing is a process-based concurrency library; its types interact exclusively through explicit method calls, subprocess lifecycle management, and IPC — never through Python's unary numeric operators."
    - "Cross-wave summary for mp subjects:"
    - "  Wave 658 (mp3166): __add__/__sub__/__mul__ — BaseListProxy __add__=true, __mul__=true; others false."
    - "  Wave 659 (mp3181): __truediv__/__floordiv__/__mod__ — all false for all 8."
    - "  Wave 660 (mp3196): __pow__/__lshift__/__rshift__ — all false for all 8."
    - "  Wave 661 (mp3211): __and__/__or__/__xor__ — all false for all 8."
    - "  Wave 662 (mp3226): __radd__/__rsub__/__rmul__ — all false for all 8."
    - "  Wave 663 (mp3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 8."
    - "  Wave 664 (mp3256): __rpow__/__rlshift__/__rrshift__ — all false for all 8."
    - "  Wave 665 (mp3271): __rand__/__ror__/__rxor__ — all false for all 8."
    - "  Wave 666 (mp3286): __iadd__/__isub__/__imul__ — all false for all 8."
    - "  Wave 667 (mp3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 8."
    - "  Wave 668 (mp3316): __ipow__/__ilshift__/__irshift__ — all false for all 8."
    - "  Wave 669 (mp3331): __iand__/__ior__/__ixor__ — all false for all 8."
    - "  Wave 670 (mp3346): __neg__/__pos__/__abs__ — all false for all 8."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __neg__ dict-presence — operator.contains(Cls.__dict__, '__neg__')
#
# All 8 multiprocessing classes return false for __neg__.
# Unary negation (__neg__, -x) is a numeric data model method.
# multiprocessing.Process: subprocess lifecycle manager; -process is not a
#   valid Python expression.
# pool.Pool/AsyncResult/MapResult: work-dispatch and result-handle types;
#   no numeric data model is defined for any of them.
# managers.SyncManager: server process manager; -manager is undefined.
# managers.BaseListProxy: proxies list — list defines no __neg__.
# managers._BaseDictProxy: proxies dict — dict defines no __neg__.
# managers._BaseSetProxy: proxies set — set defines no __neg__. Set operations
#   use & | ^ ^ operators (binary), not unary negation. -proxy is not valid.
# ---------------------------------------------------------------------------

table mp3346.neg:
  description: "multiprocessing types __neg__ dict-presence checks; wave 670"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3346

  columns: [id, function, args, expected]
  rows:
    - ["mp3346001", operator.contains, [multiprocessing.Process.__dict__,                 "__neg__"], false]
    - ["mp3346002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__neg__"], false]
    - ["mp3346003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__neg__"], false]
    - ["mp3346004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__neg__"], false]
    - ["mp3346005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__neg__"], false]
    - ["mp3346006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__neg__"], false]
    - ["mp3346007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__neg__"], false]
    - ["mp3346008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__neg__"], false]

# ---------------------------------------------------------------------------
# __pos__ dict-presence — operator.contains(Cls.__dict__, '__pos__')
#
# All 8 multiprocessing classes return false for __pos__.
# Unary plus (__pos__, +x) mirrors __neg__ and belongs to the same numeric
#   data model. multiprocessing types define no arithmetic protocol —
#   confirmed false across waves 658–669 for all arithmetic operators.
# managers._BaseSetProxy key note: set defines no __pos__. Set does not model
#   a numeric magnitude; its algebra uses binary &, |, ^, - operators. +proxy
#   is not a valid Python expression for any proxy type.
# managers._BaseDictProxy: dict defines no __pos__. False.
# managers.BaseListProxy: list defines no __pos__. False.
# Process/Pool/AsyncResult/MapResult/SyncManager: no unary plus defined
#   for any of these process-management types.
# ---------------------------------------------------------------------------

table mp3346.pos:
  description: "multiprocessing types __pos__ dict-presence checks; wave 670"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3346

  columns: [id, function, args, expected]
  rows:
    - ["mp3346009",  operator.contains, [multiprocessing.Process.__dict__,                 "__pos__"], false]
    - ["mp3346010",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__pos__"], false]
    - ["mp3346011",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__pos__"], false]
    - ["mp3346012",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__pos__"], false]
    - ["mp3346013",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__pos__"], false]
    - ["mp3346014",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__pos__"], false]
    - ["mp3346015",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__pos__"], false]
    - ["mp3346016",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__pos__"], false]

# ---------------------------------------------------------------------------
# __abs__ dict-presence — operator.contains(Cls.__dict__, '__abs__')
#
# All 8 multiprocessing classes return false for __abs__.
# The abs() built-in delegates to __abs__, part of the numeric data model
#   (numbers.Number). None of the 8 multiprocessing types implement numeric
#   magnitude.
# managers._BaseSetProxy key note: set defines no __abs__. Set cardinality is
#   obtained via len(s), not abs(s). The proxy does not define __abs__ either.
# managers._BaseDictProxy: dict defines no __abs__. Dict size is len(d). False.
# managers.BaseListProxy: list defines no __abs__. List length is len(l). False.
# multiprocessing.Process: subprocess lifecycle manager; abs(process) is not
#   a meaningful Python operation.
# pool.Pool/AsyncResult/MapResult: task dispatchers and result handles;
#   no numeric magnitude is defined.
# managers.SyncManager: server process manager; abs(manager) is not defined.
# ---------------------------------------------------------------------------

