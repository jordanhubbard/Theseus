spec: uuid_extra631
version: ">=3.9"
backend: python_module(uuid)
docs: "Behavioral spec for uuid NAMESPACE constants and UUID comparison slot wrappers."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid NAMESPACE constants and UUID class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Checks version and variant attribute types on NAMESPACE constants, and slot_wrapper identity on UUID comparison methods"
  created_at: "2026-04-12T00:00:00Z"

table uuid_extra631.namespace_version_class:
  description: "NAMESPACE constant .version __class__.__name__ identity"
  kind: python_call_eq
  category: namespace_identity
  id_prefix: uu631ns
  columns: [id, function, args, expected]
  rows:
    - [uu631ns001, uuid.NAMESPACE_DNS.version.__class__.__name__.__eq__, ["int"], true]
    - [uu631ns002, uuid.NAMESPACE_URL.version.__class__.__name__.__eq__, ["int"], true]
    - [uu631ns003, uuid.NAMESPACE_OID.version.__class__.__name__.__eq__, ["int"], true]
    - [uu631ns004, uuid.NAMESPACE_X500.version.__class__.__name__.__eq__, ["int"], true]
    - [uu631ns005, uuid.NAMESPACE_DNS.variant.__class__.__name__.__eq__, ["UUID"], true]
    - [uu631ns006, uuid.NAMESPACE_URL.variant.__class__.__name__.__eq__, ["UUID"], true]

table uuid_extra631.uuid_class_slot_wrappers:
  description: "UUID comparison dunder methods are slot_wrapper instances"
  kind: python_call_eq
  category: class_identity
  id_prefix: uu631cl
  columns: [id, function, args, expected]
  rows:
    - [uu631cl001, uuid.UUID.__hash__.__class__.__name__.__eq__, ["slot_wrapper"], true]
    - [uu631cl002, uuid.UUID.__eq__.__class__.__name__.__eq__, ["slot_wrapper"], true]
    - [uu631cl003, uuid.UUID.__lt__.__class__.__name__.__eq__, ["slot_wrapper"], true]
    - [uu631cl004, uuid.UUID.__le__.__class__.__name__.__eq__, ["slot_wrapper"], true]
    - [uu631cl005, uuid.UUID.__gt__.__class__.__name__.__eq__, ["slot_wrapper"], true]
    - [uu631cl006, uuid.UUID.__ge__.__class__.__name__.__eq__, ["slot_wrapper"], true]
