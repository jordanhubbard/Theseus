spec: th3151
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 657 (th3151): __setitem__, __delitem__, __contains__ dict-presence checks for threading types."
    - "None of the threading types define __setitem__, __delitem__, or __contains__ in their own __dict__."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier, and threading.local are Python-level classes."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3151.setitem:
  description: "threading types __setitem__ dict-presence checks; wave 657"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th3151
  columns: [id, function, args, expected]
  rows:
    - ["th3151001", operator.contains, [threading.Thread.__dict__,           "__setitem__"], false]
    - ["th3151002", operator.contains, [type(threading.Lock()).__dict__,     "__setitem__"], false]
    - ["th3151003", operator.contains, [type(threading.RLock()).__dict__,    "__setitem__"], false]
    - ["th3151004", operator.contains, [threading.Event.__dict__,            "__setitem__"], false]
    - ["th3151005", operator.contains, [threading.Condition.__dict__,        "__setitem__"], false]
    - ["th3151006", operator.contains, [threading.Semaphore.__dict__,        "__setitem__"], false]
    - ["th3151007", operator.contains, [threading.BoundedSemaphore.__dict__, "__setitem__"], false]
    - ["th3151008", operator.contains, [threading.Timer.__dict__,            "__setitem__"], false]
    - ["th3151009", operator.contains, [threading.Barrier.__dict__,          "__setitem__"], false]
    - ["th3151010", operator.contains, [threading.local.__dict__,            "__setitem__"], false]

