spec: abc_extra169
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.__spec__.__class__.__name__=='ModuleSpec' (ModuleSpec is the universal importlib spec type; len=10); abc.__spec__.origin.__class__.__name__=='str' (origin is the string 'frozen' for frozen modules); abc.__loader__.__name__=='FrozenImporter' (abc is a frozen module; its loader IS the FrozenImporter class itself — NOT an instance; __loader__.__class__.__name__=='type'); abc.get_cache_token.__name__=='get_cache_token' (len=15); abc.get_cache_token.__module__=='_abc' (defined in the C extension _abc); abc.update_abstractmethods.__name__=='update_abstractmethods' (added in Python 3.10; len=22); abc.update_abstractmethods.__module__=='abc' (defined in pure Python abc module). KEY FINDINGS: abc.__loader__ is the FrozenImporter class ITSELF (not an instance) — so __loader__.__class__.__name__=='type' (metaclass of classes); abc.__loader__.__name__=='FrozenImporter'; get_cache_token is defined in the _abc C extension while update_abstractmethods is defined in the pure Python abc module. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__spec__.__class__.__name__=='ModuleSpec': universal for all importlib-loaded modules. abc.__spec__.origin=='frozen' (string 'frozen' for frozen modules). Verified with Python 3.14.3."
    - "abc.__loader__ is the FrozenImporter class itself (not an instance): abc.__loader__.__class__.__name__=='type' (FrozenImporter is a class; its __class__ is 'type'); abc.__loader__.__name__=='FrozenImporter' (the class name). Verified with Python 3.14.3."
    - "abc.get_cache_token.__module__=='_abc': get_cache_token is implemented in the _abc C extension alongside the core ABC machinery. Verified with Python 3.14.3."
    - "abc.update_abstractmethods.__module__=='abc': update_abstractmethods is defined in pure Python Lib/abc.py (added in Python 3.10). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc module __spec__ properties — extra169
#
# abc.__spec__.__class__.__name__.__eq__('ModuleSpec')      == True
# abc.__spec__.origin.__class__.__name__.__eq__('str')       == True
# abc.__spec__.origin.__eq__('frozen')                       == True
# ---------------------------------------------------------------------------

table abc_extra169.abc_spec_properties:
  description: "abc.__spec__ class name and origin class checks in abcmodule169spec namespace — abc.__spec__.__class__.__name__.__eq__('ModuleSpec')==True ('ModuleSpec'=10: 'Module'=6+'Spec'=4=10; the importlib ModuleSpec type is used for all importlib-loaded modules whether frozen or from file; abc uses ModuleSpec even though it is frozen — the difference from asyncio is only in the spec's .origin and .loader attributes); abc.__spec__.__class__.__name__.__len__()==10 ('ModuleSpec'=10); abc.__spec__.origin.__class__.__name__.__eq__('str')==True (abc.__spec__.origin is the string 'frozen' — a Python str object; __class__.__name__=='str' for all Python string objects; CONTRAST: asyncio.__spec__.origin is a file path string pointing to Lib/asyncio/__init__.py — also __class__.__name__=='str' but content differs: 'frozen' vs a file path); abc.__spec__.origin.__eq__('frozen')==True (abc.__spec__.origin is literally the string 'frozen'; 'frozen'=6: 'f'+'r'+'o'+'z'+'e'+'n'=6; this string origin value signals that abc is a frozen module compiled into the CPython interpreter); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmodule169spec

  columns: [id, function, args, expected, description]
  rows:
    - [spec_cls_name_eq,   abc.__spec__.__class__.__name__.__eq__,            ["ModuleSpec"],  true,  "abc.__spec__.__class__.__name__ == 'ModuleSpec' (len=10; universal importlib spec type); verified with Python 3.14.3"]
    - [spec_cls_name_len,  abc.__spec__.__class__.__name__.__len__,           [],              10,    "abc.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec'=10: 'Module'=6+'Spec'=4=10); verified with Python 3.14.3"]
    - [spec_origin_cls,    abc.__spec__.origin.__class__.__name__.__eq__,     ["str"],         true,  "abc.__spec__.origin.__class__.__name__ == 'str' (origin is a Python string; value is 'frozen'); verified with Python 3.14.3"]
    - [spec_origin_eq,     abc.__spec__.origin.__eq__,                        ["frozen"],      true,  "abc.__spec__.origin == 'frozen' (len=6; frozen module compiled into CPython interpreter); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.__loader__ identity — extra169
#
# abc.__loader__.__name__.__eq__('FrozenImporter')        == True
# abc.__loader__.__class__.__name__.__eq__('type')        == True
# ---------------------------------------------------------------------------

table abc_extra169.abc_loader_identity:
  description: "abc.__loader__ class identity checks in abcmodule169loader namespace — abc.__loader__.__name__.__eq__('FrozenImporter')==True (abc.__loader__ is the FrozenImporter class ITSELF — not an instance of FrozenImporter; the frozen module loader IS the class object _frozen_importlib.FrozenImporter; __name__=='FrozenImporter' (len=14: 'Frozen'=6+'Importer'=8=14); FrozenImporter is the loader for modules compiled into the CPython interpreter itself); abc.__loader__.__name__.__len__()==14 ('FrozenImporter'=14); abc.__loader__.__class__.__name__.__eq__('type')==True (since abc.__loader__ is a class (not an instance), its __class__ is 'type' — the metaclass of all ordinary Python classes; abc.__loader__.__class__.__name__=='type' (len=4); this is the key indicator that __loader__ is the class itself, not an instance); CONTRAST: a typical module's loader would be a SourceFileLoader INSTANCE (type(loader).__name__=='SourceFileLoader'); for frozen abc, the loader IS the FrozenImporter class (type(abc.__loader__).__name__=='type'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmodule169loader

  columns: [id, function, args, expected, description]
  rows:
    - [loader_name_eq,    abc.__loader__.__name__.__eq__,               ["FrozenImporter"],  true,  "abc.__loader__.__name__ == 'FrozenImporter' (len=14; loader IS the class itself, not an instance); verified with Python 3.14.3"]
    - [loader_name_len,   abc.__loader__.__name__.__len__,              [],                  14,    "abc.__loader__.__name__.__len__() == 14 ('FrozenImporter'=14: 'Frozen'=6+'Importer'=8=14); verified with Python 3.14.3"]
    - [loader_cls_name,   abc.__loader__.__class__.__name__.__eq__,     ["type"],            true,  "abc.__loader__.__class__.__name__ == 'type' (loader IS a class object; its __class__ is 'type'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.get_cache_token identity — extra169
#
# abc.get_cache_token.__name__.__eq__('get_cache_token')  == True (len=15)
# abc.get_cache_token.__module__.__eq__('_abc')            == True
# ---------------------------------------------------------------------------

table abc_extra169.abc_get_cache_token_identity:
  description: "abc.get_cache_token function identity checks in abcmodule169gct namespace — abc.get_cache_token.__name__.__eq__('get_cache_token')==True ('get_cache_token'=15: 'get'=3+'_'=1+'cache'=5+'_'=1+'token'=5=15; abc.get_cache_token is a function that returns the current abstract base class cache token — an integer that increments each time a new class is registered as a virtual subclass using ABCMeta.register() or ABC.register(); used to invalidate caches that depend on the ABC hierarchy); abc.get_cache_token.__name__.__len__()==15 ('get_cache_token'=15); abc.get_cache_token.__module__.__eq__('_abc')==True ('_abc'=4: underscore prefix indicates C extension; get_cache_token is implemented in Modules/_abc.c — the C extension that provides the core ABC machinery; the Python abc module imports get_cache_token from _abc); CONTRAST: abc.update_abstractmethods.__module__=='abc' (pure Python in Lib/abc.py) vs abc.get_cache_token.__module__=='_abc' (C extension in Modules/_abc.c); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmodule169gct

  columns: [id, function, args, expected, description]
  rows:
    - [gct_name_eq,    abc.get_cache_token.__name__.__eq__,    ["get_cache_token"],  true,  "get_cache_token.__name__ == 'get_cache_token' (len=15: 'get'=3+'_cache_token'=12=15); verified with Python 3.14.3"]
    - [gct_name_len,   abc.get_cache_token.__name__.__len__,   [],                   15,    "get_cache_token.__name__.__len__() == 15 ('get_cache_token'=15); verified with Python 3.14.3"]
    - [gct_mod_eq,     abc.get_cache_token.__module__.__eq__,  ["_abc"],             true,  "get_cache_token.__module__ == '_abc' (len=4; C extension; defined in Modules/_abc.c); verified with Python 3.14.3"]
    - [uam_mod_xchk,   abc.update_abstractmethods.__module__.__eq__,  ["abc"],       true,  "update_abstractmethods.__module__ == 'abc' (cross-check; pure Python abc.py; len=3; shorter than '_abc'=4); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.update_abstractmethods identity — extra169
#
# abc.update_abstractmethods.__name__.__eq__('update_abstractmethods')  == True (len=22)
# abc.update_abstractmethods.__module__.__eq__('abc')                    == True
# ---------------------------------------------------------------------------

table abc_extra169.abc_update_abstractmethods_identity:
  description: "abc.update_abstractmethods function identity checks in abcmodule169uam namespace — abc.update_abstractmethods.__name__.__eq__('update_abstractmethods')==True ('update_abstractmethods'=22: 'update'=6+'_'=1+'abstract'=8+'methods'=7=22; abc.update_abstractmethods was added in Python 3.10; it recalculates the set of abstract methods for a class — useful when methods are added or modified dynamically after class creation; if a class has been instantiated but later abstract methods are resolved via update_abstractmethods, the class can become instantiable); abc.update_abstractmethods.__name__.__len__()==22 ('update_abstractmethods'=22 is the longest function name in this spec; compare: 'get_cache_token'=15 is 7 chars shorter); abc.update_abstractmethods.__module__.__eq__('abc')==True (__module__=='abc' (len=3); update_abstractmethods is defined in Lib/abc.py (pure Python) UNLIKE get_cache_token which is in the _abc C extension; 'abc'=3 is shorter than '_abc'=4 by 1 char); DISTINCTION: update_abstractmethods.__module__=='abc' (pure Python; len=3) vs get_cache_token.__module__=='_abc' (C extension; len=4); the underscore prefix in '_abc' signals the C extension backing module; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmodule169uam

  columns: [id, function, args, expected, description]
  rows:
    - [uam_name_eq,    abc.update_abstractmethods.__name__.__eq__,    ["update_abstractmethods"],  true,  "update_abstractmethods.__name__ == 'update_abstractmethods' (len=22: longest name in spec); verified with Python 3.14.3"]
    - [uam_name_len,   abc.update_abstractmethods.__name__.__len__,   [],                          22,    "update_abstractmethods.__name__.__len__() == 22 ('update_abstractmethods'=22; 7 longer than get_cache_token=15); verified with Python 3.14.3"]
    - [uam_mod_eq,     abc.update_abstractmethods.__module__.__eq__,  ["abc"],                     true,  "update_abstractmethods.__module__ == 'abc' (len=3; pure Python Lib/abc.py; added in Python 3.10); verified with Python 3.14.3"]
    - [gct_mod_xchk,   abc.get_cache_token.__module__.__eq__,         ["_abc"],                    true,  "get_cache_token.__module__ == '_abc' (cross-check; C extension; len=4 > len('abc')=3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra169
# ---------------------------------------------------------------------------

invariant abc_extra169.abc_spec_class_is_ModuleSpec:
  description: "abc.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — abc.__spec__.__class__.__name__=='ModuleSpec' (len=10: 'Module'=6+'Spec'=4=10); ModuleSpec is importlib.machinery.ModuleSpec — the universal spec type for all modules loaded by the importlib machinery; abc uses ModuleSpec even as a frozen module; the spec stores metadata about the module: its name, loader, origin, submodule_search_locations, cached, parent, and has_location; abc.__spec__.name=='abc' (len=3); abc.__spec__.origin=='frozen' (string 'frozen'); abc.__spec__.submodule_search_locations is None (abc is not a package); COMPARISON: asyncio.__spec__.__class__.__name__=='ModuleSpec' (asyncio is a source module — also uses ModuleSpec; from asyncio_extra173); both frozen (abc) and source (asyncio) modules share the same ModuleSpec class — the difference is in .origin ('frozen' vs file path) and .loader (FrozenImporter class vs SourceFileLoader instance); NEW in extra169: first standalone abc.__spec__.__class__.__name__ invariant in abcmodule169spec namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant abc_extra169.abc_spec_origin_is_str:
  description: "abc.__spec__.origin.__class__.__name__.__eq__('str') returns True — abc.__spec__.origin.__class__.__name__=='str' (origin is a Python str; abc.__spec__.origin=='frozen' (len=6)); for frozen modules, the origin is the string literal 'frozen'; for source file modules (like asyncio), the origin is a file system path string (e.g., '/usr/lib/python3.14/asyncio/__init__.py'); in both cases __class__.__name__=='str' — the type of origin is always str (when origin is not None); abc.__spec__.origin.__eq__('frozen')==True confirms the content; STRUCTURAL NOTE: abc.__spec__ has: name='abc', loader=FrozenImporter (the class), origin='frozen', submodule_search_locations=None, has_location=False; asyncio.__spec__ has: name='asyncio', loader=SourceFileLoader instance, origin='/path/to/asyncio/__init__.py', submodule_search_locations=[...], has_location=True; NEW in extra169: first standalone abc.__spec__.origin.__class__.__name__ invariant in abcmodule169spec namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra169.abc_loader_name_is_FrozenImporter:
  description: "abc.__loader__.__name__.__eq__('FrozenImporter') returns True — abc.__loader__.__name__=='FrozenImporter' (len=14: 'Frozen'=6+'Importer'=8=14); abc.__loader__ is the FrozenImporter class itself (not an instance); FrozenImporter is defined in _frozen_importlib (the bootstrap importlib module that is itself frozen into CPython); FrozenImporter is responsible for loading all frozen modules: abc, _abc, _functools, _collections, _io, and others; abc.__loader__.__class__.__name__=='type' (FrozenImporter is a class; its metaclass is type); COMPARISON: a source module's __loader__ would be a SourceFileLoader INSTANCE (abc.__loader__.__class__.__name__=='SourceFileLoader' — an instance); abc.__loader__.__class__.__name__=='type' (a CLASS — not an instance); 'FrozenImporter'=14 matches abstractmethod.__name__='abstractmethod'=14 (from abc_extra168; same length; coincidence); NEW in extra169: first standalone abc.__loader__.__name__ invariant in abcmodule169loader namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__loader__.__name__.__eq__
  args: ["FrozenImporter"]
  expected: true

invariant abc_extra169.abc_get_cache_token_name_eq:
  description: "abc.get_cache_token.__name__.__eq__('get_cache_token') returns True — abc.get_cache_token.__name__=='get_cache_token' (len=15: 'get'=3+'_'=1+'cache'=5+'_'=1+'token'=5=15); abc.get_cache_token() returns an integer token that increments each time a class is registered as a virtual subclass of an ABC; it is used by code that caches ABC-subclass relationships to know when to invalidate those caches; the token is a monotonically increasing integer — comparing tokens tells you if the ABC registry has changed; abc.get_cache_token is re-exported from the _abc C extension: abc.get_cache_token.__module__=='_abc' (the C module where it is implemented in Modules/_abc.c); NAME LENGTH: 'get_cache_token'=15 > 'abstractmethod'=14 (from abc_extra168) by 1; 'get_cache_token'=15 < 'update_abstractmethods'=22 by 7; NEW in extra169: first standalone get_cache_token.__name__ identity invariant in abcmodule169gct namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__name__.__eq__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra169.abc_get_cache_token_module_is_abc_c_ext:
  description: "abc.get_cache_token.__module__.__eq__('_abc') returns True — abc.get_cache_token.__module__=='_abc' (len=4: '_'=1+'abc'=3=4; the underscore prefix marks _abc as a C extension module); abc.get_cache_token is defined in Modules/_abc.c and re-exported by Lib/abc.py into the abc namespace; the _abc C extension provides the performance-critical core of the ABC machinery: get_cache_token(), ABCMeta.__instancecheck__() and __subclasscheck__() acceleration, and _get_dump() for debugging; '_abc'=4 is 1 char longer than 'abc'=3 — the C backing module adds the underscore prefix; PATTERN: many Python standard library modules have this C/Python split: abc (Python) + _abc (C); functools (Python) + _functools (C); collections (Python) + _collections (C); pickle (Python) + _pickle (C); NEW in extra169: first standalone get_cache_token.__module__ identity invariant in abcmodule169gct namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra169.abc_update_abstractmethods_name_eq:
  description: "abc.update_abstractmethods.__name__.__eq__('update_abstractmethods') returns True — abc.update_abstractmethods.__name__=='update_abstractmethods' (len=22: 'update'=6+'_'=1+'abstract'=8+'methods'=7=22; 22 is the longest function name in this spec and in the abc spec series so far); abc.update_abstractmethods was added in Python 3.10; it takes a class object and recomputes its __abstractmethods__ frozenset — useful when a class has been dynamically modified to add or remove abstract methods after its initial creation; update_abstractmethods(cls) is equivalent to: ABCMeta.__new__ rerunning the abstract method detection logic on an already-created class; NAME LENGTH COMPARISON in this spec: 'frozen'=6 (spec.origin) < 'str'=3 (origin class name — wait: 'str'=3) < '_abc'=4 (C ext) < 'abc'=3 (Python module) ... actually: 'abc'=3 < '_abc'=4 < 'get_cache_token'=15 < 'update_abstractmethods'=22; 22 chars makes this the longest name here; __module__=='abc' (pure Python Lib/abc.py; NOT in the _abc C extension); NEW in extra169: first standalone update_abstractmethods.__name__ invariant in abcmodule169uam namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.update_abstractmethods.__name__.__eq__
  args: ["update_abstractmethods"]
  expected: true

invariant abc_extra169.abc_update_abstractmethods_module_eq:
  description: "abc.update_abstractmethods.__module__.__eq__('abc') returns True — abc.update_abstractmethods.__module__=='abc' (len=3: 'a'+'b'+'c'=3); update_abstractmethods is defined in Lib/abc.py (pure Python) — it was added in Python 3.10 as a pure Python addition to the abc module; CONTRAST: abc.get_cache_token.__module__=='_abc' (C extension; len=4) vs abc.update_abstractmethods.__module__=='abc' (pure Python; len=3); the distinction reflects their implementation: get_cache_token needs C-level access to the ABCMeta internal token counter (a C int), while update_abstractmethods can be implemented purely in Python by inspecting __isabstractmethod__ attributes; MODULE PATH: 'abc'=3 is the shortest module path in the entire spec series (from abc_extra168: same observation); '__module__'=='abc' places update_abstractmethods in the same namespace as abstractmethod, ABCMeta, ABC, get_cache_token (all re-exported under the 'abc' name); NEW in extra169: first standalone update_abstractmethods.__module__ invariant in abcmodule169uam namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.update_abstractmethods.__module__.__eq__
  args: ["abc"]
  expected: true
