spec: struct_extra1831
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "struct stdlib documentation"
    - "CPython source: Modules/_struct.c"
  not_derived_from:
    - "third-party binary packing libraries"
  notes:
    - "struct.Struct is a C extension type; it uses __new__ but not __init__ (C types typically do not define __init__ in their __dict__)"
    - "struct.Struct instances are not callable — no __call__ in Struct.__dict__"
    - "struct.error is an exception class inheriting from Exception; it does not define __init__ or __new__ in its own __dict__"
    - "struct module-level functions (pack, unpack, calcsize, iter_unpack) are builtin_function_or_method objects"
    - "struct.Struct defines pack, unpack, unpack_from, pack_into, iter_unpack, and size in its __dict__"
    - "struct module does not implement descriptor protocol or callable protocol at module level"
  created_at: "2026-04-12"

table struct_extra1831.descriptor_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["st1831-dp-001", "struct.Struct.__dict__.__contains__", ["__get__"], false]
    - ["st1831-dp-002", "struct.Struct.__dict__.__contains__", ["__set__"], false]
    - ["st1831-dp-003", "struct.Struct.__dict__.__contains__", ["__delete__"], false]
    - ["st1831-dp-004", "struct.Struct.__dict__.__contains__", ["__set_name__"], false]
    - ["st1831-dp-005", "struct.error.__dict__.__contains__", ["__get__"], false]
    - ["st1831-dp-006", "struct.error.__dict__.__contains__", ["__set__"], false]
    - ["st1831-dp-007", "struct.__dict__.__contains__", ["__get__"], false]
    - ["st1831-dp-008", "struct.__dict__.__contains__", ["__set__"], false]

table struct_extra1831.callable_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["st1831-cp-001", "struct.Struct.__dict__.__contains__", ["__call__"], false]
    - ["st1831-cp-002", "struct.error.__dict__.__contains__", ["__call__"], false]
    - ["st1831-cp-003", "struct.Struct.__dict__.__contains__", ["__init__"], false]
    - ["st1831-cp-004", "struct.Struct.__dict__.__contains__", ["__new__"], true]
    - ["st1831-cp-005", "struct.error.__dict__.__contains__", ["__init__"], false]
    - ["st1831-cp-006", "struct.error.__dict__.__contains__", ["__new__"], false]
    - ["st1831-cp-007", "struct.__dict__.__contains__", ["__call__"], false]
    - ["st1831-cp-008", "struct.__dict__.__contains__", ["__iter__"], false]

table struct_extra1831.struct_format_chars:
  columns: [id, function, args, expected]
  rows:
    - ["st1831-fc-001", "struct.__dict__.__contains__", ["pack"], true]
    - ["st1831-fc-002", "struct.__dict__.__contains__", ["unpack"], true]
    - ["st1831-fc-003", "struct.__dict__.__contains__", ["calcsize"], true]
    - ["st1831-fc-004", "struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st1831-fc-005", "struct.__dict__.__contains__", ["Struct"], true]
    - ["st1831-fc-006", "struct.__dict__.__contains__", ["error"], true]
    - ["st1831-fc-007", "struct.__dict__.__contains__", ["__doc__"], true]
    - ["st1831-fc-008", "struct.Struct.__dict__.__contains__", ["pack"], true]
    - ["st1831-fc-009", "struct.Struct.__dict__.__contains__", ["unpack"], true]
    - ["st1831-fc-010", "struct.Struct.__dict__.__contains__", ["size"], true]
