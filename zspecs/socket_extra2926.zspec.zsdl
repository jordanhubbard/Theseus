spec: sk2926
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket: Low-level networking interface"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 642 (sk2926): __iand__, __ior__, __ixor__ dict-presence checks for socket types."
    - "Wave 638 showed socket.AddressInfo and socket.MsgFlag define reflected bitwise ops (__rand__, __ror__, __rxor__) in their __dict__."
    - "Despite being IntFlag subclasses with reflected bitwise support, socket.AddressFamily, socket.SocketKind, socket.AddressInfo, and socket.MsgFlag do NOT define __iand__, __ior__, or __ixor__ in their own __dict__ on Python 3.14."
    - "In-place bitwise ops for IntFlag types are inherited from the IntFlag/int MRO and thus not present in the subclass __dict__ directly."
    - "socket.socket, socket.error, socket.herror, socket.gaierror, and socket.timeout likewise define none of these in-place bitwise operators."
    - "Verified types: socket.socket, socket.AddressFamily, socket.SocketKind, socket.AddressInfo, socket.MsgFlag, socket.error, socket.herror, socket.gaierror, socket.timeout."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk2926.iand:
  description: "socket types __iand__ dict-presence checks; wave 642"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2926
  columns: [id, function, args, expected]
  rows:
    - ["sk2926001", operator.contains, [socket.socket.__dict__,        "__iand__"], false]
    - ["sk2926002", operator.contains, [socket.AddressFamily.__dict__, "__iand__"], false]
    - ["sk2926003", operator.contains, [socket.SocketKind.__dict__,    "__iand__"], false]
    - ["sk2926004", operator.contains, [socket.AddressInfo.__dict__,   "__iand__"], false]
    - ["sk2926005", operator.contains, [socket.MsgFlag.__dict__,       "__iand__"], false]
    - ["sk2926006", operator.contains, [socket.error.__dict__,         "__iand__"], false]
    - ["sk2926007", operator.contains, [socket.herror.__dict__,        "__iand__"], false]
    - ["sk2926008", operator.contains, [socket.gaierror.__dict__,      "__iand__"], false]

