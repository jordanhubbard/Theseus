spec: bz2_extra8
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
  notes:
    - "This spec extends bz2.zspec.zsdl through bz2_extra7.zspec.zsdl."
    - "bz2 (base) covers: class_names, module_checks, function_names tables, compress magic bytes, compress nonempty output, BZ2Compressor/BZ2Decompressor is_type, BZ2Decompressor.eof initially false."
    - "bz2_extra covers: BZ2File/BZ2Compressor/BZ2Decompressor __name__/__module__, compress/decompress/open __name__, compress returns bytes (method_chain)."
    - "bz2_extra2 covers: compress/decompress/open __module__ table, BZ2Compressor/BZ2Decompressor instance method names, BZ2File method names, base class checks, class_is_type checks."
    - "bz2_extra3 covers: BZ2File/__name__, BZ2Compressor/__name__, BZ2Decompressor/__name__, compress/decompress/open __name__ table, BZ2File/__module__, BZ2Compressor/__module__, compress magic B/Z, compress/__module__, decompress/__module__."
    - "bz2_extra4 covers: BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ table, open/compress/decompress __qualname__ table, compress(b'') class name (method_chain), BZ2File.__qualname__ is str, compress(b'') nonempty output."
    - "bz2_extra5 covers: BZ2File/BZ2Compressor/BZ2Decompressor __name__ table (cn5), BZ2File.__module__ table, BZ2File.__qualname__ standalone, open.__name__ standalone, BZ2File.__bases__[0].__name__ == 'BaseStream' (bool form)."
    - "bz2_extra6 covers: BZ2Compressor/__module__=='_bz2' and BZ2Decompressor/__module__=='_bz2', BZ2Compressor/BZ2Decompressor base is object, compress/decompress/open __code__.co_name table, BZ2Decompressor().needs_input==True, BZ2Decompressor().unused_data==b'', BZ2Compressor.__qualname__.__class__.__name__=='str'."
    - "bz2_extra7 covers: BZ2File/BZ2Compressor/BZ2Decompressor __name__/__module__ standalone (bz7 prefix), open/compress/decompress __module__ standalone, BZ2File.__bases__[0].__name__ string-return form, BZ2Compressor() instance class name, BZ2Decompressor.__qualname__.__class__.__name__=='str'."
    - "NOT yet covered: BZ2Compressor().compress.__name__ == 'compress' as python_call_eq invariant from extra8 namespace."
    - "NOT yet covered: BZ2Compressor().flush.__name__ == 'flush' as python_call_eq invariant from extra8 namespace."
    - "NOT yet covered: BZ2Decompressor().decompress.__name__ == 'decompress' from extra8 namespace."
    - "NOT yet covered: BZ2Decompressor().eof.__class__.__name__ == 'bool' — the eof attribute is always a bool."
    - "NOT yet covered: BZ2Decompressor().needs_input.__class__.__name__ == 'bool'."
    - "NOT yet covered: BZ2Decompressor().unused_data.__class__.__name__ == 'bytes'."
    - "NOT yet covered: BZ2Decompressor().__class__.__name__ == 'BZ2Decompressor' — instance type check."
    - "NOT yet covered: BZ2File.__mro__[1].__name__ == 'BaseStream' — second MRO entry."
    - "NOT yet covered: BZ2File.__qualname__.__class__.__name__ == 'str'."
    - "NOT yet covered: decompress(pre-computed-bz2-of-hello-world) == b'hello world' as python_call_eq invariant."
    - "bz2.BZ2Decompressor().eof is False initially and its type is bool (not int)."
    - "bz2.BZ2Decompressor().needs_input is True initially (ready for more compressed input)."
    - "bz2.BZ2Decompressor().unused_data is b'' initially (no trailing data consumed yet)."
    - "Pre-computed bz2 of b'hello world' (hex): 425a683931415926535944f7137800000191804000064490802000220334843021b68154278bb9229c2848227b89bc00 — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BZ2Compressor instance method __name__ attributes
#
# bz2_extra2 covers instance method names via method_chain in invariant blocks.
# These standalone python_call_eq invariants verify compress and flush
# __name__ attributes from the extra8 namespace.
# ---------------------------------------------------------------------------

invariant bz2_extra8.BZ2Compressor.compress_method_name:
  description: "bz2.BZ2Compressor().compress.__name__ == 'compress'"
  category: method_names
  kind: python_call_eq
  function: BZ2Compressor
  args: []
  method: compress.__name__.__eq__
  method_args: ["compress"]
  expected: true

invariant bz2_extra8.BZ2Compressor.flush_method_name:
  description: "bz2.BZ2Compressor().flush.__name__ == 'flush'"
  category: method_names
  kind: python_call_eq
  function: BZ2Compressor
  args: []
  method: flush.__name__.__eq__
  method_args: ["flush"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2Decompressor instance method __name__ attribute
#
# bz2_extra2 covers decompress method name via method_chain on a BZ2Decompressor.
# This standalone invariant verifies it from the extra8 namespace.
# ---------------------------------------------------------------------------

invariant bz2_extra8.BZ2Decompressor.decompress_method_name:
  description: "bz2.BZ2Decompressor().decompress.__name__ == 'decompress'"
  category: method_names
  kind: python_call_eq
  function: BZ2Decompressor
  args: []
  method: decompress.__name__.__eq__
  method_args: ["decompress"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2Decompressor instance attribute types
#
# bz2_extra6 covers the values of needs_input (True) and unused_data (b'').
# No prior spec checks the types of these attributes.
# ---------------------------------------------------------------------------

invariant bz2_extra8.BZ2Decompressor.eof_is_bool:
  description: "bz2.BZ2Decompressor().eof.__class__.__name__ == 'bool' — eof attribute is always a bool"
  category: types
  kind: python_call_eq
  function: BZ2Decompressor
  args: []
  method: eof.__class__.__name__.__eq__
  method_args: ["bool"]
  expected: true

invariant bz2_extra8.BZ2Decompressor.needs_input_is_bool:
  description: "bz2.BZ2Decompressor().needs_input.__class__.__name__ == 'bool' — needs_input attribute is always a bool"
  category: types
  kind: python_call_eq
  function: BZ2Decompressor
  args: []
  method: needs_input.__class__.__name__.__eq__
  method_args: ["bool"]
  expected: true

invariant bz2_extra8.BZ2Decompressor.unused_data_is_bytes:
  description: "bz2.BZ2Decompressor().unused_data.__class__.__name__ == 'bytes' — unused_data attribute is always bytes"
  category: types
  kind: python_call_eq
  function: BZ2Decompressor
  args: []
  method: unused_data.__class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2Decompressor() instance type check
#
# bz2_extra7 checks BZ2Compressor().__class__.__name__. No prior spec
# verifies this for BZ2Decompressor instances from the extra8 namespace.
# ---------------------------------------------------------------------------

invariant bz2_extra8.BZ2Decompressor.instance_class_name:
  description: "bz2.BZ2Decompressor().__class__.__name__ == 'BZ2Decompressor'"
  category: types
  kind: python_call_eq
  function: BZ2Decompressor
  args: []
  method: __class__.__name__.__eq__
  method_args: ["BZ2Decompressor"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2File.__mro__[1].__name__ — second MRO entry is BaseStream
#
# bz2_extra5 and bz2_extra7 check __bases__[0].__name__ == 'BaseStream'.
# The MRO access pattern is a distinct axis. No prior spec verifies
# BZ2File.__mro__[1].__name__.
# ---------------------------------------------------------------------------

invariant bz2_extra8.BZ2File.mro_base_is_BaseStream:
  description: "bz2.BZ2File.__mro__[1].__name__ == 'BaseStream' — second MRO entry is BaseStream"
  category: hierarchy
  kind: python_call_eq
  function: BZ2File.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "BaseStream"

# ---------------------------------------------------------------------------
# BZ2File.__qualname__.__class__.__name__ == 'str'
#
# bz2_extra6 checks BZ2Compressor.__qualname__.__class__.__name__.
# bz2_extra7 checks BZ2Decompressor.__qualname__.__class__.__name__.
# BZ2File is the remaining class in the module — not yet covered.
# ---------------------------------------------------------------------------

invariant bz2_extra8.BZ2File.qualname_is_str:
  description: "bz2.BZ2File.__qualname__.__class__.__name__ == 'str' — __qualname__ is always a str"
  category: qualnames
  kind: python_call_eq
  function: BZ2File.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# decompress(pre-computed) — roundtrip verification
#
# Pre-computed bz2 bytes of b'hello world' (level 9, default).
# Verifies that decompress correctly recovers the original data.
# bz2_extra covers that compress returns bytes; no prior spec checks
# decompress against a pre-computed compressed value.
# ---------------------------------------------------------------------------

invariant bz2_extra8.decompress.precomputed_hello_world:
  description: "bz2.decompress(pre-computed-bz2-of-hello-world) == b'hello world'"
  category: roundtrip
  kind: python_call_eq
  function: decompress
  args: [!hex 425a683931415926535944f7137800000191804000064490802000220334843021b68154278bb9229c2848227b89bc00]
  method: __eq__
  method_args: [!ascii "hello world"]
  expected: true
