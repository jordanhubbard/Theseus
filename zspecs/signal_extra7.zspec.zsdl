spec: signal_extra7
version: ">=3.9"
backend: python_module(signal)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/signal.html — Python signal module documentation"
    - "POSIX.1-2017 — The Open Group Base Specifications Issue 7, 2018 Edition"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
  notes:
    - "Extends signal.zspec.zsdl through signal_extra6.zspec.zsdl."
    - "signal.zspec covers: POSIX signal int values; Signals/Handlers class names; SIG_DFL/SIG_IGN values; strsignal strings for SIGINT/SIGTERM/SIGHUP/SIGKILL/SIGQUIT/SIGALRM/SIGPIPE."
    - "signal_extra covers: getsignal/raise_signal/strsignal/valid_signals __name__; SIG_DFL/SIG_IGN/SIGABRT/SIGFPE/SIGILL/SIGINT/SIGSEGV/SIGTERM class names; valid_signals() type and membership for SIGINT/SIGTERM."
    - "signal_extra2 covers: function __module__ table; signal/getsignal __name__; SIG_DFL/SIG_IGN/SIGTERM/SIGINT class names; Signals/Handlers __name__; Signals/Handlers __bases__[0].__name__."
    - "signal_extra3 covers: module __name__; NSIG >= 16; NSIG is_int; SIGHUP/SIGKILL/SIGQUIT/SIGALRM/SIGPIPE class names; SIGHUP/SIGKILL .name; SIG_DFL/SIG_IGN .name."
    - "signal_extra4 covers: function __qualname__ table; Signals/Handlers __qualname__; Signals/Handlers __module__."
    - "signal_extra5 covers: SIGABRT/SIGFPE/SIGILL/SIGSEGV .name; Signals.SIGABRT.value and Signals.SIGHUP.value; strsignal for SIGABRT/SIGFPE/SIGILL/SIGSEGV; valid_signals() membership for SIGHUP/SIGKILL/SIGQUIT/SIGABRT."
    - "signal_extra6 covers: NSIG == 32; Signals.SIGQUIT/SIGALRM/SIGPIPE .value; SIGQUIT/SIGALRM/SIGPIPE .name."
    - "This spec adds: Signals.SIGUSR1/SIGUSR2/SIGCHLD/SIGWINCH .value checks; SIGUSR1/SIGUSR2/SIGCHLD/SIGWINCH .name checks; strsignal for SIGUSR1/SIGUSR2/SIGCHLD/SIGWINCH; valid_signals() membership for SIGUSR1/SIGUSR2/SIGCHLD/SIGWINCH."
    - "SIGUSR1 == 30, SIGUSR2 == 31 on macOS/Darwin (differs from Linux: USR1=10, USR2=12)."
    - "SIGCHLD == 20 on macOS/Darwin (Linux: SIGCHLD == 17)."
    - "SIGWINCH == 28 on macOS/Darwin (Linux: SIGWINCH == 28 — same)."
    - "strsignal(30) == 'User defined signal 1: 30' on macOS/Darwin."
    - "strsignal(31) == 'User defined signal 2: 31' on macOS/Darwin."
    - "strsignal(20) == 'Child exited: 20' on macOS/Darwin."
    - "strsignal(28) == 'Window size changes: 28' on macOS/Darwin."
    - "All four signals are members of valid_signals() on macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Signals enum — .value attributes for SIGUSR1, SIGUSR2, SIGCHLD, SIGWINCH
#
# signal.zspec covers Signals.SIGINT.value and Signals.SIGTERM.value.
# signal_extra5 covers Signals.SIGABRT.value and Signals.SIGHUP.value.
# signal_extra6 covers Signals.SIGQUIT.value, Signals.SIGALRM.value, Signals.SIGPIPE.value.
# New here: SIGUSR1 (30), SIGUSR2 (31), SIGCHLD (20), SIGWINCH (28) on macOS.
# ---------------------------------------------------------------------------

table signal_extra7.signal_enum_values:
  description: "SIGUSR1/SIGUSR2/SIGCHLD/SIGWINCH Signals enum .value attributes (macOS)"
  kind: python_call_eq
  category: enum
  id_prefix: evalue

  columns: [id, function, args, expected]
  rows:
    - [SIGUSR1,  Signals.SIGUSR1.value.__eq__,  [30], true]
    - [SIGUSR2,  Signals.SIGUSR2.value.__eq__,  [31], true]
    - [SIGCHLD,  Signals.SIGCHLD.value.__eq__,  [20], true]
    - [SIGWINCH, Signals.SIGWINCH.value.__eq__,  [28], true]

# ---------------------------------------------------------------------------
# Signals enum — .name attributes for SIGUSR1, SIGUSR2, SIGCHLD, SIGWINCH
#
# signal.zspec covers SIGINT.name and SIGTERM.name.
# signal_extra3 covers SIGHUP.name and SIGKILL.name.
# signal_extra5 covers SIGABRT/SIGFPE/SIGILL/SIGSEGV .name.
# signal_extra6 covers SIGQUIT/SIGALRM/SIGPIPE .name.
# New here: SIGUSR1, SIGUSR2, SIGCHLD, SIGWINCH .name.
# ---------------------------------------------------------------------------

table signal_extra7.signal_enum_names:
  description: "SIGUSR1/SIGUSR2/SIGCHLD/SIGWINCH enum .name attributes match their symbol"
  kind: python_call_eq
  category: enum_names
  id_prefix: ename

  columns: [id, function, args, expected]
  rows:
    - [SIGUSR1,  SIGUSR1.name.__eq__,  ["SIGUSR1"],  true]
    - [SIGUSR2,  SIGUSR2.name.__eq__,  ["SIGUSR2"],  true]
    - [SIGCHLD,  SIGCHLD.name.__eq__,  ["SIGCHLD"],  true]
    - [SIGWINCH, SIGWINCH.name.__eq__, ["SIGWINCH"], true]

# ---------------------------------------------------------------------------
# strsignal — OS-level descriptions for SIGUSR1, SIGUSR2, SIGCHLD, SIGWINCH
#
# signal.zspec covers: SIGINT/SIGTERM/SIGHUP/SIGKILL/SIGQUIT/SIGALRM/SIGPIPE.
# signal_extra5 covers: SIGABRT/SIGFPE/SIGILL/SIGSEGV.
# New here: SIGUSR1/SIGUSR2/SIGCHLD/SIGWINCH strsignal descriptions (macOS).
# ---------------------------------------------------------------------------

table signal_extra7.strsignal_user_signals:
  description: "strsignal descriptions for SIGUSR1/SIGUSR2/SIGCHLD/SIGWINCH on macOS"
  kind: python_call_eq
  category: strsignal
  id_prefix: strsignal

  columns: [id, function, args, expected]
  rows:
    - [sigusr1,  strsignal, [30], "User defined signal 1: 30"]
    - [sigusr2,  strsignal, [31], "User defined signal 2: 31"]
    - [sigchld,  strsignal, [20], "Child exited: 20"         ]
    - [sigwinch, strsignal, [28], "Window size changes: 28"  ]

# ---------------------------------------------------------------------------
# valid_signals() — membership for SIGUSR1, SIGUSR2, SIGCHLD, SIGWINCH
#
# signal_extra covers: SIGINT (2) and SIGTERM (15).
# signal_extra5 covers: SIGHUP (1), SIGKILL (9), SIGQUIT (3), SIGABRT (6).
# New here: SIGUSR1 (30), SIGUSR2 (31), SIGCHLD (20), SIGWINCH (28).
# ---------------------------------------------------------------------------

table signal_extra7.valid_signals_membership:
  description: "SIGUSR1/SIGUSR2/SIGCHLD/SIGWINCH are all in valid_signals()"
  kind: python_call_eq
  category: valid_signals
  id_prefix: vs

  columns: [id, function, args, expected]
  rows:
    - [sigusr1,  valid_signals().__contains__, [30], true]
    - [sigusr2,  valid_signals().__contains__, [31], true]
    - [sigchld,  valid_signals().__contains__, [20], true]
    - [sigwinch, valid_signals().__contains__, [28], true]
