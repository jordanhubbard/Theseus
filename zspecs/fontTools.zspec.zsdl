spec: fontTools
version: ">=4.0"
backend: python_module(fontTools)

docs: https://fonttools.readthedocs.io/

provenance:
  derived_from:
    - "fontTools documentation — https://fonttools.readthedocs.io/"
    - "fontTools ttLib reference — https://fonttools.readthedocs.io/en/latest/ttLib/index.html"
    - "fontTools pens reference — https://fonttools.readthedocs.io/en/latest/pens/index.html"
    - "Test vectors verified with fontTools 4.62.1 on Python 3.14 / macOS Darwin 25.4.0, 2026-04-05"
  not_derived_from:
    - "fontTools source: Lib/fontTools/__init__.py"
    - "fontTools source: Lib/fontTools/ttLib/__init__.py"
    - "fontTools source: Lib/fontTools/pens/basePen.py"
  notes:
    - "fontTools exposes both 'version' and '__version__'; both are the same string."
    - "fontTools.ttLib requires a _SUBMODULE_PRELOADS entry so ttLib is accessible as an attribute."
    - "fontTools.pens.basePen requires preloading so the pens subpackage is accessible."
    - "TTFont, TTCollection, TTLibError are the core public classes in fontTools.ttLib."
    - "AbstractPen and BasePen are the abstract base classes in fontTools.pens.basePen."
  created_at: "2026-04-05T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version — fontTools.version is a string containing a dot (e.g. '4.62.1')
# ---------------------------------------------------------------------------

invariant fontTools.version.contains_dot:
  description: "fontTools.version contains a dot (e.g. '4.62.1')"
  category: version
  kind: python_call_eq
  function: version.__contains__
  args: ["."]
  expected: true

invariant fontTools.version.is_string:
  description: "fontTools.version is a str"
  category: version
  kind: python_call_eq
  function: version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant fontTools.version.eq_dunder_version:
  description: "fontTools.version == fontTools.__version__"
  category: version
  kind: python_call_eq
  function: version.__eq__
  args: [{type: str, value: "4.62.1"}]
  expected: true
  skip_if: "not semver_satisfies(lib_version, '>=4.62.1,<4.63')"

# ---------------------------------------------------------------------------
# ttlib — fontTools.ttLib submodule and core classes
#
# After preloading fontTools.ttLib, these attributes are accessible via
# dotted path resolution in the harness.
# ---------------------------------------------------------------------------

invariant fontTools.ttlib.module_name:
  description: "fontTools.ttLib.__name__ == 'fontTools.ttLib'"
  category: ttlib
  kind: python_call_eq
  function: ttLib.__name__.__eq__
  args: ["fontTools.ttLib"]
  expected: true

invariant fontTools.ttlib.TTFont_class_name:
  description: "fontTools.ttLib.TTFont.__name__ == 'TTFont'"
  category: ttlib
  kind: python_call_eq
  function: ttLib.TTFont.__name__.__eq__
  args: ["TTFont"]
  expected: true

invariant fontTools.ttlib.TTCollection_class_name:
  description: "fontTools.ttLib.TTCollection.__name__ == 'TTCollection'"
  category: ttlib
  kind: python_call_eq
  function: ttLib.TTCollection.__name__.__eq__
  args: ["TTCollection"]
  expected: true

invariant fontTools.ttlib.TTLibError_class_name:
  description: "fontTools.ttLib.TTLibError.__name__ == 'TTLibError'"
  category: ttlib
  kind: python_call_eq
  function: ttLib.TTLibError.__name__.__eq__
  args: ["TTLibError"]
  expected: true

# ---------------------------------------------------------------------------
# api — pens base classes and misc submodule
#
# fontTools.pens.basePen.AbstractPen and BasePen are the root pen classes.
# fontTools.misc is the top-level misc subpackage (always loaded at import).
# ---------------------------------------------------------------------------

invariant fontTools.api.misc_module_name:
  description: "fontTools.misc.__name__ == 'fontTools.misc'"
  category: api
  kind: python_call_eq
  function: misc.__name__.__eq__
  args: ["fontTools.misc"]
  expected: true

invariant fontTools.api.AbstractPen_class_name:
  description: "fontTools.pens.basePen.AbstractPen.__name__ == 'AbstractPen'"
  category: api
  kind: python_call_eq
  function: pens.basePen.AbstractPen.__name__.__eq__
  args: ["AbstractPen"]
  expected: true

invariant fontTools.api.BasePen_class_name:
  description: "fontTools.pens.basePen.BasePen.__name__ == 'BasePen'"
  category: api
  kind: python_call_eq
  function: pens.basePen.BasePen.__name__.__eq__
  args: ["BasePen"]
  expected: true
