spec: struct_extra202
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec covers struct module-level and class-level doc strings and name attributes; struct module functions are C-level builtins with no __code__."
    - "struct.Struct.__doc__.__class__.__name__ == 'str' — the Struct class docstring is a plain Python str; verified with Python 3.14.3."
    - "struct.Struct.__doc__.__len__() == 40 — the Struct class docstring is exactly 40 characters long; verified with Python 3.14.3."
    - "struct.error.__doc__ is None — the struct.error exception class has no docstring; type(struct.error.__doc__).__name__ == 'NoneType'; verified with Python 3.14.3."
    - "struct.__doc__.__class__.__name__ == 'str' — the struct module docstring is a plain Python str; verified with Python 3.14.3."
    - "struct.__doc__.__len__() == 1278 — the struct module docstring is exactly 1278 characters long; verified with Python 3.14.3."
    - "struct.Struct.__name__ == 'Struct' — the Struct class name attribute is the string 'Struct'; verified with Python 3.14.3."
    - "struct.Struct.__name__.__len__() == 6 — the class name 'Struct' has exactly 6 characters; verified with Python 3.14.3."
    - "struct.error.__name__ == 'error' — the error exception class name is 'error'; verified with Python 3.14.3."
    - "struct.__name__ == 'struct' — the module __name__ is 'struct'; verified with Python 3.14.3."
    - "struct.__package__ == '' — the struct module's __package__ is an empty string; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.Struct class doc and name attributes
#
# struct.Struct.__doc__ is a str of length 40.
# struct.Struct.__name__ is 'Struct' with length 6.
# ---------------------------------------------------------------------------

table struct_extra202.Struct_doc_and_name:
  description: "struct.Struct.__doc__ is str of len 40; struct.Struct.__name__ is 'Struct' len 6; new to extra202"
  kind: python_call_eq
  category: doc_attrs
  id_prefix: structcoflags202

  columns: [id, function, args, expected, description]
  rows:
    - [struct_doc_class_eq,
       Struct.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "struct.Struct.__doc__.__class__.__name__.__eq__('str') == True — the Struct class docstring is a plain Python str; verified with Python 3.14.3; new to extra202"]
    - [struct_doc_len_eq_40,
       Struct.__doc__.__len__,
       [],
       40,
       "struct.Struct.__doc__.__len__() == 40 — the Struct class docstring is exactly 40 characters long; verified with Python 3.14.3; new to extra202"]
    - [struct_name_class_eq,
       Struct.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "struct.Struct.__name__.__class__.__name__.__eq__('str') == True — the Struct class __name__ is a plain str; verified with Python 3.14.3; new to extra202"]
    - [struct_name_len_eq_6,
       Struct.__name__.__len__,
       [],
       6,
       "struct.Struct.__name__.__len__() == 6 — the class name 'Struct' has exactly 6 characters: S-t-r-u-c-t; verified with Python 3.14.3; new to extra202"]

# ---------------------------------------------------------------------------
# Table 2: struct.error class doc and name attributes
#
# struct.error.__doc__ is None (NoneType).
# struct.error.__name__ == 'error' with length 5.
# ---------------------------------------------------------------------------

table struct_extra202.error_doc_and_name:
  description: "struct.error.__doc__ is NoneType; struct.error.__name__ is 'error' of len 5; new to extra202"
  kind: python_call_eq
  category: doc_attrs
  id_prefix: structcoflags202

  columns: [id, function, args, expected, description]
  rows:
    - [error_doc_class_eq,
       error.__doc__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "struct.error.__doc__.__class__.__name__.__eq__('NoneType') == True — the struct.error exception class has no docstring; __doc__ is None whose type is NoneType; verified with Python 3.14.3; new to extra202"]
    - [error_name_class_eq,
       error.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "struct.error.__name__.__class__.__name__.__eq__('str') == True — the error class __name__ is a plain str; verified with Python 3.14.3; new to extra202"]
    - [error_name_eq,
       error.__name__.__eq__,
       ["error"],
       true,
       "struct.error.__name__.__eq__('error') == True — the exception class is named 'error'; verified with Python 3.14.3; new to extra202"]
    - [error_name_len_eq_5,
       error.__name__.__len__,
       [],
       5,
       "struct.error.__name__.__len__() == 5 — the class name 'error' has exactly 5 characters: e-r-r-o-r; verified with Python 3.14.3; new to extra202"]

# ---------------------------------------------------------------------------
# Table 3: struct module __doc__ and __name__ attributes
#
# struct.__doc__ is a str of length 1278.
# struct.__name__ == 'struct', struct.__package__ == ''.
# ---------------------------------------------------------------------------

table struct_extra202.module_doc_and_name:
  description: "struct.__doc__ is str of len 1278; struct.__name__ is 'struct'; struct.__package__ is '' of len 0; new to extra202"
  kind: python_call_eq
  category: doc_attrs
  id_prefix: structcoflags202

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_class_eq,
       __doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "struct.__doc__.__class__.__name__.__eq__('str') == True — the struct module docstring is a plain Python str; verified with Python 3.14.3; new to extra202"]
    - [module_doc_len_eq_1278,
       __doc__.__len__,
       [],
       1278,
       "struct.__doc__.__len__() == 1278 — the struct module docstring is exactly 1278 characters long; verified with Python 3.14.3; new to extra202"]
    - [module_name_eq,
       __name__.__eq__,
       ["struct"],
       true,
       "struct.__name__.__eq__('struct') == True — the module's __name__ attribute is the string 'struct'; verified with Python 3.14.3; new to extra202"]
    - [module_package_len_eq_0,
       __package__.__len__,
       [],
       0,
       "struct.__package__.__len__() == 0 — the struct module's __package__ is an empty string of length 0; verified with Python 3.14.3; new to extra202"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra202
# ---------------------------------------------------------------------------

invariant struct_extra202.Struct_doc_is_str:
  description: "struct.Struct.__doc__.__class__.__name__ == 'str' — the Struct class docstring is a plain Python str object; verified with Python 3.14.3; new to extra202"
  category: doc_attrs
  kind: python_call_eq
  function: Struct.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant struct_extra202.Struct_doc_len_is_40:
  description: "struct.Struct.__doc__.__len__() == 40 — the Struct class docstring is exactly 40 characters long; verified with Python 3.14.3; new to extra202"
  category: doc_attrs
  kind: python_call_eq
  function: Struct.__doc__.__len__
  args: []
  expected: 40

invariant struct_extra202.error_doc_is_nonetype:
  description: "struct.error.__doc__.__class__.__name__ == 'NoneType' — struct.error has no docstring; __doc__ is None; type(None).__name__ is 'NoneType'; verified with Python 3.14.3; new to extra202"
  category: doc_attrs
  kind: python_call_eq
  function: error.__doc__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant struct_extra202.module_doc_is_str:
  description: "struct.__doc__.__class__.__name__ == 'str' — the struct module docstring is a plain Python str; verified with Python 3.14.3; new to extra202"
  category: doc_attrs
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant struct_extra202.module_doc_len_is_1278:
  description: "struct.__doc__.__len__() == 1278 — the struct module docstring is exactly 1278 characters long; verified with Python 3.14.3; new to extra202"
  category: doc_attrs
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 1278

invariant struct_extra202.Struct_name_is_Struct:
  description: "struct.Struct.__name__.__eq__('Struct') == True — the Struct class __name__ attribute is the string 'Struct'; verified with Python 3.14.3; new to extra202"
  category: doc_attrs
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

invariant struct_extra202.error_name_is_error:
  description: "struct.error.__name__.__eq__('error') == True — the struct.error exception class __name__ is 'error'; verified with Python 3.14.3; new to extra202"
  category: doc_attrs
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant struct_extra202.module_package_len_is_0:
  description: "struct.__package__.__len__() == 0 — the struct module's __package__ is an empty string of length 0; top-level stdlib modules have __package__ == ''; verified with Python 3.14.3; new to extra202"
  category: doc_attrs
  kind: python_call_eq
  function: __package__.__len__
  args: []
  expected: 0
