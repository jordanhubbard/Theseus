spec: venv
version: ">=3.3"
backend: python_module(venv)

docs: https://docs.python.org/3/library/venv.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/venv.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/venv/__init__.py"
  notes:
    - "venv.EnvBuilder is the main class; venv.create() is a convenience wrapper around EnvBuilder."
    - "EnvBuilder is a plain Python class; type(EnvBuilder).__name__ == 'type'."
    - "venv.create is a Python function; type(create).__name__ == 'function'."
    - "EnvBuilder methods (create, setup_python, setup_scripts, install_scripts, post_setup, ensure_directories) are all Python functions."
    - "system_site_packages and clear are plain bool attributes set in __init__; they are not callable, so tested via __init__ inspection only."
    - "Tests do not invoke create() or EnvBuilder() methods that write to the filesystem."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name check — EnvBuilder
# ---------------------------------------------------------------------------

invariant venv.EnvBuilder.class_name:
  description: "venv.EnvBuilder.__name__ == 'EnvBuilder'"
  category: classnames
  kind: python_call_eq
  function: EnvBuilder.__name__.__eq__
  args: ["EnvBuilder"]
  expected: true

# ---------------------------------------------------------------------------
# Module check — EnvBuilder belongs to venv
# ---------------------------------------------------------------------------

invariant venv.EnvBuilder.module_name:
  description: "venv.EnvBuilder.__module__ == 'venv'"
  category: module
  kind: python_call_eq
  function: EnvBuilder.__module__.__eq__
  args: ["venv"]
  expected: true

# ---------------------------------------------------------------------------
# Type check — EnvBuilder is a type (class) object
# ---------------------------------------------------------------------------

invariant venv.EnvBuilder.is_type:
  description: "type(venv.EnvBuilder).__name__ == 'type' — EnvBuilder is a class"
  category: types
  kind: python_call_eq
  function: EnvBuilder.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Function name check — top-level venv.create
# ---------------------------------------------------------------------------

invariant venv.create.function_name:
  description: "venv.create.__name__ == 'create'"
  category: functions
  kind: python_call_eq
  function: create.__name__.__eq__
  args: ["create"]
  expected: true

invariant venv.create.is_function:
  description: "type(venv.create).__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: create.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder method name checks
# ---------------------------------------------------------------------------

table venv.EnvBuilder.method_names:
  kind: python_call_eq
  category: methods
  id_prefix: method

  columns: [id, function, args, expected]
  rows:
    - [create,             EnvBuilder.create.__name__.__eq__,             ["create"],             true]
    - [setup_python,       EnvBuilder.setup_python.__name__.__eq__,       ["setup_python"],       true]
    - [setup_scripts,      EnvBuilder.setup_scripts.__name__.__eq__,      ["setup_scripts"],      true]
    - [install_scripts,    EnvBuilder.install_scripts.__name__.__eq__,    ["install_scripts"],    true]
    - [post_setup,         EnvBuilder.post_setup.__name__.__eq__,         ["post_setup"],         true]
    - [ensure_directories, EnvBuilder.ensure_directories.__name__.__eq__, ["ensure_directories"], true]
