  not_derived_from: ["CPython source code"]
  notes: ["Checks functools.__package__.__class__.__name__, functools.__loader__.__class__.__name__, functools.__all__.__class__.__name__, functools.__all__.__len__(), singledispatch/__module__, singledispatchmethod/__module__, cached_property/__module__, partial/__module__ — not covered in _extra1126/_extra1141"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1156.package_loader_all_class_names:
  description: "functools.__package__, __loader__, and __all__ class name identity"
  kind: python_call_eq
  category: package_loader_all_class_names
  id_prefix: fn1156pl
  columns: [id, function, args, expected]
  rows:
    - [fn1156pl001, functools.__package__.__class__.__name__.__eq__,                ["str"],                          true]
    - [fn1156pl002, functools.__package__.__eq__,                                   ["functools"],                    true]
    - [fn1156pl003, functools.__loader__.__class__.__name__.__eq__,                 ["SourceFileLoader"],              true]
    - [fn1156pl004, functools.__all__.__class__.__name__.__eq__,                    ["list"],                         true]
    - [fn1156pl005, functools.__all__.__len__,                                      [],                               20]
    - [fn1156pl006, functools.__all__.__contains__,                                 ["reduce"],                       true]
    - [fn1156pl007, functools.__all__.__contains__,                                 ["partial"],                      true]
    - [fn1156pl008, functools.__all__.__contains__,                                 ["lru_cache"],                    true]

