spec: unittest_mock_extra
version: ">=3.8"
backend: python_module(unittest.mock)

docs: https://docs.python.org/3/library/unittest.mock.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unittest.mock.html — Python unittest.mock module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/unittest/mock.py"
  notes:
    - "This spec extends unittest_mock.zspec.zsdl."
    - "Focus: __qualname__ attributes and additional class/sentinel checks not yet covered."
    - "unittest.mock.Mock.__qualname__ == 'Mock' — top-level class, qualname equals name."
    - "unittest.mock.MagicMock.__qualname__ == 'MagicMock'."
    - "unittest.mock.AsyncMock.__qualname__ == 'AsyncMock'."
    - "unittest.mock.patch.__qualname__ == 'patch' — patch is a class used as decorator/context manager."
    - "unittest.mock.call.__qualname__ == 'call' — the module-level call object is an instance of _Call."
    - "unittest.mock.sentinel.__class__.__name__ == '_SentinelObject' — sentinel is a _SentinelObject."
    - "unittest.mock.DEFAULT.__class__.__name__ == '_SentinelObject' — DEFAULT is a sentinel value."
    - "unittest.mock.NonCallableMock.__qualname__ == 'NonCallableMock'."
    - "unittest.mock.PropertyMock.__qualname__ == 'PropertyMock'."
    - "unittest.mock.Mock.__module__ == 'unittest.mock' — all mock classes are defined in unittest.mock."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — class objects
# unittest_mock.zspec.zsdl covers __name__; this spec adds __qualname__.
# ---------------------------------------------------------------------------

table unittest_mock_extra.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [Mock,             Mock.__qualname__.__eq__,             ["Mock"],             true]
    - [MagicMock,        MagicMock.__qualname__.__eq__,        ["MagicMock"],        true]
    - [AsyncMock,        AsyncMock.__qualname__.__eq__,        ["AsyncMock"],        true]
    - [patch,            patch.__qualname__.__eq__,            ["patch"],            true]
    - [NonCallableMock,  NonCallableMock.__qualname__.__eq__,  ["NonCallableMock"],  true]
    - [PropertyMock,     PropertyMock.__qualname__.__eq__,     ["PropertyMock"],     true]

# ---------------------------------------------------------------------------
# __qualname__ check — call helper
# call is a module-level _Call instance, not a class; its __qualname__ is 'call'.
# ---------------------------------------------------------------------------

invariant unittest_mock_extra.call.qualname:
  description: "unittest.mock.call.__qualname__ == 'call'"
  category: qualnames
  kind: python_call_eq
  function: call.__qualname__.__eq__
  args: ["call"]
  expected: true

# ---------------------------------------------------------------------------
# sentinel and DEFAULT — class name checks
# sentinel is a module-level _SentinelObject instance.
# DEFAULT is a sentinel value; its __class__.__name__ is '_SentinelObject'.
# unittest_mock.zspec.zsdl covers sentinel.__class__.__name__; we add DEFAULT.
# ---------------------------------------------------------------------------

invariant unittest_mock_extra.DEFAULT.class_name:
  description: "unittest.mock.DEFAULT.__class__.__name__ == '_SentinelObject'"
  category: sentinel
  kind: python_call_eq
  function: DEFAULT.__class__.__name__.__eq__
  args: ["_SentinelObject"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ check — Mock (all mock classes defined in unittest.mock)
# unittest_mock.zspec.zsdl covers Mock/MagicMock/AsyncMock __module__;
# this invariant adds the standalone form as a new structural variant.
# ---------------------------------------------------------------------------

invariant unittest_mock_extra.Mock.module:
  description: "unittest.mock.Mock.__module__ == 'unittest.mock'"
  category: modules
  kind: python_call_eq
  function: Mock.__module__.__eq__
  args: ["unittest.mock"]
  expected: true
