spec: fileinput_extra7
version: ">=3.9"
backend: python_module(fileinput)

docs: https://docs.python.org/3/library/fileinput.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fileinput.html — Python fileinput module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fileinput.py"
    - "fileinput_extra2.zspec.zsdl — covers FileInput.__qualname__ standalone; input/filename/fileno/lineno/filelineno/isfirstline/isstdin qualname equality in a table"
    - "fileinput_extra3.zspec.zsdl — covers close/nextfile/hook_compressed/hook_encoded/FileInput __qualname__ as standalone invariants"
    - "fileinput_extra5.zspec.zsdl — covers qualname lengths for lineno/filelineno/isfirstline/isstdin/nextfile as standalone length invariants"
    - "fileinput_extra6.zspec.zsdl — covers qualname lengths for FileInput/input/filename/fileno/hook_compressed/hook_encoded as standalone length invariants"
  notes:
    - "This spec extends fileinput.zspec.zsdl and all prior fileinput_extra specs through fileinput_extra6.zspec.zsdl."
    - "Focus: standalone __qualname__ equality invariants for input, filename, fileno, lineno, filelineno, isfirstline, and isstdin."
    - "fileinput_extra2 covers these seven functions in a table but provides no standalone equality invariants for any of them."
    - "fileinput.input.__qualname__ == 'input' — standalone qualname equality invariant not previously written."
    - "fileinput.filename.__qualname__ == 'filename' — standalone qualname equality invariant not previously written."
    - "fileinput.fileno.__qualname__ == 'fileno' — standalone qualname equality invariant not previously written."
    - "fileinput.lineno.__qualname__ == 'lineno' — standalone qualname equality invariant not previously written."
    - "fileinput.filelineno.__qualname__ == 'filelineno' — standalone qualname equality invariant not previously written."
    - "fileinput.isfirstline.__qualname__ == 'isfirstline' — standalone qualname equality invariant not previously written."
    - "fileinput.isstdin.__qualname__ == 'isstdin' — standalone qualname equality invariant not previously written."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ equality table — input, filename, fileno, lineno, filelineno,
# isfirstline, isstdin
#
# fileinput_extra2 covers all seven in a table but provides no standalone
# equality invariants. fileinput_extra5 and fileinput_extra6 provide length
# standalone invariants for these functions. This table anchors the same seven
# functions in the extra7 namespace as a compact cross-reference for the
# standalone invariants below.
# ---------------------------------------------------------------------------

table fileinput_extra7.function_qualnames:
  description: "__qualname__ equality for fileinput module-level functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: qualname7

  columns: [id, function, args, expected]
  rows:
    - [input,       input.__qualname__.__eq__,       ["input"],       true]
    - [filename,    filename.__qualname__.__eq__,     ["filename"],    true]
    - [fileno,      fileno.__qualname__.__eq__,       ["fileno"],      true]
    - [lineno,      lineno.__qualname__.__eq__,       ["lineno"],      true]
    - [filelineno,  filelineno.__qualname__.__eq__,   ["filelineno"],  true]
    - [isfirstline, isfirstline.__qualname__.__eq__,  ["isfirstline"], true]
    - [isstdin,     isstdin.__qualname__.__eq__,      ["isstdin"],     true]

# ---------------------------------------------------------------------------
# Standalone __qualname__ equality invariants
#
# Each invariant below is individually addressable in the extra7 namespace.
# fileinput_extra5/extra6 provide length invariants for the same functions;
# these equality invariants form a complementary set.
# ---------------------------------------------------------------------------

invariant fileinput_extra7.input.qualname:
  description: "fileinput.input.__qualname__ == 'input' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: input.__qualname__.__eq__
  args: ["input"]
  expected: true

invariant fileinput_extra7.filename.qualname:
  description: "fileinput.filename.__qualname__ == 'filename' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: filename.__qualname__.__eq__
  args: ["filename"]
  expected: true

invariant fileinput_extra7.fileno.qualname:
  description: "fileinput.fileno.__qualname__ == 'fileno' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: fileno.__qualname__.__eq__
  args: ["fileno"]
  expected: true

invariant fileinput_extra7.lineno.qualname:
  description: "fileinput.lineno.__qualname__ == 'lineno' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: lineno.__qualname__.__eq__
  args: ["lineno"]
  expected: true

invariant fileinput_extra7.filelineno.qualname:
  description: "fileinput.filelineno.__qualname__ == 'filelineno' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: filelineno.__qualname__.__eq__
  args: ["filelineno"]
  expected: true

invariant fileinput_extra7.isfirstline.qualname:
  description: "fileinput.isfirstline.__qualname__ == 'isfirstline' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: isfirstline.__qualname__.__eq__
  args: ["isfirstline"]
  expected: true

invariant fileinput_extra7.isstdin.qualname:
  description: "fileinput.isstdin.__qualname__ == 'isstdin' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: isstdin.__qualname__.__eq__
  args: ["isstdin"]
  expected: true
