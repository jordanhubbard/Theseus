spec: concurrent_futures_extra616
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module constants, Future state, and executor introspection"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED constant type checks, Future method qualnames, and executor/exception module membership"
  created_at: "2026-04-12T00:00:00Z"

table concurrent_futures_extra616.wait_constants:
  description: "Verify that wait-condition constants are strings"
  kind: python_call_eq
  category: constant_type
  id_prefix: cf616st
  columns: [id, function, args, expected]
  rows:
    - [cf616st001, concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__, ["str"], true]
    - [cf616st002, concurrent.futures.FIRST_EXCEPTION.__class__.__name__.__eq__, ["str"], true]
    - [cf616st003, concurrent.futures.ALL_COMPLETED.__class__.__name__.__eq__, ["str"], true]

table concurrent_futures_extra616.future_qualnames:
  description: "Verify __qualname__ of concurrent.futures.Future methods"
  kind: python_call_eq
  category: qualname
  id_prefix: cf616qn
  columns: [id, function, args, expected]
  rows:
    - [cf616qn001, concurrent.futures.Future.running.__qualname__.__eq__, ["Future.running"], true]
    - [cf616qn002, concurrent.futures.Future.done.__qualname__.__eq__, ["Future.done"], true]
    - [cf616qn003, concurrent.futures.Future.cancelled.__qualname__.__eq__, ["Future.cancelled"], true]
    - [cf616qn004, concurrent.futures.Future.__str__.__qualname__.__eq__, ["Future.__str__"], true]

table concurrent_futures_extra616.doc_class_name:
  description: "Verify __module__ membership of executor and exception classes"
  kind: python_call_eq
  category: module_membership
  id_prefix: cf616dc
  columns: [id, function, args, expected]
  rows:
    - [cf616dc001, concurrent.futures.ThreadPoolExecutor.__module__.__eq__, ["concurrent.futures.thread"], true]
    - [cf616dc002, concurrent.futures.ProcessPoolExecutor.__module__.__eq__, ["concurrent.futures.process"], true]
    - [cf616dc003, concurrent.futures.BrokenExecutor.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf616dc004, concurrent.futures.InvalidStateError.__qualname__.__eq__, ["InvalidStateError"], true]
