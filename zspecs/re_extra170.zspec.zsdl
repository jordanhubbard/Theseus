spec: re_extra170
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module public function __name__ and __module__ attributes for compile, search, match, fullmatch, sub, findall, and finditer."
    - "re.compile.__name__ == 'compile' (len=7) — the function for creating compiled Pattern objects."
    - "re.compile.__module__ == 're' (len=2) — all re public functions share __module__ == 're'."
    - "re.search.__name__ == 'search' (len=6)."
    - "re.match.__name__ == 'match' (len=5)."
    - "re.fullmatch.__name__ == 'fullmatch' (len=9: 'full'(4)+'match'(5)=9)."
    - "re.sub.__name__ == 'sub' (len=3) — the shortest function name in this spec."
    - "re.findall.__name__ == 'findall' (len=7: 'find'(4)+'all'(3)=7)."
    - "re.finditer.__name__ == 'finditer' (len=8: 'find'(4)+'iter'(4)=8)."
    - "Function name length ascending sequence: sub(3) < match(5) < search(6) < compile(7)=findall(7) < finditer(8) < fullmatch(9)."
    - "All seven functions have __module__ == 're' (2 chars): uniform module attribution."
    - "sub (3 chars) is the shortest public re function name; fullmatch (9 chars) is the longest in this spec."
    - "compile (7) ties with findall (7) in function name length."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile and re.search function identity
# compile.__name__ == 'compile' (len=7), search.__name__ == 'search' (len=6)
# Both have __module__ == 're' (len=2)
# ---------------------------------------------------------------------------

table re_extra170.compile_search_identity:
  description: "re.compile.__name__=='compile' (len=7), re.compile.__module__=='re' (len=2); re.search.__name__=='search' (len=6), re.search.__module__=='re' (len=2); compile (7) > search (6) by 1; both are public re module functions"
  kind: python_call_eq
  category: identity
  id_prefix: refn170

  columns: [id, function, args, expected, description]
  rows:
    - [compile_name,   re.compile.__name__.__eq__,   ["compile"], true, "re.compile.__name__ == 'compile' — the function that creates a compiled regular expression (re.Pattern) from a pattern string; 'compile' has 7 characters: 'c-o-m-p-i-l-e'; compile (7 chars) == findall (7 chars): the two-way tie at 7 in the re public function name family; compile (7) > search (6) by 1; compile (7) < finditer (8) by 1; re.compile() is the primary function for creating reusable Pattern objects: compiled patterns are faster than calling re.search() with a raw string pattern repeatedly; re.compile.__name__ (7: 'compile') == re.Pattern.__name__.__len__() (7: 'Pattern') — coincidental tie between the compiler function name length and the output class name length; confirmed Python 3.14.3 macOS"]
    - [compile_module, re.compile.__module__.__eq__, ["re"],      true, "re.compile.__module__ == 're' — re.compile is defined in the public 're' module; 're' has 2 characters; re.compile.__module__ (2: 're') is the same for all seven public re functions in this spec: compile, search, match, fullmatch, sub, findall, finditer all have __module__ == 're' (2 chars); the 2-character module name 're' is shorter than any of the seven function names (minimum is sub (3 chars)); confirmed Python 3.14.3 macOS"]
    - [search_name,    re.search.__name__.__eq__,    ["search"],  true, "re.search.__name__ == 'search' — the function that scans through a string looking for the first location where the pattern matches; 'search' has 6 characters: 's-e-a-r-c-h'; search (6 chars) sits between match (5) and compile (7) in the ascending function name length sequence: sub(3) < match(5) < search(6) < compile(7)=findall(7) < finditer(8) < fullmatch(9); re.search() scans the entire string for a match anywhere (unlike re.match() which anchors at the start); search (6 chars) and match (5 chars) differ by 1 — the most closely separated pair in the function name length sequence; confirmed Python 3.14.3 macOS"]
    - [search_module,  re.search.__module__.__eq__, ["re"],       true, "re.search.__module__ == 're' — re.search is defined in the public 're' module; 're' has 2 characters; re.search.__module__ (2) == re.compile.__module__ (2): all public re functions share the 2-character module name 're'; the uniform module name across all seven re functions means they are all co-located in the same public module namespace; 're' (2 chars) < 'search' (6 chars) by 4 — the module name is 4 characters shorter than the search function name; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.match and re.fullmatch function identity
# match.__name__ == 'match' (len=5), fullmatch.__name__ == 'fullmatch' (len=9)
# fullmatch (9) == 'full'(4) + 'match'(5) — compound of 'full' prefix + 'match'
# fullmatch (9) > match (5) by 4 == len('full')
# ---------------------------------------------------------------------------

table re_extra170.match_fullmatch_identity:
  description: "re.match.__name__=='match' (len=5), re.match.__module__=='re' (len=2); re.fullmatch.__name__=='fullmatch' (len=9), re.fullmatch.__module__=='re' (len=2); fullmatch (9) = 'full'(4)+'match'(5) = 9; fullmatch (9) > match (5) by 4 == len('full')"
  kind: python_call_eq
  category: identity
  id_prefix: rematch170

  columns: [id, function, args, expected, description]
  rows:
    - [match_name,     re.match.__name__.__eq__,     ["match"],     true, "re.match.__name__ == 'match' — the function that applies the pattern only at the beginning of the string; 'match' has 5 characters: 'm-a-t-c-h'; match (5 chars) is the same string as re.Match.__name__ (also 'match'... wait: re.Match.__name__ == 'Match' (capital M) while re.match.__name__ == 'match' (lowercase m); the function 'match' (5, lowercase) and the class 'Match' (5, uppercase first) have the same 5-character length but differ in case; match (5 chars) < search (6 chars) by 1 — match and search are consecutive in the ascending function name length sequence; re.match() anchors at the beginning of the string; confirmed Python 3.14.3 macOS"]
    - [match_module,   re.match.__module__.__eq__,   ["re"],        true, "re.match.__module__ == 're' — re.match is defined in the public 're' module; 're' has 2 characters; re.match.__module__ (2) == re.search.__module__ (2) == re.compile.__module__ (2): all public re functions share the same 2-character module name; 're' (2 chars) < 'match' (5 chars) by 3 — the module name is 3 characters shorter than the match function name; confirmed Python 3.14.3 macOS"]
    - [fullmatch_name, re.fullmatch.__name__.__eq__, ["fullmatch"], true, "re.fullmatch.__name__ == 'fullmatch' — the function that applies the pattern to the entire string (anchors at both start and end); 'fullmatch' has 9 characters: 'full'(4)+'match'(5)=9; fullmatch (9 chars) is the longest re function name in this spec; fullmatch (9) > match (5) by 4 == len('full'): the 'full' prefix (4 chars) is the sole difference between 'fullmatch' and 'match'; re.fullmatch(p, s) is equivalent to re.match(p+'$', s) but cleaner; fullmatch (9 chars) > finditer (8 chars) by 1 — fullmatch is the longest of the seven function names in this spec; confirmed Python 3.14.3 macOS"]
    - [fullmatch_mod,  re.fullmatch.__module__.__eq__, ["re"],      true, "re.fullmatch.__module__ == 're' — re.fullmatch is defined in the public 're' module; 're' has 2 characters; all seven public re functions (compile, search, match, fullmatch, sub, findall, finditer) share __module__ == 're' (2 chars); 're' (2 chars) << 'fullmatch' (9 chars): the module name is less than a quarter the length of the fullmatch function name; the shortest module name (2 chars: 're') is paired with the longest function name (9 chars: 'fullmatch') — a 7-character gap between module and function name lengths; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.sub function identity
# sub.__name__ == 'sub' (len=3) — shortest re function name in this spec
# sub.__module__ == 're' (len=2)
# sub (3) is the global minimum function name length in this spec
# ---------------------------------------------------------------------------

table re_extra170.sub_identity:
  description: "re.sub.__name__=='sub' (len=3), re.sub.__module__=='re' (len=2); sub (3) is the shortest re function name in this spec: sub(3) < match(5) < search(6) < compile(7)=findall(7) < finditer(8) < fullmatch(9); sub module name 're' (2) is 1 shorter than 'sub' (3)"
  kind: python_call_eq
  category: identity
  id_prefix: resub170

  columns: [id, function, args, expected, description]
  rows:
    - [sub_name,      re.sub.__name__.__eq__,   ["sub"],  true, "re.sub.__name__ == 'sub' — the function for substituting (replacing) occurrences of a pattern in a string; 'sub' has 3 characters: 's-u-b'; sub (3 chars) is the shortest function name in this spec: sub(3) < match(5) < search(6) < compile(7)=findall(7) < finditer(8) < fullmatch(9); the brevity of 'sub' (3 chars) contrasts with the more explicit names like 'fullmatch' (9 chars) and 'finditer' (8 chars); re.sub(pattern, repl, string) returns the string with all non-overlapping occurrences of pattern replaced by repl; 'sub' (3 chars) == len('_io') (3 chars: the io C extension module name) — a cross-module coincidental tie at 3 characters; confirmed Python 3.14.3 macOS"]
    - [sub_module,    re.sub.__module__.__eq__, ["re"],   true, "re.sub.__module__ == 're' — re.sub is defined in the public 're' module; 're' has 2 characters; re.sub.__module__ (2) < re.sub.__name__ (3) by 1 — the module name is 1 character shorter than the function name; this 2-vs-3 gap between module name ('re') and function name ('sub') is the smallest such gap among the seven re functions in this spec; the 1-character gap: re (2 chars) and sub (3 chars) differ by exactly 1; all seven re public functions share __module__ == 're' (2 chars): compile, search, match, fullmatch, sub, findall, finditer; confirmed Python 3.14.3 macOS"]
    - [sub_name_len,  re.sub.__name__.__len__,  [],      3,    "re.sub.__name__.__len__() == 3 — 'sub' has 3 characters; sub (3) is the minimum function name length among the seven public re functions in this spec; the ascending length sequence: sub(3) < match(5) < search(6) < compile(7)=findall(7) < finditer(8) < fullmatch(9); sub (3 chars) is also the length of the io C extension module name '_io' (3 chars) — a coincidental cross-module tie at 3; re.sub.__name__.__len__() (3) == re.sub.__module__.__len__() (2) + 1: the function name is exactly 1 character longer than its module name; confirmed Python 3.14.3 macOS"]
    - [sub_ne_find,   re.sub.__name__.__eq__,   ["findall"], false, "re.sub.__name__.__eq__('findall') == False — 'sub' (3 chars) != 'findall' (7 chars); sub is the substitution function while findall is the find-all-matches function — completely different operations with very different name lengths; sub (3) < findall (7) by 4; the two functions represent opposite ends of common regex operations: sub() transforms strings by replacement, findall() extracts all matching substrings; re.sub.__name__ ('sub', 3 chars) is the minimum-length function name in this spec while re.findall.__name__ ('findall', 7 chars) ties for middle length with compile (7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.findall and re.finditer function identity
# findall.__name__ == 'findall' (len=7), finditer.__name__ == 'finditer' (len=8)
# Both share 'find' prefix (4 chars); findall (7) < finditer (8) by 1
# findall (7) ties with compile (7) in name length
# ---------------------------------------------------------------------------

table re_extra170.findall_finditer_identity:
  description: "re.findall.__name__=='findall' (len=7), re.findall.__module__=='re' (len=2); re.finditer.__name__=='finditer' (len=8), re.finditer.__module__=='re' (len=2); findall (7) < finditer (8) by 1; both share 'find' prefix (4 chars)"
  kind: python_call_eq
  category: identity
  id_prefix: refind170

  columns: [id, function, args, expected, description]
  rows:
    - [findall_name,   re.findall.__name__.__eq__,   ["findall"],   true, "re.findall.__name__ == 'findall' — the function that returns a list of all non-overlapping matches; 'findall' has 7 characters: 'find'(4)+'all'(3)=7; findall (7 chars) ties with compile (7 chars) in function name length — a two-way tie at 7 in the seven-function name family; findall (7 chars) > search (6 chars) by 1; findall (7 chars) < finditer (8 chars) by 1: findall and finditer are adjacent in the ascending length sequence; the 'find' prefix (4 chars) is shared between findall ('find'+'all') and finditer ('find'+'iter'); re.findall() returns a list of strings or groups; confirmed Python 3.14.3 macOS"]
    - [findall_module, re.findall.__module__.__eq__, ["re"],        true, "re.findall.__module__ == 're' — re.findall is defined in the public 're' module; 're' has 2 characters; re.findall.__module__ (2) == all other re public function modules (2 chars each): compile, search, match, fullmatch, sub, finditer all have __module__ == 're'; 're' (2 chars) < 'findall' (7 chars) by 5 — the module name is 5 characters shorter than the findall function name; confirmed Python 3.14.3 macOS"]
    - [finditer_name,  re.finditer.__name__.__eq__,  ["finditer"],  true, "re.finditer.__name__ == 'finditer' — the function that returns an iterator yielding Match objects for all non-overlapping matches; 'finditer' has 8 characters: 'find'(4)+'iter'(4)=8; finditer (8 chars) > findall (7 chars) by 1 — the 'iter' suffix (4 chars) > 'all' suffix (3 chars) by 1; finditer (8 chars) < fullmatch (9 chars) by 1: finditer is the second-longest function name in this spec; the 'find' prefix (4 chars) is shared between findall ('find'+'all': 4+3=7) and finditer ('find'+'iter': 4+4=8); finditer (8 chars) == len('StringIO') (8 chars) — a coincidental cross-module tie; confirmed Python 3.14.3 macOS"]
    - [finditer_module, re.finditer.__module__.__eq__, ["re"],      true, "re.finditer.__module__ == 're' — re.finditer is defined in the public 're' module; 're' has 2 characters; re.finditer.__module__ (2) == re.findall.__module__ (2): the two 'find*' functions share both the 'find' prefix in their names and the same 2-character module name 're'; 're' (2 chars) < 'finditer' (8 chars) by 6 — the module name is 6 characters shorter than the finditer function name; re.finditer() returns an iterator (lazy) while re.findall() returns a list (eager) — the name difference ('iter' vs 'all') reflects this lazy vs. eager distinction; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Function name length ordering across all seven re public functions
# sub(3) < match(5) < search(6) < compile(7)=findall(7) < finditer(8) < fullmatch(9)
# ---------------------------------------------------------------------------

table re_extra170.function_name_length_ordering:
  description: "re function name lengths: sub(3) < match(5) < search(6) < compile(7)=findall(7) < finditer(8) < fullmatch(9); two-way tie at 7 for compile and findall; sub (3) is minimum; fullmatch (9) is maximum; all seven have __module__=='re' (len=2)"
  kind: python_call_eq
  category: identity
  id_prefix: refnlen170

  columns: [id, function, args, expected, description]
  rows:
    - [sub_len_3,       re.sub.__name__.__len__,       [],  3, "re.sub.__name__.__len__() == 3 — 'sub' is the shortest re function name in this spec (minimum = 3); the ascending sequence: sub(3) < match(5) < search(6) < compile(7)=findall(7) < finditer(8) < fullmatch(9); sub (3) < match (5) by 2: there is a gap of 2 between the shortest (sub=3) and the next-shortest (match=5); sub (3) is 1 character longer than the 're' module name (2 chars); the 7 function names span lengths 3 through 9 (a range of 6 characters); confirmed Python 3.14.3 macOS"]
    - [match_len_5,     re.match.__name__.__len__,     [],  5, "re.match.__name__.__len__() == 5 — 'match' has 5 characters; match (5) is the second-shortest in the ascending function name sequence: sub(3) < match(5) < search(6) < compile(7)=findall(7) < finditer(8) < fullmatch(9); match (5) - sub (3) == 2: the gap between the two shortest function names is 2; match (5) < search (6) by 1: match and search are separated by only 1 character; 'match' (5 chars) == len('Match') (5 chars): the function and its output class have the same name length (both 5 chars, one lowercase, one CamelCase); confirmed Python 3.14.3 macOS"]
    - [search_len_6,    re.search.__name__.__len__,    [],  6, "re.search.__name__.__len__() == 6 — 'search' has 6 characters; search (6) is the third in the ascending sequence: sub(3) < match(5) < search(6) < compile(7)=findall(7) < finditer(8) < fullmatch(9); search (6) - match (5) == 1: the smallest gap between adjacent elements in the function name length sequence; compile (7) - search (6) == 1: another unit gap; the three consecutive unit-gap steps are: match(5)->search(6)->compile/findall(7)->finditer(8): four consecutive 1-unit increments with a tie at 7; confirmed Python 3.14.3 macOS"]
    - [compile_len_7,   re.compile.__name__.__len__,   [],  7, "re.compile.__name__.__len__() == 7 — 'compile' has 7 characters; compile (7) ties with findall (7) — the only two-way tie in the seven function name lengths; the tie: 'compile' (7) and 'findall' (7) reach length 7 by different compositions: 'compile' is a single word while 'findall' = 'find'(4)+'all'(3)=7; compile (7) > search (6) by 1; compile (7) < finditer (8) by 1; the 7-character name length of compile also equals len('Pattern') (7) and len('Decimal') (7) — common standard library name length; confirmed Python 3.14.3 macOS"]
    - [fullmatch_len_9, re.fullmatch.__name__.__len__, [],  9, "re.fullmatch.__name__.__len__() == 9 — 'fullmatch' has 9 characters: 'full'(4)+'match'(5)=9; fullmatch (9) is the maximum function name length in this spec; the ascending sequence tops at: finditer(8) < fullmatch(9); fullmatch (9) > finditer (8) by 1; fullmatch (9) = match (5) + 4 == match + len('full'): fullmatch is exactly 4 characters longer than match, matching the length of the 'full' prefix; fullmatch (9 chars) == len('RegexFlag') (9 chars) — a coincidental tie between the longest function name and the RegexFlag class name; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra170.compile_name_is_compile:
  description: "re.compile.__name__ == 'compile' — the re module's function for creating compiled Pattern objects; 'compile' has 7 characters; compile (7) ties with findall (7) — the only two-way tie among the seven re public function names in this spec; compile (7) == len('Pattern') (7): the compiler function name length equals the output class name length; re.compile.__module__ == 're' (2 chars): all seven public re functions share this 2-character module name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.compile.__name__.__eq__
  args: ["compile"]
  expected: true

invariant re_extra170.search_name_is_search:
  description: "re.search.__name__ == 'search' — the function that scans a string for the first match anywhere; 'search' has 6 characters; search (6) is between match (5) and compile (7) in the ascending function name length sequence: sub(3) < match(5) < search(6) < compile(7)=findall(7) < finditer(8) < fullmatch(9); re.search.__module__ == 're' (2 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.search.__name__.__eq__
  args: ["search"]
  expected: true

invariant re_extra170.match_name_is_match:
  description: "re.match.__name__ == 'match' — the function that applies the pattern only at the beginning of the string; 'match' has 5 characters; match (5) < search (6) by 1 — they are consecutive in the function name length sequence; 'match' (5, lowercase) == len('Match') (5, CamelCase): the function and its output class have the same 5-character name length; re.match.__module__ == 're' (2 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.match.__name__.__eq__
  args: ["match"]
  expected: true

invariant re_extra170.fullmatch_name_is_fullmatch:
  description: "re.fullmatch.__name__ == 'fullmatch' — the function that matches the pattern against the entire string; 'fullmatch' has 9 characters: 'full'(4)+'match'(5)=9; fullmatch (9) is the longest re function name in this spec; fullmatch (9) > match (5) by 4 == len('full') — the 'full' prefix accounts for the entire difference; re.fullmatch.__module__ == 're' (2 chars); fullmatch (9 chars) == len('RegexFlag') (9 chars): a coincidental tie; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.fullmatch.__name__.__eq__
  args: ["fullmatch"]
  expected: true

invariant re_extra170.sub_name_is_sub:
  description: "re.sub.__name__ == 'sub' — the function for replacing pattern occurrences in a string; 'sub' has 3 characters — the shortest public re function name in this spec; sub (3) < match (5) by 2: there is a 2-character gap between the minimum (sub=3) and the next-shortest (match=5); re.sub.__module__ == 're' (2 chars): the module name 're' (2 chars) is only 1 character shorter than the function name 'sub' (3 chars) — the smallest module-to-function gap in this spec; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.sub.__name__.__eq__
  args: ["sub"]
  expected: true

invariant re_extra170.findall_name_is_findall:
  description: "re.findall.__name__ == 'findall' — the function that returns a list of all non-overlapping matches; 'findall' has 7 characters: 'find'(4)+'all'(3)=7; findall (7) ties with compile (7) in name length — the only tie among the seven re function names; the 'find' prefix (4 chars) is shared with finditer; findall returns a list (eager) while finditer returns an iterator (lazy); re.findall.__module__ == 're' (2 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.findall.__name__.__eq__
  args: ["findall"]
  expected: true

invariant re_extra170.finditer_name_is_finditer:
  description: "re.finditer.__name__ == 'finditer' — the function that returns an iterator of Match objects for all non-overlapping matches; 'finditer' has 8 characters: 'find'(4)+'iter'(4)=8; finditer (8) > findall (7) by 1: the 'iter' suffix (4 chars) is 1 longer than the 'all' suffix (3 chars); finditer (8 chars) == len('StringIO') (8 chars) == len('PurePath') (8 chars) — cross-module coincidental ties at 8; re.finditer.__module__ == 're' (2 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.finditer.__name__.__eq__
  args: ["finditer"]
  expected: true

invariant re_extra170.all_re_functions_module_is_re:
  description: "re.sub.__module__ == 're' — all seven public re functions (compile, search, match, fullmatch, sub, findall, finditer) have __module__ == 're' (2 chars); the uniform 2-character module attribution means all re public functions are co-located in the same module namespace; 're' (2 chars) is the minimum string length in the re function name family — shorter than every function name (minimum is sub=3 chars); the uniform __module__ == 're' means each function can be identified by its module + function name pair; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.sub.__module__.__eq__
  args: ["re"]
  expected: true
