spec: copy_extra4
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
  notes:
    - "This spec extends prior copy specs."
    - "Focus: __module__ and __name__ for copy functions; copy.copy and copy.deepcopy behavior."
    - "copy.copy([1, 2, 3]) returns a new list equal to [1, 2, 3]."
    - "copy.deepcopy([1, 2, 3]) returns a new list equal to [1, 2, 3]."
    - "copy.copy.__name__ == 'copy'."
    - "copy.deepcopy.__name__ == 'deepcopy'."
    - "copy.Error.__name__ == 'Error'."
    - "copy.copy({1: 2}) == {1: 2} — shallow copy of dict."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table copy_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [copy,     copy.__name__.__eq__,     ["copy"],     true]
    - [deepcopy, deepcopy.__name__.__eq__, ["deepcopy"], true]

table copy_extra4.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [copy,     copy.__module__.__eq__,     ["copy"], true]
    - [deepcopy, deepcopy.__module__.__eq__, ["copy"], true]

invariant copy_extra4.copy.list_value:
  description: "copy.copy([1, 2, 3]) == [1, 2, 3]"
  category: copy
  kind: python_call_eq
  function: copy
  args: [[1, 2, 3]]
  expected: [1, 2, 3]

invariant copy_extra4.copy.list_class:
  description: "copy.copy([1, 2, 3]).__class__.__name__ == 'list'"
  category: copy
  kind: python_call_eq
  function: copy
  args: [[1, 2, 3]]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["list"]
  expected: true

invariant copy_extra4.deepcopy.list_value:
  description: "copy.deepcopy([1, 2, 3]) == [1, 2, 3]"
  category: deepcopy
  kind: python_call_eq
  function: deepcopy
  args: [[1, 2, 3]]
  expected: [1, 2, 3]

invariant copy_extra4.deepcopy.dict_value:
  description: "copy.deepcopy({'a': 1}) == {'a': 1}"
  category: deepcopy
  kind: python_call_eq
  function: deepcopy
  args: [{a: 1}]
  expected: {a: 1}

invariant copy_extra4.copy.dict_value:
  description: "copy.copy({'a': 1}) == {'a': 1}"
  category: copy
  kind: python_call_eq
  function: copy
  args: [{a: 1}]
  expected: {a: 1}

invariant copy_extra4.copy.string_value:
  description: "copy.copy('hello') == 'hello'"
  category: copy
  kind: python_call_eq
  function: copy
  args: ["hello"]
  expected: "hello"

invariant copy_extra4.deepcopy.nested_list:
  description: "copy.deepcopy([[1, 2], [3, 4]]) == [[1, 2], [3, 4]]"
  category: deepcopy
  kind: python_call_eq
  function: deepcopy
  args: [[[1, 2], [3, 4]]]
  expected: [[1, 2], [3, 4]]

invariant copy_extra4.Error.class_name:
  description: "copy.Error.__name__ == 'Error'"
  category: exceptions
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant copy_extra4.Error.module:
  description: "copy.Error.__module__ == 'copy'"
  category: exceptions
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["copy"]
  expected: true
