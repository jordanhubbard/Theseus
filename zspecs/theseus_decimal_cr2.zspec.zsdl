spec: theseus_decimal_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_decimal_cr2)
blocks: decimal

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html"
  notes:
    - "Clean-room extended decimal arithmetic. Do NOT import decimal."
    - "getcontext(): return current context with prec, rounding attributes."
    - "localcontext(ctx): context manager that temporarily overrides context."
    - "Context(prec=28): create a context with specified precision."
    - "Decimal rounding modes: ROUND_HALF_UP, ROUND_HALF_EVEN, ROUND_DOWN."
    - "decimal2_getcontext_prec(): getcontext().prec >= 1."
    - "decimal2_round_half_up(): Decimal('2.5').quantize(Decimal('1'), ROUND_HALF_UP) == 3."
    - "decimal2_round_half_even(): Decimal('2.5').quantize(Decimal('1'), ROUND_HALF_EVEN) == 2."
    - "Export: getcontext, localcontext, Context, ROUND_HALF_UP, ROUND_HALF_EVEN, ROUND_DOWN."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_decimal_cr2.getcontext_prec:
  description: "getcontext().prec >= 1"
  category: context
  kind: python_call_eq
  function: decimal2_getcontext_prec
  args: []
  expected: true

invariant theseus_decimal_cr2.round_half_up:
  description: "Decimal('2.5').quantize(Decimal('1'), ROUND_HALF_UP) == 3"
  category: rounding
  kind: python_call_eq
  function: decimal2_round_half_up
  args: []
  expected: 3

invariant theseus_decimal_cr2.round_half_even:
  description: "Decimal('2.5').quantize(Decimal('1'), ROUND_HALF_EVEN) == 2"
  category: rounding
  kind: python_call_eq
  function: decimal2_round_half_even
  args: []
  expected: 2
