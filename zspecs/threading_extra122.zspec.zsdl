spec: threading_extra122
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra121.zspec.zsdl."
    - "This spec covers: threading.Semaphore class method __code__.co_varnames elements not previously covered — Semaphore.__init__ co_varnames[0]='self'(4), co_varnames[1]='value'(5); Semaphore.acquire co_varnames[1]='blocking'(8), co_varnames[2]='timeout'(7); Semaphore.release co_varnames[1]='n'(1); co_varnames tuple lengths; wave 272."
    - "Prior spec extra104 covered Semaphore method qualnames (acquire, release, __enter__ all len=17). New here: the co_varnames elements (parameter names) for the three Semaphore methods."
    - "threading.Semaphore.__init__.__code__.co_varnames[0] == 'self' (len 4). Verified with Python 3.14.3."
    - "threading.Semaphore.__init__.__code__.co_varnames[1] == 'value' (len 5). Verified with Python 3.14.3."
    - "threading.Semaphore.__init__.__code__.co_varnames.__len__() == 2. Verified with Python 3.14.3."
    - "threading.Semaphore.acquire.__code__.co_varnames[1] == 'blocking' (len 8). Verified with Python 3.14.3."
    - "threading.Semaphore.acquire.__code__.co_varnames[2] == 'timeout' (len 7). Verified with Python 3.14.3."
    - "threading.Semaphore.acquire.__code__.co_varnames.__len__() == 5. Verified with Python 3.14.3."
    - "threading.Semaphore.release.__code__.co_varnames[1] == 'n' (len 1). Verified with Python 3.14.3."
    - "threading.Semaphore.release.__code__.co_varnames.__len__() == 2. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Semaphore.__init__ co_varnames[0] and [1]
#
# Wave 272 theme: threading.Semaphore.__init__(self, value=1) is a pure-Python
# method. Its code object has co_varnames with exactly 2 entries: co_varnames[0]
# == 'self' (4 chars) — the bound instance parameter, always first in Python
# methods — and co_varnames[1] == 'value' (5 chars) — the initial counter value
# defaulting to 1. A Semaphore with value=1 is equivalent to a binary semaphore
# (mutex). The co_varnames tuple length is 2: exactly the declared parameter count
# with no additional internal locals.
#
# Semaphore.__init__.__code__.co_varnames[0] == 'self'   (len 4)
# Semaphore.__init__.__code__.co_varnames[1] == 'value'  (len 5)
# Semaphore.__init__.__code__.co_varnames.__len__() == 2
#
# New to extra122.
# ---------------------------------------------------------------------------

table threading_extra122.semaphore_init_co_varnames:
  description: "threading.Semaphore.__init__ co_varnames[0]='self'(4), [1]='value'(5); tuple len=2; no internal locals; prior extra104 covered qualname length; wave 272; new to extra122"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingsicv122

  columns: [id, function, args, expected, description]
  rows:
    - [init_cv0_eq,
       "Semaphore.__init__.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "threading.Semaphore.__init__.__code__.co_varnames[0] == 'self' — the instance parameter; always first in Python methods; Semaphore.__init__(self, value=1); tuple.__getitem__(0) returns 'self'; new to extra122"]
    - [init_cv0_len,
       "Semaphore.__init__.__code__.co_varnames.__getitem__(0).__len__",
       [],
       4,
       "threading.Semaphore.__init__.__code__.co_varnames[0].__len__() == 4 — 'self' has 4 chars: s-e-l-f; the universal Python method receiver name; str.__len__() returns 4; new to extra122"]
    - [init_cv1_eq,
       "Semaphore.__init__.__code__.co_varnames.__getitem__",
       [1],
       "value",
       "threading.Semaphore.__init__.__code__.co_varnames[1] == 'value' — the initial counter value; defaults to 1; a Semaphore(value=1) is a binary semaphore; tuple.__getitem__(1) returns 'value'; new to extra122"]
    - [init_cv1_len,
       "Semaphore.__init__.__code__.co_varnames.__getitem__(1).__len__",
       [],
       5,
       "threading.Semaphore.__init__.__code__.co_varnames[1].__len__() == 5 — 'value' has 5 chars: v-a-l-u-e; one more than 'self' (4 chars); str.__len__() returns 5; new to extra122"]
    - [init_cv_len,
       "Semaphore.__init__.__code__.co_varnames.__len__",
       [],
       2,
       "threading.Semaphore.__init__.__code__.co_varnames.__len__() == 2 — __init__ has exactly 2 local variable names: 'self' and 'value'; no internal locals beyond declared parameters; tuple.__len__() returns 2; new to extra122"]

# ---------------------------------------------------------------------------
# Table 2: threading.Semaphore.acquire co_varnames[1] and [2]
#
# Wave 272 theme: threading.Semaphore.acquire(self, blocking=True, timeout=None)
# has a total of 5 co_varnames entries: 'self'(0), 'blocking'(1), 'timeout'(2),
# 'rc'(3), 'endtime'(4). Prior spec extra104 covered the acquire qualname
# 'Semaphore.acquire' (len 17). New here: co_varnames[1] == 'blocking' (8 chars)
# — determines whether the call blocks or returns immediately. co_varnames[2] ==
# 'timeout' (7 chars) — the maximum time to wait in seconds (None = indefinite).
# The co_varnames tuple has 5 entries (2 declared params + 3 internal locals).
#
# acquire.__code__.co_varnames[1] == 'blocking'  (len 8)
# acquire.__code__.co_varnames[2] == 'timeout'   (len 7)
# acquire.__code__.co_varnames.__len__() == 5
#
# New to extra122.
# ---------------------------------------------------------------------------

table threading_extra122.semaphore_acquire_co_varnames:
  description: "threading.Semaphore.acquire co_varnames[1]='blocking'(8), [2]='timeout'(7); tuple len=5 (2 params + 3 locals); prior extra104 covered qualname; wave 272; new to extra122"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingsacv122

  columns: [id, function, args, expected, description]
  rows:
    - [acquire_cv1_eq,
       "Semaphore.acquire.__code__.co_varnames.__getitem__",
       [1],
       "blocking",
       "threading.Semaphore.acquire.__code__.co_varnames[1] == 'blocking' — the blocking parameter; if True the call blocks until the semaphore is available; acquire(self, blocking=True, timeout=None); tuple.__getitem__(1) returns 'blocking'; new to extra122"]
    - [acquire_cv1_len,
       "Semaphore.acquire.__code__.co_varnames.__getitem__(1).__len__",
       [],
       8,
       "threading.Semaphore.acquire.__code__.co_varnames[1].__len__() == 8 — 'blocking' has 8 chars: b-l-o-c-k-i-n-g; one more than 'timeout' (7 chars); str.__len__() returns 8; new to extra122"]
    - [acquire_cv2_eq,
       "Semaphore.acquire.__code__.co_varnames.__getitem__",
       [2],
       "timeout",
       "threading.Semaphore.acquire.__code__.co_varnames[2] == 'timeout' — the timeout parameter in seconds; None means wait indefinitely; acquire(self, blocking=True, timeout=None); tuple.__getitem__(2) returns 'timeout'; new to extra122"]
    - [acquire_cv2_len,
       "Semaphore.acquire.__code__.co_varnames.__getitem__(2).__len__",
       [],
       7,
       "threading.Semaphore.acquire.__code__.co_varnames[2].__len__() == 7 — 'timeout' has 7 chars: t-i-m-e-o-u-t; one less than 'blocking' (8 chars); str.__len__() returns 7; new to extra122"]
    - [acquire_cv_len,
       "Semaphore.acquire.__code__.co_varnames.__len__",
       [],
       5,
       "threading.Semaphore.acquire.__code__.co_varnames.__len__() == 5 — acquire has 5 local variable names: 3 declared parameters (self, blocking, timeout) + 2 internal locals (rc, endtime); tuple.__len__() returns 5; new to extra122"]

# ---------------------------------------------------------------------------
# Table 3: threading.Semaphore.release co_varnames[1] and co_varnames tuple length
#
# Wave 272 theme: threading.Semaphore.release(self, n=1) has exactly 2 co_varnames
# entries: 'self' and 'n'. co_varnames[1] == 'n' (1 char) — the number of
# releases to perform (added in Python 3.9 to allow releasing multiple times in
# one call). 'n' is the shortest parameter name in the Semaphore method set.
# Its single-character name follows the mathematical convention where n denotes
# a count. Comparing lengths: release co_varnames len=2 (same as __init__), while
# acquire co_varnames len=5 (more complex, has internal timing locals).
#
# release.__code__.co_varnames[1] == 'n'   (len 1)
# release.__code__.co_varnames.__len__() == 2
#
# New to extra122.
# ---------------------------------------------------------------------------

table threading_extra122.semaphore_release_co_varnames:
  description: "threading.Semaphore.release co_varnames[1]='n'(1); tuple len=2; 'n' is shortest param name in Semaphore methods; release and __init__ share len=2 while acquire has len=5; wave 272; new to extra122"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingsrcv122

  columns: [id, function, args, expected, description]
  rows:
    - [release_cv1_eq,
       "Semaphore.release.__code__.co_varnames.__getitem__",
       [1],
       "n",
       "threading.Semaphore.release.__code__.co_varnames[1] == 'n' — the count of releases to perform; added in Python 3.9; release(self, n=1) increments the counter by n; tuple.__getitem__(1) returns 'n'; new to extra122"]
    - [release_cv1_len,
       "Semaphore.release.__code__.co_varnames.__getitem__(1).__len__",
       [],
       1,
       "threading.Semaphore.release.__code__.co_varnames[1].__len__() == 1 — 'n' has 1 char; the shortest parameter name in the Semaphore method set; mathematical convention for count; str.__len__() returns 1; new to extra122"]
    - [release_cv_len,
       "Semaphore.release.__code__.co_varnames.__len__",
       [],
       2,
       "threading.Semaphore.release.__code__.co_varnames.__len__() == 2 — release has 2 local variable names: 'self' and 'n'; no internal locals; same count as __init__; tuple.__len__() returns 2; new to extra122"]
    - [release_cv0_eq,
       "Semaphore.release.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "threading.Semaphore.release.__code__.co_varnames[0] == 'self' — the instance parameter; always first in Python methods; consistent with __init__ co_varnames[0] and acquire co_varnames[0]; tuple.__getitem__(0) returns 'self'; new to extra122"]
    - [release_vs_acquire_cv_len,
       "Semaphore.acquire.__code__.co_varnames.__len__",
       [],
       5,
       "threading.Semaphore.acquire.__code__.co_varnames.__len__() == 5 — confirming acquire (5 locals) has more entries than release (2) and __init__ (2); acquire has internal timing variables rc and endtime; tuple.__len__() returns 5; new to extra122"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra122
# ---------------------------------------------------------------------------

invariant threading_extra122.semaphore_init_cv1_value:
  description: "threading.Semaphore.__init__.__code__.co_varnames[1] == 'value' — initial counter param; defaults to 1; binary semaphore when value=1; wave 272; new to extra122"
  kind: python_call_eq
  function: "Semaphore.__init__.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "value"

invariant threading_extra122.semaphore_acquire_cv1_blocking:
  description: "threading.Semaphore.acquire.__code__.co_varnames[1] == 'blocking' — second param; controls blocking behavior; 8 chars; wave 272; new to extra122"
  kind: python_call_eq
  function: "Semaphore.acquire.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "blocking"

invariant threading_extra122.semaphore_acquire_cv2_timeout:
  description: "threading.Semaphore.acquire.__code__.co_varnames[2] == 'timeout' — third param; maximum wait time in seconds; 7 chars; wave 272; new to extra122"
  kind: python_call_eq
  function: "Semaphore.acquire.__code__.co_varnames.__getitem__"
  args: [2]
  expected: "timeout"

invariant threading_extra122.semaphore_release_cv1_n:
  description: "threading.Semaphore.release.__code__.co_varnames[1] == 'n' — release count param; 1 char; shortest param name in Semaphore methods; added Python 3.9; wave 272; new to extra122"
  kind: python_call_eq
  function: "Semaphore.release.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "n"

invariant threading_extra122.semaphore_acquire_cv_len:
  description: "threading.Semaphore.acquire.__code__.co_varnames.__len__() == 5 — 3 params + 2 internal locals (rc, endtime); more than __init__ and release (both 2); wave 272; new to extra122"
  kind: python_call_eq
  function: Semaphore.acquire.__code__.co_varnames.__len__
  args: []
  expected: 5
