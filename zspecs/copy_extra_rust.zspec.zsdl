spec: copy_extra_rust
version: ">=3.9"
backend: rust_module(copy_extra_rust)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — copy stdlib"
  notes:
    - "copy provides shallow and deep copy operations."
    - "copy.copy([1, 2, 3]) == [1, 2, 3]."
    - "copy.deepcopy({'a': [1]}) == {'a': [1]}."
    - "copy.copy is callable."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant copy_extra_rust.copy_list:
  description: "copy.copy([1, 2, 3]) == [1, 2, 3]"
  category: copy
  kind: python_call_eq
  function: copy_extra_copy_list
  args: []
  expected: [1, 2, 3]

invariant copy_extra_rust.deepcopy_dict:
  description: "copy.deepcopy({'a': 1}) == {'a': 1}"
  category: deepcopy
  kind: python_call_eq
  function: copy_extra_deepcopy_dict
  args: []
  expected: true

invariant copy_extra_rust.has_deepcopy:
  description: "copy.deepcopy is callable"
  category: presence
  kind: python_call_eq
  function: copy_extra_has_deepcopy
  args: []
  expected: true

