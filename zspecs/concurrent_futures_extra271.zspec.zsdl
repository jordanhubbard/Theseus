spec: concurrent_futures_extra271
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "concurrent.futures.wait.__module__ == 'concurrent.futures._base' — the function is defined in the private _base submodule."
    - "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base' — same submodule."
    - "FIRST_COMPLETED == 'FIRST_COMPLETED'; ALL_COMPLETED == 'ALL_COMPLETED' — string sentinels verified."
    - "concurrent.futures.Executor.__module__ == 'concurrent.futures._base'; inherits from object."
    - "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' — it is a RuntimeError subclass."
    - "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'."
    - "Executor.map.__qualname__ == 'Executor.map'; Executor.submit.__qualname__ == 'Executor.submit'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# wait and as_completed function identity — table
#
# Both top-level functions live in concurrent.futures._base.
# ---------------------------------------------------------------------------

table concurrent_futures_extra271.function_identity:
  description: "concurrent.futures.wait and as_completed __module__ and __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: fnid

  columns: [id, function, args, expected, description]
  rows:
    - [wait_name,         wait.__name__.__eq__,              ["wait"],                         true, "concurrent.futures.wait.__name__ == 'wait'"]
    - [wait_module,       wait.__module__.__eq__,            ["concurrent.futures._base"],     true, "concurrent.futures.wait.__module__ == 'concurrent.futures._base'"]
    - [wait_qualname,     wait.__qualname__.__eq__,          ["wait"],                         true, "concurrent.futures.wait.__qualname__ == 'wait'"]
    - [asc_name,          as_completed.__name__.__eq__,      ["as_completed"],                 true, "concurrent.futures.as_completed.__name__ == 'as_completed'"]
    - [asc_module,        as_completed.__module__.__eq__,    ["concurrent.futures._base"],     true, "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base'"]
    - [asc_qualname,      as_completed.__qualname__.__eq__,  ["as_completed"],                 true, "concurrent.futures.as_completed.__qualname__ == 'as_completed'"]

# ---------------------------------------------------------------------------
# FIRST_COMPLETED / ALL_COMPLETED constant values — table
#
# These string sentinel constants are passed as return_when to wait().
# ---------------------------------------------------------------------------

table concurrent_futures_extra271.constant_values:
  description: "concurrent.futures string sentinel constants FIRST_COMPLETED and ALL_COMPLETED"
  kind: python_call_eq
  category: constants
  id_prefix: cval

  columns: [id, function, args, expected, description]
  rows:
    - [fc_value,  FIRST_COMPLETED.__eq__,   ["FIRST_COMPLETED"],   true, "FIRST_COMPLETED == 'FIRST_COMPLETED'"]
    - [fe_value,  FIRST_EXCEPTION.__eq__,   ["FIRST_EXCEPTION"],   true, "FIRST_EXCEPTION == 'FIRST_EXCEPTION'"]
    - [ac_value,  ALL_COMPLETED.__eq__,     ["ALL_COMPLETED"],     true, "ALL_COMPLETED == 'ALL_COMPLETED'"]

# ---------------------------------------------------------------------------
# Executor base class identity — standalone invariants
#
# Executor lives in concurrent.futures._base and inherits from object.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra271.Executor.name:
  description: "concurrent.futures.Executor.__name__ == 'Executor'"
  category: identity
  kind: python_call_eq
  function: Executor.__name__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra271.Executor.module:
  description: "concurrent.futures.Executor.__module__ == 'concurrent.futures._base'"
  category: identity
  kind: python_call_eq
  function: Executor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra271.Executor.bases0_name:
  description: "concurrent.futures.Executor.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: "Executor.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant concurrent_futures_extra271.Executor.map_qualname:
  description: "concurrent.futures.Executor.map.__qualname__ == 'Executor.map'"
  category: identity
  kind: python_call_eq
  function: Executor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true

invariant concurrent_futures_extra271.Executor.submit_name:
  description: "concurrent.futures.Executor.submit.__name__ == 'submit'"
  category: identity
  kind: python_call_eq
  function: Executor.submit.__name__.__eq__
  args: ["submit"]
  expected: true

invariant concurrent_futures_extra271.Executor.shutdown_name:
  description: "concurrent.futures.Executor.shutdown.__name__ == 'shutdown'"
  category: identity
  kind: python_call_eq
  function: Executor.shutdown.__name__.__eq__
  args: ["shutdown"]
  expected: true

# ---------------------------------------------------------------------------
# BrokenExecutor exception identity — standalone invariants
#
# BrokenExecutor is an exception class that inherits from RuntimeError.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra271.BrokenExecutor.name:
  description: "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor'"
  category: identity
  kind: python_call_eq
  function: BrokenExecutor.__name__.__eq__
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra271.BrokenExecutor.module:
  description: "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'"
  category: identity
  kind: python_call_eq
  function: BrokenExecutor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra271.BrokenExecutor.bases0_name:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'"
  category: identity
  kind: python_call_eq
  function: "BrokenExecutor.__bases__[0].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true
