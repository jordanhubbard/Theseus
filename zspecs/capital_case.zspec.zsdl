spec: capital_case
version: ">=3.0.0"
backend: node(capital-case)

docs: https://www.npmjs.com/package/capital-case

provenance:
  derived_from:
    - "capital-case README — https://www.npmjs.com/package/capital-case"
    - "Test vectors verified with capital-case@3.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "capital-case source"
  notes:
    - "capital-case exports {capitalCase} named function."
    - "capitalCase converts string to Capital Case (space-separated, each word capitalized)."
    - "Splits camelCase, PascalCase, snake_case, and kebab-case inputs."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns Capital Cased string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table capital_case.capital_case:
  kind: node_module_call_eq
  function: capitalCase
  category: capitalCase
  id_prefix: capcase

  columns: [id, args, expected]
  rows:
    - [camel,  ["fooBar"],      "Foo Bar"]
    - [snake,  ["foo_bar_baz"], "Foo Bar Baz"]
    - [dash,   ["foo-bar"],     "Foo Bar"]
    - [space,  ["hello world"], "Hello World"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:08:07Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
