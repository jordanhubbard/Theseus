spec: re3451
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 677 (re3451): __getitem__, __setitem__, __delitem__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __getitem__/__setitem__/__delitem__ dict-presence (subscript access)."
    - "re.Match defines __getitem__ (true): match[group] subscript syntax is supported — match[0] returns the full match, match[1] returns group 1, etc."
    - "re.Match does NOT define __setitem__ or __delitem__ (false): match objects are read-only."
    - "re.Pattern and re.RegexFlag do not define any of the three in their own __dict__ (false)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __getitem__ dict-presence — operator.contains(Cls.__dict__, '__getitem__')
#
# re.Match DOES define __getitem__ in its own __dict__: true.
# match[group] subscript syntax is supported: match[0] returns the full
# match string, match[1] returns group 1, match['name'] returns a named group.
# re.Pattern and re.RegexFlag do not define __getitem__: false.
# ---------------------------------------------------------------------------

table re3451.getitem:
  description: "re types __getitem__ dict-presence checks; wave 677"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3451

  columns: [id, function, args, expected]
  rows:
    - ["re3451001", operator.contains, [re.Pattern.__dict__,   "__getitem__"], false]
    - ["re3451002", operator.contains, [re.Match.__dict__,     "__getitem__"], true]
    - ["re3451003", operator.contains, [re.RegexFlag.__dict__, "__getitem__"], false]

# ---------------------------------------------------------------------------
# __setitem__ dict-presence — operator.contains(Cls.__dict__, '__setitem__')
#
# No re class defines __setitem__ in its own __dict__; all false.
# re.Match objects are read-only: group values cannot be assigned via
# subscript. re.Pattern and re.RegexFlag similarly do not define __setitem__.
# ---------------------------------------------------------------------------

table re3451.setitem:
  description: "re types __setitem__ dict-presence checks; wave 677"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3451

  columns: [id, function, args, expected]
  rows:
    - ["re3451004", operator.contains, [re.Pattern.__dict__,   "__setitem__"], false]
    - ["re3451005", operator.contains, [re.Match.__dict__,     "__setitem__"], false]
    - ["re3451006", operator.contains, [re.RegexFlag.__dict__, "__setitem__"], false]

# ---------------------------------------------------------------------------
# __delitem__ dict-presence — operator.contains(Cls.__dict__, '__delitem__')
#
# No re class defines __delitem__ in its own __dict__; all false.
# re.Match objects are read-only: groups cannot be deleted via subscript.
# re.Pattern and re.RegexFlag similarly do not define __delitem__.
# ---------------------------------------------------------------------------

table re3451.delitem:
  description: "re types __delitem__ dict-presence checks; wave 677"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3451

  columns: [id, function, args, expected]
  rows:
    - ["re3451007", operator.contains, [re.Pattern.__dict__,   "__delitem__"], false]
    - ["re3451008", operator.contains, [re.Match.__dict__,     "__delitem__"], false]
    - ["re3451009", operator.contains, [re.RegexFlag.__dict__, "__delitem__"], false]

# ---------------------------------------------------------------------------
# combined — __getitem__, __setitem__, __delitem__ across all 3 re subjects
#
# 3 classes x 3 methods = 9 rows.
# Key finding: re.Match.__getitem__ = true (match[group] subscript access
# is supported), while re.Match.__setitem__ and re.Match.__delitem__ are
# false (match objects are read-only). re.Pattern and re.RegexFlag are
# false for all three methods in their own __dict__.
# ---------------------------------------------------------------------------

table re3451.combined:
