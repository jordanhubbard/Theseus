spec: cmath_extra12
version: ">=3.9"
backend: python_module(cmath)

docs: https://docs.python.org/3/library/cmath.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cmath.html — Python cmath module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/cmathmodule.c"
  notes:
    - "This spec extends cmath_extra11.zspec.zsdl."
    - "cmath_extra11 covers __qualname__.__len__() for sin/cos/exp/log/sqrt/rect/phase/polar."
    - "No prior cmath spec checks __class__.__name__.__len__() for any module constant."
    - "No prior cmath spec checks __qualname__.__len__() for tan/asin/acos/atan/sinh/cosh/tanh/log10/isfinite/isinf/isnan/isclose."
    - "cmath has no __all__ attribute — confirmed by inspection."
    - "cmath.__name__ == 'cmath' (5 chars)."
    - "All real-valued constants (pi, tau, e, inf, nan) are float — class name 'float' (5 chars)."
    - "All complex-valued constants (infj, nanj) are complex — class name 'complex' (7 chars)."
    - "Qualname lengths: tan=3, asin=4, acos=4, atan=4, sinh=4, cosh=4, tanh=4, log10=5, isinf=5, isnan=5, isfinite=8, isclose=7."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# cmath module name and constant type names
#
# cmath.__name__ == 'cmath' (5 chars). All real-valued constants (pi, tau, e,
# inf, nan) are Python float objects; their class name is 'float' (5 chars).
# The complex-valued constants infj and nanj are complex objects; class name
# 'complex' (7 chars). No prior cmath spec checks any of these values.
# ---------------------------------------------------------------------------

invariant cmath_extra12.module.name_len:
  description: "len(cmath.__name__) == 5 — 'cmath' is 5 chars"
  category: module_identity
  kind: python_call_eq
  function: cmath.__name__.__len__
  args: []
  expected: 5

table cmath_extra12.constant_class_name_lens:
  description: "__class__.__name__.__len__() for all cmath module constants"
  kind: python_call_eq
  category: constant_identity
  id_prefix: const_cls_len

  columns: [id, function, args, expected, description]
  rows:
    - [pi,
       pi.__class__.__name__.__len__,
       [],
       5,
       "cmath.pi is a float — class name 'float' (5 chars)"]
    - [tau,
       tau.__class__.__name__.__len__,
       [],
       5,
       "cmath.tau is a float — class name 'float' (5 chars)"]
    - [e,
       e.__class__.__name__.__len__,
       [],
       5,
       "cmath.e is a float — class name 'float' (5 chars)"]
    - [inf,
       inf.__class__.__name__.__len__,
       [],
       5,
       "cmath.inf is a float — class name 'float' (5 chars)"]
    - [nan,
       nan.__class__.__name__.__len__,
       [],
       5,
       "cmath.nan is a float — class name 'float' (5 chars)"]
    - [infj,
       infj.__class__.__name__.__len__,
       [],
       7,
       "cmath.infj is a complex — class name 'complex' (7 chars)"]
    - [nanj,
       nanj.__class__.__name__.__len__,
       [],
       7,
       "cmath.nanj is a complex — class name 'complex' (7 chars)"]

# ---------------------------------------------------------------------------
# cmath function __qualname__.__len__() — trigonometric and inverse trig
#
# cmath_extra11 recorded qualname lengths for sin/cos/exp/log/sqrt/rect/phase/
# polar. This table records the remaining trig functions: tan (3), and the
# inverse/hyperbolic variants: asin/acos/atan/sinh/cosh/tanh (all 4 chars).
# ---------------------------------------------------------------------------

table cmath_extra12.trig_qualname_lens:
  description: "__qualname__.__len__() for cmath trig/inverse-trig/hyperbolic functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: cqlen12_trig

  columns: [id, function, args, expected, description]
  rows:
    - [tan,
       tan.__qualname__.__len__,
       [],
       3,
       "cmath.tan.__qualname__ == 'tan' (3 chars)"]
    - [asin,
       asin.__qualname__.__len__,
       [],
       4,
       "cmath.asin.__qualname__ == 'asin' (4 chars)"]
    - [acos,
       acos.__qualname__.__len__,
       [],
       4,
       "cmath.acos.__qualname__ == 'acos' (4 chars)"]
    - [atan,
       atan.__qualname__.__len__,
       [],
       4,
       "cmath.atan.__qualname__ == 'atan' (4 chars)"]
    - [sinh,
       sinh.__qualname__.__len__,
       [],
       4,
       "cmath.sinh.__qualname__ == 'sinh' (4 chars)"]
    - [cosh,
       cosh.__qualname__.__len__,
       [],
       4,
       "cmath.cosh.__qualname__ == 'cosh' (4 chars)"]
    - [tanh,
       tanh.__qualname__.__len__,
       [],
       4,
       "cmath.tanh.__qualname__ == 'tanh' (4 chars)"]

# ---------------------------------------------------------------------------
# cmath function __qualname__.__len__() — logarithm and classification functions
#
# log10 has qualname 'log10' (5 chars). The classification functions isfinite
# (8), isinf (5), isnan (5), isclose (7) — sorted by length. No prior cmath
# spec records qualname lengths for any of these functions.
# ---------------------------------------------------------------------------

table cmath_extra12.classification_qualname_lens:
  description: "__qualname__.__len__() for cmath log10 and classification functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: cqlen12_cls

  columns: [id, function, args, expected, description]
  rows:
    - [log10,
       log10.__qualname__.__len__,
       [],
       5,
       "cmath.log10.__qualname__ == 'log10' (5 chars)"]
    - [isinf,
       isinf.__qualname__.__len__,
       [],
       5,
       "cmath.isinf.__qualname__ == 'isinf' (5 chars)"]
    - [isnan,
       isnan.__qualname__.__len__,
       [],
       5,
       "cmath.isnan.__qualname__ == 'isnan' (5 chars)"]
    - [isclose,
       isclose.__qualname__.__len__,
       [],
       7,
       "cmath.isclose.__qualname__ == 'isclose' (7 chars)"]
    - [isfinite,
       isfinite.__qualname__.__len__,
       [],
       8,
       "cmath.isfinite.__qualname__ == 'isfinite' (8 chars)"]
