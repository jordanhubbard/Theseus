spec: uuid_extra2251
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "any prior uuid zspec files"
  notes:
    - "Wave 597 (_extra2251): callable protocol and function-attribute dict-presence checks for uuid types and functions."
    - "uuid.UUID is a pure-Python class; __call__ is absent from its __dict__ (the metaclass type provides __call__ for construction)."
    - "uuid.UUID has __init__ in its __dict__ (True) but __new__ is absent (False) — construction delegates to object.__new__."
    - "uuid.UUID defines comparison and hashing dunder methods directly: __hash__, __eq__, __lt__, __str__, __repr__, __int__, __setattr__."
    - "uuid.SafeUUID is an IntEnum subclass; __call__ is absent from its __dict__ — enum construction goes through EnumType.__call__."
    - "uuid.uuid1, uuid.uuid3, uuid.uuid4, uuid.uuid5 are Python functions; they have __code__ (class name 'code') and __globals__ (class name 'dict')."
    - "uuid.uuid1 has defaults=(None, None); uuid.uuid4 has no defaults (None)."
    - "Function-object attributes (__code__, __globals__, __defaults__, etc.) are absent from the uuid.UUID and uuid.SafeUUID class __dict__s."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra2251.uuid_class_call_protocol:
  description: "uuid.UUID class callable protocol and function-attribute dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2251
  columns: [id, function, args, expected]
  rows:
    - ["uu2251001", "uuid.UUID.__dict__.__contains__", ["__call__"],        false]
    - ["uu2251002", "uuid.UUID.__dict__.__contains__", ["__new__"],         false]
    - ["uu2251003", "uuid.UUID.__dict__.__contains__", ["__code__"],        false]
    - ["uu2251004", "uuid.UUID.__dict__.__contains__", ["__globals__"],     false]
    - ["uu2251005", "uuid.UUID.__dict__.__contains__", ["__defaults__"],    false]
    - ["uu2251006", "uuid.UUID.__dict__.__contains__", ["__kwdefaults__"],  false]
    - ["uu2251007", "uuid.UUID.__dict__.__contains__", ["__annotations__"], false]
    - ["uu2251008", "uuid.UUID.__dict__.__contains__", ["__builtins__"],    false]

table uuid_extra2251.uuid_class_positive_anchors:
  description: "uuid.UUID dict members that ARE present: dunder methods, slots, property descriptors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2251
  columns: [id, function, args, expected]
  rows:
    - ["uu2251009",  "uuid.UUID.__dict__.__contains__", ["__init__"],      true]
    - ["uu2251010",  "uuid.UUID.__dict__.__contains__", ["__slots__"],     true]
    - ["uu2251011",  "uuid.UUID.__dict__.__contains__", ["__hash__"],      true]
    - ["uu2251012",  "uuid.UUID.__dict__.__contains__", ["__eq__"],        true]
    - ["uu2251013",  "uuid.UUID.__dict__.__contains__", ["__str__"],       true]
    - ["uu2251014",  "uuid.UUID.__dict__.__contains__", ["__repr__"],      true]
    - ["uu2251015",  "uuid.UUID.__dict__.__contains__", ["__int__"],       true]
    - ["uu2251016",  "uuid.UUID.__dict__.__contains__", ["__lt__"],        true]
    - ["uu2251017",  "uuid.UUID.__dict__.__contains__", ["__setattr__"],   true]
    - ["uu2251018",  "uuid.UUID.__dict__.__contains__", ["__doc__"],       true]
    - ["uu2251019",  "uuid.UUID.__dict__.__contains__", ["hex"],           true]
    - ["uu2251020",  "uuid.UUID.__dict__.__contains__", ["urn"],           true]
    - ["uu2251021",  "uuid.UUID.__dict__.__contains__", ["variant"],       true]
    - ["uu2251022",  "uuid.UUID.__dict__.__contains__", ["version"],       true]
    - ["uu2251023",  "uuid.UUID.__dict__.__contains__", ["is_safe"],       true]
    - ["uu2251024",  "uuid.UUID.__dict__.__contains__", ["bytes"],         true]
    - ["uu2251025",  "uuid.UUID.__dict__.__contains__", ["bytes_le"],      true]
    - ["uu2251026",  "uuid.UUID.__dict__.__contains__", ["int"],           true]

table uuid_extra2251.safeuuid_call_protocol:
  description: "uuid.SafeUUID (IntEnum) callable protocol and function-attribute dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2251
  columns: [id, function, args, expected]
  rows:
    - ["uu2251027", "uuid.SafeUUID.__dict__.__contains__", ["__call__"],        false]
    - ["uu2251028", "uuid.SafeUUID.__dict__.__contains__", ["__code__"],        false]
    - ["uu2251029", "uuid.SafeUUID.__dict__.__contains__", ["__globals__"],     false]
    - ["uu2251030", "uuid.SafeUUID.__dict__.__contains__", ["__defaults__"],    false]
    - ["uu2251031", "uuid.SafeUUID.__dict__.__contains__", ["__kwdefaults__"],  false]
    - ["uu2251032", "uuid.SafeUUID.__dict__.__contains__", ["__annotations__"], false]
    - ["uu2251033", "uuid.SafeUUID.__dict__.__contains__", ["__builtins__"],    false]
    - ["uu2251034", "uuid.SafeUUID.__dict__.__contains__", ["__new__"],         true]
    - ["uu2251035", "uuid.SafeUUID.__dict__.__contains__", ["safe"],            true]
    - ["uu2251036", "uuid.SafeUUID.__dict__.__contains__", ["unsafe"],          true]
    - ["uu2251037", "uuid.SafeUUID.__dict__.__contains__", ["unknown"],         true]

table uuid_extra2251.module_func_code_globals:
  description: "uuid module-level Python functions: __code__ and __globals__ class names (always 'code' and 'dict')"
  kind: python_call_eq
  category: code_globals
  id_prefix: uu2251
  columns: [id, function, args, expected]
  rows:
    - ["uu2251038", "uuid.uuid4.__code__.__class__.__name__.__eq__",    ["code"], true]
    - ["uu2251039", "uuid.uuid4.__globals__.__class__.__name__.__eq__", ["dict"], true]
    - ["uu2251040", "uuid.uuid1.__code__.__class__.__name__.__eq__",    ["code"], true]
    - ["uu2251041", "uuid.uuid1.__globals__.__class__.__name__.__eq__", ["dict"], true]
    - ["uu2251042", "uuid.uuid3.__code__.__class__.__name__.__eq__",    ["code"], true]
    - ["uu2251043", "uuid.uuid3.__globals__.__class__.__name__.__eq__", ["dict"], true]
    - ["uu2251044", "uuid.uuid5.__code__.__class__.__name__.__eq__",    ["code"], true]
    - ["uu2251045", "uuid.uuid5.__globals__.__class__.__name__.__eq__", ["dict"], true]

table uuid_extra2251.module_func_defaults:
  description: "uuid module-level function __defaults__ and __annotations__ class names"
  kind: python_call_eq
  category: func_attributes
  id_prefix: uu2251
  columns: [id, function, args, expected]
  rows:
    - ["uu2251046", "uuid.uuid1.__defaults__.__class__.__name__.__eq__",    ["tuple"], true]
    - ["uu2251047", "uuid.uuid4.__annotations__.__class__.__name__.__eq__", ["dict"],  true]
    - ["uu2251048", "uuid.uuid1.__annotations__.__class__.__name__.__eq__", ["dict"],  true]
    - ["uu2251049", "uuid.uuid3.__annotations__.__class__.__name__.__eq__", ["dict"],  true]
    - ["uu2251050", "uuid.uuid5.__annotations__.__class__.__name__.__eq__", ["dict"],  true]
