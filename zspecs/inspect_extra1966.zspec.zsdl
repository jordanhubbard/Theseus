spec: inspect_extra1966
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 578 (_extra1966): __enter__/__exit__, __aenter__/__aexit__, __del__ dict-presence checks."
    - "inspect.Parameter, inspect.Signature, inspect.BoundArguments do NOT define context manager protocol."
    - "None of the inspect classes define __aenter__ or __aexit__ — inspect has no async context manager types."
    - "None of the inspect classes define __del__ — no finalizer protocol in inspect."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

table inspect_extra1966.context_manager_enter:
  description: "inspect types __enter__ dict-presence checks — none define context manager protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1966
  columns: [id, function, args, expected]
  rows:
    - ["in1966001", "inspect.Parameter.__dict__.__contains__",      ["__enter__"], false]
    - ["in1966002", "inspect.Signature.__dict__.__contains__",      ["__enter__"], false]
    - ["in1966003", "inspect.BoundArguments.__dict__.__contains__", ["__enter__"], false]

