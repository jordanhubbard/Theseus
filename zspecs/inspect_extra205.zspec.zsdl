spec: inspect_extra205
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect.zspec.zsdl — covers isfunction, isbuiltin, isclass, ismodule, isroutine, isgeneratorfunction, iscoroutinefunction, isasyncgenfunction, signature, getmembers, getdoc __name__ checks"
    - "inspect_extra.zspec.zsdl — covers ismethod/isgenerator/iscoroutine/getsourcefile __name__ checks, function module checks, Parameter/__name__, Signature/__name__"
    - "inspect_signature.zspec.zsdl — covers BoundArguments/__name__/__module__, Signature/__module__, Parameter/__module__, kind names, Parameter.empty, Signature.empty"
  notes:
    - "This spec covers MRO (method resolution order) of inspect classes: Parameter, Signature, BoundArguments."
    - "inspect.Parameter.__mro__ is a 2-tuple: (Parameter, object). Parameter is a pure-Python class defined in Lib/inspect.py; it inherits directly from object."
    - "inspect.Signature.__mro__ is a 2-tuple: (Signature, object). Signature is a pure-Python class defined in Lib/inspect.py."
    - "inspect.BoundArguments.__mro__ is a 2-tuple: (BoundArguments, object). BoundArguments is a pure-Python class defined in Lib/inspect.py."
    - "All three inspect introspection classes have MRO length 2, consistent with direct inheritance from object."
    - "inspect.Parameter.__mro__[0].__name__ == 'Parameter' — the class is always the first MRO entry."
    - "inspect.Parameter.__mro__[1].__name__ == 'object' — object is always the terminal MRO entry."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.Parameter MRO — type, length, and indexed name checks
#
# inspect.Parameter.__mro__ == (<class 'inspect.Parameter'>, <class 'object'>)
# len == 2, [0].__name__ == 'Parameter', [1].__name__ == 'object'
# ---------------------------------------------------------------------------

table inspect_extra205.parameter_mro:
  description: "inspect.Parameter.__mro__ shape and indexed name checks — pure-Python class, 2-entry MRO"
  kind: python_call_eq
  category: mro
  id_prefix: inspectmro205

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_mro_is_tuple,  Parameter.__mro__.__class__.__name__.__eq__,  ["tuple"],     true,  "Parameter.__mro__.__class__.__name__ == 'tuple'"]
    - [parameter_mro_len,       Parameter.__mro__.__len__,                    [],            2,     "len(Parameter.__mro__) == 2"]
    - [parameter_mro0_name,     "Parameter.__mro__[0].__name__.__eq__",       ["Parameter"], true,  "Parameter.__mro__[0].__name__ == 'Parameter'"]
    - [parameter_mro1_name,     "Parameter.__mro__[1].__name__.__eq__",       ["object"],    true,  "Parameter.__mro__[1].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# inspect.Signature MRO — type, length, and indexed name checks
#
# inspect.Signature.__mro__ == (<class 'inspect.Signature'>, <class 'object'>)
# len == 2, [0].__name__ == 'Signature', [1].__name__ == 'object'
# ---------------------------------------------------------------------------

table inspect_extra205.signature_mro:
  description: "inspect.Signature.__mro__ shape and indexed name checks — pure-Python class, 2-entry MRO"
  kind: python_call_eq
  category: mro
  id_prefix: inspectmro205

  columns: [id, function, args, expected, description]
  rows:
    - [signature_mro_is_tuple,  Signature.__mro__.__class__.__name__.__eq__,  ["tuple"],     true,  "Signature.__mro__.__class__.__name__ == 'tuple'"]
    - [signature_mro_len,       Signature.__mro__.__len__,                    [],            2,     "len(Signature.__mro__) == 2"]
    - [signature_mro0_name,     "Signature.__mro__[0].__name__.__eq__",       ["Signature"], true,  "Signature.__mro__[0].__name__ == 'Signature'"]
    - [signature_mro1_name,     "Signature.__mro__[1].__name__.__eq__",       ["object"],    true,  "Signature.__mro__[1].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# inspect.BoundArguments MRO — type, length, and indexed name checks
#
# inspect.BoundArguments.__mro__ == (<class 'inspect.BoundArguments'>, <class 'object'>)
# len == 2, [0].__name__ == 'BoundArguments', [1].__name__ == 'object'
# ---------------------------------------------------------------------------

table inspect_extra205.bound_arguments_mro:
  description: "inspect.BoundArguments.__mro__ shape and indexed name checks — pure-Python class, 2-entry MRO"
  kind: python_call_eq
  category: mro
  id_prefix: inspectmro205

  columns: [id, function, args, expected, description]
  rows:
    - [boundarguments_mro_is_tuple,  BoundArguments.__mro__.__class__.__name__.__eq__,  ["tuple"],          true,  "BoundArguments.__mro__.__class__.__name__ == 'tuple'"]
    - [boundarguments_mro_len,       BoundArguments.__mro__.__len__,                    [],                 2,     "len(BoundArguments.__mro__) == 2"]
    - [boundarguments_mro0_name,     "BoundArguments.__mro__[0].__name__.__eq__",       ["BoundArguments"], true,  "BoundArguments.__mro__[0].__name__ == 'BoundArguments'"]
    - [boundarguments_mro1_name,     "BoundArguments.__mro__[1].__name__.__eq__",       ["object"],         true,  "BoundArguments.__mro__[1].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant inspect_extra205.parameter_mro_is_tuple:
  description: "inspect.Parameter.__mro__.__class__.__name__ == 'tuple' — MRO is always a tuple in CPython"
  category: mro
  kind: python_call_eq
  function: Parameter.__mro__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra205.parameter_mro_len_eq_2:
  description: "len(inspect.Parameter.__mro__) == 2 — Parameter is a pure-Python class that inherits only from object"
  category: mro
  kind: python_call_eq
  function: Parameter.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra205.parameter_mro0_name:
  description: "inspect.Parameter.__mro__[0].__name__ == 'Parameter' — first MRO entry is always the class itself"
  category: mro
  kind: python_call_eq
  function: "Parameter.__mro__[0].__name__.__eq__"
  args: ["Parameter"]
  expected: true

invariant inspect_extra205.parameter_mro1_name:
  description: "inspect.Parameter.__mro__[1].__name__ == 'object' — second and final MRO entry is object"
  category: mro
  kind: python_call_eq
  function: "Parameter.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra205.signature_mro_len_eq_2:
  description: "len(inspect.Signature.__mro__) == 2 — Signature is a pure-Python class that inherits only from object"
  category: mro
  kind: python_call_eq
  function: Signature.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra205.signature_mro0_name:
  description: "inspect.Signature.__mro__[0].__name__ == 'Signature' — first MRO entry is the class itself"
  category: mro
  kind: python_call_eq
  function: "Signature.__mro__[0].__name__.__eq__"
  args: ["Signature"]
  expected: true

invariant inspect_extra205.bound_arguments_mro_len_eq_2:
  description: "len(inspect.BoundArguments.__mro__) == 2 — BoundArguments is a pure-Python class that inherits only from object"
  category: mro
  kind: python_call_eq
  function: BoundArguments.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra205.bound_arguments_mro0_name:
  description: "inspect.BoundArguments.__mro__[0].__name__ == 'BoundArguments' — first MRO entry is the class itself"
  category: mro
  kind: python_call_eq
  function: "BoundArguments.__mro__[0].__name__.__eq__"
  args: ["BoundArguments"]
  expected: true

