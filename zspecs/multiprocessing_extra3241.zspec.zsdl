    - ["mp3241002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__rtruediv__"], false]
    - ["mp3241003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__rtruediv__"], false]
    - ["mp3241004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__rtruediv__"], false]
    - ["mp3241005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__rtruediv__"], false]
    - ["mp3241006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__rtruediv__"], false]
    - ["mp3241007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__rtruediv__"], false]
    - ["mp3241008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__rtruediv__"], false]

# ---------------------------------------------------------------------------
# __rfloordiv__ dict-presence — operator.contains(Cls.__dict__, '__rfloordiv__')
#
# All 8 multiprocessing classes return false for __rfloordiv__.
# Process/Pool/AsyncResult/MapResult/SyncManager: process-management types
#   with no arithmetic semantics of any kind.
# managers.BaseListProxy: proxies list — list defines no __floordiv__ or
#   __rfloordiv__. n // list is not a valid Python expression.
# managers._BaseDictProxy: proxies dict — dict defines no arithmetic operators.
# managers._BaseSetProxy: proxies set — set defines no floor division from
#   either side. The proxy's _method IPC callthrough handles no arithmetic.
# ---------------------------------------------------------------------------

