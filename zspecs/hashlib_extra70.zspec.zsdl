spec: hashlib_extra70
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_blake2/blake2module.c"
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra69.zspec.zsdl — covers new.__defaults__.__class__.__name__=='tuple' / new.__defaults__.__len__()==1 / new.__defaults__[0].__class__.__name__=='bytes' / file_digest.__defaults__.__class__.__name__=='NoneType' / md5/sha256/sha512 __class__.__name__=='builtin_function_or_method' / md5/sha256 __module__.__contains__('hash') (table + invariants)."
    - "hashlib_extra68.zspec.zsdl — covers new.__code__.co_consts/__class__.__name__=='tuple' / file_digest.__code__.co_consts/__class__.__name__=='tuple' / co_nlocals/__class__.__name__=='int' / co_stacksize/__class__.__name__=='int' / algorithms_guaranteed.__contains__ sha3_256/sha3_512/sha224/sha384/blake2b/blake2s (table + invariants)."
    - "hashlib_extra67.zspec.zsdl — covers new.__code__.co_varnames/__class__.__name__=='tuple' / file_digest.__code__.co_varnames/__class__.__name__=='tuple' / new.__code__.co_varnames[0]=='name' / file_digest.__code__.co_varnames[0]=='fileobj' / algorithms_guaranteed.__contains__ sha256/md5/sha1/sha512 (table + invariants)."
    - "hashlib_extra66.zspec.zsdl — covers new.__code__.co_name ('__hash_new') / file_digest.__code__.co_name / new.__code__.co_argcount==1 / file_digest.__code__.co_argcount==2 (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra69; it does NOT duplicate invariants present in those files."
    - "Wave 234 theme: __kwdefaults__ NoneType for hashlib.new and file_digest + __doc__.__class__.__name__=='str' for md5/sha256/sha1/sha512 + doc content anchors for new and file_digest."
    - "hashlib.new.__kwdefaults__.__class__.__name__ == 'NoneType' — hashlib.new is internally __hash_new(name, string=b'', **kwargs); **kwargs means no keyword-only parameters so __kwdefaults__ is None. No prior hashlib spec checks new.__kwdefaults__.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__kwdefaults__.__class__.__name__ == 'NoneType' — file_digest(fileobj, digest, /) has no keyword-only parameters so __kwdefaults__ is None. No prior hashlib spec checks file_digest.__kwdefaults__.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__doc__.__class__.__name__ == 'str' — md5 is a C builtin callable from _hashlib; it has a docstring; the docstring's __class__.__name__ is 'str'. No prior hashlib spec checks md5.__doc__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__doc__.__class__.__name__ == 'str' — same reasoning as md5. No prior hashlib spec checks sha256.__doc__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__doc__.__class__.__name__ == 'str' — sha1 is a C builtin callable from _hashlib; it has a docstring; the docstring's __class__.__name__ is 'str'. No prior hashlib spec checks sha1.__doc__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__doc__.__class__.__name__ == 'str' — same reasoning as sha1. No prior hashlib spec checks sha512.__doc__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__doc__.__class__.__name__ == 'str' — hashlib.new is a Python function (Lib/hashlib.py) with a docstring; __doc__.__class__.__name__ is 'str'. No prior hashlib spec checks new.__doc__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__doc__.__contains__('name') == True — the docstring for new references 'name' (the first positional parameter). No prior hashlib spec checks new.__doc__.__contains__('name'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__doc__.__class__.__name__ == 'str' — file_digest is a Python function (Lib/hashlib.py) with a docstring; __doc__.__class__.__name__ is 'str'. No prior hashlib spec checks file_digest.__doc__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__doc__.__contains__('digest') == True — the docstring for file_digest references 'digest'. No prior hashlib spec checks file_digest.__doc__.__contains__('digest'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new and file_digest __kwdefaults__ NoneType
#
# Wave 234 theme: __kwdefaults__ NoneType for hashlib Python wrapper functions.
#
# hashlib.new is internally __hash_new(name, string=b'', **kwargs). The **kwargs
# absorbs any keyword arguments but there are no keyword-only parameters defined
# after *, so __kwdefaults__ is None (NoneType). file_digest(fileobj, digest, /)
# similarly has no keyword-only parameters; __kwdefaults__ is None.
# No prior hashlib spec checks new.__kwdefaults__ or file_digest.__kwdefaults__
# in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra70.none_kwdefaults:
  description: "hashlib.new/__kwdefaults__/__class__/__name__=='NoneType' / file_digest/__kwdefaults__/__class__/__name__=='NoneType' — new is __hash_new(name, string=b'', **kwargs) with no keyword-only parameters; file_digest(fileobj, digest, /) also has no keyword-only parameters; __kwdefaults__ is None (NoneType) for both; no prior hashlib spec checks new/__kwdefaults__ or file_digest/__kwdefaults__ in any form; first __kwdefaults__ identity anchor for hashlib wrapper functions"
  kind: python_call_eq
  category: kwdefaults
  id_prefix: hashlibkw70

  columns: [id, function, args, expected]
  rows:
    - [new_kwdefaults_class_NoneType,          new.__kwdefaults__.__class__.__name__.__eq__,          ["NoneType"], true]
    - [file_digest_kwdefaults_class_NoneType,  file_digest.__kwdefaults__.__class__.__name__.__eq__,  ["NoneType"], true]

# ---------------------------------------------------------------------------
# hashlib md5 / sha256 / sha1 / sha512 __doc__.__class__.__name__ == 'str'
#
# Wave 234 theme: docstring class identity for hashlib C builtin constructors.
#
# hashlib.md5, sha256, sha1, and sha512 are C builtin callables from the
# _hashlib C extension. Each has a docstring (a help string describing the
# constructor). The docstring's __class__.__name__ is 'str'. No prior hashlib
# spec checks __doc__.__class__.__name__ for md5, sha256, sha1, or sha512.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra70.hash_functions_doc_class:
  description: "hashlib.md5/__doc__/__class__/__name__=='str' / sha256/__doc__/__class__/__name__=='str' / sha1/__doc__/__class__/__name__=='str' / sha512/__doc__/__class__/__name__=='str' — md5/sha256/sha1/sha512 are C builtin callables from _hashlib; each has a docstring (str); __doc__.__class__.__name__ is 'str' for all four; no prior hashlib spec checks __doc__.__class__.__name__ for these functions; first docstring class identity anchor for hashlib C builtin constructors"
  kind: python_call_eq
  category: docstrings
  id_prefix: hashlibkw70

  columns: [id, function, args, expected]
  rows:
    - [md5_doc_class_str,    md5.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [sha256_doc_class_str, sha256.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sha1_doc_class_str,   sha1.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [sha512_doc_class_str, sha512.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# hashlib.new __doc__ class identity and content
#
# Wave 234 theme: new.__doc__ is a str and contains 'name'.
#
# hashlib.new is a Python function in Lib/hashlib.py with a docstring. Its
# __doc__ is a str. The docstring references 'name' (the required first
# parameter). No prior hashlib spec checks new.__doc__.__class__.__name__ or
# new.__doc__.__contains__('name') in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra70.new_doc_contains:
  description: "hashlib.new/__doc__/__class__/__name__=='str' / new/__doc__.__contains__('name')==True — new is a Python function in Lib/hashlib.py with a docstring; __doc__.__class__.__name__ is 'str'; the docstring contains 'name' (the first positional parameter); no prior hashlib spec checks new/__doc__/__class__/__name__ or new/__doc__.__contains__('name'); first docstring class and content anchor for hashlib.new"
  kind: python_call_eq
  category: docstrings
  id_prefix: hashlibkw70

  columns: [id, function, args, expected]
  rows:
    - [new_doc_class_str,       new.__doc__.__class__.__name__.__eq__, ["str"],  true]
    - [new_doc_contains_name,   new.__doc__.__contains__,              ["name"], true]

# ---------------------------------------------------------------------------
# hashlib.file_digest __doc__ class identity and content
#
# Wave 234 theme: file_digest.__doc__ is a str and contains 'digest'.
#
# hashlib.file_digest is a Python function in Lib/hashlib.py with a docstring.
# Its __doc__ is a str. The docstring references 'digest' (the function's
# purpose is to compute a digest of a file object). No prior hashlib spec
# checks file_digest.__doc__.__class__.__name__ or
# file_digest.__doc__.__contains__('digest') in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra70.file_digest_doc_contains:
  description: "hashlib.file_digest/__doc__/__class__/__name__=='str' / file_digest/__doc__.__contains__('digest')==True — file_digest is a Python function in Lib/hashlib.py with a docstring; __doc__.__class__.__name__ is 'str'; the docstring contains 'digest' (core purpose of the function); no prior hashlib spec checks file_digest/__doc__/__class__/__name__ or file_digest/__doc__.__contains__('digest'); first docstring class and content anchor for hashlib.file_digest"
  kind: python_call_eq
  category: docstrings
  id_prefix: hashlibkw70

  columns: [id, function, args, expected]
  rows:
    - [file_digest_doc_class_str,      file_digest.__doc__.__class__.__name__.__eq__, ["str"],    true]
    - [file_digest_doc_contains_digest, file_digest.__doc__.__contains__,             ["digest"], true]

# ---------------------------------------------------------------------------
# hashlib.new.__kwdefaults__.__class__.__name__.__eq__('NoneType') — standalone
#
# hashlib.new is internally __hash_new(name, string=b'', **kwargs) in
# Lib/hashlib.py. The **kwargs means no keyword-only parameters are defined,
# so __kwdefaults__ is None (NoneType). No prior hashlib spec checks
# new.__kwdefaults__ in any form. First __kwdefaults__ NoneType anchor for
# hashlib.new. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra70.new_kwdefaults_NoneType:
  description: "hashlib.new.__kwdefaults__.__class__.__name__.__eq__('NoneType') == True — new is __hash_new(name, string=b'', **kwargs) with no keyword-only parameters; __kwdefaults__ is None (NoneType); no prior hashlib spec checks new.__kwdefaults__ in any form; first __kwdefaults__ NoneType anchor for hashlib.new"
  category: kwdefaults
  kind: python_call_eq
  function: new.__kwdefaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__kwdefaults__.__class__.__name__.__eq__('NoneType') — standalone
#
# hashlib.file_digest(fileobj, digest, /) has no keyword-only parameters.
# __kwdefaults__ is None (NoneType). No prior hashlib spec checks
# file_digest.__kwdefaults__ in any form. First __kwdefaults__ NoneType anchor
# for hashlib.file_digest. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra70.file_digest_kwdefaults_NoneType:
  description: "hashlib.file_digest.__kwdefaults__.__class__.__name__.__eq__('NoneType') == True — file_digest(fileobj, digest, /) has no keyword-only parameters; __kwdefaults__ is None (NoneType); no prior hashlib spec checks file_digest.__kwdefaults__ in any form; first __kwdefaults__ NoneType anchor for hashlib.file_digest"
  category: kwdefaults
  kind: python_call_eq
  function: file_digest.__kwdefaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5.__doc__.__class__.__name__.__eq__('str') — standalone
#
# hashlib.md5 is a C builtin callable from the _hashlib C extension. It has a
# docstring whose __class__.__name__ is 'str'. No prior hashlib spec checks
# md5.__doc__.__class__.__name__ in any form. First docstring class identity
# anchor for hashlib.md5. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra70.md5_doc_str:
  description: "hashlib.md5.__doc__.__class__.__name__.__eq__('str') == True — md5 is a C builtin callable from _hashlib with a docstring; __doc__.__class__.__name__ is 'str'; no prior hashlib spec checks md5.__doc__.__class__.__name__; first docstring class identity anchor for hashlib.md5"
  category: docstrings
  kind: python_call_eq
  function: md5.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__doc__.__contains__('name') == True — standalone
#
# hashlib.new is a Python wrapper for the hash factory in Lib/hashlib.py.
# Its docstring references 'name' (the required first positional parameter
# identifying which hash algorithm to instantiate). No prior hashlib spec
# checks new.__doc__.__contains__('name'). First docstring content anchor
# for hashlib.new. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra70.new_doc_name:
  description: "hashlib.new.__doc__.__contains__('name') == True — the docstring for new references 'name' (the first positional parameter for the hash algorithm name); no prior hashlib spec checks new.__doc__.__contains__('name'); first docstring content anchor for hashlib.new"
  category: docstrings
  kind: python_call_eq
  function: new.__doc__.__contains__
  args: ["name"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__doc__.__contains__('digest') == True — standalone
#
# hashlib.file_digest is a Python function in Lib/hashlib.py whose purpose is
# to compute a digest of a file object. Its docstring contains 'digest'.
# No prior hashlib spec checks file_digest.__doc__.__contains__('digest').
# First docstring content anchor for hashlib.file_digest.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra70.file_digest_doc_digest:
  description: "hashlib.file_digest.__doc__.__contains__('digest') == True — the docstring for file_digest references 'digest' (the function's core purpose is to compute a digest); no prior hashlib spec checks file_digest.__doc__.__contains__('digest'); first docstring content anchor for hashlib.file_digest"
  category: docstrings
  kind: python_call_eq
  function: file_digest.__doc__.__contains__
  args: ["digest"]
  expected: true
