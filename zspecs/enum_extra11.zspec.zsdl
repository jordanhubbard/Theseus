spec: enum_extra11
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum.zspec.zsdl and prior extras."
    - "enum through enum_extra10 cover: __name__/__module__/__qualname__ for Enum/IntEnum/IntFlag/Flag/StrEnum/auto/unique/EnumMeta/EnumType; __bases__[0].__name__ for IntEnum (int), IntFlag (int), Flag (Enum), StrEnum (str); MRO structure for Enum/IntEnum/Flag; auto.__bases__[0].__name__ == 'int'; Enum.__bases__.__len__() == 1; auto.__qualname__."
    - "NEW in this spec: __bases__.__len__() for IntEnum, Flag, IntFlag (base count not yet tested); EnumMeta.__bases__[0].__name__ == 'type' (EnumMeta's metaclass hierarchy); StrEnum.__bases__.__len__() (not yet tested); Flag.__qualname__ (covered in extra4 — skip); IntFlag.__qualname__ (covered in extra4 — skip)."
    - "enum.IntEnum.__bases__.__len__() == 2 — IntEnum has two direct bases: int and Enum."
    - "enum.Flag.__bases__.__len__() == 1 — Flag has exactly one direct base (Enum)."
    - "enum.IntFlag.__bases__.__len__() == 2 — IntFlag has two direct bases: int and Flag."
    - "enum.StrEnum.__bases__.__len__() == 2 — StrEnum has two direct bases: str and ReprEnum (Python 3.11+)."
    - "enum.EnumMeta.__bases__[0].__name__ == 'type' — EnumMeta inherits from type."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__.__len__() for IntEnum, Flag, IntFlag
#
# Prior specs verified the __name__ of specific bases via __bases__[0].__name__
# and __bases__[1].__name__ for IntEnum and IntFlag. Not yet verified: the
# total count of direct bases for each class.
# ---------------------------------------------------------------------------

invariant enum_extra11.IntEnum.bases_len:
  description: "enum.IntEnum.__bases__.__len__() == 2 — IntEnum has two direct bases: int and Enum"
  category: class_hierarchy
  kind: python_call_eq
  function: IntEnum.__bases__.__len__
  args: []
  expected: 2

invariant enum_extra11.Flag.bases_len:
  description: "enum.Flag.__bases__.__len__() == 1 — Flag has exactly one direct base (Enum)"
  category: class_hierarchy
  kind: python_call_eq
  function: Flag.__bases__.__len__
  args: []
  expected: 1

invariant enum_extra11.IntFlag.bases_len:
  description: "enum.IntFlag.__bases__.__len__() == 2 — IntFlag has two direct bases: int and Flag"
  category: class_hierarchy
  kind: python_call_eq
  function: IntFlag.__bases__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# StrEnum.__bases__.__len__() (Python 3.11+)
#
# enum.StrEnum inherits from str and ReprEnum. Its bases tuple has length 2.
# Prior specs verified StrEnum.__bases__[0].__name__ == 'str' but not the
# total count of bases.
# ---------------------------------------------------------------------------

invariant enum_extra11.StrEnum.bases_len:
  description: "enum.StrEnum.__bases__.__len__() == 2 — StrEnum has two direct bases: str and ReprEnum (Python 3.11+)"
  category: class_hierarchy
  version: ">=3.11"
  kind: python_call_eq
  function: StrEnum.__bases__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# EnumMeta.__bases__[0].__name__ == 'type'
#
# EnumMeta (the metaclass for all enum classes) inherits from 'type'. Prior
# specs covered EnumMeta.__name__, __module__, and __qualname__, but no spec
# has verified the base class of EnumMeta itself.
# ---------------------------------------------------------------------------

invariant enum_extra11.EnumMeta.base_is_type:
  description: "enum.EnumMeta.__bases__[0].__name__ == 'type' — EnumMeta inherits from type"
  category: class_hierarchy
  kind: python_call_eq
  function: EnumMeta.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "type"

# ---------------------------------------------------------------------------
# EnumMeta.__bases__.__len__() == 1
#
# EnumMeta has exactly one direct base: type. This is consistent with the
# single-inheritance metaclass pattern.
# ---------------------------------------------------------------------------

invariant enum_extra11.EnumMeta.bases_len:
  description: "enum.EnumMeta.__bases__.__len__() == 1 — EnumMeta has exactly one direct base (type)"
  category: class_hierarchy
  kind: python_call_eq
  function: EnumMeta.__bases__.__len__
  args: []
  expected: 1
