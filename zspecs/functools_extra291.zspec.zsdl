spec: functools_extra291
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools.WRAPPER_ASSIGNMENTS and functools.WRAPPER_UPDATES constants, singledispatch/singledispatchmethod identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "WRAPPER_ASSIGNMENTS in Python 3.14 has 6 elements: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__"
    - "__annotations__ was replaced by __annotate__ in Python 3.14; __type_params__ was added in Python 3.12"
    - "WRAPPER_UPDATES has exactly 1 element: __dict__"
    - "Both WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES are plain tuples"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table functools_extra291.wrapper_assignments_membership:
  description: "Membership checks for functools.WRAPPER_ASSIGNMENTS tuple contents"
  kind: python_call_eq
  category: identity
  id_prefix: fwam

  columns: [id, function, args, expected, description]
  rows:
    - [fwam001, functools.WRAPPER_ASSIGNMENTS.__contains__, ["__module__"], true, "__module__ is in WRAPPER_ASSIGNMENTS"]
    - [fwam002, functools.WRAPPER_ASSIGNMENTS.__contains__, ["__name__"], true, "__name__ is in WRAPPER_ASSIGNMENTS"]
    - [fwam003, functools.WRAPPER_ASSIGNMENTS.__contains__, ["__qualname__"], true, "__qualname__ is in WRAPPER_ASSIGNMENTS"]
    - [fwam004, functools.WRAPPER_ASSIGNMENTS.__contains__, ["__doc__"], true, "__doc__ is in WRAPPER_ASSIGNMENTS"]
    - [fwam005, functools.WRAPPER_ASSIGNMENTS.__contains__, ["__annotate__"], true, "__annotate__ is in WRAPPER_ASSIGNMENTS (Python 3.14+)"]
    - [fwam006, functools.WRAPPER_ASSIGNMENTS.__contains__, ["__type_params__"], true, "__type_params__ is in WRAPPER_ASSIGNMENTS (Python 3.12+)"]
    - [fwam007, functools.WRAPPER_ASSIGNMENTS.__contains__, ["__annotations__"], false, "__annotations__ is NOT in WRAPPER_ASSIGNMENTS in Python 3.14"]
    - [fwam008, functools.WRAPPER_UPDATES.__contains__, ["__dict__"], true, "__dict__ is in WRAPPER_UPDATES"]

table functools_extra291.singledispatch_identity:
  description: "Identity checks for singledispatch and singledispatchmethod"
  kind: python_call_eq
  category: identity
  id_prefix: fsdi

  columns: [id, function, args, expected, description]
  rows:
    - [fsdi001, functools.singledispatch.__class__.__name__.__eq__, ["function"], true, "singledispatch is a function"]
    - [fsdi002, functools.singledispatch.__name__.__eq__, ["singledispatch"], true, "singledispatch.__name__ is 'singledispatch'"]
    - [fsdi003, functools.singledispatch.__module__.__eq__, ["functools"], true, "singledispatch.__module__ is 'functools'"]
    - [fsdi004, functools.singledispatchmethod.__name__.__eq__, ["singledispatchmethod"], true, "singledispatchmethod.__name__ is 'singledispatchmethod'"]
    - [fsdi005, functools.singledispatchmethod.__module__.__eq__, ["functools"], true, "singledispatchmethod.__module__ is 'functools'"]
    - [fsdi006, functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__, ["tuple"], true, "WRAPPER_ASSIGNMENTS is a tuple"]
    - [fsdi007, functools.WRAPPER_UPDATES.__class__.__name__.__eq__, ["tuple"], true, "WRAPPER_UPDATES is a tuple"]

invariant functools_extra291.wrapper_assignments_len:
  description: "WRAPPER_ASSIGNMENTS has 6 elements in Python 3.14"
  category: identity
  kind: python_call_eq
  function: functools.WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra291.wrapper_updates_len:
  description: "WRAPPER_UPDATES has exactly 1 element"
  category: identity
  kind: python_call_eq
  function: functools.WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra291.wrapper_assignments_class:
  description: "WRAPPER_ASSIGNMENTS is a tuple"
  category: identity
  kind: python_call_eq
  function: functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra291.wrapper_updates_class:
  description: "WRAPPER_UPDATES is a tuple"
  category: identity
  kind: python_call_eq
  function: functools.WRAPPER_UPDATES.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true
