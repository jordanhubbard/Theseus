spec: abc_extra1021
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc.ABCMeta and abc.ABC abstractmethods descriptors, subclasshook qualname, and module-level attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra1021.abstractmethods_descriptors:
  description: "abc.ABCMeta and abc.ABC __abstractmethods__ descriptor class name identity"
  kind: python_call_eq
  category: abstractmethods_descriptors
  id_prefix: ab1021d
  columns: [id, function, args, expected]
  rows:
    - [ab1021d001, abc.ABCMeta.__abstractmethods__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [ab1021d002, abc.ABC.__abstractmethods__.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [ab1021d003, abc.ABCMeta.__class__.__name__.__eq__,                     ["type"],              true]
    - [ab1021d004, abc.ABC.__class__.__name__.__eq__,                         ["ABCMeta"],           true]
    - [ab1021d005, abc.ABCMeta.__module__.__eq__,                             ["abc"],               true]
    - [ab1021d006, abc.ABC.__module__.__eq__,                                 ["abc"],               true]
    - [ab1021d007, abc.ABCMeta.__name__.__eq__,                               ["ABCMeta"],           true]

table abc_extra1021.subclasshook_qualname:
  description: "abc.ABCMeta.__subclasshook__ qualname identity"
  kind: python_call_eq
  category: subclasshook_qualname
  id_prefix: ab1021s
  columns: [id, function, args, expected]
  rows:
    - [ab1021s001, abc.ABCMeta.__subclasshook__.__func__.__qualname__.__eq__, ["ABCMeta.__subclasshook__"], true]
    - [ab1021s002, abc.ABCMeta.__subclasshook__.__func__.__module__.__eq__,   ["abc"],                     true]
    - [ab1021s003, abc.ABCMeta.__subclasshook__.__class__.__name__.__eq__,    ["classmethod_descriptor"],  true]
    - [ab1021s004, abc.ABCMeta.register.__qualname__.__eq__,                  ["ABCMeta.register"],        true]
    - [ab1021s005, abc.ABCMeta.__instancecheck__.__qualname__.__eq__,         ["ABCMeta.__instancecheck__"], true]

table abc_extra1021.module_attributes:
  description: "abc module-level attribute class identity"
  kind: python_call_eq
  category: module_attributes
  id_prefix: ab1021m
  columns: [id, function, args, expected]
  rows:
    - [ab1021m001, abc.__all__.__class__.__name__.__eq__,     ["list"], true]
    - [ab1021m002, abc.__cached__.__class__.__name__.__eq__,  ["str"],  true]
    - [ab1021m003, abc.__file__.__class__.__name__.__eq__,    ["str"],  true]
    - [ab1021m004, abc.__name__.__eq__,                       ["abc"],  true]
    - [ab1021m005, abc.__package__.__eq__,                    ["abc"],  true]
