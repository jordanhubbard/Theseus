spec: typing_extra9
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "PEP 484 — Type Hints"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing.zspec.zsdl and prior extras."
    - "typing_extra/extra2/extra4/extra6 cover TypeVar.__name__ and TypeVar.__module__."
    - "typing_extra4/extra5/extra6 cover TypeVar.__qualname__."
    - "typing_extra/extra2 cover Generic.__name__ and Generic.__module__."
    - "typing_extra4/extra5 cover Protocol.__name__, Protocol.__module__."
    - "typing_extra2 covers get_type_hints.__name__, cast.__name__, overload.__name__."
    - "typing_extra7 covers Generic.__qualname__, Protocol.__qualname__, NamedTuple.__qualname__, TypedDict.__qualname__."
    - "typing_extra7 covers get_type_hints.__qualname__, cast.__qualname__, overload.__qualname__."
    - "NOT yet covered: ForwardRef.__qualname__."
    - "NOT yet covered: ForwardRef.__bases__[0].__name__ == 'object' — ForwardRef has a single base."
    - "NOT yet covered: get_overloads.__qualname__ — typing_extra3 covers get_overloads.__name__ via names category but not __qualname__."
    - "NOT yet covered: TypeVar.__bases__[0].__name__ — TypeVar is a class; its base is 'object'."
    - "NOT yet covered: Generic.__mro__.__len__() == 2 — Generic, object."
    - "NOT yet covered: Protocol.__mro__.__len__() == 3 — Protocol, Generic, object."
    - "typing.ForwardRef.__qualname__ == 'ForwardRef' — top-level class in typing module."
    - "typing.ForwardRef.__bases__[0].__name__ == 'object' — ForwardRef's sole direct base."
    - "typing.get_overloads.__qualname__ == 'get_overloads' — module-level function (Python 3.11+)."
    - "typing.TypeVar.__bases__[0].__name__ == 'object' — TypeVar is a plain class inheriting from object."
    - "typing.Generic.__mro__.__len__() == 2 — [Generic, object]."
    - "typing.Protocol.__mro__.__len__() == 3 — [Protocol, Generic, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ForwardRef — __qualname__ and base class
#
# typing_extra4 covers ForwardRef.__name__ and ForwardRef.__module__.
# typing_extra7 does not include ForwardRef.__qualname__.
# Neither prior spec checks ForwardRef.__bases__[0].__name__.
# ForwardRef is a plain class at module level; qualname == name == 'ForwardRef'.
# ForwardRef's only direct base is object.
# ---------------------------------------------------------------------------

invariant typing_extra9.ForwardRef.qualname:
  description: "typing.ForwardRef.__qualname__ == 'ForwardRef'"
  category: class_qualnames
  kind: python_call_eq
  function: ForwardRef.__qualname__.__eq__
  args: ["ForwardRef"]
  expected: true

invariant typing_extra9.ForwardRef.base_is_object:
  description: "typing.ForwardRef.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: ForwardRef.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# get_overloads — __qualname__ (Python 3.11+)
#
# typing_extra has get_overloads.__name__ (via names category invariant).
# No prior spec covers get_overloads.__qualname__.
# Module-level functions have __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant typing_extra9.get_overloads.qualname:
  description: "typing.get_overloads.__qualname__ == 'get_overloads' (Python 3.11+)"
  category: function_qualnames
  kind: python_call_eq
  function: get_overloads.__qualname__.__eq__
  args: ["get_overloads"]
  expected: true
  version: ">=3.11"

# ---------------------------------------------------------------------------
# TypeVar class hierarchy
#
# typing.TypeVar is a plain Python class. No prior spec checks TypeVar.__bases__.
# Its single direct base is object.
# ---------------------------------------------------------------------------

invariant typing_extra9.TypeVar.base_is_object:
  description: "typing.TypeVar.__bases__[0].__name__ == 'object' — TypeVar is a plain class"
  category: TypeVar
  kind: python_call_eq
  function: TypeVar.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Generic and Protocol MRO lengths
#
# typing_extra7 covers Generic.__bases__[0].__name__ == 'object' and
# Protocol.__bases__[0].__name__ == 'Generic'.
# No prior spec checks __mro__.__len__() for Generic or Protocol.
# Generic.__mro__ == [Generic, object] — length 2.
# Protocol.__mro__ == [Protocol, Generic, object] — length 3.
# ---------------------------------------------------------------------------

invariant typing_extra9.Generic.mro_len:
  description: "typing.Generic.__mro__.__len__() == 2 — Generic, object"
  category: Generic
  kind: python_call_eq
  function: Generic.__mro__.__len__
  args: []
  expected: 2

invariant typing_extra9.Protocol.mro_len:
  description: "typing.Protocol.__mro__.__len__() == 3 — Protocol, Generic, object"
  category: Protocol
  kind: python_call_eq
  function: Protocol.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# is_typeddict — __qualname__ (Python 3.10+)
#
# typing_extra covers is_typeddict.__name__.
# No prior spec covers is_typeddict.__qualname__.
# ---------------------------------------------------------------------------

invariant typing_extra9.is_typeddict.qualname:
  description: "typing.is_typeddict.__qualname__ == 'is_typeddict' (Python 3.10+)"
  category: function_qualnames
  kind: python_call_eq
  function: is_typeddict.__qualname__.__eq__
  args: ["is_typeddict"]
  expected: true
  version: ">=3.10"

# ---------------------------------------------------------------------------
# runtime_checkable — __name__ check
#
# typing_extra5 covers runtime_checkable.__module__.
# No prior spec covers runtime_checkable.__name__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant typing_extra9.runtime_checkable.name:
  description: "typing.runtime_checkable.__name__ == 'runtime_checkable'"
  category: function_names
  kind: python_call_eq
  function: runtime_checkable.__name__.__eq__
  args: ["runtime_checkable"]
  expected: true
