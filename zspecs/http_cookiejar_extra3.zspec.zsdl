spec: http_cookiejar_extra3
version: ">=3.0"
backend: python_module(http.cookiejar)

docs: https://docs.python.org/3/library/http.cookiejar.html

provenance:
  derived_from:
    - "Python http.cookiejar documentation — https://docs.python.org/3/library/http.cookiejar.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/cookiejar.py"
  notes:
    - "This spec extends http_cookiejar.zspec.zsdl, http_cookiejar_extra.zspec.zsdl, and http_cookiejar_extra2.zspec.zsdl."
    - "http_cookiejar.zspec.zsdl covers: __name__ for all 8 public classes; CookieJar.__module__; DefaultCookiePolicy/__bases__[0].__name__=='CookiePolicy'; FileCookieJar/__bases__[0].__name__=='CookieJar'; LoadError/__bases__[0].__name__=='OSError'; CookieJar().__len__()==0."
    - "http_cookiejar_extra.zspec.zsdl covers: __qualname__ for all seven public classes."
    - "http_cookiejar_extra2.zspec.zsdl covers: __module__ for FileCookieJar/LWPCookieJar/MozillaCookieJar/Cookie/CookiePolicy/DefaultCookiePolicy/LoadError; LWPCookieJar/__bases__[0].__name__=='FileCookieJar'; MozillaCookieJar/__bases__[0].__name__=='FileCookieJar'; CookieJar/__bases__[0].__name__=='object'; CookiePolicy/__bases__[0].__name__=='object'; __name__ lengths for CookieJar/FileCookieJar/DefaultCookiePolicy."
    - "No prior spec covers: CookieJar.__mro__[0].__name__ == 'CookieJar' (MRO self-check)."
    - "No prior spec covers: CookieJar.__mro__[1].__name__ == 'object' (MRO terminus)."
    - "No prior spec covers: FileCookieJar.__mro__[1].__name__ == 'CookieJar' (MRO index 1)."
    - "No prior spec covers: LWPCookieJar.__mro__[2].__name__ == 'CookieJar' (MRO depth 2)."
    - "No prior spec covers: MozillaCookieJar.__mro__[2].__name__ == 'CookieJar' (MRO depth 2)."
    - "No prior spec covers: DefaultCookiePolicy.__mro__[1].__name__ == 'CookiePolicy' (MRO index 1)."
    - "No prior spec covers: LoadError.__mro__[1].__name__ == 'OSError' (MRO index 1)."
    - "No prior spec covers: __name__ length checks for LWPCookieJar (12), MozillaCookieJar (16), Cookie (6)."
    - "CookieJar.__mro__: [CookieJar, object]."
    - "FileCookieJar.__mro__: [FileCookieJar, CookieJar, object]."
    - "LWPCookieJar.__mro__: [LWPCookieJar, FileCookieJar, CookieJar, object]."
    - "MozillaCookieJar.__mro__: [MozillaCookieJar, FileCookieJar, CookieJar, object]."
    - "DefaultCookiePolicy.__mro__: [DefaultCookiePolicy, CookiePolicy, object]."
    - "LoadError.__mro__: [LoadError, OSError, Exception, BaseException, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# CookieJar MRO — two-entry MRO: [CookieJar, object]
#
# http_cookiejar_extra2 covers CookieJar.__bases__[0].__name__ == 'object'.
# No prior spec checks CookieJar.__mro__ at any index.
# ---------------------------------------------------------------------------

invariant http_cookiejar_extra3.CookieJar.mro_index0:
  description: "CookieJar.__mro__[0].__name__ == 'CookieJar' — MRO self-check at index 0"
  category: class_hierarchy
  kind: python_call_eq
  function: CookieJar.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "CookieJar"

invariant http_cookiejar_extra3.CookieJar.mro_index1:
  description: "CookieJar.__mro__[1].__name__ == 'object' — CookieJar MRO terminus is object"
  category: class_hierarchy
  kind: python_call_eq
  function: CookieJar.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# FileCookieJar MRO — three-entry MRO: [FileCookieJar, CookieJar, object]
#
# No prior spec checks FileCookieJar.__mro__ at any index.
# http_cookiejar_extra2 covers FileCookieJar.__bases__[0].__name__ == 'CookieJar'.
# ---------------------------------------------------------------------------

invariant http_cookiejar_extra3.FileCookieJar.mro_index1:
  description: "FileCookieJar.__mro__[1].__name__ == 'CookieJar' — FileCookieJar inherits CookieJar"
  category: class_hierarchy
  kind: python_call_eq
  function: FileCookieJar.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "CookieJar"

# ---------------------------------------------------------------------------
# LWPCookieJar and MozillaCookieJar MRO — index 2 is CookieJar
#
# Both subclass FileCookieJar, so their MRO[2] == CookieJar.
# http_cookiejar_extra2 covers their __bases__[0].__name__ == 'FileCookieJar'.
# No prior spec covers MRO at any index for either class.
# ---------------------------------------------------------------------------

invariant http_cookiejar_extra3.LWPCookieJar.mro_index2:
  description: "LWPCookieJar.__mro__[2].__name__ == 'CookieJar' — LWPCookieJar MRO depth 2"
  category: class_hierarchy
  kind: python_call_eq
  function: LWPCookieJar.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "CookieJar"

invariant http_cookiejar_extra3.MozillaCookieJar.mro_index2:
  description: "MozillaCookieJar.__mro__[2].__name__ == 'CookieJar' — MozillaCookieJar MRO depth 2"
  category: class_hierarchy
  kind: python_call_eq
  function: MozillaCookieJar.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "CookieJar"

# ---------------------------------------------------------------------------
# DefaultCookiePolicy MRO — index 1 is CookiePolicy
#
# No prior spec covers DefaultCookiePolicy.__mro__ at any index.
# http_cookiejar covers DefaultCookiePolicy.__bases__[0].__name__ == 'CookiePolicy'.
# ---------------------------------------------------------------------------

invariant http_cookiejar_extra3.DefaultCookiePolicy.mro_index1:
  description: "DefaultCookiePolicy.__mro__[1].__name__ == 'CookiePolicy' — DefaultCookiePolicy MRO index 1"
  category: class_hierarchy
  kind: python_call_eq
  function: DefaultCookiePolicy.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "CookiePolicy"

# ---------------------------------------------------------------------------
# LoadError MRO — inherits from OSError; MRO index 1 == OSError
#
# http_cookiejar covers LoadError.__bases__[0].__name__ == 'OSError'.
# No prior spec checks LoadError.__mro__ at any index.
# ---------------------------------------------------------------------------

invariant http_cookiejar_extra3.LoadError.mro_index1:
  description: "LoadError.__mro__[1].__name__ == 'OSError' — LoadError MRO index 1 is OSError"
  category: class_hierarchy
  kind: python_call_eq
  function: LoadError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# __name__ length checks — LWPCookieJar, MozillaCookieJar, Cookie
#
# http_cookiejar_extra2 covers __name__ lengths for CookieJar(9)/FileCookieJar(13)/DefaultCookiePolicy(19).
# No prior spec covers LWPCookieJar(12), MozillaCookieJar(16), Cookie(6) lengths.
# ---------------------------------------------------------------------------

invariant http_cookiejar_extra3.LWPCookieJar.name_len:
  description: "LWPCookieJar.__name__.__len__() == 12 — 'LWPCookieJar' has 12 characters"
  category: class_identity
  kind: python_call_eq
  function: LWPCookieJar.__name__.__len__
  args: []
  expected: 12

invariant http_cookiejar_extra3.MozillaCookieJar.name_len:
  description: "MozillaCookieJar.__name__.__len__() == 16 — 'MozillaCookieJar' has 16 characters"
  category: class_identity
  kind: python_call_eq
  function: MozillaCookieJar.__name__.__len__
  args: []
  expected: 16

invariant http_cookiejar_extra3.Cookie.name_len:
  description: "Cookie.__name__.__len__() == 6 — 'Cookie' has 6 characters"
  category: class_identity
  kind: python_call_eq
  function: Cookie.__name__.__len__
  args: []
  expected: 6
