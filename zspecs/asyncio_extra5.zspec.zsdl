spec: asyncio_extra5
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
  notes:
    - "This spec extends prior asyncio specs."
    - "Focus: asyncio class and function names not yet covered."
    - "asyncio.Queue.__name__ == 'Queue'."
    - "asyncio.PriorityQueue.__name__ == 'PriorityQueue'."
    - "asyncio.LifoQueue.__name__ == 'LifoQueue'."
    - "asyncio.QueueEmpty.__name__ == 'QueueEmpty'."
    - "asyncio.QueueFull.__name__ == 'QueueFull'."
    - "asyncio.Lock.__name__ == 'Lock'."
    - "asyncio.Event.__name__ == 'Event'."
    - "asyncio.Condition.__name__ == 'Condition'."
    - "asyncio.Semaphore.__name__ == 'Semaphore'."
    - "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore'."
    - "asyncio.Semaphore.__module__ == 'asyncio.locks'."
    - "asyncio.iscoroutine.__name__ == 'iscoroutine'."
    - "asyncio.iscoroutinefunction.__name__ == 'iscoroutinefunction'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table asyncio_extra5.queue_class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: qcname

  columns: [id, function, args, expected]
  rows:
    - [Queue,        Queue.__name__.__eq__,        ["Queue"],        true]
    - [PriorityQueue, PriorityQueue.__name__.__eq__, ["PriorityQueue"], true]
    - [LifoQueue,    LifoQueue.__name__.__eq__,    ["LifoQueue"],    true]
    - [QueueEmpty,   QueueEmpty.__name__.__eq__,   ["QueueEmpty"],   true]
    - [QueueFull,    QueueFull.__name__.__eq__,    ["QueueFull"],    true]

table asyncio_extra5.lock_class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: lcname

  columns: [id, function, args, expected]
  rows:
    - [Lock,             Lock.__name__.__eq__,             ["Lock"],             true]
    - [Event,            Event.__name__.__eq__,            ["Event"],            true]
    - [Condition,        Condition.__name__.__eq__,        ["Condition"],        true]
    - [Semaphore,        Semaphore.__name__.__eq__,        ["Semaphore"],        true]
    - [BoundedSemaphore, BoundedSemaphore.__name__.__eq__, ["BoundedSemaphore"], true]

table asyncio_extra5.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [iscoroutine,              iscoroutine.__name__.__eq__,              ["iscoroutine"],         true]
    - [iscoroutinefunction,      iscoroutinefunction.__name__.__eq__,      ["iscoroutinefunction"], true]
    - [isfuture,                 isfuture.__name__.__eq__,                 ["isfuture"],            true]
    - [iscoroutinefunction_module, iscoroutinefunction.__module__.__eq__,  ["asyncio.coroutines"], true]

invariant asyncio_extra5.Semaphore.module:
  description: "asyncio.Semaphore.__module__ == 'asyncio.locks'"
  category: module
  kind: python_call_eq
  function: Semaphore.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra5.Lock.module:
  description: "asyncio.Lock.__module__ == 'asyncio.locks'"
  category: module
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra5.Queue.module:
  description: "asyncio.Queue.__module__ == 'asyncio.queues'"
  category: module
  kind: python_call_eq
  function: Queue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra5.TimeoutError.base:
  description: "asyncio.TimeoutError.__bases__[0].__name__ in ('TimeoutError', 'Exception')"
  category: exceptions
  kind: python_call_eq
  function: TimeoutError.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant asyncio_extra5.InvalidStateError.class_name:
  description: "asyncio.InvalidStateError.__name__ == 'InvalidStateError'"
  category: exceptions
  kind: python_call_eq
  function: InvalidStateError.__name__.__eq__
  args: ["InvalidStateError"]
  expected: true
