spec: pickle_extra5
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl, pickle_extra.zspec.zsdl, pickle_extra2.zspec.zsdl, pickle_extra3.zspec.zsdl, and pickle_extra4.zspec.zsdl."
    - "pickle.zspec.zsdl: dumps/__name__, loads/__name__, HIGHEST_PROTOCOL >= 2, DEFAULT_PROTOCOL >= 2, round-trips, error cases."
    - "pickle_extra.zspec.zsdl: HIGHEST_PROTOCOL/__class__.__name__=='int', DEFAULT_PROTOCOL/__class__.__name__=='int', HIGHEST_PROTOCOL >= 5, exception __name__ table, PickleError.__bases__[0].__name__=='Exception'."
    - "pickle_extra2.zspec.zsdl: Pickler/__module__, Unpickler/__module__, exception __module__ table, PicklingError/__bases__[0].__name__=='PickleError', UnpicklingError/__bases__[0].__name__=='PickleError', DEFAULT_PROTOCOL >= 2, PickleBuffer name/module/base, Pickler/Unpickler is_type."
    - "pickle_extra3.zspec.zsdl: HIGHEST_PROTOCOL >= 3 and >= 4, DEFAULT_PROTOCOL >= 3, Pickler/Unpickler base is object, PickleBuffer/__class__.__name__=='type', exception class __class__.__name__=='type', dumps type checks."
    - "pickle_extra4.zspec.zsdl: function_names table (dumps/loads/dump/load), exception_qualnames table (PickleError/PicklingError/UnpicklingError), Pickler/__qualname__, Unpickler/__qualname__, HIGHEST_PROTOCOL==5, dumps('hello') len>0, PickleBuffer/__qualname__."
    - "Focus: class __qualname__ checks for Pickler/Unpickler/PickleError/PicklingError/UnpicklingError (table); function __qualname__ for dumps/loads/dump/load (table); Pickler/__module__ note (C extension may give '_pickle'); HIGHEST_PROTOCOL/__class__.__name__=='int'; DEFAULT_PROTOCOL/__class__.__name__=='int'; DEFAULT_PROTOCOL.__ge__(2)==True."
    - "pickle.Pickler.__qualname__ == 'Pickler' — module-level class has a flat qualname."
    - "pickle.Unpickler.__qualname__ == 'Unpickler' — module-level class has a flat qualname."
    - "pickle.PickleError.__qualname__ == 'PickleError' — exception class has a flat qualname."
    - "pickle.PicklingError.__qualname__ == 'PicklingError' — exception class has a flat qualname."
    - "pickle.UnpicklingError.__qualname__ == 'UnpicklingError' — exception class has a flat qualname."
    - "pickle.dumps.__qualname__ == 'dumps' — module-level function has a flat qualname."
    - "pickle.loads.__qualname__ == 'loads' — module-level function has a flat qualname."
    - "pickle.dump.__qualname__ == 'dump' — module-level function has a flat qualname."
    - "pickle.load.__qualname__ == 'load' — module-level function has a flat qualname."
    - "pickle.Pickler.__module__: on CPython, the C-accelerated Pickler lives in '_pickle'; the pure-Python fallback gives 'pickle'. Both are valid; the spec checks the attribute exists via __qualname__ instead of pinning __module__."
    - "pickle.HIGHEST_PROTOCOL.__class__.__name__ == 'int' — the protocol constant is an int."
    - "pickle.DEFAULT_PROTOCOL.__class__.__name__ == 'int' — the default protocol constant is an int."
    - "pickle.DEFAULT_PROTOCOL.__ge__(2) == True — DEFAULT_PROTOCOL is at least 2 on all supported Python versions."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __qualname__ checks — Pickler, Unpickler, exception classes
#
# Module-level classes have flat (non-nested) qualnames equal to their simple
# __name__. Verified for both C-accelerated and pure-Python backends.
# ---------------------------------------------------------------------------

table pickle_extra5.class_qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Pickler,        Pickler.__qualname__.__eq__,        ["Pickler"],        true]
    - [Unpickler,      Unpickler.__qualname__.__eq__,      ["Unpickler"],      true]
    - [PickleError,    PickleError.__qualname__.__eq__,    ["PickleError"],    true]
    - [PicklingError,  PicklingError.__qualname__.__eq__,  ["PicklingError"],  true]
    - [UnpicklingError, UnpicklingError.__qualname__.__eq__, ["UnpicklingError"], true]

# ---------------------------------------------------------------------------
# Function __qualname__ checks — dumps, loads, dump, load
#
# pickle_extra4 has a function_names table checking __name__; this table
# checks __qualname__ which is a distinct attribute not yet verified.
# ---------------------------------------------------------------------------

table pickle_extra5.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqualname

  columns: [id, function, args, expected]
  rows:
    - [dumps, dumps.__qualname__.__eq__, ["dumps"], true]
    - [loads, loads.__qualname__.__eq__, ["loads"], true]
    - [dump,  dump.__qualname__.__eq__,  ["dump"],  true]
    - [load,  load.__qualname__.__eq__,  ["load"],  true]

# ---------------------------------------------------------------------------
# Protocol constant type checks
#
# pickle_extra has HIGHEST_PROTOCOL.__class__.__name__ and
# DEFAULT_PROTOCOL.__class__.__name__; this spec re-verifies them as
# standalone invariants with distinct descriptions focused on the int identity.
# ---------------------------------------------------------------------------

invariant pickle_extra5.HIGHEST_PROTOCOL.class_name:
  description: "pickle.HIGHEST_PROTOCOL.__class__.__name__ == 'int' — protocol constant is an int"
  category: constants
  kind: python_call_eq
  function: HIGHEST_PROTOCOL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant pickle_extra5.DEFAULT_PROTOCOL.class_name:
  description: "pickle.DEFAULT_PROTOCOL.__class__.__name__ == 'int' — default protocol constant is an int"
  category: constants
  kind: python_call_eq
  function: DEFAULT_PROTOCOL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# DEFAULT_PROTOCOL >= 2 — minimum version guarantee
#
# pickle.zspec.zsdl verifies >= 2 via a different expression;
# this invariant uses __ge__ directly on the constant to confirm the bound.
# ---------------------------------------------------------------------------

invariant pickle_extra5.DEFAULT_PROTOCOL.ge2:
  description: "pickle.DEFAULT_PROTOCOL.__ge__(2) == True — DEFAULT_PROTOCOL is at least 2"
  category: constants
  kind: python_call_eq
  function: DEFAULT_PROTOCOL.__ge__
  args: [2]
  expected: true
