# Standalone invariants — extra135
# ---------------------------------------------------------------------------

invariant multiprocessing_extra135.process_init_qualname_len_20:
  description: "multiprocessing.Process.__init__.__qualname__.__len__() == 20 — Process.__init__.__qualname__ is 'BaseProcess.__init__' (20 chars: 'BaseProcess'=11+'.'=1+'__init__'=8=20); the qualname reflects the defining class BaseProcess, not the public Process name; __init__.__code__.co_argcount==6; co_varnames.__len__()==8; NEW in extra135: first standalone Process.__init__ qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__qualname__.__len__
  args: []
  expected: 20

invariant multiprocessing_extra135.process_start_qualname_len_17:
  description: "multiprocessing.Process.start.__qualname__.__len__() == 17 — Process.start.__qualname__ is 'BaseProcess.start' (17 chars: 'BaseProcess'=11+'.'=1+'start'=5=17); start co_argcount==1 (self only); compare with join qualname len==16 and run qualname len==15; NEW in extra135: first standalone Process.start qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.start.__qualname__.__len__
  args: []
  expected: 17

invariant multiprocessing_extra135.process_run_qualname_len_15:
  description: "multiprocessing.Process.run.__qualname__.__len__() == 15 — Process.run.__qualname__ is 'BaseProcess.run' (15 chars: 'BaseProcess'=11+'.'=1+'run'=3=15); run is the shortest qualname of the three methods (run=15, join=16, start=17); run co_argcount==1 (self only — no arguments, override to define process behavior); NEW in extra135: first standalone Process.run qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.run.__qualname__.__len__
  args: []
  expected: 15

invariant multiprocessing_extra135.process_base0_name_len_11:
  description: "multiprocessing.Process.__bases__[0].__name__.__len__() == 11 — Process.__bases__[0].__name__ is 'BaseProcess' (11 chars: 'Base'=4+'Process'=7=11); BaseProcess is the single base class of Process; BaseProcess.__module__ is 'multiprocessing.process' (len=23); NEW in extra135: first standalone Process.__bases__[0].__name__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.Process.__bases__[0].__name__.__len__"
  args: []
  expected: 11

invariant multiprocessing_extra135.process_module_len_23:
  description: "multiprocessing.Process.__module__.__len__() == 23 — Process.__module__ is 'multiprocessing.context' (23 chars: 'multiprocessing'=15+'.'=1+'context'=7=23); Process is re-exported via the context module; the implementation BaseProcess lives in 'multiprocessing.process' (also len=23, same length as 'multiprocessing.context'); NEW in extra135: first standalone Process.__module__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.__module__.__len__
  args: []
  expected: 23

