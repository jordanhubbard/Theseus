# ---------------------------------------------------------------------------

table multiprocessing_extra135.process_join_identity:
  description: "multiprocessing.Process.join qualname and co_argcount checks — join.__qualname__.__eq__('BaseProcess.join')==True (len=16: 'BaseProcess'=11+'.'=1+'join'=4=16); join.__code__.co_argcount==2 (self + timeout); join takes an optional timeout argument unlike start and run (which take only self); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpjoin135

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,  multiprocessing.Process.join.__qualname__.__eq__,           ["BaseProcess.join"], true, "multiprocessing.Process.join.__qualname__ == 'BaseProcess.join' (len=16); verified with Python 3.14.3"]
    - [qn_len, multiprocessing.Process.join.__qualname__.__len__,           [],                  16,   "multiprocessing.Process.join.__qualname__.__len__() == 16; verified with Python 3.14.3"]
    - [argc,   multiprocessing.Process.join.__code__.co_argcount.__eq__,   [2],                 true, "multiprocessing.Process.join.__code__.co_argcount == 2 (self, timeout); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
