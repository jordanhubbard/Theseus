spec: multiprocessing_extra135
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Process

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Process — Python multiprocessing.Process documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec covers: multiprocessing.Process method qualnames, modules, and code object attributes. Process.__init__.__qualname__=='BaseProcess.__init__' (len=20) — the methods are defined on BaseProcess, not Process; Process.start.__qualname__=='BaseProcess.start' (len=17); Process.run.__qualname__=='BaseProcess.run' (len=15); Process.join.__qualname__=='BaseProcess.join' (len=16); Process.__bases__[0].__name__=='BaseProcess' (len=11); Process.__module__=='multiprocessing.context' (len=23). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Process inherits from BaseProcess (defined in Lib/multiprocessing/process.py). multiprocessing.Process.__module__ is 'multiprocessing.context' (len=23) because Process is re-exported via the context module; the actual implementation methods have __module__=='multiprocessing.process' (len=23, same length). Process.__init__.__code__.co_argcount==6 (self, group, target, name, args, kwargs); co_varnames.__len__()==8 (adds daemon, count). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process.__init__ qualname and module — extra135
#
# multiprocessing.Process.__init__.__qualname__  == 'BaseProcess.__init__' (len=20)
# multiprocessing.Process.__init__.__module__    == 'multiprocessing.process' (len=23)
# multiprocessing.Process.__init__.__code__.co_argcount == 6
# ---------------------------------------------------------------------------

table multiprocessing_extra135.process_init_identity:
  description: "multiprocessing.Process.__init__ qualname, module, and co_argcount checks — __init__.__qualname__.__eq__('BaseProcess.__init__')==True (len=20: methods are defined on BaseProcess); __init__.__module__.__eq__('multiprocessing.process')==True (len=23); __init__.__code__.co_argcount==6 (self, group, target, name, args, kwargs); co_varnames.__len__()==8 (adds daemon and count); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpinit135

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,        multiprocessing.Process.__init__.__qualname__.__eq__,            ["BaseProcess.__init__"],    true, "multiprocessing.Process.__init__.__qualname__ == 'BaseProcess.__init__' (len=20); verified with Python 3.14.3"]
    - [qn_len,       multiprocessing.Process.__init__.__qualname__.__len__,            [],                         20,   "multiprocessing.Process.__init__.__qualname__.__len__() == 20; verified with Python 3.14.3"]
    - [mod_eq,       multiprocessing.Process.__init__.__module__.__eq__,              ["multiprocessing.process"], true, "multiprocessing.Process.__init__.__module__ == 'multiprocessing.process' (len=23); verified with Python 3.14.3"]
    - [mod_len,      multiprocessing.Process.__init__.__module__.__len__,              [],                         23,   "multiprocessing.Process.__init__.__module__.__len__() == 23; verified with Python 3.14.3"]
    - [argc,         multiprocessing.Process.__init__.__code__.co_argcount.__eq__,    [6],                        true, "multiprocessing.Process.__init__.__code__.co_argcount == 6 (self, group, target, name, args, kwargs); verified with Python 3.14.3"]
    - [varnames_len, multiprocessing.Process.__init__.__code__.co_varnames.__len__,    [],                        8,    "multiprocessing.Process.__init__.__code__.co_varnames.__len__() == 8 (adds daemon, count); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Process.start and run qualnames — extra135
#
# multiprocessing.Process.start.__qualname__ == 'BaseProcess.start' (len=17)
# multiprocessing.Process.run.__qualname__   == 'BaseProcess.run'   (len=15)
# ---------------------------------------------------------------------------

table multiprocessing_extra135.process_start_run_qualnames:
  description: "multiprocessing.Process.start and run qualname checks — start.__qualname__.__eq__('BaseProcess.start')==True (len=17: 'BaseProcess'=11+'.'=1+'start'=5=17); run.__qualname__.__eq__('BaseProcess.run')==True (len=15: 'BaseProcess'=11+'.'=1+'run'=3=15); both methods are defined on BaseProcess not Process; start co_argcount==1 (self only); run co_argcount==1 (self only); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpstartrun135

  columns: [id, function, args, expected, description]
  rows:
    - [start_qn_eq,   multiprocessing.Process.start.__qualname__.__eq__,  ["BaseProcess.start"], true, "multiprocessing.Process.start.__qualname__ == 'BaseProcess.start' (len=17); verified with Python 3.14.3"]
    - [start_qn_len,  multiprocessing.Process.start.__qualname__.__len__,  [],                   17,   "multiprocessing.Process.start.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [start_argc,    multiprocessing.Process.start.__code__.co_argcount.__eq__,  [1],            true, "multiprocessing.Process.start.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]
    - [run_qn_eq,     multiprocessing.Process.run.__qualname__.__eq__,    ["BaseProcess.run"],   true, "multiprocessing.Process.run.__qualname__ == 'BaseProcess.run' (len=15); verified with Python 3.14.3"]
    - [run_qn_len,    multiprocessing.Process.run.__qualname__.__len__,    [],                   15,   "multiprocessing.Process.run.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [run_argc,      multiprocessing.Process.run.__code__.co_argcount.__eq__,    [1],            true, "multiprocessing.Process.run.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]

