# multiprocessing.Process.__bases__[0].__module__ == 'multiprocessing.process' (len=23)
# multiprocessing.Process.__module__              == 'multiprocessing.context' (len=23)
# ---------------------------------------------------------------------------

table multiprocessing_extra135.process_base_identity:
  description: "multiprocessing.Process base class identity checks — __bases__[0].__name__.__eq__('BaseProcess')==True (len=11); __bases__[0].__module__.__eq__('multiprocessing.process')==True (len=23); Process.__module__.__eq__('multiprocessing.context')==True (len=23) — Process is re-exported via context module; both module strings have the same length (23); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbase135

  columns: [id, function, args, expected, description]
  rows:
    - [base0_name_eq,  "multiprocessing.Process.__bases__[0].__name__.__eq__",   ["BaseProcess"],             true, "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess' (len=11); verified with Python 3.14.3"]
    - [base0_name_len, "multiprocessing.Process.__bases__[0].__name__.__len__",   [],                         11,   "multiprocessing.Process.__bases__[0].__name__.__len__() == 11; verified with Python 3.14.3"]
    - [base0_mod_eq,   "multiprocessing.Process.__bases__[0].__module__.__eq__", ["multiprocessing.process"], true, "multiprocessing.Process.__bases__[0].__module__ == 'multiprocessing.process' (len=23); verified with Python 3.14.3"]
    - [mod_eq,         multiprocessing.Process.__module__.__eq__,               ["multiprocessing.context"],  true, "multiprocessing.Process.__module__ == 'multiprocessing.context' (len=23); verified with Python 3.14.3"]
    - [mod_len,        multiprocessing.Process.__module__.__len__,               [],                          23,   "multiprocessing.Process.__module__.__len__() == 23; verified with Python 3.14.3"]

