spec: socket_extra1516
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra15.zspec.zsdl — covers IPPROTO_ICMP/IPV6/RAW values and class names; SO_RCVBUF/SO_SNDBUF values; AddressFamily/SocketKind __mro__[1].__name__."
    - "socket_extra14.zspec.zsdl — covers IPPROTO_TCP/UDP/IP values; SO_KEEPALIVE/SO_BROADCAST values; gaierror.__mro__ entries."
    - "socket_extra12.zspec.zsdl — covers AddressFamily/__qualname__; SocketKind/__qualname__; AF_INET6/__class__.__name__; SOCK_RAW/__class__.__name__."
    - "socket_extra9.zspec.zsdl — covers AF_INET.name; AF_INET6.name; SOCK_STREAM.name; SOCK_DGRAM.name; SOCK_RAW.name."
    - "socket_extra6.zspec.zsdl — covers SOCK_STREAM.value; SOCK_DGRAM.value; AF_INET.value; AF_UNIX.value; IPPROTO_TCP.value."
    - "socket_extra5.zspec.zsdl — covers herror.__module__ and herror.__qualname__."
    - "socket_extra4.zspec.zsdl — covers AddressFamily/__bases__[0].__name__; SocketKind/__bases__[0].__name__."
    - "socket_extra3.zspec.zsdl — covers AddressFamily/__name__; SocketKind/__name__."
    - "socket_extra2.zspec.zsdl — covers AF_INET/__class__.__name__; SOCK_STREAM/__class__.__name__."
  notes:
    - "This spec is wave 548 / suffix _extra1516. Theme: arithmetic/numeric operator dict-presence checks."
    - "socket.socket is a Python wrapper class for OS-level sockets. It is not numeric and has no arithmetic operators."
    - "socket.error is OSError (they are the same object: socket.error is OSError == True). OSError is an exception, not numeric."
    - "socket.timeout is TimeoutError (a subclass of OSError). Also not numeric."
    - "Verified: socket.socket.__dict__.__contains__('__add__') == False (through '__pow__') == False."
    - "Verified True for socket.socket: __init__, __enter__, __exit__, __repr__, close, accept, makefile, sendfile, dup, detach, family, type."
    - "Verified: socket.error.__dict__.__contains__('__add__') == False (through '__pow__') == False."
    - "Verified True for socket.error: __new__, __str__, __init__, __reduce__, errno, strerror, filename, filename2."
    - "socket.timeout.__dict__ contains only '__doc__' — it adds no methods; all behaviour inherited from TimeoutError / OSError."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket — arithmetic operator absence checks
#
# socket.socket is a Python-level class (Lib/socket.py) wrapping OS sockets.
# It provides I/O and context-manager protocol, but no arithmetic operators.
# All seven standard arithmetic dunders are absent from its __dict__.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table socket_extra1516.socket_arith_absent:
  description: "Arithmetic operator dunders absent from socket.socket.__dict__ — socket is not numeric"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk1516aa

  columns: [id, function, args, expected]
  rows:
    - ["sk1516aa001", "socket.__dict__.__contains__", ["__add__"],      false]
    - ["sk1516aa002", "socket.__dict__.__contains__", ["__mul__"],      false]
    - ["sk1516aa003", "socket.__dict__.__contains__", ["__sub__"],      false]
    - ["sk1516aa004", "socket.__dict__.__contains__", ["__truediv__"],  false]
    - ["sk1516aa005", "socket.__dict__.__contains__", ["__floordiv__"], false]
    - ["sk1516aa006", "socket.__dict__.__contains__", ["__mod__"],      false]
    - ["sk1516aa007", "socket.__dict__.__contains__", ["__pow__"],      false]

# ---------------------------------------------------------------------------
# socket.socket — method and protocol presence checks
#
# socket.socket implements the context-manager protocol (__enter__, __exit__)
# and defines methods for I/O (accept, close, makefile, sendfile, dup,
# detach) and attribute descriptors (family, type). These True entries
# confirm the dict-presence mechanism and contrast with the absent
# arithmetic operators.
# ---------------------------------------------------------------------------

table socket_extra1516.socket_methods_present:
  description: "I/O methods and protocol dunders present in socket.socket.__dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk1516mp

  columns: [id, function, args, expected]
  rows:
    - ["sk1516mp001", "socket.__dict__.__contains__", ["__init__"],   true]
    - ["sk1516mp002", "socket.__dict__.__contains__", ["__enter__"],  true]
    - ["sk1516mp003", "socket.__dict__.__contains__", ["__exit__"],   true]
    - ["sk1516mp004", "socket.__dict__.__contains__", ["__repr__"],   true]
    - ["sk1516mp005", "socket.__dict__.__contains__", ["close"],      true]
    - ["sk1516mp006", "socket.__dict__.__contains__", ["accept"],     true]
    - ["sk1516mp007", "socket.__dict__.__contains__", ["makefile"],   true]
    - ["sk1516mp008", "socket.__dict__.__contains__", ["sendfile"],   true]
    - ["sk1516mp009", "socket.__dict__.__contains__", ["dup"],        true]
    - ["sk1516mp010", "socket.__dict__.__contains__", ["detach"],     true]
    - ["sk1516mp011", "socket.__dict__.__contains__", ["family"],     true]
    - ["sk1516mp012", "socket.__dict__.__contains__", ["type"],       true]

# ---------------------------------------------------------------------------
# socket.error (OSError) — arithmetic operator absence checks
#
# socket.error is OSError (identical object). OSError is an exception class
# wrapping errno/strerror pairs. It is not numeric; no arithmetic operators
# appear in its own __dict__. Verified Python 3.12 macOS/Darwin 25.4.0.
# The True entries (errno, strerror, filename, __new__, __str__, __init__,
# __reduce__) confirm lookup correctness.
# ---------------------------------------------------------------------------

table socket_extra1516.error_arith_absent:
  description: "Arithmetic operator dunders absent from socket.error (OSError).__dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk1516ea

  columns: [id, function, args, expected]
  rows:
    - ["sk1516ea001", "error.__dict__.__contains__", ["__add__"],      false]
    - ["sk1516ea002", "error.__dict__.__contains__", ["__mul__"],      false]
    - ["sk1516ea003", "error.__dict__.__contains__", ["__sub__"],      false]
    - ["sk1516ea004", "error.__dict__.__contains__", ["__truediv__"],  false]
    - ["sk1516ea005", "error.__dict__.__contains__", ["__floordiv__"], false]
    - ["sk1516ea006", "error.__dict__.__contains__", ["__mod__"],      false]
    - ["sk1516ea007", "error.__dict__.__contains__", ["__pow__"],      false]
    - ["sk1516ea008", "error.__dict__.__contains__", ["errno"],        true]
    - ["sk1516ea009", "error.__dict__.__contains__", ["strerror"],     true]
    - ["sk1516ea010", "error.__dict__.__contains__", ["filename"],     true]
    - ["sk1516ea011", "error.__dict__.__contains__", ["__new__"],      true]
    - ["sk1516ea012", "error.__dict__.__contains__", ["__str__"],      true]
