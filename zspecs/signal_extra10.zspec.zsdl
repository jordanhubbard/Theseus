spec: signal_extra10
version: ">=3.9"
backend: python_module(signal)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/signal.html — Python signal module documentation"
    - "POSIX.1-2017 — The Open Group Base Specifications Issue 7, 2018 Edition"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
  notes:
    - "Extends signal.zspec.zsdl through signal_extra9.zspec.zsdl."
    - "signal_extra4 covers: function __qualname__ __eq__ checks for signal/getsignal/raise_signal/strsignal/valid_signals; Signals/Handlers __qualname__/__module__."
    - "signal_extra covers: SIG_DFL/SIG_IGN class names ('Handlers'); SIGABRT/SIGFPE/SIGILL/SIGINT/SIGSEGV/SIGTERM class names ('Signals')."
    - "signal_extra2 covers: Signals/Handlers __name__; Signals/Handlers __bases__[0].__name__."
    - "This spec adds: __qualname__ string length checks for signal/getsignal/raise_signal/strsignal/valid_signals (no prior spec checks lengths); Signals and Handlers __mro__ length (6); Signals/Handlers __mro__ member names by index."
    - "signal.__qualname__ == 'signal' has length 6; getsignal has 9; raise_signal has 12; strsignal has 9; valid_signals has 13."
    - "Signals and Handlers are both IntEnum subclasses. Their MRO is: [self, IntEnum, int, ReprEnum, Enum, object] — length 6."
    - "Signals.__mro__[1].__name__ == 'IntEnum' — both enums inherit from IntEnum."
    - "Signals.__mro__[2].__name__ == 'int' — IntEnum itself inherits from int."
    - "Signals.__mro__[4].__name__ == 'Enum' — Enum is the abstract enum base."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ string lengths
#
# signal_extra4 covers __qualname__.__eq__ for signal/getsignal/raise_signal/
# strsignal/valid_signals. No prior spec checks the *length* of these strings.
# signal='signal'(6); getsignal='getsignal'(9); raise_signal='raise_signal'(12);
# strsignal='strsignal'(9); valid_signals='valid_signals'(13).
# ---------------------------------------------------------------------------

table signal_extra10.function_qualname_lengths:
  description: "signal callable __qualname__ string lengths — no prior spec checks these lengths"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qnamelen

  columns: [id, function, args, expected]
  rows:
    - [signal,        signal.__qualname__.__len__,        [], 6]
    - [getsignal,     getsignal.__qualname__.__len__,     [], 9]
    - [raise_signal,  raise_signal.__qualname__.__len__,  [], 12]
    - [strsignal,     strsignal.__qualname__.__len__,     [], 9]
    - [valid_signals, valid_signals.__qualname__.__len__, [], 13]

# ---------------------------------------------------------------------------
# Signals and Handlers enum MRO length
#
# No prior signal spec checks __mro__ length for Signals or Handlers.
# Both are IntEnum subclasses: [Signals/Handlers, IntEnum, int, ReprEnum, Enum, object]
# — length 6.
# ---------------------------------------------------------------------------

invariant signal_extra10.Signals.mro_len:
  description: "signal.Signals.__mro__ has 6 entries — [Signals, IntEnum, int, ReprEnum, Enum, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: Signals.__mro__.__len__
  args: []
  expected: 6

invariant signal_extra10.Handlers.mro_len:
  description: "signal.Handlers.__mro__ has 6 entries — [Handlers, IntEnum, int, ReprEnum, Enum, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: Handlers.__mro__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Signals and Handlers MRO member names by index
#
# No prior signal spec checks individual MRO entries by index for Signals or
# Handlers. IntEnum sits at index 1; int at index 2; Enum at index 4.
# ---------------------------------------------------------------------------

invariant signal_extra10.Signals.mro1_IntEnum:
  description: "signal.Signals.__mro__[1].__name__ == 'IntEnum' — Signals inherits from IntEnum"
  category: class_hierarchy
  kind: python_call_eq
  function: Signals.__mro__.__getitem__
  args: [1]
  method: __name__.__eq__
  method_args: ["IntEnum"]
  expected: true

invariant signal_extra10.Signals.mro2_int:
  description: "signal.Signals.__mro__[2].__name__ == 'int' — IntEnum itself inherits from int"
  category: class_hierarchy
  kind: python_call_eq
  function: Signals.__mro__.__getitem__
  args: [2]
  method: __name__.__eq__
  method_args: ["int"]
  expected: true

invariant signal_extra10.Signals.mro4_Enum:
  description: "signal.Signals.__mro__[4].__name__ == 'Enum' — abstract enum base is at index 4"
  category: class_hierarchy
  kind: python_call_eq
  function: Signals.__mro__.__getitem__
  args: [4]
  method: __name__.__eq__
  method_args: ["Enum"]
  expected: true

invariant signal_extra10.Handlers.mro1_IntEnum:
  description: "signal.Handlers.__mro__[1].__name__ == 'IntEnum' — Handlers inherits from IntEnum"
  category: class_hierarchy
  kind: python_call_eq
  function: Handlers.__mro__.__getitem__
  args: [1]
  method: __name__.__eq__
  method_args: ["IntEnum"]
  expected: true

invariant signal_extra10.Handlers.mro2_int:
  description: "signal.Handlers.__mro__[2].__name__ == 'int' — IntEnum itself inherits from int"
  category: class_hierarchy
  kind: python_call_eq
  function: Handlers.__mro__.__getitem__
  args: [2]
  method: __name__.__eq__
  method_args: ["int"]
  expected: true

invariant signal_extra10.Handlers.mro4_Enum:
  description: "signal.Handlers.__mro__[4].__name__ == 'Enum' — abstract enum base is at index 4"
  category: class_hierarchy
  kind: python_call_eq
  function: Handlers.__mro__.__getitem__
  args: [4]
  method: __name__.__eq__
  method_args: ["Enum"]
  expected: true
