spec: threading_extra1231
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading.__dict__.__contains__ for 'Thread', 'Lock', 'RLock', 'Condition', 'Event', 'Semaphore', 'BoundedSemaphore', 'Barrier', 'Timer', 'local', 'current_thread', 'main_thread', 'active_count', 'enumerate', 'settrace', 'setprofile', and absent keys — not covered in _extra1201/_extra1216"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1231.dict_contains_synchronization_classes:
  description: "threading.__dict__.__contains__ for synchronization primitive classes"
  kind: python_call_eq
  category: dict_contains_synchronization_classes
  id_prefix: th1231dc
  columns: [id, function, args, expected]
  rows:
    - [th1231dc001, threading.__dict__.__contains__, ["Thread"],            true]
    - [th1231dc002, threading.__dict__.__contains__, ["Lock"],              true]
    - [th1231dc003, threading.__dict__.__contains__, ["RLock"],             true]
    - [th1231dc004, threading.__dict__.__contains__, ["Condition"],         true]
    - [th1231dc005, threading.__dict__.__contains__, ["Event"],             true]
    - [th1231dc006, threading.__dict__.__contains__, ["Semaphore"],         true]
    - [th1231dc007, threading.__dict__.__contains__, ["BoundedSemaphore"],  true]
    - [th1231dc008, threading.__dict__.__contains__, ["Barrier"],           true]

table threading_extra1231.dict_contains_timer_and_thread_functions:
  description: "threading.__dict__.__contains__ for Timer, local, and thread utility functions"
  kind: python_call_eq
  category: dict_contains_timer_and_thread_functions
  id_prefix: th1231tf
  columns: [id, function, args, expected]
  rows:
    - [th1231tf001, threading.__dict__.__contains__, ["Timer"],            true]
    - [th1231tf002, threading.__dict__.__contains__, ["local"],            true]
    - [th1231tf003, threading.__dict__.__contains__, ["current_thread"],   true]
    - [th1231tf004, threading.__dict__.__contains__, ["main_thread"],      true]
    - [th1231tf005, threading.__dict__.__contains__, ["active_count"],     true]
    - [th1231tf006, threading.__dict__.__contains__, ["enumerate"],        true]
    - [th1231tf007, threading.__dict__.__contains__, ["settrace"],         true]
    - [th1231tf008, threading.__dict__.__contains__, ["setprofile"],       true]

table threading_extra1231.dict_contains_stack_size_and_absent:
  description: "threading.__dict__.__contains__ for stack_size, excepthook, and absent keys"
  kind: python_call_eq
  category: dict_contains_stack_size_and_absent
  id_prefix: th1231sa
  columns: [id, function, args, expected]
  rows:
    - [th1231sa001, threading.__dict__.__contains__, ["stack_size"],        true]
    - [th1231sa002, threading.__dict__.__contains__, ["excepthook"],        true]
    - [th1231sa003, threading.__dict__.__contains__, ["get_ident"],         true]
    - [th1231sa004, threading.__dict__.__contains__, ["get_native_id"],     true]
    - [th1231sa005, threading.__dict__.__contains__, ["nonexistent_cls"],   false]
    - [th1231sa006, threading.__dict__.__contains__, ["Process"],           false]
    - [th1231sa007, threading.__dict__.__contains__, ["Queue"],             false]
    - [th1231sa008, threading.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
