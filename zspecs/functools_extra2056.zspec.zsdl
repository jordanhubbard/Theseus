spec: functools_extra2056
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 584 (_extra2056): __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__ dict-presence checks."
    - "functools classes do not define sequence/mapping or attribute access protocol methods."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

table functools_extra2056.getitem_protocol:
  description: "functools types __getitem__/__setitem__/__delitem__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2056
  columns: [id, function, args, expected]
  rows:
    - ["ft2056001", "functools.partial.__dict__.__contains__",         ["__getitem__"], false]
    - ["ft2056002", "functools.partialmethod.__dict__.__contains__",   ["__getitem__"], false]
    - ["ft2056003", "functools.cached_property.__dict__.__contains__", ["__getitem__"], false]
    - ["ft2056004", "functools.partial.__dict__.__contains__",         ["__setitem__"], false]
    - ["ft2056005", "functools.partialmethod.__dict__.__contains__",   ["__setitem__"], false]
    - ["ft2056006", "functools.cached_property.__dict__.__contains__", ["__setitem__"], false]
    - ["ft2056007", "functools.partial.__dict__.__contains__",         ["__delitem__"], false]
    - ["ft2056008", "functools.partialmethod.__dict__.__contains__",   ["__delitem__"], false]
    - ["ft2056009", "functools.cached_property.__dict__.__contains__", ["__delitem__"], false]

