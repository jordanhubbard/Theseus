spec: re_extra287
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Regular expression flag constants"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py, Modules/_sre.c"
  notes:
    - "re flag constants are re.RegexFlag IntFlag enum members since Python 3.6"
    - "re.IGNORECASE==2, re.MULTILINE==8, re.DOTALL==16, re.VERBOSE==64, re.ASCII==256, re.UNICODE==32, re.LOCALE==4, re.NOFLAG==0"
    - "Short aliases re.I, re.M, re.S, re.X are identical objects to their long-form equivalents"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table re_extra287.flag_values:
  description: "Integer values of re module flag constants"
  kind: python_call_eq
  category: identity
  id_prefix: re287v

  columns: [id, function, args, expected, description]
  rows:
    - [re287v001, re.IGNORECASE.__eq__, [2], true, "IGNORECASE == 2"]
    - [re287v002, re.MULTILINE.__eq__, [8], true, "MULTILINE == 8"]
    - [re287v003, re.DOTALL.__eq__, [16], true, "DOTALL == 16"]
    - [re287v004, re.VERBOSE.__eq__, [64], true, "VERBOSE == 64"]
    - [re287v005, re.ASCII.__eq__, [256], true, "ASCII == 256"]
    - [re287v006, re.UNICODE.__eq__, [32], true, "UNICODE == 32"]
    - [re287v007, re.LOCALE.__eq__, [4], true, "LOCALE == 4"]
    - [re287v008, re.NOFLAG.__eq__, [0], true, "NOFLAG == 0"]

table re_extra287.flag_class_names:
  description: "All flag constants have class name RegexFlag"
  kind: python_call_eq
  category: identity
  id_prefix: re287c

  columns: [id, function, args, expected, description]
  rows:
    - [re287c001, re.IGNORECASE.__class__.__name__.__eq__, ["RegexFlag"], true, "IGNORECASE class is RegexFlag"]
    - [re287c002, re.MULTILINE.__class__.__name__.__eq__, ["RegexFlag"], true, "MULTILINE class is RegexFlag"]
    - [re287c003, re.DOTALL.__class__.__name__.__eq__, ["RegexFlag"], true, "DOTALL class is RegexFlag"]
    - [re287c004, re.VERBOSE.__class__.__name__.__eq__, ["RegexFlag"], true, "VERBOSE class is RegexFlag"]
    - [re287c005, re.ASCII.__class__.__name__.__eq__, ["RegexFlag"], true, "ASCII class is RegexFlag"]
    - [re287c006, re.UNICODE.__class__.__name__.__eq__, ["RegexFlag"], true, "UNICODE class is RegexFlag"]
    - [re287c007, re.LOCALE.__class__.__name__.__eq__, ["RegexFlag"], true, "LOCALE class is RegexFlag"]
    - [re287c008, re.NOFLAG.__class__.__name__.__eq__, ["RegexFlag"], true, "NOFLAG class is RegexFlag"]

invariant re_extra287.alias_I:
  description: "re.I (alias for IGNORECASE) equals 2"
  category: identity
  kind: python_call_eq
  function: re.I.__eq__
  args: [2]
  expected: true

invariant re_extra287.alias_M:
  description: "re.M (alias for MULTILINE) equals 8"
  category: identity
  kind: python_call_eq
  function: re.M.__eq__
  args: [8]
  expected: true

invariant re_extra287.alias_S:
  description: "re.S (alias for DOTALL) equals 16"
  category: identity
  kind: python_call_eq
  function: re.S.__eq__
  args: [16]
  expected: true

invariant re_extra287.alias_X:
  description: "re.X (alias for VERBOSE) equals 64"
  category: identity
  kind: python_call_eq
  function: re.X.__eq__
  args: [64]
  expected: true
