spec: concurrent_futures_extra2701
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 627 (_extra2701): __lshift__, __rshift__, __invert__ dict-presence checks."
    - "concurrent.futures types (Future, ThreadPoolExecutor, ProcessPoolExecutor) are concurrency primitives, not bitwise types."
    - "None of these types define left-shift, right-shift, or bitwise NOT protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __lshift__ dict-presence checks
#
# Wave 627 theme: concurrent.futures executor and future types do not
# implement the left-shift operator. Neither __lshift__ nor its reflected
# variant __rlshift__ appear in any of these classes' own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2701.lshift_protocol:
  description: "concurrent.futures types __lshift__/__rlshift__ dict-presence checks — none define left-shift in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2701

  columns: [id, function, args, expected]
  rows:
    - ["cf2701001", "concurrent.futures.Future.__dict__.__contains__",              ["__lshift__"],  false]
    - ["cf2701002", "concurrent.futures.Future.__dict__.__contains__",              ["__rlshift__"], false]
    - ["cf2701003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__lshift__"],  false]
    - ["cf2701004", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__rlshift__"], false]
    - ["cf2701005", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__lshift__"],  false]
    - ["cf2701006", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__rlshift__"], false]

# ---------------------------------------------------------------------------
# Table 2: __rshift__ dict-presence checks
#
# Wave 627 theme: concurrent.futures types do not implement the right-shift
# operator. Neither __rshift__ nor its reflected variant __rrshift__ appear
# in any of these classes' own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2701.rshift_protocol:
  description: "concurrent.futures types __rshift__/__rrshift__ dict-presence checks — none define right-shift in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2701

  columns: [id, function, args, expected]
  rows:
    - ["cf2701007", "concurrent.futures.Future.__dict__.__contains__",              ["__rshift__"],  false]
    - ["cf2701008", "concurrent.futures.Future.__dict__.__contains__",              ["__rrshift__"], false]
    - ["cf2701009", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__rshift__"],  false]
    - ["cf2701010", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__rrshift__"], false]
    - ["cf2701011", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__rshift__"],  false]
    - ["cf2701012", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__rrshift__"], false]

# ---------------------------------------------------------------------------
# Table 3: __invert__ dict-presence checks
#
# Wave 627 theme: concurrent.futures types do not implement the bitwise NOT
# (unary ~) operator. __invert__ does not appear in any of these classes'
# own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2701.invert_protocol:
  description: "concurrent.futures types __invert__ dict-presence checks — none define bitwise NOT in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2701

  columns: [id, function, args, expected]
  rows:
    - ["cf2701013", "concurrent.futures.Future.__dict__.__contains__",              ["__invert__"], false]
    - ["cf2701014", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__invert__"], false]
    - ["cf2701015", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__invert__"], false]

# ---------------------------------------------------------------------------
# Table 4: Executor base class __lshift__/__rshift__/__invert__ checks
#
# Wave 627 theme: concurrent.futures.Executor is the abstract base class for
# ThreadPoolExecutor and ProcessPoolExecutor. It also does not define any
# bitwise operator protocol in its own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2701.executor_base_bitwise:
  description: "concurrent.futures.Executor __lshift__/__rshift__/__invert__ dict-presence checks — abstract base class also defines none"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2701

  columns: [id, function, args, expected]
  rows:
    - ["cf2701016", "concurrent.futures.Executor.__dict__.__contains__", ["__lshift__"],  false]
    - ["cf2701017", "concurrent.futures.Executor.__dict__.__contains__", ["__rlshift__"], false]
    - ["cf2701018", "concurrent.futures.Executor.__dict__.__contains__", ["__rshift__"],  false]
    - ["cf2701019", "concurrent.futures.Executor.__dict__.__contains__", ["__rrshift__"], false]
    - ["cf2701020", "concurrent.futures.Executor.__dict__.__contains__", ["__invert__"],  false]
