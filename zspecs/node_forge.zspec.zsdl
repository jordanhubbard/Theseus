spec: node_forge
version: ">=1.0.0"
backend: node(node-forge)

docs: https://github.com/digitalbazaar/forge#readme

provenance:
  derived_from:
    - "node-forge README — https://github.com/digitalbazaar/forge#readme"
    - "FIPS 180-4 (SHA family) and RFC 1321 (MD5)"
    - "Test vectors verified with node-forge via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "node-forge source"
  notes:
    - "Pure-JS TLS / X.509 / cryptography toolkit — installed by countless packages."
    - "Install: npm install node-forge"
    - "v1 CJS; module exposes md / hmac / cipher / pki / pkcs5 / util namespaces."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; throw on malformed inputs only."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# Message digests — known vectors against FIPS-180-4 / RFC-1321
invariant node_forge.sha256_hello_world:
  description: "sha256('hello world') hex matches FIPS test vector"
  category: digest
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "md.sha256"}
    - {method: create, args: []}
    - {method: update, args: ["hello world"]}
    - {method: digest, args: []}
    - {method: toHex, args: []}
  expected: "b94d27b9934d3e08a52e52d7da7dabfac484efe37a5380ee9088f7ace2efcde9"

invariant node_forge.md5_a:
  description: "md5('a') hex matches RFC-1321 test vector"
  category: digest
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "md.md5"}
    - {method: create, args: []}
    - {method: update, args: ["a"]}
    - {method: digest, args: []}
    - {method: toHex, args: []}
  expected: "0cc175b9c0f1b6a831c399e269772661"

invariant node_forge.sha1_hello:
  description: "sha1('hello') hex matches FIPS-180-4 test vector"
  category: digest
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "md.sha1"}
    - {method: create, args: []}
    - {method: update, args: ["hello"]}
    - {method: digest, args: []}
    - {method: toHex, args: []}
  expected: "aaf4c61ddcc5e8a2dabede0f3b482cd9aea9434d"

# Util — base64 / hex round-trip
invariant node_forge.util_encode64:
  description: "util.encode64('hello') is 'aGVsbG8='"
  category: util
  kind: node_chain_eq
  entry: named
  function: "util.encode64"
  entry_args: ["hello"]
  chain: []
  expected: "aGVsbG8="

invariant node_forge.util_decode64:
  description: "util.decode64('SGVsbG8=') is 'Hello'"
  category: util
  kind: node_chain_eq
  entry: named
  function: "util.decode64"
  entry_args: ["SGVsbG8="]
  chain: []
  expected: "Hello"

invariant node_forge.util_bytesToHex:
  description: "util.bytesToHex('h') is '68'"
  category: util
  kind: node_chain_eq
  entry: named
  function: "util.bytesToHex"
  entry_args: ["h"]
  chain: []
  expected: "68"

invariant node_forge.util_hexToBytes:
  description: "util.hexToBytes('68') is 'h'"
  category: util
  kind: node_chain_eq
  entry: named
  function: "util.hexToBytes"
  entry_args: ["68"]
  chain: []
  expected: "h"
