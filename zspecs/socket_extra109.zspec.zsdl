spec: socket_extra109
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra108.zspec.zsdl — covers gethostname/gethostbyname/getnameinfo C-level identity / getaddrinfo/getfqdn Python-level identity / setdefaulttimeout/getdefaulttimeout C-level / create_connection Python-level / getfqdn code attributes (table + invariants)."
    - "socket_extra107.zspec.zsdl — covers socket SO_* option constants class names and integer values / socket.error and socket.timeout class identity and MRO (table + invariants)."
    - "socket_extra106.zspec.zsdl — covers IPPROTO_TCP/UDP/IP/ICMP/IPV6 class names and values / SOL_SOCKET class name and value (table + invariants)."
    - "socket_extra105.zspec.zsdl — covers AF_*/SOCK_* class module/qualname/mro / AddressFamily/SocketKind name/module/metaclass/base identity (table + invariants)."
    - "socket_extra104.zspec.zsdl — covers socket.socket C-method types / socket.socket method qualname lengths / socket.socket Python-level method types and class identity (table + invariants)."
    - "socket_extra103.zspec.zsdl — covers socket.inet_aton/ntoa/pton/ntop class names and qualname lengths / htons/htonl/ntohs/ntohl class names / herror/gaierror MRO depth / AddressFamily/SocketKind MRO depth (table + invariants)."
    - "socket_extra102.zspec.zsdl — covers socket.socket __qualname__/__name__.__len__()==6 / error/__name__.__eq__('OSError') / herror/gaierror qualname/module/bases / AddressFamily/SocketKind qualname lengths and module (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module-level function qualname lengths / SocketIO class metaclass/module/bases (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC and SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ (table + invariants)."
  notes:
    - "This spec extends socket through socket_extra108; it does NOT duplicate invariants present in those files."
    - "Wave 271 theme: socket.socket Python-defined method co_argcount values — close, makefile, accept, detach (all have __code__); socket.socket.__init__ co_argcount; method qualnames for close/makefile/accept/detach/__init__; type names for Python-level socket methods."
    - "type(socket.socket.close).__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__qualname__ == 'socket.close'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.socket.makefile).__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__qualname__ == 'socket.makefile'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__code__.co_argcount == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.socket.accept).__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__qualname__ == 'socket.accept'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.detach.__qualname__ == 'socket.detach'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.detach.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__init__.__qualname__ == 'socket.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__init__.__code__.co_argcount == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.socket.__init__).__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket is a Python class defined in Lib/socket.py wrapping the C-level _socket.socket. Its Python-defined methods (close, makefile, accept, detach, __init__, etc.) have type 'function' and have __code__ attributes. C-level socket methods (send, recv, connect, bind, etc.) are method_descriptor objects with no __code__."
    - "Note: close and accept have co_argcount==1 (only 'self'); makefile has co_argcount==3 (self, mode='r', buffering=None); __init__ has co_argcount==5 (self, family, type, proto, fileno)."
    - "Note: socket_extra104 anchors socket.socket Python-level method types and qualname lengths; this spec anchors the co_argcount values and qualname string equality for the Python-defined methods as new grouped tables under sockcode109."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# type(socket.socket.close).__name__.__eq__('function')
# socket.socket.close.__qualname__.__eq__('socket.close')
# socket.socket.close.__code__.co_argcount.__eq__(1)
# type(socket.socket.accept).__name__.__eq__('function')
# socket.socket.accept.__qualname__.__eq__('socket.accept')
#
# Wave 271 theme: socket.socket.close and accept — Python function type, qualname, co_argcount.
#
# socket.socket.close and socket.socket.accept are Python-defined functions
# (type 'function') from Lib/socket.py. close.__qualname__ is 'socket.close'
# and accept.__qualname__ is 'socket.accept'. Both have co_argcount==1 (only
# 'self' parameter; close takes no other args, accept returns (socket, address)
# by invoking the underlying C accept). socket_extra104 anchors Python-level
# method types and qualname lengths; this spec anchors qualname equality and
# co_argcount for close/accept as a new grouped table under sockcode109.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra109.socket_close_and_accept_type_qualname_argcount:
  description: "type(socket.close).__name__.__eq__('function')==True / socket.close.__qualname__.__eq__('socket.close')==True / socket.close.__code__.co_argcount.__eq__(1)==True / type(socket.accept).__name__.__eq__('function')==True / socket.accept.__qualname__.__eq__('socket.accept')==True — close and accept are Python-defined functions from Lib/socket.py; qualnames follow 'socket.method' pattern; co_argcount==1 (only self); extra104 anchors Python-level method types; this spec anchors qualname equality and co_argcount; first sockcode109 anchor"
  kind: python_call_eq
  category: method_identity
  id_prefix: sockcode109

  columns: [id, function, args, expected, description]
  rows:
    - [close_type_fn,        "socket.close.__class__.__name__.__eq__",         ["function"],      true, "type(socket.close) is 'function' (Python-defined in Lib/socket.py; not a C-level method_descriptor)"]
    - [close_qualname_eq,    "socket.close.__qualname__.__eq__",               ["socket.close"],  true, "socket.close.__qualname__ is 'socket.close' (class 'socket' + method 'close'; Python method in socket class)"]
    - [close_co_argcount,    "socket.close.__code__.co_argcount.__eq__",       [1],               true, "socket.close.__code__.co_argcount is 1 (only 'self'; no other positional args; invokes self._real_close())"]
    - [accept_type_fn,       "socket.accept.__class__.__name__.__eq__",        ["function"],      true, "type(socket.accept) is 'function' (Python-defined in Lib/socket.py; wraps C-level _sock.accept)"]
    - [accept_qualname_eq,   "socket.accept.__qualname__.__eq__",              ["socket.accept"], true, "socket.accept.__qualname__ is 'socket.accept' (class 'socket' + method 'accept'; Python wrapper)"]

# ---------------------------------------------------------------------------
# socket.socket.accept.__code__.co_argcount.__eq__(1)
# type(socket.socket.makefile).__name__.__eq__('function')
# socket.socket.makefile.__qualname__.__eq__('socket.makefile')
# socket.socket.makefile.__code__.co_argcount.__eq__(3)
# socket.socket.detach.__qualname__.__eq__('socket.detach')
#
# Wave 271 theme: accept co_argcount, makefile type/qualname/argcount, detach qualname.
#
# accept.__code__.co_argcount is 1 (only 'self'). makefile is a Python-defined
# function with co_argcount==3: (self, mode='r', buffering=None). makefile
# qualname is 'socket.makefile'. detach is a Python-defined function that
# detaches the underlying file descriptor from the socket object; its qualname
# is 'socket.detach'. No prior socket spec anchors makefile co_argcount or
# detach qualname as a grouped table under sockcode109.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra109.socket_accept_argcount_makefile_detach_identity:
  description: "socket.accept.__code__.co_argcount.__eq__(1)==True / type(socket.makefile).__name__.__eq__('function')==True / socket.makefile.__qualname__.__eq__('socket.makefile')==True / socket.makefile.__code__.co_argcount.__eq__(3)==True / socket.detach.__qualname__.__eq__('socket.detach')==True — accept has co_argcount=1 (self only); makefile is Python function with 3 args (self, mode, buffering); detach qualname is 'socket.detach'; first sockcode109 anchor"
  kind: python_call_eq
  category: method_identity
  id_prefix: sockcode109

  columns: [id, function, args, expected, description]
  rows:
    - [accept_co_argcount,    "socket.accept.__code__.co_argcount.__eq__",     [1],                 true, "socket.accept.__code__.co_argcount is 1 (only 'self'; returns new (socket, address) pair)"]
    - [makefile_type_fn,      "socket.makefile.__class__.__name__.__eq__",     ["function"],        true, "type(socket.makefile) is 'function' (Python-defined in Lib/socket.py; wraps socket in file-like object)"]
    - [makefile_qualname_eq,  "socket.makefile.__qualname__.__eq__",           ["socket.makefile"], true, "socket.makefile.__qualname__ is 'socket.makefile' (class 'socket' + method 'makefile')"]
    - [makefile_co_argcount,  "socket.makefile.__code__.co_argcount.__eq__",   [3],                 true, "socket.makefile.__code__.co_argcount is 3 (self, mode='r', buffering=None; wraps socket in SocketIO)"]
    - [detach_qualname_eq,    "socket.detach.__qualname__.__eq__",             ["socket.detach"],   true, "socket.detach.__qualname__ is 'socket.detach' (class 'socket' + method 'detach'; detaches underlying fd)"]

# ---------------------------------------------------------------------------
# socket.socket.__init__.__qualname__.__eq__('socket.__init__')
# type(socket.socket.__init__).__name__.__eq__('function')
# socket.socket.__init__.__code__.co_argcount.__eq__(5)
# socket.socket.detach.__code__.co_argcount.__eq__(1)
# socket.socket.detach.__code__.co_name.__eq__('detach')
#
# Wave 271 theme: socket.__init__ qualname/type/argcount and detach code attributes.
#
# socket.socket.__init__.__qualname__ is 'socket.__init__'. It is a Python-
# defined function with co_argcount==5: (self, family=AF_INET, type=SOCK_STREAM,
# proto=0, fileno=None). socket.socket.detach.__code__.co_argcount is 1 (only
# 'self'). detach.__code__.co_name is 'detach'. socket_extra104 anchors
# socket.socket __init__ type identity; this spec anchors the __init__ qualname,
# co_argcount, and detach code attributes as a grouped table under sockcode109.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra109.socket_init_qualname_argcount_and_detach_code:
  description: "socket.__init__.__qualname__.__eq__('socket.__init__')==True / type(socket.__init__).__name__.__eq__('function')==True / socket.__init__.__code__.co_argcount.__eq__(5)==True / socket.detach.__code__.co_argcount.__eq__(1)==True / socket.detach.__code__.co_name.__eq__('detach')==True — __init__ has 5 positional args (self, family, type, proto, fileno); detach has co_argcount=1 and co_name='detach'; extra104 anchors __init__ type; first sockcode109 anchor"
  kind: python_call_eq
  category: method_identity
  id_prefix: sockcode109

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname_eq,      "socket.__init__.__qualname__.__eq__",          ["socket.__init__"], true, "socket.__init__.__qualname__ is 'socket.__init__' (class 'socket' + '__init__'; Python-defined constructor)"]
    - [init_type_fn,          "socket.__init__.__class__.__name__.__eq__",    ["function"],        true, "type(socket.__init__) is 'function' (Python-defined __init__ in Lib/socket.py; wraps _socket.socket.__init__)"]
    - [init_co_argcount,      "socket.__init__.__code__.co_argcount.__eq__",  [5],                 true, "socket.__init__.__code__.co_argcount is 5 (self, family=AF_INET, type=SOCK_STREAM, proto=0, fileno=None)"]
    - [detach_co_argcount,    "socket.detach.__code__.co_argcount.__eq__",    [1],                 true, "socket.detach.__code__.co_argcount is 1 (only 'self'; detach returns fd int and resets socket state)"]
    - [detach_co_name,        "socket.detach.__code__.co_name.__eq__",        ["detach"],          true, "socket.detach.__code__.co_name is 'detach' (def statement name; Python function defined in Lib/socket.py)"]

# ---------------------------------------------------------------------------
# socket.socket.close.__qualname__.__eq__('socket.close') — standalone
#
# socket.socket.close.__qualname__ is 'socket.close'. In Lib/socket.py, the
# socket class is named 'socket' (lowercase), and its Python-defined methods
# use the 'socket.methodname' qualname pattern. close() is the Python-level
# wrapper that invokes self._real_close() — which calls the underlying C-level
# socket close, cleaning up the file descriptor. The qualname 'socket.close'
# (12 chars: 'socket.'=7 + 'close'=5) follows the standard 'ClassName.method'
# format. socket_extra104 anchors Python-level method qualname lengths; this
# spec anchors the qualname string equality as a standalone under sockcode109.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra109.socket_close_qualname_eq:
  description: "socket.socket.close.__qualname__.__eq__('socket.close') == True — qualname is 'socket.close' (12 chars = 'socket.'7 + 'close'5); Python-defined in Lib/socket.py (class 'socket', method 'close'); invokes self._real_close() to close the underlying fd; extra104 anchors qualname length; first standalone under sockcode109"
  category: method_identity
  kind: python_call_eq
  function: "socket.close.__qualname__.__eq__"
  args: ["socket.close"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.makefile.__code__.co_argcount.__eq__(3) — standalone
#
# socket.socket.makefile.__code__.co_argcount is 3. makefile(mode='r',
# buffering=None) wraps the socket in a file-like SocketIO object for use
# with Python's io module. The 3 positional args are: self (the socket instance),
# mode (default 'r'), and buffering (default None, which selects line-buffered
# for text mode or block-buffered for binary). This makes makefile the Python-
# defined socket method with the highest co_argcount (3) among close/accept/
# detach (all 1). No prior socket spec anchors makefile co_argcount as a
# standalone under sockcode109. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra109.socket_makefile_co_argcount_3:
  description: "socket.socket.makefile.__code__.co_argcount.__eq__(3) == True — co_argcount is 3 (self, mode='r', buffering=None); makefile wraps socket in SocketIO for io module use; highest co_argcount among Python-defined socket methods (close/accept/detach all have 1); no prior spec anchors makefile co_argcount as standalone; first standalone under sockcode109"
  category: method_identity
  kind: python_call_eq
  function: "socket.makefile.__code__.co_argcount.__eq__"
  args: [3]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__init__.__code__.co_argcount.__eq__(5) — standalone
#
# socket.socket.__init__.__code__.co_argcount is 5. The socket.__init__ signature
# is: __init__(self, family=AF_INET, type=SOCK_STREAM, proto=0, fileno=None).
# The 5 positional args are: self, family, type, proto, fileno. This is the
# most args of any Python-defined socket.socket method. When fileno is provided,
# __init__ wraps an existing OS file descriptor rather than creating a new socket.
# When not provided, it calls the C-level _socket.socket() to allocate a new
# OS socket. No prior socket spec anchors socket.__init__ co_argcount as a
# standalone under sockcode109. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra109.socket_init_co_argcount_5:
  description: "socket.socket.__init__.__code__.co_argcount.__eq__(5) == True — co_argcount is 5 (self, family=AF_INET, type=SOCK_STREAM, proto=0, fileno=None); most args of any Python-defined socket.socket method; fileno param allows wrapping existing OS fd; no prior spec anchors socket.__init__ co_argcount as standalone; first standalone under sockcode109"
  category: method_identity
  kind: python_call_eq
  function: "socket.__init__.__code__.co_argcount.__eq__"
  args: [5]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.accept.__qualname__.__eq__('socket.accept') — standalone
#
# socket.socket.accept.__qualname__ is 'socket.accept'. accept() is the Python-
# level wrapper for accepting incoming connections on a listening socket. It
# returns a (socket, address) pair where the socket is a new socket object
# connected to the peer and address is the peer's address. The Python-level
# accept() wraps the C-level _sock.accept() with dup() or appropriate
# handling. Its qualname 'socket.accept' (13 chars: 'socket.'=7 + 'accept'=6)
# follows the standard 'ClassName.method' format. No prior socket spec anchors
# accept.__qualname__ equality as a standalone under sockcode109.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra109.socket_accept_qualname_eq:
  description: "socket.socket.accept.__qualname__.__eq__('socket.accept') == True — qualname is 'socket.accept' (13 chars = 'socket.'7 + 'accept'6); Python-defined wrapper returning (new_socket, address) pair from listening socket; wraps C-level _sock.accept(); co_argcount==1 (self only); no prior spec anchors accept qualname as standalone; first standalone under sockcode109"
  category: method_identity
  kind: python_call_eq
  function: "socket.accept.__qualname__.__eq__"
  args: ["socket.accept"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__init__.__qualname__.__eq__('socket.__init__') — standalone
#
# socket.socket.__init__.__qualname__ is 'socket.__init__'. The socket class
# (lowercase 'socket' in Lib/socket.py) defines __init__ as a Python-level
# method to initialize the socket. The qualname 'socket.__init__' (15 chars:
# 'socket.'=7 + '__init__'=8) follows the standard 'ClassName.method' format.
# The Python __init__ calls the inherited C-level _socket.socket.__init__ for
# the actual socket creation. socket_extra104 anchors __init__ type as 'function';
# this spec anchors the qualname equality as a standalone under sockcode109.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra109.socket_init_qualname_eq:
  description: "socket.socket.__init__.__qualname__.__eq__('socket.__init__') == True — qualname is 'socket.__init__' (15 chars = 'socket.'7 + '__init__'8); Python-defined constructor that calls C-level _socket.socket.__init__; co_argcount==5 (self, family, type, proto, fileno); extra104 anchors __init__ type as 'function'; first standalone under sockcode109"
  category: method_identity
  kind: python_call_eq
  function: "socket.__init__.__qualname__.__eq__"
  args: ["socket.__init__"]
  expected: true
