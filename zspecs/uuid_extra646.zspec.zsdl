spec: uuid_extra646
version: ">=3.9"
backend: python_module(uuid)
docs: "Behavioral spec for uuid.UUID __doc__, qualname, SafeUUID enum identity, and uuid function qualnames."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid: UUID objects according to RFC 4122"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers UUID __qualname__ and __module__, doc class identity for UUID and SafeUUID, SafeUUID.safe member doc (NoneType), str/repr doc class, and uuid1/3/4/5/getnode qualnames."
  created_at: "2026-04-12T00:00:00Z"

table uuid_extra646.uuid_class_identity:
  description: "Verifies UUID class __qualname__, __module__, and __doc__ class identity."
  kind: python_call_eq
  category: class_identity
  id_prefix: uu646dc
  columns: [id, function, args, expected]
  rows:
    - [uu646dc001, uuid.UUID.__qualname__.__eq__, ["UUID"], true]
    - [uu646dc002, uuid.UUID.__module__.__eq__, ["uuid"], true]
    - [uu646dc003, uuid.UUID.__doc__.__class__.__name__.__eq__, ["str"], true]

table uuid_extra646.safeuuid_identity:
  description: "Verifies SafeUUID enum and member doc class identity."
  kind: python_call_eq
  category: enum_identity
  id_prefix: uu646se
  columns: [id, function, args, expected]
  rows:
    - [uu646se001, uuid.SafeUUID.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu646se002, uuid.SafeUUID.safe.__doc__.__class__.__name__.__eq__, ["NoneType"], true]

table uuid_extra646.uuid_method_doc_identity:
  description: "Verifies __str__ and __repr__ doc class identity on UUID."
  kind: python_call_eq
  category: method_identity
  id_prefix: uu646md
  columns: [id, function, args, expected]
  rows:
    - [uu646md001, uuid.UUID.__str__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu646md002, uuid.UUID.__repr__.__doc__.__class__.__name__.__eq__, ["str"], true]

table uuid_extra646.uuid_function_qualnames:
  description: "Verifies __qualname__ for top-level uuid generator functions and getnode."
  kind: python_call_eq
  category: qualname_identity
  id_prefix: uu646qn
  columns: [id, function, args, expected]
  rows:
    - [uu646qn001, uuid.uuid1.__qualname__.__eq__, ["uuid1"], true]
    - [uu646qn002, uuid.uuid3.__qualname__.__eq__, ["uuid3"], true]
    - [uu646qn003, uuid.uuid4.__qualname__.__eq__, ["uuid4"], true]
    - [uu646qn004, uuid.uuid5.__qualname__.__eq__, ["uuid5"], true]
    - [uu646qn005, uuid.getnode.__qualname__.__eq__, ["getnode"], true]
