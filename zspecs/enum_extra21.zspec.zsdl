spec: enum_extra21
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum.zspec.zsdl through enum_extra20.zspec.zsdl."
    - "enum_extra20 covers: functional Enum/IntEnum API __len__; Enum.__name__ via functional call; auto/__qualname__.__eq__; unique/__qualname__.__eq__; Enum/__qualname__.__eq__; IntEnum/__qualname__.__eq__; Flag/__qualname__.__eq__; EnumMeta/__qualname__.__len__."
    - "enum_extra18 covers: __qualname__.__len__() for Enum/Flag/IntFlag/auto/unique/nonmember/member; EnumType/__qualname__.__eq__/__len__; EnumMeta/__qualname__==EnumType; IntFlag/__qualname__.__eq__; StrEnum/__qualname__.__eq__."
    - "enum_extra17 covers: StrEnum/IntEnum/__qualname__.__len__; StrEnum/__bases__[1]; IntEnum/__bases__[1]; IntEnum/__mro__[2]; Flag/__mro__[1]; EnumMeta/__mro__[1]; StrEnum/__mro__[3]."
    - "enum_extra15 covers: Enum/__module__/__qualname__/__name__.__len__; auto/__module__/__qualname__; EnumMeta/__qualname__."
    - "Focus of this spec: (1) combined __qualname__ table for Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique; (2) EnumMeta.__qualname__ standalone; (3) combined __module__ table for Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique (all 'enum')."
    - "NOT yet covered (entering this spec): combined __qualname__ table for Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique; EnumMeta.__qualname__ value standalone (it is 'EnumType' on Python 3.11+); combined __module__ table for all seven."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ values for Enum, IntEnum, Flag, IntFlag, StrEnum, auto, unique
#
# Prior specs cover individual __qualname__.__eq__ values in various tables
# and standalone invariants. No prior spec has all seven in a single combined
# table. EnumMeta.__qualname__ == 'EnumType' on Python 3.11+ (alias changed).
# Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique all have simple __qualname__
# equal to their own name.
# ---------------------------------------------------------------------------

table enum_extra21.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Enum,    Enum.__qualname__.__eq__,    ["Enum"],    true]
    - [IntEnum, IntEnum.__qualname__.__eq__, ["IntEnum"], true]
    - [Flag,    Flag.__qualname__.__eq__,    ["Flag"],    true]
    - [IntFlag, IntFlag.__qualname__.__eq__, ["IntFlag"], true]
    - [StrEnum, StrEnum.__qualname__.__eq__, ["StrEnum"], true]
    - [auto,    auto.__qualname__.__eq__,    ["auto"],    true]
    - [unique,  unique.__qualname__.__eq__,  ["unique"],  true]

# ---------------------------------------------------------------------------
# __module__ for Enum, IntEnum, Flag, IntFlag, StrEnum, auto, unique
#
# All seven are defined in the enum module; __module__ == 'enum'.
# enum_extra15 covers Enum/__module__ and auto/__module__ as standalone
# invariants. No prior spec has all seven together in a single combined table.
# ---------------------------------------------------------------------------

table enum_extra21.modules:
  kind: python_call_eq
  category: modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Enum,    Enum.__module__.__eq__,    ["enum"], true]
    - [IntEnum, IntEnum.__module__.__eq__, ["enum"], true]
    - [Flag,    Flag.__module__.__eq__,    ["enum"], true]
    - [IntFlag, IntFlag.__module__.__eq__, ["enum"], true]
    - [StrEnum, StrEnum.__module__.__eq__, ["enum"], true]
    - [auto,    auto.__module__.__eq__,    ["enum"], true]
    - [unique,  unique.__module__.__eq__,  ["enum"], true]

# ---------------------------------------------------------------------------
# EnumMeta.__qualname__ standalone
#
# On Python 3.11+ enum.EnumMeta was renamed to enum.EnumType; the canonical
# __qualname__ of EnumMeta is 'EnumType'. enum_extra18 and enum_extra20 cover
# EnumType/__qualname__.__len__ and EnumMeta/__qualname__.__len__ (both 8).
# No prior spec checks EnumMeta.__qualname__.__eq__('EnumType') as a standalone
# boolean invariant.
# ---------------------------------------------------------------------------

invariant enum_extra21.EnumMeta.qualname_eq:
  description: "enum.EnumMeta.__qualname__ == 'EnumType' — EnumMeta is aliased to EnumType on Python 3.11+"
  category: qualnames
  kind: python_call_eq
  function: EnumMeta.__qualname__.__eq__
  args: ["EnumType"]
  expected: true
