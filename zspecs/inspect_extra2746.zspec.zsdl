spec: inspect_extra2746
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 630 theme: __round__, __divmod__, and __pow__ dict-presence checks (numeric arithmetic protocol — used by round(), divmod(), and the ** operator)."
    - "inspect.Parameter is an introspection value object; it does not implement numeric arithmetic protocols."
    - "inspect.BoundArguments wraps a signature binding; it exposes .args and .kwargs but does not define __round__, __divmod__, or __pow__ itself."
    - "inspect.Signature is a callable signature descriptor; it defines __eq__ and __hash__ but not __round__, __divmod__, or __pow__."
    - "inspect.FullArgSpec is a namedtuple subclass; namedtuples inherit tuple methods but do not define __round__, __divmod__, or __pow__ in their own __dict__."
    - "None of these four inspect types define __round__, __divmod__, or __pow__ in their own class __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __round__ dict-presence — absent from all four inspect types
# ---------------------------------------------------------------------------

table inspect_extra2746.round_protocol:
  description: "__round__ is absent from all inspect type __dict__s — none define the round() numeric protocol directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2746

  columns: [id, function, args, expected]
  rows:
    - ["in2746001", "inspect.Parameter.__dict__.__contains__",       ["__round__"], false]
    - ["in2746002", "inspect.BoundArguments.__dict__.__contains__",  ["__round__"], false]
    - ["in2746003", "inspect.Signature.__dict__.__contains__",       ["__round__"], false]
    - ["in2746004", "inspect.FullArgSpec.__dict__.__contains__",     ["__round__"], false]

# ---------------------------------------------------------------------------
# __divmod__ dict-presence — absent from all four inspect types
# ---------------------------------------------------------------------------

table inspect_extra2746.divmod_protocol:
  description: "__divmod__ is absent from all inspect type __dict__s — none define the divmod() numeric protocol directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2746

  columns: [id, function, args, expected]
  rows:
    - ["in2746005", "inspect.Parameter.__dict__.__contains__",       ["__divmod__"], false]
    - ["in2746006", "inspect.BoundArguments.__dict__.__contains__",  ["__divmod__"], false]
    - ["in2746007", "inspect.Signature.__dict__.__contains__",       ["__divmod__"], false]
    - ["in2746008", "inspect.FullArgSpec.__dict__.__contains__",     ["__divmod__"], false]

# ---------------------------------------------------------------------------
# __pow__ dict-presence — absent from all four inspect types
# ---------------------------------------------------------------------------

table inspect_extra2746.pow_protocol:
  description: "__pow__ is absent from all inspect type __dict__s — none define the ** exponentiation protocol directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2746

  columns: [id, function, args, expected]
  rows:
    - ["in2746009",  "inspect.Parameter.__dict__.__contains__",       ["__pow__"], false]
    - ["in2746010",  "inspect.BoundArguments.__dict__.__contains__",  ["__pow__"], false]
    - ["in2746011",  "inspect.Signature.__dict__.__contains__",       ["__pow__"], false]
    - ["in2746012",  "inspect.FullArgSpec.__dict__.__contains__",     ["__pow__"], false]

# ---------------------------------------------------------------------------
# Combined per-type view — all four inspect types vs. all three arithmetic protocols
# ---------------------------------------------------------------------------

table inspect_extra2746.signature_combined:
  description: "inspect.Parameter, inspect.Signature, inspect.BoundArguments, and inspect.FullArgSpec define none of __round__, __divmod__, __pow__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2746

  columns: [id, function, args, expected]
  rows:
    - ["in2746013", "inspect.Parameter.__dict__.__contains__",       ["__round__"],  false]
    - ["in2746014", "inspect.Parameter.__dict__.__contains__",       ["__divmod__"], false]
    - ["in2746015", "inspect.Parameter.__dict__.__contains__",       ["__pow__"],    false]
    - ["in2746016", "inspect.Signature.__dict__.__contains__",       ["__round__"],  false]
    - ["in2746017", "inspect.Signature.__dict__.__contains__",       ["__divmod__"], false]
    - ["in2746018", "inspect.Signature.__dict__.__contains__",       ["__pow__"],    false]
    - ["in2746019", "inspect.BoundArguments.__dict__.__contains__",  ["__round__"],  false]
    - ["in2746020", "inspect.BoundArguments.__dict__.__contains__",  ["__divmod__"], false]
    - ["in2746021", "inspect.BoundArguments.__dict__.__contains__",  ["__pow__"],    false]
    - ["in2746022", "inspect.FullArgSpec.__dict__.__contains__",     ["__round__"],  false]
    - ["in2746023", "inspect.FullArgSpec.__dict__.__contains__",     ["__divmod__"], false]
    - ["in2746024", "inspect.FullArgSpec.__dict__.__contains__",     ["__pow__"],    false]
