spec: pathlib_extra2806
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers existing pathlib invariants"
    - "pathlib_extra2791.zspec.zsdl — covers __iand__/__ior__/__ixor__ dict-presence"
    - "pathlib_extra2776.zspec.zsdl — covers __isub__/__imul__/__itruediv__ dict-presence"
    - "pathlib_extra2761.zspec.zsdl — covers __matmul__/__truediv__/__iadd__ dict-presence"
    - "pathlib_extra2746.zspec.zsdl — covers __round__/__divmod__/__pow__ dict-presence"
    - "pathlib_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
  notes:
    - "Wave 634 (pathlib_extra2806) theme: __ilshift__, __irshift__, and __ipow__ dict-presence checks."
    - "None of the pathlib classes define __ilshift__, __irshift__, or __ipow__ in their own __dict__."
    - "__ilshift__ supports the <<= operator; pathlib path objects do not implement in-place left-shift semantics."
    - "__irshift__ supports the >>= operator; pathlib path objects do not implement in-place right-shift semantics."
    - "__ipow__ supports the **= operator; pathlib path objects do not implement in-place exponentiation semantics."
    - "Covers pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, and pathlib.Path."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __ilshift__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2806.no_ilshift_in_pathlib_classes:
  description: "__ilshift__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the <<= in-place left-shift protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2806

  columns: [id, function, args, expected]
  rows:
    - ["pp2806001", "pathlib.PurePath.__dict__.__contains__",        ["__ilshift__"], false]
    - ["pp2806002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__ilshift__"], false]
    - ["pp2806003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__ilshift__"], false]
    - ["pp2806004", "pathlib.Path.__dict__.__contains__",            ["__ilshift__"], false]

# ---------------------------------------------------------------------------
# __irshift__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2806.no_irshift_in_pathlib_classes:
  description: "__irshift__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the >>= in-place right-shift protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2806

  columns: [id, function, args, expected]
  rows:
    - ["pp2806005", "pathlib.PurePath.__dict__.__contains__",        ["__irshift__"], false]
    - ["pp2806006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__irshift__"], false]
    - ["pp2806007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__irshift__"], false]
    - ["pp2806008", "pathlib.Path.__dict__.__contains__",            ["__irshift__"], false]

# ---------------------------------------------------------------------------
# __ipow__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2806.no_ipow_in_pathlib_classes:
  description: "__ipow__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the **= in-place exponentiation protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2806

  columns: [id, function, args, expected]
  rows:
    - ["pp2806009", "pathlib.PurePath.__dict__.__contains__",        ["__ipow__"], false]
    - ["pp2806010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__ipow__"], false]
    - ["pp2806011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__ipow__"], false]
    - ["pp2806012", "pathlib.Path.__dict__.__contains__",            ["__ipow__"], false]

# ---------------------------------------------------------------------------
# Complementary: PurePath has __truediv__ but not __ilshift__, __irshift__, or __ipow__
# Distinguishes the path-joining / operator from unsupported in-place shift/exponentiation operations
# ---------------------------------------------------------------------------

table pathlib_extra2806.pathlib_truediv_but_not_inplace_shift_pow:
  description: "pathlib.PurePath defines __truediv__/__rtruediv__ for path joining but NOT __ilshift__/__irshift__/__ipow__; pathlib.Path defines stat/exists/open but none of the in-place shift or exponentiation hooks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2806

  columns: [id, function, args, expected]
  rows:
    - ["pp2806013", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"],  true]
    - ["pp2806014", "pathlib.PurePath.__dict__.__contains__", ["__rtruediv__"], true]
    - ["pp2806015", "pathlib.PurePath.__dict__.__contains__", ["__ilshift__"],  false]
    - ["pp2806016", "pathlib.PurePath.__dict__.__contains__", ["__irshift__"],  false]
    - ["pp2806017", "pathlib.PurePath.__dict__.__contains__", ["__ipow__"],     false]
    - ["pp2806018", "pathlib.Path.__dict__.__contains__",     ["stat"],         true]
    - ["pp2806019", "pathlib.Path.__dict__.__contains__",     ["exists"],       true]
    - ["pp2806020", "pathlib.Path.__dict__.__contains__",     ["open"],         true]
    - ["pp2806021", "pathlib.Path.__dict__.__contains__",     ["__ilshift__"],  false]
    - ["pp2806022", "pathlib.Path.__dict__.__contains__",     ["__irshift__"],  false]
    - ["pp2806023", "pathlib.Path.__dict__.__contains__",     ["__ipow__"],     false]
