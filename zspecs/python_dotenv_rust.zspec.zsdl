spec: python_dotenv_rust
version: ">=3.9"
backend: rust_module(python_dotenv_rust)

docs: https://saurabh-kumar.com/python-dotenv/

provenance:
  derived_from:
    - "https://saurabh-kumar.com/python-dotenv/ — python-dotenv documentation"
  not_derived_from:
    - "python-dotenv source: dotenv/__init__.py"
  notes:
    - "python-dotenv reads key-value pairs from .env files."
    - "dotenv.dotenv_values('file') returns an OrderedDict."
    - "dotenv.get_key('.env', 'KEY') returns None if file doesn't exist."
    - "dotenv.main.dotenv_values is available."
    - "from dotenv import dotenv_values, find_dotenv, load_dotenv."
    - "Expose dotenv_has_dotenv_values() -> bool: hasattr(dotenv, 'dotenv_values')."
    - "Expose dotenv_has_load_dotenv() -> bool: hasattr(dotenv, 'load_dotenv')."
    - "Expose dotenv_has_find_dotenv() -> bool: hasattr(dotenv, 'find_dotenv')."
    - "All test vectors verified against python-dotenv 1.0.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# dotenv module attributes
invariant python_dotenv_rust.module.has_dotenv_values:
  description: "dotenv.dotenv_values is available"
  category: module
  kind: python_call_eq
  function: dotenv_has_dotenv_values
  args: []
  expected: true

invariant python_dotenv_rust.module.has_load_dotenv:
  description: "dotenv.load_dotenv is available"
  category: module
  kind: python_call_eq
  function: dotenv_has_load_dotenv
  args: []
  expected: true

invariant python_dotenv_rust.module.has_find_dotenv:
  description: "dotenv.find_dotenv is available"
  category: module
  kind: python_call_eq
  function: dotenv_has_find_dotenv
  args: []
  expected: true

