spec: math_sum
version: ">=3.0.0"
backend: node(math-sum)

docs: https://www.npmjs.com/package/math-sum

provenance:
  derived_from:
    - "math-sum README — https://www.npmjs.com/package/math-sum"
    - "Test vectors verified with math-sum via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "math-sum source"
  notes:
    - "math-sum is an npm package. Install: npm install math-sum"
    - "Returns the sum of an array of numbers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table math_sum.mathSum:
  kind: node_module_call_eq
  function: "default"
  category: math
  id_prefix: msum

  columns: [id, args, expected]
  rows:
    - [four,   [[1, 2, 3, 4]],     10]
    - [three,  [[5, 10, 15]],       30]
    - [one,    [[42]],              42]
    - [empty,  [[]],                0]
