spec: struct_extra50
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra49.zspec.zsdl — covers struct module __dict__/__class__/__name__/__qualname__/__module__.__eq__('mappingproxy'/'builtins')."
    - "struct_extra48.zspec.zsdl — covers Struct/error __dict__/__class__/__name__/__qualname__/__module__.__eq__('mappingproxy'/'builtins')."
    - "struct_extra43.zspec.zsdl — covers Struct/pack/error __class__.__module__.__eq__('builtins') as three representative rows; does NOT cover unpack/calcsize/pack_into/unpack_from/iter_unpack on the __class__.__module__ axis."
    - "struct_extra40.zspec.zsdl — covers Struct.__init__/__repr__ __name__.__eq__ and __name__.__len__()==8."
    - "struct_extra18.zspec.zsdl — covers Struct/__module__.__eq__('_struct') and module-level functions __module__.__eq__('_struct')."
  notes:
    - "This spec extends struct through struct_extra49; it does NOT duplicate invariants present in those files."
    - "Wave 221 theme: __class__.__module__ string equality checks + __init__.__class__ checks for class objects."
    - "Coverage gap 1: struct_extra43 checks Struct/pack/error __class__.__module__.__eq__('builtins') as three representative rows covering the metaclass (type), builtin function, and exception type patterns. It does NOT cover unpack, calcsize, pack_into, unpack_from, or iter_unpack on the __class__.__module__.__eq__('builtins') axis. All five are builtin_function_or_method objects; their __class__.__module__ is 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__class__.__module__ == 'builtins'. unpack is a C builtin function in the _struct extension; the builtin_function_or_method type has __module__ == 'builtins'. struct_extra43 covers pack.__class__.__module__.__eq__('builtins') but NOT unpack. No prior struct spec checks unpack.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__class__.__module__ == 'builtins'. Same C builtin pattern as unpack. No prior struct spec checks calcsize.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__class__.__module__ == 'builtins'. Same C builtin pattern. No prior struct spec checks pack_into.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__class__.__module__ == 'builtins'. Same C builtin pattern. No prior struct spec checks unpack_from.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__class__.__module__ == 'builtins'. Same C builtin pattern. No prior struct spec checks iter_unpack.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior struct spec checks __init__.__class__.__name__ or __init__.__class__.__module__ for struct.Struct or struct.error. struct_extra40 covers Struct.__init__.__name__.__eq__ (the __name__ attribute of the descriptor itself), but NOT __init__.__class__.__name__ (the type of the descriptor). Struct and error are C extension types; their __init__ is a 'wrapper_descriptor' (C slot wrapper for tp_init). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__class__.__name__ == 'wrapper_descriptor'. Struct is a C extension type; its __init__ is exposed as a wrapper_descriptor (CPython's C slot wrapper type). No prior struct spec checks Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__init__.__class__.__name__ == 'wrapper_descriptor'. error is a C extension exception type; its __init__ follows the same C slot wrapper pattern. No prior struct spec checks error.__init__.__class__.__name__.__eq__('wrapper_descriptor'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__class__.__module__ == 'builtins'. wrapper_descriptor is a C builtin type with __module__ == 'builtins'. No prior struct spec checks Struct.__init__.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__init__.__class__.__module__ == 'builtins'. Same wrapper_descriptor pattern as Struct. No prior struct spec checks error.__init__.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.unpack/calcsize/pack_into/unpack_from/iter_unpack __class__.__module__
#
# struct_extra43 checks Struct/pack/error __class__.__module__.__eq__('builtins')
# as three representative rows (one per distinct __class__ kind). It does NOT
# cover unpack, calcsize, pack_into, unpack_from, or iter_unpack. All five are
# builtin_function_or_method objects defined in the _struct C extension; their
# type has __module__ == 'builtins'. Completing coverage to all five functions
# closes the gap on the __class__.__module__.__eq__('builtins') axis.
# ---------------------------------------------------------------------------

table struct_extra50.func_class_module_eq:
  description: "struct.unpack/calcsize/pack_into/unpack_from/iter_unpack __class__.__module__.__eq__('builtins') — C builtin functions whose type has __module__ == 'builtins'; struct_extra43 covers Struct/pack/error __class__.__module__.__eq__('builtins') (3 representative rows) but NOT unpack/calcsize/pack_into/unpack_from/iter_unpack; novel extension of the __class__.__module__ axis for remaining struct functions"
  kind: python_call_eq
  category: type_structure
  id_prefix: structmod50

  columns: [id, function, args, expected]
  rows:
    - [unpack_class_module_eq,      unpack.__class__.__module__.__eq__,      ["builtins"], true]
    - [calcsize_class_module_eq,    calcsize.__class__.__module__.__eq__,    ["builtins"], true]
    - [pack_into_class_module_eq,   pack_into.__class__.__module__.__eq__,   ["builtins"], true]
    - [unpack_from_class_module_eq, unpack_from.__class__.__module__.__eq__, ["builtins"], true]
    - [iter_unpack_class_module_eq, iter_unpack.__class__.__module__.__eq__, ["builtins"], true]

# ---------------------------------------------------------------------------
# struct.Struct and struct.error __init__.__class__.__name__.__eq__
#
# No prior struct spec checks __init__.__class__.__name__ for Struct or error.
# struct_extra40 covers Struct.__init__.__name__.__eq__ (the descriptor's own
# __name__ attribute, which is '__init__'), but NOT Struct.__init__.__class__.__name__
# (the type of the descriptor itself). Struct and error are C extension types;
# their __init__ attribute is a 'wrapper_descriptor' — the CPython internal type
# that wraps a C-level slot function (tp_init) for Python-level access.
# ---------------------------------------------------------------------------

table struct_extra50.init_class_name_eq:
  description: "struct.Struct/__init__/__class__/__name__.__eq__('wrapper_descriptor') and error same — C extension types expose __init__ as a wrapper_descriptor (C slot wrapper); struct_extra40 covers Struct.__init__.__name__.__eq__ (descriptor's own name) but NOT __init__.__class__.__name__ (the descriptor type); no prior struct spec checks __init__.__class__.__name__.__eq__('wrapper_descriptor') for Struct or error"
  kind: python_call_eq
  category: type_structure
  id_prefix: structmod50

  columns: [id, function, args, expected]
  rows:
    - [Struct_init_class_name_eq, Struct.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [error_init_class_name_eq,  error.__init__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# struct.Struct __init__.__class__.__module__.__eq__('builtins')
#
# No prior struct spec checks __init__.__class__.__module__ for Struct or error.
# wrapper_descriptor is a C builtin type whose __module__ is 'builtins'.
# This is independent from the __class__.__name__ check above: __module__
# confirms the home module of the descriptor type; if the type were moved
# out of builtins (hypothetically), __module__ catches it while __name__ would
# not.
# ---------------------------------------------------------------------------

invariant struct_extra50.Struct.init_class_module_eq:
  description: "struct.Struct.__init__.__class__.__module__ == 'builtins' — wrapper_descriptor is a C builtin type with __module__ == 'builtins'; independent from __class__.__name__ axis; no prior struct spec checks Struct.__init__.__class__.__module__.__eq__('builtins')"
  category: type_structure
  kind: python_call_eq
  function: Struct.__init__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant struct_extra50.error.init_class_module_eq:
  description: "struct.error.__init__.__class__.__module__ == 'builtins' — same wrapper_descriptor pattern as Struct; no prior struct spec checks error.__init__.__class__.__module__.__eq__('builtins')"
  category: type_structure
  kind: python_call_eq
  function: error.__init__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true
