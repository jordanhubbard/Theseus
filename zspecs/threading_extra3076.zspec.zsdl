spec: th3076
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 652 (th3076): __get__, __set__, __delete__ dict-presence checks for threading types."
    - "None of the threading types define __get__, __set__, or __delete__ in their own __dict__."
    - "threading synchronization types (Lock, RLock, Condition, Semaphore) implement the synchronous context manager protocol; none define descriptor protocol dunders."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3076.get:
  description: "threading types __get__ dict-presence checks; wave 652"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th3076
  columns: [id, function, args, expected]
  rows:
    - ["th3076001", operator.contains, [threading.Thread.__dict__,            "__get__"], false]
    - ["th3076002", operator.contains, [type(threading.Lock()).__dict__,      "__get__"], false]
    - ["th3076003", operator.contains, [type(threading.RLock()).__dict__,     "__get__"], false]
    - ["th3076004", operator.contains, [threading.Event.__dict__,             "__get__"], false]
    - ["th3076005", operator.contains, [threading.Condition.__dict__,         "__get__"], false]
    - ["th3076006", operator.contains, [threading.Semaphore.__dict__,         "__get__"], false]
    - ["th3076007", operator.contains, [threading.BoundedSemaphore.__dict__,  "__get__"], false]
    - ["th3076008", operator.contains, [threading.Timer.__dict__,             "__get__"], false]
    - ["th3076009", operator.contains, [threading.Barrier.__dict__,           "__get__"], false]
    - ["th3076010", operator.contains, [threading.local.__dict__,             "__get__"], false]

