spec: socket_extra196
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "socket.create_connection.__name__ == 'create_connection' (len=17) — pure-Python convenience function defined in Lib/socket.py."
    - "socket.create_connection.__module__ == 'socket' — belongs to the public socket module."
    - "socket.create_connection.__qualname__ == 'create_connection' — top-level function, qualname equals name."
    - "socket.create_server.__name__ == 'create_server' (len=13) — shorter convenience function also in Lib/socket.py."
    - "socket.create_server.__module__ == 'socket' — belongs to the public socket module."
    - "socket.setdefaulttimeout.__name__ == 'setdefaulttimeout' (len=17) — C-level function from _socket; __module__ == '_socket'."
    - "socket.setdefaulttimeout.__module__ == '_socket' — unlike create_connection/create_server, this is a C extension function."
    - "Name length ordering: create_server(13) < create_connection(17) == setdefaulttimeout(17)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.create_connection identity — name, module, qualname
# Pure-Python function in Lib/socket.py; qualname equals name
# ---------------------------------------------------------------------------

table socketconn196.create_connection_identity:
  kind: python_call_eq
  category: function_identity
  id_prefix: socketconn196

  columns: [id, function, args, expected, description]
  rows:
    - [cc_name,     create_connection.__name__.__eq__,     ["create_connection"], true, "socket.create_connection.__name__ == 'create_connection' (pure-Python convenience function)"]
    - [cc_module,   create_connection.__module__.__eq__,   ["socket"],            true, "socket.create_connection.__module__ == 'socket' (defined in Lib/socket.py)"]
    - [cc_qualname, create_connection.__qualname__.__eq__, ["create_connection"], true, "socket.create_connection.__qualname__ == 'create_connection' (top-level; qualname equals name)"]

# ---------------------------------------------------------------------------
# socket.create_server identity — name, module, qualname
# Pure-Python function in Lib/socket.py; shorter name than create_connection
# ---------------------------------------------------------------------------

table socketconn196.create_server_identity:
  kind: python_call_eq
  category: function_identity
  id_prefix: socketconn196

  columns: [id, function, args, expected, description]
  rows:
    - [cs_name,     create_server.__name__.__eq__,     ["create_server"], true, "socket.create_server.__name__ == 'create_server' (pure-Python server convenience function)"]
    - [cs_module,   create_server.__module__.__eq__,   ["socket"],        true, "socket.create_server.__module__ == 'socket' (defined in Lib/socket.py)"]
    - [cs_qualname, create_server.__qualname__.__eq__, ["create_server"], true, "socket.create_server.__qualname__ == 'create_server' (top-level; qualname equals name)"]

# ---------------------------------------------------------------------------
# socket.setdefaulttimeout identity — name, module; C extension from _socket
# __module__ == '_socket' distinguishes this from the pure-Python functions above
# ---------------------------------------------------------------------------

table socketconn196.setdefaulttimeout_identity:
  kind: python_call_eq
  category: function_identity
  id_prefix: socketconn196

  columns: [id, function, args, expected, description]
  rows:
    - [sdt_name,     setdefaulttimeout.__name__.__eq__,   ["setdefaulttimeout"], true, "socket.setdefaulttimeout.__name__ == 'setdefaulttimeout' (C-level function from _socket)"]
    - [sdt_module,   setdefaulttimeout.__module__.__eq__,  ["_socket"],          true, "socket.setdefaulttimeout.__module__ == '_socket' (C extension — unlike create_connection/create_server)"]
    - [cs_name_len,  create_server.__name__.__len__,        [], 13, "len(socket.create_server.__name__) == 13 ('create_server' has 13 characters — shorter than create_connection)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socketconn196.create_connection.name:
  description: "socket.create_connection.__name__ == 'create_connection' (pure-Python convenience function in Lib/socket.py)"
  category: function_identity
  kind: python_call_eq
  function: create_connection.__name__.__eq__
  args: ["create_connection"]
  expected: true

invariant socketconn196.create_connection.module:
  description: "socket.create_connection.__module__ == 'socket' (belongs to the public socket module)"
  category: function_identity
  kind: python_call_eq
  function: create_connection.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socketconn196.create_connection.qualname:
  description: "socket.create_connection.__qualname__ == 'create_connection' (top-level function; qualname equals name)"
  category: function_identity
  kind: python_call_eq
  function: create_connection.__qualname__.__eq__
  args: ["create_connection"]
  expected: true

invariant socketconn196.create_server.name:
  description: "socket.create_server.__name__ == 'create_server' (pure-Python server convenience function in Lib/socket.py)"
  category: function_identity
  kind: python_call_eq
  function: create_server.__name__.__eq__
  args: ["create_server"]
  expected: true

invariant socketconn196.create_server.module:
  description: "socket.create_server.__module__ == 'socket' (belongs to the public socket module)"
  category: function_identity
  kind: python_call_eq
  function: create_server.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socketconn196.create_server.qualname:
  description: "socket.create_server.__qualname__ == 'create_server' (top-level function; qualname equals name)"
  category: function_identity
  kind: python_call_eq
  function: create_server.__qualname__.__eq__
  args: ["create_server"]
  expected: true

invariant socketconn196.setdefaulttimeout.name:
  description: "socket.setdefaulttimeout.__name__ == 'setdefaulttimeout' (C-level function exposed via _socket)"
  category: function_identity
  kind: python_call_eq
  function: setdefaulttimeout.__name__.__eq__
  args: ["setdefaulttimeout"]
  expected: true

invariant socketconn196.setdefaulttimeout.module:
  description: "socket.setdefaulttimeout.__module__ == '_socket' (C extension; distinguished from pure-Python socket functions by module)"
  category: function_identity
  kind: python_call_eq
  function: setdefaulttimeout.__module__.__eq__
  args: ["_socket"]
  expected: true
