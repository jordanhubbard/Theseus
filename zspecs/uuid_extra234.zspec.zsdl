spec: uuid_extra234
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
  - "RFC 9562 — Universally Unique IDentifiers (UUID)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "RFC 9562 — Universally Unique IDentifiers (UUID)"
    - "Test vectors verified by running Python 3.14.3 uuid on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra233.zspec.zsdl — covers UUID bytes_le/fields/node/time_low/clock_seq_hi_variant attribute identity; bytes_le length; fields length."
    - "uuid_extra232.zspec.zsdl — covers UUID bytes form constructor; UUID(int=0) nil UUID; UUID('f47ac10b-...') v4 version/hex."
    - "uuid_extra24.zspec.zsdl — covers UUID property fget qualname lengths for node/time/clock_seq/clock_seq_hi_variant."
    - "uuid_extra18.zspec.zsdl — covers UUID property fget __qualname__ values for hex/bytes/bytes_le/fields/variant."
  notes:
    - "This spec covers uuid.NAMESPACE_DNS, uuid.NAMESPACE_URL, uuid.NAMESPACE_OID, uuid.NAMESPACE_X500 constant identity."
    - "All four RFC 4122 namespace UUIDs are version 1 (time-based). Verified Python 3.14.3."
    - "uuid.NAMESPACE_DNS = UUID('6ba7b810-9dad-11d1-80b4-00c04fd430c8') — assigned in RFC 4122 Appendix C. version=1."
    - "uuid.NAMESPACE_URL = UUID('6ba7b811-9dad-11d1-80b4-00c04fd430c8') — RFC 4122 Appendix C. version=1."
    - "uuid.NAMESPACE_OID = UUID('6ba7b812-9dad-11d1-80b4-00c04fd430c8') — RFC 4122 Appendix C. version=1."
    - "uuid.NAMESPACE_X500 = UUID('6ba7b814-9dad-11d1-80b4-00c04fd430c8') — RFC 4122 Appendix C. version=1."
    - "All namespace UUIDs have variant 'specified in RFC 4122' (len 21). Verified Python 3.14.3."
    - "All namespace UUIDs have __class__.__name__ == 'UUID'. Verified Python 3.14.3."
    - "NAMESPACE_DNS hex == '6ba7b8109dad11d180b400c04fd430c8' (32 chars). Verified Python 3.14.3."
    - "NAMESPACE_URL hex == '6ba7b8119dad11d180b400c04fd430c8' (32 chars). Verified Python 3.14.3."
    - "NAMESPACE_OID hex == '6ba7b8129dad11d180b400c04fd430c8' (32 chars). Verified Python 3.14.3."
    - "NAMESPACE_X500 hex == '6ba7b8149dad11d180b400c04fd430c8' (32 chars). Verified Python 3.14.3."
    - "variant string is 'specified in RFC 4122' (21 characters) for all four namespace constants."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "uuid.UUID raises ValueError for malformed UUID strings. Attribute access on module-level UUID constants never raises."
  stderr: "null"
  stickiness: "N/A — UUID instances are immutable; all attributes are read-only."
  codes: {}

# ---------------------------------------------------------------------------
# namespace UUID class identity
#
# All four RFC 4122 namespace constants are UUID instances:
#   NAMESPACE_DNS.__class__.__name__ == 'UUID'
#   NAMESPACE_URL.__class__.__name__ == 'UUID'
#   NAMESPACE_OID.__class__.__name__ == 'UUID'
#   NAMESPACE_X500.__class__.__name__ == 'UUID'
#
# These are module-level attributes, accessed via dotted attribute chains.
# ---------------------------------------------------------------------------

table uuid234ns.class_names:
  description: "NAMESPACE_DNS/URL/OID/X500 __class__.__name__=='UUID'; all are UUID instances; new to extra234"
  kind: python_call_eq
  category: class_identity
  id_prefix: uuid234ns

  columns: [id, function, args, expected, description]
  rows:
    - [dns_class_uuid,
       "NAMESPACE_DNS.__class__.__name__.__eq__",
       ["UUID"],
       true,
       "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — NAMESPACE_DNS is a UUID instance; RFC 4122 Appendix C assigns 6ba7b810-9dad-11d1-80b4-00c04fd430c8; new anchor in extra234 namespace; verified Python 3.14.3"]
    - [url_class_uuid,
       "NAMESPACE_URL.__class__.__name__.__eq__",
       ["UUID"],
       true,
       "uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID') == True — NAMESPACE_URL is a UUID instance; RFC 4122 Appendix C assigns 6ba7b811-9dad-11d1-80b4-00c04fd430c8; new anchor in extra234 namespace; verified Python 3.14.3"]
    - [oid_class_uuid,
       "NAMESPACE_OID.__class__.__name__.__eq__",
       ["UUID"],
       true,
       "uuid.NAMESPACE_OID.__class__.__name__.__eq__('UUID') == True — NAMESPACE_OID is a UUID instance; RFC 4122 Appendix C assigns 6ba7b812-9dad-11d1-80b4-00c04fd430c8; new anchor in extra234 namespace; verified Python 3.14.3"]
    - [x500_class_uuid,
       "NAMESPACE_X500.__class__.__name__.__eq__",
       ["UUID"],
       true,
       "uuid.NAMESPACE_X500.__class__.__name__.__eq__('UUID') == True — NAMESPACE_X500 is a UUID instance; RFC 4122 Appendix C assigns 6ba7b814-9dad-11d1-80b4-00c04fd430c8; new anchor in extra234 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# namespace UUID version == 1
#
# All RFC 4122 predefined namespace UUIDs are version 1 (time-based).
# The version field encodes bits 12-15 of the time_hi_version field.
# These were generated as version 1 UUIDs in RFC 4122 Appendix C.
# ---------------------------------------------------------------------------

table uuid234ns.versions:
  description: "NAMESPACE_DNS/URL/OID/X500 .version==1; all RFC 4122 predefined namespace UUIDs are version 1; new to extra234"
  kind: python_call_eq
  category: attribute_value
  id_prefix: uuid234ns

  columns: [id, function, args, expected, description]
  rows:
    - [dns_version_1,
       "NAMESPACE_DNS.version.__eq__",
       [1],
       true,
       "uuid.NAMESPACE_DNS.version.__eq__(1) == True — NAMESPACE_DNS is a version 1 (time-based) UUID as specified in RFC 4122 Appendix C; version 1 encodes a 60-bit timestamp; new anchor in extra234 namespace; verified Python 3.14.3"]
    - [url_version_1,
       "NAMESPACE_URL.version.__eq__",
       [1],
       true,
       "uuid.NAMESPACE_URL.version.__eq__(1) == True — NAMESPACE_URL is a version 1 UUID per RFC 4122 Appendix C; version bits in time_hi_version are 0001; new anchor in extra234 namespace; verified Python 3.14.3"]
    - [oid_version_1,
       "NAMESPACE_OID.version.__eq__",
       [1],
       true,
       "uuid.NAMESPACE_OID.version.__eq__(1) == True — NAMESPACE_OID is a version 1 UUID per RFC 4122 Appendix C; new anchor in extra234 namespace; verified Python 3.14.3"]
    - [x500_version_1,
       "NAMESPACE_X500.version.__eq__",
       [1],
       true,
       "uuid.NAMESPACE_X500.version.__eq__(1) == True — NAMESPACE_X500 is a version 1 UUID per RFC 4122 Appendix C; new anchor in extra234 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# namespace UUID variant string
#
# All four namespace UUIDs have variant == 'specified in RFC 4122'.
# The variant string has length 21.
# ---------------------------------------------------------------------------

table uuid234ns.variants:
  description: "NAMESPACE_DNS/URL/OID/X500 .variant=='specified in RFC 4122'; all namespace UUIDs have RFC 4122 variant; new to extra234"
  kind: python_call_eq
  category: attribute_value
  id_prefix: uuid234ns

  columns: [id, function, args, expected, description]
  rows:
    - [dns_variant_rfc4122,
       "NAMESPACE_DNS.variant.__eq__",
       ["specified in RFC 4122"],
       true,
       "uuid.NAMESPACE_DNS.variant.__eq__('specified in RFC 4122') == True — variant indicates the UUID layout follows RFC 4122 (bits 6-7 of clock_seq_hi_variant are 10 binary); new anchor in extra234 namespace; verified Python 3.14.3"]
    - [url_variant_rfc4122,
       "NAMESPACE_URL.variant.__eq__",
       ["specified in RFC 4122"],
       true,
       "uuid.NAMESPACE_URL.variant.__eq__('specified in RFC 4122') == True — NAMESPACE_URL follows RFC 4122 variant layout; new anchor in extra234 namespace; verified Python 3.14.3"]
    - [oid_variant_rfc4122,
       "NAMESPACE_OID.variant.__eq__",
       ["specified in RFC 4122"],
       true,
       "uuid.NAMESPACE_OID.variant.__eq__('specified in RFC 4122') == True — NAMESPACE_OID follows RFC 4122 variant layout; new anchor in extra234 namespace; verified Python 3.14.3"]
    - [x500_variant_rfc4122,
       "NAMESPACE_X500.variant.__eq__",
       ["specified in RFC 4122"],
       true,
       "uuid.NAMESPACE_X500.variant.__eq__('specified in RFC 4122') == True — NAMESPACE_X500 follows RFC 4122 variant layout; new anchor in extra234 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuid234ns.dns_class_name:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — NAMESPACE_DNS is a UUID instance defined in RFC 4122 Appendix C as '6ba7b810-9dad-11d1-80b4-00c04fd430c8'; it is a version 1 (time-based) UUID with RFC 4122 variant; it is used as the namespace for generating version 3 (MD5-based) and version 5 (SHA-1-based) UUIDs when the input name is a DNS domain name; prior uuid specs cover constructed UUIDs; extra234 is the first namespace to anchor the predefined namespace UUID constants directly as standalone invariants; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: "NAMESPACE_DNS.__class__.__name__.__eq__"
  args: ["UUID"]
  expected: true

invariant uuid234ns.dns_version_1:
  description: "uuid.NAMESPACE_DNS.version.__eq__(1) == True — NAMESPACE_DNS is a version 1 (time-based) UUID; version 1 encodes a 60-bit UTC timestamp in the time_low, time_mid, and time_hi_version fields; the RFC 4122 namespace UUIDs were generated as version 1 UUIDs in Appendix C of the RFC; version 1 is distinct from version 4 (random) which is used for generated UUIDs; extra234 is the first namespace to anchor NAMESPACE_DNS.version as a standalone invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: attribute_value
  kind: python_call_eq
  function: "NAMESPACE_DNS.version.__eq__"
  args: [1]
  expected: true

invariant uuid234ns.dns_variant_rfc4122:
  description: "uuid.NAMESPACE_DNS.variant.__eq__('specified in RFC 4122') == True — the variant string 'specified in RFC 4122' (21 characters) indicates that the UUID layout follows RFC 4122; this variant uses bits 6-7 of byte 8 (clock_seq_hi_variant) encoded as binary 10; the Python uuid module returns this exact string for RFC 4122 variant UUIDs; the other possible variants are 'reserved for NCS compatibility', 'reserved, Microsoft Corporation backward compatibility', and 'reserved for future definition'; extra234 anchors this variant string as a standalone invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: attribute_value
  kind: python_call_eq
  function: "NAMESPACE_DNS.variant.__eq__"
  args: ["specified in RFC 4122"]
  expected: true

invariant uuid234ns.variant_len_21:
  description: "uuid.NAMESPACE_DNS.variant.__len__() == 21 — len('specified in RFC 4122') == 21; the variant string has 21 characters; this length is the same for all four namespace UUID constants; extra234 anchors this length as the first standalone variant length invariant in the uuid namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: attribute_length
  kind: python_call_eq
  function: "NAMESPACE_DNS.variant.__len__"
  args: []
  expected: 21

invariant uuid234ns.url_version_1:
  description: "uuid.NAMESPACE_URL.version.__eq__(1) == True — NAMESPACE_URL is a version 1 UUID defined in RFC 4122 Appendix C as '6ba7b811-9dad-11d1-80b4-00c04fd430c8'; it is used as the namespace for generating version 3/5 UUIDs when the input name is a URL; NAMESPACE_DNS and NAMESPACE_URL differ only in the last hex digit of the first component (810 vs 811); extra234 anchors NAMESPACE_URL.version as a standalone invariant in the extra234 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: attribute_value
  kind: python_call_eq
  function: "NAMESPACE_URL.version.__eq__"
  args: [1]
  expected: true

invariant uuid234ns.x500_class_name:
  description: "uuid.NAMESPACE_X500.__class__.__name__.__eq__('UUID') == True — NAMESPACE_X500 is a UUID instance defined in RFC 4122 Appendix C as '6ba7b814-9dad-11d1-80b4-00c04fd430c8'; it is used as the namespace for generating version 3/5 UUIDs when the input name is an X.500 DN in DER or text output format; note the hex digits 810/811/812/814 for DNS/URL/OID/X500 — there is no 813; extra234 anchors NAMESPACE_X500 class identity as a standalone invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: "NAMESPACE_X500.__class__.__name__.__eq__"
  args: ["UUID"]
  expected: true
