spec: contextlib_extra32
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib_extra31.zspec.zsdl."
    - "Prior specs covered: __module__/__name__/__qualname__ for all major contextlib symbols; MRO lengths; AbstractContextManager.__abstractmethods__.__len__()==1; method __qualname__.__len__() for suppress/__enter__/__exit__/__init__, nullcontext/__enter__/__exit__/__init__, ExitStack.close/__enter__/__exit__, closing/__enter__/__exit__/__init__."
    - "This spec covers: contextlib.__all__.__len__()==14 and .__class__.__name__.__len__()==4; contextmanager.__qualname__.__len__()==14; asynccontextmanager.__qualname__.__len__()==19; __dict__.__class__.__name__.__len__()==12 for closing/suppress/ExitStack/AsyncExitStack/AbstractContextManager/nullcontext/ContextDecorator/AbstractAsyncContextManager; ExitStack.enter_context/__qualname__.__len__()==28; ExitStack.callback/__qualname__.__len__()==23; suppress/__bases__[0].__name__.__len__()==22; closing/__bases__[0].__name__.__len__()==22."
    - "contextlib.__all__.__len__() == 14 — fourteen public names in contextlib.__all__."
    - "contextlib.__all__.__class__.__name__ == 'list' (len=4) — __all__ is a plain list."
    - "contextlib.contextmanager.__qualname__ == 'contextmanager' (len=14) — top-level decorator function."
    - "contextlib.asynccontextmanager.__qualname__ == 'asynccontextmanager' (len=19) — top-level async decorator."
    - "All context manager class __dict__.__class__.__name__ == 'mappingproxy' (len=12)."
    - "ExitStack.enter_context.__qualname__ == '_BaseExitStack.enter_context' (len=28) — inherited from _BaseExitStack."
    - "ExitStack.callback.__qualname__ == '_BaseExitStack.callback' (len=23) — inherited from _BaseExitStack."
    - "suppress.__bases__[0].__name__ == 'AbstractContextManager' (len=22) — suppress inherits from the ABC directly."
    - "closing.__bases__[0].__name__ == 'AbstractContextManager' (len=22) — same as suppress; both are direct ABC subclasses."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() table for contextlib classes
# (extra32 namespace)
#
# Every Python class namespace is wrapped in a 'mappingproxy' (12 chars).
# This table records that invariant for eight contextlib classes:
# closing, suppress, ExitStack, AsyncExitStack, AbstractContextManager,
# nullcontext, ContextDecorator, AbstractAsyncContextManager.
# No prior contextlib spec records all eight together in the extra32 namespace.
# ---------------------------------------------------------------------------

table contextlib_extra32.class_dict_class_name_lens:
  description: "__dict__.__class__.__name__.__len__() for contextlib classes — all equal 12 ('mappingproxy')"
  kind: python_call_eq
  category: class_dict_attrs
  id_prefix: dict_class_name_len

  columns: [id, function, args, expected]
  rows:
    - [closing,                      closing.__dict__.__class__.__name__.__len__,                      [], 12]
    - [suppress,                     suppress.__dict__.__class__.__name__.__len__,                     [], 12]
    - [ExitStack,                    ExitStack.__dict__.__class__.__name__.__len__,                    [], 12]
    - [AsyncExitStack,               AsyncExitStack.__dict__.__class__.__name__.__len__,               [], 12]
    - [AbstractContextManager,       AbstractContextManager.__dict__.__class__.__name__.__len__,       [], 12]
    - [nullcontext,                  nullcontext.__dict__.__class__.__name__.__len__,                  [], 12]
    - [ContextDecorator,             ContextDecorator.__dict__.__class__.__name__.__len__,             [], 12]
    - [AbstractAsyncContextManager,  AbstractAsyncContextManager.__dict__.__class__.__name__.__len__,  [], 12]

# ---------------------------------------------------------------------------
# ExitStack inherited method __qualname__.__len__() table (extra32 namespace)
#
# ExitStack.enter_context and ExitStack.callback are defined on the internal
# _BaseExitStack class and inherited by ExitStack. Their qualnames therefore
# carry the '_BaseExitStack.' prefix:
#   enter_context -> '_BaseExitStack.enter_context' (len=28)
#   callback      -> '_BaseExitStack.callback'       (len=23)
# ExitStack.close is defined directly on ExitStack ('ExitStack.close', len=15)
# and was recorded in contextlib_extra31. This table focuses on the two
# inherited methods whose qualnames differ from 'ExitStack.*'.
# No prior contextlib spec records these qualname lengths in the extra32
# namespace.
# ---------------------------------------------------------------------------

table contextlib_extra32.exitstack_inherited_method_qualname_lens:
  description: "__qualname__.__len__() for ExitStack methods inherited from _BaseExitStack"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: exitstack_inherited_qualname_len

  columns: [id, function, args, expected]
  rows:
    - [enter_context, ExitStack.enter_context.__qualname__.__len__, [], 28]
    - [callback,      ExitStack.callback.__qualname__.__len__,      [], 23]

# ---------------------------------------------------------------------------
# contextlib.__all__.__len__() == 14 — standalone (extra32 namespace)
#
# contextlib.__all__ contains 14 names. No prior contextlib spec records this
# standalone count in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra32.all_len:
  description: "len(contextlib.__all__) == 14 — fourteen public names exported by contextlib"
  category: module_attrs
  kind: python_call_eq
  function: contextlib.__all__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# contextlib.__all__.__class__.__name__.__len__() == 4 — standalone
# (extra32 namespace)
#
# contextlib.__all__ is a plain Python list, so __class__.__name__ == 'list'
# (4 characters). No prior contextlib spec records this in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra32.all_class_name_len:
  description: "len(contextlib.__all__.__class__.__name__) == 4 — __all__ is a list"
  category: module_attrs
  kind: python_call_eq
  function: contextlib.__all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# contextlib.asynccontextmanager.__qualname__.__len__() == 19 — standalone
# (extra32 namespace)
#
# 'asynccontextmanager' has 19 characters, making it the longest of the two
# top-level decorator function qualnames in contextlib (contextmanager=14,
# asynccontextmanager=19). The async variant is 5 characters longer because
# of the 'async' prefix. No prior contextlib spec records this standalone in
# the extra32 namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra32.asynccontextmanager.qualname_len:
  description: "len(contextlib.asynccontextmanager.__qualname__) == 19 — 5 chars longer than contextmanager (14)"
  category: qualname_attrs
  kind: python_call_eq
  function: asynccontextmanager.__qualname__.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# suppress.__bases__[0].__name__.__len__() == 22 — standalone
# (extra32 namespace)
#
# suppress inherits directly from AbstractContextManager, whose name has 22
# characters. This is the longest base-class name among the concrete context
# manager classes in contextlib. closing shares the same base (also 22).
# No prior contextlib spec records this standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra32.suppress.base_name_len:
  description: "len(contextlib.suppress.__bases__[0].__name__) == 22 — direct base is 'AbstractContextManager'"
  category: class_hierarchy
  kind: python_call_eq
  function: "suppress.__bases__[0].__name__.__len__"
  args: []
  expected: 22

# ---------------------------------------------------------------------------
# ExitStack.enter_context.__qualname__.__len__() == 28 — standalone
# (extra32 namespace)
#
# ExitStack.enter_context is defined on _BaseExitStack, so its __qualname__
# is '_BaseExitStack.enter_context' — 28 characters. This is the longest
# method qualname recorded in the contextlib spec series. No prior contextlib
# spec records this standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra32.ExitStack.enter_context.qualname_len:
  description: "len(contextlib.ExitStack.enter_context.__qualname__) == 28 — inherited from _BaseExitStack, longest contextlib method qualname"
  category: method_qualname_lengths
  kind: python_call_eq
  function: ExitStack.enter_context.__qualname__.__len__
  args: []
  expected: 28
