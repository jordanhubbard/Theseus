spec: itertools_extra91
version: ">=3.9"
backend: python_module(itertools)
extends: itertools_extra90

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra90.zspec.zsdl."
    - "This spec covers: itertools C-type __dict__.__class__.__name__ identity — all should be 'mappingproxy' (Wave 251)."
    - "For C extension types, class __dict__ is a types.MappingProxyType, so __dict__.__class__.__name__ is 'mappingproxy'."
    - "itertools.chain.__dict__.__class__.__name__ == 'mappingproxy' — C type in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.product.__dict__.__class__.__name__ == 'mappingproxy' — C type. Verified with Python 3.14.3."
    - "itertools.combinations.__dict__.__class__.__name__ == 'mappingproxy' — C type. Verified with Python 3.14.3."
    - "itertools.permutations.__dict__.__class__.__name__ == 'mappingproxy' — C type. Verified with Python 3.14.3."
    - "itertools.accumulate.__dict__.__class__.__name__ == 'mappingproxy' — C type. Verified with Python 3.14.3."
    - "itertools.groupby.__dict__.__class__.__name__ == 'mappingproxy' — C type. Verified with Python 3.14.3."
    - "itertools.islice.__dict__.__class__.__name__ == 'mappingproxy' — C type. Verified with Python 3.14.3."
    - "itertools.starmap.__dict__.__class__.__name__ == 'mappingproxy' — C type. Verified with Python 3.14.3."
    - "itertools.filterfalse.__dict__.__class__.__name__ == 'mappingproxy' — C type. Verified with Python 3.14.3."
    - "itertools.takewhile.__dict__.__class__.__name__ == 'mappingproxy' — C type. Verified with Python 3.14.3."
    - "itertools.count.__dict__.__class__.__name__ == 'mappingproxy' — C type. Verified with Python 3.14.3."
    - "itertools.repeat.__dict__.__class__.__name__ == 'mappingproxy' — C type. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# chain/product/combinations dict class names
#
# Wave 251 theme: itertools C-type __dict__.__class__.__name__ identity — group 1.
#
# itertools.chain.__dict__.__class__.__name__.__eq__('mappingproxy')       == True
# itertools.product.__dict__.__class__.__name__.__eq__('mappingproxy')     == True
# itertools.combinations.__dict__.__class__.__name__.__eq__('mappingproxy') == True
# itertools.permutations.__dict__.__class__.__name__.__eq__('mappingproxy') == True
#
# Prior spec extra90 checked __module__ string equality. This spec (extra91) checks __dict__.__class__.__name__. New to extra91.
# ---------------------------------------------------------------------------

table itertools_extra91.dict_class_names_group1:
  description: "chain/product/combinations/permutations __dict__.__class__.__name__ == 'mappingproxy'; C types in itertoolsmodule.c; wave 251; new to extra91"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsdictcls91

  columns: [id, function, args, expected, description]
  rows:
    - [chain_dict_class_name_eq_mappingproxy,
       "chain.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "itertools.chain.__dict__.__class__.__name__.__eq__('mappingproxy') == True — chain is a C extension type in Modules/itertoolsmodule.c; class __dict__ in Python is a types.MappingProxyType, a read-only proxy that prevents direct modification of the class namespace; __dict__.__class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; prior spec extra90 checked chain.__module__; this spec (extra91) checks __dict__.__class__.__name__; new to extra91"]
    - [product_dict_class_name_eq_mappingproxy,
       "product.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "itertools.product.__dict__.__class__.__name__.__eq__('mappingproxy') == True — product is a C extension type in Modules/itertoolsmodule.c; class __dict__ is a mappingproxy; __dict__.__class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra91"]
    - [combinations_dict_class_name_eq_mappingproxy,
       "combinations.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "itertools.combinations.__dict__.__class__.__name__.__eq__('mappingproxy') == True — combinations is a C extension type in Modules/itertoolsmodule.c; class __dict__ is a mappingproxy; __dict__.__class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra91"]
    - [permutations_dict_class_name_eq_mappingproxy,
       "permutations.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "itertools.permutations.__dict__.__class__.__name__.__eq__('mappingproxy') == True — permutations is a C extension type in Modules/itertoolsmodule.c; class __dict__ is a mappingproxy; __dict__.__class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra91"]

