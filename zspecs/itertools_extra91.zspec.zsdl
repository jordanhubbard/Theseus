# ---------------------------------------------------------------------------
# Cross-check: dict class names are not 'dict'
#
# Wave 251 theme: confirm class __dict__ is mappingproxy and not a plain dict.
#
# itertools.chain.__dict__.__class__.__name__.__eq__('dict')        == False
# itertools.accumulate.__dict__.__class__.__name__.__eq__('dict')   == False
# itertools.filterfalse.__dict__.__class__.__name__.__eq__('dict')  == False
# itertools.repeat.__dict__.__class__.__name__.__eq__('dict')       == False
#
# Cross-checks confirm class __dict__ is always a mappingproxy, never a plain dict. New to extra91.
# ---------------------------------------------------------------------------

table itertools_extra91.dict_class_names_ne_dict:
  description: "chain/accumulate/filterfalse/repeat __dict__.__class__.__name__ != 'dict'; cross-checks confirming class __dict__ is a mappingproxy not a dict; wave 251; new to extra91"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsdictcls91

  columns: [id, function, args, expected, description]
  rows:
    - [chain_dict_class_name_ne_dict,
       "chain.__dict__.__class__.__name__.__eq__",
       ["dict"],
       false,
       "itertools.chain.__dict__.__class__.__name__.__eq__('dict') == False — chain class __dict__ is a mappingproxy (types.MappingProxyType), not a plain mutable dict; mappingproxy prevents direct assignment to the class namespace; __dict__.__class__.__name__ is 'mappingproxy', not 'dict'; str.__eq__('dict') returns False; new to extra91"]
    - [accumulate_dict_class_name_ne_dict,
       "accumulate.__dict__.__class__.__name__.__eq__",
       ["dict"],
       false,
       "itertools.accumulate.__dict__.__class__.__name__.__eq__('dict') == False — accumulate class __dict__ is a mappingproxy, not a plain dict; str.__eq__('dict') returns False; confirms consistent mappingproxy usage across all itertools C types; new to extra91"]
    - [filterfalse_dict_class_name_ne_dict,
       "filterfalse.__dict__.__class__.__name__.__eq__",
       ["dict"],
       false,
       "itertools.filterfalse.__dict__.__class__.__name__.__eq__('dict') == False — filterfalse class __dict__ is a mappingproxy, not a plain dict; str.__eq__('dict') returns False; new to extra91"]
    - [repeat_dict_class_name_ne_dict,
       "repeat.__dict__.__class__.__name__.__eq__",
       ["dict"],
       false,
       "itertools.repeat.__dict__.__class__.__name__.__eq__('dict') == False — repeat class __dict__ is a mappingproxy, not a plain dict; str.__eq__('dict') returns False; new to extra91"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra91
# ---------------------------------------------------------------------------

invariant itertools_extra91.chain_dict_class_name_eq_mappingproxy:
  description: "itertools.chain.__dict__.__class__.__name__.__eq__('mappingproxy') == True — chain C type class __dict__ is a mappingproxy; wave 251; new to extra91"
  kind: python_call_eq
  function: "chain.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

invariant itertools_extra91.accumulate_dict_class_name_eq_mappingproxy:
