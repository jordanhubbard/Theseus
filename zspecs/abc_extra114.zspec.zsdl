spec: abc_extra114
version: ">=3.11"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra113.zspec.zsdl."
    - "This spec covers: wave 259 theme — abc module-level function co_varnames element equality checks not previously covered. Prior specs covered: extra110 covered abstractmethod.__code__.co_varnames.__len__()==1 and update_abstractmethods.__code__.co_varnames.__len__()==5; extra112 covered ABCMeta.register/__instancecheck__/__subclasscheck__ co_varnames.__len__()==2 and ABCMeta.__new__ co_varnames.__len__()==6. NOT previously covered: abstractmethod.__code__.co_varnames[0].__eq__('funcobj'); update_abstractmethods.__code__.co_varnames[0].__eq__('cls'); update_abstractmethods.__code__.co_varnames[1].__eq__('abstracts'); ABCMeta.register.__code__.co_varnames[0].__eq__('cls'); ABCMeta.register.__code__.co_varnames[1].__eq__('subclass'); ABCMeta.__new__.__code__.co_varnames[0].__eq__('mcls'); ABCMeta.__instancecheck__.__code__.co_varnames[1].__eq__('instance'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractmethod.__code__.co_varnames[0] == 'funcobj' (len=7: the single parameter of abstractmethod; abstractmethod is a decorator that marks a method as abstract; 'funcobj' is the name used internally rather than the conventional 'func' or 'fn'; co_varnames.__len__()==1 covered in extra110). abc.update_abstractmethods.__code__.co_varnames[0] == 'cls' (len=3: the positional parameter; co_varnames[1]=='abstracts' len=9: a local set variable). ABCMeta.register.__code__.co_varnames[0] == 'cls'; co_varnames[1] == 'subclass' (len=8: the class to register as a virtual subclass). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "ABCMeta.__new__.__code__.co_varnames[0] == 'mcls' (len=4: the metaclass parameter; uses 'mcls' instead of 'cls' to signal it is a metaclass __new__, not a regular class __new__). ABCMeta.__instancecheck__.__code__.co_varnames[1] == 'instance' (len=8: the object to test; co_varnames[0]=='cls'). ABCMeta.__subclasscheck__.__code__.co_varnames[1] == 'subclass' (len=8: the candidate subclass; tied with ABCMeta.register co_varnames[1]=='subclass'). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc module-level function co_varnames[0] equality — extra114
#
# Wave 259 theme: abstractmethod and update_abstractmethods co_varnames element equality.
#
# abc.abstractmethod.__code__.co_varnames[0]          == 'funcobj'    (len=7)
# abc.update_abstractmethods.__code__.co_varnames[0]  == 'cls'        (len=3)
# abc.update_abstractmethods.__code__.co_varnames[1]  == 'abstracts'  (len=9)
# ---------------------------------------------------------------------------

table abc_extra114.abc_function_co_varnames_elements:
  description: "abc module-level function co_varnames element equality checks in abcvar114 namespace — wave 259 theme: abstractmethod and update_abstractmethods co_varnames[0] equality; abc.abstractmethod.__code__.co_varnames[0].__eq__('funcobj')==True (len=7: abstractmethod's single parameter is named 'funcobj' not 'func' or 'fn'; this unconventional name reflects that abstractmethod can decorate any callable object, not just functions; co_varnames.__len__()==1 was covered in extra110; co_varnames[0]='funcobj' is the first coverage of the element itself); abc.abstractmethod.__code__.co_varnames[0].__len__()==7; abc.update_abstractmethods.__code__.co_varnames[0].__eq__('cls')==True (len=3: update_abstractmethods takes one positional parameter 'cls' — the class to update; co_argcount==1 covered in extra106; co_varnames.__len__()==5 covered in extra110; co_varnames[0]='cls' is the first element coverage); abc.update_abstractmethods.__code__.co_varnames[0].__len__()==3; abc.update_abstractmethods.__code__.co_varnames[1].__eq__('abstracts')==True (len=9: 'abstracts' is a local set variable in update_abstractmethods that collects abstract method names found in the class; co_varnames[1]='abstracts' is the first second-element coverage); abc.update_abstractmethods.__code__.co_varnames[1].__len__()==9; compare: abstractmethod co_varnames[0]='funcobj' len=7 > update_abstractmethods co_varnames[0]='cls' len=3 (4 more: 'funcobj' is a more descriptive name than 'cls'); update_abstractmethods co_varnames[1]='abstracts' len=9 (longest element in this table); all three functions are pure-Python functions with __code__ attribute; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcvar114

  columns: [id, function, args, expected, description]
  rows:
    - [am_v0_eq,    "abc.abstractmethod.__code__.co_varnames[0].__eq__",            ["funcobj"],    true, "abstractmethod.__code__.co_varnames[0] == 'funcobj' (len=7; unconventional param name); verified with Python 3.14.3"]
    - [am_v0_len,   "abc.abstractmethod.__code__.co_varnames[0].__len__",           [],             7,    "abstractmethod.__code__.co_varnames[0].__len__() == 7 ('funcobj'=7); verified with Python 3.14.3"]
    - [uam_v0_eq,   "abc.update_abstractmethods.__code__.co_varnames[0].__eq__",    ["cls"],        true, "update_abstractmethods.__code__.co_varnames[0] == 'cls' (len=3; positional param); verified with Python 3.14.3"]
    - [uam_v0_len,  "abc.update_abstractmethods.__code__.co_varnames[0].__len__",   [],             3,    "update_abstractmethods.__code__.co_varnames[0].__len__() == 3 ('cls'=3); verified with Python 3.14.3"]
    - [uam_v1_eq,   "abc.update_abstractmethods.__code__.co_varnames[1].__eq__",    ["abstracts"],  true, "update_abstractmethods.__code__.co_varnames[1] == 'abstracts' (len=9; local set of abstract names); verified with Python 3.14.3"]
    - [uam_v1_len,  "abc.update_abstractmethods.__code__.co_varnames[1].__len__",   [],             9,    "update_abstractmethods.__code__.co_varnames[1].__len__() == 9 ('abstracts'=9, longest element in table); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta method co_varnames element equality — extra114
#
# Wave 259 theme: ABCMeta.register, __new__, __instancecheck__, __subclasscheck__ co_varnames elements.
#
# ABCMeta.register.__code__.co_varnames[0]       == 'cls'      (len=3)
# ABCMeta.register.__code__.co_varnames[1]       == 'subclass' (len=8)
# ABCMeta.__new__.__code__.co_varnames[0]        == 'mcls'     (len=4)
# ABCMeta.__instancecheck__.__code__.co_varnames[1] == 'instance' (len=8)
# ---------------------------------------------------------------------------

table abc_extra114.abc_abcmeta_co_varnames_elements:
  description: "abc.ABCMeta method co_varnames element equality checks in abcvar114 namespace — wave 259 theme: register, __new__, __instancecheck__ co_varnames element equality; ABCMeta.register.__code__.co_varnames[0].__eq__('cls')==True (len=3: ABCMeta.register is a classmethod; the first parameter is the class itself, conventionally named 'cls'; co_varnames[0]='cls' is the first element coverage); ABCMeta.register.__code__.co_varnames[0].__len__()==3; ABCMeta.register.__code__.co_varnames[1].__eq__('subclass')==True (len=8: the second parameter 'subclass' is the class to register as a virtual subclass of the ABC; co_varnames[1]='subclass' is the first second-element coverage); ABCMeta.register.__code__.co_varnames[1].__len__()==8; ABCMeta.__new__.__code__.co_varnames[0].__eq__('mcls')==True (len=4: ABCMeta.__new__ uses 'mcls' for the metaclass parameter instead of the conventional 'cls'; this signals the first argument is a metaclass, not a regular class; co_varnames.__len__()==6 covered in extra112); ABCMeta.__new__.__code__.co_varnames[0].__len__()==4; ABCMeta.__instancecheck__.__code__.co_varnames[1].__eq__('instance')==True (len=8: the second parameter 'instance' is the object to test with isinstance(); co_varnames[0]=='cls'; 'instance'=8 chars is the same length as 'subclass'=8 chars — tied; co_varnames.__len__()==2 covered in extra112); ABCMeta.__instancecheck__.__code__.co_varnames[1].__len__()==8; compare: register co_varnames[0]='cls' len=3 (shortest, tied with __instancecheck__/co_varnames[0]); register co_varnames[1]='subclass'=8 (tied with __instancecheck__ co_varnames[1]='instance'=8); __new__ co_varnames[0]='mcls'=4 (1 more than 'cls'=3); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcvar114a

  columns: [id, function, args, expected, description]
  rows:
    - [reg_v0_eq,   "abc.ABCMeta.register.__code__.co_varnames[0].__eq__",               ["cls"],      true, "ABCMeta.register.__code__.co_varnames[0] == 'cls' (len=3; classmethod first param); verified with Python 3.14.3"]
    - [reg_v0_len,  "abc.ABCMeta.register.__code__.co_varnames[0].__len__",              [],           3,    "ABCMeta.register.__code__.co_varnames[0].__len__() == 3 ('cls'=3); verified with Python 3.14.3"]
    - [reg_v1_eq,   "abc.ABCMeta.register.__code__.co_varnames[1].__eq__",               ["subclass"], true, "ABCMeta.register.__code__.co_varnames[1] == 'subclass' (len=8; class to register as virtual subclass); verified with Python 3.14.3"]
    - [reg_v1_len,  "abc.ABCMeta.register.__code__.co_varnames[1].__len__",              [],           8,    "ABCMeta.register.__code__.co_varnames[1].__len__() == 8 ('subclass'=8); verified with Python 3.14.3"]
    - [new_v0_eq,   "abc.ABCMeta.__new__.__code__.co_varnames[0].__eq__",                ["mcls"],     true, "ABCMeta.__new__.__code__.co_varnames[0] == 'mcls' (len=4; metaclass param, not 'cls'); verified with Python 3.14.3"]
    - [new_v0_len,  "abc.ABCMeta.__new__.__code__.co_varnames[0].__len__",               [],           4,    "ABCMeta.__new__.__code__.co_varnames[0].__len__() == 4 ('mcls'=4; 1 more than 'cls'=3); verified with Python 3.14.3"]
    - [ic_v1_eq,    "abc.ABCMeta.__instancecheck__.__code__.co_varnames[1].__eq__",      ["instance"], true, "ABCMeta.__instancecheck__.__code__.co_varnames[1] == 'instance' (len=8; object to test); verified with Python 3.14.3"]
    - [ic_v1_len,   "abc.ABCMeta.__instancecheck__.__code__.co_varnames[1].__len__",     [],           8,    "ABCMeta.__instancecheck__.__code__.co_varnames[1].__len__() == 8 ('instance'=8, tied with 'subclass'=8); verified with Python 3.14.3"]
    - [sc_v1_eq,    "abc.ABCMeta.__subclasscheck__.__code__.co_varnames[1].__eq__",      ["subclass"], true, "ABCMeta.__subclasscheck__.__code__.co_varnames[1] == 'subclass' (len=8; candidate subclass; tied with __instancecheck__ co_varnames[1] len=8); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc module-level function co_varnames element ordering cross-checks — extra114
#
# Wave 259 theme: compare co_varnames element lengths across abc functions.
#
# abstractmethod co_varnames[0] = 'funcobj'   len=7
# update_abstractmethods co_varnames[0] = 'cls'  len=3  (shortest)
# update_abstractmethods co_varnames[1] = 'abstracts'  len=9 (longest element)
# ABCMeta.register co_varnames[1] = 'subclass'  len=8
# ABCMeta.__new__ co_varnames[0] = 'mcls'  len=4
# ---------------------------------------------------------------------------

table abc_extra114.abc_co_varnames_element_ordering:
  description: "abc module function co_varnames element length ordering cross-checks in abcvar114 namespace — wave 259 theme: comparing co_varnames element lengths across abc functions; abc.update_abstractmethods.__code__.co_varnames[0].__len__()==3 ('cls'=3, shortest element in spec); abc.ABCMeta.register.__code__.co_varnames[0].__len__()==3 (tied with update_abstractmethods co_varnames[0]: both are 'cls'=3); abc.ABCMeta.__new__.__code__.co_varnames[0].__len__()==4 ('mcls'=4: 1 more than 'cls'=3; 'mcls'=4 because it prepends 'm' for metaclass); abc.abstractmethod.__code__.co_varnames[0].__len__()==7 ('funcobj'=7: most descriptive param name; 4 more than 'cls'=3); abc.ABCMeta.register.__code__.co_varnames[1].__len__()==8 ('subclass'=8; tied with __instancecheck__ co_varnames[1]='instance'=8 and __subclasscheck__ co_varnames[1]='subclass'=8); abc.update_abstractmethods.__code__.co_varnames[1].__len__()==9 ('abstracts'=9, longest element in spec: 1 more than 'subclass'=8 and 'instance'=8); length ordering: cls=3 (shortest, shared by register[0] and uam[0]) < mcls=4 < funcobj=7 < subclass==instance=8 (tied) < abstracts=9 (longest); all elements are plain Python strings from the code object co_varnames tuple; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcvar114b

  columns: [id, function, args, expected, description]
  rows:
    - [cls_3,     "abc.update_abstractmethods.__code__.co_varnames[0].__len__",   [], 3, "update_abstractmethods co_varnames[0]='cls' len=3 (shortest in spec); verified with Python 3.14.3"]
    - [reg_cls_3, "abc.ABCMeta.register.__code__.co_varnames[0].__len__",         [], 3, "ABCMeta.register co_varnames[0]='cls' len=3 (tied with uam co_varnames[0]='cls'); verified with Python 3.14.3"]
    - [mcls_4,    "abc.ABCMeta.__new__.__code__.co_varnames[0].__len__",          [], 4, "ABCMeta.__new__ co_varnames[0]='mcls' len=4 (1 more than 'cls'=3); verified with Python 3.14.3"]
    - [funcobj_7, "abc.abstractmethod.__code__.co_varnames[0].__len__",           [], 7, "abstractmethod co_varnames[0]='funcobj' len=7 (most chars of any first-param name in spec); verified with Python 3.14.3"]
    - [subcls_8,  "abc.ABCMeta.register.__code__.co_varnames[1].__len__",         [], 8, "ABCMeta.register co_varnames[1]='subclass' len=8 (tied with 'instance'=8); verified with Python 3.14.3"]
    - [inst_8,    "abc.ABCMeta.__instancecheck__.__code__.co_varnames[1].__len__", [], 8, "ABCMeta.__instancecheck__ co_varnames[1]='instance' len=8 (tied with 'subclass'=8); verified with Python 3.14.3"]
    - [abst_9,    "abc.update_abstractmethods.__code__.co_varnames[1].__len__",   [], 9, "update_abstractmethods co_varnames[1]='abstracts' len=9 (longest element in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra114
# ---------------------------------------------------------------------------

invariant abc_extra114.abstractmethod_co_varnames_0_funcobj:
  description: "abc.abstractmethod.__code__.co_varnames[0].__eq__('funcobj') returns True — abstractmethod's first (and only) parameter is named 'funcobj'; co_varnames==('funcobj',) with co_varnames.__len__()==1 (covered in extra110); 'funcobj' has len=7: 'func'=4+'obj'=3=7 (a compound abbreviation meaning 'function object'); unlike typical decorator parameters named 'func' or 'fn', abstractmethod uses 'funcobj' to emphasize that it accepts any callable object, not just functions; abstractmethod.__code__.co_argcount==1 (funcobj is the single positional parameter); abstractmethod.__code__.co_qualname=='abstractmethod' (len=14); abstractmethod.__module__=='abc' (len=3); abstractmethod.__code__.co_varnames[0].__len__()==7; compare: ABCMeta.register co_varnames[0]='cls' len=3 (4 shorter than 'funcobj'); ABCMeta.__new__ co_varnames[0]='mcls' len=4 (3 shorter); 'funcobj'=7 is the longest first-parameter name among abc functions; first standalone abstractmethod co_varnames[0] equality invariant in abcvar114 namespace; wave 259; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "abc.abstractmethod.__code__.co_varnames[0].__eq__"
  args: ["funcobj"]
  expected: true

invariant abc_extra114.update_abstractmethods_co_varnames_0_cls:
  description: "abc.update_abstractmethods.__code__.co_varnames[0].__eq__('cls') returns True — update_abstractmethods first parameter is 'cls' (len=3); co_varnames==('cls','abstracts','scls','name','value') with co_varnames.__len__()==5 (covered in extra110); 'cls' is the conventional name for the class being updated; update_abstractmethods(cls) re-examines a class's abstract methods by checking if any method that was abstract in a base class has now been concretely defined in cls (added in Python 3.10); co_argcount==1 (only cls is positional); abstractmethod.__code__.co_varnames[0]='funcobj' (7 chars, 4 more than 'cls'=3); ABCMeta.register.__code__.co_varnames[0]='cls' (tied: same 'cls'=3, same length); ABCMeta.__instancecheck__.__code__.co_varnames[0]='cls' (also tied: all three functions use 'cls'=3 as first param); update_abstractmethods.__code__.co_qualname=='update_abstractmethods' (len=22); update_abstractmethods.__module__=='abc'; first standalone update_abstractmethods co_varnames[0] equality invariant in abcvar114 namespace; wave 259; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "abc.update_abstractmethods.__code__.co_varnames[0].__eq__"
  args: ["cls"]
  expected: true

invariant abc_extra114.ABCMeta_register_co_varnames_1_subclass:
  description: "abc.ABCMeta.register.__code__.co_varnames[1].__eq__('subclass') returns True — ABCMeta.register's second parameter is 'subclass' (len=8); co_varnames==('cls','subclass') with co_varnames.__len__()==2 (covered in extra112); 'subclass' is the class to register as a virtual subclass of the ABC; after registration, isinstance(obj, ABC) returns True for instances of subclass, and issubclass(subclass, ABC) returns True, even if subclass does not inherit from ABC; ABCMeta.register.__code__.co_argcount==2 (both cls and subclass are positional); ABCMeta.register.__code__.co_varnames[1].__len__()==8 (tied with ABCMeta.__instancecheck__ co_varnames[1]='instance'=8); compare: ABCMeta.__subclasscheck__.__code__.co_varnames[1]='subclass' (same value; both register and __subclasscheck__ have 'subclass' as second param); ABCMeta.register.__code__.co_qualname=='ABCMeta.register' (len=16); ABCMeta.__module__=='abc'; first standalone ABCMeta.register co_varnames[1] equality invariant in abcvar114 namespace; wave 259; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "abc.ABCMeta.register.__code__.co_varnames[1].__eq__"
  args: ["subclass"]
  expected: true

invariant abc_extra114.ABCMeta_new_co_varnames_0_mcls:
  description: "abc.ABCMeta.__new__.__code__.co_varnames[0].__eq__('mcls') returns True — ABCMeta.__new__ first parameter is 'mcls' (len=4); co_varnames==('mcls','name','bases','namespace','kwargs','cls') with co_varnames.__len__()==6 (covered in extra112); 'mcls' is used instead of the conventional 'cls' to signal that this is a metaclass __new__: the first argument is the metaclass (ABCMeta) rather than a regular class; co_argcount==4 (mcls, name, bases, namespace are positional; kwargs is VAR_KEYWORD); ABCMeta.__new__.__code__.co_varnames[0].__len__()==4 ('mcls'=4: 'm'=1+'cls'=3=4; 1 more than 'cls'=3); compare: update_abstractmethods co_varnames[0]='cls' len=3 (1 shorter); ABCMeta.register co_varnames[0]='cls' len=3 (1 shorter); abstractmethod co_varnames[0]='funcobj' len=7 (3 more); ABCMeta.__new__.__code__.co_qualname=='ABCMeta.__new__' (len=15); ABCMeta.__module__=='abc'; first standalone ABCMeta.__new__ co_varnames[0] equality invariant in abcvar114 namespace; wave 259; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "abc.ABCMeta.__new__.__code__.co_varnames[0].__eq__"
  args: ["mcls"]
  expected: true

invariant abc_extra114.update_abstractmethods_co_varnames_1_abstracts:
  description: "abc.update_abstractmethods.__code__.co_varnames[1].__eq__('abstracts') returns True — update_abstractmethods second variable (index 1) is 'abstracts' (len=9); co_varnames[1]='abstracts' is a local variable (not a parameter: co_argcount==1, so co_varnames[0]='cls' is the only param; indices 1-4 are locals); 'abstracts' is a set that accumulates the names of methods that remain abstract after examining all MRO bases; update_abstractmethods.__code__.co_varnames[1].__len__()==9 ('abstracts'=9, longest element name in this spec; 1 more than 'subclass'=8 and 'instance'=8); compare: update_abstractmethods co_varnames==('cls','abstracts','scls','name','value'); 'abstracts'=9 > 'subclass'=8 > 'funcobj'=7 > 'mcls'=4 > 'cls'=3; update_abstractmethods.__code__.co_qualname=='update_abstractmethods' (len=22; longest abc function co_qualname); update_abstractmethods was added in Python 3.10; ABCMeta.__module__=='abc'; first standalone update_abstractmethods co_varnames[1] equality invariant in abcvar114 namespace; wave 259; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "abc.update_abstractmethods.__code__.co_varnames[1].__eq__"
  args: ["abstracts"]
  expected: true

