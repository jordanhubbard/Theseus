spec: heapq_extra16
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
  notes:
    - "This spec extends heapq.zspec.zsdl through heapq_extra15.zspec.zsdl."
    - "Prior specs cover: __name__/__module__/__qualname__ for all 7 heapq functions; behavioral vectors; name lengths; __module__ table extra12/extra15."
    - "heapq_extra12 covers heappush/heappop/heapify/heapreplace __qualname__ as standalone invariants."
    - "heapq_extra15 covers merge/nlargest/nsmallest __qualname__ as standalone invariants."
    - "heapq_extra5 covers heappushpop.__qualname__ in a table row only."
    - "heapq_extra4 covers heapq module __name__ == 'heapq' via __name__.__eq__."
    - "NOT yet covered: heappushpop.__qualname__ as standalone extra16 invariant; heapq __package__ == '' (never covered); qualname length table for all 7 functions."
    - "Focus: heapq module __package__; heappushpop.__qualname__ standalone anchor; __qualname__.__len__() table for all 7 functions."
    - "heapq.__package__ == '' — heapq is a top-level module with no parent package. Verified Python 3.12 macOS."
    - "heapq.heappushpop.__qualname__ == 'heappushpop' — C builtin qualname. Verified."
    - "len('heappush') == 8, len('heappop') == 7, len('heapify') == 7, len('heapreplace') == 11, len('heappushpop') == 11, len('merge') == 5, len('nlargest') == 8, len('nsmallest') == 9."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# heapq module __package__ attribute
#
# heapq is a top-level module; its __package__ is the empty string.
# heapq_extra4 covers heapq.__name__ == 'heapq'. No prior heapq spec checks
# __package__. Under python_module(heapq), function: __package__.__eq__
# accesses heapq.__package__.__eq__('').
# ---------------------------------------------------------------------------

invariant heapq_extra16.module.package:
  description: "heapq.__package__ == '' — heapq is a top-level module with no parent package"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# heappushpop.__qualname__ — standalone extra16 invariant
#
# heapq_extra5 covered heappushpop.__qualname__ in a table row.
# heapq_extra12 added heappush/heappop/heapify/heapreplace as standalone
# invariants. heappushpop was not added as a standalone invariant in any prior
# spec. This anchor provides the extra16-namespace standalone form.
# heappushpop is a C builtin; __qualname__ equals __name__.
# ---------------------------------------------------------------------------

invariant heapq_extra16.heappushpop.qualname:
  description: "heapq.heappushpop.__qualname__ == 'heappushpop' — C builtin qualname matches plain name"
  category: function_qualnames
  kind: python_call_eq
  function: heappushpop.__qualname__.__eq__
  args: ["heappushpop"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__.__len__() table for all 7 heapq functions
#
# No prior heapq spec checks the length of __qualname__ for any function.
# heapq_extra15 noted that name-length vectors were covered; those cover
# __name__.__len__(). __qualname__.__len__() is a separate execution path.
# For C builtins __qualname__ == __name__, so lengths match; for pure-Python
# functions (merge/nlargest/nsmallest) the same holds at the top level.
# id_prefix hql16 does not conflict with any prior heapq spec.
# ---------------------------------------------------------------------------

table heapq_extra16.qualname_lengths:
  description: "__qualname__.__len__() for all 7 heapq functions"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: hql16

  columns: [id, function, args, expected]
  rows:
    - [heappush,    heappush.__qualname__.__len__,    [], 8]
    - [heappop,     heappop.__qualname__.__len__,     [], 7]
    - [heapify,     heapify.__qualname__.__len__,     [], 7]
    - [heapreplace, heapreplace.__qualname__.__len__, [], 11]
    - [heappushpop, heappushpop.__qualname__.__len__, [], 11]
    - [merge,       merge.__qualname__.__len__,       [], 5]
    - [nlargest,    nlargest.__qualname__.__len__,    [], 8]
    - [nsmallest,   nsmallest.__qualname__.__len__,   [], 9]
