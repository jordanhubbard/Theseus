spec: itertools_extra946
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __class__.__name__ for iterator types: accumulate, compress, dropwhile, filterfalse, groupby, islice, starmap, takewhile, zip_longest"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra946.iterator_class_names:
  description: "itertools iterator type __class__.__name__ identity"
  kind: python_call_eq
  category: class_names
  id_prefix: it946cn
  columns: [id, function, args, expected]
  rows:
    - [it946cn001, itertools.accumulate.__name__.__eq__,                           ["accumulate"],    true]
    - [it946cn002, itertools.compress.__name__.__eq__,                             ["compress"],      true]
    - [it946cn003, itertools.dropwhile.__name__.__eq__,                            ["dropwhile"],     true]
    - [it946cn004, itertools.filterfalse.__name__.__eq__,                          ["filterfalse"],   true]
    - [it946cn005, itertools.groupby.__name__.__eq__,                              ["groupby"],       true]
    - [it946cn006, itertools.islice.__name__.__eq__,                               ["islice"],        true]
    - [it946cn007, itertools.starmap.__name__.__eq__,                              ["starmap"],       true]
    - [it946cn008, itertools.takewhile.__name__.__eq__,                            ["takewhile"],     true]
    - [it946cn009, itertools.zip_longest.__name__.__eq__,                          ["zip_longest"],   true]

