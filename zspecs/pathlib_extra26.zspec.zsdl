spec: pathlib_extra26
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra25.zspec.zsdl — covers __bases__[0].__name__ for full class hierarchy table; __module__ for Path/PurePath/PosixPath/PurePosixPath/PureWindowsPath"
    - "pathlib_extra24.zspec.zsdl — covers Path('/a/b/c').parts/stem/suffix/suffixes; Path('/a/b').joinpath('c','d'); PurePosixPath('/a/b').root"
  notes:
    - "This spec extends pathlib.zspec.zsdl and all prior pathlib_extra specs through pathlib_extra25.zspec.zsdl."
    - "MRO (Method Resolution Order) length reflects how many classes appear in the linearized inheritance chain, including the class itself and object."
    - "Path.__mro__ len == 3: [Path, PurePath, object] — verified at runtime."
    - "PurePosixPath.__mro__ len == 3: [PurePosixPath, PurePath, object] — verified at runtime."
    - "PureWindowsPath.__mro__ len == 3: [PureWindowsPath, PurePath, object] — verified at runtime."
    - "PosixPath.__mro__ len == 5: [PosixPath, Path, PurePosixPath, PurePath, object] — verified at runtime."
    - "WindowsPath.__mro__ len == 5: [WindowsPath, Path, PureWindowsPath, PurePath, object] — verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# MRO lengths for all 5 pathlib concrete/pure-path classes
#
# The MRO (C3 linearization) length differs between pure-path classes (len 3)
# and concrete path classes (len 5). Pure paths — PurePosixPath, PureWindowsPath,
# and Path — each resolve through exactly PurePath then object. Concrete
# PosixPath and WindowsPath each insert an extra intermediate pure-path class,
# pushing the chain to 5. No prior pathlib spec groups all five in a single
# MRO-length table.
# ---------------------------------------------------------------------------

table pathlib_extra26.mro_lengths:
  description: "__mro__ length for all 5 pathlib classes (verified with len())"
  kind: python_call_eq
  category: mro
  id_prefix: plmro26

  columns: [id, function, args, expected]
  rows:
    - [Path,             "Path.__mro__.__len__",             [], 3]
    - [PurePosixPath,    "PurePosixPath.__mro__.__len__",    [], 3]
    - [PureWindowsPath,  "PureWindowsPath.__mro__.__len__",  [], 3]
    - [PosixPath,        "PosixPath.__mro__.__len__",        [], 5]
    - [WindowsPath,      "WindowsPath.__mro__.__len__",      [], 5]

# ---------------------------------------------------------------------------
# Standalone MRO length invariants — named checks for each class
#
# These complement the table above with individually named invariants for
# clearer reporting. Each invariant targets the same __mro__.__len__ call
# but carries a descriptive name and explains the MRO chain in the description.
# ---------------------------------------------------------------------------

invariant pathlib_extra26.Path.mro_len:
  description: "pathlib.Path.__mro__ has 3 entries: [Path, PurePath, object]"
  category: mro
  kind: python_call_eq
  function: Path.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra26.PurePosixPath.mro_len:
  description: "pathlib.PurePosixPath.__mro__ has 3 entries: [PurePosixPath, PurePath, object]"
  category: mro
  kind: python_call_eq
  function: PurePosixPath.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra26.PureWindowsPath.mro_len:
  description: "pathlib.PureWindowsPath.__mro__ has 3 entries: [PureWindowsPath, PurePath, object]"
  category: mro
  kind: python_call_eq
  function: PureWindowsPath.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra26.PosixPath.mro_len:
  description: "pathlib.PosixPath.__mro__ has 5 entries: [PosixPath, Path, PurePosixPath, PurePath, object]"
  category: mro
  kind: python_call_eq
  function: PosixPath.__mro__.__len__
  args: []
  expected: 5

invariant pathlib_extra26.WindowsPath.mro_len:
  description: "pathlib.WindowsPath.__mro__ has 5 entries: [WindowsPath, Path, PureWindowsPath, PurePath, object]"
  category: mro
  kind: python_call_eq
  function: WindowsPath.__mro__.__len__
  args: []
  expected: 5
