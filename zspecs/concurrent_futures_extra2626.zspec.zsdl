spec: concurrent_futures_extra2626
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 622 theme: __length_hint__, __missing__, and __reversed__ dict-presence checks."
    - "None of concurrent.futures.Future, ThreadPoolExecutor, ProcessPoolExecutor, or Executor define __length_hint__, __missing__, or __reversed__ in their own __dict__."
    - "concurrent.futures classes are concurrency primitives; they are not iterators, dict subclasses, or sequences."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — concurrent.futures classes
#
# Future, ThreadPoolExecutor, ProcessPoolExecutor, and Executor do NOT
# define __length_hint__ in their own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2626.length_hint_checks:
  description: "concurrent.futures classes do NOT define __length_hint__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2626
  columns: [id, function, args, expected]
  rows:
    - ["cf2626001", "concurrent.futures.Future.__dict__.__contains__",              ["__length_hint__"], false]
    - ["cf2626002", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__length_hint__"], false]
    - ["cf2626003", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__length_hint__"], false]
    - ["cf2626004", "concurrent.futures.Executor.__dict__.__contains__",            ["__length_hint__"], false]

