spec: sqlite3_extra10
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl and prior extras through sqlite3_extra9.zspec.zsdl."
    - "sqlite3_extra covers: Connection/__name__/__module__; Cursor/__name__/__module__; Row/__name__/__module__."
    - "sqlite3_extra2 covers: Connection/__name__; Cursor/__name__; Row/__name__; exception names table."
    - "sqlite3_extra4 covers: Row/Connection/Cursor __name__ table; PARSE_DECLTYPES/__eq__; PARSE_COLNAMES/__eq__; version/__class__/__name__."
    - "sqlite3_extra5 covers: __qualname__ for Connection/Cursor/Row/Error/Warning/IntegrityError/OperationalError/connect/complete_statement."
    - "sqlite3_extra7 covers: SQLITE_OK/SQLITE_ERROR/SQLITE_INTERNAL; Connection/Row/Cursor __module__; exception __bases__[0]/__name__ table."
    - "sqlite3_extra8 covers: SQLITE_BUSY/SQLITE_LOCKED/SQLITE_MISUSE/SQLITE_NOTADB; connect/__name__/__module__; Warning/__name__/__module__."
    - "sqlite3_extra9 covers: SQLITE_ABORT/SQLITE_CONSTRAINT/SQLITE_RANGE; complete_statement/__name__/__module__; DatabaseError/Error MRO[1]/__name__; PARSE_DECLTYPES/PARSE_COLNAMES type; version/__len__."
    - "This spec adds four new axes: Connection/__class__/__name__; Cursor/__class__/__name__; Row/__class__/__name__; connect/__class__/__name__."
    - "sqlite3.Connection.__class__.__name__ — Connection is a C-extension type; its metaclass is 'type'."
    - "sqlite3.Cursor.__class__.__name__ — Cursor is a C-extension type; its metaclass is 'type'."
    - "sqlite3.Row.__class__.__name__ — Row is a C-extension type; its metaclass is 'type'."
    - "sqlite3.connect.__class__.__name__ — connect is a builtin_function_or_method defined in the _sqlite3 C extension."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Metaclass checks for Connection, Cursor, and Row
#
# Prior specs check __name__ and __module__ for all three classes.
# sqlite3_extra5 checks __qualname__.
# No prior sqlite3 spec checks __class__.__name__ for Connection, Cursor, or Row.
# All three are C-extension type objects; their metaclass is 'type'.
# ---------------------------------------------------------------------------

table sqlite3_extra10.class_metaclasses:
  kind: python_call_eq
  category: metaclasses
  id_prefix: meta10

  columns: [id, function, args, expected]
  rows:
    - [Connection, Connection.__class__.__name__.__eq__, ["type"], true]
    - [Cursor,     Cursor.__class__.__name__.__eq__,     ["type"], true]
    - [Row,        Row.__class__.__name__.__eq__,        ["type"], true]

# ---------------------------------------------------------------------------
# connect.__class__.__name__
#
# sqlite3_extra8 checks connect.__name__ == 'connect' and
# connect.__module__ == 'sqlite3'.
# sqlite3_extra5 checks connect.__qualname__ == 'connect'.
# No prior spec checks connect.__class__.__name__.
# sqlite3.connect is a builtin callable exposed from the _sqlite3 C extension;
# its __class__.__name__ == 'builtin_function_or_method'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra10.connect.class_name:
  description: "sqlite3.connect.__class__.__name__ == 'builtin_function_or_method' — connect is a C builtin"
  category: functions
  kind: python_call_eq
  function: connect.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
