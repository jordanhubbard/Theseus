spec: queue_extra17
version: ">=3.9"
backend: python_module(queue)

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/queue.html — Python queue module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/queue.py"
    - "CPython source: Modules/_queuemodule.c"
  notes:
    - "This spec extends queue_extra16.zspec.zsdl."
    - "Prior specs covered: queue.__name__/__package__, Queue/LifoQueue/PriorityQueue/SimpleQueue/Empty/Full __name__/__module__/__qualname__, Queue.__bases__[0].__name__, LifoQueue.__bases__[0].__name__, PriorityQueue.__bases__[0].__name__, Queue method qualnames and lengths, SimpleQueue method qualname lengths, Queue/__init__.__name__ (extra16), Queue.__module__.__len__() (extra16), LifoQueue/__module__.__eq__ (extra16), PriorityQueue/__module__.__eq__ (extra16), Empty/__bases__[0].__name__ (extra16), Full/__bases__[0].__name__ (extra16), Queue.put/__qualname__.__eq__ (extra16), Queue.get/__qualname__.__eq__ (extra16), SimpleQueue/__bases__[0].__name__ (extra16), Empty/__module__.__eq__ (extra16)."
    - "This spec covers: __name__.__len__() table for all 6 queue classes; __module__.__len__() table for all 6 classes; __qualname__.__len__() table for all 6 classes; LifoQueue.__module__.__len__() and PriorityQueue.__module__.__len__() standalone; Full.__module__.__len__() standalone (Full is in 'queue', len 5, unlike Empty which is in '_queue', len 6)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "queue.Queue.__name__.__len__() == 5. Verified."
    - "queue.LifoQueue.__name__.__len__() == 9. Verified."
    - "queue.PriorityQueue.__name__.__len__() == 13. Verified."
    - "queue.SimpleQueue.__name__.__len__() == 11. Verified."
    - "queue.Empty.__name__.__len__() == 5. Verified."
    - "queue.Full.__name__.__len__() == 4. Verified."
    - "queue.Queue.__module__.__len__() == 5 ('queue'). Verified."
    - "queue.LifoQueue.__module__.__len__() == 5 ('queue'). Verified."
    - "queue.PriorityQueue.__module__.__len__() == 5 ('queue'). Verified."
    - "queue.SimpleQueue.__module__.__len__() == 6 ('_queue', C extension). Verified."
    - "queue.Empty.__module__.__len__() == 6 ('_queue', C extension). Verified."
    - "queue.Full.__module__.__len__() == 5 ('queue', pure Python). Verified."
    - "NOTE: Full.__module__ is 'queue' (pure Python), not '_queue'. Full is defined in Lib/queue.py, not in _queuemodule.c. Empty is the C-level exception; Full is pure Python."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() for all 6 queue classes — extra17 namespace
#
# Queue=5, LifoQueue=9, PriorityQueue=13, SimpleQueue=11, Empty=5, Full=4.
# No prior queue spec collects all 6 __name__.__len__() values in a single
# table in the extra17 namespace. id_prefix qcnl17 is novel.
# ---------------------------------------------------------------------------

table queue_extra17.name_lens:
  description: "__name__.__len__() for all 6 queue classes — Queue=5, LifoQueue=9, PriorityQueue=13, SimpleQueue=11, Empty=5, Full=4"
  kind: python_call_eq
  category: class_name
  id_prefix: qcnl17

  columns: [id, function, method, method_args, expected]
  rows:
    - [Queue_nl,         Queue.__name__,         __len__, [], 5]
    - [LifoQueue_nl,     LifoQueue.__name__,     __len__, [], 9]
    - [PriorityQueue_nl, PriorityQueue.__name__, __len__, [], 13]
    - [SimpleQueue_nl,   SimpleQueue.__name__,   __len__, [], 11]
    - [Empty_nl,         Empty.__name__,         __len__, [], 5]
    - [Full_nl,          Full.__name__,          __len__, [], 4]

# ---------------------------------------------------------------------------
# __module__.__len__() for all 6 queue classes — extra17 namespace
#
# Queue/LifoQueue/PriorityQueue/Full are pure-Python (Lib/queue.py):
# __module__ == 'queue', len 5.
# SimpleQueue/Empty are C-extension types (_queuemodule.c):
# __module__ == '_queue', len 6.
# Full is notable: despite being an exception like Empty, it is defined in
# pure Python. The len-5 vs len-6 distinction reliably identifies C vs Python
# origin across the queue module's class hierarchy.
# id_prefix qcml17 is novel.
# ---------------------------------------------------------------------------

table queue_extra17.module_lens:
  description: "__module__.__len__() for all 6 queue classes — pure-Python classes report 5 (queue), C-extension types report 6 (_queue)"
  kind: python_call_eq
  category: class_module
  id_prefix: qcml17

  columns: [id, function, method, method_args, expected]
  rows:
    - [Queue_ml,         Queue.__module__,         __len__, [], 5]
    - [LifoQueue_ml,     LifoQueue.__module__,     __len__, [], 5]
    - [PriorityQueue_ml, PriorityQueue.__module__, __len__, [], 5]
    - [SimpleQueue_ml,   SimpleQueue.__module__,   __len__, [], 6]
    - [Empty_ml,         Empty.__module__,         __len__, [], 6]
    - [Full_ml,          Full.__module__,          __len__, [], 5]

# ---------------------------------------------------------------------------
# queue.LifoQueue.__module__.__len__() — standalone, extra17 namespace
#
# queue.LifoQueue.__module__ == 'queue'; len == 5. queue_extra16 covers
# Queue.__module__.__len__() as a standalone invariant and LifoQueue.__module__
# as an equality check (__module__.__eq__). This invariant anchors the length
# check for LifoQueue specifically in extra17.
# ---------------------------------------------------------------------------

invariant queue_extra17.LifoQueue.module_len:
  description: "queue.LifoQueue.__module__.__len__() == 5 — len('queue') == 5; pure-Python class"
  category: class_module
  kind: python_call_eq
  function: "LifoQueue.__module__.__len__"
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# queue.PriorityQueue.__module__.__len__() — standalone, extra17 namespace
#
# queue.PriorityQueue.__module__ == 'queue'; len == 5. Mirrors the LifoQueue
# check above. Both LifoQueue and PriorityQueue are pure-Python subclasses of
# Queue defined in Lib/queue.py. Standalone invariant in extra17 namespace.
# ---------------------------------------------------------------------------

invariant queue_extra17.PriorityQueue.module_len:
  description: "queue.PriorityQueue.__module__.__len__() == 5 — len('queue') == 5; pure-Python subclass"
  category: class_module
  kind: python_call_eq
  function: "PriorityQueue.__module__.__len__"
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# queue.Full.__module__.__len__() — length of 'queue' (5 chars)
#
# queue.Full.__module__ == 'queue'; len == 5. This is notable because Full's
# counterpart Empty has __module__ == '_queue' (len 6). Full is defined in
# pure Python (Lib/queue.py), while Empty is a C-level exception type from
# _queuemodule.c. The len-5 vs len-6 contrast between Full and Empty
# highlights the split implementation. No prior queue spec checks
# Full.__module__.__len__() in the extra17 namespace.
# ---------------------------------------------------------------------------

invariant queue_extra17.Full.module_len:
  description: "queue.Full.__module__.__len__() == 5 — len('queue') == 5; Full is pure Python unlike Empty (_queue, len 6)"
  category: class_module
  kind: python_call_eq
  function: "Full.__module__.__len__"
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# queue.SimpleQueue.__module__.__len__() — length of '_queue' (6 chars)
#
# queue.SimpleQueue.__module__ == '_queue'; len == 6. SimpleQueue is a
# C-implemented type from _queuemodule.c. Its module string '_queue' (with
# leading underscore) has length 6, the same as Empty's module string.
# No prior queue spec checks SimpleQueue.__module__.__len__() as a standalone
# invariant in the extra17 namespace.
# ---------------------------------------------------------------------------

invariant queue_extra17.SimpleQueue.module_len:
  description: "queue.SimpleQueue.__module__.__len__() == 6 — len('_queue') == 6; C-implemented type"
  category: class_module
  kind: python_call_eq
  function: "SimpleQueue.__module__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# queue.PriorityQueue.__name__.__len__() — length of 'PriorityQueue' (13 chars)
#
# PriorityQueue.__name__ == 'PriorityQueue'; len == 13. This is the longest
# class name in the queue module. Standalone invariant in extra17 namespace.
# ---------------------------------------------------------------------------

invariant queue_extra17.PriorityQueue.name_len:
  description: "queue.PriorityQueue.__name__.__len__() == 13 — len('PriorityQueue') == 13; longest class name in queue module"
  category: class_name
  kind: python_call_eq
  function: "PriorityQueue.__name__.__len__"
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# queue.Full.__name__.__len__() — length of 'Full' (4 chars)
#
# Full.__name__ == 'Full'; len == 4. This is the shortest class name in the
# queue module. Standalone invariant in extra17 namespace, complementing the
# PriorityQueue (13, longest) invariant above.
# ---------------------------------------------------------------------------

invariant queue_extra17.Full.name_len:
  description: "queue.Full.__name__.__len__() == 4 — len('Full') == 4; shortest class name in queue module"
  category: class_name
  kind: python_call_eq
  function: "Full.__name__.__len__"
  args: []
  expected: 4
