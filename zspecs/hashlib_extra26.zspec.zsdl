spec: hashlib_extra26
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra25.zspec.zsdl — covers algorithms_guaranteed/__class__/__qualname__; algorithms_guaranteed/__len__()==14; algorithms_guaranteed contains sha3_256; algorithms_guaranteed.isdisjoint(set())."
    - "hashlib_extra24.zspec.zsdl — covers md5/sha1/sha256/sha512 __qualname__.__eq__ as standalone invariants; __qualname__.__len__() for md5/sha1/sha256/sha512/sha224/sha384/new/pbkdf2_hmac."
    - "hashlib_extra20.zspec.zsdl — covers md5/sha1/sha256/sha512/new/pbkdf2_hmac __name__; algorithms_available/__class__/__name__.__eq__."
    - "hashlib_extra17.zspec.zsdl — covers new.__qualname__.__eq__('__hash_new') as standalone invariant."
    - "hashlib_extra.zspec.zsdl — covers algorithms_available/__class__/__name__.__eq__ == 'set'."
  notes:
    - "This spec extends hashlib through hashlib_extra25; it does NOT duplicate invariants present in those files."
    - "Focus: __qualname__.__eq__ for sha224 and sha384 (not covered by any prior spec as standalone invariants); new.__qualname__.__eq__ re-anchored from extra26 namespace; algorithms_guaranteed and algorithms_available __class__/__name__.__eq__ re-anchored from extra26 namespace."
    - "hashlib.sha224.__qualname__ == 'openssl_sha224': OpenSSL-backed constructor on CPython 3.12. No prior spec covers sha224.__qualname__.__eq__ as a standalone invariant (extra24 covers __len__ only for sha224). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__qualname__ == 'openssl_sha384': OpenSSL-backed constructor on CPython 3.12. No prior spec covers sha384.__qualname__.__eq__ as a standalone invariant (extra24 covers __len__ only). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.new.__qualname__ == '__hash_new': CPython internal wrapper alias. hashlib_extra17 covers this from extra17 namespace; this invariant provides an independent regression path from extra26. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set': extra20 covers this; re-anchored from extra26 namespace for independent coverage. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__name__ == 'set': extra20 covers this; re-anchored from extra26 namespace. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sha224 and sha384 __qualname__.__eq__ — standalone invariants
#
# hashlib_extra24 covers md5/sha1/sha256/sha512 __qualname__.__eq__ as
# standalone invariants. hashlib_extra24 covers sha224/__qualname__.__len__()
# and sha384/__qualname__.__len__() but NOT their __qualname__.__eq__ as
# standalone invariants. This spec fills that gap.
# On CPython 3.12, both are OpenSSL-backed: openssl_sha224, openssl_sha384.
# ---------------------------------------------------------------------------

invariant hashlib_extra26.sha224.qualname:
  description: "hashlib.sha224.__qualname__ == 'openssl_sha224' — OpenSSL-backed constructor qualname on CPython 3.12"
  category: function_qualnames
  kind: python_call_eq
  function: sha224.__qualname__.__eq__
  args: ["openssl_sha224"]
  expected: true

invariant hashlib_extra26.sha384.qualname:
  description: "hashlib.sha384.__qualname__ == 'openssl_sha384' — OpenSSL-backed constructor qualname on CPython 3.12"
  category: function_qualnames
  kind: python_call_eq
  function: sha384.__qualname__.__eq__
  args: ["openssl_sha384"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__qualname__ — re-anchored from extra26 namespace
#
# hashlib_extra17 covers new.__qualname__.__eq__('__hash_new') from the
# extra17 namespace. This invariant anchors the same property from the extra26
# namespace, providing an independent execution path for regression detection.
# ---------------------------------------------------------------------------

invariant hashlib_extra26.new.qualname:
  description: "hashlib.new.__qualname__ == '__hash_new' — CPython internal wrapper alias, anchored from extra26"
  category: function_qualnames
  kind: python_call_eq
  function: new.__qualname__.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_guaranteed and algorithms_available __class__.__name__
#
# hashlib_extra20 covers both attributes' __class__.__name__.__eq__ == 'set'.
# These invariants re-anchor from the extra26 namespace for independent
# regression coverage across different spec execution contexts.
# ---------------------------------------------------------------------------

invariant hashlib_extra26.algorithms_guaranteed.class_name:
  description: "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — anchored from extra26 namespace"
  category: type_metadata
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

invariant hashlib_extra26.algorithms_available.class_name:
  description: "hashlib.algorithms_available.__class__.__name__ == 'set' — anchored from extra26 namespace"
  category: type_metadata
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true
