spec: multiprocessing_extra167
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec covers: multiprocessing.cpu_count bound method __name__, __module__, and __qualname__ identity; multiprocessing.set_start_method bound method __name__, __module__, and __qualname__ identity; multiprocessing.get_start_method bound method __name__ and __module__ identity; multiprocessing.get_context bound method __name__, __module__, and __qualname__ identity. KEY FINDINGS: all four are BOUND METHODS on context objects: cpu_count.__qualname__=='BaseContext.cpu_count' (len=21); set_start_method.__qualname__=='DefaultContext.set_start_method' (len=31: 'DefaultContext'=14+'.'+set_start_method'=16=31 — DefaultContext, not BaseContext, because set_start_method is defined on DefaultContext which overrides the BaseContext version); get_start_method.__qualname__=='DefaultContext.get_start_method' (len=31); get_context.__qualname__=='DefaultContext.get_context' (len=26). All have __module__=='multiprocessing.context' (len=23). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.cpu_count.__name__=='cpu_count' (len=9: 'cpu'=3+'_'=1+'count'=5=9); __module__=='multiprocessing.context' (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23); __qualname__=='BaseContext.cpu_count' (len=21: 'BaseContext'=11+'.'=1+'cpu_count'=9=21; cpu_count is defined in BaseContext since it is common to all context types). Verified with Python 3.14.3."
    - "multiprocessing.set_start_method.__name__=='set_start_method' (len=16: 'set'=3+'_'=1+'start'=5+'_'=1+'method'=6=16); __module__=='multiprocessing.context' (len=23); __qualname__=='DefaultContext.set_start_method' (len=31: 'DefaultContext'=14+'.'=1+'set_start_method'=16=31; set_start_method is on DefaultContext — only DefaultContext allows changing the start method; BaseContext does not define set_start_method). Verified with Python 3.14.3."
    - "multiprocessing.get_start_method.__name__=='get_start_method' (len=16: same as set_start_method=16); __module__=='multiprocessing.context' (len=23); __qualname__=='DefaultContext.get_start_method' (len=31; same as set_start_method qualname len=31: 'DefaultContext'=14+'.'=1+'get_start_method'=16=31). Verified with Python 3.14.3."
    - "multiprocessing.get_context.__name__=='get_context' (len=11: 'get'=3+'_'=1+'context'=7=11); __module__=='multiprocessing.context' (len=23); __qualname__=='DefaultContext.get_context' (len=26: 'DefaultContext'=14+'.'=1+'get_context'=11=26). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.cpu_count bound method identity — extra167
#
# multiprocessing.cpu_count.__name__.__eq__('cpu_count')                 == True
# multiprocessing.cpu_count.__name__.__len__()                           == 9
# multiprocessing.cpu_count.__module__.__eq__('multiprocessing.context') == True
# multiprocessing.cpu_count.__qualname__.__eq__('BaseContext.cpu_count') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra167.mp_cpu_count_identity:
  description: "multiprocessing.cpu_count bound method name, module, and qualname identity checks in mpcpucount167 namespace — multiprocessing.cpu_count.__name__.__eq__('cpu_count')==True (cpu_count.__name__=='cpu_count' (len=9: 'cpu'=3+'_'=1+'count'=5=9); multiprocessing.cpu_count() returns the number of CPUs in the system; raises NotImplementedError if it cannot be determined; it is a bound method on the default context object (DefaultContext), defined in BaseContext since all context types can report CPU count); multiprocessing.cpu_count.__name__.__len__()==9 ('cpu_count'=9; compare: get_context=11 is 2 longer; set_start_method=get_start_method=16 are 7 longer); multiprocessing.cpu_count.__module__.__eq__('multiprocessing.context')==True (__module__=='multiprocessing.context' (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23; same length as multiprocessing.process=23 from extra166)); multiprocessing.cpu_count.__qualname__.__eq__('BaseContext.cpu_count')==True (__qualname__=='BaseContext.cpu_count' (len=21: 'BaseContext'=11+'.'=1+'cpu_count'=9=21; cpu_count is defined in BaseContext — the common base for all context types (fork, spawn, forkserver))); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpcpucount167

  columns: [id, function, args, expected, description]
  rows:
    - [cc_name_eq,      multiprocessing.cpu_count.__name__.__eq__,     ["cpu_count"],                true,  "cpu_count.__name__ == 'cpu_count' (len=9: 'cpu'=3+'_count'=6=9; returns number of CPUs); verified with Python 3.14.3"]
    - [cc_name_len,     multiprocessing.cpu_count.__name__.__len__,    [],                           9,     "cpu_count.__name__.__len__() == 9 ('cpu_count'=9; get_context=11 > cpu_count=9 by 2); verified with Python 3.14.3"]
    - [cc_mod_eq,       multiprocessing.cpu_count.__module__.__eq__,   ["multiprocessing.context"],  true,  "cpu_count.__module__ == 'multiprocessing.context' (len=23; same len as multiprocessing.process=23); verified with Python 3.14.3"]
    - [cc_qualname_eq,  multiprocessing.cpu_count.__qualname__.__eq__, ["BaseContext.cpu_count"],    true,  "cpu_count.__qualname__ == 'BaseContext.cpu_count' (len=21; defined in BaseContext for all context types); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.set_start_method bound method identity — extra167
#
# multiprocessing.set_start_method.__name__.__eq__('set_start_method')                == True
# multiprocessing.set_start_method.__name__.__len__()                                 == 16
# multiprocessing.set_start_method.__module__.__eq__('multiprocessing.context')       == True
# multiprocessing.set_start_method.__qualname__.__eq__('DefaultContext.set_start_method') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra167.mp_set_start_method_identity:
  description: "multiprocessing.set_start_method bound method name, module, and qualname identity checks in mpsetstart167 namespace — multiprocessing.set_start_method.__name__.__eq__('set_start_method')==True (set_start_method.__name__=='set_start_method' (len=16: 'set'=3+'_'=1+'start'=5+'_'=1+'method'=6=16); multiprocessing.set_start_method(method, force=False) sets the start method for creating child processes: 'fork' (default on Unix), 'spawn' (default on Windows and macOS), or 'forkserver'; must be called in the if __name__ == '__main__' guard; can only be called once per program unless force=True); multiprocessing.set_start_method.__name__.__len__()==16 ('set_start_method'=16: same length as get_start_method=16 — both are 16-char names with the same '_start_method' suffix, differing only in 'set' vs 'get' prefix); multiprocessing.set_start_method.__module__.__eq__('multiprocessing.context')==True (__module__=='multiprocessing.context' (len=23)); KEY: multiprocessing.set_start_method.__qualname__.__eq__('DefaultContext.set_start_method')==True (__qualname__=='DefaultContext.set_start_method' (len=31: 'DefaultContext'=14+'.'=1+'set_start_method'=16=31; set_start_method is on DefaultContext — only the default context can change the start method; non-default contexts (fork, spawn, forkserver) are fixed)); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsetstart167

  columns: [id, function, args, expected, description]
  rows:
    - [ssm_name_eq,      multiprocessing.set_start_method.__name__.__eq__,     ["set_start_method"],                true,  "set_start_method.__name__ == 'set_start_method' (len=16: 'set'=3+'_start_method'=13=16); verified with Python 3.14.3"]
    - [ssm_name_len,     multiprocessing.set_start_method.__name__.__len__,    [],                                  16,    "set_start_method.__name__.__len__() == 16 (same as get_start_method=16; differ only in set vs get prefix); verified with Python 3.14.3"]
    - [ssm_mod_eq,       multiprocessing.set_start_method.__module__.__eq__,   ["multiprocessing.context"],         true,  "set_start_method.__module__ == 'multiprocessing.context' (len=23; same as cpu_count module); verified with Python 3.14.3"]
    - [ssm_qualname_eq,  multiprocessing.set_start_method.__qualname__.__eq__, ["DefaultContext.set_start_method"], true,  "set_start_method.__qualname__ == 'DefaultContext.set_start_method' (len=31; defined on DefaultContext); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.get_start_method bound method identity — extra167
#
# multiprocessing.get_start_method.__name__.__eq__('get_start_method')                == True
# multiprocessing.get_start_method.__name__.__len__()                                 == 16
# multiprocessing.get_start_method.__module__.__eq__('multiprocessing.context')       == True
# multiprocessing.get_start_method.__qualname__.__eq__('DefaultContext.get_start_method') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra167.mp_get_start_method_identity:
  description: "multiprocessing.get_start_method bound method name, module, and qualname identity checks in mpgetstart167 namespace — multiprocessing.get_start_method.__name__.__eq__('get_start_method')==True (get_start_method.__name__=='get_start_method' (len=16: 'get'=3+'_'=1+'start'=5+'_'=1+'method'=6=16; same length as set_start_method=16); multiprocessing.get_start_method(allow_none=False) returns the current start method as a string ('fork', 'spawn', or 'forkserver'); returns None if allow_none=True and no method has been set; get_start_method is a counterpart to set_start_method); multiprocessing.get_start_method.__name__.__len__()==16 ('get_start_method'=16 == set_start_method=16; LENGTH EQUALITY: get_ and set_ variants share the same 16-char name length because both 'get'=3 and 'set'=3 are 3-char prefixes with the same '_start_method'=13 suffix); multiprocessing.get_start_method.__module__.__eq__('multiprocessing.context')==True (__module__=='multiprocessing.context' (len=23; same as set_start_method and cpu_count)); multiprocessing.get_start_method.__qualname__.__eq__('DefaultContext.get_start_method')==True (__qualname__=='DefaultContext.get_start_method' (len=31: same as set_start_method qualname len=31; both defined on DefaultContext)); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpgetstart167

  columns: [id, function, args, expected, description]
  rows:
    - [gsm_name_eq,      multiprocessing.get_start_method.__name__.__eq__,     ["get_start_method"],                true,  "get_start_method.__name__ == 'get_start_method' (len=16: same as set_start_method=16); verified with Python 3.14.3"]
    - [gsm_name_len,     multiprocessing.get_start_method.__name__.__len__,    [],                                  16,    "get_start_method.__name__.__len__() == 16 (same as set_start_method=16; 'get'=3=='set'=3 in length); verified with Python 3.14.3"]
    - [gsm_mod_eq,       multiprocessing.get_start_method.__module__.__eq__,   ["multiprocessing.context"],         true,  "get_start_method.__module__ == 'multiprocessing.context' (len=23; same as set_start_method module); verified with Python 3.14.3"]
    - [gsm_qualname_eq,  multiprocessing.get_start_method.__qualname__.__eq__, ["DefaultContext.get_start_method"], true,  "get_start_method.__qualname__ == 'DefaultContext.get_start_method' (len=31; same as set_start_method qualname len=31); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.get_context bound method identity — extra167
#
# multiprocessing.get_context.__name__.__eq__('get_context')                     == True
# multiprocessing.get_context.__name__.__len__()                                 == 11
# multiprocessing.get_context.__module__.__eq__('multiprocessing.context')       == True
# multiprocessing.get_context.__qualname__.__eq__('DefaultContext.get_context')  == True
# ---------------------------------------------------------------------------

table multiprocessing_extra167.mp_get_context_identity:
  description: "multiprocessing.get_context bound method name, module, and qualname identity checks in mpgetctx167 namespace — multiprocessing.get_context.__name__.__eq__('get_context')==True (get_context.__name__=='get_context' (len=11: 'get'=3+'_'=1+'context'=7=11); multiprocessing.get_context(method=None) returns a context object with the specified start method; get_context('fork') returns a fork context, get_context('spawn') returns a spawn context; the returned context object has the same methods as the multiprocessing module (Process, Queue, Pipe, etc.) but creates objects using the specified start method; get_context is the recommended API for library code that needs a specific start method without changing the global setting); multiprocessing.get_context.__name__.__len__()==11 ('get_context'=11; compare: cpu_count=9 is 2 shorter; get_start_method=set_start_method=16 are 5 longer); multiprocessing.get_context.__module__.__eq__('multiprocessing.context')==True (__module__=='multiprocessing.context' (len=23)); multiprocessing.get_context.__qualname__.__eq__('DefaultContext.get_context')==True (__qualname__=='DefaultContext.get_context' (len=26: 'DefaultContext'=14+'.'=1+'get_context'=11=26)); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpgetctx167

  columns: [id, function, args, expected, description]
  rows:
    - [gc_name_eq,      multiprocessing.get_context.__name__.__eq__,     ["get_context"],                true,  "get_context.__name__ == 'get_context' (len=11: 'get'=3+'_context'=8=11); verified with Python 3.14.3"]
    - [gc_name_len,     multiprocessing.get_context.__name__.__len__,    [],                             11,    "get_context.__name__.__len__() == 11 (cpu_count=9 < get_context=11 < get/set_start_method=16); verified with Python 3.14.3"]
    - [gc_mod_eq,       multiprocessing.get_context.__module__.__eq__,   ["multiprocessing.context"],    true,  "get_context.__module__ == 'multiprocessing.context' (len=23; same as all context methods); verified with Python 3.14.3"]
    - [gc_qualname_eq,  multiprocessing.get_context.__qualname__.__eq__, ["DefaultContext.get_context"], true,  "get_context.__qualname__ == 'DefaultContext.get_context' (len=26: DefaultContext=14+.+get_context=11=26); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra167
# ---------------------------------------------------------------------------

invariant multiprocessing_extra167.mp_cpu_count_name_eq:
  description: "multiprocessing.cpu_count.__name__.__eq__('cpu_count') returns True — multiprocessing.cpu_count.__name__=='cpu_count' (len=9: 'cpu'=3+'_'=1+'count'=5=9); multiprocessing.cpu_count() returns os.cpu_count() — the number of CPUs in the system including logical CPUs (hyperthreading cores); on systems where cpu count cannot be determined, it raises NotImplementedError; cpu_count is a BOUND METHOD on the default context object (BaseContext); cpu_count.__qualname__=='BaseContext.cpu_count' (len=21: 'BaseContext'=11+'.'=1+'cpu_count'=9=21) — defined in BaseContext because CPU count is context-independent (all context types report the same count); compare: multiprocessing.Value.__qualname__=='BaseContext.Value' (from extra166; len=17) — both Value and cpu_count are BaseContext methods but cpu_count's qualname is 4 chars longer: 'cpu_count'=9 > 'Value'=5 by 4, accounting for all the difference in qualname lengths (21 vs 17); cpu_count.__module__=='multiprocessing.context' (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23; same total length as multiprocessing.process=23 from extra166 because 'context'=7=='process'=7 in length); NEW in extra167: first standalone cpu_count.__name__ identity invariant in mpcpucount167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.cpu_count.__name__.__eq__
  args: ["cpu_count"]
  expected: true

invariant multiprocessing_extra167.mp_cpu_count_qualname_eq:
  description: "multiprocessing.cpu_count.__qualname__.__eq__('BaseContext.cpu_count') returns True — multiprocessing.cpu_count.__qualname__=='BaseContext.cpu_count' (len=21: 'BaseContext'=11+'.'=1+'cpu_count'=9=21); cpu_count is defined in BaseContext (the common base class for all multiprocessing context types: ForkContext, SpawnContext, ForkServerContext, and DefaultContext); because all context types inherit from BaseContext, cpu_count is available via any context object; compare: multiprocessing.set_start_method.__qualname__=='DefaultContext.set_start_method' (len=31: from extra167 — set_start_method is on DefaultContext, NOT BaseContext, because set_start_method allows changing the global start method which is only meaningful on the default context); compare: multiprocessing.Value.__qualname__=='BaseContext.Value' (from extra166; len=17) — Value is also on BaseContext; VALUE QUALNAME LENGTH: cpu_count(21) > Value(17) by 4 ('cpu_count'=9 > 'Value'=5 by 4); DEFAULTCONTEXT vs BASECONTEXT: cpu_count and Value are on BaseContext; set_start_method, get_start_method, get_context are on DefaultContext — reflecting that start-method control is only for the default (mutable) context; NEW in extra167: first standalone cpu_count.__qualname__ identity invariant in mpcpucount167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.cpu_count.__qualname__.__eq__
  args: ["BaseContext.cpu_count"]
  expected: true

invariant multiprocessing_extra167.mp_set_start_method_name_eq:
  description: "multiprocessing.set_start_method.__name__.__eq__('set_start_method') returns True — multiprocessing.set_start_method.__name__=='set_start_method' (len=16: 'set'=3+'_'=1+'start'=5+'_'=1+'method'=6=16); multiprocessing.set_start_method(method, force=False) is the global setter for the child process start method; valid values are 'fork' (POSIX default), 'spawn' (Windows/macOS default), or 'forkserver'; must be called inside if __name__ == '__main__' to avoid recursive spawning; set_start_method.__qualname__=='DefaultContext.set_start_method' (len=31: 'DefaultContext'=14+'.'=1+'set_start_method'=16=31); KEY: set_start_method is on DefaultContext (not BaseContext) — only the mutable default context allows changing the start method; fixed contexts (ForkContext, SpawnContext) do not expose set_start_method; compare: multiprocessing.get_start_method.__name__=='get_start_method' (len=16: same length — both 16-char names; 'set'=3=='get'=3 in prefix length); LENGTH ORDERING for context methods: cpu_count(9) < get_context(11) < set_start_method=get_start_method(16); NEW in extra167: first standalone set_start_method.__name__ identity invariant in mpsetstart167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.set_start_method.__name__.__eq__
  args: ["set_start_method"]
  expected: true

invariant multiprocessing_extra167.mp_set_start_method_module_eq:
  description: "multiprocessing.set_start_method.__module__.__eq__('multiprocessing.context') returns True — multiprocessing.set_start_method.__module__=='multiprocessing.context' (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23); all four context bound methods (cpu_count, set_start_method, get_start_method, get_context) share __module__=='multiprocessing.context' because they are all defined in Lib/multiprocessing/context.py; 'multiprocessing.context' (len=23) equals 'multiprocessing.process' (len=23) from extra166 — both submodule names are 7 chars ('context'=7=='process'=7) giving the same 23-char total module path; set_start_method.__module__ == get_start_method.__module__ == cpu_count.__module__ == get_context.__module__ == 'multiprocessing.context' — module equality for all four context bound methods; compare: 'multiprocessing.managers'=24 is 1 longer than 'multiprocessing.context'=23 because 'managers'=8 > 'context'=7 by 1; NEW in extra167: first standalone set_start_method.__module__ identity invariant in mpsetstart167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.set_start_method.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra167.mp_get_start_method_name_eq:
  description: "multiprocessing.get_start_method.__name__.__eq__('get_start_method') returns True — multiprocessing.get_start_method.__name__=='get_start_method' (len=16: 'get'=3+'_'=1+'start'=5+'_'=1+'method'=6=16); multiprocessing.get_start_method(allow_none=False) returns the current start method string ('fork', 'spawn', or 'forkserver') or None if allow_none=True and no start method has been explicitly set; get_start_method is the read counterpart to set_start_method; get_start_method.__qualname__=='DefaultContext.get_start_method' (len=31: same qualname length as set_start_method=31 because 'DefaultContext'=14 is the shared prefix and 'get_start_method'=16=='set_start_method'=16 in length); KEY LENGTH EQUALITY: get_start_method.__name__.__len__()==16 == set_start_method.__name__.__len__()==16 (the names are symmetric: 'get' prefix vs 'set' prefix, both 3 chars; '_start_method'=13 is the shared 13-char suffix); compare: cpu_count(9) < get_context(11) < get_start_method=set_start_method(16) in method name length ordering; NEW in extra167: first standalone get_start_method.__name__ identity invariant in mpgetstart167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.get_start_method.__name__.__eq__
  args: ["get_start_method"]
  expected: true

invariant multiprocessing_extra167.mp_get_context_name_eq:
  description: "multiprocessing.get_context.__name__.__eq__('get_context') returns True — multiprocessing.get_context.__name__=='get_context' (len=11: 'get'=3+'_'=1+'context'=7=11); multiprocessing.get_context(method=None) returns a context object for the specified start method without changing the global default; library code should prefer get_context() over set_start_method() to avoid interfering with user code that may set its own start method; the returned context object has the same API as the multiprocessing module top-level (Process, Queue, Pipe, Lock, etc.) but all objects use the specified start method; get_context.__qualname__=='DefaultContext.get_context' (len=26: 'DefaultContext'=14+'.'=1+'get_context'=11=26); compare qualname lengths: cpu_count qualname=21, get_context qualname=26, set_start_method=get_start_method qualname=31 — all DefaultContext/BaseContext methods have qualname length = 'BaseContext'=11 or 'DefaultContext'=14 as the prefix plus dot plus method name; LENGTH ORDERING for method names: cpu_count(9) < get_context(11) < get_start_method=set_start_method(16); NEW in extra167: first standalone get_context.__name__ identity invariant in mpgetctx167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.get_context.__name__.__eq__
  args: ["get_context"]
  expected: true

invariant multiprocessing_extra167.mp_get_context_qualname_eq:
  description: "multiprocessing.get_context.__qualname__.__eq__('DefaultContext.get_context') returns True — multiprocessing.get_context.__qualname__=='DefaultContext.get_context' (len=26: 'DefaultContext'=14+'.'=1+'get_context'=11=26); get_context is defined on DefaultContext — the singleton default context that backs all the top-level multiprocessing functions; compare: cpu_count.__qualname__=='BaseContext.cpu_count' (len=21: on BaseContext — cpu_count is context-type-independent); compare: set_start_method.__qualname__=='DefaultContext.set_start_method' (len=31: on DefaultContext — only the mutable default context allows setting the method); QUALNAME LENGTH ORDERING: Value(17) < cpu_count(21) < get_context(26) < set_start_method=get_start_method(31) — ordered by method name length since the class prefix changes: BaseContext(11) for cpu_count/Value vs DefaultContext(14) for get_context/set_start_method/get_start_method; get_context qualname len(26) == 'DefaultContext'=14+'.'=1+'get_context'=11=26; NEW in extra167: first standalone get_context.__qualname__ identity invariant in mpgetctx167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.get_context.__qualname__.__eq__
  args: ["DefaultContext.get_context"]
  expected: true
