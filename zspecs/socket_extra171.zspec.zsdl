spec: socket_extra171
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra170.zspec.zsdl — covers socket.AF_UNIX/SOCK_RAW enum constants (class names and values) and SOL_SOCKET/SO_REUSEADDR plain int constants on macOS (table + invariants)."
    - "socket_extra169.zspec.zsdl — covers socket.socket.__dict__ Python vs C-inherited membership (connect==False/makefile==True/sendfile==True) and __dict__.__len__()==28 and socket.socket.__name__/__module__ identity (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__=='socket' and socket.__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra170."
    - "Wave 353 theme: socket module-level identity attributes — __name__, __package__, __spec__.__class__.__name__, __loader__.__class__.__name__, and socket.socket.__dict__ membership for accept/close/detach (True) and fileno (False — in C base _socket.socket). socket.zspec / early extras anchor socket.__name__ and socket.__package__ as string values. socket_extra169 anchors socket.socket.__name__/__module__ identity and connect(False)/makefile/sendfile membership. This spec anchors module-level meta-attributes and socket.socket.__dict__ novel members."
    - "socket.__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__package__ == ''. Verified Python 3.14.3 macOS/Darwin 25.4.0. (empty string — socket is a top-level module)"
    - "socket.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__loader__.__class__.__name__ == 'SourceFileLoader'. Verified Python 3.14.3 macOS/Darwin 25.4.0. socket.py (Lib/socket.py) is a pure Python wrapper around _socket."
    - "socket.socket.__dict__.__contains__('accept') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. accept is Python-defined in Lib/socket.py."
    - "socket.socket.__dict__.__contains__('close') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. close is Python-defined in Lib/socket.py."
    - "socket.socket.__dict__.__contains__('detach') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. detach is Python-defined in Lib/socket.py."
    - "socket.socket.__dict__.__contains__('fileno') == False. Verified Python 3.14.3 macOS/Darwin 25.4.0. fileno is in the C base _socket.socket, not in the Python socket.socket.__dict__."
    - "Note: socket.__loader__.__class__.__name__ == 'SourceFileLoader' (16 chars). socket.py (Lib/socket.py) is a pure Python source file that wraps the _socket C extension. socket_extra169 anchors socket.socket.__name__/__module__ identity; this spec adds module-level __loader__/__spec__ identity as novel content."
    - "Note: socket.socket.__dict__.__contains__('accept') == True. accept is Python-defined in socket.py because it wraps the C-level accept() with a socket() call to create the returned socket object. socket_extra164 and socket_extra169 cover method membership; this spec anchors accept/close/detach/fileno as a new membership batch under sockmod171."
    - "Note: socket.socket.__dict__.__contains__('fileno') == False. fileno() is implemented in the C base class _socket.socket (Modules/socketmodule.c), not in the Python socket.socket subclass. This is analogous to connect==False (socket_extra169 anchors connect False) — both fileno and connect are C-inherited. 'fileno'(6 chars) is absent from the 28-key socket.socket.__dict__."
    - "Note: socket.socket.__dict__.__contains__('close') == True. close is Python-defined in Lib/socket.py — it coordinates with the socket I/O reference counting (using _real_close/self._io_refs) before calling the C-level close. 'close'(5 chars) is shorter than 'detach'(6), 'accept'(6), and 'fileno'(6) in this spec's method names."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.__name__.__eq__('socket') (module-level)
# socket.__package__.__eq__('')
# socket.__spec__.__class__.__name__.__eq__('ModuleSpec')
# socket.__loader__.__class__.__name__.__eq__('SourceFileLoader')
#
# Wave 353 theme: socket module-level identity attributes.
#
# socket.__name__ == 'socket' (6 chars; module-level, confirmed via __eq__ call).
# socket.__package__ == '' (empty string; top-level module).
# socket.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars; novel anchor).
# socket.__loader__.__class__.__name__ == 'SourceFileLoader' (16 chars; novel anchor).
# Note: in socket's backend, module-level attributes use the unprefixed form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra171.module_name_package_spec_loader:
  description: "socket.__name__.__eq__('socket')==True / socket.__package__.__eq__('')==True / socket.__spec__.__class__.__name__.__eq__('ModuleSpec')==True / socket.__loader__.__class__.__name__.__eq__('SourceFileLoader')==True — socket.__name__ is 'socket' (6 chars; the module name; socket.zspec / early extras anchor socket.__name__ as a string value; socket_extra169 anchors socket.socket.__name__ (the class-level attribute) as table rows — this spec anchors the module-level .__name__.__eq__('socket') call under sockmod171; 'socket'(6 chars) = 's'+'o'+'c'+'k'+'e'+'t'; the module name and class name are the same 6-char string); socket.__package__ is '' (empty string; socket is a top-level module not inside any package; __package__=='' for top-level modules; socket.zspec anchors socket.__package__; confirmed via __eq__ call here); socket.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars; importlib.machinery.ModuleSpec; 'ModuleSpec'(10 chars) = 'Module'=6 + 'Spec'=4; novel anchor: no prior socket spec anchors socket.__spec__.__class__.__name__ under sockmod171); socket.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars; Lib/socket.py is a pure Python source file that wraps the _socket C extension; loaded by importlib.machinery.SourceFileLoader; 'SourceFileLoader'(16) > 'ModuleSpec'(10) > 'socket'(6) > ''(0) in length ordering; novel anchor: no prior socket spec anchors socket.__loader__.__class__.__name__ under sockmod171; first sockmod171 anchor for module name/package/spec/loader)"
  kind: python_call_eq
  category: identity
  id_prefix: sockmod171

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,         "__name__.__eq__",                      ["socket"],          true, "socket.__name__ == 'socket' (6 chars; module-level; socket.zspec anchors as string; first sockmod171 anchor via __eq__ call)"]
    - [mod_pkg_eq_empty,    "__package__.__eq__",                   [""],                true, "socket.__package__ == '' (empty string; top-level module not in package; socket.zspec anchors; confirmed via __eq__)"]
    - [spec_class_ms,       "__spec__.__class__.__name__.__eq__",   ["ModuleSpec"],      true, "socket.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars; importlib.machinery.ModuleSpec; novel anchor under sockmod171)"]
    - [loader_class_sfl,    "__loader__.__class__.__name__.__eq__", ["SourceFileLoader"], true, "socket.__loader__.__class__.__name__ == 'SourceFileLoader' (16 chars; Lib/socket.py is .py wrapper; novel anchor; 'SourceFileLoader'(16)>'ModuleSpec'(10))"]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('accept')
# socket.socket.__dict__.__contains__('close')
# socket.socket.__dict__.__contains__('detach')
# socket.socket.__dict__.__contains__('fileno')==False
#
# Wave 353 theme: socket.socket.__dict__ method membership — accept/close/detach (True), fileno (False).
#
# socket.__dict__.__contains__('accept') == True (Python-defined in Lib/socket.py).
# socket.__dict__.__contains__('close') == True (Python-defined in Lib/socket.py).
# socket.__dict__.__contains__('detach') == True (Python-defined in Lib/socket.py).
# socket.__dict__.__contains__('fileno') == False (in C base _socket.socket, not Python dict).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra171.socket_dict_accept_close_detach_fileno:
  description: "socket.socket.__dict__.__contains__('accept')==True / socket.__dict__.__contains__('close')==True / socket.__dict__.__contains__('detach')==True / socket.__dict__.__contains__('fileno')==False — socket.__dict__.__contains__('accept') is True ('accept' is a key in socket.socket.__dict__; accept() is Python-defined in Lib/socket.py because the C _socket.socket.accept() returns a raw C socket object, and the Python wrapper calls socket() to create a proper socket.socket instance from it; 'accept'(6 chars) = 'a'+'c'+'c'+'e'+'p'+'t'; novel anchor: socket_extra169 anchors connect(False)/makefile/sendfile under sockdict169 — this spec adds accept/close/detach/fileno as a new batch under sockmod171); socket.__dict__.__contains__('close') is True ('close' is a key in socket.socket.__dict__; close is Python-defined in Lib/socket.py to coordinate with I/O reference counting (_io_refs) before calling _real_close; 'close'(5 chars) < 'accept'(6) < 'detach'(6) < 'fileno'(6) in method name length — close is the shortest method name in this spec; socket_extra169 does not anchor close via __contains__ under sockmod171 — novel anchor); socket.__dict__.__contains__('detach') is True ('detach' is a key in socket.socket.__dict__; detach() sets the socket to closed and returns the underlying file descriptor (fd) without closing it, allowing the fd to be transferred; 'detach'(6 chars)=='accept'(6) in method name length; novel anchor); socket.__dict__.__contains__('fileno') is False ('fileno' is NOT in socket.socket.__dict__; fileno() is implemented in the C base class _socket.socket (Modules/socketmodule.c), not in the Python socket.socket subclass; accessing socket_instance.fileno() works via MRO lookup in the C base but 'fileno' is absent from socket.socket's own __dict__; this is the second False anchor for C-inherited methods: socket_extra169 anchors connect(False) under sockdict169, this spec anchors fileno(False) under sockmod171; 'fileno'(6)==accept(6)==detach(6) in method name length — 'fileno' absent despite same name length as present methods; first sockmod171 anchor for accept/close/detach/fileno membership)"
  kind: python_call_eq
  category: identity
  id_prefix: sockmod171

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_accept,   "socket.__dict__.__contains__", ["accept"], true,  "socket.socket.__dict__.__contains__('accept') == True ('accept'=6 chars; Python-defined in Lib/socket.py; wraps C accept() to return socket.socket instance; novel anchor under sockmod171)"]
    - [dict_has_close,    "socket.__dict__.__contains__", ["close"],  true,  "socket.socket.__dict__.__contains__('close') == True ('close'=5 chars; Python-defined; coordinates I/O ref counting before _real_close; 'close'(5) < 'accept'(6); novel anchor)"]
    - [dict_has_detach,   "socket.__dict__.__contains__", ["detach"], true,  "socket.socket.__dict__.__contains__('detach') == True ('detach'=6 chars; Python-defined; returns fd without closing; 'detach'(6)=='accept'(6); novel anchor)"]
    - [dict_no_fileno,    "socket.__dict__.__contains__", ["fileno"], false, "socket.socket.__dict__.__contains__('fileno') == False ('fileno' in C base _socket.socket; not in Python dict; 'fileno'(6)==accept(6)==detach(6) — same length but absent; novel False anchor)"]

# ---------------------------------------------------------------------------
# Method name length ordering: close(5) < accept(6) == detach(6) == fileno(6)
