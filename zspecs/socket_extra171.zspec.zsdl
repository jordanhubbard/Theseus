# ---------------------------------------------------------------------------
# socket.__name__.__eq__('socket') (module-level) — standalone
#
# socket.__name__ is 'socket' (6 chars). socket is the Python networking module providing
# the socket interface. socket.zspec / early extras anchor socket.__name__ as a string value;
# this standalone anchors the module-level __name__ via __eq__ call under sockmod171.
# Note: socket_extra169 anchors socket.socket.__name__.__eq__('socket') (class-level attribute);
# this anchors the module-level socket.__name__.__eq__('socket') as a distinct fresh anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra171.mod_name_eq_socket:
  description: "socket.__name__.__eq__('socket') == True — 'socket' (6 chars; module-level attribute; socket.zspec anchors socket.__name__ as string value; socket_extra169 anchors socket.socket.__name__.__eq__('socket') for the class-level attribute — this spec anchors the module-level __name__.__eq__('socket') call under sockmod171; the socket module and socket.socket class share the same 6-char name 'socket'; first sockmod171 standalone for socket.__name__.__eq__('socket') at module level"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__package__.__eq__('') — standalone
#
# socket.__package__ is '' (empty string). socket is a top-level module not in any package.
# For top-level modules, Python sets __package__ to the empty string ''. socket.zspec /
# early extras anchor socket.__package__; this standalone anchors via __eq__ call under
# sockmod171. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra171.mod_package_eq_empty:
  description: "socket.__package__.__eq__('') == True — '' (empty string; socket is a top-level module not in any package; __package__=='' for top-level modules; socket.zspec anchors socket.__package__; confirmed via __eq__ here; socket.__name__(6) >> socket.__package__(0): module name is 6 chars longer than the empty package string; first sockmod171 standalone for socket.__package__.__eq__('')"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# socket.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# socket.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars). Every imported Python module
# has a .__spec__ attribute of type importlib.machinery.ModuleSpec. 'ModuleSpec' (10 chars) =
# 'Module'=6 + 'Spec'=4. Novel: no prior socket spec anchors socket.__spec__.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra171.spec_class_modulespec:
  description: "socket.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — 'ModuleSpec' (10 chars = 'Module'=6 + 'Spec'=4; importlib.machinery.ModuleSpec is the standard descriptor for Python module imports; 'ModuleSpec'(10) > 'socket'(6) by 4 chars; novel anchor: no prior socket spec anchors socket.__spec__.__class__.__name__ under sockmod171; first sockmod171 standalone for socket.__spec__.__class__.__name__.__eq__('ModuleSpec')"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# socket.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars). socket.py is a
# pure Python source file in Lib/socket.py that wraps the _socket C extension. The module
# itself is loaded by importlib.machinery.SourceFileLoader. 'SourceFileLoader' (16 chars) =
# 'Source'=6 + 'File'=4 + 'Loader'=6. Novel anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra171.loader_class_sourcefileloader:
  description: "socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — 'SourceFileLoader' (16 chars = 'Source'=6 + 'File'=4 + 'Loader'=6; Lib/socket.py is a pure Python source file wrapping the _socket C extension; loaded by importlib.machinery.SourceFileLoader; 'SourceFileLoader'(16) > 'ModuleSpec'(10) > 'socket'(6) > 'str'(3) in class name length ordering; novel anchor: no prior socket spec anchors socket.__loader__.__class__.__name__ under sockmod171; first sockmod171 standalone for socket.__loader__.__class__.__name__.__eq__('SourceFileLoader')"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('accept')==True — standalone
#
# socket.socket.__dict__.__contains__('accept') is True. accept is Python-defined in
# Lib/socket.py because the C _socket.socket.accept() returns a raw tuple (fd, addr) and
# the Python wrapper creates a proper socket.socket instance from it. 'accept' (6 chars).
# Novel anchor under sockmod171. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra171.socket_dict_has_accept:
  description: "socket.socket.__dict__.__contains__('accept') == True — 'accept' (6 chars; socket.socket.accept() is Python-defined in Lib/socket.py; it wraps the C base _socket.socket.accept() to return a (socket.socket_instance, address) pair rather than a raw fd; 'accept'(6)==detach'(6)=='fileno'(6) in method name length — yet accept(True) and fileno(False): both 6-char names but different source (Python vs C); socket_extra169 anchors connect(False)/makefile/sendfile under sockdict169; this spec adds accept as a novel anchor under sockmod171; socket.socket.__dict__.__len__()==28; first sockmod171 standalone for socket.socket.__dict__.__contains__('accept')==True"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["accept"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('close')==True — standalone
#
# socket.socket.__dict__.__contains__('close') is True. close is Python-defined in
# Lib/socket.py to coordinate with the socket I/O reference counting (self._io_refs)
# before calling the actual _real_close. 'close' (5 chars) is the shortest method name
# in this spec. Novel anchor under sockmod171.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra171.socket_dict_has_close:
  description: "socket.socket.__dict__.__contains__('close') == True — 'close' (5 chars; socket.socket.close() is Python-defined in Lib/socket.py; it decrements self._io_refs and calls _real_close when refs reach 0; 'close'(5) < 'accept'(6)=='detach'(6)=='fileno'(6) — shortest method name in this spec; 'close'(5) > 'dup'(3)/'type'(4)/'family'(6) among socket.socket.__dict__ public members; socket.socket.__dict__.__len__()==28; novel anchor: socket_extra169 does not anchor close under sockmod171; first sockmod171 standalone for socket.socket.__dict__.__contains__('close')==True"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["close"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('detach')==True — standalone
#
# socket.socket.__dict__.__contains__('detach') is True. detach is Python-defined in
# Lib/socket.py. It marks the socket as closed and returns the underlying file descriptor
# without closing it, allowing the fd to be passed elsewhere. 'detach' (6 chars).
# Novel anchor under sockmod171. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra171.socket_dict_has_detach:
  description: "socket.socket.__dict__.__contains__('detach') == True — 'detach' (6 chars; socket.socket.detach() is Python-defined in Lib/socket.py; it marks the socket as closed (self._closed = True) and returns the underlying file descriptor (self.fileno()) so the caller can take ownership; unlike close(), detach() does NOT close the fd; 'detach'(6)=='accept'(6)==fileno'(6) in method name length; detach(True) contrasts with fileno(False) — both 6-char names but detach is Python-defined while fileno is C-inherited; socket.socket.__dict__.__len__()==28; novel anchor: socket_extra169 does not anchor detach under sockmod171; first sockmod171 standalone for socket.socket.__dict__.__contains__('detach')==True"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["detach"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('fileno')==False — standalone
#
# socket.socket.__dict__.__contains__('fileno') is False. fileno is implemented in the C
# base class _socket.socket (Modules/socketmodule.c), not in the Python socket.socket subclass.
# 'fileno' (6 chars) = same length as accept(6) and detach(6) — yet fileno is absent.
# This is the second False anchor for C-inherited methods: socket_extra169 anchors connect(False).
# Novel anchor under sockmod171. Verified Python 3.14.3 macOS/Darwin 25.4.0.
