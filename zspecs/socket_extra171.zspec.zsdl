# Wave 353 theme: method name lengths for accept/close/detach/fileno.
#
# socket.__dict__.__contains__('close') == True ('close'=5 chars; shortest).
# socket.__dict__.__contains__('accept') == True ('accept'=6 chars).
# socket.__dict__.__contains__('detach') == True ('detach'=6 chars).
# socket.__dict__.__contains__('fileno') == False ('fileno'=6 chars; C-inherited).
# Length ordering: 'close'(5) < 'accept'(6) == 'detach'(6) == 'fileno'(6).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra171.socket_dict_method_name_lengths:
  description: "socket.socket.__dict__.__contains__('close')==True / socket.__dict__.__contains__('accept')==True / socket.__dict__.__contains__('detach')==True / socket.__dict__.__contains__('fileno')==False — socket.__dict__.__contains__('close') is True (confirmed; 'close'=5 chars; shortest method name in this spec: 'close'(5) < 'accept'(6)=='detach'(6)=='fileno'(6); Python-defined method); socket.__dict__.__contains__('accept') is True (confirmed; 'accept'=6 chars; 'accept'(6) > 'close'(5) by 1; three methods share 6 chars: 'accept'=='detach'=='fileno'=6; accept is Python-defined); socket.__dict__.__contains__('detach') is True (confirmed; 'detach'=6 chars; 'detach'(6)=='accept'(6) — tied; detach is Python-defined; the presence of detach(True) alongside fileno(False) shows that same-length names can differ in C vs Python origin); socket.__dict__.__contains__('fileno') is False (confirmed; 'fileno'=6 chars; same 6-char length as accept and detach — yet fileno is absent because it is C-inherited from _socket.socket; length ordering: 'close'(5) < 'accept'(6)=='detach'(6)=='fileno'(6) — fileno matches the length of Python-defined methods but is nonetheless absent; first sockmod171 anchor for combined method name length ordering with True/False contrast)"
  kind: python_call_eq
  category: identity
  id_prefix: sockmod171

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_close_b,   "socket.__dict__.__contains__", ["close"],  true,  "socket.socket.__dict__.__contains__('close') == True (confirmed; 'close'=5 chars; shortest; Python-defined; 'close'(5) < 'accept'/'detach'/'fileno'(6) by 1)"]
    - [dict_has_accept_b,  "socket.__dict__.__contains__", ["accept"], true,  "socket.socket.__dict__.__contains__('accept') == True (confirmed; 'accept'=6 chars; Python-defined; tied with detach/fileno at 6 chars)"]
    - [dict_has_detach_b,  "socket.__dict__.__contains__", ["detach"], true,  "socket.socket.__dict__.__contains__('detach') == True (confirmed; 'detach'=6 chars; Python-defined; 'detach'(True) vs 'fileno'(False) at same length)"]
    - [dict_no_fileno_b,   "socket.__dict__.__contains__", ["fileno"], false, "socket.socket.__dict__.__contains__('fileno') == False (confirmed; 'fileno'=6 chars; C-inherited; same length as accept/detach but absent from Python dict)"]

