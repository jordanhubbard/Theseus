spec: concurrent_futures_extra394
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "ThreadPoolExecutor.submit.__name__ == 'submit'"
    - "ThreadPoolExecutor.map.__name__ == 'map'"
    - "ThreadPoolExecutor.shutdown.__name__ == 'shutdown'"
    - "ProcessPoolExecutor.submit.__name__ == 'submit'"
    - "ProcessPoolExecutor.map.__name__ == 'map'"
    - "ProcessPoolExecutor.shutdown.__name__ == 'shutdown'"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra394.thread_method_names:
  description: "Verify __name__ attribute of ThreadPoolExecutor methods"
  kind: python_call_eq
  category: identity
  id_prefix: cf394t

  columns: [id, function, args, expected]
  rows:
    - [cf394t001, concurrent.futures.ThreadPoolExecutor.submit.__name__.__eq__, ["submit"], true]
    - [cf394t002, concurrent.futures.ThreadPoolExecutor.map.__name__.__eq__, ["map"], true]
    - [cf394t003, concurrent.futures.ThreadPoolExecutor.shutdown.__name__.__eq__, ["shutdown"], true]

table concurrent_futures_extra394.process_method_names:
  description: "Verify __name__ attribute of ProcessPoolExecutor methods"
  kind: python_call_eq
  category: identity
  id_prefix: cf394p

  columns: [id, function, args, expected]
  rows:
    - [cf394p001, concurrent.futures.ProcessPoolExecutor.submit.__name__.__eq__, ["submit"], true]
    - [cf394p002, concurrent.futures.ProcessPoolExecutor.map.__name__.__eq__, ["map"], true]
    - [cf394p003, concurrent.futures.ProcessPoolExecutor.shutdown.__name__.__eq__, ["shutdown"], true]
