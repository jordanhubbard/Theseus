spec: concurrent_futures_extra38
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra37.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__.__class__.__name__.__len__() tables, as_completed/wait __module__.__len__(), __all__.__len__()==14, __mro__.__len__() tables, __bases__[0].__name__.__len__() for all classes, Executor context manager qualname lens, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, map/__qualname__.__len__() for both executors, Future method __name__/__qualname__.__len__() tables, ThreadPoolExecutor submit/shutdown __name__/__qualname__.__len__() tables, InvalidStateError/__name__.__len__()==17, CancelledError/__qualname__.__len__()==14, BrokenExecutor/__name__/__qualname__.__len__()==14, BrokenExecutor/__module__.__len__()==24, CancelledError/__module__.__len__()==24, BrokenExecutor/__bases__[0].__name__.__len__()==12, TimeoutError/__name__/__module__.__len__(), concurrent.futures.__package__.__len__()==18, __spec__.__class__.__name__.__len__()==10, ThreadPoolExecutor/__name__=='ThreadPoolExecutor' (extra36), ProcessPoolExecutor/__name__=='ProcessPoolExecutor' (extra36), executor __module__ string equality checks (extra36), wait/__name__=='wait' (extra36), function __module__ string equality checks (extra36), Executor/__name__=='Executor'/__module__==concurrent.futures._base (extra37), Executor map/submit qualname lengths (extra37), InvalidStateError/BrokenExecutor __name__/__module__ string equality (extra37)."
    - "This spec covers: ProcessPoolExecutor.__bases__[0].__name__=='Executor'; ThreadPoolExecutor.__bases__[0].__name__=='Executor'; Future.__bases__[0].__name__=='object'; CancelledError.__mro__.__len__()==5; InvalidStateError.__mro__.__len__()==5; BrokenExecutor.__mro__.__len__()==5; TimeoutError.__mro__.__len__()==5."
    - "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'. concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'. Both concrete executor implementations inherit directly from the abstract Executor base class. This is the standard Template Method pattern: Executor defines the interface (submit, map, shutdown), and the two concrete subclasses implement it."
    - "concurrent.futures.Future.__bases__[0].__name__ == 'object'. Future does not inherit from any asyncio.Future or other Future class — it is a standalone class rooted directly in object. This is important: concurrent.futures.Future and asyncio.Future are separate class hierarchies."
    - "All four exception classes have __mro__.__len__() == 5. CancelledError MRO: [CancelledError, Error, Exception, BaseException, object]. InvalidStateError MRO: [InvalidStateError, Error, Exception, BaseException, object]. BrokenExecutor MRO: [BrokenExecutor, RuntimeError, Exception, BaseException, object]. TimeoutError MRO: [TimeoutError, OSError, Exception, BaseException, object]. All have depth 5 despite different intermediate classes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures executor base class inheritance — extra38 namespace
#
# Both concrete executors inherit from the abstract Executor class:
#   ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'
#   ThreadPoolExecutor.__bases__[0].__name__  == 'Executor'
#   Future.__bases__[0].__name__              == 'object'
# ProcessPoolExecutor and ThreadPoolExecutor both extend Executor directly.
# Future is a standalone class with no domain-specific base (inherits object).
# Prior specs measured __bases__[0].__name__.__len__() as integers; extra38
# captures string equality checks in this namespace.
# ---------------------------------------------------------------------------

table concurrent_futures_extra38.executor_base_inheritance:
  description: "concurrent.futures executor and Future base class names in extra38 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: cfbaseinher38

  columns: [id, function, args, expected, description]
  rows:
    - [ProcessPoolExecutor_base, "ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"], true, "ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' — inherits from abstract Executor"]
    - [ThreadPoolExecutor_base,  "ThreadPoolExecutor.__bases__[0].__name__.__eq__",  ["Executor"], true, "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' — inherits from abstract Executor"]
    - [Future_base,              "Future.__bases__[0].__name__.__eq__",              ["object"],   true, "Future.__bases__[0].__name__ == 'object' — Future inherits directly from object (no domain base)"]

# ---------------------------------------------------------------------------
# concurrent.futures exception MRO depths — extra38 namespace
#
# All four exception classes have MRO depth 5:
#   CancelledError.__mro__:    [CancelledError, Error, Exception, BaseException, object]
#   InvalidStateError.__mro__: [InvalidStateError, Error, Exception, BaseException, object]
#   BrokenExecutor.__mro__:    [BrokenExecutor, RuntimeError, Exception, BaseException, object]
#   TimeoutError.__mro__:      [TimeoutError, OSError, Exception, BaseException, object]
# All share depth 5 despite having different intermediate classes (Error vs
# RuntimeError vs OSError). This uniformity is structurally notable.
# Prior specs measured __mro__.__len__() for the main class hierarchy tables;
# extra38 focuses specifically on these four exception classes together.
# ---------------------------------------------------------------------------

table concurrent_futures_extra38.exception_mro_depths:
  description: "concurrent.futures exception MRO depths in extra38 namespace — all four exceptions have depth 5"
  kind: python_call_eq
  category: class_names
  id_prefix: cfexcmrolen38

  columns: [id, function, args, expected, description]
  rows:
    - [CancelledError,    CancelledError.__mro__.__len__,    [], 5, "CancelledError.__mro__.__len__() == 5 — MRO: [CancelledError, Error, Exception, BaseException, object]"]
    - [InvalidStateError, InvalidStateError.__mro__.__len__, [], 5, "InvalidStateError.__mro__.__len__() == 5 — MRO: [InvalidStateError, Error, Exception, BaseException, object]"]
    - [BrokenExecutor,    BrokenExecutor.__mro__.__len__,    [], 5, "BrokenExecutor.__mro__.__len__() == 5 — MRO: [BrokenExecutor, RuntimeError, Exception, BaseException, object]"]
    - [TimeoutError,      TimeoutError.__mro__.__len__,      [], 5, "TimeoutError.__mro__.__len__() == 5 — MRO: [TimeoutError, OSError, Exception, BaseException, object]"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra38
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra38.ProcessPoolExecutor_bases0_name_eq:
  description: "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' — ProcessPoolExecutor directly extends the abstract Executor base class"
  category: class_names
  kind: python_call_eq
  function: "ProcessPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra38.ThreadPoolExecutor_bases0_name_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' — ThreadPoolExecutor directly extends the abstract Executor base class"
  category: class_names
  kind: python_call_eq
  function: "ThreadPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra38.Future_bases0_name_eq:
  description: "concurrent.futures.Future.__bases__[0].__name__ == 'object' — Future is a standalone class that inherits directly from object, not from any asyncio or domain-specific Future"
  category: class_names
  kind: python_call_eq
  function: "Future.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant concurrent_futures_extra38.CancelledError_mro_len:
  description: "concurrent.futures.CancelledError.__mro__.__len__() == 5 — MRO is [CancelledError, Error, Exception, BaseException, object]"
  category: class_names
  kind: python_call_eq
  function: CancelledError.__mro__.__len__
  args: []
  expected: 5

invariant concurrent_futures_extra38.InvalidStateError_mro_len:
  description: "concurrent.futures.InvalidStateError.__mro__.__len__() == 5 — MRO is [InvalidStateError, Error, Exception, BaseException, object]"
  category: class_names
  kind: python_call_eq
  function: InvalidStateError.__mro__.__len__
  args: []
  expected: 5

invariant concurrent_futures_extra38.BrokenExecutor_mro_len:
  description: "concurrent.futures.BrokenExecutor.__mro__.__len__() == 5 — MRO is [BrokenExecutor, RuntimeError, Exception, BaseException, object]"
  category: class_names
  kind: python_call_eq
  function: BrokenExecutor.__mro__.__len__
  args: []
  expected: 5

invariant concurrent_futures_extra38.TimeoutError_mro_len:
  description: "concurrent.futures.TimeoutError.__mro__.__len__() == 5 — MRO is [TimeoutError, OSError, Exception, BaseException, object]"
  category: class_names
  kind: python_call_eq
  function: TimeoutError.__mro__.__len__
  args: []
  expected: 5
