spec: syslog
version: ">=3.2"
backend: python_module(syslog)

docs: https://docs.python.org/3/library/syslog.html

provenance:
  derived_from:
    - "Python syslog documentation — https://docs.python.org/3/library/syslog.html"
    - "POSIX syslog(3) man page — https://pubs.opengroup.org/onlinepubs/9699919799/functions/syslog.html"
    - "Test vectors verified by running Python 3.14.3 syslog module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/syslogmodule.c"
  notes:
    - "syslog is a POSIX-only module available on macOS, Linux, and FreeBSD; not available on Windows."
    - "Priority constants (LOG_EMERG through LOG_DEBUG) are standardized by POSIX and identical across platforms."
    - "Facility constant LOG_KERN == 0 is standardized; LOG_USER == 8 and LOG_DAEMON == 24 are also POSIX-standard."
    - "LOG_MASK and LOG_UPTO are helper functions for constructing log masks, not integer constants."
    - "syslog.syslog() writes directly to the system log; openlog/closelog manage the connection."
    - "All expected values verified by running Python 3.14.3 syslog module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "syslog functions raise OSError on underlying system call failure"
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table syslog.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [syslog,      syslog.__name__.__eq__,      ["syslog"],      true]
    - [openlog,     openlog.__name__.__eq__,     ["openlog"],     true]
    - [closelog,    closelog.__name__.__eq__,    ["closelog"],    true]
    - [setlogmask,  setlogmask.__name__.__eq__,  ["setlogmask"],  true]
    - [log_mask,    LOG_MASK.__name__.__eq__,    ["LOG_MASK"],    true]
    - [log_upto,    LOG_UPTO.__name__.__eq__,    ["LOG_UPTO"],    true]

# ---------------------------------------------------------------------------
# Priority constants — standardized POSIX values
# ---------------------------------------------------------------------------

table syslog.priority_constants:
  kind: python_call_eq
  category: constants
  id_prefix: prio

  columns: [id, description, function, args, expected]
  rows:
    - [emerg,   "syslog.LOG_EMERG == 0 — highest priority: system is unusable",       LOG_EMERG.__eq__,   [0], true]
    - [alert,   "syslog.LOG_ALERT == 1 — action must be taken immediately",           LOG_ALERT.__eq__,   [1], true]
    - [crit,    "syslog.LOG_CRIT == 2 — critical condition",                          LOG_CRIT.__eq__,    [2], true]
    - [err,     "syslog.LOG_ERR == 3 — error condition",                              LOG_ERR.__eq__,     [3], true]
    - [warning, "syslog.LOG_WARNING == 4 — warning condition",                        LOG_WARNING.__eq__, [4], true]
    - [notice,  "syslog.LOG_NOTICE == 5 — normal but significant condition",          LOG_NOTICE.__eq__,  [5], true]
    - [info,    "syslog.LOG_INFO == 6 — informational message",                       LOG_INFO.__eq__,    [6], true]
    - [debug,   "syslog.LOG_DEBUG == 7 — debug-level message",                        LOG_DEBUG.__eq__,   [7], true]

# ---------------------------------------------------------------------------
# Facility constants — standardized POSIX values
# ---------------------------------------------------------------------------

invariant syslog.LOG_KERN.value:
  description: "syslog.LOG_KERN == 0 — kernel messages facility"
  category: constants
  kind: python_call_eq
  function: LOG_KERN.__eq__
  args: [0]
  expected: true

invariant syslog.LOG_USER.value:
  description: "syslog.LOG_USER == 8 — user-level messages facility"
  category: constants
  kind: python_call_eq
  function: LOG_USER.__eq__
  args: [8]
  expected: true

invariant syslog.LOG_DAEMON.value:
  description: "syslog.LOG_DAEMON == 24 — system daemons facility"
  category: constants
  kind: python_call_eq
  function: LOG_DAEMON.__eq__
  args: [24]
  expected: true

