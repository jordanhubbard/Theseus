  notes:
    - "This spec covers: itertools.starmap and itertools.zip_longest class attributes — __name__, __module__, __doc__.__class__.__name__, __bases__[0].__name__."
    - "itertools.starmap.__name__ == 'starmap' — starmap is a C extension type in Modules/itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.starmap.__module__ == 'itertools' — starmap is defined in the itertools C extension; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.starmap.__doc__.__class__.__name__ == 'str' — the docstring is a plain Python string (str). Verified with Python 3.14.3."
    - "itertools.starmap.__bases__[0].__name__ == 'object' — starmap inherits directly from object with no intermediary. Verified with Python 3.14.3."
    - "itertools.zip_longest.__name__ == 'zip_longest' — zip_longest is a C extension type in Modules/itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.zip_longest.__module__ == 'itertools' — zip_longest is defined in the itertools C extension; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.zip_longest.__doc__.__class__.__name__ == 'str' — the docstring is a plain Python string (str). Verified with Python 3.14.3."
    - "itertools.zip_longest.__bases__[0].__name__ == 'object' — zip_longest inherits directly from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.starmap identity — __name__, __module__, __qualname__
#
# itertools.starmap.__name__.__eq__('starmap') == True
# itertools.starmap.__module__.__eq__('itertools') == True
# itertools.starmap.__qualname__.__eq__('starmap') == True
#
# starmap is a C extension type defined in Modules/itertoolsmodule.c.
# It applies a function to tuples from an iterable. New to extra198.
# ---------------------------------------------------------------------------

table itertools_extra198.starmap_identity:
  description: "itertools.starmap __name__, __module__, __qualname__; C extension type in itertoolsmodule.c; new to extra198"
  kind: python_call_eq
  category: string_identity
  id_prefix: iterstarmap198

  columns: [id, function, args, expected, description]
  rows:
    - [starmap_name_eq_starmap,
       starmap.__name__.__eq__,
       ["starmap"],
       true,
       "itertools.starmap.__name__.__eq__('starmap') == True — starmap is a C extension type in Modules/itertoolsmodule.c; __name__ is 'starmap'; str.__eq__('starmap') returns True; new to extra198"]
    - [starmap_module_eq_itertools,
       starmap.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.starmap.__module__.__eq__('itertools') == True — starmap is defined in the itertools C extension; __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra198"]
    - [starmap_qualname_eq_starmap,
       starmap.__qualname__.__eq__,
       ["starmap"],
       true,
       "itertools.starmap.__qualname__.__eq__('starmap') == True — starmap is defined at module scope; __qualname__ is the simple type name 'starmap' with no enclosing scope prefix; str.__eq__('starmap') returns True; new to extra198"]

