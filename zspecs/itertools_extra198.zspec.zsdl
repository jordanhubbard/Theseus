# ---------------------------------------------------------------------------
# Table 3: starmap and zip_longest doc class and bases cross-check
#
# itertools.starmap.__doc__.__class__.__name__.__eq__('str') == True
# itertools.starmap.__bases__[0].__name__.__eq__('object') == True
# itertools.zip_longest.__doc__.__class__.__name__.__eq__('str') == True
# itertools.zip_longest.__bases__[0].__name__.__eq__('object') == True
#
# Both types have str docstrings and inherit directly from object.
# __bases__[0].__name__ requires double-quoting since the function path
# contains a '[' bracket. New to extra198.
# ---------------------------------------------------------------------------

