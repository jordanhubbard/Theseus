spec: io_extra9
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl, io_extra.zspec.zsdl, io_extra2.zspec.zsdl, io_extra3.zspec.zsdl, io_extra4.zspec.zsdl, io_extra5.zspec.zsdl, io_extra6.zspec.zsdl, io_extra7.zspec.zsdl, io_extra8.zspec.zsdl."
    - "io_extra.zspec.zsdl covers DEFAULT_BUFFER_SIZE.__class__.__name__=='int'."
    - "io.zspec.zsdl covers DEFAULT_BUFFER_SIZE.__ge__(4096)."
    - "io_extra7.zspec.zsdl covers __name__ for BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, TextIOWrapper, etc."
    - "io_extra8.zspec.zsdl covers IOBase.__name__ and __module__, and __bases__ hierarchy checks."
    - "No prior spec covers __qualname__ for any io class."
    - "io.BytesIO.__qualname__ == 'BytesIO' — module-level class, qualname equals name."
    - "io.StringIO.__qualname__ == 'StringIO' — module-level class, qualname equals name."
    - "io.FileIO.__qualname__ == 'FileIO' — module-level class, qualname equals name."
    - "io.BufferedReader.__qualname__ == 'BufferedReader' — module-level class."
    - "io.BufferedWriter.__qualname__ == 'BufferedWriter' — module-level class."
    - "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — module-level class."
    - "io.IOBase.__qualname__ == 'IOBase' — abstract base class at module level."
    - "io.RawIOBase.__qualname__ == 'RawIOBase' — abstract base class at module level."
    - "io.BufferedIOBase.__qualname__ == 'BufferedIOBase' — abstract base class at module level."
    - "io.TextIOBase.__qualname__ == 'TextIOBase' — abstract base class at module level."
    - "No prior spec checks __mro__ for any io class."
    - "io.IOBase.__mro__.__len__() == 2 — IOBase, object."
    - "io.RawIOBase.__mro__.__len__() == 3 — RawIOBase, IOBase, object."
    - "io.FileIO.__mro__.__len__() == 4 — FileIO, RawIOBase, IOBase, object."
    - "io.BytesIO.__mro__.__len__() == 4 — BytesIO, BufferedIOBase, IOBase, object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for concrete io classes
#
# No prior spec covers __qualname__ for any io class.  For module-level
# classes, __qualname__ equals __name__.
# ---------------------------------------------------------------------------

table io_extra9.concrete_class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [BytesIO,        BytesIO.__qualname__.__eq__,        ["BytesIO"],        true]
    - [StringIO,       StringIO.__qualname__.__eq__,       ["StringIO"],       true]
    - [FileIO,         FileIO.__qualname__.__eq__,         ["FileIO"],         true]
    - [BufferedReader, BufferedReader.__qualname__.__eq__,  ["BufferedReader"],  true]
    - [BufferedWriter, BufferedWriter.__qualname__.__eq__,  ["BufferedWriter"],  true]
    - [BufferedRandom, BufferedRandom.__qualname__.__eq__,  ["BufferedRandom"],  true]
    - [TextIOWrapper,  TextIOWrapper.__qualname__.__eq__,  ["TextIOWrapper"],  true]

# ---------------------------------------------------------------------------
# __qualname__ checks for abstract base classes
# ---------------------------------------------------------------------------

table io_extra9.abc_class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: abc_qualname

  columns: [id, function, args, expected]
  rows:
    - [IOBase,         IOBase.__qualname__.__eq__,         ["IOBase"],         true]
    - [RawIOBase,      RawIOBase.__qualname__.__eq__,      ["RawIOBase"],      true]
    - [BufferedIOBase, BufferedIOBase.__qualname__.__eq__,  ["BufferedIOBase"],  true]
    - [TextIOBase,     TextIOBase.__qualname__.__eq__,     ["TextIOBase"],     true]

# ---------------------------------------------------------------------------
# UnsupportedOperation — __qualname__ check
#
# io_extra7 covers UnsupportedOperation.__name__ and __module__.
# This adds the __qualname__ check.
# ---------------------------------------------------------------------------

invariant io_extra9.UnsupportedOperation.qualname:
  description: "io.UnsupportedOperation.__qualname__ == 'UnsupportedOperation'"
  category: qualnames
  kind: python_call_eq
  function: UnsupportedOperation.__qualname__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

# ---------------------------------------------------------------------------
# __mro__ length checks — MRO (Method Resolution Order) size
#
# No prior spec checks __mro__ for any io class.
# IOBase.__mro__ has 2 entries: IOBase, object.
# RawIOBase.__mro__ has 3: RawIOBase, IOBase, object.
# FileIO.__mro__ has 4: FileIO, RawIOBase, IOBase, object.
# BytesIO.__mro__ has 4: BytesIO, BufferedIOBase, IOBase, object.
# ---------------------------------------------------------------------------

invariant io_extra9.IOBase.mro_len:
  description: "io.IOBase.__mro__.__len__() == 2 — IOBase, object"
  category: mro
  kind: python_call_eq
  function: IOBase.__mro__.__len__
  args: []
  expected: 2

invariant io_extra9.RawIOBase.mro_len:
  description: "io.RawIOBase.__mro__.__len__() == 3 — RawIOBase, IOBase, object"
  category: mro
  kind: python_call_eq
  function: RawIOBase.__mro__.__len__
  args: []
  expected: 3

invariant io_extra9.FileIO.mro_len:
  description: "io.FileIO.__mro__.__len__() == 4 — FileIO, RawIOBase, IOBase, object"
  category: mro
  kind: python_call_eq
  function: FileIO.__mro__.__len__
  args: []
  expected: 4

invariant io_extra9.BytesIO.mro_len:
  description: "io.BytesIO.__mro__.__len__() == 4 — BytesIO, BufferedIOBase, IOBase, object"
  category: mro
  kind: python_call_eq
  function: BytesIO.__mro__.__len__
  args: []
  expected: 4
