spec: multiprocessing_extra1051
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing queue classes documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing.Queue, JoinableQueue, SimpleQueue module identity, weakref descriptor type, and queue method qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1051.queue_module_identity:
  description: "multiprocessing queue class __module__ identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp1051qm
  columns: [id, function, args, expected]
  rows:
    - [mp1051qm001, multiprocessing.Queue.__module__.__eq__,         ["multiprocessing.queues"], true]
    - [mp1051qm002, multiprocessing.JoinableQueue.__module__.__eq__, ["multiprocessing.queues"], true]
    - [mp1051qm003, multiprocessing.SimpleQueue.__module__.__eq__,   ["multiprocessing.queues"], true]
    - [mp1051qm004, multiprocessing.Queue.__qualname__.__eq__,       ["Queue"],                  true]
    - [mp1051qm005, multiprocessing.JoinableQueue.__qualname__.__eq__, ["JoinableQueue"],         true]
    - [mp1051qm006, multiprocessing.SimpleQueue.__qualname__.__eq__, ["SimpleQueue"],             true]

table multiprocessing_extra1051.queue_weakref_identity:
  description: "multiprocessing.Queue __weakref__ descriptor type identity"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: mp1051wr
  columns: [id, function, args, expected]
  rows:
    - [mp1051wr001, multiprocessing.Queue.__weakref__.__class__.__name__.__eq__,         ["getset_descriptor"], true]
    - [mp1051wr002, multiprocessing.Queue.__class__.__name__.__eq__,                     ["type"],              true]
    - [mp1051wr003, multiprocessing.JoinableQueue.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [mp1051wr004, multiprocessing.JoinableQueue.__class__.__name__.__eq__,             ["type"],              true]

table multiprocessing_extra1051.queue_method_qualnames:
  description: "multiprocessing.Queue method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mp1051mq
  columns: [id, function, args, expected]
  rows:
    - [mp1051mq001, multiprocessing.Queue.get.__qualname__.__eq__,   ["Queue.get"],   true]
    - [mp1051mq002, multiprocessing.Queue.put.__qualname__.__eq__,   ["Queue.put"],   true]
    - [mp1051mq003, multiprocessing.Queue.empty.__qualname__.__eq__, ["Queue.empty"], true]
    - [mp1051mq004, multiprocessing.Queue.close.__qualname__.__eq__, ["Queue.close"], true]
    - [mp1051mq005, multiprocessing.Queue.get.__class__.__name__.__eq__, ["function"], true]
    - [mp1051mq006, multiprocessing.Queue.put.__class__.__name__.__eq__, ["function"], true]
