spec: logging_extra8
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends logging.zspec.zsdl through logging_extra7.zspec.zsdl."
    - "Prior specs cover: level constants and ordering (logging + logging_extra + logging_extra5 + logging_extra6); getLevelName int↔str (logging + logging_extra5); class __name__ for all major classes (logging + logging_extra + logging_extra3 + logging_extra4 + logging_extra5); class __module__ for Logger/Handler/Formatter/Filter/LogRecord/NullHandler/StreamHandler/FileHandler/Filterer (logging_extra3 + logging_extra4 + logging_extra5); class __qualname__ for all major classes (logging_extra6 + logging_extra7); function __name__/__qualname__ for getLogger/basicConfig/getLevelName/makeLogRecord/disable (logging + logging_extra6); function __module__ for getLogger/basicConfig/getLevelName (logging_extra3 + logging_extra7); class hierarchy __bases__ (logging_extra4); Logger method names debug/info/warning/error/critical/exception/log (logging_extra3); BASIC_FORMAT type check (logging_extra4)."
    - "This spec adds new axes: __module__ for Manager/PlaceHolder/makeLogRecord/disable/captureWarnings/addLevelName (all == 'logging')."
    - "This spec adds LoggerAdapter.__qualname__ and LoggerAdapter.__module__."
    - "This spec adds Logger method __qualname__ for setLevel/addHandler/removeHandler."
    - "This spec adds Filterer method __qualname__ for addFilter/removeFilter."
    - "This spec adds BASIC_FORMAT content membership checks (contains levelname, %(name)s, %(message)s)."
    - "logging.Manager.__module__ == 'logging' — Manager is the logger hierarchy tracker."
    - "logging.PlaceHolder.__module__ == 'logging' — PlaceHolder fills gaps in the hierarchy."
    - "logging.LoggerAdapter.__qualname__ == 'LoggerAdapter' — top-level adapter class."
    - "logging.Logger.setLevel.__qualname__ == 'Logger.setLevel' — bound method qualname includes class name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for Manager and PlaceHolder
#
# logging_extra4 checked __name__ for Manager and PlaceHolder.
# logging_extra7 checked __qualname__ for Manager and PlaceHolder.
# This spec adds __module__ for both (not previously covered).
# ---------------------------------------------------------------------------

invariant logging_extra8.Manager.module:
  description: "logging.Manager.__module__ == 'logging'"
  category: class_modules
  kind: python_call_eq
  function: Manager.__module__.__eq__
  args: ["logging"]
  expected: true

invariant logging_extra8.PlaceHolder.module:
  description: "logging.PlaceHolder.__module__ == 'logging'"
  category: class_modules
  kind: python_call_eq
  function: PlaceHolder.__module__.__eq__
  args: ["logging"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for top-level functions not yet covered
#
# makeLogRecord, disable, captureWarnings, addLevelName are module-scope
# functions defined in logging/__init__.py; each has __module__ == 'logging'.
# Prior specs verified __name__ but not __module__ for these.
# ---------------------------------------------------------------------------

table logging_extra8.function_modules:
  description: "makeLogRecord, disable, captureWarnings, addLevelName have __module__ == 'logging'"
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [makeLogRecord,    makeLogRecord.__module__.__eq__,    ["logging"], true]
    - [disable,         disable.__module__.__eq__,          ["logging"], true]
    - [captureWarnings, captureWarnings.__module__.__eq__,  ["logging"], true]
    - [addLevelName,    addLevelName.__module__.__eq__,     ["logging"], true]

# ---------------------------------------------------------------------------
# LoggerAdapter — __qualname__ and __module__
#
# LoggerAdapter is a top-level class in logging that wraps a Logger with
# extra contextual information. Prior specs checked __name__ (logging.zspec).
# This spec adds __qualname__ and __module__ (new axes for LoggerAdapter).
# ---------------------------------------------------------------------------

invariant logging_extra8.LoggerAdapter.qualname:
  description: "logging.LoggerAdapter.__qualname__ == 'LoggerAdapter'"
  category: class_attrs
  kind: python_call_eq
  function: LoggerAdapter.__qualname__.__eq__
  args: ["LoggerAdapter"]
  expected: true

invariant logging_extra8.LoggerAdapter.module:
  description: "logging.LoggerAdapter.__module__ == 'logging'"
  category: class_attrs
  kind: python_call_eq
  function: LoggerAdapter.__module__.__eq__
  args: ["logging"]
  expected: true

# ---------------------------------------------------------------------------
# Logger method __qualname__ checks
#
# Instance methods on Logger have __qualname__ == 'Logger.<method>',
# reflecting the enclosing class.  Prior specs checked __name__ only
# (logging_extra3 covers debug/info/warning/error/critical/exception/log).
# This spec adds __qualname__ for setLevel/addHandler/removeHandler.
# ---------------------------------------------------------------------------

table logging_extra8.Logger_method_qualnames:
  description: "Logger methods have __qualname__ == 'Logger.<method>'"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mqname

  columns: [id, function, args, expected]
  rows:
    - [setLevel,      Logger.setLevel.__qualname__.__eq__,      ["Logger.setLevel"],      true]
    - [addHandler,    Logger.addHandler.__qualname__.__eq__,    ["Logger.addHandler"],    true]
    - [removeHandler, Logger.removeHandler.__qualname__.__eq__, ["Logger.removeHandler"], true]

# ---------------------------------------------------------------------------
# Filterer method __qualname__ checks
#
# Filterer.addFilter and Filterer.removeFilter have __qualname__ entries
# that include the class name.  Prior specs did not check these method attrs.
# ---------------------------------------------------------------------------

invariant logging_extra8.Filterer_addFilter.qualname:
  description: "logging.Filterer.addFilter.__qualname__ == 'Filterer.addFilter'"
  category: method_qualnames
  kind: python_call_eq
  function: Filterer.addFilter.__qualname__.__eq__
  args: ["Filterer.addFilter"]
  expected: true

invariant logging_extra8.Filterer_removeFilter.qualname:
  description: "logging.Filterer.removeFilter.__qualname__ == 'Filterer.removeFilter'"
  category: method_qualnames
  kind: python_call_eq
  function: Filterer.removeFilter.__qualname__.__eq__
  args: ["Filterer.removeFilter"]
  expected: true

# ---------------------------------------------------------------------------
# BASIC_FORMAT — content membership checks
#
# logging_extra4 verified BASIC_FORMAT.__class__.__name__ == 'str'.
# This spec adds checks that BASIC_FORMAT contains the three key format
# specifiers used by basicConfig: %(levelname)s, %(name)s, %(message)s.
# ---------------------------------------------------------------------------

invariant logging_extra8.BASIC_FORMAT.contains_levelname:
  description: "logging.BASIC_FORMAT contains '%(levelname)s'"
  category: constants
  kind: python_call_eq
  function: BASIC_FORMAT.__contains__
  args: ["%(levelname)s"]
  expected: true

invariant logging_extra8.BASIC_FORMAT.contains_name:
  description: "logging.BASIC_FORMAT contains '%(name)s'"
  category: constants
  kind: python_call_eq
  function: BASIC_FORMAT.__contains__
  args: ["%(name)s"]
  expected: true

invariant logging_extra8.BASIC_FORMAT.contains_message:
  description: "logging.BASIC_FORMAT contains '%(message)s'"
  category: constants
  kind: python_call_eq
  function: BASIC_FORMAT.__contains__
  args: ["%(message)s"]
  expected: true
