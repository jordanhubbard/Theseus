spec: io_extra304
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Most io classes are implemented in the C extension _io; their __module__ is '_io', not 'io'."
    - "BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, TextIOWrapper all report __module__ == '_io'."
    - "IOBase and UnsupportedOperation are exposed from the io namespace and report __module__ == 'io'."
    - "_BufferedIOBase, _TextIOBase, _RawIOBase are internal C extension base classes — not public but accessible via __bases__."
    - "UnsupportedOperation inherits from OSError (index 0) and ValueError (index 1)."
    - "All class identity values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks — all major io classes
# ---------------------------------------------------------------------------

table io_extra304.class_names:
  description: "__name__ for io classes — each class's __name__ matches its declared name"
  kind: python_call_eq
  category: class_names

  columns: [id, function, args, expected]
  rows:
    - [BytesIO,              BytesIO.__name__.__eq__,              ["BytesIO"],         true]
    - [StringIO,             StringIO.__name__.__eq__,             ["StringIO"],         true]
    - [FileIO,               FileIO.__name__.__eq__,               ["FileIO"],           true]
    - [BufferedReader,       BufferedReader.__name__.__eq__,       ["BufferedReader"],   true]
    - [BufferedWriter,       BufferedWriter.__name__.__eq__,       ["BufferedWriter"],   true]
    - [TextIOWrapper,        TextIOWrapper.__name__.__eq__,        ["TextIOWrapper"],    true]
    - [IOBase,               IOBase.__name__.__eq__,               ["IOBase"],           true]
    - [UnsupportedOperation, UnsupportedOperation.__name__.__eq__, ["UnsupportedOperation"], true]

# ---------------------------------------------------------------------------
# __module__ checks — C extension classes report '_io'; io-namespace classes report 'io'
# ---------------------------------------------------------------------------

table io_extra304.class_modules:
  description: "__module__ for io classes — C extension types report '_io'; pure-Python wrappers report 'io'"
  kind: python_call_eq
  category: class_modules

  columns: [id, function, args, expected]
  rows:
    - [BytesIO,              BytesIO.__module__.__eq__,              ["_io"], true]
    - [StringIO,             StringIO.__module__.__eq__,             ["_io"], true]
    - [FileIO,               FileIO.__module__.__eq__,               ["_io"], true]
    - [BufferedReader,       BufferedReader.__module__.__eq__,       ["_io"], true]
    - [BufferedWriter,       BufferedWriter.__module__.__eq__,       ["_io"], true]
    - [TextIOWrapper,        TextIOWrapper.__module__.__eq__,        ["_io"], true]
    - [IOBase,               IOBase.__module__.__eq__,               ["io"],  true]
    - [UnsupportedOperation, UnsupportedOperation.__module__.__eq__, ["io"],  true]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ checks — direct base class identity
# ---------------------------------------------------------------------------

invariant io_extra304.BytesIO.base0_name:
  description: "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — C extension base"
  category: base_classes
  kind: python_call_eq
  function: BytesIO.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["_BufferedIOBase"]
  expected: true

invariant io_extra304.StringIO.base0_name:
  description: "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — C extension base"
  category: base_classes
  kind: python_call_eq
  function: StringIO.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["_TextIOBase"]
  expected: true

invariant io_extra304.FileIO.base0_name:
  description: "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — C extension base"
  category: base_classes
  kind: python_call_eq
  function: FileIO.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["_RawIOBase"]
  expected: true

invariant io_extra304.BufferedReader.base0_name:
  description: "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — C extension base"
  category: base_classes
  kind: python_call_eq
  function: BufferedReader.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["_BufferedIOBase"]
  expected: true

invariant io_extra304.BufferedWriter.base0_name:
  description: "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — C extension base"
  category: base_classes
  kind: python_call_eq
  function: BufferedWriter.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["_BufferedIOBase"]
  expected: true

invariant io_extra304.TextIOWrapper.base0_name:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — C extension base"
  category: base_classes
  kind: python_call_eq
  function: TextIOWrapper.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["_TextIOBase"]
  expected: true

invariant io_extra304.UnsupportedOperation.base0_name:
  description: "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — first declared base is OSError"
  category: base_classes
  kind: python_call_eq
  function: UnsupportedOperation.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["OSError"]
  expected: true
