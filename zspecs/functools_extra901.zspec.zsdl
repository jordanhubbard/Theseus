spec: functools_extra901
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks functools.partial class name, functools.reduce module, lru_cache __wrapped__ type, functools.cache module"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra901.partial_class_identity:
  description: "functools.partial __class__.__name__ and identity checks"
  kind: python_call_eq
  category: partial_class_identity
  id_prefix: ft901pc
  columns: [id, function, args, expected]
  rows:
    - [ft901pc001, functools.partial.__class__.__name__.__eq__,         ["type"],                    true]
    - [ft901pc002, functools.partial.__module__.__eq__,                 ["functools"],               true]
    - [ft901pc003, functools.partial.__qualname__.__eq__,               ["partial"],                 true]
    - [ft901pc004, functools.partial.__doc__.__class__.__name__.__eq__, ["str"],                     true]
    - [ft901pc005, functools.partial.__init__.__qualname__.__eq__,      ["partial.__init__"],        true]
    - [ft901pc006, functools.partial.__new__.__qualname__.__eq__,       ["partial.__new__"],         true]

table functools_extra901.reduce_module_identity:
  description: "functools.reduce __module__ and qualname identity checks"
  kind: python_call_eq
  category: reduce_module_identity
  id_prefix: ft901rm
  columns: [id, function, args, expected]
  rows:
    - [ft901rm001, functools.reduce.__module__.__eq__,                  ["_functools"],              true]
    - [ft901rm002, functools.reduce.__qualname__.__eq__,                ["reduce"],                  true]
    - [ft901rm003, functools.reduce.__class__.__name__.__eq__,          ["builtin_function_or_method"], true]
    - [ft901rm004, functools.reduce.__doc__.__class__.__name__.__eq__,  ["str"],                     true]
    - [ft901rm005, functools.reduce.__name__.__eq__,                    ["reduce"],                  true]

table functools_extra901.lru_cache_wrapper_identity:
  description: "functools.lru_cache wrapper __wrapped__ attribute type and identity"
  kind: python_call_eq
  category: lru_cache_wrapper_identity
  id_prefix: ft901lc
  columns: [id, function, args, expected]
  rows:
    - [ft901lc001, functools.lru_cache.__module__.__eq__,               ["functools"],               true]
    - [ft901lc002, functools.lru_cache.__qualname__.__eq__,             ["lru_cache"],               true]
    - [ft901lc003, functools.lru_cache.__class__.__name__.__eq__,       ["function"],                true]
    - [ft901lc004, functools.cache.__module__.__eq__,                   ["functools"],               true]
    - [ft901lc005, functools.cache.__qualname__.__eq__,                 ["cache"],                   true]
    - [ft901lc006, functools.cache.__class__.__name__.__eq__,           ["function"],                true]
    - [ft901lc007, functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__, ["tuple"],               true]
