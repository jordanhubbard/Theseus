spec: struct_extra2221
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct.zspec.zsdl"
  notes:
    - "Wave _extra2221: identity/display protocol dict-presence checks for struct classes."
    - "Covers __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__ presence in Struct and error class dicts."
    - "struct.Struct is a C extension type implemented in _struct; struct.__module__ == '_struct'."
    - "struct.Struct defines __repr__ in its own __dict__ (C extension provides a custom repr)."
    - "struct.Struct does NOT define __hash__ or __str__ in its own __dict__ (inherited from object)."
    - "struct.Struct.__doc__ and __module__ are present in __dict__."
    - "struct.Struct.__qualname__ and __name__ are NOT present in __dict__ (C extension type attributes)."
    - "struct.Struct defines __new__, __init__, and __sizeof__ in its own __dict__ (C extension lifecycle slots)."
    - "struct.error is a pure Python exception class; it defines __doc__ and __module__ but not __hash__, __repr__, __str__."
    - "struct.error.__qualname__ and __name__ are NOT in struct.error.__dict__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2221.Struct_identity_protocol:
  description: "struct.Struct identity/display protocol dict-presence: __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2221

  columns: [id, function, args, expected]
  rows:
    - ["st2221001", "struct.Struct.__dict__.__contains__", ["__hash__"],     false]
    - ["st2221002", "struct.Struct.__dict__.__contains__", ["__repr__"],     true]
    - ["st2221003", "struct.Struct.__dict__.__contains__", ["__str__"],      false]
    - ["st2221004", "struct.Struct.__dict__.__contains__", ["__doc__"],      true]
    - ["st2221005", "struct.Struct.__dict__.__contains__", ["__module__"],   true]
    - ["st2221006", "struct.Struct.__dict__.__contains__", ["__qualname__"], false]
    - ["st2221007", "struct.Struct.__dict__.__contains__", ["__name__"],     false]

table struct_extra2221.error_identity_protocol:
  description: "struct.error identity/display protocol dict-presence: __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2221

  columns: [id, function, args, expected]
  rows:
    - ["st2221008", "struct.error.__dict__.__contains__", ["__hash__"],     false]
    - ["st2221009", "struct.error.__dict__.__contains__", ["__repr__"],     false]
    - ["st2221010", "struct.error.__dict__.__contains__", ["__str__"],      false]
    - ["st2221011", "struct.error.__dict__.__contains__", ["__doc__"],      true]
    - ["st2221012", "struct.error.__dict__.__contains__", ["__module__"],   true]
    - ["st2221013", "struct.error.__dict__.__contains__", ["__qualname__"], false]
    - ["st2221014", "struct.error.__dict__.__contains__", ["__name__"],     false]

table struct_extra2221.Struct_constructor_protocol:
  description: "struct.Struct constructor/lifecycle dict-presence: __new__, __init__, __sizeof__, __format__, __bytes__, __reduce__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2221

  columns: [id, function, args, expected]
  rows:
    - ["st2221015", "struct.Struct.__dict__.__contains__", ["__new__"],    true]
    - ["st2221016", "struct.Struct.__dict__.__contains__", ["__init__"],   true]
    - ["st2221017", "struct.Struct.__dict__.__contains__", ["__sizeof__"], true]
    - ["st2221018", "struct.Struct.__dict__.__contains__", ["__format__"], false]
    - ["st2221019", "struct.Struct.__dict__.__contains__", ["__bytes__"],  false]
    - ["st2221020", "struct.Struct.__dict__.__contains__", ["__reduce__"], false]

table struct_extra2221.error_constructor_protocol:
  description: "struct.error constructor/lifecycle dict-presence: __new__, __init__, __format__, __bytes__, __reduce__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2221

  columns: [id, function, args, expected]
  rows:
    - ["st2221021", "struct.error.__dict__.__contains__", ["__new__"],    false]
    - ["st2221022", "struct.error.__dict__.__contains__", ["__init__"],   false]
    - ["st2221023", "struct.error.__dict__.__contains__", ["__format__"], false]
    - ["st2221024", "struct.error.__dict__.__contains__", ["__bytes__"],  false]
    - ["st2221025", "struct.error.__dict__.__contains__", ["__reduce__"], false]

table struct_extra2221.cross_checks:
  description: "struct cross-checks: Struct defines __repr__ but error does not; both define __doc__ and __module__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2221

  columns: [id, function, args, expected]
  rows:
    - ["st2221026", "struct.Struct.__dict__.__contains__", ["__repr__"],   true]
    - ["st2221027", "struct.error.__dict__.__contains__",  ["__repr__"],   false]
    - ["st2221028", "struct.Struct.__dict__.__contains__", ["__doc__"],    true]
    - ["st2221029", "struct.error.__dict__.__contains__",  ["__doc__"],    true]
    - ["st2221030", "struct.Struct.__dict__.__contains__", ["__module__"], true]
    - ["st2221031", "struct.error.__dict__.__contains__",  ["__module__"], true]
