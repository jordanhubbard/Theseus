spec: theseus_timeit_cr
version: ">=3.8"
backend: python_cleanroom(theseus_timeit_cr)
blocks: timeit

docs: https://docs.python.org/3/library/timeit.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/timeit.html"
  not_derived_from:
    - "CPython source: Lib/timeit.py (internal implementation)"
  notes:
    - "Clean-room timeit module. Do NOT import timeit."
    - "timeit(stmt, setup, number): time a statement; return total time in seconds."
    - "repeat(stmt, setup, number, repeat): return list of timings."
    - "Timer(stmt, setup): callable timing object."
    - "default_timer(): return a high-resolution timer value (time.perf_counter)."

error_model: python_exceptions

invariant theseus_timeit_cr.timeit2_basic:
  description: "timeit('pass', number=1000) returns a non-negative float"
  category: timeit
  kind: python_call_eq
  function: timeit2_basic
  args: []
  expected: true

invariant theseus_timeit_cr.timeit2_repeat:
  description: "repeat('pass', number=10, repeat=3) returns list of 3 floats"
  category: repeat
  kind: python_call_eq
  function: timeit2_repeat
  args: []
  expected: 3

invariant theseus_timeit_cr.timeit2_timer_callable:
  description: "Timer('1+1').timeit(number=10) returns non-negative float"
  category: Timer
  kind: python_call_eq
  function: timeit2_timer_callable
  args: []
  expected: true
