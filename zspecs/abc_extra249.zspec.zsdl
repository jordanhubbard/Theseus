spec: abc_extra249
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc abstract base classes documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py (abstract base class definitions)"
  notes:
    - "collections.abc.Sequence.__abstractmethods__ == frozenset({'__getitem__', '__len__'}) — exactly 2 abstract methods; __getitem__(len=11), __len__(len=7)."
    - "collections.abc.Mapping.__abstractmethods__ == frozenset({'__getitem__', '__iter__', '__len__'}) — exactly 3 abstract methods; adds __iter__(len=8) beyond Sequence requirements."
    - "collections.abc.Iterable.__abstractmethods__ == frozenset({'__iter__'}) — exactly 1 abstract method; __iter__(len=8)."
    - "collections.abc.Iterator.__abstractmethods__ == frozenset({'__next__'}) — exactly 1 abstract method; __iter__ is NOT in Iterator.__abstractmethods__ (it is inherited as a mixin from Iterable but already has a concrete implementation in Iterator)."
    - "All __contains__ checks use the frozenset.__contains__ method on the __abstractmethods__ attribute."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# collections.abc.Sequence abstract method membership
#
# Sequence.__abstractmethods__ == frozenset({'__getitem__', '__len__'})
# __getitem__(len=11), __len__(len=7)
# ---------------------------------------------------------------------------

table abc_extra249.sequence_abstractmethods:
  description: "collections.abc.Sequence abstract method membership — Sequence has exactly 2 abstract methods: __getitem__(len=11) and __len__(len=7); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc249seq

  columns: [id, function, args, expected, description]
  rows:
    - [seq_getitem,  collections.abc.Sequence.__abstractmethods__.__contains__, ["__getitem__"], true, "collections.abc.Sequence.__abstractmethods__.__contains__('__getitem__') == True; verified with Python 3.14.3"]
    - [seq_len,      collections.abc.Sequence.__abstractmethods__.__contains__, ["__len__"],     true, "collections.abc.Sequence.__abstractmethods__.__contains__('__len__') == True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# collections.abc.Mapping abstract method membership
#
# Mapping.__abstractmethods__ == frozenset({'__getitem__', '__iter__', '__len__'})
# __getitem__(len=11), __iter__(len=8), __len__(len=7)
# ---------------------------------------------------------------------------

table abc_extra249.mapping_abstractmethods:
  description: "collections.abc.Mapping abstract method membership — Mapping has exactly 3 abstract methods: __getitem__(len=11), __iter__(len=8), and __len__(len=7); Mapping requires __iter__ in addition to the methods Sequence requires; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc249map

  columns: [id, function, args, expected, description]
  rows:
    - [map_getitem,  collections.abc.Mapping.__abstractmethods__.__contains__, ["__getitem__"], true, "collections.abc.Mapping.__abstractmethods__.__contains__('__getitem__') == True; verified with Python 3.14.3"]
    - [map_iter,     collections.abc.Mapping.__abstractmethods__.__contains__, ["__iter__"],    true, "collections.abc.Mapping.__abstractmethods__.__contains__('__iter__') == True; verified with Python 3.14.3"]
    - [map_len,      collections.abc.Mapping.__abstractmethods__.__contains__, ["__len__"],     true, "collections.abc.Mapping.__abstractmethods__.__contains__('__len__') == True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# collections.abc.Iterable and Iterator abstract method membership
#
# Iterable.__abstractmethods__ == frozenset({'__iter__'})
# Iterator.__abstractmethods__ == frozenset({'__next__'})
# Note: __iter__ is NOT in Iterator.__abstractmethods__ — it has a concrete
#       implementation in Iterator (returns self), so only __next__ is abstract.
# ---------------------------------------------------------------------------

table abc_extra249.iterable_iterator_abstractmethods:
  description: "collections.abc.Iterable and Iterator abstract method membership — Iterable requires only __iter__(len=8); Iterator requires only __next__(len=8), because Iterator provides a concrete __iter__ implementation (returns self); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc249iter

  columns: [id, function, args, expected, description]
  rows:
    - [ibl_iter,     collections.abc.Iterable.__abstractmethods__.__contains__, ["__iter__"],  true,  "collections.abc.Iterable.__abstractmethods__.__contains__('__iter__') == True; verified with Python 3.14.3"]
    - [itr_next,     collections.abc.Iterator.__abstractmethods__.__contains__, ["__next__"],  true,  "collections.abc.Iterator.__abstractmethods__.__contains__('__next__') == True; verified with Python 3.14.3"]
    - [itr_no_iter,  collections.abc.Iterator.__abstractmethods__.__contains__, ["__iter__"],  false, "collections.abc.Iterator.__abstractmethods__.__contains__('__iter__') == False — Iterator.__iter__ is concrete (returns self), not abstract; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra249
# ---------------------------------------------------------------------------

invariant abc_extra249.mapping_requires_iter:
  description: "collections.abc.Mapping.__abstractmethods__.__contains__('__iter__') returns True — Mapping requires __iter__ as an abstract method (unlike Sequence which does not); this distinguishes Mapping from Sequence at the abstract method level; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Mapping.__abstractmethods__.__contains__
  args: ["__iter__"]
  expected: true

invariant abc_extra249.iterator_iter_is_not_abstract:
  description: "collections.abc.Iterator.__abstractmethods__.__contains__('__iter__') returns False — Iterator provides a concrete __iter__ that returns self, so __iter__ is NOT abstract on Iterator; only __next__ is abstract; this is a key behavioral distinction from Iterable where __iter__ IS abstract; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Iterator.__abstractmethods__.__contains__
  args: ["__iter__"]
  expected: false
