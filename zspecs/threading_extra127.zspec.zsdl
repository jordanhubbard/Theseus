# ---------------------------------------------------------------------------
# Table 1: threading.Semaphore.__init__ and acquire code object attributes
#
# Wave 258 theme: threading.Semaphore.__init__ and acquire co_varnames/co_argcount.
#
# threading.Semaphore.__init__.__code__.co_varnames[0] == 'self'
# threading.Semaphore.__init__.__code__.co_varnames[1] == 'value'
# threading.Semaphore.__init__.__code__.co_argcount == 2
# threading.Semaphore.acquire.__code__.co_varnames[0] == 'self'
# threading.Semaphore.acquire.__code__.co_varnames[1] == 'blocking'
# threading.Semaphore.acquire.__code__.co_varnames[2] == 'timeout'
# threading.Semaphore.acquire.__code__.co_argcount == 3
#
# Semaphore.__init__ takes (self, value=1) where value is the initial count.
# Semaphore.acquire takes (self, blocking=True, timeout=None). New to extra127.
# ---------------------------------------------------------------------------

table threading_extra127.semaphore_init_acquire_code:
  description: "threading.Semaphore.__init__ and acquire co_varnames and co_argcount; init takes self+value, acquire takes self+blocking+timeout; wave 258; new to extra127"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingsemaphore127

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_init_co_varnames_first_eq_self,
       "Semaphore.__init__.__code__.co_varnames[0].__eq__",
       ["self"],
       true,
       "threading.Semaphore.__init__.__code__.co_varnames[0].__eq__('self') == True — Semaphore.__init__ is defined as 'def __init__(self, value=1):' in Lib/threading.py; its first parameter is 'self' (the instance); co_varnames[0] is 'self'; str.__eq__('self') returns True; new to extra127"]
    - [semaphore_init_co_varnames_second_eq_value,
       "Semaphore.__init__.__code__.co_varnames[1].__eq__",
       ["value"],
       true,
       "threading.Semaphore.__init__.__code__.co_varnames[1].__eq__('value') == True — Semaphore.__init__ takes 'value' as its second parameter (the initial semaphore count, defaulting to 1); co_varnames[1] is 'value'; str.__eq__('value') returns True; new to extra127"]
    - [semaphore_init_co_argcount_eq_2,
       "Semaphore.__init__.__code__.co_argcount.__eq__",
       [2],
       true,
       "threading.Semaphore.__init__.__code__.co_argcount.__eq__(2) == True — Semaphore.__init__ takes two positional arguments: 'self' and 'value'; co_argcount is 2; int.__eq__(2) returns True; new to extra127"]
    - [semaphore_acquire_co_varnames_first_eq_self,
       "Semaphore.acquire.__code__.co_varnames[0].__eq__",
       ["self"],
       true,
       "threading.Semaphore.acquire.__code__.co_varnames[0].__eq__('self') == True — Semaphore.acquire is defined in Lib/threading.py; its first parameter is 'self'; co_varnames[0] is 'self'; str.__eq__('self') returns True; new to extra127"]
    - [semaphore_acquire_co_varnames_second_eq_blocking,
       "Semaphore.acquire.__code__.co_varnames[1].__eq__",
       ["blocking"],
       true,
       "threading.Semaphore.acquire.__code__.co_varnames[1].__eq__('blocking') == True — Semaphore.acquire takes 'blocking' as its second parameter (whether to block waiting for the semaphore, defaulting to True); co_varnames[1] is 'blocking'; str.__eq__('blocking') returns True; new to extra127"]
    - [semaphore_acquire_co_varnames_third_eq_timeout,
       "Semaphore.acquire.__code__.co_varnames[2].__eq__",
       ["timeout"],
       true,
       "threading.Semaphore.acquire.__code__.co_varnames[2].__eq__('timeout') == True — Semaphore.acquire takes 'timeout' as its third parameter (maximum time to wait if blocking, defaulting to None); co_varnames[2] is 'timeout'; str.__eq__('timeout') returns True; new to extra127"]
    - [semaphore_acquire_co_argcount_eq_3,
       "Semaphore.acquire.__code__.co_argcount.__eq__",
       [3],
       true,
       "threading.Semaphore.acquire.__code__.co_argcount.__eq__(3) == True — Semaphore.acquire takes three positional arguments: 'self', 'blocking', and 'timeout'; co_argcount is 3; int.__eq__(3) returns True; new to extra127"]

# ---------------------------------------------------------------------------
