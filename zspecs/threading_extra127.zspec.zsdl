# ---------------------------------------------------------------------------

table threading_extra127.semaphore_release_exit_code:
  description: "threading.Semaphore.release and __exit__ co_varnames and co_argcount; release takes self+n, __exit__ takes self+t+v+tb; wave 258; new to extra127"
  kind: python_call_eq
