    - [semaphore_release_co_varnames_first_eq_self,
       "Semaphore.release.__code__.co_varnames[0].__eq__",
       ["self"],
       true,
       "threading.Semaphore.release.__code__.co_varnames[0].__eq__('self') == True — Semaphore.release is a method in Lib/threading.py; its first parameter is 'self'; co_varnames[0] is 'self'; str.__eq__('self') returns True; new to extra127"]
    - [semaphore_release_co_varnames_second_eq_n,
       "Semaphore.release.__code__.co_varnames[1].__eq__",
       ["n"],
       true,
       "threading.Semaphore.release.__code__.co_varnames[1].__eq__('n') == True — Semaphore.release takes 'n' as its second parameter (the number of units to release, defaulting to 1); co_varnames[1] is 'n'; str.__eq__('n') returns True; new to extra127"]
    - [semaphore_release_co_argcount_eq_2,
       "Semaphore.release.__code__.co_argcount.__eq__",
       [2],
       true,
       "threading.Semaphore.release.__code__.co_argcount.__eq__(2) == True — Semaphore.release takes two positional arguments: 'self' and 'n'; co_argcount is 2; int.__eq__(2) returns True; new to extra127"]
    - [semaphore_exit_co_varnames_first_eq_self,
       "Semaphore.__exit__.__code__.co_varnames[0].__eq__",
       ["self"],
       true,
       "threading.Semaphore.__exit__.__code__.co_varnames[0].__eq__('self') == True — Semaphore.__exit__ implements the context manager exit protocol; its first parameter is 'self'; co_varnames[0] is 'self'; str.__eq__('self') returns True; new to extra127"]
    - [semaphore_exit_co_argcount_eq_4,
       "Semaphore.__exit__.__code__.co_argcount.__eq__",
       [4],
       true,
       "threading.Semaphore.__exit__.__code__.co_argcount.__eq__(4) == True — Semaphore.__exit__ takes four positional arguments: 'self', 't' (exception type), 'v' (exception value), and 'tb' (traceback), following the context manager protocol; co_argcount is 4; int.__eq__(4) returns True; new to extra127"]

