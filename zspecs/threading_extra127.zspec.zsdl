       true,
       "threading.Semaphore.__enter__.__code__.co_varnames[1].__eq__('blocking') == True — Semaphore.__enter__ takes 'blocking' as its second parameter (passed through to acquire); co_varnames[1] is 'blocking'; str.__eq__('blocking') returns True; new to extra127"]
    - [semaphore_enter_co_varnames_third_eq_timeout,
       "Semaphore.__enter__.__code__.co_varnames[2].__eq__",
       ["timeout"],
       true,
       "threading.Semaphore.__enter__.__code__.co_varnames[2].__eq__('timeout') == True — Semaphore.__enter__ takes 'timeout' as its third parameter (passed through to acquire); co_varnames[2] is 'timeout'; str.__eq__('timeout') returns True; new to extra127"]
    - [semaphore_release_len_co_varnames_eq_2,
       "Semaphore.release.__code__.co_varnames.__len__",
       [],
       2,
       "threading.Semaphore.release.__code__.co_varnames.__len__() == 2 — release uses exactly 2 local variables: 'self' and 'n'; len(co_varnames) == 2; new to extra127"]

