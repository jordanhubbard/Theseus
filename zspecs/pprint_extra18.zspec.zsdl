spec: pprint_extra18
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "This spec extends pprint.zspec.zsdl through pprint_extra17.zspec.zsdl."
    - "pprint_extra14 covers: PrettyPrinter.__bases__[0].__name__=='object'; pformat/pprint/isreadable/isrecursive/saferepr __qualname__ standalones; pformat.__module__ standalone."
    - "pprint_extra16 covers: PrettyPrinter.pprint/pformat/isreadable/isrecursive __qualname__ as standalone invariants."
    - "pprint_extra17 covers: PrettyPrinter.__repr__.__qualname__; PrettyPrinter._pprint_dict/_pprint_list/_pprint_tuple/_pprint_set/_format __qualname__ standalones."
    - "No prior spec verifies PrettyPrinter._pprint_ordered_dict.__qualname__, PrettyPrinter._pprint_dataclass.__qualname__, PrettyPrinter._format_dict_items.__qualname__, or PrettyPrinter._format_items.__qualname__ as standalone invariants."
    - "PrettyPrinter._pprint_ordered_dict.__qualname__ == 'PrettyPrinter._pprint_ordered_dict' — private dispatch method for OrderedDict. Verified at runtime."
    - "PrettyPrinter._pprint_dataclass.__qualname__ == 'PrettyPrinter._pprint_dataclass' — private dispatch method for dataclasses. Verified at runtime."
    - "PrettyPrinter._format_dict_items.__qualname__ == 'PrettyPrinter._format_dict_items' — private helper for formatting dict key-value pairs. Verified at runtime."
    - "PrettyPrinter._format_items.__qualname__ == 'PrettyPrinter._format_items' — private helper for formatting iterable items. Verified at runtime."
    - "All four methods are defined in the pprint module; their __module__ == 'pprint'. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PrettyPrinter._pprint_ordered_dict method __qualname__
#
# No prior spec verifies PrettyPrinter._pprint_ordered_dict.__qualname__ as a
# standalone invariant. This is the private dispatch method for OrderedDict
# objects, added in Python 3.7+. Verified: __qualname__ == 'PrettyPrinter._pprint_ordered_dict'.
# ---------------------------------------------------------------------------

invariant pprint_extra18.PrettyPrinter._pprint_ordered_dict_qualname:
  description: "pprint.PrettyPrinter._pprint_ordered_dict.__qualname__ == 'PrettyPrinter._pprint_ordered_dict' — private dispatch method for OrderedDict"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter._pprint_ordered_dict.__qualname__.__eq__
  args: ["PrettyPrinter._pprint_ordered_dict"]
  expected: true

# ---------------------------------------------------------------------------
# PrettyPrinter._pprint_dataclass method __qualname__
#
# No prior spec verifies PrettyPrinter._pprint_dataclass.__qualname__ as a
# standalone invariant. This method formats dataclass instances with field
# names and values. Verified: __qualname__ == 'PrettyPrinter._pprint_dataclass'.
# ---------------------------------------------------------------------------

invariant pprint_extra18.PrettyPrinter._pprint_dataclass_qualname:
  description: "pprint.PrettyPrinter._pprint_dataclass.__qualname__ == 'PrettyPrinter._pprint_dataclass' — private dispatch method for dataclasses"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter._pprint_dataclass.__qualname__.__eq__
  args: ["PrettyPrinter._pprint_dataclass"]
  expected: true

# ---------------------------------------------------------------------------
# PrettyPrinter._format_dict_items method __qualname__
#
# No prior spec verifies PrettyPrinter._format_dict_items.__qualname__ as a
# standalone invariant. This private helper method formats the key-value pairs
# of a dict across multiple lines when the width budget is exceeded.
# Verified: __qualname__ == 'PrettyPrinter._format_dict_items'.
# ---------------------------------------------------------------------------

invariant pprint_extra18.PrettyPrinter._format_dict_items_qualname:
  description: "pprint.PrettyPrinter._format_dict_items.__qualname__ == 'PrettyPrinter._format_dict_items' — private helper for dict item formatting"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter._format_dict_items.__qualname__.__eq__
  args: ["PrettyPrinter._format_dict_items"]
  expected: true

# ---------------------------------------------------------------------------
# PrettyPrinter._format_items method __qualname__
#
# No prior spec verifies PrettyPrinter._format_items.__qualname__ as a
# standalone invariant. This private helper method formats elements of an
# iterable (lists, tuples, sets) across multiple lines.
# Verified: __qualname__ == 'PrettyPrinter._format_items'.
# ---------------------------------------------------------------------------

invariant pprint_extra18.PrettyPrinter._format_items_qualname:
  description: "pprint.PrettyPrinter._format_items.__qualname__ == 'PrettyPrinter._format_items' — private helper for iterable item formatting"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter._format_items.__qualname__.__eq__
  args: ["PrettyPrinter._format_items"]
  expected: true

# ---------------------------------------------------------------------------
# PrettyPrinter._pprint_ordered_dict and _pprint_dataclass __module__
#
# No prior spec verifies __module__ for these two private dispatch methods.
# Both are defined in the pprint module. Verified at runtime.
# ---------------------------------------------------------------------------

invariant pprint_extra18.PrettyPrinter._pprint_ordered_dict_module:
  description: "pprint.PrettyPrinter._pprint_ordered_dict.__module__ == 'pprint' — method defined in pprint module"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter._pprint_ordered_dict.__module__.__eq__
  args: ["pprint"]
  expected: true

invariant pprint_extra18.PrettyPrinter._pprint_dataclass_module:
  description: "pprint.PrettyPrinter._pprint_dataclass.__module__ == 'pprint' — method defined in pprint module"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter._pprint_dataclass.__module__.__eq__
  args: ["pprint"]
  expected: true

# ---------------------------------------------------------------------------
# Table: PrettyPrinter additional private method __qualname__ attributes
#
# Groups the four new private-method qualname checks in one indexed table.
# No prior table covers _pprint_ordered_dict, _pprint_dataclass,
# _format_dict_items, or _format_items __qualname__ values.
# All verified at runtime.
# ---------------------------------------------------------------------------

table pprint_extra18.PrettyPrinter_additional_private_method_qualnames:
  description: "pprint.PrettyPrinter additional private method __qualname__ attributes — ordered_dict, dataclass, format_dict_items, format_items"
  kind: python_call_eq
  category: function_identity
  id_prefix: pp18pmq

  columns: [id, function, args, expected]
  rows:
    - [_pprint_ordered_dict, PrettyPrinter._pprint_ordered_dict.__qualname__.__eq__, ["PrettyPrinter._pprint_ordered_dict"], true]
    - [_pprint_dataclass,    PrettyPrinter._pprint_dataclass.__qualname__.__eq__,    ["PrettyPrinter._pprint_dataclass"],    true]
    - [_format_dict_items,   PrettyPrinter._format_dict_items.__qualname__.__eq__,   ["PrettyPrinter._format_dict_items"],   true]
    - [_format_items,        PrettyPrinter._format_items.__qualname__.__eq__,        ["PrettyPrinter._format_items"],        true]
