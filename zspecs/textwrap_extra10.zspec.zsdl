spec: textwrap_extra10
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
    - "textwrap.zspec.zsdl — covers wrap/fill/dedent/indent/shorten basic vectors; TextWrapper(width=40).width."
    - "textwrap_extra.zspec.zsdl — covers wrap/fill/dedent/indent/shorten __name__; TextWrapper __name__/__module__; additional behavioral vectors."
    - "textwrap_extra2.zspec.zsdl — covers TextWrapper defaults (width=70, break_long_words); fill/dedent return type."
    - "textwrap_extra3.zspec.zsdl — covers function __module__ table; wrap/fill behavioral vectors; indent angle prefix; dedent blank_first_line; shorten vectors."
    - "textwrap_extra4.zspec.zsdl — covers function_names/function_modules tables; TextWrapper defaults (width, expand_tabs)."
    - "textwrap_extra5.zspec.zsdl — covers TextWrapper defaults (drop_whitespace, fix_sentence_endings, placeholder)."
    - "textwrap_extra6.zspec.zsdl — covers TextWrapper __name__/__module__/__qualname__/__bases__ extra6 anchors."
    - "textwrap_extra7.zspec.zsdl — covers TextWrapper defaults (break_on_hyphens, max_lines, tabsize); function __class__.__name__; indent hash prefix; TextWrapper.wrap with initial_indent; shorten unicode placeholder; fill three-line output."
    - "textwrap_extra8.zspec.zsdl — covers function __module__ standalone invariants; TextWrapper __module__/__name__ extra8 anchors; TextWrapper width=40/80; initial_indent/subsequent_indent/break_long_words/break_on_hyphens defaults."
    - "textwrap_extra9.zspec.zsdl — covers name_attrs table; wrap/fill width=5; dedent two-line; shorten width=15; TextWrapper default_width extra9 anchor."
  notes:
    - "This spec adds genuinely new test vectors not present in any prior textwrap spec."
    - "textwrap.wrap('supercalifragilistic', width=10) == ['supercalif', 'ragilistic'] — no prior spec wraps a single word longer than width."
    - "textwrap.wrap('supercalifragilistic', width=10, break_long_words=False) == ['supercalifragilistic'] — no prior spec checks break_long_words=False behavioral effect."
    - "textwrap.fill('The quick brown fox jumps', width=15) == 'The quick brown\\nfox jumps' — new input/width combo not in prior specs."
    - "textwrap.shorten('Hi', width=20) == 'Hi' — short string that fits entirely; extra5 uses a longer input for 'fits' check."
    - "textwrap.wrap returns a list — no prior spec checks __class__.__name__ of wrap() return value."
    - "textwrap.shorten returns a str — no prior spec checks __class__.__name__ of shorten() return value."
    - "textwrap.TextWrapper(width=60).width == 60 — no prior spec uses width=60 for a TextWrapper instance."
    - "textwrap.TextWrapper().fix_sentence_endings == False — extra5 covers this; this is the extra10-namespace anchor."
    - "textwrap.TextWrapper().expand_tabs == True — extra4 covers this; this is the extra10-namespace anchor."
    - "textwrap.wrap('hello world foo bar baz', width=15, subsequent_indent='  ') — subsequent_indent behavioral vector; no prior spec tests subsequent_indent in wrap()."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# wrap — long word breaking behavior
#
# No prior spec wraps a single word longer than the given width.
# With break_long_words=True (default), 'supercalifragilistic' at width=10
# is split into ['supercalif', 'ragilistic'].
# With break_long_words=False the single long word is kept on one line:
# ['supercalifragilistic'].
# ---------------------------------------------------------------------------

invariant textwrap_extra10.wrap.break_long_word_default:
  description: "textwrap.wrap('supercalifragilistic', width=10) == ['supercalif', 'ragilistic']"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["supercalifragilistic"]
  kwargs: {width: 10}
  method: __eq__
  method_args: [["supercalif", "ragilistic"]]
  expected: true

invariant textwrap_extra10.wrap.break_long_words_false:
  description: "textwrap.wrap('supercalifragilistic', width=10, break_long_words=False) == ['supercalifragilistic']"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["supercalifragilistic"]
  kwargs: {width: 10, break_long_words: false}
  method: __eq__
  method_args: [["supercalifragilistic"]]
  expected: true

# ---------------------------------------------------------------------------
# fill — new input/width combination
#
# No prior spec tests fill('The quick brown fox jumps', width=15).
# Result is 'The quick brown\nfox jumps' — two lines, word-wrapped at 15.
# ---------------------------------------------------------------------------

invariant textwrap_extra10.fill.width_15_fox:
  description: "textwrap.fill('The quick brown fox jumps', width=15) == 'The quick brown\\nfox jumps'"
  category: fill
  kind: python_call_eq
  function: fill
  args: ["The quick brown fox jumps"]
  kwargs: {width: 15}
  expected: "The quick brown\nfox jumps"

# ---------------------------------------------------------------------------
# shorten — string that fits entirely within width
#
# textwrap_extra5 covers shorten with an exact-fit and a longer text.
# No prior spec checks shorten('Hi', width=20): the string is so short it is
# returned unchanged — 'Hi'.
# ---------------------------------------------------------------------------

invariant textwrap_extra10.shorten.short_input:
  description: "textwrap.shorten('Hi', width=20) == 'Hi' — string fits entirely, returned unchanged"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["Hi"]
  kwargs: {width: 20}
  expected: "Hi"

# ---------------------------------------------------------------------------
# wrap and shorten return types
#
# No prior spec checks the __class__.__name__ of the values returned by wrap()
# or shorten(). wrap() always returns a list; shorten() always returns a str.
# ---------------------------------------------------------------------------

invariant textwrap_extra10.wrap.returns_list:
  description: "textwrap.wrap('hello world').__class__.__name__ == 'list' — wrap always returns a list"
  category: function_identity
  kind: python_call_eq
  function: wrap
  args: ["hello world"]
  method: __class__.__name__.__eq__
  method_args: ["list"]
  expected: true

invariant textwrap_extra10.shorten.returns_str:
  description: "textwrap.shorten('hello world', width=20).__class__.__name__ == 'str' — shorten returns str"
  category: function_identity
  kind: python_call_eq
  function: shorten
  args: ["hello world"]
  kwargs: {width: 20}
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# TextWrapper — width=60 instance
#
# textwrap_extra8 tests width=40 and width=80. No prior spec uses width=60.
# TextWrapper(width=60).width == 60 confirms that the constructor stores the
# supplied width correctly.
# ---------------------------------------------------------------------------

invariant textwrap_extra10.TextWrapper.width_60:
  description: "textwrap.TextWrapper(width=60).width == 60"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  kwargs: {width: 60}
  method: width.__eq__
  method_args: [60]
  expected: true

# ---------------------------------------------------------------------------
# TextWrapper defaults — fix_sentence_endings and expand_tabs — extra10 anchors
#
# textwrap_extra5 covers fix_sentence_endings in its namespace.
# textwrap_extra4 covers expand_tabs in its namespace.
# These are extra10-namespace standalone anchors for each attribute.
# ---------------------------------------------------------------------------

invariant textwrap_extra10.TextWrapper.fix_sentence_endings_default:
  description: "textwrap.TextWrapper().fix_sentence_endings == False — default is False"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: fix_sentence_endings.__eq__
  method_args: [false]
  expected: true

invariant textwrap_extra10.TextWrapper.expand_tabs_default:
  description: "textwrap.TextWrapper().expand_tabs == True — default is True"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: expand_tabs.__eq__
  method_args: [true]
  expected: true

# ---------------------------------------------------------------------------
# wrap — subsequent_indent behavioral vector
#
# No prior spec tests subsequent_indent in a call to wrap().
# textwrap_extra8 confirms subsequent_indent defaults to '' on an instance.
# textwrap_extra7 uses initial_indent in TextWrapper.wrap().
# wrap('hello world foo bar baz', width=15, subsequent_indent='  ') produces
# ['hello world foo', '  bar baz']: the second line is indented by two spaces.
# ---------------------------------------------------------------------------

invariant textwrap_extra10.wrap.subsequent_indent:
  description: "textwrap.wrap('hello world foo bar baz', width=15, subsequent_indent='  ') == ['hello world foo', '  bar baz']"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["hello world foo bar baz"]
  kwargs: {width: 15, subsequent_indent: "  "}
  method: __eq__
  method_args: [["hello world foo", "  bar baz"]]
  expected: true
