spec: as3076
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 652 (as3076): __get__, __set__, __delete__ dict-presence for asyncio types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: asyncio.Task, asyncio.Future, asyncio.Queue, asyncio.Event, asyncio.Semaphore, asyncio.Lock, asyncio.Condition, asyncio.BoundedSemaphore, asyncio.Handle, asyncio.TimerHandle, asyncio.Timeout, asyncio.TaskGroup, asyncio.StreamReader, asyncio.StreamWriter."
    - "All 14 asyncio classes return false for __get__, __set__, and __delete__ in their own __dict__."
    - "asyncio classes are coordination primitives and I/O abstractions, not descriptors; none implement the descriptor protocol (__get__/__set__/__delete__)."
    - "asyncio.Lock, asyncio.Semaphore, asyncio.Condition, asyncio.BoundedSemaphore are synchronization primitives; descriptor protocol support would be semantically inappropriate."
    - "asyncio.StreamReader and asyncio.StreamWriter are I/O stream wrappers; they do not participate in attribute lookup protocol."
    - "asyncio.Timeout and asyncio.TaskGroup are async context managers (wave 651) but implement no descriptor protocol."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
#
# No asyncio class defines __get__ in its own __dict__; all results are false.
# asyncio classes are coordination primitives and I/O abstractions, not
# descriptors. None implement the non-data or data descriptor __get__ method.
# ---------------------------------------------------------------------------

