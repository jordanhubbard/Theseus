spec: theseus_pathlib
version: ">=3.9"
backend: python_cleanroom(theseus_pathlib)

docs: https://en.wikipedia.org/wiki/Path_(computing)

provenance:
  derived_from:
    - "https://en.wikipedia.org/wiki/Path_(computing) — filesystem path concepts"
  notes:
    - "Clean-room path manipulation. Do NOT import pathlib, os.path, or posixpath."
    - "Implement using only Python stdlib string operations."
    - "path_join: join('a', 'b', 'c') returns 'a/b/c'."
    - "path_basename: basename('/foo/bar.txt') returns 'bar.txt'."
    - "path_dirname: dirname('/foo/bar.txt') returns '/foo'."
    - "path_splitext: splitext('file.txt') returns ('file', '.txt') — return the extension part."
    - "path_is_absolute: is_absolute('/foo') returns True; is_absolute('foo') returns False."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_pathlib.join_abc:
  description: "join('a', 'b', 'c') == 'a/b/c'"
  category: join
  kind: python_call_eq
  function: path_join
  args: ["a", "b", "c"]
  expected: "a/b/c"

invariant theseus_pathlib.basename:
  description: "basename('/foo/bar.txt') == 'bar.txt'"
  category: basename
  kind: python_call_eq
  function: path_basename
  args: ["/foo/bar.txt"]
  expected: "bar.txt"

invariant theseus_pathlib.dirname:
  description: "dirname('/foo/bar.txt') == '/foo'"
  category: dirname
  kind: python_call_eq
  function: path_dirname
  args: ["/foo/bar.txt"]
  expected: "/foo"
