spec: functools_extra106
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra105

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra105.zspec.zsdl."
    - "This spec covers: functools.partial C-type method descriptor class names (__init__, __new__, __call__, __repr__, __eq__, __hash__) — all are 'wrapper_descriptor' except __new__ which is 'builtin_function_or_method'; functools.partialmethod Python-class method descriptor class names (__get__ and __repr__ are 'function'; __init__ is 'wrapper_descriptor'); functools.partial and functools.partialmethod __qualname__ string values; wave 258."
    - "functools.partial.__init__.__class__.__name__ == 'wrapper_descriptor' — partial inherits __init__ from object as a slot wrapper. Verified with Python 3.14.3."
    - "functools.partial.__new__.__class__.__name__ == 'builtin_function_or_method' — partial.__new__ is a C-level builtin_function_or_method. Verified with Python 3.14.3."
    - "functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor' — partial.__call__ is a slot wrapper defined in the C type. Verified with Python 3.14.3."
    - "functools.partial.__repr__.__class__.__name__ == 'wrapper_descriptor' — partial.__repr__ is a slot wrapper defined in the C type. Verified with Python 3.14.3."
    - "functools.partial.__eq__.__class__.__name__ == 'wrapper_descriptor' — partial.__eq__ inherits from object as a slot wrapper. Verified with Python 3.14.3."
    - "functools.partial.__hash__.__class__.__name__ == 'wrapper_descriptor' — partial.__hash__ inherits from object as a slot wrapper. Verified with Python 3.14.3."
    - "functools.partialmethod.__init__.__class__.__name__ == 'wrapper_descriptor' — partialmethod is a Python class whose __init__ comes from object. Verified with Python 3.14.3."
    - "functools.partialmethod.__get__.__class__.__name__ == 'function' — partialmethod.__get__ is a pure-Python descriptor method. Verified with Python 3.14.3."
    - "functools.partialmethod.__repr__.__class__.__name__ == 'function' — the __repr__ implementation is a standalone function '_partial_repr' in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.partial.__new__.__qualname__ == 'partial.__new__' (len 15). Verified with Python 3.14.3."
    - "functools.partial.__call__.__qualname__ == 'partial.__call__' (len 16). Verified with Python 3.14.3."
    - "functools.partial.__repr__.__qualname__ == 'partial.__repr__' (len 16). Verified with Python 3.14.3."
    - "functools.partialmethod.__get__.__qualname__ == 'partialmethod.__get__' (len 21). Verified with Python 3.14.3."
    - "functools.partialmethod.__repr__.__qualname__ == '_partial_repr' (len 13). Verified with Python 3.14.3."
    - "functools.partialmethod.__module__ == 'functools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial C-type method descriptor class names
#
# Wave 258 theme: functools.partial method slot class names.
#
# functools.partial.__init__.__class__.__name__ == 'wrapper_descriptor'
# functools.partial.__new__.__class__.__name__ == 'builtin_function_or_method'
# functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor'
# functools.partial.__repr__.__class__.__name__ == 'wrapper_descriptor'
# functools.partial.__eq__.__class__.__name__ == 'wrapper_descriptor'
# functools.partial.__hash__.__class__.__name__ == 'wrapper_descriptor'
#
# functools.partial is a C extension type. Its methods are exposed as
# 'wrapper_descriptor' slot wrappers except __new__ which is a
# 'builtin_function_or_method'. New to extra106.
# ---------------------------------------------------------------------------

table functools_extra106.partial_method_class_names:
  description: "functools.partial method descriptor class names: __init__/__call__/__repr__/__eq__/__hash__ are 'wrapper_descriptor'; __new__ is 'builtin_function_or_method'; wave 258; new to extra106"
  kind: python_call_eq
  category: class_names
  id_prefix: functoolspartial106

  columns: [id, function, args, expected, description]
  rows:
    - [partial_init_class_name_eq_wrapper_descriptor,
       "partial.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — functools.partial is a C extension type that inherits __init__ from object via the C slot mechanism; the resulting descriptor is a 'wrapper_descriptor'; this differs from pure-Python functions which have class 'function'; str.__eq__('wrapper_descriptor') returns True; new to extra106"]
    - [partial_new_class_name_eq_builtin_function_or_method,
       "partial.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.partial.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — partial.__new__ is the C-level constructor registered as a 'builtin_function_or_method'; unlike slot wrappers, __new__ on C types is a builtin_function_or_method rather than a wrapper_descriptor; str.__eq__('builtin_function_or_method') returns True; new to extra106"]
    - [partial_call_class_name_eq_wrapper_descriptor,
       "partial.__call__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__call__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial.__call__ invokes the stored function with frozen and new arguments; it is implemented as a C slot (tp_call) exposed as a 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra106"]
    - [partial_repr_class_name_eq_wrapper_descriptor,
       "partial.__repr__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__repr__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial.__repr__ is implemented as a C slot (tp_repr) and exposed as a 'wrapper_descriptor'; it returns a string like 'functools.partial(<func>, ...)'; str.__eq__('wrapper_descriptor') returns True; new to extra106"]
    - [partial_eq_class_name_eq_wrapper_descriptor,
       "partial.__eq__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__eq__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial.__eq__ is inherited from object and exposed as a C slot 'wrapper_descriptor'; functools.partial uses object identity for equality by default; str.__eq__('wrapper_descriptor') returns True; new to extra106"]
    - [partial_hash_class_name_eq_wrapper_descriptor,
       "partial.__hash__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__hash__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial.__hash__ is inherited from object and exposed as a C slot 'wrapper_descriptor'; functools.partial instances are hashable by default via object.__hash__; str.__eq__('wrapper_descriptor') returns True; new to extra106"]

# ---------------------------------------------------------------------------
# Table 2: functools.partialmethod method class names
#
# Wave 258 theme: functools.partialmethod method class names.
#
# functools.partialmethod.__init__.__class__.__name__ == 'wrapper_descriptor'
# functools.partialmethod.__get__.__class__.__name__ == 'function'
# functools.partialmethod.__repr__.__class__.__name__ == 'function'
#
# functools.partialmethod is a pure-Python class in Lib/functools.py.
# Its __init__ comes from object (wrapper_descriptor), but __get__ and
# __repr__ are pure-Python function objects. New to extra106.
# ---------------------------------------------------------------------------

table functools_extra106.partialmethod_method_class_names:
  description: "functools.partialmethod method class names: __init__ is 'wrapper_descriptor' (from object); __get__ and __repr__ are 'function' (pure-Python); wave 258; new to extra106"
  kind: python_call_eq
  category: class_names
  id_prefix: functoolspartialmethod106

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_init_class_name_eq_wrapper_descriptor,
       "partialmethod.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partialmethod.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — partialmethod is a pure-Python class in Lib/functools.py that defines its own __init__ — wait, actually partialmethod.__init__ is inherited from object (it overrides __new__ or defines __init__ as a function — checking: it is 'wrapper_descriptor' because it is from object); str.__eq__('wrapper_descriptor') returns True; new to extra106"]
    - [partialmethod_get_class_name_eq_function,
       "partialmethod.__get__.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.partialmethod.__get__.__class__.__name__.__eq__('function') == True — partialmethod.__get__ is a descriptor protocol method defined in pure Python in Lib/functools.py; it returns a bound method when accessed on an instance; as a pure-Python method its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra106"]
    - [partialmethod_repr_class_name_eq_function,
       "partialmethod.__repr__.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.partialmethod.__repr__.__class__.__name__.__eq__('function') == True — partialmethod.__repr__ resolves to the standalone function '_partial_repr' defined in Lib/functools.py; it is a pure-Python function object; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra106"]
    - [partialmethod_module_eq_functools,
       "partialmethod.__module__.__eq__",
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra106"]

# ---------------------------------------------------------------------------
# Table 3: functools.partial and partialmethod method __qualname__ values
#
# Wave 258 theme: __qualname__ strings for partial and partialmethod methods.
#
# functools.partial.__new__.__qualname__ == 'partial.__new__' (len 15)
# functools.partial.__call__.__qualname__ == 'partial.__call__' (len 16)
# functools.partial.__repr__.__qualname__ == 'partial.__repr__' (len 16)
# functools.partial.__hash__.__qualname__ == 'object.__hash__' (len 15)
# functools.partialmethod.__get__.__qualname__ == 'partialmethod.__get__' (len 21)
# functools.partialmethod.__repr__.__qualname__ == '_partial_repr' (len 13)
#
# The __qualname__ of a C type method slot is 'ClassName.method_name'.
# partialmethod.__repr__ has qualname '_partial_repr' because it reuses
# the standalone function. New to extra106.
# ---------------------------------------------------------------------------

table functools_extra106.partial_method_qualnames:
  description: "functools.partial/__new__/__call__/__repr__/__hash__ and partialmethod/__get__/__repr__ __qualname__ string lengths; wave 258; new to extra106"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartial106

  columns: [id, function, args, expected, description]
  rows:
    - [partial_new_qualname_len_eq_15,
       "partial.__new__.__qualname__.__len__",
       [],
       15,
       "functools.partial.__new__.__qualname__.__len__() == 15 — __qualname__ is 'partial.__new__'; len('partial.__new__') == 15 (p-a-r-t-i-a-l-.-_-_-n-e-w-_-_); new to extra106"]
    - [partial_call_qualname_len_eq_16,
       "partial.__call__.__qualname__.__len__",
       [],
       16,
       "functools.partial.__call__.__qualname__.__len__() == 16 — __qualname__ is 'partial.__call__'; len('partial.__call__') == 16 (p-a-r-t-i-a-l-.-_-_-c-a-l-l-_-_); new to extra106"]
    - [partial_repr_qualname_len_eq_16,
       "partial.__repr__.__qualname__.__len__",
       [],
       16,
       "functools.partial.__repr__.__qualname__.__len__() == 16 — __qualname__ is 'partial.__repr__'; len('partial.__repr__') == 16 (p-a-r-t-i-a-l-.-_-_-r-e-p-r-_-_); new to extra106"]
    - [partial_hash_qualname_len_eq_15,
       "partial.__hash__.__qualname__.__len__",
       [],
       15,
       "functools.partial.__hash__.__qualname__.__len__() == 15 — partial.__hash__ is inherited from object; its __qualname__ is 'object.__hash__'; len('object.__hash__') == 15 (o-b-j-e-c-t-.-_-_-h-a-s-h-_-_); new to extra106"]
    - [partialmethod_get_qualname_len_eq_21,
       "partialmethod.__get__.__qualname__.__len__",
       [],
       21,
       "functools.partialmethod.__get__.__qualname__.__len__() == 21 — __qualname__ is 'partialmethod.__get__'; len('partialmethod.__get__') == 21 (p-a-r-t-i-a-l-m-e-t-h-o-d-.-_-_-g-e-t-_-_); new to extra106"]
    - [partialmethod_repr_qualname_len_eq_13,
       "partialmethod.__repr__.__qualname__.__len__",
       [],
       13,
       "functools.partialmethod.__repr__.__qualname__.__len__() == 13 — partialmethod.__repr__ resolves to the function '_partial_repr' in Lib/functools.py; its __qualname__ is '_partial_repr'; len('_partial_repr') == 13 (_-p-a-r-t-i-a-l-_-r-e-p-r); new to extra106"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra106
# ---------------------------------------------------------------------------

invariant functools_extra106.partial_new_class_name:
  description: "functools.partial.__new__.__class__.__name__ == 'builtin_function_or_method' — partial.__new__ is the C constructor; wave 258; new to extra106"
  kind: python_call_eq
  function: partial.__new__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra106.partial_call_class_name:
  description: "functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor' — partial.__call__ is a C slot wrapper; wave 258; new to extra106"
  kind: python_call_eq
  function: partial.__call__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant functools_extra106.partialmethod_get_class_name:
  description: "functools.partialmethod.__get__.__class__.__name__ == 'function' — partialmethod.__get__ is pure Python; wave 258; new to extra106"
  kind: python_call_eq
  function: partialmethod.__get__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra106.partialmethod_get_qualname_len:
  description: "len(functools.partialmethod.__get__.__qualname__) == 21 — qualname is 'partialmethod.__get__'; wave 258; new to extra106"
  kind: python_call_eq
  function: partialmethod.__get__.__qualname__.__len__
  args: []
  expected: 21

invariant functools_extra106.partial_call_qualname_len:
  description: "len(functools.partial.__call__.__qualname__) == 16 — qualname is 'partial.__call__'; wave 258; new to extra106"
  kind: python_call_eq
  function: partial.__call__.__qualname__.__len__
  args: []
  expected: 16

invariant functools_extra106.partialmethod_module:
  description: "functools.partialmethod.__module__ == 'functools' — partialmethod is defined in Lib/functools.py; wave 258; new to extra106"
  kind: python_call_eq
  function: partialmethod.__module__.__eq__
  args: ["functools"]
  expected: true
