spec: uuid_extra37
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra36.zspec.zsdl — covers UUID dunder method __module__.__eq__('uuid') for __repr__/__hash__/__eq__/__int__/__lt__/__le__/__gt__/__ge__."
    - "uuid_extra35.zspec.zsdl — covers UUID dunder method __name__.__eq__ for __init__/__repr__/__hash__/__eq__/__int__/__lt__/__le__/__gt__/__ge__."
    - "uuid_extra34.zspec.zsdl — covers UUID.time/node/clock_seq/time_hi_version/clock_seq_hi_variant fget __qualname__.__eq__ string values."
    - "uuid_extra33.zspec.zsdl — covers UUID.hex.fget.__qualname__.__eq__('UUID.hex'); UUID.__repr__/__hash__/__eq__/__int__ __qualname__.__eq__."
    - "uuid_extra24.zspec.zsdl — covers UUID.node/time/clock_seq/time_hi_version/clock_seq_hi_variant fget __qualname__.__len__() (length checks only, NOT string eq values for fget __name__)."
    - "uuid_extra18.zspec.zsdl — covers UUID.bytes/version/bytes_le/fields/variant.fget.__qualname__.__eq__ and fget __qualname__.__len__(); hex/bytes/urn/version fget qualname coverage."
  notes:
    - "This spec extends uuid through uuid_extra36; it does NOT duplicate invariants present in those files."
    - "Coverage gap: No prior uuid spec checks the __name__.__eq__ attribute of any UUID property fget function. uuid_extra34 covers fget.__qualname__.__eq__ for time/node/clock_seq/time_hi_version/clock_seq_hi_variant; uuid_extra18 covers fget.__qualname__.__eq__ for bytes/version/bytes_le/fields/variant; uuid_extra33 covers hex.fget.__qualname__.__eq__. But __name__.__eq__ (the bare unqualified name) is a distinct attribute chain from __qualname__.__eq__ (the class-prefixed name). For property fget functions defined as 'def time(self):' in Lib/uuid.py, __name__ == 'time' while __qualname__ == 'UUID.time'. These are independent regression vectors. NO prior uuid spec checks ANY property fget __name__.__eq__ value. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__name__ == 'time'. uuid_extra34 covers __qualname__.__eq__('UUID.time'); uuid_extra24 covers __qualname__.__len__()==9. No prior spec checks time.fget.__name__.__eq__('time'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__name__ == 'variant'. uuid_extra18 covers __qualname__.__eq__('UUID.variant'). No prior spec checks variant.fget.__name__.__eq__('variant'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__name__ == 'bytes'. uuid_extra18 covers __qualname__.__eq__('UUID.bytes'). No prior spec checks bytes.fget.__name__.__eq__('bytes'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__name__ == 'hex'. uuid_extra33 covers __qualname__.__eq__('UUID.hex'). No prior spec checks hex.fget.__name__.__eq__('hex'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.urn.fget.__name__ == 'urn'. uuid_extra18 covers __qualname__.__eq__ and __qualname__.__len__() for urn. No prior spec checks urn.fget.__name__.__eq__('urn'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.fget.__name__ == 'node'. uuid_extra34 covers __qualname__.__eq__('UUID.node'); uuid_extra24 covers __qualname__.__len__()==9. No prior spec checks node.fget.__name__.__eq__('node'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__name__ == 'version'. uuid_extra18 covers version.fget.__qualname__.__eq__('UUID.version'). No prior spec checks version.fget.__name__.__eq__('version'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq.fget.__name__ == 'clock_seq'. uuid_extra34 covers __qualname__.__eq__('UUID.clock_seq'). No prior spec checks clock_seq.fget.__name__.__eq__('clock_seq'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID property fget __name__.__eq__ string values
#
# No prior uuid spec checks the __name__.__eq__ attribute of any UUID property fget.
# uuid_extra34 covers time/node/clock_seq/time_hi_version/clock_seq_hi_variant
#   fget.__qualname__.__eq__ (__qualname__ axis).
# uuid_extra18 covers bytes/version/bytes_le/fields/variant fget.__qualname__.__eq__
#   (__qualname__ axis).
# uuid_extra33 covers hex.fget.__qualname__.__eq__ (__qualname__ axis).
# uuid_extra24 covers time/node/clock_seq/time_hi_version/clock_seq_hi_variant
#   fget.__qualname__.__len__() (length axis).
# For property fget functions, __name__ gives the bare method name (e.g., 'time')
# while __qualname__ gives the class-prefixed form ('UUID.time').
# These are distinct attribute chains and provide independent regression vectors.
# All fget functions are Python-defined in Lib/uuid.py, so __name__ == property_name.
# ---------------------------------------------------------------------------

table uuid_extra37.UUID_property_fget_name_eq:
  description: "uuid.UUID property fget __name__.__eq__ string values — novel: extra34/extra18/extra33 cover fget __qualname__.__eq__ (different axis); extra24 covers fget __qualname__.__len__; no prior spec checks __name__.__eq__ for any UUID property fget"
  kind: python_call_eq
  category: function_names
  id_prefix: upfne37

  columns: [id, function, args, expected]
  rows:
    - [time_fget_name_eq,      "UUID.time.fget.__name__.__eq__",      ["time"],      true]
    - [variant_fget_name_eq,   "UUID.variant.fget.__name__.__eq__",   ["variant"],   true]
    - [bytes_fget_name_eq,     "UUID.bytes.fget.__name__.__eq__",     ["bytes"],     true]
    - [hex_fget_name_eq,       "UUID.hex.fget.__name__.__eq__",       ["hex"],       true]
    - [urn_fget_name_eq,       "UUID.urn.fget.__name__.__eq__",       ["urn"],       true]
    - [node_fget_name_eq,      "UUID.node.fget.__name__.__eq__",      ["node"],      true]
    - [version_fget_name_eq,   "UUID.version.fget.__name__.__eq__",   ["version"],   true]
    - [clock_seq_fget_name_eq, "UUID.clock_seq.fget.__name__.__eq__", ["clock_seq"], true]
