spec: chunk_extra3
version: ">=3.9,<3.13"
backend: python_module(chunk)

docs: https://docs.python.org/3.11/library/chunk.html

provenance:
  derived_from:
    - "https://docs.python.org/3.11/library/chunk.html — Python chunk module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/chunk.py"
    - "chunk.zspec.zsdl — covers Chunk.__name__, Chunk.__module__, Chunk method __name__ (table), Chunk.__class__.__name__, Chunk.__bases__[0].__name__"
    - "chunk_extra.zspec.zsdl — covers Chunk.__name__, Chunk.__module__, Chunk.__class__.__name__, Chunk.__bases__[0].__name__, Chunk method __name__ (table, including isatty)"
    - "chunk_extra2.zspec.zsdl — covers Chunk.__qualname__, Chunk.__bases__.__len__, Chunk method __qualname__ (table, including isatty, read, seek, tell, close, skip)"
  notes:
    - "This spec extends chunk.zspec.zsdl, chunk_extra.zspec.zsdl, and chunk_extra2.zspec.zsdl."
    - "The chunk module was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13."
    - "Focus: __class__.__name__ (type-identity) for Chunk methods; __module__ for Chunk methods."
    - "Methods accessed as class attributes (unbound) have __class__.__name__ == 'function'."
    - "Methods defined in a pure-Python module report __module__ == 'chunk'."
    - "No prior spec checks the __class__.__name__ or __module__ of any Chunk method."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Method type-identity checks — Chunk methods are plain Python functions
# Prior specs cover method __name__ and __qualname__; __class__.__name__ is new.
# Unbound methods accessed via the class are 'function' objects in Python 3.
# ---------------------------------------------------------------------------

table chunk_extra3.Chunk.method_types:
  kind: python_call_eq
  category: method_identity
  id_prefix: method_type

  columns: [id, function, args, expected]
  rows:
    - [getname, Chunk.getname.__class__.__name__.__eq__, ["function"], true]
    - [getsize, Chunk.getsize.__class__.__name__.__eq__, ["function"], true]
    - [read,    Chunk.read.__class__.__name__.__eq__,    ["function"], true]
    - [seek,    Chunk.seek.__class__.__name__.__eq__,    ["function"], true]
    - [tell,    Chunk.tell.__class__.__name__.__eq__,    ["function"], true]
    - [skip,    Chunk.skip.__class__.__name__.__eq__,    ["function"], true]
    - [close,   Chunk.close.__class__.__name__.__eq__,   ["function"], true]
    - [isatty,  Chunk.isatty.__class__.__name__.__eq__,  ["function"], true]

# ---------------------------------------------------------------------------
# Method __module__ checks — Chunk methods are defined in the chunk module
# No prior spec checks the __module__ attribute of any Chunk method.
# Pure-Python methods defined at module level report __module__ == 'chunk'.
# ---------------------------------------------------------------------------

table chunk_extra3.Chunk.method_modules:
  kind: python_call_eq
  category: method_modules
  id_prefix: method_module

  columns: [id, function, args, expected]
  rows:
    - [getname, Chunk.getname.__module__.__eq__, ["chunk"], true]
    - [getsize, Chunk.getsize.__module__.__eq__, ["chunk"], true]
    - [read,    Chunk.read.__module__.__eq__,    ["chunk"], true]
    - [seek,    Chunk.seek.__module__.__eq__,    ["chunk"], true]
    - [tell,    Chunk.tell.__module__.__eq__,    ["chunk"], true]
    - [skip,    Chunk.skip.__module__.__eq__,    ["chunk"], true]
    - [close,   Chunk.close.__module__.__eq__,   ["chunk"], true]
    - [isatty,  Chunk.isatty.__module__.__eq__,  ["chunk"], true]
