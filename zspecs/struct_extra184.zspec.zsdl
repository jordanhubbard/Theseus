spec: struct_extra184
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/struct.py"
  notes:
    - "struct.Struct.__doc__.__class__.__name__ == 'str' — Struct class has a str docstring."
    - "struct.Struct.__class__.__name__ == 'type' — Struct is a regular C-extension class created by type."
    - "struct.Struct.__mro__ len == 2 — [_struct.Struct, object]; no intermediate base classes."
    - "struct.Struct.__bases__[0].__name__ == 'object' — Struct directly extends object."
    - "struct.Struct.__qualname__ == 'Struct' — simple unqualified name."
    - "struct.Struct.__module__ == '_struct' — implemented in the _struct C extension."
    - "struct.pack.__doc__.__class__.__name__ == 'str' — pack() builtin has a str docstring."
    - "struct.unpack.__doc__.__class__.__name__ == 'str' — unpack() builtin has a str docstring."
    - "struct.calcsize.__doc__.__class__.__name__ == 'str' — calcsize() builtin has a str docstring."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.Struct class identity — __doc__, __class__, __mro__, __bases__
#
# struct.Struct.__doc__.__class__.__name__  == 'str'
# struct.Struct.__class__.__name__          == 'type'
# struct.Struct.__mro__.__len__()           == 2   ([_struct.Struct, object])
# struct.Struct.__bases__[0].__name__       == 'object'
#
# struct.Struct is implemented in the _struct C extension module.  Its MRO
# is [_struct.Struct, object], giving len 2.  The metaclass is the built-in
# 'type'.  The class has a docstring of type str.
# ---------------------------------------------------------------------------

table struct_extra184.struct_class_identity:
  description: "struct.Struct class __doc__, __class__, __mro__, __bases__ identity; new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: structdoc184

  columns: [id, function, args, expected, description]
  rows:
    - [struct_doc_class,
       struct.Struct.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "struct.Struct.__doc__.__class__.__name__.__eq__('str') == True — Struct class has a str docstring; new to extra184"]
    - [struct_class_name,
       struct.Struct.__class__.__name__.__eq__,
       ["type"],
       true,
       "struct.Struct.__class__.__name__.__eq__('type') == True — Struct metaclass is built-in type; new to extra184"]
    - [struct_mro_len,
       struct.Struct.__mro__.__len__,
       [],
       2,
       "struct.Struct.__mro__.__len__() == 2 — MRO is [_struct.Struct, object]; no intermediate base classes; new to extra184"]
    - [struct_bases_object,
       "struct.Struct.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "struct.Struct.__bases__[0].__name__.__eq__('object') == True — Struct directly extends object; new to extra184"]

# ---------------------------------------------------------------------------
# Table 2: struct.Struct __qualname__ and __module__ identity
#
# struct.Struct.__qualname__ == 'Struct'    (len=6)
# struct.Struct.__module__   == '_struct'   (len=7)
#
# The __qualname__ is the simple unqualified name 'Struct'.  The __module__
# is '_struct' because the class is defined in the private C extension,
# even though it is accessible as struct.Struct via the public Python wrapper.
# ---------------------------------------------------------------------------

table struct_extra184.struct_qualname_module:
  description: "struct.Struct __qualname__ and __module__ identity; new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: structdoc184

  columns: [id, function, args, expected, description]
  rows:
    - [struct_qualname_eq,
       struct.Struct.__qualname__.__eq__,
       ["Struct"],
       true,
       "struct.Struct.__qualname__.__eq__('Struct') == True — simple unqualified name; len=6; new to extra184"]
    - [struct_qualname_len,
       struct.Struct.__qualname__.__len__,
       [],
       6,
       "struct.Struct.__qualname__.__len__() == 6 — 'Struct' has 6 characters; new to extra184"]
    - [struct_module_eq,
       struct.Struct.__module__.__eq__,
       ["_struct"],
       true,
       "struct.Struct.__module__.__eq__('_struct') == True — implemented in _struct C extension; new to extra184"]
    - [struct_module_len,
       struct.Struct.__module__.__len__,
       [],
       7,
       "struct.Struct.__module__.__len__() == 7 — '_struct' has 7 characters; new to extra184"]

# ---------------------------------------------------------------------------
# Table 3: struct module-level function __doc__ class identity
#
# struct.pack.__doc__.__class__.__name__     == 'str'
# struct.unpack.__doc__.__class__.__name__   == 'str'
# struct.calcsize.__doc__.__class__.__name__ == 'str'
#
# pack, unpack, and calcsize are C-level builtin functions exposed by the
# _struct extension.  All three carry docstrings of type str accessible
# via __doc__.
# ---------------------------------------------------------------------------

table struct_extra184.function_doc_class:
  description: "struct module-level functions (pack, unpack, calcsize) have str docstrings; new to extra184"
  kind: python_call_eq
  category: identity
  id_prefix: structdoc184

  columns: [id, function, args, expected, description]
  rows:
    - [pack_doc_class,
       struct.pack.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "struct.pack.__doc__.__class__.__name__.__eq__('str') == True — pack() has a str docstring; new to extra184"]
    - [unpack_doc_class,
       struct.unpack.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "struct.unpack.__doc__.__class__.__name__.__eq__('str') == True — unpack() has a str docstring; new to extra184"]
    - [calcsize_doc_class,
       struct.calcsize.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "struct.calcsize.__doc__.__class__.__name__.__eq__('str') == True — calcsize() has a str docstring; new to extra184"]
    - [pack_name_eq,
       struct.pack.__name__.__eq__,
       ["pack"],
       true,
       "struct.pack.__name__.__eq__('pack') == True — pack function name; len=4; new to extra184"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra184
# ---------------------------------------------------------------------------

invariant struct_extra184.struct_doc_is_str:
  description: "struct.Struct.__doc__.__class__.__name__ == 'str' — Struct class has a str docstring; new to extra184"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant struct_extra184.struct_class_is_type:
  description: "struct.Struct.__class__.__name__ == 'type' — Struct metaclass is built-in type; new to extra184"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant struct_extra184.struct_mro_len:
  description: "struct.Struct.__mro__.__len__() == 2 — MRO is [_struct.Struct, object]; no intermediate base classes; new to extra184"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__mro__.__len__
  args: []
  expected: 2

invariant struct_extra184.struct_bases_object:
  description: "struct.Struct.__bases__[0].__name__ == 'object' — Struct directly extends object; new to extra184"
  category: identity
  kind: python_call_eq
  function: "struct.Struct.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant struct_extra184.struct_qualname:
  description: "struct.Struct.__qualname__ == 'Struct' — simple unqualified name; len=6; new to extra184"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__qualname__.__eq__
  args: ["Struct"]
  expected: true

invariant struct_extra184.pack_doc_is_str:
  description: "struct.pack.__doc__.__class__.__name__ == 'str' — pack() builtin has a str docstring; new to extra184"
  category: identity
  kind: python_call_eq
  function: struct.pack.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant struct_extra184.unpack_doc_is_str:
  description: "struct.unpack.__doc__.__class__.__name__ == 'str' — unpack() builtin has a str docstring; new to extra184"
  category: identity
  kind: python_call_eq
  function: struct.unpack.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant struct_extra184.calcsize_doc_is_str:
  description: "struct.calcsize.__doc__.__class__.__name__ == 'str' — calcsize() builtin has a str docstring; new to extra184"
  category: identity
  kind: python_call_eq
  function: struct.calcsize.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
