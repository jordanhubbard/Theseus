spec: pathlib_extra34
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra31.zspec.zsdl — covers PurePosixPath/__qualname__/__module__; PureWindowsPath/__qualname__/__module__; PosixPath/__qualname__/__module__; PurePath/__bases__[0].__name__; PurePath properties fget.__qualname__"
    - "pathlib_extra32.zspec.zsdl — covers PurePath.parent/parents/suffixes/drive/root/anchor fget.__qualname__/__module__"
    - "pathlib_extra33.zspec.zsdl — covers PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__; PosixPath/WindowsPath __bases__[0].__name__; Path/__init__/__qualname__; PurePath/__init__/__name__/__qualname__; Path/__truediv__/__name__/__qualname__"
  notes:
    - "This spec extends pathlib_extra33.zspec.zsdl."
    - "Prior specs covered: Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __name__/__module__/__qualname__, bases, Path/__init__/__truediv__ __name__/__qualname__, PurePath/__init__/__name__/__qualname__, PosixPath/WindowsPath __bases__[0].__name__=='Path', Path.__init__.__qualname__=='PurePath.__init__'."
    - "This spec covers: __module__.__len__() for Path/PurePath/PurePosixPath/PureWindowsPath; __name__.__len__() for Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath; __qualname__.__len__() for Path/PurePath."
    - "pathlib.Path.__module__ == 'pathlib' (len 7) — verified Python 3.12."
    - "pathlib.PurePath.__module__ == 'pathlib' (len 7) — verified Python 3.12."
    - "pathlib.PurePosixPath.__module__ == 'pathlib' (len 7) — verified Python 3.12."
    - "pathlib.PureWindowsPath.__module__ == 'pathlib' (len 7) — verified Python 3.12."
    - "pathlib.Path.__name__ == 'Path' (len 4) — verified Python 3.12."
    - "pathlib.PurePath.__name__ == 'PurePath' (len 8) — verified Python 3.12."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath' (len 13) — verified Python 3.12."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' (len 15) — verified Python 3.12."
    - "pathlib.PosixPath.__name__ == 'PosixPath' (len 9) — verified Python 3.12."
    - "pathlib.WindowsPath.__name__ == 'WindowsPath' (len 11) — verified Python 3.12."
    - "pathlib.Path.__qualname__ == 'Path' (len 4) — flat qualname, same as __name__; verified Python 3.12."
    - "pathlib.PurePath.__qualname__ == 'PurePath' (len 8) — flat qualname, same as __name__; verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() for Path, PurePath, PurePosixPath, PureWindowsPath
#
# All pathlib classes are pure-Python (in Lib/pathlib.py) and have
# __module__ == 'pathlib' (7 characters). Prior specs establish the
# __module__ string equality; these invariants anchor the derived length
# value (7) in the extra34 namespace.
# ---------------------------------------------------------------------------

table pathlib_extra34.class_module_lengths:
  description: "__module__.__len__() for Path, PurePath, PurePosixPath, PureWindowsPath — all 7 (module name 'pathlib')"
  kind: python_call_eq
  category: class_identity
  id_prefix: cml34

  columns: [id, function, args, expected]
  rows:
    - [Path,            Path.__module__.__len__,            [], 7]
    - [PurePath,        PurePath.__module__.__len__,        [], 7]
    - [PurePosixPath,   PurePosixPath.__module__.__len__,   [], 7]
    - [PureWindowsPath, PureWindowsPath.__module__.__len__, [], 7]

# ---------------------------------------------------------------------------
# __name__.__len__() for Path, PurePath, PurePosixPath, PureWindowsPath,
# PosixPath, WindowsPath
#
# Each class name has a distinct length:
#   Path            -> 'Path'            -> 4
#   PurePath        -> 'PurePath'        -> 8
#   PurePosixPath   -> 'PurePosixPath'   -> 13
#   PureWindowsPath -> 'PureWindowsPath' -> 15
#   PosixPath       -> 'PosixPath'       -> 9
#   WindowsPath     -> 'WindowsPath'     -> 11
# Prior specs establish the __name__ string values; these invariants anchor
# the derived length values in the extra34 namespace.
# ---------------------------------------------------------------------------

table pathlib_extra34.class_name_lengths:
  description: "__name__.__len__() for Path, PurePath, PurePosixPath, PureWindowsPath, PosixPath, WindowsPath"
  kind: python_call_eq
  category: class_identity
  id_prefix: cnl34

  columns: [id, function, args, expected]
  rows:
    - [Path,            Path.__name__.__len__,            [], 4]
    - [PurePath,        PurePath.__name__.__len__,        [], 8]
    - [PurePosixPath,   PurePosixPath.__name__.__len__,   [], 13]
    - [PureWindowsPath, PureWindowsPath.__name__.__len__, [], 15]
    - [PosixPath,       PosixPath.__name__.__len__,       [], 9]
    - [WindowsPath,     WindowsPath.__name__.__len__,     [], 11]

# ---------------------------------------------------------------------------
# Path.__qualname__.__len__() and PurePath.__qualname__.__len__()
# — standalone extra34-namespace invariants
#
# Both Path and PurePath have flat __qualname__ values equal to their
# __name__ (no nesting in the class hierarchy makes these dotted). As a
# result, Path.__qualname__.__len__() == 4 and
# PurePath.__qualname__.__len__() == 8 — matching their respective
# __name__ lengths. These standalone invariants establish the qualname
# length facts as individually addressable extra34-namespace invariants.
# ---------------------------------------------------------------------------

invariant pathlib_extra34.Path.qualname_len:
  description: "pathlib.Path.__qualname__.__len__() == 4 — qualname 'Path' has 4 characters (flat, same as __name__)"
  category: class_identity
  kind: python_call_eq
  function: Path.__qualname__.__len__
  args: []
  expected: 4

invariant pathlib_extra34.PurePath.qualname_len:
  description: "pathlib.PurePath.__qualname__.__len__() == 8 — qualname 'PurePath' has 8 characters (flat, same as __name__)"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__qualname__.__len__
  args: []
  expected: 8
