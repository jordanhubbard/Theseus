spec: concurrent_futures_extra106
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra105.zspec.zsdl."
    - "This spec covers: wave 254 theme — concurrent.futures.wait return type (namedtuple DoneAndNotDoneFutures), and concurrent.futures.as_completed and wait function code attributes. Also ThreadPoolExecutor.map and ProcessPoolExecutor.map code attrs. NEW in extra106: concurrent.futures.as_completed.__code__.co_name=='as_completed' (co_argcount=2: fs, timeout); concurrent.futures.wait.__code__.co_name=='wait' (co_argcount=3: fs, timeout, return_when); concurrent.futures.ThreadPoolExecutor.map.__code__.co_name=='map' (co_argcount=2: self, fn; others keyword-only); concurrent.futures.ProcessPoolExecutor.map.__qualname__=='ProcessPoolExecutor.map' (len=23, co_argcount=2); DoneAndNotDoneFutures.__name__=='DoneAndNotDoneFutures', __bases__[0].__name__=='tuple', __mro__.__len__()==3, _fields==('done','not_done'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__code__.co_argcount == 2. The two parameters are fs and timeout. as_completed.__code__.co_name=='as_completed'; as_completed.__qualname__=='as_completed' (len=12). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__code__.co_argcount == 3. The three parameters are fs, timeout, and return_when. wait.__code__.co_name=='wait'; wait.__qualname__=='wait' (len=4, shortest qualname in spec). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures._base.DoneAndNotDoneFutures.__name__=='DoneAndNotDoneFutures', __bases__[0].__name__=='tuple' (it is a namedtuple subclass), __mro__.__len__()==3 ([DoneAndNotDoneFutures, tuple, object]), _fields==('done','not_done'). This is the return type of concurrent.futures.wait(). DoneAndNotDoneFutures.__name__.__len__()==21 (longest class name in spec). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.as_completed and wait code attributes — extra106
#
# Wave 254 theme: as_completed and wait function code attributes.
#
# concurrent.futures.as_completed.__code__.co_name  == 'as_completed'  (co_argcount=2)
# concurrent.futures.wait.__code__.co_name          == 'wait'          (co_argcount=3)
# ---------------------------------------------------------------------------

table concurrent_futures_extra106.cf_as_completed_wait_code_attrs:
  description: "concurrent.futures.as_completed and wait function code attribute checks in cfwait106 namespace — wave 254 theme: concurrent.futures.as_completed.__code__.co_name.__eq__('as_completed')==True; concurrent.futures.as_completed.__code__.co_argcount==2 (fs and timeout); concurrent.futures.as_completed.__qualname__.__eq__('as_completed')==True (len=12: 'as_completed'=12); concurrent.futures.wait.__code__.co_name.__eq__('wait')==True; concurrent.futures.wait.__code__.co_argcount==3 (fs, timeout, return_when); concurrent.futures.wait.__qualname__.__eq__('wait')==True (len=4: 'wait'=4, shortest qualname in spec); compare: as_completed co_argcount=2 < wait co_argcount=3; as_completed qualname=12 (longer) vs wait qualname=4 (shorter and fewest chars in spec); wait qualname=4 is the shortest qualname in this spec; as_completed is a generator that yields futures as they complete; wait blocks until a condition is met and returns a DoneAndNotDoneFutures namedtuple; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfwait106

  columns: [id, function, args, expected, description]
  rows:
    - [ac_co_name,      concurrent.futures.as_completed.__code__.co_name.__eq__,       ["as_completed"],      true, "as_completed.__code__.co_name == 'as_completed'; verified with Python 3.14.3"]
    - [ac_co_argc,      concurrent.futures.as_completed.__code__.co_argcount.__eq__,   [2],                   true, "as_completed.__code__.co_argcount == 2 (fs and timeout); verified with Python 3.14.3"]
    - [ac_qn_eq,        concurrent.futures.as_completed.__qualname__.__eq__,           ["as_completed"],      true, "as_completed.__qualname__ == 'as_completed' (len=12); verified with Python 3.14.3"]
    - [ac_qn_len,       concurrent.futures.as_completed.__qualname__.__len__,          [],                    12,   "as_completed.__qualname__.__len__() == 12 ('as_completed'=12); verified with Python 3.14.3"]
    - [wait_co_name,    concurrent.futures.wait.__code__.co_name.__eq__,               ["wait"],              true, "wait.__code__.co_name == 'wait'; verified with Python 3.14.3"]
    - [wait_co_argc,    concurrent.futures.wait.__code__.co_argcount.__eq__,           [3],                   true, "wait.__code__.co_argcount == 3 (fs, timeout, return_when); verified with Python 3.14.3"]
    - [wait_qn_eq,      concurrent.futures.wait.__qualname__.__eq__,                   ["wait"],              true, "wait.__qualname__ == 'wait' (len=4, shortest qualname in spec); verified with Python 3.14.3"]
    - [wait_qn_len,     concurrent.futures.wait.__qualname__.__len__,                  [],                    4,    "wait.__qualname__.__len__() == 4 ('wait'=4, shortest in spec); verified with Python 3.14.3"]
    - [ac_wait_cmp,     concurrent.futures.as_completed.__qualname__.__len__,          [],                    12,   "as_completed qualname len=12 > wait qualname len=4; longest vs shortest in spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ThreadPoolExecutor.map and ProcessPoolExecutor.map code attributes — extra106
#
# Wave 254 theme: Executor.map code attributes.
#
# ThreadPoolExecutor.map.__code__.co_name     == 'map'               (co_argcount=2: self, fn)
# ProcessPoolExecutor.map.__qualname__        == 'ProcessPoolExecutor.map' (len=23)
# ---------------------------------------------------------------------------

table concurrent_futures_extra106.cf_executor_map_code_attrs:
  description: "concurrent.futures.ThreadPoolExecutor.map and ProcessPoolExecutor.map code attribute checks in cfwait106 namespace — wave 254 theme: concurrent.futures.ThreadPoolExecutor.map.__code__.co_name.__eq__('map')==True; concurrent.futures.ThreadPoolExecutor.map.__code__.co_argcount==2 (self and fn; iterables and timeout are keyword-only); concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__('Executor.map')==True (len=12: 'Executor.map'=12 — the method is defined on Executor base class); concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__('ProcessPoolExecutor.map')==True (len=23: 'ProcessPoolExecutor.'=20+'map'=3=23, longest qualname in spec); concurrent.futures.ProcessPoolExecutor.map.__code__.co_argcount==2 (self and fn); compare qualname lengths: ThreadPoolExecutor.map qualname='Executor.map'=12 (shorter, since method defined on Executor base) vs ProcessPoolExecutor.map qualname='ProcessPoolExecutor.map'=23 (longer); both map methods have co_argcount=2; wait qualname=4 (shortest in spec); as_completed qualname=12 (tied with Executor.map); ProcessPoolExecutor.map=23 (longest in spec); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfwait106a

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_map_co_name, concurrent.futures.ThreadPoolExecutor.map.__code__.co_name.__eq__, ["map"],           true, "ThreadPoolExecutor.map.__code__.co_name == 'map' (defined on Executor base class); verified with Python 3.14.3"]
    - [tpe_map_co_argc, concurrent.futures.ThreadPoolExecutor.map.__code__.co_argcount.__eq__, [2],           true, "ThreadPoolExecutor.map.__code__.co_argcount == 2 (self and fn; others keyword-only); verified with Python 3.14.3"]
    - [tpe_map_qn_eq,   concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__,    ["Executor.map"],  true, "ThreadPoolExecutor.map.__qualname__ == 'Executor.map' (len=12, method defined on Executor base); verified with Python 3.14.3"]
    - [tpe_map_qn_len,  concurrent.futures.ThreadPoolExecutor.map.__qualname__.__len__,   [],                12,   "ThreadPoolExecutor.map.__qualname__.__len__() == 12 ('Executor.map'=12); verified with Python 3.14.3"]
    - [ppe_map_co_argc, concurrent.futures.ProcessPoolExecutor.map.__code__.co_argcount.__eq__, [2],          true, "ProcessPoolExecutor.map.__code__.co_argcount == 2 (self and fn; others keyword-only); verified with Python 3.14.3"]
    - [ppe_map_qn_eq,   concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__,   ["ProcessPoolExecutor.map"], true, "ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (len=23, longest in spec); verified with Python 3.14.3"]
    - [ppe_map_qn_len,  concurrent.futures.ProcessPoolExecutor.map.__qualname__.__len__,  [],                23,   "ProcessPoolExecutor.map.__qualname__.__len__() == 23 ('ProcessPoolExecutor.map'=23, longest qualname in spec); verified with Python 3.14.3"]
    - [ppe_map_co_name, concurrent.futures.ProcessPoolExecutor.map.__code__.co_name.__eq__, ["map"],          true, "ProcessPoolExecutor.map.__code__.co_name == 'map'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# DoneAndNotDoneFutures namedtuple identity — extra106
#
# Wave 254 theme: wait() return type identity.
#
# DoneAndNotDoneFutures.__name__             == 'DoneAndNotDoneFutures' (len=21)
# DoneAndNotDoneFutures.__bases__[0].__name__ == 'tuple'              (namedtuple)
# DoneAndNotDoneFutures.__mro__.__len__()    == 3
# DoneAndNotDoneFutures._fields              == ('done', 'not_done')
# ---------------------------------------------------------------------------

table concurrent_futures_extra106.cf_done_and_not_done_futures_identity:
  description: "concurrent.futures._base.DoneAndNotDoneFutures namedtuple identity checks in cfwait106 namespace — wave 254 theme: concurrent.futures._base.DoneAndNotDoneFutures.__name__.__eq__('DoneAndNotDoneFutures')==True (len=21: longest class name in spec); concurrent.futures._base.DoneAndNotDoneFutures.__bases__[0].__name__.__eq__('tuple')==True (DoneAndNotDoneFutures is a namedtuple — its base is tuple, MRO=[DoneAndNotDoneFutures, tuple, object], length=3); concurrent.futures._base.DoneAndNotDoneFutures.__mro__.__len__()==3; concurrent.futures._base.DoneAndNotDoneFutures._fields.__len__()==2 (the two fields are 'done' and 'not_done'); concurrent.futures._base.DoneAndNotDoneFutures.__module__.__eq__('concurrent.futures._base')==True; DoneAndNotDoneFutures is the return type of concurrent.futures.wait(); compare namedtuple mro len=3 ([DoneAndNotDoneFutures, tuple, object]) vs plain function qualname: wait=4 (shortest) < as_completed=12 < Executor.map=12 < ProcessPoolExecutor.map=23 < DoneAndNotDoneFutures name len=21; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cfwait106b

  columns: [id, function, args, expected, description]
  rows:
    - [nt_name_eq,      concurrent.futures._base.DoneAndNotDoneFutures.__name__.__eq__,        ["DoneAndNotDoneFutures"], true, "DoneAndNotDoneFutures.__name__ == 'DoneAndNotDoneFutures' (len=21, longest class name in spec); verified with Python 3.14.3"]
    - [nt_name_len,     concurrent.futures._base.DoneAndNotDoneFutures.__name__.__len__,       [],                        21,   "DoneAndNotDoneFutures.__name__.__len__() == 21 ('DoneAndNotDoneFutures'=21); verified with Python 3.14.3"]
    - [nt_base_eq,      "concurrent.futures._base.DoneAndNotDoneFutures.__bases__[0].__name__.__eq__", ["tuple"],         true, "DoneAndNotDoneFutures.__bases__[0].__name__ == 'tuple' (namedtuple subclass); verified with Python 3.14.3"]
    - [nt_mro_len,      concurrent.futures._base.DoneAndNotDoneFutures.__mro__.__len__,        [],                        3,    "DoneAndNotDoneFutures.__mro__.__len__() == 3 ([DoneAndNotDoneFutures, tuple, object]); verified with Python 3.14.3"]
    - [nt_fields_len,   concurrent.futures._base.DoneAndNotDoneFutures._fields.__len__,        [],                        2,    "DoneAndNotDoneFutures._fields.__len__() == 2 ('done' and 'not_done'); verified with Python 3.14.3"]
    - [nt_module_eq,    concurrent.futures._base.DoneAndNotDoneFutures.__module__.__eq__,      ["concurrent.futures._base"], true, "DoneAndNotDoneFutures.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [nt_field0_eq,    "concurrent.futures._base.DoneAndNotDoneFutures._fields[0].__eq__",    ["done"],                  true, "DoneAndNotDoneFutures._fields[0] == 'done'; verified with Python 3.14.3"]
    - [nt_field1_eq,    "concurrent.futures._base.DoneAndNotDoneFutures._fields[1].__eq__",    ["not_done"],              true, "DoneAndNotDoneFutures._fields[1] == 'not_done'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra106
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra106.as_completed_co_argcount_2:
  description: "concurrent.futures.as_completed.__code__.co_argcount == 2 — as_completed takes fs (futures iterable) and timeout; as_completed.__code__.co_name=='as_completed'; as_completed.__qualname__=='as_completed' (len=12); compare: wait.__code__.co_argcount==3 (fs, timeout, return_when — one more arg); as_completed co_argcount=2 < wait co_argcount=3; as_completed is a generator function that yields futures as they complete, allowing iteration over results as soon as they are ready (contrast with wait which blocks until a condition is met); as_completed qualname=12 > wait qualname=4; NEW in extra106: first standalone as_completed argcount invariant in cfwait106 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.as_completed.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant concurrent_futures_extra106.wait_co_argcount_3:
  description: "concurrent.futures.wait.__code__.co_argcount == 3 — wait takes fs (futures iterable), timeout, and return_when; wait.__code__.co_name=='wait'; wait.__qualname__=='wait' (len=4, shortest qualname in this spec); compare: as_completed.__code__.co_argcount==2 (one fewer arg); wait co_argcount=3 > as_completed co_argcount=2; wait blocks until all futures are done (or timeout), or until the first future completes (depending on return_when); wait qualname=4 is the shortest qualname in the spec ('wait'=4 < as_completed=12 < Executor.map=12 < ProcessPoolExecutor.map=23); wait returns a DoneAndNotDoneFutures namedtuple; NEW in extra106: first standalone wait argcount invariant in cfwait106 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.wait.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant concurrent_futures_extra106.DoneAndNotDoneFutures_base_is_tuple:
  description: "concurrent.futures._base.DoneAndNotDoneFutures.__bases__[0].__name__.__eq__('tuple') returns True — DoneAndNotDoneFutures is a namedtuple subclass; its base is tuple, giving MRO [DoneAndNotDoneFutures, tuple, object] (length=3); DoneAndNotDoneFutures.__name__.__len__()==21 (longest class name in spec); DoneAndNotDoneFutures._fields==('done','not_done') (2 fields); DoneAndNotDoneFutures.__module__=='concurrent.futures._base'; this is the return type of concurrent.futures.wait(); the namedtuple inheritance means instances support both attribute access (.done, .not_done) and positional tuple indexing; DoneAndNotDoneFutures.__mro__.__len__()==3 (one more than a direct object subclass); NEW in extra106: first standalone DoneAndNotDoneFutures base invariant in cfwait106 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "concurrent.futures._base.DoneAndNotDoneFutures.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true

invariant concurrent_futures_extra106.DoneAndNotDoneFutures_mro_len_3:
  description: "concurrent.futures._base.DoneAndNotDoneFutures.__mro__.__len__() == 3 — MRO is [DoneAndNotDoneFutures, tuple, object]; DoneAndNotDoneFutures.__name__.__len__()==21 (longest name in spec: 'DoneAndNotDoneFutures'=21); compare: as_completed and wait are plain functions with no MRO (not classes); ThreadPoolExecutor and ProcessPoolExecutor have longer MROs as class hierarchies; DoneAndNotDoneFutures is a namedtuple so its MRO has 3 entries (itself, tuple, object) — one more than a plain object subclass (mro len=2); _fields.__len__()==2 (fields: 'done', 'not_done'); DoneAndNotDoneFutures serves as the return type of concurrent.futures.wait(); NEW in extra106: first standalone DoneAndNotDoneFutures mro length invariant in cfwait106 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: concurrent.futures._base.DoneAndNotDoneFutures.__mro__.__len__
  args: []
  expected: 3

invariant concurrent_futures_extra106.ProcessPoolExecutor_map_qualname_len_23:
  description: "concurrent.futures.ProcessPoolExecutor.map.__qualname__.__len__() == 23 — 'ProcessPoolExecutor.map' = 'ProcessPoolExecutor.'=20 + 'map'=3 = 23; this is the longest qualname in this spec; compare: ThreadPoolExecutor.map.__qualname__=='Executor.map' (len=12 — defined on Executor base class); ProcessPoolExecutor.map has its own override method so qualname reflects the owning class; ProcessPoolExecutor.map.__code__.co_argcount==2 (self and fn, same as ThreadPoolExecutor.map); ProcessPoolExecutor.map.__code__.co_name=='map'; ProcessPoolExecutor.map qualname=23 > as_completed=12 = Executor.map=12 > wait=4 (shortest); 'ProcessPoolExecutor' alone is 19 chars + '.'=1 + 'map'=3 = 23; NEW in extra106: first standalone ProcessPoolExecutor.map qualname invariant in cfwait106 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.map.__qualname__.__len__
  args: []
  expected: 23
