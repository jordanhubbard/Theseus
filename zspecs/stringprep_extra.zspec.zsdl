spec: stringprep_extra
version: ">=3.9"
backend: python_module(stringprep)

docs: https://docs.python.org/3/library/stringprep.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/stringprep.html — Python stringprep module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/stringprep.py"
  notes:
    - "Extends stringprep.zspec.zsdl with additional function name, module affiliation, and type invariants."
    - "stringprep implements RFC 3454 (Preparation of Internationalized Strings) for use in SASL and LDAP."
    - "All public table-checking functions have __module__ == 'stringprep' and are plain functions (type 'function')."
    - "in_table_a1 checks Unassigned Code Points in Unicode 3.2 (RFC 3454 Appendix A.1)."
    - "in_table_b1 checks Commonly Mapped To Nothing (RFC 3454 Appendix B.1)."
    - "in_table_c11 checks Non-ASCII space characters (RFC 3454 Appendix C.1.1)."
    - "in_table_c12 checks ASCII space characters (RFC 3454 Appendix C.1.2)."
    - "in_table_c21 checks Non-ASCII control characters (RFC 3454 Appendix C.2.1)."
    - "in_table_d1 checks right-to-left characters (R and AL categories, RFC 3454 Appendix D.1)."
    - "in_table_d2 checks left-to-right characters (L category, RFC 3454 Appendix D.2)."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant stringprep_extra.in_table_a1.name:
  description: "stringprep.in_table_a1.__name__ == 'in_table_a1'"
  category: functions
  kind: python_call_eq
  function: in_table_a1.__name__.__eq__
  args: ["in_table_a1"]
  expected: true

invariant stringprep_extra.in_table_b1.name:
  description: "stringprep.in_table_b1.__name__ == 'in_table_b1'"
  category: functions
  kind: python_call_eq
  function: in_table_b1.__name__.__eq__
  args: ["in_table_b1"]
  expected: true

invariant stringprep_extra.in_table_c11.name:
  description: "stringprep.in_table_c11.__name__ == 'in_table_c11'"
  category: functions
  kind: python_call_eq
  function: in_table_c11.__name__.__eq__
  args: ["in_table_c11"]
  expected: true

invariant stringprep_extra.in_table_c12.name:
  description: "stringprep.in_table_c12.__name__ == 'in_table_c12'"
  category: functions
  kind: python_call_eq
  function: in_table_c12.__name__.__eq__
  args: ["in_table_c12"]
  expected: true

invariant stringprep_extra.in_table_c21.name:
  description: "stringprep.in_table_c21.__name__ == 'in_table_c21'"
  category: functions
  kind: python_call_eq
  function: in_table_c21.__name__.__eq__
  args: ["in_table_c21"]
  expected: true

invariant stringprep_extra.in_table_d1.name:
  description: "stringprep.in_table_d1.__name__ == 'in_table_d1'"
  category: functions
  kind: python_call_eq
  function: in_table_d1.__name__.__eq__
  args: ["in_table_d1"]
  expected: true

invariant stringprep_extra.in_table_d2.name:
  description: "stringprep.in_table_d2.__name__ == 'in_table_d2'"
  category: functions
  kind: python_call_eq
  function: in_table_d2.__name__.__eq__
  args: ["in_table_d2"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation checks
# ---------------------------------------------------------------------------

invariant stringprep_extra.in_table_a1.module:
  description: "stringprep.in_table_a1.__module__ == 'stringprep'"
  category: functions
  kind: python_call_eq
  function: in_table_a1.__module__.__eq__
  args: ["stringprep"]
  expected: true

invariant stringprep_extra.in_table_b1.module:
  description: "stringprep.in_table_b1.__module__ == 'stringprep'"
  category: functions
  kind: python_call_eq
  function: in_table_b1.__module__.__eq__
  args: ["stringprep"]
  expected: true

invariant stringprep_extra.in_table_c11.module:
  description: "stringprep.in_table_c11.__module__ == 'stringprep'"
  category: functions
  kind: python_call_eq
  function: in_table_c11.__module__.__eq__
  args: ["stringprep"]
  expected: true

invariant stringprep_extra.in_table_d1.module:
  description: "stringprep.in_table_d1.__module__ == 'stringprep'"
  category: functions
  kind: python_call_eq
  function: in_table_d1.__module__.__eq__
  args: ["stringprep"]
  expected: true

# ---------------------------------------------------------------------------
# Type checks — all are plain functions
# ---------------------------------------------------------------------------

table stringprep_extra.function_types:
  kind: python_call_eq
  category: types
  id_prefix: ftype

  columns: [id, function, args, expected]
  rows:
    - [in_table_a1,  "in_table_a1.__class__.__name__.__eq__",  ["function"], true]
    - [in_table_b1,  "in_table_b1.__class__.__name__.__eq__",  ["function"], true]
    - [in_table_c11, "in_table_c11.__class__.__name__.__eq__", ["function"], true]
    - [in_table_c12, "in_table_c12.__class__.__name__.__eq__", ["function"], true]
    - [in_table_c21, "in_table_c21.__class__.__name__.__eq__", ["function"], true]
    - [in_table_d1,  "in_table_d1.__class__.__name__.__eq__",  ["function"], true]
    - [in_table_d2,  "in_table_d2.__class__.__name__.__eq__",  ["function"], true]
