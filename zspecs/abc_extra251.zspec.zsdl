table abc_extra251.generator_coroutine_awaitable_identity:
  description: "collections.abc Generator(len=9), Coroutine(len=9), and Awaitable(len=9) class identity — all three share __name__ length 9; Generator inherits from Iterator; Coroutine inherits from Awaitable; Awaitable inherits from object; all in collections.abc(len=15); verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: abc251gca

  columns: [id, function, args, expected, description]
  rows:
    - [gen_name_eq,   Generator.__name__.__eq__,                      ["Generator"],          true, "collections.abc.Generator.__name__ == 'Generator'; verified with Python 3.14.4"]
    - [gen_name_len,  Generator.__name__.__len__,                     [],                      9,    "collections.abc.Generator.__name__.__len__() == 9; verified with Python 3.14.4"]
    - [gen_mod_eq,    Generator.__module__.__eq__,                    ["collections.abc"],    true, "collections.abc.Generator.__module__ == 'collections.abc'; verified with Python 3.14.4"]
    - [gen_mod_len,   Generator.__module__.__len__,                   [],                      15,   "collections.abc.Generator.__module__.__len__() == 15; verified with Python 3.14.4"]
    - [gen_base_eq,   "Generator.__bases__[0].__name__.__eq__",       ["Iterator"],           true, "collections.abc.Generator.__bases__[0].__name__ == 'Iterator' — Generator extends Iterator; verified with Python 3.14.4"]
    - [gen_base_len,  "Generator.__bases__[0].__name__.__len__",      [],                      8,    "collections.abc.Generator.__bases__[0].__name__.__len__() == 8; verified with Python 3.14.4"]
    - [co_name_eq,    Coroutine.__name__.__eq__,                      ["Coroutine"],          true, "collections.abc.Coroutine.__name__ == 'Coroutine'; verified with Python 3.14.4"]
    - [co_name_len,   Coroutine.__name__.__len__,                     [],                      9,    "collections.abc.Coroutine.__name__.__len__() == 9 — same length as Generator (9); verified with Python 3.14.4"]
    - [co_mod_eq,     Coroutine.__module__.__eq__,                    ["collections.abc"],    true, "collections.abc.Coroutine.__module__ == 'collections.abc'; verified with Python 3.14.4"]
    - [co_mod_len,    Coroutine.__module__.__len__,                   [],                      15,   "collections.abc.Coroutine.__module__.__len__() == 15; verified with Python 3.14.4"]
    - [co_base_eq,    "Coroutine.__bases__[0].__name__.__eq__",       ["Awaitable"],          true, "collections.abc.Coroutine.__bases__[0].__name__ == 'Awaitable' — Coroutine inherits from Awaitable; verified with Python 3.14.4"]
    - [co_base_len,   "Coroutine.__bases__[0].__name__.__len__",      [],                      9,    "collections.abc.Coroutine.__bases__[0].__name__.__len__() == 9 — Awaitable length (9) equals Coroutine length (9); verified with Python 3.14.4"]
    - [aw_name_eq,    Awaitable.__name__.__eq__,                      ["Awaitable"],          true, "collections.abc.Awaitable.__name__ == 'Awaitable'; verified with Python 3.14.4"]
    - [aw_name_len,   Awaitable.__name__.__len__,                     [],                      9,    "collections.abc.Awaitable.__name__.__len__() == 9 — Awaitable, Generator, and Coroutine all share length 9; verified with Python 3.14.4"]
    - [aw_mod_eq,     Awaitable.__module__.__eq__,                    ["collections.abc"],    true, "collections.abc.Awaitable.__module__ == 'collections.abc'; verified with Python 3.14.4"]
    - [aw_mod_len,    Awaitable.__module__.__len__,                   [],                      15,   "collections.abc.Awaitable.__module__.__len__() == 15; verified with Python 3.14.4"]
    - [aw_base_eq,    "Awaitable.__bases__[0].__name__.__eq__",       ["object"],             true, "collections.abc.Awaitable.__bases__[0].__name__ == 'object' — Awaitable is the async-callable hierarchy root; verified with Python 3.14.4"]
    - [aw_base_len,   "Awaitable.__bases__[0].__name__.__len__",      [],                      6,    "collections.abc.Awaitable.__bases__[0].__name__.__len__() == 6; verified with Python 3.14.4"]

