spec: abc_extra251
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "collections.abc.Generator.__name__ == 'Generator' (len=9); __module__ == 'collections.abc' (len=15); __bases__[0].__name__ == 'Iterator' — Generator is a single-inheritance subclass of Iterator."
    - "collections.abc.Coroutine.__name__ == 'Coroutine' (len=9); __module__ == 'collections.abc' (len=15); __bases__[0].__name__ == 'Awaitable' — Coroutine inherits from Awaitable; Generator and Coroutine share the same __name__ length (9)."
    - "collections.abc.AsyncGenerator.__name__ == 'AsyncGenerator' (len=14); __module__ == 'collections.abc' (len=15); __bases__[0].__name__ == 'AsyncIterator' — AsyncGenerator inherits from AsyncIterator."
    - "collections.abc.AsyncIterable.__name__ == 'AsyncIterable' (len=13); __bases__[0].__name__ == 'object' — AsyncIterable is the async hierarchy root."
    - "collections.abc.AsyncIterator.__name__ == 'AsyncIterator' (len=13); __bases__[0].__name__ == 'AsyncIterable' — AsyncIterator inherits from AsyncIterable; AsyncIterable and AsyncIterator share length 13."
    - "collections.abc.Awaitable.__name__ == 'Awaitable' (len=9); __bases__[0].__name__ == 'object' — Awaitable, Generator, and Coroutine share the same __name__ length (9)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

