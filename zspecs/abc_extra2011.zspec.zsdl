spec: abc_extra2011
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 581 (_extra2011): __add__/__radd__/__iadd__, __mul__/__rmul__/__imul__, __sub__/__rsub__/__isub__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "abc.ABCMeta, abc.ABC, abc.abstractmethod do not define arithmetic operators; all checks return False."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __add__ / __radd__ / __iadd__ dict-presence for abc types
#
# None of ABCMeta, ABC, abstractmethod define addition operators.
# All checks return False.
# ---------------------------------------------------------------------------

table abc_extra2011.add_protocol:
  description: "abc types __add__/__radd__/__iadd__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2011

  columns: [id, function, args, expected]
  rows:
    - ["ab2011001", "abc.ABCMeta.__dict__.__contains__",        ["__add__"],  false]
    - ["ab2011002", "abc.ABC.__dict__.__contains__",            ["__add__"],  false]
    - ["ab2011003", "abc.abstractmethod.__dict__.__contains__", ["__add__"],  false]
    - ["ab2011004", "abc.ABCMeta.__dict__.__contains__",        ["__radd__"], false]
    - ["ab2011005", "abc.ABC.__dict__.__contains__",            ["__radd__"], false]
    - ["ab2011006", "abc.abstractmethod.__dict__.__contains__", ["__radd__"], false]
    - ["ab2011007", "abc.ABCMeta.__dict__.__contains__",        ["__iadd__"], false]
    - ["ab2011008", "abc.ABC.__dict__.__contains__",            ["__iadd__"], false]
    - ["ab2011009", "abc.abstractmethod.__dict__.__contains__", ["__iadd__"], false]

