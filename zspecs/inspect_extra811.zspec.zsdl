spec: inspect_extra811
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "CPython inspect module source"
    - "Python 3.9+ language reference"
  not_derived_from:
    - "any third-party library"
  notes:
    - "Covers inspect module-level function qualnames and module identity"
    - "Functions covered: getmembers, isfunction, isclass, ismodule, isbuiltin, signature"
  created_at: "2026-04-12"

table inspect_extra811.getmembers_isfunction_identity:
  description: "inspect.getmembers and isfunction qualname and module identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: in811gf
  columns: [id, function, args, expected]
  rows:
    - [in811gf001, "inspect.getmembers.__qualname__.__eq__", ["getmembers"], true]
    - [in811gf002, "inspect.getmembers.__module__.__eq__", ["inspect"], true]
    - [in811gf003, "inspect.isfunction.__qualname__.__eq__", ["isfunction"], true]
    - [in811gf004, "inspect.isfunction.__module__.__eq__", ["inspect"], true]

