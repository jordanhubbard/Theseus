spec: multiprocessing_extra130
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/reduction.py"
  notes:
    - "This spec covers: wave 254 theme — multiprocessing.reduction module identity (for pickling). NEW in extra130: multiprocessing.reduction.__name__=='multiprocessing.reduction' (len=25); multiprocessing.reduction.__package__=='multiprocessing'; multiprocessing.reduction.ForkingPickler.__name__=='ForkingPickler' (len=14); multiprocessing.reduction.ForkingPickler.__module__=='multiprocessing.reduction'; multiprocessing.reduction.ForkingPickler.__bases__[0].__name__=='Pickler'; multiprocessing.reduction.ForkingPickler.__mro__.__len__()==3 ([ForkingPickler, Pickler, object]); multiprocessing.reduction.dump.__code__.co_name=='dump'; multiprocessing.reduction.dump.__code__.co_argcount==3; multiprocessing.reduction.AbstractReducer.__name__=='AbstractReducer' (len=15); multiprocessing.reduction.AbstractReducer.__mro__.__len__()==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.reduction.ForkingPickler.__bases__[0].__name__ == 'Pickler'. ForkingPickler inherits from pickle.Pickler (the C-accelerated Pickler), giving the MRO [ForkingPickler, Pickler, object] (length=3). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.reduction.dump.__code__.co_argcount == 3. The dump function has signature dump(obj, file, protocol=None) — 3 positional parameters (including the defaulted one): co_argcount counts all positional params. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.reduction.__package__ == 'multiprocessing'. Unlike multiprocessing.reduction.__name__ (which is 'multiprocessing.reduction'), the __package__ is just 'multiprocessing' (the parent package, not the submodule's own name). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.reduction module identity — extra130
#
# Wave 254 theme: multiprocessing.reduction module identity (for pickling).
#
# multiprocessing.reduction.__name__      == 'multiprocessing.reduction'  (len=25)
# multiprocessing.reduction.__package__   == 'multiprocessing'
# multiprocessing.reduction.__spec__.__class__.__name__ == 'ModuleSpec'
# multiprocessing.reduction.__name__.__len__()          == 25
# multiprocessing.reduction.__package__.__len__()       == 15
# ---------------------------------------------------------------------------

table multiprocessing_extra130.mp_reduction_module_identity:
  description: "multiprocessing.reduction module identity checks in mpreduction130 namespace — wave 254 theme: multiprocessing.reduction module identity; multiprocessing.reduction is defined in Lib/multiprocessing/reduction.py and provides cross-platform pickling support for multiprocessing; __name__.__eq__('multiprocessing.reduction')==True (len=25: 'multiprocessing'=15+'.'=1+'reduction'=9); __name__.__len__()==25; __package__.__eq__('multiprocessing')==True (for submodules, __package__ is the parent package name, not the submodule's own __name__); __package__.__len__()==15 ('multiprocessing'=15); __spec__.__class__.__name__.__eq__('ModuleSpec')==True (standard ModuleSpec for all regular modules); __name__.__class__.__name__.__eq__('str')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpreduction130

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,      multiprocessing.reduction.__name__.__eq__,                      ["multiprocessing.reduction"], true, "multiprocessing.reduction.__name__ == 'multiprocessing.reduction' (len=25); verified with Python 3.14.3"]
    - [name_len,     multiprocessing.reduction.__name__.__len__,                     [],                            25,   "multiprocessing.reduction.__name__.__len__() == 25; verified with Python 3.14.3"]
    - [pkg_eq,       multiprocessing.reduction.__package__.__eq__,                   ["multiprocessing"],           true, "multiprocessing.reduction.__package__ == 'multiprocessing' (parent package, not submodule name); verified with Python 3.14.3"]
    - [pkg_len,      multiprocessing.reduction.__package__.__len__,                  [],                            15,   "multiprocessing.reduction.__package__.__len__() == 15 ('multiprocessing'=15); verified with Python 3.14.3"]
    - [spec_cls,     multiprocessing.reduction.__spec__.__class__.__name__.__eq__,   ["ModuleSpec"],                true, "multiprocessing.reduction.__spec__.__class__.__name__ == 'ModuleSpec'; verified with Python 3.14.3"]
    - [name_cls,     multiprocessing.reduction.__name__.__class__.__name__.__eq__,   ["str"],                       true, "multiprocessing.reduction.__name__.__class__.__name__ == 'str'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.reduction.ForkingPickler class identity — extra130
#
# multiprocessing.reduction.ForkingPickler.__name__              == 'ForkingPickler' (len=14)
# multiprocessing.reduction.ForkingPickler.__module__            == 'multiprocessing.reduction'
# multiprocessing.reduction.ForkingPickler.__bases__[0].__name__ == 'Pickler'
# multiprocessing.reduction.ForkingPickler.__mro__.__len__()     == 3
# multiprocessing.reduction.ForkingPickler.__class__.__name__    == 'type'
# multiprocessing.reduction.ForkingPickler.__qualname__          == 'ForkingPickler' (len=14)
# ---------------------------------------------------------------------------

table multiprocessing_extra130.mp_reduction_forkingpickler_identity:
  description: "multiprocessing.reduction.ForkingPickler class identity checks in mpreduction130 namespace — wave 254 theme: ForkingPickler class hierarchy; ForkingPickler is a subclass of pickle.Pickler (the C-accelerated Pickler) defined in Lib/multiprocessing/reduction.py; ForkingPickler.__name__.__eq__('ForkingPickler')==True (len=14); ForkingPickler.__module__.__eq__('multiprocessing.reduction')==True (module matches the reduction submodule __name__); ForkingPickler.__bases__[0].__name__.__eq__('Pickler')==True (direct subclass of pickle.Pickler); ForkingPickler.__mro__.__len__()==3 (MRO is [ForkingPickler, Pickler, object]); ForkingPickler.__class__.__name__.__eq__('type')==True (ForkingPickler is a class, metaclass is type); ForkingPickler.__qualname__.__eq__('ForkingPickler')==True (len=14, module-level class so qualname equals name); ForkingPickler extends Pickler to support multiprocessing-aware serialization using dispatch_table; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpreduction130a

  columns: [id, function, args, expected, description]
  rows:
    - [fp_name_eq,    multiprocessing.reduction.ForkingPickler.__name__.__eq__,                      ["ForkingPickler"],             true, "multiprocessing.reduction.ForkingPickler.__name__ == 'ForkingPickler' (len=14); verified with Python 3.14.3"]
    - [fp_name_len,   multiprocessing.reduction.ForkingPickler.__name__.__len__,                     [],                            14,   "multiprocessing.reduction.ForkingPickler.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [fp_module,     multiprocessing.reduction.ForkingPickler.__module__.__eq__,                    ["multiprocessing.reduction"],  true, "multiprocessing.reduction.ForkingPickler.__module__ == 'multiprocessing.reduction'; verified with Python 3.14.3"]
    - [fp_base0,      "multiprocessing.reduction.ForkingPickler.__bases__[0].__name__.__eq__",       ["Pickler"],                    true, "multiprocessing.reduction.ForkingPickler.__bases__[0].__name__ == 'Pickler' (C-accelerated pickle.Pickler); verified with Python 3.14.3"]
    - [fp_mro_len,    multiprocessing.reduction.ForkingPickler.__mro__.__len__,                      [],                            3,    "multiprocessing.reduction.ForkingPickler.__mro__.__len__() == 3 — [ForkingPickler, Pickler, object]; verified with Python 3.14.3"]
    - [fp_class_nm,   multiprocessing.reduction.ForkingPickler.__class__.__name__.__eq__,            ["type"],                       true, "multiprocessing.reduction.ForkingPickler.__class__.__name__ == 'type'; verified with Python 3.14.3"]
    - [fp_qualname,   multiprocessing.reduction.ForkingPickler.__qualname__.__eq__,                  ["ForkingPickler"],             true, "multiprocessing.reduction.ForkingPickler.__qualname__ == 'ForkingPickler' (len=14); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.reduction.dump function identity — extra130
#
# multiprocessing.reduction.dump.__code__.co_name      == 'dump'
# multiprocessing.reduction.dump.__code__.co_argcount  == 3
# multiprocessing.reduction.dump.__class__.__name__    == 'function'
# multiprocessing.reduction.dump.__module__            == 'multiprocessing.reduction'
# multiprocessing.reduction.AbstractReducer.__name__   == 'AbstractReducer' (len=15)
# multiprocessing.reduction.AbstractReducer.__mro__.__len__() == 2
# ---------------------------------------------------------------------------

table multiprocessing_extra130.mp_reduction_dump_and_abstract:
  description: "multiprocessing.reduction.dump function identity and AbstractReducer class checks in mpreduction130 namespace — wave 254 theme: dump function and AbstractReducer class; dump is a module-level function in Lib/multiprocessing/reduction.py that pickles obj to file using ForkingPickler; dump.__code__.co_name.__eq__('dump')==True (the compiled code object's name matches the function name); dump.__code__.co_argcount==3 (signature is dump(obj, file, protocol=None) — 3 positional params including the defaulted protocol); dump.__class__.__name__.__eq__('function')==True (pure-Python module-level function); dump.__module__.__eq__('multiprocessing.reduction')==True; AbstractReducer.__name__.__eq__('AbstractReducer')==True (len=15: 'Abstract'=8+'Reducer'=7); AbstractReducer.__bases__[0].__name__.__eq__('object')==True (direct subclass of object); AbstractReducer.__mro__.__len__()==2 (MRO is [AbstractReducer, object], minimal 2-element chain); AbstractReducer.__module__.__eq__('multiprocessing.reduction')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpreduction130b

  columns: [id, function, args, expected, description]
  rows:
    - [dump_coname,   multiprocessing.reduction.dump.__code__.co_name.__eq__,        ["dump"],                      true, "multiprocessing.reduction.dump.__code__.co_name == 'dump'; verified with Python 3.14.3"]
    - [dump_argc,     multiprocessing.reduction.dump.__code__.co_argcount.__eq__,    [3],                           true, "multiprocessing.reduction.dump.__code__.co_argcount == 3 (obj, file, protocol=None); verified with Python 3.14.3"]
    - [dump_cls,      multiprocessing.reduction.dump.__class__.__name__.__eq__,      ["function"],                  true, "multiprocessing.reduction.dump.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [dump_module,   multiprocessing.reduction.dump.__module__.__eq__,              ["multiprocessing.reduction"], true, "multiprocessing.reduction.dump.__module__ == 'multiprocessing.reduction'; verified with Python 3.14.3"]
    - [ar_name_eq,    multiprocessing.reduction.AbstractReducer.__name__.__eq__,     ["AbstractReducer"],           true, "multiprocessing.reduction.AbstractReducer.__name__ == 'AbstractReducer' (len=15); verified with Python 3.14.3"]
    - [ar_name_len,   multiprocessing.reduction.AbstractReducer.__name__.__len__,    [],                            15,   "multiprocessing.reduction.AbstractReducer.__name__.__len__() == 15 ('Abstract'=8+'Reducer'=7); verified with Python 3.14.3"]
    - [ar_base0,      "multiprocessing.reduction.AbstractReducer.__bases__[0].__name__.__eq__", ["object"],         true, "multiprocessing.reduction.AbstractReducer.__bases__[0].__name__ == 'object' (direct subclass); verified with Python 3.14.3"]
    - [ar_mro_len,    multiprocessing.reduction.AbstractReducer.__mro__.__len__,     [],                            2,    "multiprocessing.reduction.AbstractReducer.__mro__.__len__() == 2 — [AbstractReducer, object]; verified with Python 3.14.3"]
    - [ar_module,     multiprocessing.reduction.AbstractReducer.__module__.__eq__,   ["multiprocessing.reduction"], true, "multiprocessing.reduction.AbstractReducer.__module__ == 'multiprocessing.reduction'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra130
# ---------------------------------------------------------------------------

invariant multiprocessing_extra130.reduction_name_len_25:
  description: "multiprocessing.reduction.__name__.__len__() == 25 — multiprocessing.reduction.__name__ is 'multiprocessing.reduction' (25 chars: 'multiprocessing'=15 + '.'=1 + 'reduction'=9 = 25); this contrasts with multiprocessing.reduction.__package__ which is just 'multiprocessing' (15 chars) — for submodules, __package__ is the parent package name, not the full dotted module name; compare other multiprocessing submodule name lengths: multiprocessing.pool='multiprocessing.pool' (20 chars), multiprocessing.context='multiprocessing.context' (23 chars), multiprocessing.reduction='multiprocessing.reduction' (25 chars, longest in this context); NEW in extra130: first standalone reduction module name length invariant in mpreduction130 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.reduction.__name__.__len__
  args: []
  expected: 25

invariant multiprocessing_extra130.ForkingPickler_base_is_Pickler:
  description: "multiprocessing.reduction.ForkingPickler.__bases__[0].__name__.__eq__('Pickler') returns True — ForkingPickler inherits from pickle.Pickler (the C-accelerated Pickler class in _pickle); this gives ForkingPickler the MRO [ForkingPickler, Pickler, object] (length=3); ForkingPickler extends Pickler to support multiprocessing by overriding dispatch_table with a process-shared reducer registry; ForkingPickler.__module__ is 'multiprocessing.reduction'; ForkingPickler.__name__ is 'ForkingPickler' (len=14); the 'Pickler' base is from the _pickle C extension (not from the pure-Python pickle module fallback); NEW in extra130: first standalone ForkingPickler base class invariant in mpreduction130 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.reduction.ForkingPickler.__bases__[0].__name__.__eq__"
  args: ["Pickler"]
  expected: true

invariant multiprocessing_extra130.ForkingPickler_mro_len_3:
  description: "multiprocessing.reduction.ForkingPickler.__mro__.__len__() == 3 — ForkingPickler's MRO is [ForkingPickler, Pickler, object] (length=3); this 3-element chain reflects ForkingPickler's single-base inheritance from Pickler; compare: AbstractReducer.__mro__.__len__()==2 ([AbstractReducer, object]) — direct subclass of object; multiprocessing.Process.__mro__.__len__()==3 ([Process, BaseProcess, object]) — same depth as ForkingPickler; asyncio.Task.__mro__.__len__()==3 ([Task, Future, object]) — same depth; ForkingPickler.__name__.__len__() is 14 and ForkingPickler.__module__ is 'multiprocessing.reduction'; NEW in extra130: first standalone ForkingPickler MRO length invariant in mpreduction130 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.reduction.ForkingPickler.__mro__.__len__
  args: []
  expected: 3

invariant multiprocessing_extra130.dump_co_argcount_3:
  description: "multiprocessing.reduction.dump.__code__.co_argcount == 3 — dump's signature is dump(obj, file, protocol=None); co_argcount counts positional parameters including those with defaults (but not *args or **kwargs), giving 3 (obj, file, protocol); dump uses ForkingPickler to pickle obj into file; dump.__class__.__name__ is 'function'; dump.__module__ is 'multiprocessing.reduction'; dump.__code__.co_name is 'dump'; compare: AbstractReducer has 0 methods counted here; ForkingPickler inherits dump behavior through the Pickler base; NEW in extra130: first standalone dump co_argcount invariant in mpreduction130 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.reduction.dump.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant multiprocessing_extra130.AbstractReducer_mro_len_2:
  description: "multiprocessing.reduction.AbstractReducer.__mro__.__len__() == 2 — AbstractReducer's MRO is [AbstractReducer, object] (length=2); this minimal 2-element chain reflects AbstractReducer's direct inheritance from object with no intermediate classes; AbstractReducer provides an abstract base for implementing custom reducers for multiprocessing; AbstractReducer.__name__ is 'AbstractReducer' (len=15: 'Abstract'=8 + 'Reducer'=7); AbstractReducer.__module__ is 'multiprocessing.reduction'; compare MRO lengths: AbstractReducer=2, ForkingPickler=3; the 2-element depth matches asyncio.Future.__mro__.__len__()==2 ([Future, object]); NEW in extra130: first standalone AbstractReducer MRO length invariant in mpreduction130 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.reduction.AbstractReducer.__mro__.__len__
  args: []
  expected: 2
