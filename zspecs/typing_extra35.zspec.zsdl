spec: typing_extra35
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing_extra34.zspec.zsdl."
    - "Prior specs covered: TypeVar/__name__/__module__/__qualname__/__init__.__name__, Protocol/__module__/__qualname__/__bases__[0].__name__, Generic/__module__/__qualname__/__bases__[0].__name__, NamedTuple/__name__/__module__, TypedDict/__name__/__module__, get_type_hints/__name__, overload/__name__, cast/__name__, TYPE_CHECKING value, TypeVar/Protocol/Generic __module__.__len__() and __name__.__len__(), __qualname__.__len__() for overload/cast/get_type_hints/no_type_check/get_args/get_origin, __module__.__len__() and __name__.__len__() for Any/Union/Optional/Callable/ClassVar/Final/Literal, __mro__.__len__() for Protocol(3)/Generic(2)/TypeVar(2), __bases__[0].__name__.__len__() for Generic(6) and TypeVar(6), Protocol.__slots__/__abstractmethods__/__class__.__name__, TYPE_CHECKING.__class__.__name__.__len__() (4), AnyStr.__class__.__name__.__len__() (7), typing.__all__.__len__() (105) and .__class__.__name__.__len__() (4), __dict__.__class__.__name__.__len__() for TypeVar/Generic/Protocol (mappingproxy=12) and NamedTuple (dict=4), __qualname__.__len__() for final(5)/runtime_checkable(17), TypeVar.__init__.__qualname__.__len__() (15), Protocol.__init_subclass__.__qualname__.__len__() (26)."
    - "This spec covers: __qualname__.__len__() for TypeVar(7)/Generic(7)/Protocol(8)/ParamSpec(9)/TypeVarTuple(12); __class__.__name__.__len__() for Union(4 — 'type')/Optional(12 — '_SpecialForm')/Any(8 — '_AnyMeta')/ClassVar(12 — '_SpecialForm')/Final(12 — '_SpecialForm')/Literal(22 — '_TypedCacheSpecialForm')/TYPE_CHECKING(4 — 'bool')."
    - "Key findings: typing.Union is a plain 'type' (class name length 4) — unlike Optional/ClassVar/Final/ClassVar which are '_SpecialForm' (12). typing.Any.__class__.__name__ is '_AnyMeta' (8) — a metaclass, not a _SpecialForm. typing.Literal.__class__.__name__ is '_TypedCacheSpecialForm' (22) — the longest class name in this series. ParamSpec and TypeVarTuple are newer type variable forms (Python 3.10+) with qualname lengths 9 and 12 respectively."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — TypeVar family classes
#
# typing.TypeVar.__qualname__ == 'TypeVar' (length 7). typing.Generic.__qualname__
# == 'Generic' (length 7). typing.Protocol.__qualname__ == 'Protocol' (length 8).
# typing.ParamSpec.__qualname__ == 'ParamSpec' (length 9). typing.TypeVarTuple.
# __qualname__ == 'TypeVarTuple' (length 12). These are the five parameterization
# building blocks of the typing module. No prior typing spec records
# __qualname__.__len__() for TypeVar, Generic, Protocol, ParamSpec, or TypeVarTuple.
# ---------------------------------------------------------------------------

table typing_extra35.typevar_family_qualname_lens:
  description: "__qualname__.__len__() for TypeVar/Generic/Protocol/ParamSpec/TypeVarTuple"
  kind: python_call_eq
  category: qualname_attr_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [TypeVar,
       TypeVar.__qualname__.__len__,
       [],
       7,
       "len(typing.TypeVar.__qualname__) == 7 — 'TypeVar'"]
    - [Generic,
       Generic.__qualname__.__len__,
       [],
       7,
       "len(typing.Generic.__qualname__) == 7 — 'Generic'"]
    - [Protocol,
       Protocol.__qualname__.__len__,
       [],
       8,
       "len(typing.Protocol.__qualname__) == 8 — 'Protocol'"]
    - [ParamSpec,
       ParamSpec.__qualname__.__len__,
       [],
       9,
       "len(typing.ParamSpec.__qualname__) == 9 — 'ParamSpec'"]
    - [TypeVarTuple,
       TypeVarTuple.__qualname__.__len__,
       [],
       12,
       "len(typing.TypeVarTuple.__qualname__) == 12 — 'TypeVarTuple'"]

# ---------------------------------------------------------------------------
# __class__.__name__.__len__() table — special form constants
#
# typing.Optional, ClassVar, Final, and Concatenate are all instances of
# '_SpecialForm' (length 12). typing.Literal is an instance of the more
# specialized '_TypedCacheSpecialForm' (length 22). typing.Union is unusual:
# it is a plain 'type' (length 4), not a _SpecialForm. typing.Any is an
# instance of '_AnyMeta' (length 8) — a metaclass approach rather than a
# _SpecialForm. typing.TYPE_CHECKING is a plain 'bool' (length 4).
# No prior typing spec records __class__.__name__.__len__() for these objects.
# ---------------------------------------------------------------------------

table typing_extra35.special_form_class_name_lens:
  description: "__class__.__name__.__len__() for typing special forms — Union is 'type'(4), Optional/ClassVar/Final are '_SpecialForm'(12), Any is '_AnyMeta'(8), Literal is '_TypedCacheSpecialForm'(22)"
  kind: python_call_eq
  category: class_name_lengths
  id_prefix: class_name_len

  columns: [id, function, args, expected, description]
  rows:
    - [Union,
       Union.__class__.__name__.__len__,
       [],
       4,
       "typing.Union.__class__.__name__ == 'type' (length 4) — Union is a plain type, not a _SpecialForm"]
    - [Optional,
       Optional.__class__.__name__.__len__,
       [],
       12,
       "typing.Optional.__class__.__name__ == '_SpecialForm' (length 12)"]
    - [Any,
       Any.__class__.__name__.__len__,
       [],
       8,
       "typing.Any.__class__.__name__ == '_AnyMeta' (length 8) — a metaclass, not _SpecialForm"]
    - [ClassVar,
       ClassVar.__class__.__name__.__len__,
       [],
       12,
       "typing.ClassVar.__class__.__name__ == '_SpecialForm' (length 12)"]
    - [Final,
       Final.__class__.__name__.__len__,
       [],
       12,
       "typing.Final.__class__.__name__ == '_SpecialForm' (length 12)"]
    - [Literal,
       Literal.__class__.__name__.__len__,
       [],
       22,
       "typing.Literal.__class__.__name__ == '_TypedCacheSpecialForm' (length 22) — longest class name in this series"]
    - [TYPE_CHECKING,
       TYPE_CHECKING.__class__.__name__.__len__,
       [],
       4,
       "typing.TYPE_CHECKING.__class__.__name__ == 'bool' (length 4)"]

# ---------------------------------------------------------------------------
# typing.TypeVar.__qualname__.__len__() == 7 — standalone invariant
#
# typing.TypeVar.__qualname__ == 'TypeVar' (length 7). TypeVar is the primary
# class for creating type variables in Python's type system. Its qualname
# exactly matches its public class name with no enclosing class prefix.
# This invariant complements the __name__.__len__() == 7 established in prior
# specs by confirming that qualname and name agree for TypeVar.
# ---------------------------------------------------------------------------

invariant typing_extra35.TypeVar.qualname_len:
  description: "typing.TypeVar.__qualname__.__len__() == 7 — qualname is 'TypeVar' (7 characters); qualname and name agree for this top-level class"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: TypeVar.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# typing.Union.__class__.__name__.__len__() == 4 — standalone invariant
#
# typing.Union.__class__.__name__ == 'type' (length 4). Unlike Optional,
# ClassVar, Final, and most other typing special forms — which are instances
# of _SpecialForm (12) — Union is a plain 'type'. This makes Union the only
# major typing constant whose __class__.__name__.__len__() equals 4 for this
# reason (TYPE_CHECKING is also 4 but as 'bool'). No prior typing spec records
# this class name length for Union.
# ---------------------------------------------------------------------------

invariant typing_extra35.Union.class_name_len:
  description: "typing.Union.__class__.__name__.__len__() == 4 — Union is a plain 'type' (length 4), unlike Optional/ClassVar/Final which are '_SpecialForm' (12)"
  category: class_name_lengths
  kind: python_call_eq
  function: Union.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# typing.Literal.__class__.__name__.__len__() == 22 — standalone invariant
#
# typing.Literal.__class__.__name__ == '_TypedCacheSpecialForm' (length 22).
# Literal uses a more specialized internal class than the generic _SpecialForm
# used by Optional/ClassVar/Final. The '_TypedCacheSpecialForm' name (22 chars)
# is the longest class name in this spec series. No prior typing spec records
# this class name length for Literal.
# ---------------------------------------------------------------------------

invariant typing_extra35.Literal.class_name_len:
  description: "typing.Literal.__class__.__name__.__len__() == 22 — Literal is a '_TypedCacheSpecialForm' (length 22); longer than _SpecialForm (12) used by Optional/ClassVar/Final"
  category: class_name_lengths
  kind: python_call_eq
  function: Literal.__class__.__name__.__len__
  args: []
  expected: 22
