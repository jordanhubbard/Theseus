spec: array_extra26
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
    - "array_extra21.zspec.zsdl — covers __qualname__ for append/extend/pop/insert/remove/reverse/tolist/tobytes/frombytes."
    - "array_extra22.zspec.zsdl — covers __qualname__ for buffer_info/byteswap/index; array.__qualname__; ArrayType.__qualname__."
    - "array_extra23.zspec.zsdl — covers __qualname__ for count/fromlist/fromfile/tofile/__len__/__iter__."
    - "array_extra24.zspec.zsdl — covers __qualname__ for __add__/__contains__/__repr__/__eq__/__mul__/__getitem__/__setitem__/__delitem__; module __name__/__package__ attrs."
    - "array_extra25.zspec.zsdl — covers __qualname__ for __iadd__/__imul__/__rmul__/__ne__/__lt__/__le__/__gt__/__ge__/fromunicode/tounicode/clear/__new__/__sizeof__."
  notes:
    - "This spec extends array_extra25.zspec.zsdl."
    - "Prior specs covered: __qualname__ for all major array.array methods (append/extend/pop/remove/reverse/tolist/frombytes/tobytes and dunders); module __name__/__package__."
    - "This spec covers: array.array.__init__.__qualname__ (special case: inherited from object, yields 'object.__init__'); __name__ and __qualname__ for append/extend/pop/reverse/tolist/frombytes as a grouped table; __name__.__len__() for these methods as a cross-check."
    - "array.array.__init__.__qualname__ == 'object.__init__' — array.array does not define its own __init__; the slot is inherited from object. Verified."
    - "len('object.__init__') == 15. Verified."
    - "array.array.append.__name__ == 'append', __qualname__ == 'array.append'. Verified."
    - "array.array.extend.__name__ == 'extend', __qualname__ == 'array.extend'. Verified."
    - "array.array.pop.__name__ == 'pop', __qualname__ == 'array.pop'. Verified."
    - "array.array.reverse.__name__ == 'reverse', __qualname__ == 'array.reverse'. Verified."
    - "array.array.tolist.__name__ == 'tolist', __qualname__ == 'array.tolist'. Verified."
    - "array.array.frombytes.__name__ == 'frombytes', __qualname__ == 'array.frombytes'. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __name__ for append/extend/pop/reverse/tolist/frombytes
#
# array_extra21 covers __qualname__ for these methods. No prior spec groups
# their __name__ attributes in a single table. For C extension type methods,
# __name__ is the simple method name (no class prefix), distinct from
# __qualname__ which includes the 'array.' prefix.
# Verified: append='append', extend='extend', pop='pop',
#   reverse='reverse', tolist='tolist', frombytes='frombytes'.
# ---------------------------------------------------------------------------

table array_extra26.method_names:
  description: "array.array method __name__ for append/extend/pop/reverse/tolist/frombytes — simple names without class prefix"
  kind: python_call_eq
  category: method_identity
  id_prefix: amn26

  columns: [id, function, args, expected]
  rows:
    - [append,    "array.append.__name__.__eq__",    ["append"],    true]
    - [extend,    "array.extend.__name__.__eq__",    ["extend"],    true]
    - [pop,       "array.pop.__name__.__eq__",       ["pop"],       true]
    - [reverse,   "array.reverse.__name__.__eq__",   ["reverse"],   true]
    - [tolist,    "array.tolist.__name__.__eq__",    ["tolist"],    true]
    - [frombytes, "array.frombytes.__name__.__eq__", ["frombytes"], true]

# ---------------------------------------------------------------------------
# Table: __qualname__ for append/extend/pop/reverse/tolist/frombytes
#
# array_extra21 covers these qualnames as individual checks but under a
# different namespace. This table groups them in extra26 for co-location with
# the __name__ and __name__.__len__() tables above.
# Verified: append='array.append', extend='array.extend', pop='array.pop',
#   reverse='array.reverse', tolist='array.tolist', frombytes='array.frombytes'.
# ---------------------------------------------------------------------------

table array_extra26.method_qualnames:
  description: "array.array method __qualname__ for append/extend/pop/reverse/tolist/frombytes — includes 'array.' class prefix"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: amqn26

  columns: [id, function, args, expected]
  rows:
    - [append,    "array.append.__qualname__.__eq__",    ["array.append"],    true]
    - [extend,    "array.extend.__qualname__.__eq__",    ["array.extend"],    true]
    - [pop,       "array.pop.__qualname__.__eq__",       ["array.pop"],       true]
    - [reverse,   "array.reverse.__qualname__.__eq__",   ["array.reverse"],   true]
    - [tolist,    "array.tolist.__qualname__.__eq__",    ["array.tolist"],    true]
    - [frombytes, "array.frombytes.__qualname__.__eq__", ["array.frombytes"], true]

# ---------------------------------------------------------------------------
# Table: __name__.__len__() for append/extend/pop/reverse/tolist/frombytes
#
# No prior spec covers __name__.__len__() for any of these array methods.
# Length checks provide an independent cross-validation axis for the __name__
# attribute separate from the qualname lengths covered in extra21.
# Verified: append=6, extend=6, pop=3, reverse=7, tolist=6, frombytes=9.
# ---------------------------------------------------------------------------

table array_extra26.method_name_lengths:
  description: "array.array method __name__.__len__() for append/extend/pop/reverse/tolist/frombytes — simple name lengths"
  kind: python_call_eq
  category: method_identity
  id_prefix: amnlen26

  columns: [id, function, args, expected]
  rows:
    - [append,    "array.append.__name__.__len__",    [], 6]
    - [extend,    "array.extend.__name__.__len__",    [], 6]
    - [pop,       "array.pop.__name__.__len__",       [], 3]
    - [reverse,   "array.reverse.__name__.__len__",   [], 7]
    - [tolist,    "array.tolist.__name__.__len__",    [], 6]
    - [frombytes, "array.frombytes.__name__.__len__", [], 9]

# ---------------------------------------------------------------------------
# Standalone: array.array.__init__.__qualname__ == 'object.__init__'
#
# array.array is a C extension type that does not define its own __init__ slot.
# Accessing array.array.__init__ returns the inherited object.__init__ wrapper,
# whose __qualname__ is 'object.__init__' — not 'array.__init__'. This is the
# only method in scope where __qualname__ references a different class name.
# No prior array spec covers __init__.__qualname__.
# Verified: array.array.__init__.__qualname__ == 'object.__init__'.
# ---------------------------------------------------------------------------

invariant array_extra26.array.init_qualname:
  description: "array.array.__init__.__qualname__ == 'object.__init__' — array does not define its own __init__; inherited from object"
  category: method_qualnames
  kind: python_call_eq
  function: "array.__init__.__qualname__.__eq__"
  args: ["object.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: array.array.__init__.__qualname__.__len__() == 15
#
# 'object.__init__' has 15 characters. This length check provides an
# independent cross-validation for the __qualname__ value above.
# It also highlights that this qualname is longer than any method-level
# qualname of the form 'array.<name>' (max is 'array.fromunicode' at 17).
# Verified: len('object.__init__') == 15.
# ---------------------------------------------------------------------------

invariant array_extra26.array.init_qualname_len:
  description: "array.array.__init__.__qualname__.__len__() == 15 — len('object.__init__') == 15"
  category: method_qualnames
  kind: python_call_eq
  function: "array.__init__.__qualname__.__len__"
  args: []
  expected: 15
