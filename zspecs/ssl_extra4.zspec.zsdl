spec: ssl_extra4
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html
rfcs:
  - "RFC 8446 — The Transport Layer Security (TLS) Protocol Version 1.3"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ssl.py"
    - "CPython source: Modules/_ssl.c"
    - "ssl.zspec.zsdl — covers SSLError/SSLContext/SSLSocket/SSLCertVerificationError __name__; SSLError base and module; CERT_NONE/OPTIONAL/REQUIRED values; HAS_SNI/HAS_ALPN __class__.__name__"
    - "ssl_extra.zspec.zsdl — covers SSLContext.__module__ == '_ssl'; create_default_context name/return/check_hostname; OP_NO_SSLv2/OP_NO_SSLv3 Options type; Purpose class and members; PROTOCOL_TLS_CLIENT/SERVER Protocol type; SSLCertVerificationError module and base"
    - "ssl_extra2.zspec.zsdl — covers SSLZeroReturnError/SSLWantReadError/SSLWantWriteError names/bases/modules; CERT_NONE/REQUIRED VerifyMode class name; PROTOCOL_TLS_CLIENT/SERVER truthiness; SSLSocket.__module__"
    - "ssl_extra3.zspec.zsdl — covers TLSVersion name/base (IntEnum); TLSv1_2/TLSv1_3 member names; PROTOCOL_TLS_CLIENT._SSLMethod class"
    - "_ssl.zspec.zsdl — covers _ssl module C extension invariants"
    - "_ssl_extra.zspec.zsdl — covers additional _ssl module invariants"
  notes:
    - "This spec extends the ssl chain; it does NOT duplicate invariants present in any prior spec."
    - "ssl.SSLObject was added in Python 3.6 for memory-BIO-based TLS without a real socket; __name__ == 'SSLObject', __module__ == 'ssl', __bases__[0].__name__ == 'object'."
    - "ssl.CertificateError is an alias for ssl.SSLCertVerificationError (since Python 3.7); ssl.CertificateError.__name__ == 'SSLCertVerificationError' and __bases__[0].__name__ == 'SSLError'."
    - "ssl.VerifyMode is an IntEnum subclass; ssl.VerifyMode.__name__ == 'VerifyMode' and __bases__[0].__name__ == 'IntEnum'."
    - "ssl.CERT_OPTIONAL.__class__.__name__ == 'VerifyMode' — ssl_extra2 only checks CERT_NONE and CERT_REQUIRED."
    - "ssl.HAS_SNI is True on all modern Python builds (OpenSSL has supported SNI for many years)."
    - "ssl.SSLContext.__name__ == 'SSLContext' is in ssl.zspec.zsdl; this spec adds __bases__[0].__name__ == 'object' (SSLContext has no Python-visible parent class)."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "ssl.SSLError (subclass of OSError) is raised for TLS-level failures. All invariants in this spec are pure attribute reads and do not initiate TLS handshakes."
  stderr: "null"
  stickiness: "N/A — all tested invariants are stateless class attribute reads."
  codes: {}

# ---------------------------------------------------------------------------
# SSLObject — class name, module, and base class
# SSLObject is not covered by any prior spec in the ssl chain.
# ---------------------------------------------------------------------------

invariant ssl_extra4.SSLObject.name:
  description: "ssl.SSLObject.__name__ == 'SSLObject'"
  category: class_names
  kind: python_call_eq
  function: SSLObject.__name__.__eq__
  args: ["SSLObject"]
  expected: true

invariant ssl_extra4.SSLObject.module:
  description: "ssl.SSLObject.__module__ == 'ssl'"
  category: class_modules
  kind: python_call_eq
  function: SSLObject.__module__.__eq__
  args: ["ssl"]
  expected: true

invariant ssl_extra4.SSLObject.base:
  description: "ssl.SSLObject.__bases__[0].__name__ == 'object' — SSLObject has no Python-visible parent class"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLObject.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# CertificateError — alias for SSLCertVerificationError since Python 3.7
# ssl.CertificateError.__name__ reports the real class name of the aliased class.
# ssl_extra.zspec.zsdl checks SSLCertVerificationError directly; this spec
# documents that CertificateError is that same class.
# ---------------------------------------------------------------------------

invariant ssl_extra4.CertificateError.name:
  description: "ssl.CertificateError.__name__ == 'SSLCertVerificationError' — CertificateError is an alias"
  category: class_names
  kind: python_call_eq
  function: CertificateError.__name__.__eq__
  args: ["SSLCertVerificationError"]
  expected: true

invariant ssl_extra4.CertificateError.module:
  description: "ssl.CertificateError.__module__ == 'ssl'"
  category: class_modules
  kind: python_call_eq
  function: CertificateError.__module__.__eq__
  args: ["ssl"]
  expected: true

invariant ssl_extra4.CertificateError.base:
  description: "ssl.CertificateError.__bases__[0].__name__ == 'SSLError'"
  category: class_hierarchy
  kind: python_call_eq
  function: CertificateError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "SSLError"

# ---------------------------------------------------------------------------
# VerifyMode — class name and IntEnum base class
# ssl_extra2.zspec.zsdl checks CERT_NONE/REQUIRED instances' class name ('VerifyMode');
# this spec checks the VerifyMode class itself and its IntEnum inheritance.
# ---------------------------------------------------------------------------

invariant ssl_extra4.VerifyMode.name:
  description: "ssl.VerifyMode.__name__ == 'VerifyMode'"
  category: class_names
  kind: python_call_eq
  function: VerifyMode.__name__.__eq__
  args: ["VerifyMode"]
  expected: true

invariant ssl_extra4.VerifyMode.base:
  description: "ssl.VerifyMode.__bases__[0].__name__ == 'IntEnum' — VerifyMode is an IntEnum subclass"
  category: class_hierarchy
  kind: python_call_eq
  function: VerifyMode.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IntEnum"

# ---------------------------------------------------------------------------
# CERT_OPTIONAL — VerifyMode class name check
# ssl_extra2.zspec.zsdl already checks CERT_NONE and CERT_REQUIRED; this spec
# adds CERT_OPTIONAL to complete the VerifyMode instance type coverage.
# ---------------------------------------------------------------------------

invariant ssl_extra4.CERT_OPTIONAL.class_name:
  description: "ssl.CERT_OPTIONAL.__class__.__name__ == 'VerifyMode'"
  category: constants
  kind: python_call_eq
  function: CERT_OPTIONAL.__class__.__name__.__eq__
  args: ["VerifyMode"]
  expected: true

# ---------------------------------------------------------------------------
# HAS_SNI — always True on modern Python builds with OpenSSL
# ssl.zspec.zsdl checks __class__.__name__ == 'bool'; this spec checks the value.
# ---------------------------------------------------------------------------

invariant ssl_extra4.HAS_SNI.value:
  description: "ssl.HAS_SNI == True — SNI support is present in all modern OpenSSL builds"
  category: constants
  kind: python_call_eq
  function: HAS_SNI.__eq__
  args: [true]
  expected: true

# ---------------------------------------------------------------------------
# SSLContext base class — SSLContext inherits from object (no Python parent)
# ssl.zspec.zsdl checks __name__; ssl_extra checks __module__ == '_ssl'.
# This spec adds the base class check.
# ---------------------------------------------------------------------------

invariant ssl_extra4.SSLContext.base:
  description: "ssl.SSLContext.__bases__[0].__name__ == 'object' — SSLContext has no Python-visible parent class"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLContext.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
