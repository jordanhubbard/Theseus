spec: itertools_extra52
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra51.zspec.zsdl."
    - "Prior specs covered: __module__.__eq__('itertools') for groupby/chain/compress/islice/zip_longest/product/count/cycle/repeat/accumulate (various specs extra3..extra35); chain.__module__.__len__()==9 and accumulate.__module__.__len__()==9 (extra3/extra5); chain/__module__/__len__ in table rows (extra28/extra29); itertools.__name__.__eq__('itertools') (extra51); itertools.__package__.__eq__('itertools') (extra51); chain.from_iterable.__name__.__eq__('from_iterable') (extra51)."
    - "This spec covers: itertools.groupby.__module__.__class__.__name__.__eq__('str')==true; itertools.chain.__module__.__class__.__name__.__eq__('str')==true; itertools.compress.__module__.__class__.__name__.__eq__('str')==true; itertools.islice.__module__.__class__.__name__.__eq__('str')==true; itertools.zip_longest.__module__.__class__.__name__.__eq__('str')==true; itertools.accumulate.__module__.__class__.__name__.__eq__('str')==true; itertools.product.__module__.__len__()==9 in table form (confirming alongside class check); itertools.groupby.__module__.__class__.__qualname__.__eq__('str')==true; itertools.chain.__module__.__class__.__qualname__.__eq__('str')==true."
    - "Key findings: All itertools C-level types store their __module__ as a Python str object (the string 'itertools', 9 chars). This means for any itertools type T: T.__module__.__class__.__name__ == 'str' (3 chars) and T.__module__.__class__.__qualname__ == 'str' (3 chars), because the str built-in type has __name__ == __qualname__ == 'str' and __module__ == 'builtins'. Prior specs confirmed the __module__ string equality and length for these types, but no prior itertools spec records the __class__.__name__ or __class__.__qualname__ of the __module__ attribute for any itertools type. The __class__.__name__/__qualname__ checks for str-typed attributes are a new dimension first explored in functools (extra56) and inspect (extra51); this spec brings the same pattern to itertools. All nine invariants are new to extra52."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools type __module__.__class__.__name__ == 'str' — extra52 namespace
#
# All itertools types are C-level types defined in Modules/itertoolsmodule.c.
# Their __module__ attribute is the Python string 'itertools' (9 chars). Since
# this string is a Python str object, its __class__ is the str built-in type,
# and str.__name__ == 'str' (3 chars). No prior itertools spec records
# T.__module__.__class__.__name__.__eq__('str') for any itertools type. All
# six __class__.__name__ checks below are new to extra52.
#
# Types chosen span all major categories of the itertools API:
#   groupby      — grouping
#   chain        — chaining
#   compress     — filtering by selector
#   islice       — slicing
#   zip_longest  — zipping with fillvalue
#   accumulate   — running totals
# ---------------------------------------------------------------------------

table itertools_extra52.module_string_class_name:
  description: "itertools type __module__.__class__.__name__ == 'str' — all itertools C-level types store __module__ as a Python str object; str.__name__ == 'str' (3 chars); no prior itertools spec records this class-of-module-string check for any type"
  kind: python_call_eq
  category: identity
  id_prefix: itertmod52

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_module_class_name,
       groupby.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.groupby.__module__.__class__.__name__ == 'str' — groupby is a C-level type in Modules/itertoolsmodule.c; __module__ is the Python string 'itertools' (9 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed groupby.__module__.__eq__('itertools'); this is the first __module__.__class__.__name__ check for groupby; new to extra52"]
    - [chain_module_class_name,
       chain.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.chain.__module__.__class__.__name__ == 'str' — chain is a C-level type in Modules/itertoolsmodule.c; __module__ is the Python string 'itertools' (9 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed chain.__module__.__eq__('itertools') and chain.__module__.__len__()==9; this is the first __module__.__class__.__name__ check for chain; new to extra52"]
    - [compress_module_class_name,
       compress.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.compress.__module__.__class__.__name__ == 'str' — compress is a C-level type in Modules/itertoolsmodule.c; __module__ is the Python string 'itertools' (9 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed compress.__module__.__eq__('itertools'); this is the first __module__.__class__.__name__ check for compress; new to extra52"]
    - [islice_module_class_name,
       islice.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.islice.__module__.__class__.__name__ == 'str' — islice is a C-level type in Modules/itertoolsmodule.c; __module__ is the Python string 'itertools' (9 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed islice.__module__.__eq__('itertools'); this is the first __module__.__class__.__name__ check for islice; new to extra52"]
    - [zip_longest_module_class_name,
       zip_longest.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.zip_longest.__module__.__class__.__name__ == 'str' — zip_longest is a C-level type in Modules/itertoolsmodule.c; __module__ is the Python string 'itertools' (9 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed zip_longest.__module__.__eq__('itertools'); this is the first __module__.__class__.__name__ check for zip_longest; new to extra52"]
    - [accumulate_module_class_name,
       accumulate.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.accumulate.__module__.__class__.__name__ == 'str' — accumulate is a C-level type in Modules/itertoolsmodule.c; __module__ is the Python string 'itertools' (9 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed accumulate.__module__.__eq__('itertools') and accumulate.__module__.__len__()==9; this is the first __module__.__class__.__name__ check for accumulate; new to extra52"]

# ---------------------------------------------------------------------------
# itertools type __module__.__class__.__qualname__ == 'str' — extra52 namespace
#
# The str built-in type is a top-level type defined in the builtins module.
# Its __qualname__ equals its __name__ ('str', 3 chars) because str is not a
# nested class. Therefore for any itertools type T:
#   T.__module__.__class__.__qualname__ == 'str' (3 chars)
# No prior itertools spec records T.__module__.__class__.__qualname__.__eq__('str')
# for any itertools type. The two checks below (groupby and chain) establish
# this pattern as a recorded invariant; they are new to extra52.
# ---------------------------------------------------------------------------

table itertools_extra52.module_string_class_qualname:
  description: "itertools type __module__.__class__.__qualname__ == 'str' — the str built-in type has __qualname__ == __name__ == 'str' (3 chars); top-level type with no enclosing class scope; no prior itertools spec records __module__.__class__.__qualname__.__eq__ for any type"
  kind: python_call_eq
  category: identity
  id_prefix: itertmod52

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_module_class_qualname,
       groupby.__module__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "itertools.groupby.__module__.__class__.__qualname__ == 'str' — groupby.__module__ is a Python str object; the str built-in type has __qualname__ == 'str' (3 chars) because str is a top-level type with no enclosing class; consistent with extra52's groupby.__module__.__class__.__name__.__eq__('str'); this is the first __module__.__class__.__qualname__ check for any itertools type; new to extra52"]
    - [chain_module_class_qualname,
       chain.__module__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "itertools.chain.__module__.__class__.__qualname__ == 'str' — chain.__module__ is a Python str object; the str built-in type has __qualname__ == 'str' (3 chars); prior extra52 rows confirmed chain.__module__.__class__.__name__.__eq__('str'); qualname form is consistent since str.__qualname__ == str.__name__ == 'str'; new to extra52"]

# ---------------------------------------------------------------------------
# itertools type __module__.__len__() — extra52 namespace (product and cycle)
#
# Prior specs recorded chain.__module__.__len__()==9 (extra3/extra28) and
# accumulate.__module__.__len__()==9 (extra3/extra29). The following records
# the same length invariant for product and cycle, which appear in prior __eq__
# specs but whose __len__ was not recorded as explicit rows.
# ---------------------------------------------------------------------------

table itertools_extra52.module_string_len:
  description: "itertools.product and cycle __module__.__len__()==9 — 'itertools' is 9 chars; prior specs recorded this for chain and accumulate; product and cycle are recorded here for the first time as explicit __len__ rows"
  kind: python_call_eq
  category: identity
  id_prefix: itertmod52

  columns: [id, function, args, expected, description]
  rows:
    - [product_module_len,
       product.__module__.__len__,
       [],
       9,
       "itertools.product.__module__.__len__() == 9 — 'itertools' has 9 characters; product is a C-level type that computes Cartesian products of input iterables; prior specs confirmed product.__module__.__eq__('itertools') but did not record __module__.__len__() as an explicit row for product; new to extra52"]
    - [cycle_module_len,
       cycle.__module__.__len__,
       [],
       9,
       "itertools.cycle.__module__.__len__() == 9 — 'itertools' has 9 characters; cycle is a C-level type that repeats an iterable indefinitely; prior specs confirmed cycle.__module__.__eq__('itertools') but did not record __module__.__len__() as an explicit row for cycle; new to extra52"]
