spec: dom_serializer
version: ">=2.0.0"
backend: node(dom-serializer)

docs: https://github.com/cheeriojs/dom-serializer#readme

provenance:
  derived_from:
    - "dom-serializer README — https://github.com/cheeriojs/dom-serializer#readme"
    - "Test vectors verified with dom-serializer via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "dom-serializer source"
  notes:
    - "Serializes domhandler/htmlparser2 nodes back to HTML/XML strings."
    - "Install: npm install dom-serializer"
    - "v2 ESM with CJS shim; default export is the serializer function."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on shape-correct nodes."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# Serialize plain Element-shaped objects
invariant dom_serializer.tag_with_text:
  description: "Serializes <p>hi</p> from object form"
  category: render
  kind: node_module_call_eq
  function: default
  args: [{type: "tag", name: "p", attribs: {}, children: [{type: "text", data: "hi"}]}]
  expected: "<p>hi</p>"

invariant dom_serializer.tag_with_attributes:
  description: "Serializes attributes in declared order"
  category: render
  kind: node_module_call_eq
  function: default
  args: [{type: "tag", name: "a", attribs: {href: "https://example.com"}, children: [{type: "text", data: "link"}]}]
  expected: "<a href=\"https://example.com\">link</a>"

invariant dom_serializer.empty_tag:
  description: "Empty tag serializes as <p></p>"
  category: render
  kind: node_module_call_eq
  function: default
  args: [{type: "tag", name: "p", attribs: {}, children: []}]
  expected: "<p></p>"

invariant dom_serializer.text_node:
  description: "Text node serializes to its data"
  category: render
  kind: node_module_call_eq
  function: default
  args: [{type: "text", data: "plain text"}]
  expected: "plain text"

invariant dom_serializer.array_of_nodes:
  description: "Array of nodes is concatenated"
  category: render
  kind: node_module_call_eq
  function: default
  args: [[{type: "text", data: "before "}, {type: "tag", name: "b", attribs: {}, children: [{type: "text", data: "bold"}]}, {type: "text", data: " after"}]]
  expected: "before <b>bold</b> after"

invariant dom_serializer.html_entity_escaped_in_text:
  description: "Special chars in text content are HTML-escaped"
  category: render
  kind: node_module_call_eq
  function: default
  args: [{type: "text", data: "A & B"}]
  expected: "A &amp; B"

invariant dom_serializer.angle_brackets_escaped:
  description: "< and > in text get HTML-encoded"
  category: render
  kind: node_module_call_eq
  function: default
  args: [{type: "text", data: "<script>"}]
  expected: "&lt;script&gt;"
