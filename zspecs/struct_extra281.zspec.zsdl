spec: struct_extra281
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module function and Struct class identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c, Lib/struct.py"
  notes:
    - "struct functions (calcsize, pack, unpack, pack_into, unpack_from, iter_unpack) are all C builtins; __module__ is '_struct'"
    - "Struct class __module__ is also '_struct'"
    - "Struct.format and Struct.size are getset_descriptor objects on the C type"
    - "struct.error.__doc__ is None (no docstring on the exception class)"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table struct_extra281.func_names:
  description: "struct module function __name__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: stname

  columns: [id, function, args, expected, description]
  rows:
    - [stname001, struct.calcsize.__name__, [], calcsize, "calcsize __name__"]
    - [stname002, struct.pack.__name__, [], pack, "pack __name__"]
    - [stname003, struct.unpack.__name__, [], unpack, "unpack __name__"]
    - [stname004, struct.pack_into.__name__, [], pack_into, "pack_into __name__"]
    - [stname005, struct.unpack_from.__name__, [], unpack_from, "unpack_from __name__"]
    - [stname006, struct.iter_unpack.__name__, [], iter_unpack, "iter_unpack __name__"]

table struct_extra281.func_modules:
  description: "struct module function __module__ attributes — all are C builtins in _struct"
  kind: python_call_eq
  category: identity
  id_prefix: stmod

  columns: [id, function, args, expected, description]
  rows:
    - [stmod001, struct.calcsize.__module__, [], _struct, "calcsize lives in C extension _struct"]
    - [stmod002, struct.pack.__module__, [], _struct, "pack lives in C extension _struct"]
    - [stmod003, struct.unpack.__module__, [], _struct, "unpack lives in C extension _struct"]
    - [stmod004, struct.pack_into.__module__, [], _struct, "pack_into lives in C extension _struct"]
    - [stmod005, struct.unpack_from.__module__, [], _struct, "unpack_from lives in C extension _struct"]
    - [stmod006, struct.iter_unpack.__module__, [], _struct, "iter_unpack lives in C extension _struct"]

invariant struct_extra281.struct_class_module:
  description: "Struct class __module__ is _struct (C extension)"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__module__
  args: []
  expected: _struct

invariant struct_extra281.struct_format_descriptor:
  description: "Struct.format attribute is a getset_descriptor"
  category: identity
  kind: python_call_eq
  function: struct.Struct.format.__class__.__name__
  args: []
  expected: getset_descriptor

invariant struct_extra281.struct_size_descriptor:
  description: "Struct.size attribute is a getset_descriptor"
  category: identity
  kind: python_call_eq
  function: struct.Struct.size.__class__.__name__
  args: []
  expected: getset_descriptor
