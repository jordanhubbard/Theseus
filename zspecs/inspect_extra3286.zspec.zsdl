spec: in3286
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 666 (in3286): __iadd__, __isub__, __imul__ dict-presence checks for inspect types."
    - "Theme: __iadd__/__isub__/__imul__ in-place arithmetic dict-presence."
    - "In-place augmented assignment operators (+=, -=, *=) fall back to __add__/__sub__/__mul__ if not defined."
    - "All values False — callable/iterator/inspection/synchronization types have no in-place arithmetic operators."
    - "No inspect type defines __iadd__, __isub__, or __imul__ in its own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "None of these types implement in-place arithmetic protocols directly."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3286.iadd:
  description: "inspect types __iadd__ dict-presence checks; wave 666"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3286
  columns: [id, function, args, expected]
  rows:
    - ["in3286001", operator.contains, [inspect.Parameter.__dict__,           "__iadd__"], false]
    - ["in3286002", operator.contains, [inspect.Signature.__dict__,           "__iadd__"], false]
    - ["in3286003", operator.contains, [inspect.BoundArguments.__dict__,      "__iadd__"], false]
    - ["in3286004", operator.contains, [inspect.FrameInfo.__dict__,           "__iadd__"], false]
    - ["in3286005", operator.contains, [inspect.ArgInfo.__dict__,             "__iadd__"], false]
    - ["in3286006", operator.contains, [inspect.FullArgSpec.__dict__,         "__iadd__"], false]
    - ["in3286007", operator.contains, [inspect.Attribute.__dict__,           "__iadd__"], false]
    - ["in3286008", operator.contains, [inspect.ClassFoundException.__dict__, "__iadd__"], false]
    - ["in3286009", operator.contains, [inspect.EndOfBlock.__dict__,          "__iadd__"], false]

