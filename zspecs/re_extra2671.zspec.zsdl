spec: re_extra2671
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers existing re invariants"
    - "re_extra2656.zspec.zsdl — covers __contains__/__add__/__mul__ dict-presence"
  notes:
    - "Wave 625 (re_extra2671) theme: __sub__, __floordiv__, and __mod__ dict-presence checks."
    - "Neither re.Pattern nor re.Match defines __sub__, __floordiv__, or __mod__ in its own __dict__."
    - "__sub__ is the arithmetic subtraction operator; regex objects are not numeric types."
    - "__floordiv__ is the floor-division operator; regex objects do not implement division semantics."
    - "__mod__ is the modulo operator; regex objects do not implement modulo semantics."
    - "Covers re.Pattern (type(re.compile(''))) and re.Match (type(re.match('', '')))."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __sub__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2671.no_sub_in_re_classes:
  description: "__sub__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement arithmetic subtraction"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2671

  columns: [id, function, args, expected]
  rows:
    - ["re2671001", "re.Pattern.__dict__.__contains__", ["__sub__"], false]
    - ["re2671002", "re.Match.__dict__.__contains__",   ["__sub__"], false]

# ---------------------------------------------------------------------------
# __floordiv__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2671.no_floordiv_in_re_classes:
  description: "__floordiv__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement floor-division"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2671

  columns: [id, function, args, expected]
  rows:
    - ["re2671003", "re.Pattern.__dict__.__contains__", ["__floordiv__"], false]
    - ["re2671004", "re.Match.__dict__.__contains__",   ["__floordiv__"], false]

# ---------------------------------------------------------------------------
# __mod__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2671.no_mod_in_re_classes:
  description: "__mod__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the modulo protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2671

  columns: [id, function, args, expected]
  rows:
    - ["re2671005", "re.Pattern.__dict__.__contains__", ["__mod__"], false]
    - ["re2671006", "re.Match.__dict__.__contains__",   ["__mod__"], false]

# ---------------------------------------------------------------------------
# Complementary: re.Pattern and re.Match have regex methods but not arithmetic hooks
# Confirms that regex objects are pattern-matching types, not arithmetic types
# ---------------------------------------------------------------------------

table re_extra2671.re_has_regex_methods_not_arithmetic_hooks:
  description: "re.Pattern defines match/search/sub/findall but NOT __sub__/__floordiv__/__mod__; re.Match defines group/groups/start/end but NOT __sub__/__floordiv__/__mod__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2671

  columns: [id, function, args, expected]
  rows:
    - ["re2671007", "re.Pattern.__dict__.__contains__", ["match"],        true]
    - ["re2671008", "re.Pattern.__dict__.__contains__", ["search"],       true]
    - ["re2671009", "re.Pattern.__dict__.__contains__", ["sub"],          true]
    - ["re2671010", "re.Pattern.__dict__.__contains__", ["findall"],      true]
    - ["re2671011", "re.Pattern.__dict__.__contains__", ["__sub__"],      false]
    - ["re2671012", "re.Pattern.__dict__.__contains__", ["__floordiv__"], false]
    - ["re2671013", "re.Pattern.__dict__.__contains__", ["__mod__"],      false]
    - ["re2671014", "re.Match.__dict__.__contains__",   ["group"],        true]
    - ["re2671015", "re.Match.__dict__.__contains__",   ["groups"],       true]
    - ["re2671016", "re.Match.__dict__.__contains__",   ["start"],        true]
    - ["re2671017", "re.Match.__dict__.__contains__",   ["end"],          true]
    - ["re2671018", "re.Match.__dict__.__contains__",   ["__sub__"],      false]
    - ["re2671019", "re.Match.__dict__.__contains__",   ["__floordiv__"], false]
    - ["re2671020", "re.Match.__dict__.__contains__",   ["__mod__"],      false]
