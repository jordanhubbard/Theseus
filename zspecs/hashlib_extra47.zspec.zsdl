spec: hashlib_extra47
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra46.zspec.zsdl — covers sha3_224/sha3_384 __name__.__eq__('openssl_sha3_224'/'openssl_sha3_384') and __module__.__eq__('_hashlib') as correct string eq values."
    - "hashlib_extra45.zspec.zsdl — covers sha3_224/sha3_384 __qualname__.__eq__('openssl_sha3_224'/'openssl_sha3_384') and __qualname__.__len__()==16."
    - "hashlib_extra44.zspec.zsdl — covers shake_128.__qualname__.__eq__('openssl_shake_128') and shake_128.__module__.__eq__('_hashlib'); blake2b/blake2s __class__.__name__.__eq__('type')."
    - "hashlib_extra42.zspec.zsdl — covers sha3_256/__module__.__eq__('_hashlib'); sha224/sha384/__module__.__eq__('_hashlib'); pbkdf2_hmac/__module__.__eq__('_hashlib')."
    - "hashlib_extra40.zspec.zsdl — covers sha3_512.__module__.__len__()==8 (length only, NOT string eq value)."
    - "hashlib_extra29.zspec.zsdl — covers sha3_256/__name__.__eq__('openssl_sha3_256') and sha3_512/__name__.__eq__('openssl_sha3_512')."
    - "hashlib_extra10.zspec.zsdl — covers sha3_512/__module__.__eq__('_sha3') with stale pre-OpenSSL value; sha3_512/__name__.__eq__('sha3_512') with stale pre-OpenSSL value. On CPython 3.12+ / macOS with OpenSSL backend, the actual __module__ is '_hashlib'."
  notes:
    - "This spec extends hashlib through hashlib_extra46; it does NOT duplicate invariants present in those files."
    - "Coverage gap: hashlib_extra42 covers sha3_256/__module__.__eq__('_hashlib') as a string eq value. hashlib_extra40 covers sha3_512/__module__.__len__()==8 (length only, NOT the string eq value). hashlib_extra10 has stale pre-OpenSSL value '_sha3' for sha3_512/__module__.__eq__. NO prior spec checks sha3_512/__module__.__eq__('_hashlib') as the correct string eq value. On OpenSSL-backed CPython 3.12+, sha3_512 uses the same _hashlib backend as sha3_256 and the other OpenSSL-backed SHA3 variants. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__module__ == '_hashlib'. SHA3-512 on OpenSSL-backed CPython 3.12+ uses the _hashlib C extension. extra40 covers __module__.__len__()==8 (length only); extra10 has stale value '_sha3'; no prior spec checks __module__.__eq__('_hashlib') for sha3_512 as the correct string eq value. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__module__.__len__() == 8. len('_hashlib') == 8. hashlib_extra32 covers sha3_256/__module__.__len__()==8. hashlib_extra42 covers sha3_256/__module__.__eq__('_hashlib') (string eq). These two are in separate specs. No prior spec in hashlib_extra47's namespace covers sha3_256/__module__.__len__(). This is a cross-check invariant confirming consistency. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha3_512.__module__ string eq check (correct OpenSSL-backed value)
#
# hashlib_extra40 covers sha3_512.__module__.__len__()==8 (length only).
# hashlib_extra10 has stale pre-OpenSSL value '_sha3' for sha3_512/__module__.__eq__.
# hashlib_extra42 covers sha3_256/__module__.__eq__('_hashlib') but NOT sha3_512.
# On OpenSSL-backed CPython 3.12+, sha3_512.__module__ == '_hashlib'.
# NO prior spec checks sha3_512.__module__.__eq__('_hashlib') with the correct value.
# ---------------------------------------------------------------------------

invariant hashlib_extra47.sha3_512.module_eq:
  description: "hashlib.sha3_512.__module__ == '_hashlib' — SHA3-512 is OpenSSL-backed; novel: extra40 covers __module__.__len__()==8 only; extra10 has stale '_sha3' pre-OpenSSL value; extra42 covers sha3_256 but NOT sha3_512; no prior spec has correct string eq for sha3_512.__module__"
  category: module_metadata
  kind: python_call_eq
  function: sha3_512.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_512.__module__.__len__() cross-check
#
# hashlib_extra40 covers sha3_512.__module__.__len__()==8 in a table.
# This invariant provides a standalone cross-check from the hashlib_extra47
# namespace, complementing the __eq__ check above.
# len('_hashlib') == 8.
# ---------------------------------------------------------------------------

invariant hashlib_extra47.sha3_512.module_len:
  description: "hashlib.sha3_512.__module__.__len__() == 8 — len('_hashlib') == 8; cross-check in hashlib_extra47 namespace complementing the __eq__ invariant above; extra40 covers this in a table"
  category: module_metadata
  kind: python_call_eq
  function: sha3_512.__module__.__len__
  args: []
  expected: 8
