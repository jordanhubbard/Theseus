spec: inspect_extra248
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Signature behavioral contracts — __init__, bind, bind_partial, from_callable method identity."
    - "inspect.signature(lambda x: x).__class__.__name__ == 'Signature' — signature() returns a Signature instance; verified with Python 3.14.3."
    - "inspect.signature(len).__class__.__name__ == 'Signature' — signature(len) returns a Signature instance; verified with Python 3.14.3."
    - "inspect.Signature.__init__.__name__ == '__init__' — the __init__ method of Signature; verified with Python 3.14.3."
    - "inspect.Signature.bind.__name__ == 'bind' — bind is a regular Python function on Signature; verified with Python 3.14.3."
    - "inspect.Signature.bind.__qualname__ == 'Signature.bind' — bind is defined directly on the Signature class; verified with Python 3.14.3."
    - "inspect.Signature.bind_partial.__name__ == 'bind_partial'; __qualname__ == 'Signature.bind_partial'; verified with Python 3.14.3."
    - "inspect.Signature.from_callable.__name__ == 'from_callable'; __qualname__ == 'Signature.from_callable'; verified with Python 3.14.3."
    - "inspect.Signature.__dict__.__len__() == 27 — Signature.__dict__ has exactly 27 keys on Python 3.14.3; verified with Python 3.14.3."
    - "inspect.Signature.__dict__.__contains__('bind') == True; __contains__('bind_partial') == True; __contains__('parameters') == True; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: Signature method __name__ and __qualname__ checks
#
# inspect.Signature.__init__.__name__ == '__init__'
# inspect.Signature.__init__.__qualname__ == 'Signature.__init__'
# inspect.Signature.bind.__name__ == 'bind'
# inspect.Signature.bind.__qualname__ == 'Signature.bind'
# inspect.Signature.bind_partial.__name__ == 'bind_partial'
# inspect.Signature.bind_partial.__qualname__ == 'Signature.bind_partial'
# inspect.Signature.from_callable.__name__ == 'from_callable'
# inspect.Signature.from_callable.__qualname__ == 'Signature.from_callable'
#
# These are the primary Signature methods. Their __name__ is the unqualified
# name and __qualname__ is 'Signature.<method>'. New to extra248.
# ---------------------------------------------------------------------------

table inspsig248.signature_method_names:
  description: "inspect.Signature __init__/bind/bind_partial/from_callable __name__ and __qualname__; new to extra248"
  kind: python_call_eq
  category: method_identity
  id_prefix: inspsig248

  columns: [id, function, args, expected, description]
  rows:
    - [init_name_eq,
       Signature.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "inspect.Signature.__init__.__name__.__eq__('__init__') == True — __init__ is the constructor method of Signature; its __name__ is '__init__'; str.__eq__('__init__') returns True; new to extra248"]
    - [init_qualname_eq,
       Signature.__init__.__qualname__.__eq__,
       ["Signature.__init__"],
       true,
       "inspect.Signature.__init__.__qualname__.__eq__('Signature.__init__') == True — __init__ is defined directly on the Signature class so its __qualname__ is 'Signature.__init__'; str.__eq__('Signature.__init__') returns True; new to extra248"]
    - [bind_name_eq,
       Signature.bind.__name__.__eq__,
       ["bind"],
       true,
       "inspect.Signature.bind.__name__.__eq__('bind') == True — bind is a method of Signature that applies the signature to a set of arguments; its __name__ is 'bind'; str.__eq__('bind') returns True; new to extra248"]
    - [bind_qualname_eq,
       Signature.bind.__qualname__.__eq__,
       ["Signature.bind"],
       true,
       "inspect.Signature.bind.__qualname__.__eq__('Signature.bind') == True — bind is defined on the Signature class so its __qualname__ is 'Signature.bind'; str.__eq__('Signature.bind') returns True; new to extra248"]

# ---------------------------------------------------------------------------
# Table 2: bind_partial and from_callable method identity
#
# inspect.Signature.bind_partial.__name__ == 'bind_partial'
# inspect.Signature.bind_partial.__qualname__ == 'Signature.bind_partial'
# inspect.Signature.from_callable.__name__ == 'from_callable'
# inspect.Signature.from_callable.__qualname__ == 'Signature.from_callable'
#
# bind_partial is like bind but allows partial argument sets. from_callable
# is a classmethod that creates a Signature from a callable. New to extra248.
# ---------------------------------------------------------------------------

table inspsig248.signature_method_names2:
  description: "inspect.Signature bind_partial/from_callable __name__ and __qualname__; new to extra248"
  kind: python_call_eq
  category: method_identity
  id_prefix: inspsig248

  columns: [id, function, args, expected, description]
  rows:
    - [bind_partial_name_eq,
       Signature.bind_partial.__name__.__eq__,
       ["bind_partial"],
       true,
       "inspect.Signature.bind_partial.__name__.__eq__('bind_partial') == True — bind_partial is a Signature method that works like bind but allows partial argument matching; its __name__ is 'bind_partial'; str.__eq__('bind_partial') returns True; new to extra248"]
    - [bind_partial_qualname_eq,
       Signature.bind_partial.__qualname__.__eq__,
       ["Signature.bind_partial"],
       true,
       "inspect.Signature.bind_partial.__qualname__.__eq__('Signature.bind_partial') == True — bind_partial is defined on the Signature class; its __qualname__ is 'Signature.bind_partial'; str.__eq__('Signature.bind_partial') returns True; new to extra248"]
    - [from_callable_name_eq,
       Signature.from_callable.__name__.__eq__,
       ["from_callable"],
       true,
       "inspect.Signature.from_callable.__name__.__eq__('from_callable') == True — from_callable is a classmethod that constructs a Signature from any callable; its __name__ is 'from_callable'; str.__eq__('from_callable') returns True; new to extra248"]
    - [from_callable_qualname_eq,
       Signature.from_callable.__qualname__.__eq__,
       ["Signature.from_callable"],
       true,
       "inspect.Signature.from_callable.__qualname__.__eq__('Signature.from_callable') == True — from_callable is defined on the Signature class; its __qualname__ is 'Signature.from_callable'; str.__eq__('Signature.from_callable') returns True; new to extra248"]

# ---------------------------------------------------------------------------
# Table 3: Signature.__dict__ membership checks
#
# inspect.Signature.__dict__.__contains__('bind') == True
# inspect.Signature.__dict__.__contains__('bind_partial') == True
# inspect.Signature.__dict__.__contains__('from_callable') == True
# inspect.Signature.__dict__.__contains__('parameters') == True
# inspect.Signature.__dict__.__contains__('acquire') == False
# inspect.Signature.__dict__.__contains__('nonexistent') == False
#
# Signature.__dict__ contains the class's own namespace. bind, bind_partial,
# from_callable, and parameters are all defined directly on Signature. New to
# extra248.
# ---------------------------------------------------------------------------

table inspsig248.signature_dict_membership:
  description: "inspect.Signature.__dict__ contains bind, bind_partial, from_callable, parameters; not acquire, nonexistent; new to extra248"
  kind: python_call_eq
  category: dict_membership
  id_prefix: inspsig248

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_bind,
       Signature.__dict__.__contains__,
       ["bind"],
       true,
       "inspect.Signature.__dict__.__contains__('bind') == True — Signature defines 'bind' directly in its class body; __contains__('bind') returns True; new to extra248"]
    - [dict_has_bind_partial,
       Signature.__dict__.__contains__,
       ["bind_partial"],
       true,
       "inspect.Signature.__dict__.__contains__('bind_partial') == True — Signature defines 'bind_partial' directly in its class body; __contains__('bind_partial') returns True; new to extra248"]
    - [dict_has_from_callable,
       Signature.__dict__.__contains__,
       ["from_callable"],
       true,
       "inspect.Signature.__dict__.__contains__('from_callable') == True — Signature defines 'from_callable' as a classmethod in its class body; __contains__('from_callable') returns True; new to extra248"]
    - [dict_has_parameters,
       Signature.__dict__.__contains__,
       ["parameters"],
       true,
       "inspect.Signature.__dict__.__contains__('parameters') == True — Signature defines 'parameters' as a property in its class body; __contains__('parameters') returns True; new to extra248"]
    - [dict_no_acquire,
       Signature.__dict__.__contains__,
       ["acquire"],
       false,
       "inspect.Signature.__dict__.__contains__('acquire') == False — 'acquire' is a Lock method unrelated to Signature; Signature.__dict__ does not contain 'acquire'; __contains__('acquire') returns False; new to extra248"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra248
# ---------------------------------------------------------------------------

invariant inspsig248.Signature.init_name_eq:
  description: "inspect.Signature.__init__.__name__ == '__init__' — Signature constructor method name is '__init__'; new to extra248"
  category: method_identity
  kind: python_call_eq
  function: Signature.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant inspsig248.Signature.bind_name_eq:
  description: "inspect.Signature.bind.__name__ == 'bind' — Signature.bind method name is 'bind'; new to extra248"
  category: method_identity
  kind: python_call_eq
  function: Signature.bind.__name__.__eq__
  args: ["bind"]
  expected: true

invariant inspsig248.Signature.bind_qualname_eq:
  description: "inspect.Signature.bind.__qualname__ == 'Signature.bind' — bind is defined on Signature; qualname is 'Signature.bind'; new to extra248"
  category: method_identity
  kind: python_call_eq
  function: Signature.bind.__qualname__.__eq__
  args: ["Signature.bind"]
  expected: true

invariant inspsig248.Signature.bind_class_function:
  description: "inspect.Signature.bind.__class__.__name__ == 'function' — Signature.bind is a plain Python function; new to extra248"
  category: method_identity
  kind: python_call_eq
  function: Signature.bind.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspsig248.Signature.bind_module_inspect:
  description: "inspect.Signature.bind.__module__ == 'inspect' — bind is defined in the inspect module; new to extra248"
  category: method_identity
  kind: python_call_eq
  function: Signature.bind.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspsig248.Signature.name_eq:
  description: "inspect.Signature.__name__ == 'Signature' — Signature class name is 'Signature'; new to extra248"
  category: class_identity
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspsig248.Signature.module_eq:
  description: "inspect.Signature.__module__ == 'inspect' — Signature is defined in the inspect module; new to extra248"
  category: class_identity
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspsig248.Signature.dict_len_27:
  description: "inspect.Signature.__dict__.__len__() == 27 — Signature's class namespace has exactly 27 keys on Python 3.14.3; new to extra248"
  category: dict_membership
  kind: python_call_eq
  function: Signature.__dict__.__len__
  args: []
  expected: 27

invariant inspsig248.Signature.bind_partial_name_eq:
  description: "inspect.Signature.bind_partial.__name__ == 'bind_partial' — bind_partial method name; new to extra248"
  category: method_identity
  kind: python_call_eq
  function: Signature.bind_partial.__name__.__eq__
  args: ["bind_partial"]
  expected: true

invariant inspsig248.Signature.from_callable_qualname_eq:
  description: "inspect.Signature.from_callable.__qualname__ == 'Signature.from_callable' — from_callable qualname; new to extra248"
  category: method_identity
  kind: python_call_eq
  function: Signature.from_callable.__qualname__.__eq__
  args: ["Signature.from_callable"]
  expected: true

invariant inspsig248.Signature.init_qualname_eq:
  description: "inspect.Signature.__init__.__qualname__ == 'Signature.__init__' — __init__ qualname; new to extra248"
  category: method_identity
  kind: python_call_eq
  function: Signature.__init__.__qualname__.__eq__
  args: ["Signature.__init__"]
  expected: true

invariant inspsig248.Signature.dict_no_nonexistent:
  description: "inspect.Signature.__dict__.__contains__('nonexistent') == False — 'nonexistent' is not in Signature.__dict__; new to extra248"
  category: dict_membership
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["nonexistent"]
  expected: false
