spec: threading_extra7
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec extends threading.zspec.zsdl, threading_extra.zspec.zsdl, threading_extra2.zspec.zsdl, threading_extra3.zspec.zsdl, threading_extra4.zspec.zsdl, threading_extra5.zspec.zsdl, threading_extra6.zspec.zsdl, threading_sync.zspec.zsdl, threading_timer.zspec.zsdl."
    - "Prior specs cover: __name__, __module__, __bases__, instance __class__.__name__ for Thread/Lock/RLock/Condition/Semaphore/BoundedSemaphore/Event/Timer/Barrier/local; current_thread, main_thread, active_count, enumerate, settrace, setprofile, stack_size __name__ and __module__; TIMEOUT_MAX type; Lock/RLock instance class names; Lock __module__ == '_thread'."
    - "This spec adds __qualname__ vectors for all major threading classes and functions — not previously covered in any prior threading spec."
    - "threading.Thread.__qualname__ == 'Thread' — top-level class, qualname equals name."
    - "threading.Condition.__qualname__ == 'Condition' — pure-Python class defined at module scope."
    - "threading.Semaphore.__qualname__ == 'Semaphore' — pure-Python class defined at module scope."
    - "threading.Event.__qualname__ == 'Event' — pure-Python class defined at module scope."
    - "threading.Timer.__qualname__ == 'Timer' — Thread subclass defined at module scope."
    - "threading.Barrier.__qualname__ == 'Barrier' — synchronization barrier defined at module scope."
    - "threading.local.__qualname__ == 'local' — thread-local storage class defined at module scope."
    - "threading.current_thread.__qualname__ == 'current_thread' — top-level function."
    - "threading.main_thread.__qualname__ == 'main_thread' — top-level function."
    - "threading.Lock().__class__.__qualname__ is 'lock' (lowercase) — the C-level lock type's qualname."
    - "threading.RLock().__class__.__name__ == 'RLock' — confirmed separately; qualname is also 'RLock'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ table for pure-Python threading classes
#
# For top-level (non-nested) Python classes, __qualname__ equals __name__.
# This table covers Thread, Condition, Semaphore, Event, Timer, Barrier,
# and local — none of which have been checked via __qualname__ in prior specs.
# ---------------------------------------------------------------------------

table threading_extra7.class_qualnames:
  description: "Pure-Python threading classes have correct __qualname__ (equals __name__ for top-level classes)"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Thread,    Thread.__qualname__.__eq__,    ["Thread"],    true]
    - [Condition, Condition.__qualname__.__eq__, ["Condition"], true]
    - [Semaphore, Semaphore.__qualname__.__eq__, ["Semaphore"], true]
    - [Event,     Event.__qualname__.__eq__,     ["Event"],     true]
    - [Timer,     Timer.__qualname__.__eq__,     ["Timer"],     true]
    - [Barrier,   Barrier.__qualname__.__eq__,   ["Barrier"],   true]
    - [local,     local.__qualname__.__eq__,     ["local"],     true]

# ---------------------------------------------------------------------------
# __qualname__ for threading functions
#
# current_thread and main_thread are top-level functions; their __qualname__
# equals their __name__. These were covered for __name__ in prior specs but
# not for __qualname__.
# ---------------------------------------------------------------------------

invariant threading_extra7.current_thread.qualname:
  description: "threading.current_thread.__qualname__ == 'current_thread'"
  category: function_qualnames
  kind: python_call_eq
  function: current_thread.__qualname__.__eq__
  args: ["current_thread"]
  expected: true

invariant threading_extra7.main_thread.qualname:
  description: "threading.main_thread.__qualname__ == 'main_thread'"
  category: function_qualnames
  kind: python_call_eq
  function: main_thread.__qualname__.__eq__
  args: ["main_thread"]
  expected: true

# ---------------------------------------------------------------------------
# Lock().__class__.__qualname__ — the C-level lock type
#
# threading.Lock() returns a C-level lock object. Its class __name__ is 'lock'
# (lowercase); its __qualname__ is also 'lock'. Prior specs (threading_extra4,
# threading_extra6) checked __class__.__name__; this checks __class__.__qualname__.
# ---------------------------------------------------------------------------

invariant threading_extra7.Lock.instance_class_qualname:
  description: "threading.Lock().__class__.__qualname__ == 'lock' (C-level lock type, lowercase)"
  category: lock
  kind: python_call_eq
  function: Lock
  args: []
  method: __class__
  method_chain: __qualname__.__eq__
  method_chain_args: ["lock"]
  expected: true

# ---------------------------------------------------------------------------
# RLock().__class__.__qualname__
#
# threading.RLock() returns a C-level RLock object. Its __class__.__qualname__
# is 'RLock'. Prior specs checked __class__.__name__ on instances; this
# checks __class__.__qualname__ for independent traceability.
# ---------------------------------------------------------------------------

invariant threading_extra7.RLock.instance_class_qualname:
  description: "threading.RLock().__class__.__qualname__ == 'RLock'"
  category: rlock
  kind: python_call_eq
  function: RLock
  args: []
  method: __class__
  method_chain: __qualname__.__eq__
  method_chain_args: ["RLock"]
  expected: true
