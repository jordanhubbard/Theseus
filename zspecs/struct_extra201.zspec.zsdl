spec: struct_extra201
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "struct module-level functions (pack, unpack, calcsize, etc.) are C builtins — they have no __defaults__ attribute; accessing it raises AttributeError. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.__init__ is a wrapper_descriptor (C slot) — it has no __defaults__ attribute; accessing it raises AttributeError. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.__doc__ is a str of length 40 — 'Struct(fmt) --> compiled struct object\\n\\n'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.__name__ is 'Struct' (length 6). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.error.__name__ is 'error' (length 5). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.__name__ is 'struct' (length 6). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module-level C builtins have no __defaults__ — raises AttributeError
#
# struct.calcsize, struct.pack, struct.unpack, and struct.Struct.__init__
# are all C-level objects. They have no __defaults__ attribute.
# Accessing it raises AttributeError.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra201.builtin_no_defaults_raises:
  description: "struct C-level functions and Struct.__init__ have no __defaults__ — calcsize, pack, unpack are builtin_function_or_method; Struct.__init__ is a wrapper_descriptor; all raise AttributeError when __defaults__ is accessed"
  kind: python_call_raises
  category: builtin_no_defaults
  id_prefix: structdefaults201

  columns: [id, function, args, expected]
  rows:
    - [calcsize_no_defaults,    calcsize.__getattribute__,      ["__defaults__"],  AttributeError]
    - [pack_no_defaults,        pack.__getattribute__,          ["__defaults__"],  AttributeError]
    - [unpack_no_defaults,      unpack.__getattribute__,        ["__defaults__"],  AttributeError]
    - [struct_init_no_defaults, Struct.__init__.__getattribute__, ["__defaults__"], AttributeError]

# ---------------------------------------------------------------------------
# struct.Struct.__doc__ identity
#
# struct.Struct.__doc__ is the string 'Struct(fmt) --> compiled struct object\n\n'
# Its class name is 'str' and its length is 40.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra201.struct_doc_identity:
  description: "struct.Struct.__doc__.__class__.__name__ and __len__() — Struct.__doc__ is a str; length is 40; contains 'Struct'"
  kind: python_call_eq
  category: class_doc
  id_prefix: structdefaults201

  columns: [id, function, args, expected, description]
  rows:
    - [struct_doc_classname,  Struct.__doc__.__class__.__name__.__eq__,  ["str"],    true,  "struct.Struct.__doc__.__class__.__name__ == 'str' — docstring is a string"]
    - [struct_doc_len,        Struct.__doc__.__len__,                    [],         40,    "struct.Struct.__doc__.__len__() == 40 — docstring is 40 characters"]
    - [struct_doc_contains,   Struct.__doc__.__contains__,               ["Struct"], true,  "struct.Struct.__doc__.__contains__('Struct') — docstring contains the class name"]
    - [struct_name_len,       Struct.__name__.__len__,                   [],         6,     "struct.Struct.__name__.__len__() == 6 — class name 'Struct' has 6 characters"]

# ---------------------------------------------------------------------------
# struct name identity — module, class, and error names
#
# struct.__name__ == 'struct' (length 6)
# struct.Struct.__name__ == 'Struct' (length 6)
# struct.error.__name__ == 'error' (length 5)
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra201.name_identity:
  description: "struct module, Struct class, and error class name identities — __name__ values and lengths; all verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: name_identity
  id_prefix: structdefaults201

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,        __name__.__eq__,                ["struct"],  true,  "struct.__name__ == 'struct' — module name identity"]
    - [module_name_len,       __name__.__len__,               [],          6,     "struct.__name__.__len__() == 6 — module name is 6 characters"]
    - [error_name_eq,         error.__name__.__eq__,          ["error"],   true,  "struct.error.__name__ == 'error' — error class name identity"]
    - [error_name_len,        error.__name__.__len__,         [],          5,     "struct.error.__name__.__len__() == 5 — error class name is 5 characters"]

# ---------------------------------------------------------------------------
# Standalone invariants (8 total)
# ---------------------------------------------------------------------------

invariant struct_extra201.calcsize_no_defaults_raises:
  description: "struct.calcsize.__defaults__ raises AttributeError — calcsize is a C-level builtin_function_or_method with no __defaults__ attribute; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: builtin_no_defaults
  kind: python_call_raises
  function: calcsize.__getattribute__
  args: ["__defaults__"]
  expected_exception: AttributeError

invariant struct_extra201.pack_no_defaults_raises:
  description: "struct.pack.__defaults__ raises AttributeError — pack is a C-level builtin_function_or_method with no __defaults__ attribute; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: builtin_no_defaults
  kind: python_call_raises
  function: pack.__getattribute__
  args: ["__defaults__"]
  expected_exception: AttributeError

invariant struct_extra201.struct_init_no_defaults_raises:
  description: "struct.Struct.__init__.__defaults__ raises AttributeError — Struct.__init__ is a wrapper_descriptor (C slot) with no __defaults__ attribute; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: builtin_no_defaults
  kind: python_call_raises
  function: Struct.__init__.__getattribute__
  args: ["__defaults__"]
  expected_exception: AttributeError

invariant struct_extra201.struct_doc_classname:
  description: "struct.Struct.__doc__.__class__.__name__ == 'str' — Struct has a docstring; its type is str; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: class_doc
  kind: python_call_eq
  function: Struct.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant struct_extra201.struct_doc_len:
  description: "struct.Struct.__doc__.__len__() == 40 — the Struct docstring 'Struct(fmt) --> compiled struct object\\n\\n' is 40 characters; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: class_doc
  kind: python_call_eq
  function: Struct.__doc__.__len__
  args: []
  expected: 40

invariant struct_extra201.module_name_eq:
  description: "struct.__name__ == 'struct' — module name identity; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: name_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra201.error_name_eq:
  description: "struct.error.__name__ == 'error' — error class name identity; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: name_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant struct_extra201.struct_name_len:
  description: "struct.Struct.__name__.__len__() == 6 — class name 'Struct' has 6 characters; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: name_identity
  kind: python_call_eq
  function: Struct.__name__.__len__
  args: []
  expected: 6

