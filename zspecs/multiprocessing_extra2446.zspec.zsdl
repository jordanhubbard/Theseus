spec: multiprocessing_extra2446
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2446: __enter__/__exit__ context manager protocol dict-presence checks."
    - "multiprocessing.pool.Pool defines __enter__ and __exit__ directly in its own __dict__."
    - "multiprocessing.managers.BaseManager defines __enter__ and __exit__ in its own __dict__."
    - "multiprocessing.managers.AcquirerProxy defines __enter__ and __exit__ in its own __dict__."
    - "multiprocessing.managers.SyncManager does NOT define __enter__/__exit__ in own __dict__; inherits from BaseManager."
    - "multiprocessing.Process (multiprocessing.context.Process) does NOT define __enter__/__exit__ in its own __dict__."
    - "multiprocessing.queues.Queue, SimpleQueue, JoinableQueue do NOT define __enter__/__exit__ in their own __dict__."
    - "No multiprocessing class checked here defines __aenter__ or __aexit__ (async context manager protocol)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

table multiprocessing_extra2446.pool_sync_cm:
  description: "multiprocessing.pool.Pool __enter__/__exit__ dict-presence — Pool defines own context manager"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2446

  columns: [id, function, args, expected]
  rows:
    - ["mp2446001", "multiprocessing.pool.Pool.__dict__.__contains__", ["__enter__"], true]
    - ["mp2446002", "multiprocessing.pool.Pool.__dict__.__contains__", ["__exit__"], true]
    - ["mp2446003", "multiprocessing.pool.Pool.__dict__.__contains__", ["__aenter__"], false]
    - ["mp2446004", "multiprocessing.pool.Pool.__dict__.__contains__", ["__aexit__"], false]

table multiprocessing_extra2446.process_sync_cm:
  description: "multiprocessing.Process __enter__/__exit__ dict-presence — Process is not a context manager"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2446

  columns: [id, function, args, expected]
  rows:
    - ["mp2446005", "multiprocessing.Process.__dict__.__contains__", ["__enter__"], false]
    - ["mp2446006", "multiprocessing.Process.__dict__.__contains__", ["__exit__"], false]
    - ["mp2446007", "multiprocessing.Process.__dict__.__contains__", ["__aenter__"], false]
    - ["mp2446008", "multiprocessing.Process.__dict__.__contains__", ["__aexit__"], false]

table multiprocessing_extra2446.queues_sync_cm:
  description: "multiprocessing.queues.Queue/SimpleQueue/JoinableQueue __enter__/__exit__ — none are context managers"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2446

  columns: [id, function, args, expected]
  rows:
    - ["mp2446009", "multiprocessing.queues.Queue.__dict__.__contains__", ["__enter__"], false]
    - ["mp2446010", "multiprocessing.queues.Queue.__dict__.__contains__", ["__exit__"], false]
    - ["mp2446011", "multiprocessing.queues.SimpleQueue.__dict__.__contains__", ["__enter__"], false]
    - ["mp2446012", "multiprocessing.queues.SimpleQueue.__dict__.__contains__", ["__exit__"], false]
    - ["mp2446013", "multiprocessing.queues.JoinableQueue.__dict__.__contains__", ["__enter__"], false]
    - ["mp2446014", "multiprocessing.queues.JoinableQueue.__dict__.__contains__", ["__exit__"], false]

table multiprocessing_extra2446.managers_sync_cm:
  description: "multiprocessing.managers classes __enter__/__exit__ dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2446

  columns: [id, function, args, expected]
  rows:
    - ["mp2446015", "multiprocessing.managers.BaseManager.__dict__.__contains__", ["__enter__"], true]
    - ["mp2446016", "multiprocessing.managers.BaseManager.__dict__.__contains__", ["__exit__"], true]
    - ["mp2446017", "multiprocessing.managers.SyncManager.__dict__.__contains__", ["__enter__"], false]
    - ["mp2446018", "multiprocessing.managers.SyncManager.__dict__.__contains__", ["__exit__"], false]
    - ["mp2446019", "multiprocessing.managers.AcquirerProxy.__dict__.__contains__", ["__enter__"], true]
    - ["mp2446020", "multiprocessing.managers.AcquirerProxy.__dict__.__contains__", ["__exit__"], true]
