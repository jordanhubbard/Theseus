spec: base64_extra13
version: ">=3.9"
backend: python_module(base64)

docs: https://docs.python.org/3/library/base64.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/base64.html — Python base64 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/base64.py"
    - "base64_extra12.zspec.zsdl — covers b64encode/decode/urlsafe_b64encode/decode/b16encode/b32encode __name__/__module__; b64encode(b'') value/class/decode."
    - "base64_extra11.zspec.zsdl — covers urlsafe_b64encode/decode __name__/__module__; b32decode __name__/__module__; urlsafe/b16/b32 encode/decode vectors."
    - "base64_extra10.zspec.zsdl — covers b64decode.__name__/__module__; b64encode/decode abc/Man; urlsafe fbff; b32 foo/foobar; b16 DEADBEEF."
    - "base64_extra7.zspec.zsdl — covers b16/b32/b85 __name__ and __module__; b16encode null/ff; b64encode Man; urlsafe return class."
  notes:
    - "This spec extends base64 through base64_extra12; it does NOT duplicate invariants present in those files."
    - "Focus: b64encode(b'hello') value; b64decode(b'aGVsbG8=') value; b16encode(b'hi') value; b16decode(b'6869') value; urlsafe_b64encode(b'hello') class name."
    - "base64.b64encode(b'hello') == b'aGVsbG8=': standard Base64 encoding of ASCII 'hello'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "base64.b64decode(b'aGVsbG8=') == b'hello': round-trip decoding. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "base64.b16encode(b'hi') == b'6869': hex encoding of 0x68 ('h') and 0x69 ('i'). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "base64.b16decode(b'6869') == b'hi': round-trip hex decoding. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "base64.urlsafe_b64encode(b'hello').__class__.__name__ == 'bytes': urlsafe_b64encode returns bytes. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# b64encode(b'hello') — value (extra13 namespace)
#
# Standard Base64 encoding of b'hello' produces b'aGVsbG8='.
# 'h'=0x68, 'e'=0x65, 'l'=0x6c, 'l'=0x6c, 'o'=0x6f → aGVsbG8= with one pad byte.
# Verified: base64.b64encode(b'hello') == b'aGVsbG8='
# ---------------------------------------------------------------------------

invariant base64_extra13.b64encode.hello.value:
  description: "base64.b64encode(b'hello') == b'aGVsbG8=' — standard Base64 encoding of b'hello'"
  category: b64
  kind: python_call_eq
  function: b64encode
  args: [!ascii "hello"]
  expected: !b64 "aGVsbG8="

# ---------------------------------------------------------------------------
# b64decode(b'aGVsbG8=') — value (extra13 namespace)
#
# Decoding b'aGVsbG8=' yields b'hello'. Round-trip from above.
# ---------------------------------------------------------------------------

invariant base64_extra13.b64decode.hello.value:
  description: "base64.b64decode(b'aGVsbG8=') == b'hello' — Base64 decode of 'hello' encoding"
  category: b64
  kind: python_call_eq
  function: b64decode
  args: [!b64 "aGVsbG8="]
  expected: !ascii "hello"

# ---------------------------------------------------------------------------
# b16encode(b'hi') — value (extra13 namespace)
#
# 'h' == 0x68, 'i' == 0x69 → uppercase hex b'6869'.
# Verified: base64.b16encode(b'hi') == b'6869'
# ---------------------------------------------------------------------------

invariant base64_extra13.b16encode.hi.value:
  description: "base64.b16encode(b'hi') == b'6869' — hex encoding of b'hi'"
  category: b16
  kind: python_call_eq
  function: b16encode
  args: [!ascii "hi"]
  expected: !ascii "6869"

# ---------------------------------------------------------------------------
# b16decode(b'6869') — value (extra13 namespace)
#
# Decoding the hex string b'6869' yields b'hi'. Round-trip from above.
# ---------------------------------------------------------------------------

invariant base64_extra13.b16decode.hi.value:
  description: "base64.b16decode(b'6869') == b'hi' — hex decode of b'6869'"
  category: b16
  kind: python_call_eq
  function: b16decode
  args: [!ascii "6869"]
  expected: !ascii "hi"

# ---------------------------------------------------------------------------
# urlsafe_b64encode(b'hello') — return type (extra13 namespace)
#
# urlsafe_b64encode always returns bytes. base64_extra7 covers the return
# class via a different input; this invariant anchors b'hello' from extra13.
# ---------------------------------------------------------------------------

invariant base64_extra13.urlsafe_b64encode.hello.class_name:
  description: "base64.urlsafe_b64encode(b'hello').__class__.__name__ == 'bytes' — return type is bytes"
  category: types
  kind: python_call_eq
  function: urlsafe_b64encode
  args: [!ascii "hello"]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true
