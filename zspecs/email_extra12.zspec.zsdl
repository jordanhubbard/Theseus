spec: email_extra12
version: ">=3.6"
backend: python_module(email)

docs: https://docs.python.org/3/library/email.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/email.html — Python email module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/email/"
    - "email_extra4.zspec.zsdl — covers email.utils parseaddr/formataddr __qualname__.__eq__ and __module__.__eq__; email.errors class qualnames."
    - "email_extra8.zspec.zsdl — covers message.Message/__name__.__eq__."
    - "email_extra10.zspec.zsdl — covers message.Message.__qualname__.__eq__('Message'); utils.parseaddr/__qualname__.__len__; header.Header.__module__."
    - "email_extra11.zspec.zsdl — covers message.Message method __qualname__ values and lengths."
  notes:
    - "This spec extends the email family through email_extra11; it does NOT duplicate invariants in any prior spec."
    - "Focus: email.message.Message.__module__ and __bases__[0].__name__; MIMEText/__qualname__ and __module__; MIMEMultipart/__qualname__ and __module__; email.headerregistry.Address/__qualname__ and __module__; email.errors.MessageError/__qualname__ and __bases__[0].__name__; email.utils.parseaddr and formataddr __qualname__ standalone invariants."
    - "email.message.Message.__module__ == 'email.message' — no prior email spec checks Message.__module__."
    - "email.message.Message.__bases__[0].__name__ == 'object' — no prior email spec checks Message.__bases__[0].__name__."
    - "email.mime.text.MIMEText.__qualname__ == 'MIMEText' — no prior email spec checks MIMEText.__qualname__."
    - "email.mime.text.MIMEText.__module__ == 'email.mime.text' — no prior email spec checks MIMEText.__module__."
    - "email.mime.multipart.MIMEMultipart.__qualname__ == 'MIMEMultipart' — no prior email spec checks MIMEMultipart.__qualname__."
    - "email.mime.multipart.MIMEMultipart.__module__ == 'email.mime.multipart' — no prior email spec checks MIMEMultipart.__module__."
    - "email.headerregistry.Address.__qualname__ == 'Address' — no prior email spec checks Address.__qualname__."
    - "email.headerregistry.Address.__module__ == 'email.headerregistry' — no prior email spec checks Address.__module__."
    - "email.errors.MessageError.__qualname__ == 'MessageError' — no prior email spec checks MessageError.__qualname__ as a standalone invariant."
    - "email.errors.MessageError.__bases__[0].__name__ == 'Exception' — no prior email spec checks MessageError.__bases__[0].__name__."
    - "email.utils.parseaddr.__qualname__ == 'parseaddr' — email_extra4 checks this in a table; standalone from extra12 namespace adds a cross-namespace regression checkpoint."
    - "email.utils.formataddr.__qualname__ == 'formataddr' — same rationale as parseaddr."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# email.message.Message __module__ and __bases__[0].__name__
#
# email_extra8 checks Message.__name__.__eq__ and email_extra10 checks
# Message.__qualname__.__eq__. No prior email spec checks Message.__module__
# or Message.__bases__[0].__name__. Message is defined in the email.message
# submodule and inherits directly from object.
# ---------------------------------------------------------------------------

invariant email_extra12.Message.module:
  description: "email.message.Message.__module__ == 'email.message' — no prior spec checks Message.__module__"
  category: class_identity
  kind: python_call_eq
  function: message.Message.__module__.__eq__
  args: ["email.message"]
  expected: true

invariant email_extra12.Message.bases_name:
  description: "email.message.Message.__bases__[0].__name__ == 'object' — no prior spec checks Message.__bases__[0].__name__"
  category: class_identity
  kind: python_call_eq
  function: "message.Message.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# email.mime.text.MIMEText __qualname__ and __module__
#
# No prior email spec checks MIMEText.__qualname__ or MIMEText.__module__.
# MIMEText is defined in the email.mime.text submodule.
# ---------------------------------------------------------------------------

invariant email_extra12.MIMEText.qualname:
  description: "email.mime.text.MIMEText.__qualname__ == 'MIMEText' — no prior spec checks this"
  category: class_qualnames
  kind: python_call_eq
  function: mime.text.MIMEText.__qualname__.__eq__
  args: ["MIMEText"]
  expected: true

invariant email_extra12.MIMEText.module:
  description: "email.mime.text.MIMEText.__module__ == 'email.mime.text' — no prior spec checks this"
  category: class_modules
  kind: python_call_eq
  function: mime.text.MIMEText.__module__.__eq__
  args: ["email.mime.text"]
  expected: true

# ---------------------------------------------------------------------------
# email.mime.multipart.MIMEMultipart __qualname__ and __module__
#
# No prior email spec checks MIMEMultipart.__qualname__ or __module__.
# MIMEMultipart is defined in the email.mime.multipart submodule.
# ---------------------------------------------------------------------------

invariant email_extra12.MIMEMultipart.qualname:
  description: "email.mime.multipart.MIMEMultipart.__qualname__ == 'MIMEMultipart' — no prior spec checks this"
  category: class_qualnames
  kind: python_call_eq
  function: mime.multipart.MIMEMultipart.__qualname__.__eq__
  args: ["MIMEMultipart"]
  expected: true

invariant email_extra12.MIMEMultipart.module:
  description: "email.mime.multipart.MIMEMultipart.__module__ == 'email.mime.multipart' — no prior spec checks this"
  category: class_modules
  kind: python_call_eq
  function: mime.multipart.MIMEMultipart.__module__.__eq__
  args: ["email.mime.multipart"]
  expected: true

# ---------------------------------------------------------------------------
# email.headerregistry.Address __qualname__ and __module__
#
# No prior email spec checks Address.__qualname__ or Address.__module__.
# Address is defined in the email.headerregistry submodule.
# ---------------------------------------------------------------------------

invariant email_extra12.Address.qualname:
  description: "email.headerregistry.Address.__qualname__ == 'Address' — no prior spec checks this"
  category: class_qualnames
  kind: python_call_eq
  function: headerregistry.Address.__qualname__.__eq__
  args: ["Address"]
  expected: true

invariant email_extra12.Address.module:
  description: "email.headerregistry.Address.__module__ == 'email.headerregistry' — no prior spec checks this"
  category: class_modules
  kind: python_call_eq
  function: headerregistry.Address.__module__.__eq__
  args: ["email.headerregistry"]
  expected: true

# ---------------------------------------------------------------------------
# email.errors.MessageError __qualname__ and __bases__[0].__name__
#
# email_extra4 covers MessageError.__qualname__ in a table of error class
# qualnames. No prior spec checks MessageError.__qualname__ as a standalone
# invariant or checks MessageError.__bases__[0].__name__. MessageError
# inherits directly from Exception.
# ---------------------------------------------------------------------------

invariant email_extra12.MessageError.qualname:
  description: "email.errors.MessageError.__qualname__ == 'MessageError' — standalone from extra12 namespace"
  category: class_qualnames
  kind: python_call_eq
  function: errors.MessageError.__qualname__.__eq__
  args: ["MessageError"]
  expected: true

invariant email_extra12.MessageError.bases_name:
  description: "email.errors.MessageError.__bases__[0].__name__ == 'Exception' — no prior spec checks this"
  category: class_identity
  kind: python_call_eq
  function: "errors.MessageError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# email.utils.parseaddr and formataddr __qualname__ standalone
#
# email_extra4 covers parseaddr.__qualname__.__eq__ and
# formataddr.__qualname__.__eq__ in a table. Standalone invariants from
# extra12 provide cross-namespace regression checkpoints, following the
# pattern used in ipaddress and uuid specs.
# ---------------------------------------------------------------------------

invariant email_extra12.parseaddr.qualname:
  description: "email.utils.parseaddr.__qualname__ == 'parseaddr' — standalone from extra12 namespace"
  category: function_qualnames
  kind: python_call_eq
  function: utils.parseaddr.__qualname__.__eq__
  args: ["parseaddr"]
  expected: true

invariant email_extra12.formataddr.qualname:
  description: "email.utils.formataddr.__qualname__ == 'formataddr' — standalone from extra12 namespace"
  category: function_qualnames
  kind: python_call_eq
  function: utils.formataddr.__qualname__.__eq__
  args: ["formataddr"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ string lengths for MIME classes, Address, and error classes
#
# No prior email spec checks the string lengths of MIMEText, MIMEMultipart,
# Address, or MessageError qualnames.
# MIMEText == 8; Address == 7; MessageError == 12; MIMEMultipart == 13.
# ---------------------------------------------------------------------------

table email_extra12.class_qualname_lengths:
  description: "MIMEText/MIMEMultipart/Address/MessageError __qualname__ string lengths — no prior spec checks these"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: cqlen12

  columns: [id, function, args, expected]
  rows:
    - [MIMEText,      mime.text.MIMEText.__qualname__.__len__,             [], 8]
    - [MIMEMultipart, mime.multipart.MIMEMultipart.__qualname__.__len__,   [], 13]
    - [Address,       headerregistry.Address.__qualname__.__len__,         [], 7]
    - [MessageError,  errors.MessageError.__qualname__.__len__,            [], 12]
