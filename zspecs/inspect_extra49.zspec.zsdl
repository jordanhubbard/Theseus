spec: inspect_extra49
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra48.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/iscode/isframe/istraceback __name__/__qualname__.__len__(); iscoroutinefunction/isgeneratorfunction/isasyncgenfunction __name__/__qualname__.__len__(); getmembers/getfile/getsource/getmodule/signature/stack/currentframe/getfullargspec __qualname__.__len__(); Parameter/__mro__.__len__()==2; Signature/__mro__.__len__()==2; BoundArguments/__mro__.__len__()==2; FullArgSpec/__mro__.__len__()==3; FrameInfo/__mro__.__len__()==4; Parameter.empty/kind constants; inspect.__all__.__len__()==107; CO_OPTIMIZED==1; cleandoc/formatannotation/getattr_static/classify_class_attrs __name__ lengths; Signature/Parameter/BoundArguments method qualnames; getmembers/__module__.__len__(7); parameter kind integer values; Parameter/__name__/__module__/__qualname__; Signature/__name__/__module__/__qualname__; BoundArguments/__name__/__qualname__/__module__; FullArgSpec/__name__/__qualname__/__module__; FrameInfo/__name__/__qualname__; class __bases__[0].__name__ for Parameter/Signature/BoundArguments; FullArgSpec/__bases__[0].__name__=='tuple'; FrameInfo/__bases__[0].__name__=='_FrameInfo'; all __bases__[0].__qualname__ for Parameter/Signature/BoundArguments/FullArgSpec/FrameInfo; getouterframes/__name__/__module__; getinnerframes/__name__/__module__; formatargvalues/__name__/__module__; walktree/__name__/__module__; classify_class_attrs/__name__/__module__; getattr_static/__name__/__module__; isfunction/__class__.__name__=='function'; isbuiltin/__class__.__name__=='function'; isclass/__class__.__name__=='function'; ismodule/__class__.__name__=='function'; signature/__class__.__name__=='function'; getdoc/__class__.__name__=='function'; getsource/__class__.__name__=='function'; Parameter/__class__.__name__=='type'; Signature/__class__.__name__=='type'; isfunction/__class__.__qualname__=='function'; isbuiltin/__class__.__qualname__=='function'; isclass/__class__.__qualname__=='function'; ismodule/__class__.__qualname__=='function'; signature/__class__.__qualname__=='function'; Parameter/__class__.__qualname__=='type'; Signature/__class__.__qualname__=='type'; BoundArguments/__class__.__qualname__=='type'; FullArgSpec/__class__.__qualname__=='type'."
    - "This spec covers: inspect.CO_OPTIMIZED/__class__.__name__=='int'; inspect.CO_NEWLOCALS/__class__.__name__=='int'; inspect.CO_VARARGS/__class__.__name__=='int'; inspect.CO_VARKEYWORDS/__class__.__name__=='int'; inspect.CO_NESTED/__class__.__name__=='int'; inspect.CO_GENERATOR/__class__.__name__=='int'; inspect.CO_NOFREE/__class__.__name__=='int'; inspect.Parameter.POSITIONAL_OR_KEYWORD/__class__.__name__=='_ParameterKind'; inspect.Parameter.VAR_POSITIONAL/__class__.__name__=='_ParameterKind'; inspect.Parameter.KEYWORD_ONLY/__class__.__name__=='_ParameterKind'; inspect.Parameter.VAR_KEYWORD/__class__.__name__=='_ParameterKind'; inspect.Parameter.POSITIONAL_ONLY/__class__.__name__=='_ParameterKind'."
    - "Key findings: inspect.CO_* constants are plain Python int objects — they are bitfield constants re-exported from the code object's co_flags bitmask. Their __class__.__name__ is 'int' in all CPython versions. The inspect.Parameter kind constants (POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD, POSITIONAL_ONLY) are instances of the _ParameterKind enum class defined privately in Lib/inspect.py. Their __class__.__name__ is '_ParameterKind' (not 'ParameterKind' — the leading underscore is part of the name). This is a subtle distinction: the public-facing name used in documentation is 'ParameterKind', but the actual class __name__ is '_ParameterKind' with an underscore prefix. No prior spec recorded __class__.__name__ for any CO_* constant or for any Parameter kind constant. All twelve invariants are new to extra49."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect CO_* code flag constants __class__.__name__ — extra49 namespace
#
# inspect.CO_OPTIMIZED, CO_NEWLOCALS, CO_VARARGS, CO_VARKEYWORDS, CO_NESTED,
# CO_GENERATOR, and CO_NOFREE are integer bitmask constants re-exported by the
# inspect module. Each constant is a plain int object. Therefore all seven have
# __class__.__name__ == 'int' (3 chars). Prior spec extra47 recorded CO_OPTIMIZED
# == 1 (integer value equality), but no prior spec recorded __class__.__name__
# for any CO_* constant. All seven are new to extra49.
# ---------------------------------------------------------------------------

table inspect_extra49.co_flag_constants_class_names:
  description: "inspect CO_* flag constants __class__.__name__ == 'int' — bitmask integer constants re-exported from code object co_flags; CO_OPTIMIZED==1, CO_NEWLOCALS==2, CO_VARARGS==4, CO_VARKEYWORDS==8, CO_NESTED==16, CO_GENERATOR==32, CO_NOFREE==64; __class__.__name__ == 'int' (3 chars)"
  kind: python_call_eq
  category: identity
  id_prefix: inspconst49

  columns: [id, function, args, expected, description]
  rows:
    - [CO_OPTIMIZED_class_name,
       CO_OPTIMIZED.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.CO_OPTIMIZED.__class__.__name__ == 'int' — integer bitmask constant (value 1 == 0x01); set when a function uses fast locals instead of a dictionary; re-exported from code object co_flags bitmask; __class__.__name__ == 'int' (3 chars)"]
    - [CO_NEWLOCALS_class_name,
       CO_NEWLOCALS.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.CO_NEWLOCALS.__class__.__name__ == 'int' — integer bitmask constant (value 2 == 0x02); set when a new dict is created for the locals namespace; re-exported from code object co_flags bitmask; __class__.__name__ == 'int' (3 chars)"]
    - [CO_VARARGS_class_name,
       CO_VARARGS.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.CO_VARARGS.__class__.__name__ == 'int' — integer bitmask constant (value 4 == 0x04); set when the function accepts a *args variable-length positional argument tuple; re-exported from code object co_flags bitmask; __class__.__name__ == 'int' (3 chars)"]
    - [CO_VARKEYWORDS_class_name,
       CO_VARKEYWORDS.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.CO_VARKEYWORDS.__class__.__name__ == 'int' — integer bitmask constant (value 8 == 0x08); set when the function accepts a **kwargs variable-length keyword argument dict; re-exported from code object co_flags bitmask; __class__.__name__ == 'int' (3 chars)"]
    - [CO_NESTED_class_name,
       CO_NESTED.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.CO_NESTED.__class__.__name__ == 'int' — integer bitmask constant (value 16 == 0x10); set when the code object is a nested function (defined inside another function); re-exported from code object co_flags bitmask; __class__.__name__ == 'int' (3 chars)"]
    - [CO_GENERATOR_class_name,
       CO_GENERATOR.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.CO_GENERATOR.__class__.__name__ == 'int' — integer bitmask constant (value 32 == 0x20); set when the function is a generator (contains a yield statement); re-exported from code object co_flags bitmask; __class__.__name__ == 'int' (3 chars)"]
    - [CO_NOFREE_class_name,
       CO_NOFREE.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.CO_NOFREE.__class__.__name__ == 'int' — integer bitmask constant (value 64 == 0x40); set when the function has no free variables (not a closure); re-exported from code object co_flags bitmask; __class__.__name__ == 'int' (3 chars)"]

# ---------------------------------------------------------------------------
# inspect.Parameter kind constants __class__.__name__ — extra49 namespace
#
# inspect.Parameter.POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY,
# VAR_KEYWORD, and POSITIONAL_ONLY are enum members of the _ParameterKind
# enum class defined privately in Lib/inspect.py. Their __class__.__name__
# is '_ParameterKind' — note the leading underscore. The public documentation
# refers to the enum as 'ParameterKind', but the internal class name as used
# in __class__.__name__ is '_ParameterKind' (14 chars with the underscore).
# Prior spec extra47 recorded the integer values of these constants; no prior
# spec recorded their __class__.__name__. All five are new to extra49.
# ---------------------------------------------------------------------------

table inspect_extra49.parameter_kind_constants_class_names:
  description: "inspect.Parameter kind constants __class__.__name__ == '_ParameterKind' — enum members of the privately-named _ParameterKind enum in Lib/inspect.py; note leading underscore in class name; 14-char class name"
  kind: python_call_eq
  category: identity
  id_prefix: inspconst49

  columns: [id, function, args, expected, description]
  rows:
    - [POSITIONAL_OR_KEYWORD_class_name,
       Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind' — enum member (integer value 1) of the _ParameterKind enum in Lib/inspect.py; represents a parameter that can be passed positionally or as a keyword argument; __class__.__name__ == '_ParameterKind' (14 chars including leading underscore)"]
    - [VAR_POSITIONAL_class_name,
       Parameter.VAR_POSITIONAL.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind' — enum member (integer value 2) of the _ParameterKind enum in Lib/inspect.py; represents a *args variable-length positional parameter; __class__.__name__ == '_ParameterKind' (14 chars)"]
    - [KEYWORD_ONLY_class_name,
       Parameter.KEYWORD_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind' — enum member (integer value 3) of the _ParameterKind enum in Lib/inspect.py; represents a parameter that must be passed as a keyword argument (appears after *args or bare *); __class__.__name__ == '_ParameterKind' (14 chars)"]
    - [VAR_KEYWORD_class_name,
       Parameter.VAR_KEYWORD.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind' — enum member (integer value 4) of the _ParameterKind enum in Lib/inspect.py; represents a **kwargs variable-length keyword parameter; __class__.__name__ == '_ParameterKind' (14 chars)"]
    - [POSITIONAL_ONLY_class_name,
       Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — enum member (integer value 0) of the _ParameterKind enum in Lib/inspect.py; represents a parameter that can only be passed positionally (appears before a / separator in the signature); __class__.__name__ == '_ParameterKind' (14 chars)"]
