    - ["as2311005", "asyncio.Protocol.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["as2311006", "asyncio.DatagramProtocol.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["as2311007", "asyncio.SubprocessProtocol.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["as2311008", "asyncio.BufferedProtocol.__dict__.__contains__", ["__abstractmethods__"], false]

