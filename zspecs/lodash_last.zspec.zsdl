spec: lodash_last
version: ">=4.0.0"
backend: node(lodash.last)

docs: https://lodash.com/docs/#last

provenance:
  derived_from:
    - "lodash.last README — https://www.npmjs.com/package/lodash.last"
    - "Test vectors verified with lodash.last@4.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.last exports the _.last function directly as module.exports."
    - "last(array) returns the last element of array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the last element. Returns undefined for empty array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_last.last:
  kind: node_module_call_eq
  function: ~
  category: last
  id_prefix: llast

  columns: [id, args, expected]
  rows:
    - [three_ints,  [[1, 2, 3]],     3]
    - [single,      [[42]],          42]
    - [strings,     [["a", "b"]],    "b"]
