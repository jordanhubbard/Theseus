spec: pathlib_extra112
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra111.zspec.zsdl."
    - "This spec covers: pathlib.PurePath, PurePosixPath, PureWindowsPath, Path, and PosixPath class identity."
    - "pathlib.PurePath.__name__ == 'PurePath', __module__ == 'pathlib', __bases__[0].__name__ == 'object', __mro__.__len__() == 2."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath', __bases__[0].__name__ == 'PurePath', __mro__.__len__() == 3."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath', __bases__[0].__name__ == 'PurePath', __mro__.__len__() == 3."
    - "pathlib.Path.__name__ == 'Path', __bases__[0].__name__ == 'PurePath', __mro__.__len__() == 3."
    - "pathlib.PosixPath.__name__ == 'PosixPath', __bases__[0].__name__ == 'Path', __mro__.__len__() == 5 (PosixPath, Path, PurePosixPath, PurePath, object)."
    - "len('PurePath') == 8; len('PurePosixPath') == 13; len('PureWindowsPath') == 15; len('Path') == 4; len('PosixPath') == 9."
    - "PurePath.__qualname__ == PurePath.__name__ == 'PurePath' (top-level class, qualname equals name)."
    - "PurePosixPath.__qualname__ == 'PurePosixPath'; PureWindowsPath.__qualname__ == 'PureWindowsPath'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath class identity: __name__, __module__, __qualname__
# PurePath is the abstract base for all pathlib path types.
# It inherits directly from object, giving __mro__.__len__() == 2.
# __qualname__ equals __name__ for top-level classes.
# ---------------------------------------------------------------------------

table pathlib_extra112.PurePath_identity:
  description: "pathlib.PurePath class identity: __name__='PurePath', __module__='pathlib', __qualname__='PurePath', __bases__[0].__name__='object', __mro__ len=2"
  kind: python_call_eq
  category: class_names
  id_prefix: pathlibid112a

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_name_eq,   PurePath.__name__.__eq__,          ["PurePath"],  true,  "pathlib.PurePath.__name__ == 'PurePath'"]
    - [purepath_module_eq, PurePath.__module__.__eq__,         ["pathlib"],   true,  "pathlib.PurePath.__module__ == 'pathlib'"]
    - [purepath_qn_eq,     PurePath.__qualname__.__eq__,       ["PurePath"],  true,  "pathlib.PurePath.__qualname__ == 'PurePath' (qualname equals name for top-level class)"]
    - [purepath_base_eq,   "PurePath.__bases__[0].__name__.__eq__", ["object"], true, "pathlib.PurePath.__bases__[0].__name__ == 'object' (PurePath inherits directly from object)"]
    - [purepath_mro_len,   "PurePath.__mro__.__len__",         [],            2,     "pathlib.PurePath.__mro__.__len__() == 2 (PurePath, object)"]
    - [purepath_name_len,  PurePath.__name__.__len__,          [],            8,     "pathlib.PurePath.__name__.__len__() == 8 ('PurePath' has 8 characters)"]
    - [purepath_not_path,  PurePath.__name__.__eq__,           ["Path"],      false, "pathlib.PurePath.__name__ != 'Path' (PurePath and Path are distinct classes)"]

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath and pathlib.PureWindowsPath class identity
# Both inherit from PurePath, giving __mro__.__len__() == 3.
# PureWindowsPath.__name__ is 15 chars; PurePosixPath.__name__ is 13 chars.
# ---------------------------------------------------------------------------

table pathlib_extra112.PurePosixPath_PureWindowsPath_identity:
  description: "pathlib.PurePosixPath and PureWindowsPath class identity: bases[0]=PurePath, mro len=3, name lens: PurePosixPath=13, PureWindowsPath=15"
  kind: python_call_eq
  category: class_names
  id_prefix: pathlibid112b

  columns: [id, function, args, expected, description]
  rows:
    - [pposix_name_eq,    PurePosixPath.__name__.__eq__,           ["PurePosixPath"],   true,  "pathlib.PurePosixPath.__name__ == 'PurePosixPath'"]
    - [pposix_module_eq,  PurePosixPath.__module__.__eq__,          ["pathlib"],         true,  "pathlib.PurePosixPath.__module__ == 'pathlib'"]
    - [pposix_base_eq,    "PurePosixPath.__bases__[0].__name__.__eq__", ["PurePath"],    true,  "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath'"]
    - [pposix_mro_len,    "PurePosixPath.__mro__.__len__",          [],                 3,     "pathlib.PurePosixPath.__mro__.__len__() == 3 (PurePosixPath, PurePath, object)"]
    - [pposix_name_len,   PurePosixPath.__name__.__len__,           [],                 13,    "pathlib.PurePosixPath.__name__.__len__() == 13 ('PurePosixPath' has 13 characters)"]
    - [pwin_name_eq,      PureWindowsPath.__name__.__eq__,          ["PureWindowsPath"], true,  "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath'"]
    - [pwin_module_eq,    PureWindowsPath.__module__.__eq__,         ["pathlib"],         true,  "pathlib.PureWindowsPath.__module__ == 'pathlib'"]
    - [pwin_base_eq,      "PureWindowsPath.__bases__[0].__name__.__eq__", ["PurePath"],  true,  "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath'"]
    - [pwin_mro_len,      "PureWindowsPath.__mro__.__len__",         [],                 3,     "pathlib.PureWindowsPath.__mro__.__len__() == 3 (PureWindowsPath, PurePath, object)"]
    - [pwin_name_len,     PureWindowsPath.__name__.__len__,          [],                 15,    "pathlib.PureWindowsPath.__name__.__len__() == 15 ('PureWindowsPath' has 15 characters; longest among Pure* classes)"]

# ---------------------------------------------------------------------------
# pathlib.Path and pathlib.PosixPath class identity
# Path.__bases__[0].__name__ == 'PurePath'; Path.__mro__.__len__() == 3.
# PosixPath.__bases__[0].__name__ == 'Path'; PosixPath.__mro__.__len__() == 5
# (PosixPath, Path, PurePosixPath, PurePath, object).
# len('Path') == 4; len('PosixPath') == 9.
# ---------------------------------------------------------------------------

table pathlib_extra112.Path_PosixPath_identity:
  description: "pathlib.Path and PosixPath class identity: Path bases=PurePath(mro=3), PosixPath bases=Path(mro=5), name lens: Path=4, PosixPath=9"
  kind: python_call_eq
  category: class_names
  id_prefix: pathlibid112c

  columns: [id, function, args, expected, description]
  rows:
    - [path_name_eq,      Path.__name__.__eq__,                   ["Path"],      true,  "pathlib.Path.__name__ == 'Path'"]
    - [path_module_eq,    Path.__module__.__eq__,                  ["pathlib"],   true,  "pathlib.Path.__module__ == 'pathlib'"]
    - [path_base_eq,      "Path.__bases__[0].__name__.__eq__",     ["PurePath"],  true,  "pathlib.Path.__bases__[0].__name__ == 'PurePath' (Path directly inherits from PurePath)"]
    - [path_mro_len,      "Path.__mro__.__len__",                  [],            3,     "pathlib.Path.__mro__.__len__() == 3 (Path, PurePath, object)"]
    - [path_name_len,     Path.__name__.__len__,                   [],            4,     "pathlib.Path.__name__.__len__() == 4 ('Path' has 4 characters; shortest name among pathlib path classes)"]
    - [posix_name_eq,     PosixPath.__name__.__eq__,               ["PosixPath"], true,  "pathlib.PosixPath.__name__ == 'PosixPath'"]
    - [posix_module_eq,   PosixPath.__module__.__eq__,              ["pathlib"],   true,  "pathlib.PosixPath.__module__ == 'pathlib'"]
    - [posix_base_eq,     "PosixPath.__bases__[0].__name__.__eq__", ["Path"],      true,  "pathlib.PosixPath.__bases__[0].__name__ == 'Path'"]
    - [posix_mro_len,     "PosixPath.__mro__.__len__",              [],            5,     "pathlib.PosixPath.__mro__.__len__() == 5 (PosixPath, Path, PurePosixPath, PurePath, object)"]
    - [posix_name_len,    PosixPath.__name__.__len__,               [],            9,     "pathlib.PosixPath.__name__.__len__() == 9 ('PosixPath' has 9 characters)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra112.PurePath.bases_is_object:
  description: "pathlib.PurePath.__bases__[0].__name__ == 'object' (PurePath is the root of the pathlib class hierarchy; it inherits directly from object, so its MRO has only 2 entries: PurePath and object)"
  category: class_names
  kind: python_call_eq
  function: "PurePath.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant pathlib_extra112.PurePath.mro_len_2:
  description: "pathlib.PurePath.__mro__.__len__() == 2 (PurePath is at the root of the pathlib hierarchy; its MRO is (PurePath, object) with length 2, unlike PurePosixPath/PureWindowsPath/Path which have MRO length 3)"
  category: class_names
  kind: python_call_eq
  function: "PurePath.__mro__.__len__"
  args: []
  expected: 2

invariant pathlib_extra112.PureWindowsPath.name_len_15:
  description: "pathlib.PureWindowsPath.__name__.__len__() == 15 ('PureWindowsPath' is the longest __name__ among the pathlib Pure* classes; PurePath=8, PurePosixPath=13, PureWindowsPath=15)"
  category: class_names
  kind: python_call_eq
  function: PureWindowsPath.__name__.__len__
  args: []
  expected: 15

invariant pathlib_extra112.PosixPath.mro_len_5:
  description: "pathlib.PosixPath.__mro__.__len__() == 5 (PosixPath's MRO is (PosixPath, Path, PurePosixPath, PurePath, object); it inherits from both the concrete Path and the pure PurePosixPath, giving a 5-entry MRO)"
  category: class_names
  kind: python_call_eq
  function: "PosixPath.__mro__.__len__"
  args: []
  expected: 5

invariant pathlib_extra112.Path.bases_is_PurePath:
  description: "pathlib.Path.__bases__[0].__name__ == 'PurePath' (Path is the concrete OS-specific path class; it directly subclasses PurePath, giving an MRO of (Path, PurePath, object) with length 3)"
  category: class_names
  kind: python_call_eq
  function: "Path.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true
