spec: abc_extra1291
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "abc standard library documentation — https://docs.python.org/3/library/abc.html"
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "Test vectors verified with Python 3.13 on macOS Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any third-party abstract base class library"
  notes:
    - "Wave 533 (_extra1291): focus on __init__ and __new__ method presence and qualname checks."
    - "ABCMeta defines __new__ directly in its own __dict__; __new__.__qualname__ is 'ABCMeta.__new__'."
    - "ABCMeta does NOT define __init__ in its own __dict__; it inherits type.__init__."
    - "ABCMeta.__init__.__qualname__ is 'type.__init__' — inherited from type, not overridden."
    - "ABC does NOT define __init__ or __new__ in its own __dict__; it inherits from object."
    - "ABC.__init__.__qualname__ is 'object.__init__' and ABC.__new__.__qualname__ is 'object.__new__'."
    - "abstractmethod does NOT define __init__ in its own __dict__; inherits object.__init__."
    - "abstractmethod.__init__.__qualname__ is 'object.__init__'."
    - "ABCMeta.__new__ is a Python-level function; __class__.__name__ is 'function'."
    - "All expected values verified by running Python 3.13 on macOS Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra1291.init_qualnames:
  description: "abc class __init__ and __new__ qualname identity"
  kind: python_call_eq
  category: init_qualname
  id_prefix: ab1291
  columns: [id, function, args, expected]
  rows:
    - ["ab1291qi001", "abc.ABCMeta.__new__.__qualname__.__eq__", ["ABCMeta.__new__"], true]
    - ["ab1291qi002", "abc.ABCMeta.__init__.__qualname__.__eq__", ["type.__init__"], true]
    - ["ab1291qi003", "abc.ABC.__init__.__qualname__.__eq__", ["object.__init__"], true]
    - ["ab1291qi004", "abc.ABC.__new__.__qualname__.__eq__", ["object.__new__"], true]
    - ["ab1291qi005", "abc.abstractmethod.__init__.__qualname__.__eq__", ["object.__init__"], true]
    - ["ab1291qi006", "abc.ABCMeta.__new__.__class__.__name__.__eq__", ["function"], true]

table abc_extra1291.dict_contains_init_and_new:
  description: "abc class __dict__ membership for __init__ and __new__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ab1291
  columns: [id, function, args, expected]
  rows:
    - ["ab1291dc001", "abc.ABCMeta.__dict__.__contains__", ["__new__"], true]
    - ["ab1291dc002", "abc.ABCMeta.__dict__.__contains__", ["__init__"], false]
    - ["ab1291dc003", "abc.ABC.__dict__.__contains__", ["__init__"], false]
    - ["ab1291dc004", "abc.ABC.__dict__.__contains__", ["__new__"], false]
    - ["ab1291dc005", "abc.abstractmethod.__dict__.__contains__", ["__init__"], false]
    - ["ab1291dc006", "abc.ABCMeta.__dict__.__contains__", ["__instancecheck__"], true]
    - ["ab1291dc007", "abc.ABCMeta.__dict__.__contains__", ["__subclasscheck__"], true]
    - ["ab1291dc008", "abc.ABCMeta.__dict__.__contains__", ["register"], true]

table abc_extra1291.init_class_names:
  description: "abc __init__ and __new__ method type via __class__.__name__"
  kind: python_call_eq
  category: init_class
  id_prefix: ab1291
  columns: [id, function, args, expected]
  rows:
    - ["ab1291ic001", "abc.ABCMeta.__new__.__class__.__name__.__eq__", ["function"], true]
    - ["ab1291ic002", "abc.ABCMeta.__init__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["ab1291ic003", "abc.abstractmethod.__init__.__class__.__name__.__eq__", ["method-wrapper"], true]
    - ["ab1291ic004", "abc.ABCMeta.__dict__.__contains__", ["__new__"], true]
    - ["ab1291ic005", "abc.ABCMeta.__dict__.__contains__", ["__init__"], false]
    - ["ab1291ic006", "abc.ABC.__dict__.__contains__", ["__init__"], false]
    - ["ab1291ic007", "abc.abstractmethod.__dict__.__contains__", ["__init__"], false]
    - ["ab1291ic008", "abc.abstractmethod.__qualname__.__eq__", ["abstractmethod"], true]
