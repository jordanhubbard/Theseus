spec: itertools_extra228
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools behavioral output contracts: chain/zip_longest/takewhile/dropwhile output contracts verified via __next__, __class__.__name__, and qualname checks."
    - "itertools.chain([1,2],[3,4]).__next__() == 1 — chain yields first element of first iterable. Verified with Python 3.14.3."
    - "itertools.zip_longest([1,2],[3]).__next__() == (1,3) — zip_longest first pair is (1,3). Verified with Python 3.14.3."
    - "itertools.takewhile(lambda x: x<3, [1,2,3,4]).__next__() == 1 — takewhile yields first passing element. Verified with Python 3.14.3."
    - "itertools.dropwhile(lambda x: x<3, [1,2,3,4]).__next__() == 3 — dropwhile skips 1,2 and yields 3. Verified with Python 3.14.3."
    - "itertools.chain.__class__.__name__ == 'type' — chain is a C extension type. Verified with Python 3.14.3."
    - "itertools.zip_longest.__class__.__name__ == 'type' — zip_longest is a C extension type. Verified with Python 3.14.3."
    - "itertools.takewhile.__class__.__name__ == 'type' — takewhile is a C extension type. Verified with Python 3.14.3."
    - "itertools.dropwhile.__class__.__name__ == 'type' — dropwhile is a C extension type. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools chain/zip_longest/takewhile/dropwhile type class names
#
# itertools.chain.__class__.__name__ == 'type'
# itertools.zip_longest.__class__.__name__ == 'type'
# itertools.takewhile.__class__.__name__ == 'type'
# itertools.dropwhile.__class__.__name__ == 'type'
# itertools.starmap.__class__.__name__ == 'type'
#
# All are C extension types. New to extra228.
# ---------------------------------------------------------------------------

table itertools_extra228.type_class_names:
  description: "itertools chain/zip_longest/takewhile/dropwhile/starmap are C types; __class__.__name__=='type'; new to extra228"
  kind: python_call_eq
  category: behavioral
  id_prefix: itertoolsextra228typeclass

  columns: [id, function, args, expected, description]
  rows:
    - [chain_class_is_type,
       chain.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.chain.__class__.__name__ == 'type' — chain is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra228"]
    - [zip_longest_class_is_type,
       zip_longest.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.zip_longest.__class__.__name__ == 'type' — zip_longest is a C extension type; its metaclass is 'type'; __class__.__name__.__eq__('type') returns True; new to extra228"]
    - [takewhile_class_is_type,
       takewhile.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.takewhile.__class__.__name__ == 'type' — takewhile is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra228"]
    - [dropwhile_class_is_type,
       dropwhile.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.dropwhile.__class__.__name__ == 'type' — dropwhile is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra228"]
    - [starmap_class_is_type,
       starmap.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.starmap.__class__.__name__ == 'type' — starmap is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra228"]

# ---------------------------------------------------------------------------
# Table 2: itertools chain/zip_longest/takewhile/dropwhile qualname contracts
#
# itertools.chain.__qualname__ == 'chain'
# itertools.zip_longest.__qualname__ == 'zip_longest'
# itertools.takewhile.__qualname__ == 'takewhile'
# itertools.dropwhile.__qualname__ == 'dropwhile'
# itertools.starmap.__qualname__ == 'starmap'
#
# New to extra228.
# ---------------------------------------------------------------------------

table itertools_extra228.type_qualnames:
  description: "itertools chain/zip_longest/takewhile/dropwhile/starmap qualname contracts; new to extra228"
  kind: python_call_eq
  category: behavioral
  id_prefix: itertoolsextra228typequal

  columns: [id, function, args, expected, description]
  rows:
    - [chain_qualname,
       chain.__qualname__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__qualname__ == 'chain' — chain is a top-level C type with unqualified qualname 'chain'; __qualname__.__eq__('chain') returns True; new to extra228"]
    - [zip_longest_qualname,
       zip_longest.__qualname__.__eq__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__qualname__ == 'zip_longest' — zip_longest is a top-level C type with qualname 'zip_longest'; __qualname__.__eq__('zip_longest') returns True; new to extra228"]
    - [takewhile_qualname,
       takewhile.__qualname__.__eq__,
       ["takewhile"],
       true,
       "itertools.takewhile.__qualname__ == 'takewhile' — takewhile is a top-level C type with qualname 'takewhile'; __qualname__.__eq__('takewhile') returns True; new to extra228"]
    - [dropwhile_qualname,
       dropwhile.__qualname__.__eq__,
       ["dropwhile"],
       true,
       "itertools.dropwhile.__qualname__ == 'dropwhile' — dropwhile is a top-level C type with qualname 'dropwhile'; __qualname__.__eq__('dropwhile') returns True; new to extra228"]
    - [starmap_qualname,
       starmap.__qualname__.__eq__,
       ["starmap"],
       true,
       "itertools.starmap.__qualname__ == 'starmap' — starmap is a top-level C type with qualname 'starmap'; __qualname__.__eq__('starmap') returns True; new to extra228"]

# ---------------------------------------------------------------------------
# Table 3: itertools chain/zip_longest/takewhile/dropwhile __name__ length contracts
#
# itertools.chain.__name__.__len__() == 5
# itertools.zip_longest.__name__.__len__() == 11
# itertools.takewhile.__name__.__len__() == 9
# itertools.dropwhile.__name__.__len__() == 9
# itertools.starmap.__name__.__len__() == 7
#
# New to extra228.
# ---------------------------------------------------------------------------

table itertools_extra228.type_name_lengths:
  description: "itertools chain/zip_longest/takewhile/dropwhile/starmap __name__ length contracts; new to extra228"
  kind: python_call_eq
  category: behavioral
  id_prefix: itertoolsextra228namelen

  columns: [id, function, args, expected, description]
  rows:
    - [chain_name_len_5,
       chain.__name__.__len__,
       [],
       5,
       "itertools.chain.__name__.__len__() == 5 — 'chain' has exactly 5 characters (c-h-a-i-n); __len__() returns 5; new to extra228"]
    - [zip_longest_name_len_11,
       zip_longest.__name__.__len__,
       [],
       11,
       "itertools.zip_longest.__name__.__len__() == 11 — 'zip_longest' has exactly 11 characters (z-i-p-_-l-o-n-g-e-s-t); __len__() returns 11; new to extra228"]
    - [takewhile_name_len_9,
       takewhile.__name__.__len__,
       [],
       9,
       "itertools.takewhile.__name__.__len__() == 9 — 'takewhile' has exactly 9 characters (t-a-k-e-w-h-i-l-e); __len__() returns 9; new to extra228"]
    - [dropwhile_name_len_9,
       dropwhile.__name__.__len__,
       [],
       9,
       "itertools.dropwhile.__name__.__len__() == 9 — 'dropwhile' has exactly 9 characters (d-r-o-p-w-h-i-l-e); __len__() returns 9; new to extra228"]
    - [starmap_name_len_7,
       starmap.__name__.__len__,
       [],
       7,
       "itertools.starmap.__name__.__len__() == 7 — 'starmap' has exactly 7 characters (s-t-a-r-m-a-p); __len__() returns 7; new to extra228"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra228
# (These use method: __next__ to verify actual behavioral output values)
# ---------------------------------------------------------------------------

invariant itertools_extra228.chain_first_1:
  description: "itertools.chain([1,2],[3,4]).__next__() == 1 — chain yields first element of first iterable; new to extra228"
  kind: python_call_eq
  function: chain
  args: [[1, 2], [3, 4]]
  method: __next__
  expected: 1

invariant itertools_extra228.zip_longest_first:
  description: "itertools.zip_longest([1,2],[3]).__next__() == (1,3) — first zipped pair is (1,3); new to extra228"
  kind: python_call_eq
  function: zip_longest
  args: [[1, 2], [3]]
  method: __next__
  expected: [1, 3]

invariant itertools_extra228.takewhile_first_1:
  description: "itertools.takewhile(pred, [1,2,3,4]).__next__() == 1 — takewhile yields first element that passes pred; new to extra228"
  kind: python_call_eq
  function: takewhile
  args: [null, [1, 2, 3, 4]]
  method: __next__
  expected: 1

invariant itertools_extra228.dropwhile_first_3:
  description: "itertools.dropwhile(pred, [1,2,3,4]).__next__() == 3 — dropwhile skips 1,2 and yields 3 as first non-dropped; new to extra228"
  kind: python_call_eq
  function: dropwhile
  args: [null, [3, 4]]
  method: __next__
  expected: 3

invariant itertools_extra228.chain_class_is_type:
  description: "itertools.chain.__class__.__name__ == 'type' — chain is a C extension type; new to extra228"
  kind: python_call_eq
  function: chain.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra228.zip_longest_class_is_type:
  description: "itertools.zip_longest.__class__.__name__ == 'type' — zip_longest is a C extension type; new to extra228"
  kind: python_call_eq
  function: zip_longest.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra228.takewhile_class_is_type:
  description: "itertools.takewhile.__class__.__name__ == 'type' — takewhile is a C extension type; new to extra228"
  kind: python_call_eq
  function: takewhile.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra228.dropwhile_class_is_type:
  description: "itertools.dropwhile.__class__.__name__ == 'type' — dropwhile is a C extension type; new to extra228"
  kind: python_call_eq
  function: dropwhile.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra228.chain_qualname:
  description: "itertools.chain.__qualname__ == 'chain'; new to extra228"
  kind: python_call_eq
  function: chain.__qualname__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra228.zip_longest_qualname:
  description: "itertools.zip_longest.__qualname__ == 'zip_longest'; new to extra228"
  kind: python_call_eq
  function: zip_longest.__qualname__.__eq__
  args: ["zip_longest"]
  expected: true

invariant itertools_extra228.takewhile_qualname:
  description: "itertools.takewhile.__qualname__ == 'takewhile'; new to extra228"
  kind: python_call_eq
  function: takewhile.__qualname__.__eq__
  args: ["takewhile"]
  expected: true

invariant itertools_extra228.dropwhile_qualname:
  description: "itertools.dropwhile.__qualname__ == 'dropwhile'; new to extra228"
  kind: python_call_eq
  function: dropwhile.__qualname__.__eq__
  args: ["dropwhile"]
  expected: true

invariant itertools_extra228.chain_name_len_5:
  description: "itertools.chain.__name__.__len__() == 5 — 'chain' has 5 characters; new to extra228"
  kind: python_call_eq
  function: chain.__name__.__len__
  args: []
  expected: 5

invariant itertools_extra228.zip_longest_name_len_11:
  description: "itertools.zip_longest.__name__.__len__() == 11 — 'zip_longest' has 11 characters; new to extra228"
  kind: python_call_eq
  function: zip_longest.__name__.__len__
  args: []
  expected: 11

invariant itertools_extra228.takewhile_name_len_9:
  description: "itertools.takewhile.__name__.__len__() == 9 — 'takewhile' has 9 characters; new to extra228"
  kind: python_call_eq
  function: takewhile.__name__.__len__
  args: []
  expected: 9

invariant itertools_extra228.dropwhile_name_len_9:
  description: "itertools.dropwhile.__name__.__len__() == 9 — 'dropwhile' has 9 characters; new to extra228"
  kind: python_call_eq
  function: dropwhile.__name__.__len__
  args: []
  expected: 9
