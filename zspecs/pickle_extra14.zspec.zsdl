spec: pickle_extra14
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl through pickle_extra13.zspec.zsdl."
    - "pickle_extra13 covers: HIGHEST_PROTOCOL/__class__.__name__; HIGHEST_PROTOCOL>=5; DEFAULT_PROTOCOL/__class__.__name__; PickleError/__name__; PicklingError/__name__; UnpicklingError/__name__; PicklingError/__bases__[0].__name__; dumps/__qualname__."
    - "pickle_extra12 covers: Pickler/Unpickler __module__; exception __module__ table; dumps/loads __module__ standalone."
    - "pickle_extra11 covers: Pickler/Unpickler __name__; PickleError/PicklingError/UnpicklingError __name__ table; PickleError/__bases__[0].__name__; PicklingError/__bases__[0].__name__; UnpicklingError/__bases__[0].__name__."
    - "pickle_extra10 covers: dumps(42).__class__.__name__; HIGHEST_PROTOCOL/DEFAULT_PROTOCOL __class__.__name__; PickleError/PicklingError/UnpicklingError __qualname__; dumps/loads __name__."
    - "Focus: new axes — Pickler/__qualname__; Unpickler/__qualname__; PickleBuffer/__qualname__; PickleBuffer/__bases__[0].__name__; loads/__qualname__; load/__qualname__; dump/__qualname__; Pickler/__bases__[0].__name__; Unpickler/__bases__[0].__name__."
    - "pickle.Pickler.__qualname__ == 'Pickler' — no prior pickle spec checks Pickler.__qualname__ as a standalone invariant in this namespace."
    - "pickle.Unpickler.__qualname__ == 'Unpickler' — no prior pickle spec checks Unpickler.__qualname__ in this namespace."
    - "pickle.PickleBuffer.__qualname__ == 'PickleBuffer' — no prior pickle spec checks PickleBuffer.__qualname__."
    - "pickle.Pickler.__bases__[0].__name__ == 'object' — Pickler inherits directly from object; no prior spec checks this."
    - "pickle.Unpickler.__bases__[0].__name__ == 'object' — Unpickler inherits directly from object; no prior spec checks this."
    - "pickle.PickleBuffer.__bases__[0].__name__ == 'object' — PickleBuffer inherits directly from object; no prior spec checks this."
    - "pickle.loads.__qualname__ == 'loads' — no prior pickle spec checks loads.__qualname__ as a standalone invariant."
    - "pickle.load.__qualname__ == 'load'; pickle.dump.__qualname__ == 'dump' — no prior spec checks these."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pickler, Unpickler, PickleBuffer — __qualname__ table
#
# pickle_extra10 checks __qualname__ for PickleError/PicklingError/UnpicklingError.
# No prior spec checks __qualname__ for Pickler, Unpickler, or PickleBuffer.
# ---------------------------------------------------------------------------

table pickle_extra14.class_qualnames:
  description: "pickle.Pickler/Unpickler/PickleBuffer — __qualname__ values"
  kind: python_call_eq
  category: class_attrs
  id_prefix: pcq14

  columns: [id, function, args, expected]
  rows:
    - [Pickler_qualname,     Pickler.__qualname__.__eq__,     ["Pickler"],      true]
    - [Unpickler_qualname,   Unpickler.__qualname__.__eq__,   ["Unpickler"],    true]
    - [PickleBuffer_qualname, PickleBuffer.__qualname__.__eq__, ["PickleBuffer"], true]

# ---------------------------------------------------------------------------
# Pickler, Unpickler, PickleBuffer — __bases__[0].__name__
#
# All three classes inherit directly from object. pickle_extra11 checks
# __bases__[0].__name__ for the exception classes only. No prior spec checks
# Pickler/Unpickler/PickleBuffer.__bases__[0].__name__.
# ---------------------------------------------------------------------------

invariant pickle_extra14.Pickler.bases_0_name:
  description: "pickle.Pickler.__bases__[0].__name__ == 'object' — inherits directly from object"
  category: class_attrs
  kind: python_call_eq
  function: "Pickler.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant pickle_extra14.Unpickler.bases_0_name:
  description: "pickle.Unpickler.__bases__[0].__name__ == 'object' — inherits directly from object"
  category: class_attrs
  kind: python_call_eq
  function: "Unpickler.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant pickle_extra14.PickleBuffer.bases_0_name:
  description: "pickle.PickleBuffer.__bases__[0].__name__ == 'object' — inherits directly from object"
  category: class_attrs
  kind: python_call_eq
  function: "PickleBuffer.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# loads, load, dump — __qualname__ standalone invariants
#
# pickle_extra13 checks dumps.__qualname__ as a standalone invariant.
# No prior pickle spec checks loads/__qualname__, load/__qualname__, or
# dump/__qualname__ as standalone invariants in any namespace.
# ---------------------------------------------------------------------------

invariant pickle_extra14.loads.qualname:
  description: "pickle.loads.__qualname__ == 'loads' — top-level function qualname"
  category: function_attrs
  kind: python_call_eq
  function: loads.__qualname__.__eq__
  args: ["loads"]
  expected: true

invariant pickle_extra14.load.qualname:
  description: "pickle.load.__qualname__ == 'load' — top-level function qualname"
  category: function_attrs
  kind: python_call_eq
  function: load.__qualname__.__eq__
  args: ["load"]
  expected: true

invariant pickle_extra14.dump.qualname:
  description: "pickle.dump.__qualname__ == 'dump' — top-level function qualname"
  category: function_attrs
  kind: python_call_eq
  function: dump.__qualname__.__eq__
  args: ["dump"]
  expected: true
