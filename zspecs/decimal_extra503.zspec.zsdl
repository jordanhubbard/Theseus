spec: decimal_extra503
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal.Context methods"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers decimal.Context method __name__ identity checks"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra503.context_method_names:
  description: "decimal.Context method __name__ identity checks"
  kind: python_call_eq
  category: method_identity
  id_prefix: dcme

  columns: [id, function, args, expected]
  rows:
    - [dcme001, decimal.Context.clear_flags.__name__.__eq__, ["clear_flags"], true]
    - [dcme002, decimal.Context.clear_traps.__name__.__eq__, ["clear_traps"], true]
    - [dcme003, decimal.Context.copy.__name__.__eq__, ["copy"], true]
    - [dcme004, decimal.Context.copy_decimal.__name__.__eq__, ["copy_decimal"], true]
    - [dcme005, decimal.Context.create_decimal.__name__.__eq__, ["create_decimal"], true]
    - [dcme006, decimal.Context.Etiny.__name__.__eq__, ["Etiny"], true]
    - [dcme007, decimal.Context.Etop.__name__.__eq__, ["Etop"], true]
    - [dcme008, decimal.Context.abs.__name__.__eq__, ["abs"], true]
    - [dcme009, decimal.Context.add.__name__.__eq__, ["add"], true]
    - [dcme010, decimal.Context.divide.__name__.__eq__, ["divide"], true]
    - [dcme011, decimal.Context.multiply.__name__.__eq__, ["multiply"], true]
    - [dcme012, decimal.Context.subtract.__name__.__eq__, ["subtract"], true]
    - [dcme013, decimal.Context.power.__name__.__eq__, ["power"], true]
    - [dcme014, decimal.Context.sqrt.__name__.__eq__, ["sqrt"], true]
