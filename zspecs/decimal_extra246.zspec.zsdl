spec: decimal_extra246
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers decimal.Decimal instance method identity: is_infinite, is_nan, is_zero, is_finite, is_signed, is_normal, is_subnormal — __name__ and __class__.__name__ for each."
    - "All seven methods are method_descriptor objects (C-level descriptors defined in the _decimal C extension); their __class__.__name__ is 'method_descriptor'."
    - "decimal.Decimal.is_infinite.__name__ == 'is_infinite', etc. — each method's __name__ is its unqualified name as a string."
    - "method_descriptor is the CPython type for C-level unbound methods on built-in types; it is distinct from 'function' (Python-level) and 'builtin_function_or_method' (C-level module functions)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal predicate method __name__ values
#
# All seven is_* predicate methods on Decimal have __name__ equal to their
# unqualified method name.
# ---------------------------------------------------------------------------

table decimal_extra246.decimal_method_names:
  description: "decimal.Decimal predicate method __name__ values — is_infinite, is_nan, is_zero, is_finite, is_signed, is_normal, is_subnormal; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: decxmn246

  columns: [id, function, args, expected, description]
  rows:
    - [is_infinite_name,
       "Decimal.is_infinite.__name__.__eq__",
       ["is_infinite"],
       true,
       "decimal.Decimal.is_infinite.__name__.__eq__('is_infinite') == True — Decimal.is_infinite returns True if the value is positive or negative infinity; its method __name__ is 'is_infinite'; str.__eq__('is_infinite') returns True; new to extra246"]
    - [is_nan_name,
       "Decimal.is_nan.__name__.__eq__",
       ["is_nan"],
       true,
       "decimal.Decimal.is_nan.__name__.__eq__('is_nan') == True — Decimal.is_nan returns True if the value is a quiet or signaling NaN; its method __name__ is 'is_nan'; str.__eq__('is_nan') returns True; new to extra246"]
    - [is_zero_name,
       "Decimal.is_zero.__name__.__eq__",
       ["is_zero"],
       true,
       "decimal.Decimal.is_zero.__name__.__eq__('is_zero') == True — Decimal.is_zero returns True if the value is positive or negative zero; its method __name__ is 'is_zero'; str.__eq__('is_zero') returns True; new to extra246"]
    - [is_finite_name,
       "Decimal.is_finite.__name__.__eq__",
       ["is_finite"],
       true,
       "decimal.Decimal.is_finite.__name__.__eq__('is_finite') == True — Decimal.is_finite returns True if the value is finite (not infinity or NaN); its method __name__ is 'is_finite'; str.__eq__('is_finite') returns True; new to extra246"]
    - [is_signed_name,
       "Decimal.is_signed.__name__.__eq__",
       ["is_signed"],
       true,
       "decimal.Decimal.is_signed.__name__.__eq__('is_signed') == True — Decimal.is_signed returns True if the value has a negative sign bit (including negative zero and negative NaN); its method __name__ is 'is_signed'; str.__eq__('is_signed') returns True; new to extra246"]
    - [is_normal_name,
       "Decimal.is_normal.__name__.__eq__",
       ["is_normal"],
       true,
       "decimal.Decimal.is_normal.__name__.__eq__('is_normal') == True — Decimal.is_normal returns True if the value is a normal finite number (not zero, subnormal, infinity, or NaN); its method __name__ is 'is_normal'; str.__eq__('is_normal') returns True; new to extra246"]
    - [is_subnormal_name,
       "Decimal.is_subnormal.__name__.__eq__",
       ["is_subnormal"],
       true,
       "decimal.Decimal.is_subnormal.__name__.__eq__('is_subnormal') == True — Decimal.is_subnormal returns True if the value is subnormal (finite but with exponent below Emin); its method __name__ is 'is_subnormal'; str.__eq__('is_subnormal') returns True; new to extra246"]

# ---------------------------------------------------------------------------
# Table 2: decimal.Decimal predicate method __class__.__name__ values
#
# All seven is_* predicate methods are C-level method_descriptor objects.
# This is because decimal.Decimal is implemented in the _decimal C extension
# on Python 3.14.3. method_descriptor is the CPython type for unbound
# C-level instance methods on built-in types.
# ---------------------------------------------------------------------------

table decimal_extra246.decimal_method_class_names:
  description: "decimal.Decimal predicate method __class__.__name__ == 'method_descriptor' — all seven methods are C-level descriptors; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: decxmcn246

  columns: [id, function, args, expected, description]
  rows:
    - [is_infinite_class,
       "Decimal.is_infinite.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.is_infinite.__class__.__name__.__eq__('method_descriptor') == True — Decimal.is_infinite is a C-level method_descriptor defined in the _decimal C extension; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra246"]
    - [is_nan_class,
       "Decimal.is_nan.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.is_nan.__class__.__name__.__eq__('method_descriptor') == True — Decimal.is_nan is a C-level method_descriptor; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra246"]
    - [is_zero_class,
       "Decimal.is_zero.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.is_zero.__class__.__name__.__eq__('method_descriptor') == True — Decimal.is_zero is a C-level method_descriptor; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra246"]
    - [is_finite_class,
       "Decimal.is_finite.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.is_finite.__class__.__name__.__eq__('method_descriptor') == True — Decimal.is_finite is a C-level method_descriptor; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra246"]
    - [is_signed_class,
       "Decimal.is_signed.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.is_signed.__class__.__name__.__eq__('method_descriptor') == True — Decimal.is_signed is a C-level method_descriptor; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra246"]
    - [is_normal_class,
       "Decimal.is_normal.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.is_normal.__class__.__name__.__eq__('method_descriptor') == True — Decimal.is_normal is a C-level method_descriptor; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra246"]
    - [is_subnormal_class,
       "Decimal.is_subnormal.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Decimal.is_subnormal.__class__.__name__.__eq__('method_descriptor') == True — Decimal.is_subnormal is a C-level method_descriptor; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra246"]

# ---------------------------------------------------------------------------
# Table 3: decimal.Decimal predicate methods — not 'function', not 'builtin'
#
# Cross-checks confirming these methods are method_descriptor, not plain
# Python functions or builtin_function_or_method.
# ---------------------------------------------------------------------------

table decimal_extra246.decimal_method_not_function:
  description: "decimal.Decimal predicate methods are not 'function' — cross-checks for is_infinite, is_nan, is_zero, is_finite; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: decxmnf246

  columns: [id, function, args, expected, description]
  rows:
    - [is_infinite_not_function,
       "Decimal.is_infinite.__class__.__name__.__eq__",
       ["function"],
       false,
       "decimal.Decimal.is_infinite.__class__.__name__.__eq__('function') == False — Decimal.is_infinite is a C-level method_descriptor, not a plain Python function; __class__.__name__ is 'method_descriptor', not 'function'; str.__eq__('function') returns False; new to extra246"]
    - [is_nan_not_function,
       "Decimal.is_nan.__class__.__name__.__eq__",
       ["function"],
       false,
       "decimal.Decimal.is_nan.__class__.__name__.__eq__('function') == False — Decimal.is_nan is a C-level method_descriptor, not a plain Python function; __class__.__name__ is 'method_descriptor', not 'function'; str.__eq__('function') returns False; new to extra246"]
    - [is_zero_not_builtin,
       "Decimal.is_zero.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       false,
       "decimal.Decimal.is_zero.__class__.__name__.__eq__('builtin_function_or_method') == False — Decimal.is_zero is a method_descriptor (unbound C instance method), not a builtin_function_or_method (which is for module-level C functions); str.__eq__('builtin_function_or_method') returns False; new to extra246"]
    - [is_finite_not_builtin,
       "Decimal.is_finite.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       false,
       "decimal.Decimal.is_finite.__class__.__name__.__eq__('builtin_function_or_method') == False — Decimal.is_finite is a method_descriptor (unbound C instance method), not a builtin_function_or_method; str.__eq__('builtin_function_or_method') returns False; new to extra246"]

# ---------------------------------------------------------------------------
# Standalone invariants — decimal_extra246
# ---------------------------------------------------------------------------

invariant decimal_extra246.is_infinite_name:
  description: "decimal.Decimal.is_infinite.__name__ == 'is_infinite' — method identity for the infinity predicate; new to extra246"
  kind: python_call_eq
  function: Decimal.is_infinite.__name__.__eq__
  args: ["is_infinite"]
  expected: true

invariant decimal_extra246.is_nan_name:
  description: "decimal.Decimal.is_nan.__name__ == 'is_nan' — method identity for the NaN predicate; new to extra246"
  kind: python_call_eq
  function: Decimal.is_nan.__name__.__eq__
  args: ["is_nan"]
  expected: true

invariant decimal_extra246.is_zero_name:
  description: "decimal.Decimal.is_zero.__name__ == 'is_zero' — method identity for the zero predicate; new to extra246"
  kind: python_call_eq
  function: Decimal.is_zero.__name__.__eq__
  args: ["is_zero"]
  expected: true

invariant decimal_extra246.is_finite_name:
  description: "decimal.Decimal.is_finite.__name__ == 'is_finite' — method identity for the finite predicate; new to extra246"
  kind: python_call_eq
  function: Decimal.is_finite.__name__.__eq__
  args: ["is_finite"]
  expected: true

invariant decimal_extra246.is_infinite_is_method_descriptor:
  description: "decimal.Decimal.is_infinite.__class__.__name__ == 'method_descriptor' — is_infinite is a C-level method_descriptor; new to extra246"
  kind: python_call_eq
  function: Decimal.is_infinite.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra246.is_signed_is_method_descriptor:
  description: "decimal.Decimal.is_signed.__class__.__name__ == 'method_descriptor' — is_signed is a C-level method_descriptor; new to extra246"
  kind: python_call_eq
  function: Decimal.is_signed.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra246.is_subnormal_name:
  description: "decimal.Decimal.is_subnormal.__name__ == 'is_subnormal' — method identity for the subnormal predicate; new to extra246"
  kind: python_call_eq
  function: Decimal.is_subnormal.__name__.__eq__
  args: ["is_subnormal"]
  expected: true
