spec: array_extra
version: ">=3.2"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "Python array documentation — https://docs.python.org/3/library/array.html"
    - "Test vectors verified by running Python 3.14.3 array module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
  notes:
    - "This spec covers identity invariants not present in array.zspec.zsdl."
    - "The array module exports both the module 'array' and the type 'array' within it; array.array is the constructor."
    - "array.__name__ accesses the __name__ attribute of the array type (the class), not the module."
    - "array.__module__ == 'array' — the type is defined in the C-level array module."
    - "ArrayType is a public alias for array.array in the array module; ArrayType.__name__ == 'array'."
    - "typecodes is a module-level str containing all valid typecode characters."
    - "array('b', [1,2,3]).itemsize == 1 — signed char is 1 byte."
    - "array('h', [1,2,3]).itemsize == 2 — short is 2 bytes."
    - "array('b', [1,2,3]).typecode == 'b' — typecode attribute reflects the constructor argument."
    - "array('b', [1,2,3]).__len__() == 3 — length equals number of elements."
    - "array('b', [1,2,3])[0] == 1 — indexed access returns the first element."
    - "array('b', [1,2,3]).tolist() == [1,2,3] — converts to a plain Python list."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class identity — array type name and module membership
# ---------------------------------------------------------------------------

invariant array_extra.class_identity.name:
  description: "array.array.__name__ == 'array' — the type name is 'array'"
  category: class_identity
  kind: python_call_eq
  function: array.__name__.__eq__
  args: ["array"]
  expected: true

invariant array_extra.class_identity.module:
  description: "array.array.__module__ == 'array' — the type is defined in the array module"
  category: class_identity
  kind: python_call_eq
  function: array.__module__.__eq__
  args: ["array"]
  expected: true

# ---------------------------------------------------------------------------
# ArrayType alias — ArrayType is a public alias for array.array in the module
# ---------------------------------------------------------------------------

invariant array_extra.arraytype_alias.name:
  description: "array.ArrayType.__name__ == 'array' — ArrayType is an alias for the array type"
  category: arraytype_alias
  kind: python_call_eq
  function: ArrayType.__name__.__eq__
  args: ["array"]
  expected: true

# ---------------------------------------------------------------------------
# typecodes — module-level string of valid typecode characters
# ---------------------------------------------------------------------------

invariant array_extra.typecodes.is_str:
  description: "array.typecodes.__class__.__name__ == 'str' — typecodes is a string"
  category: typecodes
  kind: python_call_eq
  function: typecodes.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# itemsize — storage size in bytes per element by typecode
# ---------------------------------------------------------------------------

invariant array_extra.itemsize.signed_char:
  description: "array.array('b', [1,2,3]).itemsize == 1 — signed char is 1 byte"
  category: itemsize
  kind: python_call_eq
  function: array
  args: ["b", [1, 2, 3]]
  method: itemsize
  expected: 1

invariant array_extra.itemsize.short:
  description: "array.array('h', [1,2,3]).itemsize == 2 — short is 2 bytes"
  category: itemsize
  kind: python_call_eq
  function: array
  args: ["h", [1, 2, 3]]
  method: itemsize
  expected: 2

# ---------------------------------------------------------------------------
# typecode attribute — reflects the typecode passed to the constructor
# ---------------------------------------------------------------------------

invariant array_extra.typecode.signed_char:
  description: "array.array('b', [1,2,3]).typecode == 'b'"
  category: typecode
  kind: python_call_eq
  function: array
  args: ["b", [1, 2, 3]]
  method: typecode
  expected: "b"

# ---------------------------------------------------------------------------
# Length — number of elements stored in the array
# ---------------------------------------------------------------------------

invariant array_extra.length.three_elements:
  description: "array.array('b', [1,2,3]).__len__() == 3"
  category: length
  kind: python_call_eq
  function: array
  args: ["b", [1, 2, 3]]
  method: __len__
  expected: 3

# ---------------------------------------------------------------------------
# Indexed access — __getitem__ retrieves individual elements
# ---------------------------------------------------------------------------

invariant array_extra.getitem.first:
  description: "array.array('b', [1,2,3])[0] == 1 — first element"
  category: getitem
  kind: python_call_eq
  function: array
  args: ["b", [1, 2, 3]]
  method: __getitem__
  method_args: [0]
  expected: 1

# ---------------------------------------------------------------------------
# tolist — converts array to a plain Python list
# ---------------------------------------------------------------------------

invariant array_extra.tolist.signed_char:
  description: "array.array('b', [1,2,3]).tolist() == [1,2,3]"
  category: tolist
  kind: python_call_eq
  function: array
  args: ["b", [1, 2, 3]]
  method: tolist
  expected: [1, 2, 3]
