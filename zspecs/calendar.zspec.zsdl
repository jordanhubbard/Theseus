spec: calendar
version: ">=3.2"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "Python calendar documentation — https://docs.python.org/3/library/calendar.html"
    - "Test vectors verified by running Python 3.14.3 calendar module on macOS/Darwin 25.4.0, 2026-04-08"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
  notes:
    - "calendar.isleap(year) returns True if year is a Gregorian leap year: divisible by 4, not by 100, or by 400."
    - "1900 is not a leap year (divisible by 100 but not 400). 2000 is a leap year (divisible by 400)."
    - "calendar.weekday(year, month, day) returns a Day enum whose integer value is 0=Monday…6=Sunday."
    - "The Day enum compares equal to the corresponding integer (e.g. WEDNESDAY == 2)."
    - "calendar.leapdays(y1, y2) counts leap years in range [y1, y2) — note the exclusive upper bound."
    - "calendar.month_name and calendar.month_abbr are 13-element sequences; index 0 is empty string, indices 1-12 are month names."
    - "calendar.day_name and calendar.day_abbr are 7-element sequences indexed 0=Monday…6=Sunday."
    - "calendar.MONDAY…SUNDAY and calendar.JANUARY, calendar.DECEMBER are integer-valued enum constants."
    - "calendar.January and calendar.December are deprecated aliases (removed in Python 3.14); use JANUARY/DECEMBER."
  created_at: "2026-04-08T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# isleap — Gregorian leap year predicate
# ---------------------------------------------------------------------------

table calendar.isleap.vectors:
  kind: python_call_eq
  category: isleap
  id_prefix: isleap
  function: isleap

  columns: [id, args, expected]
  rows:
    - [divisible_by_400,   [2000], true  ]
    - [divisible_by_4,     [2024], true  ]
    - [divisible_by_100,   [1900], false ]
    - [century_2100,       [2100], false ]
    - [common_year,        [2023], false ]
    - [common_year_2026,   [2026], false ]

# ---------------------------------------------------------------------------
# weekday — day-of-week for a given date (0=Monday … 6=Sunday)
# ---------------------------------------------------------------------------

invariant calendar.weekday.wednesday_2026_04_08:
  description: "calendar.weekday(2026, 4, 8) == 2 — 8 April 2026 is a Wednesday"
  category: weekday
  kind: python_call_eq
  function: weekday
  args: [2026, 4, 8]
  expected: 2

invariant calendar.weekday.monday_2024_01_01:
  description: "calendar.weekday(2024, 1, 1) == 0 — 1 January 2024 is a Monday"
  category: weekday
  kind: python_call_eq
  function: weekday
  args: [2024, 1, 1]
  expected: 0

invariant calendar.weekday.thursday_leap_day_2024:
  description: "calendar.weekday(2024, 2, 29) == 3 — leap day 2024 is a Thursday"
  category: weekday
  kind: python_call_eq
  function: weekday
  args: [2024, 2, 29]
  expected: 3

# ---------------------------------------------------------------------------
# leapdays — count leap years in [y1, y2)
# ---------------------------------------------------------------------------

invariant calendar.leapdays.2000_to_2025:
  description: "calendar.leapdays(2000, 2025) == 7 — leap years 2000,2004,2008,2012,2016,2020,2024"
  category: leapdays
  kind: python_call_eq
  function: leapdays
  args: [2000, 2025]
  expected: 7

invariant calendar.leapdays.single_leap_year:
  description: "calendar.leapdays(2000, 2001) == 1 — range contains only 2000, which is a leap year"
  category: leapdays
  kind: python_call_eq
  function: leapdays
  args: [2000, 2001]
  expected: 1

invariant calendar.leapdays.excludes_century_non_leap:
  description: "calendar.leapdays(1900, 1901) == 0 — 1900 is not a leap year"
  category: leapdays
  kind: python_call_eq
  function: leapdays
  args: [1900, 1901]
  expected: 0

# ---------------------------------------------------------------------------
# month_name — full month names (1-indexed; index 0 is empty string)
# ---------------------------------------------------------------------------

invariant calendar.month_name.january:
  description: "calendar.month_name[1] == 'January'"
  category: month_name
  kind: python_call_eq
  function: month_name.__getitem__
  args: [1]
  expected: "January"

invariant calendar.month_name.june:
  description: "calendar.month_name[6] == 'June'"
  category: month_name
  kind: python_call_eq
  function: month_name.__getitem__
  args: [6]
  expected: "June"

invariant calendar.month_name.december:
  description: "calendar.month_name[12] == 'December'"
  category: month_name
  kind: python_call_eq
  function: month_name.__getitem__
  args: [12]
  expected: "December"

# ---------------------------------------------------------------------------
# month_abbr — abbreviated month names (1-indexed)
# ---------------------------------------------------------------------------

invariant calendar.month_abbr.jan:
  description: "calendar.month_abbr[1] == 'Jan'"
  category: month_abbr
  kind: python_call_eq
  function: month_abbr.__getitem__
  args: [1]
  expected: "Jan"

invariant calendar.month_abbr.dec:
  description: "calendar.month_abbr[12] == 'Dec'"
  category: month_abbr
  kind: python_call_eq
  function: month_abbr.__getitem__
  args: [12]
  expected: "Dec"

# ---------------------------------------------------------------------------
# day_name — full day names (0=Monday … 6=Sunday)
# ---------------------------------------------------------------------------

invariant calendar.day_name.monday:
  description: "calendar.day_name[0] == 'Monday'"
  category: day_name
  kind: python_call_eq
  function: day_name.__getitem__
  args: [0]
  expected: "Monday"

invariant calendar.day_name.friday:
  description: "calendar.day_name[4] == 'Friday'"
  category: day_name
  kind: python_call_eq
  function: day_name.__getitem__
  args: [4]
  expected: "Friday"

invariant calendar.day_name.sunday:
  description: "calendar.day_name[6] == 'Sunday'"
  category: day_name
  kind: python_call_eq
  function: day_name.__getitem__
  args: [6]
  expected: "Sunday"

# ---------------------------------------------------------------------------
# day_abbr — abbreviated day names (0=Monday … 6=Sunday)
# ---------------------------------------------------------------------------

invariant calendar.day_abbr.mon:
  description: "calendar.day_abbr[0] == 'Mon'"
  category: day_abbr
  kind: python_call_eq
  function: day_abbr.__getitem__
  args: [0]
  expected: "Mon"

invariant calendar.day_abbr.sun:
  description: "calendar.day_abbr[6] == 'Sun'"
  category: day_abbr
  kind: python_call_eq
  function: day_abbr.__getitem__
  args: [6]
  expected: "Sun"

# ---------------------------------------------------------------------------
# Constants — MONDAY…SUNDAY (Day enum, compares equal to int)
# ---------------------------------------------------------------------------

invariant calendar.constants.MONDAY:
  description: "calendar.MONDAY == 0"
  category: constants
  kind: python_call_eq
  function: MONDAY.__eq__
  args: [0]
  expected: true

invariant calendar.constants.WEDNESDAY:
  description: "calendar.WEDNESDAY == 2"
  category: constants
  kind: python_call_eq
  function: WEDNESDAY.__eq__
  args: [2]
  expected: true

invariant calendar.constants.SUNDAY:
  description: "calendar.SUNDAY == 6"
  category: constants
  kind: python_call_eq
  function: SUNDAY.__eq__
  args: [6]
  expected: true

invariant calendar.constants.JANUARY:
  description: "calendar.JANUARY == 1"
  category: constants
  kind: python_call_eq
  function: JANUARY.__eq__
  args: [1]
  expected: true

invariant calendar.constants.DECEMBER:
  description: "calendar.DECEMBER == 12"
  category: constants
  kind: python_call_eq
  function: DECEMBER.__eq__
  args: [12]
  expected: true
