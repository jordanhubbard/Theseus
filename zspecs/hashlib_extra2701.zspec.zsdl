table hashlib_extra2701.hash_types_cross:
  description: "Cross-checks: HASH class, blake2b, blake2s __dict__ do not contain __lshift__, __rshift__, __invert__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2701cx
  columns: [id, function, args, expected]
  rows:
    - ["hl2701cx001", hashlib.new("sha256").__class__.__dict__.__contains__, ["__lshift__"], false]
    - ["hl2701cx002", hashlib.blake2b.__dict__.__contains__,                 ["__rshift__"], false]
    - ["hl2701cx003", hashlib.blake2s.__dict__.__contains__,                 ["__invert__"], false]
    - ["hl2701cx004", hashlib.new("sha256").__class__.__dict__.__contains__, ["__invert__"], false]
