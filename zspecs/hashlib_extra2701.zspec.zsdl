spec: hashlib_extra2701
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 627: checks hashlib HASH (accessed via hashlib.new('sha256').__class__), blake2b, blake2s __dict__ for __lshift__, __rshift__, __invert__ presence. All three classes return False for all three dunders — none defines __lshift__, __rshift__, or __invert__ in its own __dict__."]
  created_at: "2026-04-13"
error_model: python_exceptions

table hashlib_extra2701.HASH_dict_presence:
  description: "hashlib HASH class (hashlib.new('sha256').__class__) __dict__ does not contain __lshift__, __rshift__, or __invert__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2701hd
  columns: [id, function, args, expected]
  rows:
    - ["hl2701hd001", hashlib.new("sha256").__class__.__dict__.__contains__, ["__lshift__"], false]
    - ["hl2701hd002", hashlib.new("sha256").__class__.__dict__.__contains__, ["__rshift__"], false]
    - ["hl2701hd003", hashlib.new("sha256").__class__.__dict__.__contains__, ["__invert__"], false]

