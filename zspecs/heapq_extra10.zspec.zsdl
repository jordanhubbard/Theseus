spec: heapq_extra10
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
  notes:
    - "This spec extends heapq.zspec.zsdl and prior extras through heapq_extra9.zspec.zsdl."
    - "heapq.zspec.zsdl: nlargest/nsmallest tables; heappush/heappop/heapify/merge __name__."
    - "heapq_extra through heapq_extra9: __name__/__module__/__qualname__ for all functions; behavioral vectors on many distinct inputs."
    - "NOT yet covered: heappushpop behavioral result (actual return value) — prior specs only verify __name__/__module__/__qualname__ for heappushpop; heapreplace behavioral result — same situation; merge __next__() first element from two sorted lists."
    - "heapq.heappushpop(heap, item) pushes item onto a heap and then pops and returns the smallest element. If item is less than the current heap minimum, item is returned immediately without modification. If item >= heap minimum, item is pushed and the old minimum is popped and returned."
    - "heappushpop([1, 3, 5], 2) == 1 — 2 > heap min (1), so 1 is popped and returned after 2 is pushed."
    - "heappushpop([1, 3, 5], 0) == 0 — 0 < heap min (1), so 0 is returned immediately."
    - "heapreplace([1, 3, 5], 2) == 1 — always pops the current min (1) before pushing 2."
    - "heapreplace([1, 3, 5], 0) == 1 — always pops min (1) first, regardless of new item value."
    - "merge([1,3,5], [2,4,6]).__next__() == 1 — first element from the merged sorted sequence."
    - "merge([], [1,2]).__next__() == 1 — merge with one empty source; first from non-empty list."
    - "nlargest(4, [4,7,1,9,3]) == [9,7,4,3]; nsmallest(4, [4,7,1,9,3]) == [1,3,4,7]."
    - "Input [4,7,1,9,3] is a new 5-element fixture not used in any prior heapq spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# heappushpop — behavioral return value
#
# Prior specs (heapq_extra2, heapq_extra4, heapq_extra5, heapq_extra8, heapq_extra9)
# all test heappushpop.__name__, __module__, or __qualname__. No prior spec
# tests the *return value* of heappushpop(heap, item).
# heappushpop([1,3,5], 2) — item 2 > min 1 → pushes 2, pops 1, returns 1.
# heappushpop([1,3,5], 0) — item 0 < min 1 → returns 0 immediately (heap unchanged).
# ---------------------------------------------------------------------------

invariant heapq_extra10.heappushpop.item_greater_than_min:
  description: "heappushpop([1,3,5], 2) == 1 — item > min; pushes 2, pops and returns 1"
  category: behavior
  kind: python_call_eq
  function: heappushpop
  args: [[1, 3, 5], 2]
  expected: 1

invariant heapq_extra10.heappushpop.item_less_than_min:
  description: "heappushpop([1,3,5], 0) == 0 — item < min; returned immediately without heap change"
  category: behavior
  kind: python_call_eq
  function: heappushpop
  args: [[1, 3, 5], 0]
  expected: 0

invariant heapq_extra10.heappushpop.item_equal_to_min:
  description: "heappushpop([2,3,5], 2) == 2 — item == min; pushes then pops min (still 2)"
  category: behavior
  kind: python_call_eq
  function: heappushpop
  args: [[2, 3, 5], 2]
  expected: 2

# ---------------------------------------------------------------------------
# heapreplace — behavioral return value
#
# Prior specs test heapreplace.__name__, __module__, __qualname__.
# No prior spec tests the *return value* of heapreplace(heap, item).
# heapreplace always pops the current minimum FIRST, then pushes the new item.
# This is different from heappushpop when item < current min.
# heapreplace([1,3,5], 2) — pops min (1) and pushes 2; returns 1.
# heapreplace([1,3,5], 0) — pops min (1) and pushes 0; returns 1 (not 0).
# heapreplace on empty heap raises IndexError.
# ---------------------------------------------------------------------------

invariant heapq_extra10.heapreplace.item_greater_than_min:
  description: "heapreplace([1,3,5], 2) == 1 — always pops min (1) first, pushes 2; returns 1"
  category: behavior
  kind: python_call_eq
  function: heapreplace
  args: [[1, 3, 5], 2]
  expected: 1

invariant heapq_extra10.heapreplace.item_less_than_min:
  description: "heapreplace([1,3,5], 0) == 1 — pops min (1) first regardless of new item; returns 1"
  category: behavior
  kind: python_call_eq
  function: heapreplace
  args: [[1, 3, 5], 0]
  expected: 1

invariant heapq_extra10.heapreplace.empty_raises:
  description: "heapreplace([], 1) raises IndexError — cannot replace from an empty heap"
  category: edge_cases
  kind: python_call_raises
  function: heapreplace
  args: [[], 1]
  raises: IndexError

# ---------------------------------------------------------------------------
# merge — first element from two sorted iterables
#
# Prior specs test merge.__name__, __module__, __qualname__.
# No prior spec tests the first *yielded* element of merge().
# heapq.merge(*iterables) merges sorted iterables into a single sorted stream.
# merge([1,3,5], [2,4,6]).__next__() == 1 — the global minimum across all inputs.
# merge([], [1,2]).__next__() == 1 — one empty source; first from non-empty.
# ---------------------------------------------------------------------------

invariant heapq_extra10.merge.first_element_two_lists:
  description: "merge([1,3,5], [2,4,6]).__next__() == 1 — first element from merged sorted lists"
  category: behavior
  kind: python_call_eq
  function: merge
  args: [[1, 3, 5], [2, 4, 6]]
  method: __next__
  expected: 1

invariant heapq_extra10.merge.first_element_empty_first:
  description: "merge([], [1,2]).__next__() == 1 — first from non-empty second list"
  category: behavior
  kind: python_call_eq
  function: merge
  args: [[], [1, 2]]
  method: __next__
  expected: 1

# ---------------------------------------------------------------------------
# Behavioral invariants — [4, 7, 1, 9, 3]
#
# This 5-element input is new (not used in any prior heapq spec):
#   heapq        uses [1,8,2,6,3]
#   heapq_extra  uses [1,5,3,2,4]
#   heapq_extra2 uses [5,1,3,2,4]
#   heapq_extra3 uses [1,5,2,4,3]
#   heapq_extra4 uses [10,3,7,1,9,5,8,2,6,4] and negatives
#   heapq_extra5 uses [1,4,2,9,3]
#   heapq_extra6 uses [6,2,8,4,10,1,7,3,9,5]
#   heapq_extra7 uses [3,1,4,1,5,9,2,6]
#   heapq_extra8 uses [7,14,3,11,5,9]
#   heapq_extra9 uses [2,17,5,13,8,11]
# [4,7,1,9,3] is a new fixture not used in any prior spec.
# ---------------------------------------------------------------------------

invariant heapq_extra10.nlargest.fives_top3:
  description: "heapq.nlargest(3, [4,7,1,9,3]) == [9, 7, 4] — three largest in descending order"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [3, [4, 7, 1, 9, 3]]
  expected: [9, 7, 4]

invariant heapq_extra10.nsmallest.fives_top3:
  description: "heapq.nsmallest(3, [4,7,1,9,3]) == [1, 3, 4] — three smallest in ascending order"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [3, [4, 7, 1, 9, 3]]
  expected: [1, 3, 4]
