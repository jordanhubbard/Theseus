# concurrent.futures.ThreadPoolExecutor.__mro__[1].__name__ == 'Executor' (len=8)
# concurrent.futures.ThreadPoolExecutor.__mro__[2].__name__ == 'object' (len=6)
# ---------------------------------------------------------------------------

table concurrent_futures_extra202.ThreadPoolExecutor_mro_identity:
  description: "concurrent.futures.ThreadPoolExecutor MRO identity checks in cfmro202 namespace — ThreadPoolExecutor.__mro__.__len__()==3 (MRO is [ThreadPoolExecutor, Executor, object]; ThreadPoolExecutor is the concrete thread-pool implementation of Executor, giving a 3-entry MRO); ThreadPoolExecutor.__mro__[0].__name__=='ThreadPoolExecutor' (len=18); ThreadPoolExecutor.__mro__[1].__name__=='Executor' (len=8; the abstract base); ThreadPoolExecutor.__mro__[2].__name__=='object'; ThreadPoolExecutor.__mro__.__len__(3) > Executor.__mro__.__len__(2) by 1; verified with Python 3.14.3"
  kind: python_call_eq
  category: ThreadPoolExecutor_mro
  id_prefix: cfmro202

  columns: [id, function, args, expected, description]
  rows:
    - ["cf_tpe_mro_len",       "concurrent.futures.ThreadPoolExecutor.__mro__.__len__",                               [],                     3,    "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3 (MRO is [ThreadPoolExecutor, Executor, object]); verified Python 3.14.3"]
    - ["cf_tpe_mro0_name_eq",  "concurrent.futures.ThreadPoolExecutor.__mro__.__getitem__(0).__name__.__eq__",         ["ThreadPoolExecutor"], true, "concurrent.futures.ThreadPoolExecutor.__mro__[0].__name__ == 'ThreadPoolExecutor' (len=18; first MRO entry is the class itself); verified Python 3.14.3"]
    - ["cf_tpe_mro1_name_eq",  "concurrent.futures.ThreadPoolExecutor.__mro__.__getitem__(1).__name__.__eq__",         ["Executor"],           true, "concurrent.futures.ThreadPoolExecutor.__mro__[1].__name__ == 'Executor' (len=8; ThreadPoolExecutor's direct base is the abstract Executor); verified Python 3.14.3"]
    - ["cf_tpe_mro0_name_len", "concurrent.futures.ThreadPoolExecutor.__mro__.__getitem__(0).__name__.__len__",        [],                     18,   "concurrent.futures.ThreadPoolExecutor.__mro__[0].__name__.__len__() == 18 ('ThreadPoolExecutor'=18); verified Python 3.14.3"]
    - ["cf_tpe_mro2_name_eq",  "concurrent.futures.ThreadPoolExecutor.__mro__.__getitem__(2).__name__.__eq__",         ["object"],             true, "concurrent.futures.ThreadPoolExecutor.__mro__[2].__name__ == 'object' (len=6; object is the ultimate base class); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra202
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra202.cf_future_mro_is_tuple:
  description: "concurrent.futures.Future.__mro__.__class__.__name__.__eq__('tuple') == True — __mro__ is always a tuple in Python; Future.__mro__ is a tuple of 2 class objects [Future, object]; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Future_mro
  kind: python_call_eq
  function: Future.__mro__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant concurrent_futures_extra202.cf_future_mro_len_2:
  description: "concurrent.futures.Future.__mro__.__len__() == 2 — MRO is (Future, object); concurrent.futures.Future directly inherits from object with no intermediate bases; Future.__mro__.__len__(2) == Executor.__mro__.__len__(2) — both have minimal 2-entry MROs as top-level classes; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Future_mro
  kind: python_call_eq
  function: Future.__mro__.__len__
  args: []
  expected: 2

invariant concurrent_futures_extra202.cf_future_mro0_name_eq:
  description: "concurrent.futures.Future.__mro__[0].__name__.__eq__('Future') returns True — Future.__mro__[0].__name__=='Future' (len=6: F-u-t-u-r-e); the first entry in any Python MRO is always the class itself; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Future_mro
  kind: python_call_eq
  function: "concurrent.futures.Future.__mro__.__getitem__(0).__name__.__eq__"
  args: ["Future"]
  expected: true

invariant concurrent_futures_extra202.cf_executor_mro_len_2:
  description: "concurrent.futures.Executor.__mro__.__len__() == 2 — MRO is (Executor, object); Executor is the abstract base class for all executor types and directly inherits from object; Executor.__mro__.__len__(2) < ThreadPoolExecutor.__mro__.__len__(3) by 1 — concrete subclasses have deeper MROs; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Executor_mro
  kind: python_call_eq
  function: Executor.__mro__.__len__
  args: []
  expected: 2

invariant concurrent_futures_extra202.cf_executor_mro0_name_eq:
  description: "concurrent.futures.Executor.__mro__[0].__name__.__eq__('Executor') returns True — Executor.__mro__[0].__name__=='Executor' (len=8: E-x-e-c-u-t-o-r); first entry in Executor's MRO is Executor itself; Executor.__mro__[0].__name__ (8: 'Executor') < ThreadPoolExecutor.__mro__[0].__name__ (18: 'ThreadPoolExecutor') by 10; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Executor_mro
  kind: python_call_eq
  function: "concurrent.futures.Executor.__mro__.__getitem__(0).__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra202.cf_tpe_mro_len_3:
  description: "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3 — MRO is (ThreadPoolExecutor, Executor, object); ThreadPoolExecutor inherits from Executor which inherits from object, creating a 3-step chain; ThreadPoolExecutor.__mro__.__len__(3) > Future.__mro__.__len__(2) by 1 — the executor hierarchy is one step deeper; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ThreadPoolExecutor_mro
  kind: python_call_eq
  function: ThreadPoolExecutor.__mro__.__len__
  args: []
  expected: 3

invariant concurrent_futures_extra202.cf_tpe_mro0_name_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__mro__[0].__name__.__eq__('ThreadPoolExecutor') returns True — ThreadPoolExecutor.__mro__[0].__name__=='ThreadPoolExecutor' (len=18); the first entry in any Python MRO is always the class itself; ThreadPoolExecutor.__mro__[0].__name__ (18) > Executor.__mro__[0].__name__ (8: 'Executor') by 10 — the concrete class name is much longer; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ThreadPoolExecutor_mro
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__mro__.__getitem__(0).__name__.__eq__"
  args: ["ThreadPoolExecutor"]
  expected: true

invariant concurrent_futures_extra202.cf_tpe_mro1_name_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__mro__[1].__name__.__eq__('Executor') returns True — ThreadPoolExecutor.__mro__[1].__name__=='Executor' (len=8); the second entry in ThreadPoolExecutor's MRO is its direct base Executor; ThreadPoolExecutor.__mro__[1].__name__ (8: 'Executor') == Executor.__mro__[0].__name__ (8: 'Executor') — both refer to the same class; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ThreadPoolExecutor_mro
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__mro__.__getitem__(1).__name__.__eq__"
  args: ["Executor"]
  expected: true
