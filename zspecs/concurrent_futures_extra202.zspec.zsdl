spec: concurrent_futures_extra202
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/ (internal scheduling)"
  notes:
    - "concurrent.futures.Future.__mro__ has len=2 (Future, object); Future directly inherits from object."
    - "concurrent.futures.Executor.__mro__ has len=2 (Executor, object); Executor directly inherits from object."
    - "concurrent.futures.ThreadPoolExecutor.__mro__ has len=3 (ThreadPoolExecutor, Executor, object); ThreadPoolExecutor inherits from Executor which inherits from object."
    - "concurrent.futures.Future.__mro__[0].__name__ == 'Future' (len=6); first entry in Future's MRO is Future itself."
    - "concurrent.futures.Future.__mro__[1].__name__ == 'object' (len=6); Future's only base is object."
    - "concurrent.futures.Executor.__mro__[0].__name__ == 'Executor' (len=8); first entry is the class itself."
    - "concurrent.futures.ThreadPoolExecutor.__mro__[0].__name__ == 'ThreadPoolExecutor' (len=18); first entry is the class itself."
    - "concurrent.futures.ThreadPoolExecutor.__mro__[1].__name__ == 'Executor' (len=8); ThreadPoolExecutor's direct base is Executor."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.Future MRO
#
# concurrent.futures.Future.__mro__.__len__() == 2
# concurrent.futures.Future.__mro__[0].__name__ == 'Future' (len=6)
# concurrent.futures.Future.__mro__[1].__name__ == 'object' (len=6)
# ---------------------------------------------------------------------------

table concurrent_futures_extra202.Future_mro_identity:
  description: "concurrent.futures.Future MRO identity checks in cfmro202 namespace — Future.__mro__.__len__()==2 (Future MRO is [Future, object]; concurrent.futures.Future directly inherits from object with no intermediate bases, giving the minimal 2-entry MRO); Future.__mro__[0].__name__=='Future' (len=6: F-u-t-u-r-e; first MRO entry is always the class itself); Future.__mro__[1].__name__=='object' (len=6; object is Future's only base and the final MRO entry); Future.__mro__.__len__(2) == Executor.__mro__.__len__(2) — both are top-level classes with minimal MROs; verified with Python 3.14.3"
  kind: python_call_eq
  category: Future_mro
  id_prefix: cfmro202

  columns: [id, function, args, expected, description]
  rows:
    - ["cf_future_mro_is_tuple",  "concurrent.futures.Future.__mro__.__class__.__name__.__eq__",            ["tuple"],   true, "concurrent.futures.Future.__mro__.__class__.__name__ == 'tuple' — __mro__ is always a tuple; verified Python 3.14.3"]
    - ["cf_future_mro_len",       "concurrent.futures.Future.__mro__.__len__",                               [],          2,    "concurrent.futures.Future.__mro__.__len__() == 2 (MRO is [Future, object]); verified Python 3.14.3"]
    - ["cf_future_mro0_name_eq",  "concurrent.futures.Future.__mro__.__getitem__(0).__name__.__eq__",         ["Future"],  true, "concurrent.futures.Future.__mro__[0].__name__ == 'Future' (len=6; first MRO entry is the class itself); verified Python 3.14.3"]
    - ["cf_future_mro1_name_eq",  "concurrent.futures.Future.__mro__.__getitem__(1).__name__.__eq__",         ["object"],  true, "concurrent.futures.Future.__mro__[1].__name__ == 'object' (len=6; object is the only base and final MRO entry); verified Python 3.14.3"]
    - ["cf_future_mro0_name_len", "concurrent.futures.Future.__mro__.__getitem__(0).__name__.__len__",        [],          6,    "concurrent.futures.Future.__mro__[0].__name__.__len__() == 6 ('Future'=6: F(1)u(2)t(3)u(4)r(5)e(6)); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures.Executor MRO
#
# concurrent.futures.Executor.__mro__.__len__() == 2
# concurrent.futures.Executor.__mro__[0].__name__ == 'Executor' (len=8)
# concurrent.futures.Executor.__mro__[1].__name__ == 'object' (len=6)
# ---------------------------------------------------------------------------

table concurrent_futures_extra202.Executor_mro_identity:
  description: "concurrent.futures.Executor MRO identity checks in cfmro202 namespace — Executor.__mro__.__len__()==2 (Executor MRO is [Executor, object]; Executor is an abstract base class that directly inherits from object, giving the minimal 2-entry MRO); Executor.__mro__[0].__name__=='Executor' (len=8: E-x-e-c-u-t-o-r; first MRO entry is always the class itself); Executor.__mro__[1].__name__=='object' (len=6; object is Executor's only base); Executor.__mro__.__len__(2) < ThreadPoolExecutor.__mro__.__len__(3) by 1 — the concrete subclass has a deeper hierarchy; verified with Python 3.14.3"
  kind: python_call_eq
  category: Executor_mro
  id_prefix: cfmro202

  columns: [id, function, args, expected, description]
  rows:
    - ["cf_exec_mro_len",       "concurrent.futures.Executor.__mro__.__len__",                               [],           2,    "concurrent.futures.Executor.__mro__.__len__() == 2 (MRO is [Executor, object]); verified Python 3.14.3"]
    - ["cf_exec_mro0_name_eq",  "concurrent.futures.Executor.__mro__.__getitem__(0).__name__.__eq__",         ["Executor"], true, "concurrent.futures.Executor.__mro__[0].__name__ == 'Executor' (len=8; first MRO entry is the class itself); verified Python 3.14.3"]
    - ["cf_exec_mro1_name_eq",  "concurrent.futures.Executor.__mro__.__getitem__(1).__name__.__eq__",         ["object"],   true, "concurrent.futures.Executor.__mro__[1].__name__ == 'object' (len=6; object is the only base and final MRO entry); verified Python 3.14.3"]
    - ["cf_exec_mro0_name_len", "concurrent.futures.Executor.__mro__.__getitem__(0).__name__.__len__",        [],           8,    "concurrent.futures.Executor.__mro__[0].__name__.__len__() == 8 ('Executor'=8: E(1)x(2)e(3)c(4)u(5)t(6)o(7)r(8)); verified Python 3.14.3"]
    - ["cf_exec_mro1_name_len", "concurrent.futures.Executor.__mro__.__getitem__(1).__name__.__len__",        [],           6,    "concurrent.futures.Executor.__mro__[1].__name__.__len__() == 6 ('object'=6: o(1)b(2)j(3)e(4)c(5)t(6)); verified Python 3.14.3"]

