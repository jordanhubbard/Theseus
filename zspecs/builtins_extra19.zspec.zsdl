spec: builtins_extra19
version: ">=3.9"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/exceptions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/exceptions.html — Python exceptions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Objects/exceptions.c"
  notes:
    - "This spec extends prior builtins specs."
    - "Warning.__bases__[0].__name__ == 'Exception' — base class for all warning categories."
    - "DeprecationWarning.__bases__[0].__name__ == 'Warning' — for deprecated features."
    - "UserWarning.__bases__[0].__name__ == 'Warning' — for user-generated warnings."
    - "RuntimeWarning.__bases__[0].__name__ == 'Warning' — for dubious runtime behavior."
    - "SyntaxWarning.__bases__[0].__name__ == 'Warning' — for dubious syntax."
    - "FutureWarning.__bases__[0].__name__ == 'Warning' — for future semantic changes."
    - "PendingDeprecationWarning.__bases__[0].__name__ == 'Warning' — for features to be deprecated."
    - "ResourceWarning.__bases__[0].__name__ == 'Warning' — for resource usage issues."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Warning — base class
#
# Warning is the base class for all built-in warning categories. It derives
# directly from Exception.
# ---------------------------------------------------------------------------

invariant builtins_extra19.Warning.base:
  description: "Warning.__bases__[0].__name__ == 'Exception'"
  category: exception_hierarchy
  kind: python_call_eq
  function: Warning.__bases__.__getitem__(0).__name__.__eq__
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# Warning subclasses — base class verification
#
# All standard warning categories derive directly from Warning.
# ---------------------------------------------------------------------------

invariant builtins_extra19.DeprecationWarning.base:
  description: "DeprecationWarning.__bases__[0].__name__ == 'Warning'"
  category: exception_hierarchy
  kind: python_call_eq
  function: DeprecationWarning.__bases__.__getitem__(0).__name__.__eq__
  args: ["Warning"]
  expected: true

invariant builtins_extra19.UserWarning.base:
  description: "UserWarning.__bases__[0].__name__ == 'Warning'"
  category: exception_hierarchy
  kind: python_call_eq
  function: UserWarning.__bases__.__getitem__(0).__name__.__eq__
  args: ["Warning"]
  expected: true

invariant builtins_extra19.RuntimeWarning.base:
  description: "RuntimeWarning.__bases__[0].__name__ == 'Warning'"
  category: exception_hierarchy
  kind: python_call_eq
  function: RuntimeWarning.__bases__.__getitem__(0).__name__.__eq__
  args: ["Warning"]
  expected: true

invariant builtins_extra19.SyntaxWarning.base:
  description: "SyntaxWarning.__bases__[0].__name__ == 'Warning'"
  category: exception_hierarchy
  kind: python_call_eq
  function: SyntaxWarning.__bases__.__getitem__(0).__name__.__eq__
  args: ["Warning"]
  expected: true

invariant builtins_extra19.FutureWarning.base:
  description: "FutureWarning.__bases__[0].__name__ == 'Warning'"
  category: exception_hierarchy
  kind: python_call_eq
  function: FutureWarning.__bases__.__getitem__(0).__name__.__eq__
  args: ["Warning"]
  expected: true

invariant builtins_extra19.PendingDeprecationWarning.base:
  description: "PendingDeprecationWarning.__bases__[0].__name__ == 'Warning'"
  category: exception_hierarchy
  kind: python_call_eq
  function: PendingDeprecationWarning.__bases__.__getitem__(0).__name__.__eq__
  args: ["Warning"]
  expected: true

invariant builtins_extra19.ResourceWarning.base:
  description: "ResourceWarning.__bases__[0].__name__ == 'Warning'"
  category: exception_hierarchy
  kind: python_call_eq
  function: ResourceWarning.__bases__.__getitem__(0).__name__.__eq__
  args: ["Warning"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table for Warning/DeprecationWarning/UserWarning/
# RuntimeWarning/SyntaxWarning/FutureWarning
#
# All are simple non-nested warning classes so __qualname__ equals __name__.
# ---------------------------------------------------------------------------

table builtins_extra19.warning_qualnames:
  description: "__qualname__ attributes for Warning/DeprecationWarning/UserWarning/RuntimeWarning/SyntaxWarning/FutureWarning"
  kind: python_call_eq
  category: exception_classes

  columns: [id, function, args, expected]
  rows:
    - [Warning,                Warning.__qualname__.__eq__,                ["Warning"],                true]
    - [DeprecationWarning,     DeprecationWarning.__qualname__.__eq__,     ["DeprecationWarning"],     true]
    - [UserWarning,            UserWarning.__qualname__.__eq__,            ["UserWarning"],            true]
    - [RuntimeWarning,         RuntimeWarning.__qualname__.__eq__,         ["RuntimeWarning"],         true]
    - [SyntaxWarning,          SyntaxWarning.__qualname__.__eq__,          ["SyntaxWarning"],          true]
    - [FutureWarning,          FutureWarning.__qualname__.__eq__,          ["FutureWarning"],          true]
