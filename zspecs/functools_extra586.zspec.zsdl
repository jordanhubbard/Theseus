spec: functools_extra586
version: ">=3.9"
backend: python_module(functools)
docs: "Identity invariants for functools.partial, functools.partialmethod, and related callables"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__, __module__, and __doc__ identity for partial and partialmethod"
    - "Also covers __qualname__ identity for partialmethod.__init__ and partialmethod.__get__"
    - "Covers __module__ identity for reduce, cmp_to_key, and wraps"
  created_at: "2026-04-12T00:00:00Z"

table ft586cp:
  description: "functools.partial and functools.partialmethod class-level identity properties"
  columns: [id, function, args, expected]
  rows:
    - [ft586cp01, functools.partial.__qualname__.__eq__, ["partial"], true]
    - [ft586cp02, functools.partial.__module__.__eq__, ["functools"], true]
    - [ft586cp03, functools.partial.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ft586cp04, functools.partialmethod.__qualname__.__eq__, ["partialmethod"], true]
    - [ft586cp05, functools.partialmethod.__module__.__eq__, ["functools"], true]
    - [ft586cp06, functools.partialmethod.__doc__.__class__.__name__.__eq__, ["str"], true]

table ft586pm:
  description: "functools.partialmethod method qualname identity"
  columns: [id, function, args, expected]
  rows:
    - [ft586pm01, functools.partialmethod.__init__.__qualname__.__eq__, ["partialmethod.__init__"], true]
    - [ft586pm02, functools.partialmethod.__get__.__qualname__.__eq__, ["partialmethod.__get__"], true]

table ft586rd:
  description: "functools top-level callable __module__ identity"
  columns: [id, function, args, expected]
  rows:
    - [ft586rd01, functools.reduce.__module__.__eq__, ["functools"], true]
    - [ft586rd02, functools.cmp_to_key.__module__.__eq__, ["functools"], true]
    - [ft586rd03, functools.wraps.__module__.__eq__, ["functools"], true]
