spec: select_extra6
version: ">=3.9"
backend: python_module(select)

docs: https://docs.python.org/3/library/select.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/select.html — Python select module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/selectmodule.c"
  notes:
    - "Extends select.zspec.zsdl through select_extra5.zspec.zsdl."
    - "select.zspec.zsdl covers: select.__name__; poll.__name__; kqueue.__name__; kevent.__name__; POLLIN/POLLOUT/POLLERR is_int; KQ_FILTER_READ/WRITE is_int; kqueue()/poll() instance class."
    - "select_extra covers: error.__name__=='error'; error.__bases__[0].__name__=='OSError'; select.__name__; select.__module__."
    - "select_extra2 covers: select.__name__/module; error.__name__=='OSError'; error base=='Exception'; POLLIN==1; POLLOUT==4; KQ_FILTER_READ==-1; KQ_FILTER_WRITE==-2; KQ_EV_ADD/DELETE/ENABLE/DISABLE."
    - "select_extra3 covers: module __name__; poll.__module__; error.__module__; POLLERR>=1; POLLERR==8; POLLHUP==16; POLLNVAL==32."
    - "select_extra4 covers: kqueue/kevent __module__/__qualname__; select.__qualname__; KQ_FILTER_PROC==-5; KQ_FILTER_SIGNAL==-6; KQ_EV_ONESHOT/CLEAR/ERROR/EOF values and types."
    - "select_extra5 covers: PIPE_BUF==512; POLLPRI/POLLRDNORM/POLLWRNORM/POLLRDBAND/POLLWRBAND values and types; KQ_FILTER_AIO/VNODE/TIMER values; KQ_NOTE_DELETE/WRITE/EXTEND/ATTRIB/LINK/RENAME/REVOKE; KQ_NOTE_EXIT/FORK/EXEC."
    - "This spec adds: select.error.__qualname__ (not covered by any prior spec); poll.__qualname__ (not covered in prior specs); POLLIN & POLLOUT == 0 (no shared bits); POLLIN | POLLOUT == 5 (combined mask); POLLIN | POLLERR == 9 (error/read mask); select.__getattribute__('epoll') raises AttributeError on macOS."
    - "select.error.__qualname__ == 'OSError' — select.error is an alias for OSError; its __qualname__ matches its __name__."
    - "poll.__qualname__ == 'poll' — the poll class is a top-level type; qualname matches name. (kqueue.__qualname__ and kevent.__qualname__ are in select_extra4; poll.__qualname__ was not covered.)"
    - "POLLIN & POLLOUT == 0 — the two masks are disjoint (1 & 4 == 0 on macOS)."
    - "POLLIN | POLLOUT == 5 — combined read+write poll mask (1 | 4 == 5 on macOS)."
    - "POLLIN | POLLERR == 9 — combined read+error poll mask (1 | 8 == 9 on macOS)."
    - "select.epoll does not exist on macOS; __getattribute__('epoll') raises AttributeError."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# select.error — __qualname__ attribute
#
# select.zspec.zsdl and select_extra cover error.__name__.
# select_extra3 covers error.__module__.
# No prior spec checks error.__qualname__. select.error is an alias for OSError;
# OSError is a top-level builtin so __qualname__ == __name__ == 'OSError'.
# ---------------------------------------------------------------------------

invariant select_extra6.error.qualname:
  description: "select.error.__qualname__ == 'OSError' — alias for OSError; qualname matches name"
  category: exceptions
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# poll — __qualname__ attribute
#
# select_extra4 covers kqueue.__qualname__ and kevent.__qualname__.
# poll.__qualname__ has NOT been covered by any prior spec.
# ---------------------------------------------------------------------------

invariant select_extra6.poll.qualname:
  description: "select.poll.__qualname__ == 'poll' — top-level C type; qualname equals name"
  category: classes
  kind: python_call_eq
  function: poll.__qualname__.__eq__
  args: ["poll"]
  expected: true

# ---------------------------------------------------------------------------
# POLL bitmask arithmetic — no prior spec tests bitwise combinations
#
# POLLIN == 1, POLLOUT == 4, POLLERR == 8 on macOS/Darwin.
# These combinations are meaningful in practice (e.g., combined interest masks).
# ---------------------------------------------------------------------------

invariant select_extra6.poll_mask.pollin_and_pollout_zero:
  description: "select.POLLIN & select.POLLOUT == 0 — the two masks share no bits on macOS"
  category: constants
  kind: python_call_eq
  function: POLLIN.__and__
  args: [4]
  expected: 0

invariant select_extra6.poll_mask.pollin_or_pollout:
  description: "select.POLLIN | select.POLLOUT == 5 — combined read+write interest mask on macOS"
  category: constants
  kind: python_call_eq
  function: POLLIN.__or__
  args: [4]
  expected: 5

invariant select_extra6.poll_mask.pollin_or_pollerr:
  description: "select.POLLIN | select.POLLERR == 9 — combined read+error poll mask on macOS"
  category: constants
  kind: python_call_eq
  function: POLLIN.__or__
  args: [8]
  expected: 9

# ---------------------------------------------------------------------------
# select.epoll — not available on macOS (raises AttributeError)
#
# select.epoll is a Linux-only I/O notification interface; it does not exist
# on macOS/Darwin. Accessing it via __getattribute__ raises AttributeError.
# No prior spec documents this absence.
# ---------------------------------------------------------------------------

invariant select_extra6.epoll.not_available_on_macos:
  description: "select.__getattribute__('epoll') raises AttributeError on macOS — epoll is Linux-only"
  category: platform
  kind: python_call_raises
  function: __getattribute__
  args: ["epoll"]
  expected: AttributeError
