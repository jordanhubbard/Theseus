spec: socket_extra287
version: ">=3.9"
backend: python_module(socket)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Low-level networking interface"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py, Modules/socketmodule.c"
  notes:
    - "socket is a Python wrapper (Lib/socket.py) over the _socket C extension"
    - "__loader__ is SourceFileLoader because the top-level module is a .py file"
    - "__all__ is a list with 238 entries on this platform"
    - "socket.socket (the class) is a type; AF_INET class is AddressFamily; SOCK_STREAM class is SocketKind"
    - "error, gaierror, gethostname, socket, AF_INET, SOCK_STREAM are all in __all__"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table socket_extra287.module_identity:
  description: "socket module identity attributes"
  kind: python_call_eq
  category: identity
  id_prefix: skex287

  columns: [id, function, args, expected, description]
  rows:
    - [skex287_001, socket.__name__, [], socket, "socket module __name__"]
    - [skex287_002, socket.__package__, [], "", "socket module __package__ is empty string"]
    - [skex287_003, socket.__spec__.__class__.__name__, [], ModuleSpec, "socket __spec__ class"]
    - [skex287_004, socket.__loader__.__class__.__name__, [], SourceFileLoader, "socket __loader__ class (Python wrapper)"]
    - [skex287_005, socket.__all__.__class__.__name__, [], list, "socket __all__ is a list"]

table socket_extra287.all_membership:
  description: "socket.__all__ membership checks for key public names"
  kind: python_call_eq
  category: identity
  id_prefix: skex287b

  columns: [id, function, args, expected, description]
  rows:
    - [skex287b_001, socket.__all__.__contains__, ["socket"], true, "socket class is in __all__"]
    - [skex287b_002, socket.__all__.__contains__, ["AF_INET"], true, "AF_INET is in __all__"]
    - [skex287b_003, socket.__all__.__contains__, ["SOCK_STREAM"], true, "SOCK_STREAM is in __all__"]
    - [skex287b_004, socket.__all__.__contains__, ["error"], true, "error is in __all__"]
    - [skex287b_005, socket.__all__.__contains__, ["gaierror"], true, "gaierror is in __all__"]
    - [skex287b_006, socket.__all__.__contains__, ["gethostname"], true, "gethostname is in __all__"]

invariant socket_extra287.all_is_list:
  description: "socket.__all__ is a list"
  category: identity
  kind: python_call_eq
  function: socket.__all__.__class__.__name__
  args: []
  expected: list

invariant socket_extra287.socket_class_is_type:
  description: "socket.socket (the class) is a type"
  category: identity
  kind: python_call_eq
  function: socket.socket.__class__.__name__
  args: []
  expected: type

invariant socket_extra287.AF_INET_class:
  description: "socket.AF_INET is an AddressFamily enum member"
  category: identity
  kind: python_call_eq
  function: socket.AF_INET.__class__.__name__
  args: []
  expected: AddressFamily

invariant socket_extra287.SOCK_STREAM_class:
  description: "socket.SOCK_STREAM is a SocketKind enum member"
  category: identity
  kind: python_call_eq
  function: socket.SOCK_STREAM.__class__.__name__
  args: []
  expected: SocketKind
