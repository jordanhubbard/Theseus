spec: theseus_struct_cr
version: ">=3.0"
backend: python_cleanroom(theseus_struct_cr)
blocks: struct

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "CPython source: Lib/struct.py"
  notes:
    - "Clean-room struct module. Do NOT import struct."

error_model: python_exceptions

invariant theseus_struct_cr.struct2_pack:
  description: "pack() encodes values to bytes"
  category: behavior
  kind: python_call_eq
  function: struct2_pack
  args: []
  expected: true

invariant theseus_struct_cr.struct2_unpack:
  description: "unpack() decodes bytes to values"
  category: behavior
  kind: python_call_eq
  function: struct2_unpack
  args: []
  expected: true

invariant theseus_struct_cr.struct2_calcsize:
  description: "calcsize() returns correct byte counts"
  category: behavior
  kind: python_call_eq
  function: struct2_calcsize
  args: []
  expected: true
