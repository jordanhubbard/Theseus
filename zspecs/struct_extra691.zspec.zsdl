spec: struct_extra691
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct.Struct method documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.Struct method __name__ and struct.error identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra691.struct_method_names:
  description: "struct.Struct method __name__ and struct.error identity"
  kind: python_call_eq
  category: struct_method_names
  id_prefix: st691mn
  columns: [id, function, args, expected]
  rows:
    - [st691mn001, struct.Struct.__init__.__name__.__eq__,       ["__init__"],    true]
    - [st691mn002, struct.Struct.__repr__.__name__.__eq__,       ["__repr__"],    true]
    - [st691mn003, struct.Struct.pack.__name__.__eq__,           ["pack"],        true]
    - [st691mn004, struct.Struct.unpack.__name__.__eq__,         ["unpack"],      true]
    - [st691mn005, struct.Struct.pack_into.__name__.__eq__,      ["pack_into"],   true]
    - [st691mn006, struct.Struct.unpack_from.__name__.__eq__,    ["unpack_from"], true]
    - [st691mn007, struct.Struct.iter_unpack.__name__.__eq__,    ["iter_unpack"], true]
    - [st691mn008, struct.Struct.calcsize.__name__.__eq__,       ["calcsize"],    true]
    - [st691mn009, struct.error.__name__.__eq__,                 ["error"],       true]
    - [st691mn010, struct.error.__init__.__name__.__eq__,        ["__init__"],    true]
    - [st691mn011, struct.error.__str__.__name__.__eq__,         ["__str__"],     true]
    - [st691mn012, struct.error.__repr__.__name__.__eq__,        ["__repr__"],    true]
