       "count.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.count.__class__.__name__.__eq__('type') == True — count is a C extension type; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra141"]
    - [count_doc_class_eq_str,
       "count.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.count.__doc__.__class__.__name__.__eq__('str') == True — the count docstring is a plain Python str; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra141"]
    - [count_doc_len_eq_205,
       "count.__doc__.__len__",
       [],
       205,
       "itertools.count.__doc__.__len__() == 205 — the count docstring has 205 characters; len(__doc__) == 205; verified with Python 3.14.3; new to extra141"]
    - [count_name_eq,
       "count.__name__.__eq__",
       ["count"],
       true,
       "itertools.count.__name__.__eq__('count') == True — the C type's __name__ is 'count'; str.__eq__('count') returns True; new to extra141"]
    - [count_name_len_eq_5,
       "count.__name__.__len__",
       [],
       5,
       "itertools.count.__name__.__len__() == 5 — __name__ is 'count' which has 5 characters; len('count') == 5; new to extra141"]
    - [count_module_eq_itertools,
       "count.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.count.__module__.__eq__('itertools') == True — count is defined in itertoolsmodule.c; __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra141"]
    - [count_mro_len_eq_2,
       "count.__mro__.__len__",
       [],
       2,
       "itertools.count.__mro__.__len__() == 2 — count's MRO is [count, object]; len(__mro__) is 2; new to extra141"]

