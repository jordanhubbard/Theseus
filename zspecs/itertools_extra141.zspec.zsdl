spec: itertools_extra141
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.count (C type), itertools.cycle (C type), itertools.repeat (C type), itertools.dropwhile (C type), itertools.takewhile (C type), itertools.filterfalse (C type) — doc string class, doc string len, __name__, __module__, MRO (Wave 269)."
    - "All six are C extension types defined in itertoolsmodule.c; their __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.count.__doc__ len == 205. Verified with Python 3.14.3."
    - "itertools.cycle.__doc__ len == 95. Verified with Python 3.14.3."
    - "itertools.repeat.__doc__ len == 154. Verified with Python 3.14.3."
    - "itertools.dropwhile.__doc__ len == 126. Verified with Python 3.14.3."
    - "itertools.takewhile.__doc__ len == 101. Verified with Python 3.14.3."
    - "itertools.filterfalse.__doc__ len == 120; __name__ == 'filterfalse' (len 11). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.count — C type doc string, name, module, MRO
#
# Wave 269 theme: itertools.count — C extension type in itertoolsmodule.c.
#
# itertools.count.__class__.__name__ == 'type'
# itertools.count.__doc__.__class__.__name__ == 'str'
# len(itertools.count.__doc__) == 205
# itertools.count.__name__ == 'count' (len 5)
# itertools.count.__module__ == 'itertools' (len 9)
# len(itertools.count.__mro__) == 2
#
# count(start=0, step=1) yields an infinite evenly spaced sequence.
# New to extra141.
# ---------------------------------------------------------------------------

table itertools_extra141.count_type_attrs:
  description: "itertools.count: C type, __doc__ str len 205, __name__ len 5, __module__ 'itertools', MRO len 2; wave 269; new to extra141"
