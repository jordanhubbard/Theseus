spec: datetime_extra18
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
    - "datetime_extra17.zspec.zsdl — covers date/datetime/timedelta dunder operator method __qualname__ (add/sub/eq/hash/mul); timezone.__qualname__ standalone."
    - "datetime_extra16.zspec.zsdl — covers __qualname__ for date/datetime method descriptors (today, fromisoformat, strftime, isoformat, now, strptime); time.isoformat; timedelta.__qualname__."
    - "datetime_extra15.zspec.zsdl — covers MINYEAR/MAXYEAR __class__.__qualname__; resolution __class__.__name__ table; six-class __qualname__ table."
    - "datetime_extra12.zspec.zsdl — covers __qualname__ for all six classes as standalone invariants; __module__ table for five classes; MINYEAR/MAXYEAR values and class names."
    - "datetime_extra11.zspec.zsdl — covers MINYEAR/MAXYEAR __class__.__name__."
  notes:
    - "This spec extends datetime.zspec.zsdl and prior extras through datetime_extra17.zspec.zsdl."
    - "NEW in extra18 — Axis 1: timedelta.total_seconds.__qualname__ == 'timedelta.total_seconds' — compound dotted qualname for the method descriptor."
    - "NEW in extra18 — Axis 2: timezone.utc.__class__.__qualname__ == 'timezone' — qualname of utc singleton's class; prior specs check __class__.__name__, not __qualname__."
    - "NEW in extra18 — Axis 3: MINYEAR.__class__.__module__ and MAXYEAR.__class__.__module__ == 'builtins' — the int type lives in the builtins module."
    - "NEW in extra18 — Axis 4: timedelta.__qualname__.__class__.__name__ and timezone.__module__.__class__.__name__ type axes — class qualname and module are both strings."
    - "datetime_extra1 checks timezone.utc.__class__.__name__ == 'timezone'. No prior spec checks __class__.__qualname__ for the utc singleton."
    - "datetime_timedelta.zspec.zsdl and extra3 note total_seconds coverage in the timedelta spec. No extra spec checks total_seconds.__qualname__."
    - "datetime.timedelta.total_seconds.__qualname__ == 'timedelta.total_seconds' — compound qualname for C method_descriptor; verified Python 3.12."
    - "datetime.timezone.utc.__class__.__qualname__ == 'timezone' — flat qualname for the C timezone type; verified Python 3.12."
    - "datetime.MINYEAR.__class__.__module__ == 'builtins' — int is defined in builtins; verified Python 3.12."
    - "datetime.MAXYEAR.__class__.__module__ == 'builtins' — int is defined in builtins; verified Python 3.12."
    - "datetime.timedelta.__qualname__.__class__.__name__ == 'str' — qualname attribute is a plain string; verified Python 3.12."
    - "datetime.timezone.__module__.__class__.__name__ == 'str' — module attribute is a plain string; verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# timedelta.total_seconds.__qualname__
#
# datetime_extra16 checks __qualname__ for date/datetime method descriptors.
# No extra spec checks total_seconds.__qualname__.  As a method_descriptor on
# the timedelta C type, its qualname uses the compound dotted form.
# ---------------------------------------------------------------------------

invariant datetime_extra18.timedelta.total_seconds.qualname:
  description: "datetime.timedelta.total_seconds.__qualname__ == 'timedelta.total_seconds' — compound method qualname"
  category: method_qualnames
  kind: python_call_eq
  function: timedelta.total_seconds.__qualname__.__eq__
  args: ["timedelta.total_seconds"]
  expected: true

# ---------------------------------------------------------------------------
# timezone.utc.__class__.__qualname__
#
# datetime_extra (extra1) checks timezone.utc.__class__.__name__ == 'timezone'.
# No prior spec checks __class__.__qualname__ for the utc singleton.
# For the C timezone type, __qualname__ and __name__ both equal 'timezone'.
# ---------------------------------------------------------------------------

invariant datetime_extra18.timezone.utc.class_qualname:
  description: "datetime.timezone.utc.__class__.__qualname__ == 'timezone' — utc singleton's type qualname"
  category: class_attrs
  kind: python_call_eq
  function: timezone.utc.__class__.__qualname__.__eq__
  args: ["timezone"]
  expected: true

# ---------------------------------------------------------------------------
# MINYEAR and MAXYEAR — __class__.__module__
#
# datetime_extra11 and extra12 check MINYEAR/MAXYEAR __class__.__name__ == 'int'.
# datetime_extra15 checks MINYEAR/MAXYEAR __class__.__qualname__ == 'int'.
# No prior spec checks __class__.__module__ for these constants.  The int type
# is defined in the 'builtins' module, so __class__.__module__ == 'builtins'.
# ---------------------------------------------------------------------------

invariant datetime_extra18.MINYEAR.class_module:
  description: "datetime.MINYEAR.__class__.__module__ == 'builtins' — int type is defined in builtins"
  category: constant_types
  kind: python_call_eq
  function: MINYEAR.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant datetime_extra18.MAXYEAR.class_module:
  description: "datetime.MAXYEAR.__class__.__module__ == 'builtins' — int type is defined in builtins"
  category: constant_types
  kind: python_call_eq
  function: MAXYEAR.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# Type axes for timedelta.__qualname__ and timezone.__module__
#
# No prior datetime spec checks the __class__.__name__ of the timedelta
# __qualname__ string or the timezone __module__ string.  Both are plain str
# instances; this axis is novel for the datetime module in this namespace.
# ---------------------------------------------------------------------------

invariant datetime_extra18.timedelta.qualname.class_name:
  description: "datetime.timedelta.__qualname__.__class__.__name__ == 'str' — qualname is a string"
  category: type_attrs
  kind: python_call_eq
  function: timedelta.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant datetime_extra18.timezone.module.class_name:
  description: "datetime.timezone.__module__.__class__.__name__ == 'str' — __module__ is a string"
  category: type_attrs
  kind: python_call_eq
  function: timezone.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all six new invariants
#
# All six are first covered in this spec (datetime_extra18).
# ---------------------------------------------------------------------------

table datetime_extra18.new_axes:
  description: "datetime timedelta.total_seconds qualname, utc class qualname, MINYEAR/MAXYEAR class module, type axes"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: dte18

  columns: [id, function, args, expected]
  rows:
    - [total_seconds_qn,         timedelta.total_seconds.__qualname__.__eq__,           ["timedelta.total_seconds"], true]
    - [utc_class_qualname,        timezone.utc.__class__.__qualname__.__eq__,            ["timezone"],               true]
    - [MINYEAR_class_module,      MINYEAR.__class__.__module__.__eq__,                   ["builtins"],               true]
    - [MAXYEAR_class_module,      MAXYEAR.__class__.__module__.__eq__,                   ["builtins"],               true]
    - [timedelta_qn_type,         timedelta.__qualname__.__class__.__name__.__eq__,      ["str"],                    true]
    - [timezone_module_type,      timezone.__module__.__class__.__name__.__eq__,         ["str"],                    true]
