spec: socket_extra378
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "socket.timeout.__name__ == 'TimeoutError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.has_ipv6 == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX == 1 on macOS. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_RAW == 3 on macOS. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SHUT_RD == 0 on macOS. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SHUT_WR == 1 on macOS. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SHUT_RDWR == 2 on macOS. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' (IntEnum). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_RAW.__class__.__name__ == 'SocketKind' (IntEnum). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SHUT_RDWR.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.timeout and socket.error are aliases for builtins.TimeoutError and builtins.OSError respectively. They were deprecated aliases kept for backward compatibility with pre-3.3 Python code."
    - "Note: socket.AF_UNIX and socket.SOCK_RAW are IntEnum members (AddressFamily and SocketKind), so integer equality comparisons work via inherited int.__eq__."
    - "Note: SHUT_RD/SHUT_WR/SHUT_RDWR are plain int constants on macOS (not enum members). Values 0/1/2 match POSIX SHUT_RD/SHUT_WR/SHUT_RDWR definitions."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.timeout and socket.error — backward-compatibility aliases
#
# Wave 378 theme: socket module aliases, has_ipv6, and shutdown/socket
# constants on macOS.
#
# socket.timeout is an alias for the built-in TimeoutError exception (since
# Python 3.3). Before 3.3, socket operations raised socket.timeout; from 3.3
# onward, OSError subclasses were unified and socket.timeout became an alias
# for the built-in TimeoutError. Its __name__ is 'TimeoutError' and its
# __module__ is 'builtins'.
#
# socket.error is an alias for the built-in OSError (since Python 3.3).
# Before 3.3, socket.error was a distinct exception class. Now it is exactly
# the same object as builtins.OSError. Its __name__ is 'OSError' and
# __module__ is 'builtins'.
#
# socket.has_ipv6 is a compile-time bool indicating whether the platform
# supports IPv6. On modern macOS with a current CPython build, this is True.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra378.alias_exception_names:
  description: "socket.timeout and socket.error are aliases for builtins — timeout.__name__ is 'TimeoutError', error.__name__ is 'OSError'; both were unified with built-in exceptions in Python 3.3; __module__ is 'builtins' for both; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: exception_identity
  id_prefix: socketaliasid378

  columns: [id, function, args, expected]
  rows:
    - [timeout_name,   timeout.__name__.__eq__,   ["TimeoutError"], true]
    - [timeout_module, timeout.__module__.__eq__,  ["builtins"],     true]
    - [error_name,     error.__name__.__eq__,     ["OSError"],      true]
    - [error_module,   error.__module__.__eq__,    ["builtins"],     true]

invariant socket_extra378.has_ipv6:
  description: "socket.has_ipv6.__eq__(True) == True — has_ipv6 is a compile-time boolean indicating IPv6 support; True on modern macOS CPython builds; set at import time by the _socket C extension based on AF_INET6 availability; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: constant_value
  kind: python_call_eq
  function: has_ipv6.__eq__
  args: [true]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_UNIX, socket.SOCK_RAW — integer values on macOS
#
# AF_UNIX is address family 1 on macOS (and most POSIX systems). It is an
# AddressFamily IntEnum member. AF_UNIX sockets communicate between processes
# on the same host using filesystem paths as addresses.
#
# SOCK_RAW is socket kind 3 on macOS (and most POSIX systems). It is a
# SocketKind IntEnum member. SOCK_RAW provides raw access to the transport
# layer, bypassing the normal TCP/UDP socket handling; usually requires
# elevated privileges.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra378.socket_constants_macos:
  description: "socket constants numeric values on macOS — AF_UNIX==1 (AddressFamily IntEnum), SOCK_RAW==3 (SocketKind IntEnum); integer equality works because IntEnum inherits from int; values match POSIX BSD socket constants; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: constant_value
  id_prefix: socketconst378

  columns: [id, function, args, expected]
  rows:
    - [af_unix_val,  AF_UNIX.__eq__,   [1], true]
    - [sock_raw_val, SOCK_RAW.__eq__,  [3], true]

# ---------------------------------------------------------------------------
# socket.SHUT_RD, socket.SHUT_WR, socket.SHUT_RDWR — shutdown direction constants
#
# The SHUT_* constants control which direction(s) of a socket connection to
# shut down when calling socket.shutdown(). They are plain int constants on
# macOS (not IntEnum members — SHUT_RDWR.__class__.__name__ is 'int').
#
# SHUT_RD (0): Shut down the receive half; further receives will fail.
# SHUT_WR (1): Shut down the send half; further sends will fail.
# SHUT_RDWR (2): Shut down both directions simultaneously.
#
# These values match the POSIX definitions from <sys/socket.h>:
# SHUT_RD=0, SHUT_WR=1, SHUT_RDWR=2.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra378.shut_constants:
  description: "socket SHUT_* constants on macOS — SHUT_RD==0, SHUT_WR==1, SHUT_RDWR==2; plain int constants (not IntEnum) matching POSIX <sys/socket.h> definitions; control shutdown direction for socket.shutdown(); verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: constant_value
  id_prefix: socketshut378

  columns: [id, function, args, expected]
  rows:
    - [shut_rd_val,   SHUT_RD.__eq__,   [0], true]
    - [shut_wr_val,   SHUT_WR.__eq__,   [1], true]
    - [shut_rdwr_val, SHUT_RDWR.__eq__, [2], true]
