spec: abc_extra1816
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 568 (_extra1816): __format__ string formatting protocol; __reduce__/__copy__/__deepcopy__ copy/pickle protocol; ABCMeta class creation protocol dict-presence checks for abc types."
    - "abc.ABC.__dict__ does not contain __format__, __repr__, or __str__ (all inherited from object)."
    - "abc.ABCMeta.__dict__ contains __new__ (the metaclass defines __new__ for class creation bookkeeping)."
    - "abc.ABCMeta.__dict__ does not contain __init__ (uses type.__init__)."
    - "abc.abstractmethod.__dict__ contains __init__ (the decorator is a class with __init__)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra1816.format_protocol:
  description: "abc types __format__/__repr__/__str__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1816

  columns: [id, function, args, expected]
  rows:
    - ["ab1816001", "abc.ABC.__dict__.__contains__", ["__format__"], false]
    - ["ab1816002", "abc.ABC.__dict__.__contains__", ["__repr__"], false]
    - ["ab1816003", "abc.ABC.__dict__.__contains__", ["__str__"], false]
    - ["ab1816004", "abc.ABCMeta.__dict__.__contains__", ["__repr__"], false]
    - ["ab1816005", "abc.ABCMeta.__dict__.__contains__", ["__str__"], false]
    - ["ab1816006", "abc.abstractmethod.__dict__.__contains__", ["__repr__"], false]
    - ["ab1816007", "abc.abstractmethod.__dict__.__contains__", ["__str__"], false]
    - ["ab1816008", "abc.abstractmethod.__dict__.__contains__", ["__format__"], false]

table abc_extra1816.copy_protocol:
  description: "abc types __reduce__/__copy__/__deepcopy__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1816

  columns: [id, function, args, expected]
  rows:
    - ["ab1816101", "abc.ABC.__dict__.__contains__", ["__reduce__"], false]
    - ["ab1816102", "abc.ABC.__dict__.__contains__", ["__copy__"], false]
    - ["ab1816103", "abc.ABC.__dict__.__contains__", ["__deepcopy__"], false]
    - ["ab1816104", "abc.ABCMeta.__dict__.__contains__", ["__reduce__"], false]
    - ["ab1816105", "abc.abstractmethod.__dict__.__contains__", ["__reduce__"], false]
    - ["ab1816106", "abc.abstractmethod.__dict__.__contains__", ["__copy__"], false]
    - ["ab1816107", "abc.abstractmethod.__dict__.__contains__", ["__deepcopy__"], false]
    - ["ab1816108", "abc.ABCMeta.__dict__.__contains__", ["__copy__"], false]

table abc_extra1816.abcmeta_creation_protocol:
  description: "ABCMeta class creation protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1816

  columns: [id, function, args, expected]
  rows:
    - ["ab1816201", "abc.ABCMeta.__dict__.__contains__", ["__new__"], true]
    - ["ab1816202", "abc.ABCMeta.__dict__.__contains__", ["__init__"], false]
    - ["ab1816203", "abc.ABCMeta.__dict__.__contains__", ["__prepare__"], false]
    - ["ab1816204", "abc.ABCMeta.__dict__.__contains__", ["__setattr__"], false]
    - ["ab1816205", "abc.ABC.__dict__.__contains__", ["__init_subclass__"], false]
    - ["ab1816206", "abc.ABC.__dict__.__contains__", ["__new__"], false]
    - ["ab1816207", "abc.abstractmethod.__dict__.__contains__", ["__init__"], true]
    - ["ab1816208", "abc.abstractmethod.__dict__.__contains__", ["__new__"], false]
