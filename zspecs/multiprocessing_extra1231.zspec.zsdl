spec: multiprocessing_extra1231
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing.__dict__.__contains__ for Process, Queue, Lock, Pool, Manager, cpu_count, current_process, active_children, Pipe, Value, Array, Semaphore, Event, Condition, RLock, JoinableQueue, SimpleQueue, Barrier, freeze_support, set_start_method, get_start_method, get_context"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing.__dict__.__contains__ for class names, callable names, and absent names (Thread, Future, Executor, nonexistent); also checks module __name__ length and cpu_count callable class — behaviors not covered by extra1201 (__bases__.__len__) or extra1216 (__mro__.__len__)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1231.dict_contains_classes:
  description: "multiprocessing.__dict__ contains Process, Queue, Lock, Pool, Manager, Pipe, Value, Array, Semaphore, Event, Condition, RLock, JoinableQueue, SimpleQueue, Barrier"
  kind: python_call_eq
  category: module_interface
  id_prefix: mp1231dc
  columns: [id, function, args, expected]
  rows:
    - [mp1231dc001, multiprocessing.__dict__.__contains__, ["Process"],       true]
    - [mp1231dc002, multiprocessing.__dict__.__contains__, ["Queue"],         true]
    - [mp1231dc003, multiprocessing.__dict__.__contains__, ["Lock"],          true]
    - [mp1231dc004, multiprocessing.__dict__.__contains__, ["Pool"],          true]
    - [mp1231dc005, multiprocessing.__dict__.__contains__, ["Manager"],       true]
    - [mp1231dc006, multiprocessing.__dict__.__contains__, ["Pipe"],          true]
    - [mp1231dc007, multiprocessing.__dict__.__contains__, ["Value"],         true]
    - [mp1231dc008, multiprocessing.__dict__.__contains__, ["Array"],         true]
    - [mp1231dc009, multiprocessing.__dict__.__contains__, ["Semaphore"],     true]
    - [mp1231dc010, multiprocessing.__dict__.__contains__, ["Event"],         true]
    - [mp1231dc011, multiprocessing.__dict__.__contains__, ["Condition"],     true]
    - [mp1231dc012, multiprocessing.__dict__.__contains__, ["RLock"],         true]
    - [mp1231dc013, multiprocessing.__dict__.__contains__, ["JoinableQueue"], true]
    - [mp1231dc014, multiprocessing.__dict__.__contains__, ["SimpleQueue"],   true]
    - [mp1231dc015, multiprocessing.__dict__.__contains__, ["Barrier"],       true]

table multiprocessing_extra1231.dict_contains_functions:
  description: "multiprocessing.__dict__ contains cpu_count, current_process, active_children, freeze_support, set_start_method, get_start_method, get_context"
  kind: python_call_eq
  category: module_interface
  id_prefix: mp1231df
  columns: [id, function, args, expected]
  rows:
    - [mp1231df001, multiprocessing.__dict__.__contains__, ["cpu_count"],        true]
    - [mp1231df002, multiprocessing.__dict__.__contains__, ["current_process"],  true]
    - [mp1231df003, multiprocessing.__dict__.__contains__, ["active_children"],  true]
    - [mp1231df004, multiprocessing.__dict__.__contains__, ["freeze_support"],   true]
    - [mp1231df005, multiprocessing.__dict__.__contains__, ["set_start_method"], true]
    - [mp1231df006, multiprocessing.__dict__.__contains__, ["get_start_method"], true]
    - [mp1231df007, multiprocessing.__dict__.__contains__, ["get_context"],      true]

table multiprocessing_extra1231.dict_absent_names_and_module_attrs:
  description: "multiprocessing.__dict__ does NOT contain Thread, Future, Executor, nonexistent; also checks module __name__ length and cpu_count callable class"
  kind: python_call_eq
  category: module_interface
  id_prefix: mp1231ab
  columns: [id, function, args, expected]
  rows:
    - [mp1231ab001, multiprocessing.__dict__.__contains__, ["Thread"],      false]
    - [mp1231ab002, multiprocessing.__dict__.__contains__, ["Future"],      false]
    - [mp1231ab003, multiprocessing.__dict__.__contains__, ["Executor"],    false]
    - [mp1231ab004, multiprocessing.__dict__.__contains__, ["nonexistent"], false]
    - [mp1231ab005, multiprocessing.__name__.__eq__,       ["multiprocessing"], true]
    - [mp1231ab006, multiprocessing.__name__.__len__.__eq__, [15],          true]
    - [mp1231ab007, multiprocessing.cpu_count.__class__.__name__.__eq__,     ["method"], true]
    - [mp1231ab008, multiprocessing.cpu_count.__qualname__.__contains__,     ["cpu_count"], true]
