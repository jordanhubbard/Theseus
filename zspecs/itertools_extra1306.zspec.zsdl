spec: itertools_extra1306
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave 534 (_extra1306): focuses on exception-raising behavior for bad argument types and counts."
    - "itertools.chain.from_iterable(42) raises TypeError because 42 is not iterable."
    - "itertools.count('a') raises TypeError when the iterator is advanced (next() call)."
    - "itertools.repeat() with no args raises TypeError."
    - "itertools.islice([], -1) raises ValueError because stop must be non-negative."
    - "itertools.islice([], 'a') raises ValueError because stop must be an integer."
    - "itertools.combinations([], -1) raises ValueError because r must be non-negative."
    - "itertools.combinations([], 'a') raises TypeError because r must be an integer."
    - "itertools.accumulate() with no args raises TypeError."
    - "itertools.cycle() with no args raises TypeError."
    - "itertools.dropwhile() with no args raises TypeError."
    - "itertools.takewhile() with no args raises TypeError."
    - "itertools.permutations([], -1) raises ValueError because r must be non-negative."
    - "All exceptions verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table itertools_extra1306.missing_args_type_errors:
  description: "itertools functions raise TypeError when called with no arguments"
  kind: python_call_raises
  category: type_errors
  id_prefix: it1306ma
  columns: [id, function, args, exception]
  rows:
    - [it1306ma001, itertools.accumulate,  [], "TypeError"]
    - [it1306ma002, itertools.repeat,      [], "TypeError"]
    - [it1306ma003, itertools.cycle,       [], "TypeError"]
    - [it1306ma004, itertools.dropwhile,   [], "TypeError"]
    - [it1306ma005, itertools.takewhile,   [], "TypeError"]
    - [it1306ma006, itertools.combinations, [], "TypeError"]

table itertools_extra1306.non_iterable_type_errors:
  description: "itertools functions raise TypeError when passed a non-iterable where an iterable is required"
  kind: python_call_raises
  category: type_errors
  id_prefix: it1306ni
  columns: [id, function, args, exception]
  rows:
    - [it1306ni001, itertools.chain.from_iterable, [42],       "TypeError"]
    - [it1306ni002, itertools.chain.from_iterable, [null],     "TypeError"]
    - [it1306ni003, itertools.count,               ["a"],      "TypeError"]
    - [it1306ni004, itertools.combinations,        [[], "a"],  "TypeError"]
    - [it1306ni005, itertools.groupby,             [42],       "TypeError"]
    - [it1306ni006, itertools.filterfalse,         [null, 42], "TypeError"]

table itertools_extra1306.negative_count_value_errors:
  description: "itertools functions raise ValueError when given negative or invalid integer count arguments"
  kind: python_call_raises
  category: value_errors
  id_prefix: it1306nc
  columns: [id, function, args, exception]
  rows:
    - [it1306nc001, itertools.islice,        [[], -1],    "ValueError"]
    - [it1306nc002, itertools.islice,        [[], "a"],   "ValueError"]
    - [it1306nc003, itertools.combinations,  [[], -1],    "ValueError"]
    - [it1306nc004, itertools.permutations,  [[], -1],    "ValueError"]
    - [it1306nc005, itertools.combinations_with_replacement, [[], -1], "ValueError"]
    - [it1306nc006, itertools.islice,        [[], 0, -1], "ValueError"]
