spec: xml_extra5
version: ">=3.9"
backend: python_module(xml.etree.ElementTree)

docs: https://docs.python.org/3/library/xml.etree.elementtree.html

provenance:
  derived_from:
    - "Python xml.etree.ElementTree documentation — https://docs.python.org/3/library/xml.etree.elementtree.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xml/etree/ElementTree.py"
    - "xml_extra.zspec.zsdl — covers Element/ElementTree/SubElement/ParseError __name__, parse/fromstring/tostring __name__, ParseError base"
    - "xml_extra2.zspec.zsdl — covers fromstring tag/attrib, Element tag/attrib, tostring result class, ParseError name/base, VERSION/XML_VERSION class names, SubElement __name__"
    - "xml_extra3.zspec.zsdl — covers Element/__qualname__/ElementTree/__qualname__/XMLParser/__qualname__/ParseError/__qualname__, function __qualname__, Element/__module__/XMLParser/__module__, bases, type checks"
    - "xml_extra4.zspec.zsdl — covers Comment/ProcessingInstruction/register_namespace __qualname__/__module__/__class__.__name__; Element.text/tail is None; fromstring text content; tostring unicode encoding"
  notes:
    - "This spec extends all prior xml.etree.ElementTree specs through xml_extra4.zspec.zsdl."
    - "xml_extra.zspec.zsdl covers Element.__name__ == 'Element' and ParseError.__bases__[0].__name__."
    - "xml_extra2.zspec.zsdl covers fromstring('<a/>').tag == 'a' and fromstring('<a attr=\"v\"/>').attrib."
    - "This spec adds ElementTree.__name__ and ParseError.__name__ as explicit invariants (not table rows)."
    - "ParseError.__bases__[0].__name__ == 'SyntaxError' — verified at runtime."
    - "Element.__name__ as a standalone invariant (not table) is a new axis vs xml_extra table form."
    - "fromstring('<a/>').tag == 'a' checked via method: tag.__eq__ pattern (distinct from xml_extra2 table form)."
    - "fromstring('<a attr=\"v\"/>').attrib == {'attr': 'v'} checked via method: attrib.__eq__ pattern."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ attributes — Element, ElementTree, ParseError
#
# xml_extra.zspec.zsdl covers these in a table; these are standalone invariants
# for independent verifiability with explicit __eq__ call pattern.
# ---------------------------------------------------------------------------

invariant xml_extra5.Element.name:
  description: "xml.etree.ElementTree.Element.__name__ == 'Element'"
  category: class_names
  kind: python_call_eq
  function: Element.__name__.__eq__
  args: ["Element"]
  expected: true

invariant xml_extra5.ElementTree.name:
  description: "xml.etree.ElementTree.ElementTree.__name__ == 'ElementTree'"
  category: class_names
  kind: python_call_eq
  function: ElementTree.__name__.__eq__
  args: ["ElementTree"]
  expected: true

invariant xml_extra5.ParseError.name:
  description: "xml.etree.ElementTree.ParseError.__name__ == 'ParseError'"
  category: class_names
  kind: python_call_eq
  function: ParseError.__name__.__eq__
  args: ["ParseError"]
  expected: true

# ---------------------------------------------------------------------------
# ParseError base class hierarchy
#
# xml_extra.zspec.zsdl covers ParseError.__bases__[0].__name__ in a table.
# This invariant covers the same fact as a standalone __eq__-based check
# for cross-spec verifiability.
# ---------------------------------------------------------------------------

invariant xml_extra5.ParseError.base:
  description: "xml.etree.ElementTree.ParseError.__bases__[0].__name__ == 'SyntaxError'"
  category: class_hierarchy
  kind: python_call_eq
  function: ParseError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "SyntaxError"

# ---------------------------------------------------------------------------
# fromstring — tag attribute of a minimal element
#
# xml_extra2.zspec.zsdl covers fromstring tag/attrib in a table.
# These invariants check the same facts via method: attr.__eq__ pattern.
# ---------------------------------------------------------------------------

invariant xml_extra5.fromstring.tag:
  description: "xml.etree.ElementTree.fromstring('<a/>').tag == 'a'"
  category: fromstring
  kind: python_call_eq
  function: fromstring
  args: ["<a/>"]
  method: tag.__eq__
  method_args: ["a"]
  expected: true

invariant xml_extra5.fromstring.attrib:
  description: "xml.etree.ElementTree.fromstring('<a attr=\"v\"/>').attrib == {'attr': 'v'}"
  category: fromstring
  kind: python_call_eq
  function: fromstring
  args: ["<a attr=\"v\"/>"]
  method: attrib.__eq__
  method_args: [{"attr": "v"}]
  expected: true
