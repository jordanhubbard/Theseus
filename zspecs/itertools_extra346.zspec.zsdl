spec: itertools_extra346
version: ">=3.0"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "itertools.accumulate.__qualname__ == 'accumulate' — top-level C type, qualname equals name."
    - "itertools.accumulate.__doc__.__len__() == 69 — accumulate docstring length verified on Python 3.14 macOS."
    - "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — nested descriptor qualname."
    - "itertools.chain.__qualname__ == 'chain' — top-level C type."
    - "itertools.count.__qualname__ == 'count' — top-level C type."
    - "itertools.cycle.__qualname__ == 'cycle' — top-level C type."
    - "itertools.repeat.__qualname__ == 'repeat' — top-level C type."
    - "itertools.islice.__qualname__ == 'islice' — top-level C type."
    - "itertools.zip_longest.__qualname__ == 'zip_longest' — top-level C type."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.accumulate — __qualname__ and __doc__ length
# ---------------------------------------------------------------------------

invariant itertools_extra346.accumulate.qualname:
  description: "itertools.accumulate.__qualname__ == 'accumulate'"
  category: qualnames
  kind: python_call_eq
  function: accumulate.__qualname__.__eq__
  args: ["accumulate"]
  expected: true

invariant itertools_extra346.accumulate.doc_length:
  description: "itertools.accumulate.__doc__.__len__() == 69"
  category: qualnames
  kind: python_call_eq
  function: accumulate.__doc__.__len__
  args: []
  expected: 69

# ---------------------------------------------------------------------------
# itertools.chain — __qualname__ and chain.from_iterable.__qualname__
# ---------------------------------------------------------------------------

invariant itertools_extra346.chain.qualname:
  description: "itertools.chain.__qualname__ == 'chain'"
  category: qualnames
  kind: python_call_eq
  function: chain.__qualname__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra346.chain.from_iterable.qualname:
  description: "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'"
  category: qualnames
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__eq__
  args: ["chain.from_iterable"]
  expected: true

