spec: functools_extra121
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra120.zspec.zsdl."
    - "This spec covers: functools.cached_property descriptor method code object parameter names — __set_name__ co_varnames (owner, name), __get__ co_varnames (instance, owner), __init__ co_varnames (func); MRO entry names; __name__ length 15; wave 267."
    - "functools.cached_property.__mro__[0].__name__ == 'cached_property'. Verified with Python 3.14.3."
    - "functools.cached_property.__mro__[1].__name__ == 'object'. Verified with Python 3.14.3."
    - "functools.cached_property.__set_name__.__code__.co_varnames[1] == 'owner'. Verified with Python 3.14.3."
    - "functools.cached_property.__set_name__.__code__.co_varnames[2] == 'name'. Verified with Python 3.14.3."
    - "functools.cached_property.__set_name__.__code__.co_argcount == 3. Verified with Python 3.14.3."
    - "functools.cached_property.__get__.__code__.co_varnames[1] == 'instance'. Verified with Python 3.14.3."
    - "functools.cached_property.__get__.__code__.co_argcount == 3. Verified with Python 3.14.3."
    - "functools.cached_property.__init__.__code__.co_varnames[1] == 'func'. Verified with Python 3.14.3."
    - "functools.cached_property.__name__.__len__() == 15. Verified with Python 3.14.3."
    - "functools.cached_property.__module__.__len__() == 9. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.cached_property MRO entry names
#
# Wave 267 theme: functools.cached_property is a pure-Python descriptor class
# defined in Lib/functools.py that inherits directly from object. Its MRO has
# exactly 2 entries: cached_property itself (index 0) and object (index 1).
# __mro__[0].__name__ == 'cached_property' and __mro__[1].__name__ == 'object'.
# The __name__ length is 15 — one more than singledispatch (14). Previously
# covered: __mro__.__len__, __bases__[0].__name__ (earlier specs). New here:
# __mro__[0].__name__, __mro__[1].__name__, __name__.__len__.
#
# cached_property.__mro__[0].__name__ == 'cached_property'   (len 15)
# cached_property.__mro__[1].__name__ == 'object'            (len 6)
# cached_property.__name__.__len__() == 15
# cached_property.__module__.__len__() == 9
#
# New to extra121.
# ---------------------------------------------------------------------------

table functools_extra121.cached_property_mro_names:
  description: "functools.cached_property MRO: [0]='cached_property'(15), [1]='object'(6); __name__ len=15; __module__ len=9; MRO length 2; inherits directly from object; wave 267; new to extra121"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolscpmn121

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_mro0_name,
       "cached_property.__mro__.__getitem__",
       [0],
       "cached_property",
       "functools.cached_property.__mro__[0].__name__ == 'cached_property' — first MRO entry is the class itself; tuple.__getitem__(0).__name__ returns 'cached_property'; new to extra121"]
    - [cached_property_mro1_name,
       "cached_property.__mro__.__getitem__",
       [1],
       "object",
       "functools.cached_property.__mro__[1].__name__ == 'object' — second MRO entry is the root base class; cached_property inherits directly from object with no intermediate; tuple.__getitem__(1).__name__ returns 'object'; new to extra121"]
    - [cached_property_name_len,
       "cached_property.__name__.__len__",
       [],
       15,
       "functools.cached_property.__name__.__len__() == 15 — 'cached_property' has 15 chars: c-a-c-h-e-d(6)+_(1)+p-r-o-p-e-r-t-y(8); one char longer than singledispatch (14); str.__len__() returns 15; new to extra121"]
    - [cached_property_module_len,
       "cached_property.__module__.__len__",
       [],
       9,
       "functools.cached_property.__module__.__len__() == 9 — 'functools' has 9 chars: f-u-n-c-t-o-o-l-s; same as singledispatch and total_ordering module lengths; str.__len__() returns 9; new to extra121"]
    - [cached_property_mro1_object,
       "cached_property.__mro__.__getitem__",
       [1],
       "object",
       "functools.cached_property.__mro__[1].__name__ == 'object' — confirming the only parent is the root class; single-inheritance chain ends at object; tuple.__getitem__(1).__name__ returns 'object'; new to extra121"]

# ---------------------------------------------------------------------------
# Table 2: functools.cached_property.__set_name__ co_varnames
#
# Wave 267 theme: cached_property.__set_name__ is called when the descriptor
# is assigned to a class attribute at class-creation time. It takes 3 arguments:
# self (the descriptor), owner (the owning class), and name (the attribute name
# being assigned). co_argcount is 3. co_varnames[1] == 'owner' and
# co_varnames[2] == 'name'. These parameter names are new to extra121.
# Previously covered: __set_name__.__qualname__, __set_name__.__code__.co_argcount,
# __set_name__.__module__, __set_name__.__class__.__name__ (earlier specs).
# New here: co_varnames[1] ('owner'), co_varnames[2] ('name').
#
# cached_property.__set_name__.__code__.co_varnames[1] == 'owner'
# cached_property.__set_name__.__code__.co_varnames[2] == 'name'
# cached_property.__set_name__.__code__.co_argcount == 3
#
# New to extra121.
# ---------------------------------------------------------------------------

table functools_extra121.cached_property_set_name_varnames:
  description: "functools.cached_property.__set_name__ co_varnames: [1]='owner', [2]='name'; co_argcount=3 (self+owner+name); called at class-creation time; new parameter names; wave 267; new to extra121"
  kind: python_call_eq
  category: code_identity
  id_prefix: functoolscpsnv121

  columns: [id, function, args, expected, description]
  rows:
    - [set_name_varnames1,
       "cached_property.__set_name__.__code__.co_varnames.__getitem__",
       [1],
       "owner",
       "functools.cached_property.__set_name__.__code__.co_varnames[1] == 'owner' — the second parameter to __set_name__ is the owning class; tuple.__getitem__(1) returns 'owner'; new to extra121"]
    - [set_name_varnames2,
       "cached_property.__set_name__.__code__.co_varnames.__getitem__",
       [2],
       "name",
       "functools.cached_property.__set_name__.__code__.co_varnames[2] == 'name' — the third parameter is the attribute name being assigned; tuple.__getitem__(2) returns 'name'; new to extra121"]
    - [set_name_co_argcount,
       "cached_property.__set_name__.__code__.co_argcount.__eq__",
       [3],
       true,
       "functools.cached_property.__set_name__.__code__.co_argcount.__eq__(3) == True — __set_name__(self, owner, name) takes 3 positional-or-keyword params; int.__eq__(3) returns True; new to extra121"]
    - [set_name_varnames0_self,
       "cached_property.__set_name__.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "functools.cached_property.__set_name__.__code__.co_varnames[0] == 'self' — the first parameter is the descriptor instance; tuple.__getitem__(0) returns 'self'; new to extra121"]
    - [set_name_co_name,
       "cached_property.__set_name__.__code__.co_name.__eq__",
       ["__set_name__"],
       true,
       "functools.cached_property.__set_name__.__code__.co_name.__eq__('__set_name__') == True — co_name matches the def-statement identifier; str.__eq__('__set_name__') returns True; new to extra121"]

# ---------------------------------------------------------------------------
# Table 3: functools.cached_property.__get__ and __init__ co_varnames
#
# Wave 267 theme: The descriptor protocol method __get__ receives 'instance'
# as its second parameter (co_varnames[1]) and 'owner' as its third
# (co_varnames[2]). __init__ receives 'func' as its second parameter
# (co_varnames[1]) — the function whose return value will be cached. Both
# __get__ and __set_name__ have co_argcount == 3. __init__ has co_argcount == 2.
# Previously covered: __get__.__qualname__, __get__.__code__.co_argcount,
# __init__.__qualname__, __init__.__code__.co_argcount, __init__.__code__.co_name
# (earlier specs). New here: __get__ co_varnames[1], __init__ co_varnames[1].
#
# cached_property.__get__.__code__.co_varnames[1] == 'instance'
# cached_property.__get__.__code__.co_argcount == 3
# cached_property.__init__.__code__.co_varnames[1] == 'func'
#
# New to extra121.
# ---------------------------------------------------------------------------

table functools_extra121.cached_property_get_init_varnames:
  description: "functools.cached_property descriptor protocol: __get__ co_varnames[1]='instance'(co_argcount=3), __init__ co_varnames[1]='func'(co_argcount=2); non-data descriptor; wave 267; new to extra121"
  kind: python_call_eq
  category: code_identity
  id_prefix: functoolscpgiv121

  columns: [id, function, args, expected, description]
  rows:
    - [get_varnames1_instance,
       "cached_property.__get__.__code__.co_varnames.__getitem__",
       [1],
       "instance",
       "functools.cached_property.__get__.__code__.co_varnames[1] == 'instance' — the second param to __get__ is the object instance being accessed; tuple.__getitem__(1) returns 'instance'; new to extra121"]
    - [get_co_argcount,
       "cached_property.__get__.__code__.co_argcount.__eq__",
       [3],
       true,
       "functools.cached_property.__get__.__code__.co_argcount.__eq__(3) == True — __get__(self, instance, owner) takes 3 positional-or-keyword params; same as __set_name__; int.__eq__(3) returns True; new to extra121"]
    - [get_co_name,
       "cached_property.__get__.__code__.co_name.__eq__",
       ["__get__"],
       true,
       "functools.cached_property.__get__.__code__.co_name.__eq__('__get__') == True — co_name records the def-statement name '__get__'; str.__eq__('__get__') returns True; new to extra121"]
    - [init_varnames1_func,
       "cached_property.__init__.__code__.co_varnames.__getitem__",
       [1],
       "func",
       "functools.cached_property.__init__.__code__.co_varnames[1] == 'func' — the second param to __init__ is the function whose return value will be cached; tuple.__getitem__(1) returns 'func'; new to extra121"]
    - [init_co_argcount,
       "cached_property.__init__.__code__.co_argcount.__eq__",
       [2],
       true,
       "functools.cached_property.__init__.__code__.co_argcount.__eq__(2) == True — __init__(self, func) takes 2 positional-or-keyword params; one fewer than __get__ and __set_name__; int.__eq__(2) returns True; new to extra121"]
    - [get_varnames0_self,
       "cached_property.__get__.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "functools.cached_property.__get__.__code__.co_varnames[0] == 'self' — the first parameter of __get__ is the descriptor instance; tuple.__getitem__(0) returns 'self'; new to extra121"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra121
# ---------------------------------------------------------------------------

invariant functools_extra121.cached_property_mro0_name:
  description: "functools.cached_property.__mro__[0].__name__ == 'cached_property' — first MRO entry is the class itself; MRO has 2 entries total; wave 267; new to extra121"
  kind: python_call_eq
  function: "cached_property.__mro__.__getitem__"
  args: [0]
  expected: "cached_property"

invariant functools_extra121.cached_property_mro1_name:
  description: "functools.cached_property.__mro__[1].__name__ == 'object' — second and final MRO entry is the root class; cached_property inherits only from object; wave 267; new to extra121"
  kind: python_call_eq
  function: "cached_property.__mro__.__getitem__"
  args: [1]
  expected: "object"

invariant functools_extra121.cached_property_set_name_varnames1:
  description: "functools.cached_property.__set_name__.__code__.co_varnames[1] == 'owner' — __set_name__ second param is the owning class; wave 267; new to extra121"
  kind: python_call_eq
  function: "cached_property.__set_name__.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "owner"

invariant functools_extra121.cached_property_get_varnames1:
  description: "functools.cached_property.__get__.__code__.co_varnames[1] == 'instance' — descriptor __get__ second param is the instance being accessed; wave 267; new to extra121"
  kind: python_call_eq
  function: "cached_property.__get__.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "instance"

invariant functools_extra121.cached_property_init_varnames1:
  description: "functools.cached_property.__init__.__code__.co_varnames[1] == 'func' — __init__ second param is the function to cache; mirrors singledispatch first param 'func'; wave 267; new to extra121"
  kind: python_call_eq
  function: "cached_property.__init__.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "func"
