  id_prefix: inspmore75

  columns: [id, function, args, expected, description]
  rows:
    - [isroutine_co_name_eq_isroutine,
       isroutine.__code__.co_name.__eq__,
       ["isroutine"],
       true,
       "inspect.isroutine.__code__.co_name.__eq__('isroutine') == True — isroutine is a pure-Python function in Lib/inspect.py that returns True if the object is a function, method, method descriptor, or built-in; its code object's co_name stores the name from the def statement which is 'isroutine' (9 chars); str.__eq__('isroutine') returns True; no prior inspect spec checks isroutine.__code__.co_name via inspmore75; new to extra75"]
    - [isroutine_co_argcount_eq_1,
       isroutine.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.isroutine.__code__.co_argcount.__eq__(1) == True — isroutine is defined as 'def isroutine(object):' with 1 positional parameter; co_argcount counts positional-or-keyword parameters and equals 1; int.__eq__(1) returns True; no prior inspect spec checks isroutine.__code__.co_argcount via inspmore75; new to extra75"]
    - [ismethoddescriptor_co_name_eq_ismethoddescriptor,
       ismethoddescriptor.__code__.co_name.__eq__,
       ["ismethoddescriptor"],
       true,
       "inspect.ismethoddescriptor.__code__.co_name.__eq__('ismethoddescriptor') == True — ismethoddescriptor is a pure-Python function in Lib/inspect.py that returns True if the object is a method descriptor; its code object's co_name stores the name from the def statement which is 'ismethoddescriptor' (18 chars); str.__eq__('ismethoddescriptor') returns True; no prior inspect spec checks ismethoddescriptor.__code__.co_name via inspmore75; new to extra75"]
    - [ismethoddescriptor_co_argcount_eq_1,
       ismethoddescriptor.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.ismethoddescriptor.__code__.co_argcount.__eq__(1) == True — ismethoddescriptor is defined as 'def ismethoddescriptor(object):' with 1 positional parameter; co_argcount counts positional-or-keyword parameters and equals 1; int.__eq__(1) returns True; no prior inspect spec checks ismethoddescriptor.__code__.co_argcount via inspmore75; new to extra75"]

# ---------------------------------------------------------------------------
