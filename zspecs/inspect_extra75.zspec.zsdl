table inspect_extra75.isroutine_ismethoddescriptor_code:
  description: "isroutine/__code__.co_name=='isroutine', co_argcount==1; ismethoddescriptor/__code__.co_name=='ismethoddescriptor', co_argcount==1; wave 241 inspect function code attrs; new to extra75"
