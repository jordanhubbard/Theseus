# ---------------------------------------------------------------------------
# Standalone invariants — extra75
# ---------------------------------------------------------------------------

invariant inspect_extra75.ismodule_co_name:
  description: "inspect.ismodule.__code__.co_name.__eq__('ismodule') == True — ismodule co_name is 'ismodule'; wave 241 inspect function code attrs; new to extra75"
  kind: python_call_eq
  function: ismodule.__code__.co_name.__eq__
  args: ["ismodule"]
  expected: true

invariant inspect_extra75.isbuiltin_co_name:
  description: "inspect.isbuiltin.__code__.co_name.__eq__('isbuiltin') == True — isbuiltin co_name is 'isbuiltin'; wave 241 inspect function code attrs; new to extra75"
