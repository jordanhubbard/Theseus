spec: inspect_extra75
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra74.zspec.zsdl."
    - "This spec covers: inspect ismodule/isbuiltin/isroutine/ismethoddescriptor code attrs + isdatadescriptor/isgetsetdescriptor (Wave 241)."
    - "ismodule.__code__.co_name == 'ismodule' — ismodule is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "ismodule.__code__.co_argcount == 1 — ismodule(object) takes 1 positional arg. Verified with Python 3.14.3."
    - "isbuiltin.__code__.co_name == 'isbuiltin' — isbuiltin is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "isbuiltin.__code__.co_argcount == 1 — isbuiltin(object) takes 1 positional arg. Verified with Python 3.14.3."
    - "isroutine.__code__.co_name == 'isroutine' — isroutine is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "isroutine.__code__.co_argcount == 1 — isroutine(object) takes 1 positional arg. Verified with Python 3.14.3."
    - "ismethoddescriptor.__code__.co_name == 'ismethoddescriptor' — ismethoddescriptor is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "ismethoddescriptor.__code__.co_argcount == 1 — ismethoddescriptor(object) takes 1 positional arg. Verified with Python 3.14.3."
    - "isgetsetdescriptor.__code__.co_name == 'isgetsetdescriptor' — isgetsetdescriptor is present in Python 3.14.3 and is a pure-Python function. Verified with Python 3.14.3."
    - "isgetsetdescriptor.__code__.co_argcount == 1 — isgetsetdescriptor(object) takes 1 positional arg. Verified with Python 3.14.3."
    - "isdatadescriptor.__code__.co_name == 'isdatadescriptor' — isdatadescriptor is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "isdatadescriptor.__code__.co_argcount == 1 — isdatadescriptor(object) takes 1 positional arg. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ismodule and isbuiltin code attributes — extra75
#
# Wave 241 theme: inspect ismodule/isbuiltin code object attrs.
#
# inspect.ismodule.__code__.co_name     == 'ismodule'
# inspect.ismodule.__code__.co_argcount == 1
# inspect.isbuiltin.__code__.co_name    == 'isbuiltin'
# inspect.isbuiltin.__code__.co_argcount == 1
#
# No prior inspect spec checks ismodule/isbuiltin __code__ attrs via inspmore75. New to extra75.
# ---------------------------------------------------------------------------

table inspect_extra75.ismodule_isbuiltin_code:
  description: "ismodule/__code__.co_name=='ismodule', co_argcount==1; isbuiltin/__code__.co_name=='isbuiltin', co_argcount==1; wave 241 inspect function code attrs; new to extra75"
  kind: python_call_eq
  category: code_attributes
  id_prefix: inspmore75

  columns: [id, function, args, expected, description]
  rows:
    - [ismodule_co_name_eq_ismodule,
       ismodule.__code__.co_name.__eq__,
       ["ismodule"],
       true,
       "inspect.ismodule.__code__.co_name.__eq__('ismodule') == True — ismodule is a pure-Python function in Lib/inspect.py that returns True if the object is a module; its code object's co_name stores the name from the def statement which is 'ismodule' (8 chars); str.__eq__('ismodule') returns True; no prior inspect spec checks ismodule.__code__.co_name via inspmore75; new to extra75"]
    - [ismodule_co_argcount_eq_1,
       ismodule.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.ismodule.__code__.co_argcount.__eq__(1) == True — ismodule is defined as 'def ismodule(object):' with 1 positional parameter; co_argcount counts positional-or-keyword parameters and equals 1; int.__eq__(1) returns True; no prior inspect spec checks ismodule.__code__.co_argcount via inspmore75; new to extra75"]
    - [isbuiltin_co_name_eq_isbuiltin,
       isbuiltin.__code__.co_name.__eq__,
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__code__.co_name.__eq__('isbuiltin') == True — isbuiltin is a pure-Python function in Lib/inspect.py that returns True if the object is a built-in function or bound method; its code object's co_name stores the name from the def statement which is 'isbuiltin' (9 chars); str.__eq__('isbuiltin') returns True; no prior inspect spec checks isbuiltin.__code__.co_name via inspmore75; new to extra75"]
    - [isbuiltin_co_argcount_eq_1,
       isbuiltin.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.isbuiltin.__code__.co_argcount.__eq__(1) == True — isbuiltin is defined as 'def isbuiltin(object):' with 1 positional parameter; co_argcount counts positional-or-keyword parameters and equals 1; int.__eq__(1) returns True; no prior inspect spec checks isbuiltin.__code__.co_argcount via inspmore75; new to extra75"]

# ---------------------------------------------------------------------------
