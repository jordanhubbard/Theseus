#
# inspect.isgetsetdescriptor.__code__.co_name     == 'isgetsetdescriptor'
# inspect.isgetsetdescriptor.__code__.co_argcount == 1
#
# No prior inspect spec checks isgetsetdescriptor __code__ attrs via inspmore75. New to extra75.
# ---------------------------------------------------------------------------

table inspect_extra75.isgetsetdescriptor_code:
  description: "isgetsetdescriptor/__code__.co_name=='isgetsetdescriptor', co_argcount==1; wave 241 inspect isgetsetdescriptor code attrs; new to extra75"
  kind: python_call_eq
  category: code_attributes
  id_prefix: inspmore75

  columns: [id, function, args, expected, description]
  rows:
    - [isgetsetdescriptor_co_name_eq_isgetsetdescriptor,
       isgetsetdescriptor.__code__.co_name.__eq__,
       ["isgetsetdescriptor"],
       true,
       "inspect.isgetsetdescriptor.__code__.co_name.__eq__('isgetsetdescriptor') == True — isgetsetdescriptor is a pure-Python function in Lib/inspect.py that returns True if the object is a getset descriptor (C-level data descriptor); it exists in Python 3.14.3; its code object's co_name stores the name from the def statement which is 'isgetsetdescriptor' (18 chars); str.__eq__('isgetsetdescriptor') returns True; no prior inspect spec checks isgetsetdescriptor.__code__.co_name via inspmore75; new to extra75"]
    - [isgetsetdescriptor_co_argcount_eq_1,
       isgetsetdescriptor.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.isgetsetdescriptor.__code__.co_argcount.__eq__(1) == True — isgetsetdescriptor is defined as 'def isgetsetdescriptor(object):' with 1 positional parameter; co_argcount counts positional-or-keyword parameters and equals 1; int.__eq__(1) returns True; no prior inspect spec checks isgetsetdescriptor.__code__.co_argcount via inspmore75; new to extra75"]

