spec: inspect_extra144
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.signature (Python function) — __qualname__ len 9, __module__ 'inspect', __doc__ len 47, co_argcount 1; inspect.Parameter (Python class) — __name__ len 9, __qualname__ len 9, __module__ 'inspect', __doc__ len 708, MRO len 2; inspect.Parameter.POSITIONAL_ONLY — __class__.__name__ '_ParameterKind'; inspect.BoundArguments (Python class) — __name__ len 14, __qualname__ len 14, __module__ 'inspect', __doc__ len 463, MRO len 2 (Wave 272)."
    - "inspect.signature is a Python function: __qualname__ == 'signature' (len 9); __module__ == 'inspect'; __doc__ len == 47; co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.Parameter is a Python class: __name__ == 'Parameter' (len 9); __qualname__ == 'Parameter' (len 9); __module__ == 'inspect'; __doc__ len == 708; MRO len == 2. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY is a _ParameterKind enum member; __class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.BoundArguments is a Python class: __name__ == 'BoundArguments' (len 14); __qualname__ == 'BoundArguments' (len 14); __module__ == 'inspect'; __doc__ len == 463; MRO len == 2. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.signature — Python function qualname, module, doc, argcount
#
# Wave 272 theme: inspect.signature — the primary introspection function for
# callable signatures.
#
# inspect.signature.__class__.__name__ == 'function'
# inspect.signature.__qualname__ == 'signature' (len 9)
# inspect.signature.__module__ == 'inspect' (len 7)
# len(inspect.signature.__doc__) == 47
# inspect.signature.__code__.co_argcount == 1
#
# signature(obj, *, follow_wrapped=True, globals=None, locals=None, eval_str=False)
# returns a Signature object for the given callable. New to extra144.
# ---------------------------------------------------------------------------

table inspect_extra144.signature_attrs:
  description: "inspect.signature: Python function, __qualname__ len 9, __module__ 'inspect', __doc__ len 47, co_argcount 1; wave 272; new to extra144"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectsignature144

  columns: [id, function, args, expected, description]
  rows:
    - [signature_class_eq_function,
       "signature.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.signature.__class__.__name__.__eq__('function') == True — signature is a Python function defined in Lib/inspect.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra144"]
    - [signature_qualname_eq,
       "signature.__qualname__.__eq__",
       ["signature"],
       true,
       "inspect.signature.__qualname__.__eq__('signature') == True — the function's __qualname__ is 'signature'; str.__eq__('signature') returns True; new to extra144"]
    - [signature_qualname_len_eq_9,
       "signature.__qualname__.__len__",
       [],
       9,
       "inspect.signature.__qualname__.__len__() == 9 — __qualname__ is 'signature' which has 9 characters; len('signature') == 9; new to extra144"]
    - [signature_module_eq_inspect,
       "signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.signature.__module__.__eq__('inspect') == True — signature is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra144"]
    - [signature_doc_len_eq_47,
       "signature.__doc__.__len__",
       [],
       47,
       "inspect.signature.__doc__.__len__() == 47 — the signature docstring has 47 characters; len(__doc__) == 47; verified with Python 3.14.3; new to extra144"]
    - [signature_co_argcount_eq_1,
       "signature.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.signature.__code__.co_argcount.__eq__(1) == True — signature takes 1 positional-or-keyword argument: obj; co_argcount is 1; int.__eq__(1) returns True; new to extra144"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter — Python class identity, name, module, doc, MRO
#
# Wave 272 theme: inspect.Parameter — represents a parameter of a signature.
#
# inspect.Parameter.__class__.__name__ == 'type'
# inspect.Parameter.__name__ == 'Parameter' (len 9)
# inspect.Parameter.__qualname__ == 'Parameter' (len 9)
# inspect.Parameter.__module__ == 'inspect' (len 7)
# len(inspect.Parameter.__doc__) == 708
# len(inspect.Parameter.__mro__) == 2
#
# Parameter(name, kind, default=empty, annotation=empty) holds all information
# about a function parameter including its name, kind, default, and annotation.
# New to extra144.
# ---------------------------------------------------------------------------

table inspect_extra144.parameter_class_attrs:
  description: "inspect.Parameter: Python class, __name__ 'Parameter' len 9, __qualname__ len 9, __module__ 'inspect', __doc__ len 708, MRO len 2; wave 272; new to extra144"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparameter144

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_class_eq_type,
       "Parameter.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.__class__.__name__.__eq__('type') == True — Parameter is a Python class defined in Lib/inspect.py; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra144"]
    - [parameter_name_eq,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — the class __name__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra144"]
    - [parameter_name_len_eq_9,
       "Parameter.__name__.__len__",
       [],
       9,
       "inspect.Parameter.__name__.__len__() == 9 — __name__ is 'Parameter' which has 9 characters; len('Parameter') == 9; new to extra144"]
    - [parameter_qualname_eq,
       "Parameter.__qualname__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__.__eq__('Parameter') == True — the class __qualname__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra144"]
    - [parameter_module_eq_inspect,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra144"]
    - [parameter_doc_len_eq_708,
       "Parameter.__doc__.__len__",
       [],
       708,
       "inspect.Parameter.__doc__.__len__() == 708 — the Parameter docstring has 708 characters; len(__doc__) == 708; verified with Python 3.14.3; new to extra144"]
    - [parameter_mro_len_eq_2,
       "Parameter.__mro__.__len__",
       [],
       2,
       "inspect.Parameter.__mro__.__len__() == 2 — Parameter's MRO is [Parameter, object]; len(__mro__) is 2; new to extra144"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter.POSITIONAL_ONLY — enum member class name
#
# Wave 272 theme: inspect.Parameter.POSITIONAL_ONLY — the enum constant for
# positional-only parameters (PEP 570).
#
# inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'
#
# POSITIONAL_ONLY is a member of the _ParameterKind IntEnum class; its
# __class__.__name__ is '_ParameterKind'. New to extra144.
# ---------------------------------------------------------------------------

table inspect_extra144.parameter_positional_only_attrs:
  description: "inspect.Parameter.POSITIONAL_ONLY: _ParameterKind enum member; __class__.__name__ '_ParameterKind'; wave 272; new to extra144"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparamposonlyattr144

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_class_eq_parameterkind,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is a member of the _ParameterKind IntEnum; __class__.__name__ is '_ParameterKind'; str.__eq__ returns True; new to extra144"]
    - [positional_only_class_name_len,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__len__",
       [],
       14,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__len__() == 14 — __class__.__name__ is '_ParameterKind' which has 14 characters; len('_ParameterKind') == 14; new to extra144"]

# ---------------------------------------------------------------------------
# Table 4: inspect.BoundArguments — Python class identity, name, module, doc
#
# Wave 272 theme: inspect.BoundArguments — result of Signature.bind().
#
# inspect.BoundArguments.__class__.__name__ == 'type'
# inspect.BoundArguments.__name__ == 'BoundArguments' (len 14)
# inspect.BoundArguments.__qualname__ == 'BoundArguments' (len 14)
# inspect.BoundArguments.__module__ == 'inspect' (len 7)
# len(inspect.BoundArguments.__doc__) == 463
# len(inspect.BoundArguments.__mro__) == 2
#
# BoundArguments(signature, arguments) stores the mapping of parameter names
# to argument values produced by Signature.bind() or Signature.bind_partial().
# New to extra144.
# ---------------------------------------------------------------------------

table inspect_extra144.boundarguments_class_attrs:
  description: "inspect.BoundArguments: Python class, __name__ 'BoundArguments' len 14, __qualname__ len 14, __module__ 'inspect', __doc__ len 463, MRO len 2; wave 272; new to extra144"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectboundargs144

  columns: [id, function, args, expected, description]
  rows:
    - [boundargs_class_eq_type,
       "BoundArguments.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.BoundArguments.__class__.__name__.__eq__('type') == True — BoundArguments is a Python class defined in Lib/inspect.py; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra144"]
    - [boundargs_name_eq,
       "BoundArguments.__name__.__eq__",
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — the class __name__ is 'BoundArguments'; str.__eq__('BoundArguments') returns True; new to extra144"]
    - [boundargs_name_len_eq_14,
       "BoundArguments.__name__.__len__",
       [],
       14,
       "inspect.BoundArguments.__name__.__len__() == 14 — __name__ is 'BoundArguments' which has 14 characters; len('BoundArguments') == 14; new to extra144"]
    - [boundargs_qualname_eq,
       "BoundArguments.__qualname__.__eq__",
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__qualname__.__eq__('BoundArguments') == True — the class __qualname__ is 'BoundArguments'; str.__eq__('BoundArguments') returns True; new to extra144"]
    - [boundargs_module_eq_inspect,
       "BoundArguments.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra144"]
    - [boundargs_doc_len_eq_463,
       "BoundArguments.__doc__.__len__",
       [],
       463,
       "inspect.BoundArguments.__doc__.__len__() == 463 — the BoundArguments docstring has 463 characters; len(__doc__) == 463; verified with Python 3.14.3; new to extra144"]
    - [boundargs_mro_len_eq_2,
       "BoundArguments.__mro__.__len__",
       [],
       2,
       "inspect.BoundArguments.__mro__.__len__() == 2 — BoundArguments's MRO is [BoundArguments, object]; len(__mro__) is 2; new to extra144"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra144
# ---------------------------------------------------------------------------

invariant inspect_extra144.signature_qualname_len:
  description: "len(inspect.signature.__qualname__) == 9 — __qualname__ is 'signature'; wave 272; new to extra144"
  kind: python_call_eq
  function: signature.__qualname__.__len__
  args: []
  expected: 9

invariant inspect_extra144.signature_doc_len:
  description: "len(inspect.signature.__doc__) == 47 — the signature docstring has 47 characters; wave 272; new to extra144"
  kind: python_call_eq
  function: signature.__doc__.__len__
  args: []
  expected: 47

invariant inspect_extra144.signature_co_argcount:
  description: "inspect.signature.__code__.co_argcount == 1 — takes obj; wave 272; new to extra144"
  kind: python_call_eq
  function: signature.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra144.parameter_name_len:
  description: "len(inspect.Parameter.__name__) == 9 — __name__ is 'Parameter'; wave 272; new to extra144"
  kind: python_call_eq
  function: Parameter.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra144.parameter_doc_len:
  description: "len(inspect.Parameter.__doc__) == 708 — the Parameter docstring has 708 characters; wave 272; new to extra144"
  kind: python_call_eq
  function: Parameter.__doc__.__len__
  args: []
  expected: 708

invariant inspect_extra144.parameter_mro_len:
  description: "len(inspect.Parameter.__mro__) == 2 — Parameter's MRO is [Parameter, object]; wave 272; new to extra144"
  kind: python_call_eq
  function: Parameter.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra144.positional_only_class_name:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — POSITIONAL_ONLY is a _ParameterKind IntEnum member; wave 272; new to extra144"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra144.boundargs_name_len:
  description: "len(inspect.BoundArguments.__name__) == 14 — __name__ is 'BoundArguments'; wave 272; new to extra144"
  kind: python_call_eq
  function: BoundArguments.__name__.__len__
  args: []
  expected: 14

invariant inspect_extra144.boundargs_doc_len:
  description: "len(inspect.BoundArguments.__doc__) == 463 — the BoundArguments docstring has 463 characters; wave 272; new to extra144"
  kind: python_call_eq
  function: BoundArguments.__doc__.__len__
  args: []
  expected: 463

invariant inspect_extra144.boundargs_mro_len:
  description: "len(inspect.BoundArguments.__mro__) == 2 — BoundArguments's MRO is [BoundArguments, object]; wave 272; new to extra144"
  kind: python_call_eq
  function: BoundArguments.__mro__.__len__
  args: []
  expected: 2
