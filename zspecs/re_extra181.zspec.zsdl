spec: re_extra181
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module flag constants — re.NOFLAG, re.LOCALE, re.ASCII (alias re.A), re.DEBUG, re.TEMPLATE — their integer values and class membership."
    - "re.NOFLAG.__eq__(0) — zero-value flag, the absence of any flag; re.LOCALE.__eq__(4) — LOCALE flag = 4."
    - "re.ASCII.__eq__(256) — ASCII flag = 256; re.A.__eq__(256) — A is the short alias for ASCII, same value."
    - "re.DEBUG.__eq__(128) — DEBUG flag = 128; re.TEMPLATE.__eq__(512) — TEMPLATE flag = 512."
    - "re.NOFLAG.__class__.__name__ == 'RegexFlag' — all re flags are instances of the RegexFlag IntFlag enum."
    - "re.ASCII.__class__.__name__ == 'RegexFlag' — ASCII flag is also a RegexFlag instance."
    - "Flag value ordering: NOFLAG (0) < LOCALE (4) < DEBUG (128) < ASCII (256) < TEMPLATE (512)."
    - "re.A is the same object as re.ASCII: both have value 256 and class RegexFlag."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re flag zero and small values (NOFLAG, LOCALE)
# NOFLAG (0) < LOCALE (4): the two smallest flag values
# ---------------------------------------------------------------------------

table re_extra181.small_flag_values:
  description: "re small flag values: NOFLAG.__eq__(0) — the zero-value flag; LOCALE.__eq__(4) — LOCALE flag value; NOFLAG (0) < LOCALE (4): a strict ordering; both are RegexFlag instances"
  kind: python_call_eq
  category: identity
  id_prefix: reflags181

  columns: [id, function, args, expected, description]
  rows:
    - [noflag_eq_zero,   NOFLAG.__eq__,                          [0],   true, "re.NOFLAG.__eq__(0) == True — NOFLAG has integer value 0, representing the absence of any regex flag; NOFLAG (0) is the minimum flag value; NOFLAG (0) < LOCALE (4) < DEBUG (128) < ASCII (256) < TEMPLATE (512): the full flag value ordering; confirmed Python 3.14.3 macOS"]
    - [noflag_class,     NOFLAG.__class__.__name__.__eq__,       ["RegexFlag"], true, "re.NOFLAG.__class__.__name__ == 'RegexFlag' — NOFLAG is an instance of the RegexFlag IntFlag enum; all re flag constants are RegexFlag instances; confirmed Python 3.14.3 macOS"]
    - [locale_eq_4,      LOCALE.__eq__,                          [4],   true, "re.LOCALE.__eq__(4) == True — LOCALE has integer value 4; LOCALE (4) enables locale-dependent matching for \\w, \\d, \\s etc.; NOFLAG (0) < LOCALE (4): LOCALE is the second-smallest flag value; confirmed Python 3.14.3 macOS"]
    - [locale_class,     LOCALE.__class__.__name__.__eq__,       ["RegexFlag"], true, "re.LOCALE.__class__.__name__ == 'RegexFlag' — LOCALE is a RegexFlag instance; NOFLAG and LOCALE both have class RegexFlag; confirmed Python 3.14.3 macOS"]
    - [noflag_ne_locale, NOFLAG.__eq__,                          [4],   false, "re.NOFLAG.__eq__(4) == False — NOFLAG (0) != LOCALE (4): they have different integer values; this confirms NOFLAG is strictly less than LOCALE; confirmed Python 3.14.3 macOS"]
    - [locale_ne_zero,   LOCALE.__eq__,                          [0],   false, "re.LOCALE.__eq__(0) == False — LOCALE (4) != NOFLAG (0): LOCALE has value 4, not 0; NOFLAG (0) < LOCALE (4) is a strict inequality; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re flag medium and large values (DEBUG, ASCII / re.A)
# DEBUG (128) < ASCII (256): both are RegexFlag; re.A == re.ASCII
# ---------------------------------------------------------------------------

table re_extra181.medium_flag_values:
  description: "re medium flag values: DEBUG.__eq__(128) — DEBUG flag value; ASCII.__eq__(256) — ASCII flag value; A.__eq__(256) — A is the short alias for ASCII; DEBUG (128) < ASCII==A (256); all are RegexFlag instances"
  kind: python_call_eq
  category: identity
  id_prefix: reflags181

  columns: [id, function, args, expected, description]
  rows:
    - [debug_eq_128,   DEBUG.__eq__,                     [128], true, "re.DEBUG.__eq__(128) == True — DEBUG has integer value 128; DEBUG enables printing of debug info about compiled expressions; LOCALE (4) < DEBUG (128): DEBUG is much larger; DEBUG (128) < ASCII (256) < TEMPLATE (512); confirmed Python 3.14.3 macOS"]
    - [debug_class,    DEBUG.__class__.__name__.__eq__,   ["RegexFlag"], true, "re.DEBUG.__class__.__name__ == 'RegexFlag' — DEBUG is a RegexFlag instance; confirmed Python 3.14.3 macOS"]
    - [ascii_eq_256,   ASCII.__eq__,                     [256], true, "re.ASCII.__eq__(256) == True — ASCII has integer value 256; ASCII (also re.A) makes \\w, \\d, \\s etc. match only ASCII characters; DEBUG (128) < ASCII (256): ASCII is exactly twice the value of DEBUG; confirmed Python 3.14.3 macOS"]
    - [ascii_class,    ASCII.__class__.__name__.__eq__,   ["RegexFlag"], true, "re.ASCII.__class__.__name__ == 'RegexFlag' — ASCII is a RegexFlag instance; re.ASCII.__class__.__name__ == re.NOFLAG.__class__.__name__: all re flags share the RegexFlag class; confirmed Python 3.14.3 macOS"]
    - [a_eq_256,       A.__eq__,                         [256], true, "re.A.__eq__(256) == True — re.A is the short alias for re.ASCII, also with integer value 256; re.A (256) == re.ASCII (256): both names refer to the same flag value; DEBUG (128) < re.A==re.ASCII (256) < TEMPLATE (512); confirmed Python 3.14.3 macOS"]
    - [a_class,        A.__class__.__name__.__eq__,       ["RegexFlag"], true, "re.A.__class__.__name__ == 'RegexFlag' — re.A, like re.ASCII, is a RegexFlag instance; the short alias A and the full name ASCII have the same class; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re flag largest value (TEMPLATE) and class name lengths
# TEMPLATE (512) is the largest flag value covered; RegexFlag class name lengths
# ---------------------------------------------------------------------------

table re_extra181.template_flag_and_classnames:
  description: "re.TEMPLATE flag and RegexFlag class name: TEMPLATE.__eq__(512) — the largest flag value covered; ASCII (256) < TEMPLATE (512); NOFLAG.__class__.__name__.__len__() == 10 (len of 'RegexFlag'); ASCII (256) < TEMPLATE (512) by 256"
  kind: python_call_eq
  category: identity
  id_prefix: reflags181

  columns: [id, function, args, expected, description]
  rows:
    - [template_eq_512,   TEMPLATE.__eq__,                          [512], true, "re.TEMPLATE.__eq__(512) == True — TEMPLATE has integer value 512; TEMPLATE is a deprecated flag for template syntax; ASCII (256) < TEMPLATE (512): TEMPLATE is exactly twice the value of ASCII; TEMPLATE (512) is the maximum flag value covered; confirmed Python 3.14.3 macOS"]
    - [template_class,    TEMPLATE.__class__.__name__.__eq__,       ["RegexFlag"], true, "re.TEMPLATE.__class__.__name__ == 'RegexFlag' — TEMPLATE is a RegexFlag instance; all five covered flag constants (NOFLAG, LOCALE, DEBUG, ASCII, TEMPLATE) are RegexFlag instances; confirmed Python 3.14.3 macOS"]
    - [noflag_cname_len,  NOFLAG.__class__.__name__.__len__,        [],     9,    "re.NOFLAG.__class__.__name__.__len__() == 9 — 'RegexFlag' has 9 characters: R(1)e(2)g(3)e(4)x(5)F(6)l(7)a(8)g(9); all re flag constants share __class__.__name__ == 'RegexFlag' (len=9); confirmed Python 3.14.3 macOS"]
    - [ascii_cname_len,   ASCII.__class__.__name__.__len__,         [],     9,    "re.ASCII.__class__.__name__.__len__() == 9 — 'RegexFlag' has 9 characters; ASCII and NOFLAG share the same class name RegexFlag (len=9); confirmed Python 3.14.3 macOS"]
    - [template_ne_256,   TEMPLATE.__eq__,                          [256], false, "re.TEMPLATE.__eq__(256) == False — TEMPLATE (512) != ASCII (256): they are distinct flag values; ASCII (256) < TEMPLATE (512) is a strict inequality, not equality; confirmed Python 3.14.3 macOS"]
    - [debug_ne_256,      DEBUG.__eq__,                             [256], false, "re.DEBUG.__eq__(256) == False — DEBUG (128) != ASCII (256): DEBUG is half the value of ASCII; DEBUG (128) < ASCII (256): a strict inequality; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra181.noflag_is_zero:
  description: "re.NOFLAG.__eq__(0) == True — NOFLAG has value 0, the zero-value flag; NOFLAG (0) < LOCALE (4) < DEBUG (128) < ASCII (256) < TEMPLATE (512): NOFLAG is the minimum; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: NOFLAG.__eq__
  args: [0]
  expected: true

invariant re_extra181.locale_is_4:
  description: "re.LOCALE.__eq__(4) == True — LOCALE has value 4; NOFLAG (0) < LOCALE (4): LOCALE is the second-smallest flag; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: LOCALE.__eq__
  args: [4]
  expected: true

invariant re_extra181.ascii_is_256:
  description: "re.ASCII.__eq__(256) == True — ASCII has value 256; DEBUG (128) < ASCII (256) < TEMPLATE (512): ASCII is in the middle of the upper group; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ASCII.__eq__
  args: [256]
  expected: true

invariant re_extra181.a_is_256:
  description: "re.A.__eq__(256) == True — re.A is the short alias for re.ASCII, both have value 256; re.A (256) == re.ASCII (256); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: A.__eq__
  args: [256]
  expected: true

invariant re_extra181.noflag_class_is_regexflag:
  description: "re.NOFLAG.__class__.__name__ == 'RegexFlag' — all re flag constants are RegexFlag IntFlag enum instances; 'RegexFlag' has 9 characters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: NOFLAG.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra181.ascii_class_is_regexflag:
  description: "re.ASCII.__class__.__name__ == 'RegexFlag' — ASCII is a RegexFlag instance; re.ASCII.__class__.__name__ == re.NOFLAG.__class__.__name__: all re flag constants share the RegexFlag class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ASCII.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra181.debug_is_128:
  description: "re.DEBUG.__eq__(128) == True — DEBUG has value 128; LOCALE (4) < DEBUG (128) < ASCII (256): DEBUG is between LOCALE and ASCII in the value ordering; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: DEBUG.__eq__
  args: [128]
  expected: true

invariant re_extra181.template_is_512:
  description: "re.TEMPLATE.__eq__(512) == True — TEMPLATE has value 512; ASCII (256) < TEMPLATE (512): TEMPLATE is the largest covered flag value, exactly twice ASCII; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: TEMPLATE.__eq__
  args: [512]
  expected: true

