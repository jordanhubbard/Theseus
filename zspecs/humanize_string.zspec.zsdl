spec: humanize_string
version: ">=3.1.0"
backend: node(humanize-string)

docs: https://www.npmjs.com/package/humanize-string

provenance:
  derived_from:
    - "humanize-string README — https://www.npmjs.com/package/humanize-string"
    - "Test vectors verified with humanize-string via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "humanize-string source"
  notes:
    - "humanize-string is an npm package. Install: npm install humanize-string"
    - "Converts camelCase, underscore, and dash-separated strings to a human-readable form."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a human-readable string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table humanize_string.humanize:
  kind: node_module_call_eq
  function: "default"
  category: string
  id_prefix: hstr

  columns: [id, args, expected]
  rows:
    - [camel,       ["fooBar"],   "Foo bar"]
    - [underscore,  ["foo_bar"],  "Foo bar"]
    - [dash,        ["foo-bar"],  "Foo bar"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:10:56Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
