spec: tty_extra
version: ">=3.9"
backend: python_module(tty)

docs: https://docs.python.org/3/library/tty.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tty.html — Python tty module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tty.py"
  notes:
    - "This spec complements tty.zspec.zsdl with additional invariants."
    - "tty is a POSIX-only module (available on macOS and Linux; not available on Windows)."
    - "setraw.__name__ == 'setraw' and setraw.__module__ == 'tty'."
    - "setcbreak.__name__ == 'setcbreak'."
    - "IFLAG/OFLAG/CFLAG/LFLAG/ISPEED/OSPEED/CC are int-class-verified index constants."
    - "These index constants have the same integer values as the matching termios module constants."
    - "IFLAG=0, OFLAG=1, CFLAG=2, LFLAG=3, ISPEED=4, OSPEED=5, CC=6."
    - "All expected values verified by running Python 3.12 tty module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks
# ---------------------------------------------------------------------------

invariant tty_extra.setraw.name:
  description: "tty.setraw.__name__ == 'setraw'"
  category: function_names
  kind: python_call_eq
  function: setraw.__name__.__eq__
  args: ["setraw"]
  expected: true

invariant tty_extra.setcbreak.name:
  description: "tty.setcbreak.__name__ == 'setcbreak'"
  category: function_names
  kind: python_call_eq
  function: setcbreak.__name__.__eq__
  args: ["setcbreak"]
  expected: true

# ---------------------------------------------------------------------------
# Function module affiliation
# ---------------------------------------------------------------------------

invariant tty_extra.setraw.module:
  description: "tty.setraw.__module__ == 'tty'"
  category: module
  kind: python_call_eq
  function: setraw.__module__.__eq__
  args: ["tty"]
  expected: true

invariant tty_extra.setcbreak.module:
  description: "tty.setcbreak.__module__ == 'tty'"
  category: module
  kind: python_call_eq
  function: setcbreak.__module__.__eq__
  args: ["tty"]
  expected: true

# ---------------------------------------------------------------------------
# Index constants — type checks (class is int)
# ---------------------------------------------------------------------------

invariant tty_extra.IFLAG.class_is_int:
  description: "tty.IFLAG.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: IFLAG.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant tty_extra.OFLAG.class_is_int:
  description: "tty.OFLAG.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: OFLAG.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant tty_extra.CFLAG.class_is_int:
  description: "tty.CFLAG.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: CFLAG.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant tty_extra.LFLAG.class_is_int:
  description: "tty.LFLAG.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: LFLAG.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant tty_extra.CC.class_is_int:
  description: "tty.CC.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: CC.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Index constants — exact value checks
# ---------------------------------------------------------------------------

invariant tty_extra.IFLAG.value:
  description: "tty.IFLAG == 0 — index of c_iflag in the termios attribute list"
  category: constants
  kind: python_call_eq
  function: IFLAG.__eq__
  args: [0]
  expected: true

invariant tty_extra.OFLAG.value:
  description: "tty.OFLAG == 1 — index of c_oflag in the termios attribute list"
  category: constants
  kind: python_call_eq
  function: OFLAG.__eq__
  args: [1]
  expected: true

invariant tty_extra.CFLAG.value:
  description: "tty.CFLAG == 2 — index of c_cflag in the termios attribute list"
  category: constants
  kind: python_call_eq
  function: CFLAG.__eq__
  args: [2]
  expected: true

invariant tty_extra.LFLAG.value:
  description: "tty.LFLAG == 3 — index of c_lflag in the termios attribute list"
  category: constants
  kind: python_call_eq
  function: LFLAG.__eq__
  args: [3]
  expected: true

invariant tty_extra.ISPEED.value:
  description: "tty.ISPEED == 4 — index of c_ispeed in the termios attribute list"
  category: constants
  kind: python_call_eq
  function: ISPEED.__eq__
  args: [4]
  expected: true

invariant tty_extra.OSPEED.value:
  description: "tty.OSPEED == 5 — index of c_ospeed in the termios attribute list"
  category: constants
  kind: python_call_eq
  function: OSPEED.__eq__
  args: [5]
  expected: true

invariant tty_extra.CC.value:
  description: "tty.CC == 6 — index of c_cc (control characters array) in the termios attribute list"
  category: constants
  kind: python_call_eq
  function: CC.__eq__
  args: [6]
  expected: true
