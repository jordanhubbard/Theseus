spec: threading_extra133
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.main_thread, threading.current_thread, threading.active_count, and threading.settrace code attributes (Wave 257)."
    - "threading.main_thread.__code__.co_name == 'main_thread' — defined with 'def main_thread():' in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.main_thread.__code__.co_argcount == 0 — main_thread takes no arguments. Verified with Python 3.14.3."
    - "len(threading.main_thread.__code__.co_varnames) == 0 — main_thread has no local variables. Verified with Python 3.14.3."
    - "threading.current_thread.__code__.co_name == 'current_thread' — defined with 'def current_thread():' in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.current_thread.__code__.co_argcount == 0 — current_thread takes no arguments. Verified with Python 3.14.3."
    - "threading.active_count.__code__.co_name == 'active_count' — defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.active_count.__code__.co_argcount == 0 — active_count takes no arguments. Verified with Python 3.14.3."
    - "threading.settrace.__code__.co_name == 'settrace' — defined with 'def settrace(func):' in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.settrace.__code__.co_argcount == 1 — settrace takes one argument (func). Verified with Python 3.14.3."
    - "threading.settrace.__code__.co_varnames[0] == 'func' — first local variable is the 'func' parameter. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.main_thread and current_thread code attributes
#
# Wave 257 theme: threading function code attributes for zero-argument functions.
#
# threading.main_thread.__code__.co_name == 'main_thread'
# threading.main_thread.__code__.co_argcount == 0
# len(threading.main_thread.__code__.co_varnames) == 0
# threading.current_thread.__code__.co_name == 'current_thread'
# threading.current_thread.__code__.co_argcount == 0
#
# main_thread and current_thread are zero-argument Python functions in
# Lib/threading.py; their code objects confirm the zero-argument signature.
# New to extra133.
# ---------------------------------------------------------------------------

table threading_extra133.main_current_thread_code_attrs:
  description: "threading.main_thread and current_thread code attrs: co_name, co_argcount==0, co_varnames len==0; zero-argument Python functions in threading; wave 257; new to extra133"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingmaincurrent133

  columns: [id, function, args, expected, description]
  rows:
    - [main_thread_co_name_eq,
       "main_thread.__code__.co_name.__eq__",
       ["main_thread"],
       true,
       "threading.main_thread.__code__.co_name.__eq__('main_thread') == True — main_thread is defined with 'def main_thread():' in Lib/threading.py; co_name is the name from the def statement; str.__eq__('main_thread') returns True; new to extra133"]
    - [main_thread_co_argcount_eq_0,
       "main_thread.__code__.co_argcount.__eq__",
       [0],
       true,
       "threading.main_thread.__code__.co_argcount.__eq__(0) == True — main_thread accepts no arguments; co_argcount is 0; int.__eq__(0) returns True; new to extra133"]
    - [main_thread_co_varnames_len_eq_0,
       "main_thread.__code__.co_varnames.__len__",
       [],
       0,
       "threading.main_thread.__code__.co_varnames.__len__() == 0 — main_thread has no parameters and no local variables; co_varnames is an empty tuple; len() is 0; new to extra133"]
    - [current_thread_co_name_eq,
       "current_thread.__code__.co_name.__eq__",
       ["current_thread"],
       true,
       "threading.current_thread.__code__.co_name.__eq__('current_thread') == True — current_thread is defined with 'def current_thread():' in Lib/threading.py; co_name matches the def name; str.__eq__('current_thread') returns True; new to extra133"]
    - [current_thread_co_argcount_eq_0,
       "current_thread.__code__.co_argcount.__eq__",
       [0],
       true,
       "threading.current_thread.__code__.co_argcount.__eq__(0) == True — current_thread accepts no arguments; co_argcount is 0; int.__eq__(0) returns True; new to extra133"]
    - [current_thread_co_varnames_len_eq_0,
       "current_thread.__code__.co_varnames.__len__",
       [],
       0,
       "threading.current_thread.__code__.co_varnames.__len__() == 0 — current_thread has no parameters and no local variables; co_varnames is an empty tuple; len() is 0; new to extra133"]

# ---------------------------------------------------------------------------
# Table 2: threading.active_count code attributes
#
# Wave 257 theme: threading.active_count code object identity.
#
# threading.active_count.__code__.co_name == 'active_count'
# threading.active_count.__code__.co_argcount == 0
#
# active_count is a zero-argument Python function in Lib/threading.py;
# it returns the number of Thread objects currently alive. New to extra133.
# ---------------------------------------------------------------------------

table threading_extra133.active_count_code_attrs:
  description: "threading.active_count code attrs: co_name=='active_count', co_argcount==0; zero-argument Python function; wave 257; new to extra133"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingactivecount133

  columns: [id, function, args, expected, description]
  rows:
    - [active_count_co_name_eq,
       "active_count.__code__.co_name.__eq__",
       ["active_count"],
       true,
       "threading.active_count.__code__.co_name.__eq__('active_count') == True — active_count is defined with 'def active_count():' in Lib/threading.py; co_name is 'active_count'; str.__eq__('active_count') returns True; new to extra133"]
    - [active_count_co_argcount_eq_0,
       "active_count.__code__.co_argcount.__eq__",
       [0],
       true,
       "threading.active_count.__code__.co_argcount.__eq__(0) == True — active_count accepts no arguments; it returns the count of alive Thread objects; co_argcount is 0; int.__eq__(0) returns True; new to extra133"]
    - [active_count_qualname_eq,
       "active_count.__qualname__.__eq__",
       ["active_count"],
       true,
       "threading.active_count.__qualname__.__eq__('active_count') == True — active_count is defined at module scope in Lib/threading.py; __qualname__ equals the simple function name 'active_count'; str.__eq__('active_count') returns True; new to extra133"]
    - [active_count_module_eq_threading,
       "active_count.__module__.__eq__",
       ["threading"],
       true,
       "threading.active_count.__module__.__eq__('threading') == True — active_count is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra133"]

# ---------------------------------------------------------------------------
# Table 3: threading.settrace code attributes
#
# Wave 257 theme: threading.settrace code object attributes.
#
# threading.settrace.__code__.co_name == 'settrace'
# threading.settrace.__code__.co_argcount == 1
# threading.settrace.__code__.co_varnames[0] == 'func'
#
# settrace is a one-argument Python function; it installs a trace function
# for all threads spawned from the threading module. New to extra133.
# ---------------------------------------------------------------------------

table threading_extra133.settrace_code_attrs:
  description: "threading.settrace code attrs: co_name=='settrace', co_argcount==1, co_varnames[0]=='func'; one-argument Python function; wave 257; new to extra133"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingsettrace133

  columns: [id, function, args, expected, description]
  rows:
    - [settrace_co_name_eq,
       "settrace.__code__.co_name.__eq__",
       ["settrace"],
       true,
       "threading.settrace.__code__.co_name.__eq__('settrace') == True — settrace is defined with 'def settrace(func):' in Lib/threading.py; co_name is 'settrace'; str.__eq__('settrace') returns True; new to extra133"]
    - [settrace_co_argcount_eq_1,
       "settrace.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.settrace.__code__.co_argcount.__eq__(1) == True — settrace accepts one positional argument (func); co_argcount is 1; int.__eq__(1) returns True; new to extra133"]
    - [settrace_co_varnames_first_eq_func,
       "settrace.__code__.co_varnames[0].__eq__",
       ["func"],
       true,
       "threading.settrace.__code__.co_varnames[0].__eq__('func') == True — the first entry in co_varnames is the first parameter; for settrace that is 'func'; str.__eq__('func') returns True; new to extra133"]
    - [settrace_qualname_eq,
       "settrace.__qualname__.__eq__",
       ["settrace"],
       true,
       "threading.settrace.__qualname__.__eq__('settrace') == True — settrace is defined at module scope in Lib/threading.py; __qualname__ is the simple function name 'settrace'; str.__eq__('settrace') returns True; new to extra133"]
    - [settrace_module_eq_threading,
       "settrace.__module__.__eq__",
       ["threading"],
       true,
       "threading.settrace.__module__.__eq__('threading') == True — settrace is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra133"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra133
# ---------------------------------------------------------------------------

invariant threading_extra133.main_thread_co_name:
  description: "threading.main_thread.__code__.co_name == 'main_thread' — zero-argument function in Lib/threading.py; wave 257; new to extra133"
  kind: python_call_eq
  function: main_thread.__code__.co_name.__eq__
  args: ["main_thread"]
  expected: true

invariant threading_extra133.main_thread_co_argcount:
  description: "threading.main_thread.__code__.co_argcount == 0 — main_thread takes no arguments; wave 257; new to extra133"
  kind: python_call_eq
  function: main_thread.__code__.co_argcount.__eq__
  args: [0]
  expected: true

invariant threading_extra133.current_thread_co_name:
  description: "threading.current_thread.__code__.co_name == 'current_thread' — zero-argument function in Lib/threading.py; wave 257; new to extra133"
  kind: python_call_eq
  function: current_thread.__code__.co_name.__eq__
  args: ["current_thread"]
  expected: true

invariant threading_extra133.settrace_co_name:
  description: "threading.settrace.__code__.co_name == 'settrace' — one-argument function; installs trace for all threads; wave 257; new to extra133"
  kind: python_call_eq
  function: settrace.__code__.co_name.__eq__
  args: ["settrace"]
  expected: true

invariant threading_extra133.settrace_co_argcount:
  description: "threading.settrace.__code__.co_argcount == 1 — settrace takes one argument (func); wave 257; new to extra133"
  kind: python_call_eq
  function: settrace.__code__.co_argcount.__eq__
  args: [1]
  expected: true
