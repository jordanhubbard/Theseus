spec: logging_extra24
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends prior logging specs through logging_extra23.zspec.zsdl."
    - "logging_extra23 covers: Logger.debug/info/warning/error/critical/exception, Handler.emit/handle, Formatter.format __qualname__ values."
    - "Focus: __qualname__ values for StreamHandler.emit, FileHandler.emit, NullHandler.emit, Filter.filter, LogRecord.getMessage, LogRecord class, and module-level functions getLogger/basicConfig/makeLogRecord."
    - "logging.StreamHandler.emit.__qualname__ == 'StreamHandler.emit' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "logging.FileHandler.emit.__qualname__ == 'FileHandler.emit' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "logging.NullHandler.emit.__qualname__ == 'NullHandler.emit' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "logging.Filter.filter.__qualname__ == 'Filter.filter' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "logging.LogRecord.__qualname__ == 'LogRecord' — top-level class."
    - "logging.LogRecord.getMessage.__qualname__ == 'LogRecord.getMessage' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "logging.getLogger.__qualname__ == 'getLogger' — module-level function."
    - "logging.basicConfig.__qualname__ == 'basicConfig' — module-level function."
    - "logging.makeLogRecord.__qualname__ == 'makeLogRecord' — module-level function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# logging handler subclass method __qualname__ values
#
# StreamHandler, FileHandler, and NullHandler each override emit().
# Their __qualname__ encodes the defining class name, not the base Handler.
# logging_extra23 records Handler.emit.__qualname__; no prior spec records
# StreamHandler.emit, FileHandler.emit, or NullHandler.emit __qualname__.
# ---------------------------------------------------------------------------

invariant logging_extra24.StreamHandler.emit.qualname:
  description: "logging.StreamHandler.emit.__qualname__ == 'StreamHandler.emit'"
  category: method_qualname
  kind: python_call_eq
  function: "StreamHandler.emit.__qualname__.__eq__"
  args: ["StreamHandler.emit"]
  expected: true

invariant logging_extra24.FileHandler.emit.qualname:
  description: "logging.FileHandler.emit.__qualname__ == 'FileHandler.emit'"
  category: method_qualname
  kind: python_call_eq
  function: "FileHandler.emit.__qualname__.__eq__"
  args: ["FileHandler.emit"]
  expected: true

invariant logging_extra24.NullHandler.emit.qualname:
  description: "logging.NullHandler.emit.__qualname__ == 'NullHandler.emit'"
  category: method_qualname
  kind: python_call_eq
  function: "NullHandler.emit.__qualname__.__eq__"
  args: ["NullHandler.emit"]
  expected: true

# ---------------------------------------------------------------------------
# logging.Filter.filter method __qualname__ value
#
# Filter.filter is the primary filtering method on the Filter class.
# No prior logging spec records __qualname__ for Filter.filter.
# ---------------------------------------------------------------------------

invariant logging_extra24.Filter.filter.qualname:
  description: "logging.Filter.filter.__qualname__ == 'Filter.filter'"
  category: method_qualname
  kind: python_call_eq
  function: "Filter.filter.__qualname__.__eq__"
  args: ["Filter.filter"]
  expected: true

# ---------------------------------------------------------------------------
# logging.LogRecord class and method __qualname__ values
#
# LogRecord is a top-level class; its __qualname__ equals its class name.
# LogRecord.getMessage is the primary method for retrieving the formatted
# message. No prior logging spec records these __qualname__ values.
# ---------------------------------------------------------------------------

invariant logging_extra24.LogRecord.qualname:
  description: "logging.LogRecord.__qualname__ == 'LogRecord' — top-level class"
  category: class_qualname
  kind: python_call_eq
  function: "LogRecord.__qualname__.__eq__"
  args: ["LogRecord"]
  expected: true

invariant logging_extra24.LogRecord.getMessage.qualname:
  description: "logging.LogRecord.getMessage.__qualname__ == 'LogRecord.getMessage'"
  category: method_qualname
  kind: python_call_eq
  function: "LogRecord.getMessage.__qualname__.__eq__"
  args: ["LogRecord.getMessage"]
  expected: true

# ---------------------------------------------------------------------------
# logging module-level function __qualname__ values
#
# getLogger, basicConfig, and makeLogRecord are module-level functions.
# Their __qualname__ equals their simple name (no class prefix).
# No prior logging spec records __qualname__ for these three functions.
# ---------------------------------------------------------------------------

invariant logging_extra24.getLogger.qualname:
  description: "logging.getLogger.__qualname__ == 'getLogger' — module-level function"
  category: function_qualname
  kind: python_call_eq
  function: getLogger.__qualname__.__eq__
  args: ["getLogger"]
  expected: true

invariant logging_extra24.basicConfig.qualname:
  description: "logging.basicConfig.__qualname__ == 'basicConfig' — module-level function"
  category: function_qualname
  kind: python_call_eq
  function: basicConfig.__qualname__.__eq__
  args: ["basicConfig"]
  expected: true

invariant logging_extra24.makeLogRecord.qualname:
  description: "logging.makeLogRecord.__qualname__ == 'makeLogRecord' — module-level function"
  category: function_qualname
  kind: python_call_eq
  function: makeLogRecord.__qualname__.__eq__
  args: ["makeLogRecord"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all nine __qualname__ checks
#
# Covers StreamHandler.emit, FileHandler.emit, NullHandler.emit (handler
# subclass methods), Filter.filter (filter method), LogRecord class and
# LogRecord.getMessage (record class/method), and getLogger/basicConfig/
# makeLogRecord (module-level functions).
# ---------------------------------------------------------------------------

table logging_extra24.qualnames:
  description: "__qualname__ values for logging handler subclass methods, Filter, LogRecord, and module-level functions"
  kind: python_call_eq
  category: method_qualname

  columns: [id, function, args, expected]
  rows:
    - [StreamHandler.emit,      "StreamHandler.emit.__qualname__.__eq__",      ["StreamHandler.emit"],      true]
    - [FileHandler.emit,        "FileHandler.emit.__qualname__.__eq__",        ["FileHandler.emit"],        true]
    - [NullHandler.emit,        "NullHandler.emit.__qualname__.__eq__",        ["NullHandler.emit"],        true]
    - [Filter.filter,           "Filter.filter.__qualname__.__eq__",           ["Filter.filter"],           true]
    - [LogRecord,               "LogRecord.__qualname__.__eq__",               ["LogRecord"],               true]
    - [LogRecord.getMessage,    "LogRecord.getMessage.__qualname__.__eq__",    ["LogRecord.getMessage"],    true]
    - [getLogger,               getLogger.__qualname__.__eq__,                 ["getLogger"],               true]
    - [basicConfig,             basicConfig.__qualname__.__eq__,               ["basicConfig"],             true]
    - [makeLogRecord,           makeLogRecord.__qualname__.__eq__,             ["makeLogRecord"],           true]
