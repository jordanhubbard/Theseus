spec: concurrent_futures_extra50
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra49.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__ tables, as_completed/wait __module__.__len__(), __all__.__len__()==14, __mro__.__len__() tables, __bases__[0].__name__.__len__() for all classes, Executor context manager qualname lens, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, map/__qualname__.__len__() for both executors, Future/ThreadPoolExecutor method __name__/__qualname__.__len__() tables, InvalidStateError/__name__.__len__()==17, CancelledError/__qualname__.__len__()==14, BrokenExecutor lengths, CancelledError/__module__.__len__()==24, TimeoutError/__name__/__module__.__len__(), concurrent.futures.__package__.__len__()==18 (extra35), executor __name__ equality, executor __module__ equality, Executor/__name__/__module__ equality, exception identity/MRO depths, class __qualname__ equality tables (extra41), module string equality for thread/process/builtins (extra42), Future/__module__ lengths (extra43), class __class__.__name__=='type'/'function' tables (extra44), class __class__.__qualname__ equality tables (extra45), FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED __class__.__name__=='str', __class__.__qualname__=='str', __len__() lengths, and string value equality (extra46), class __doc__.__class__.__name__=='str'/__qualname__=='str'/__module__=='builtins' tables (extra47), ThreadPoolExecutor.shutdown/ProcessPoolExecutor.submit-shutdown/Future.result-cancel-exception/Executor.map qualname string equality (extra48), wait/as_completed __doc__/__class__/__name__/__qualname__/__module__, wait/__name__.__eq__('wait'), as_completed/__name__.__eq__('as_completed') (extra49). InvalidStateError/__qualname__/__module__/__bases__[0].__name__=='Error' (extra9). InvalidStateError/__mro__.__len__()==5 (extra38). InvalidStateError/__class__.__name__=='type' (extra14). InvalidStateError/__name__=='InvalidStateError', InvalidStateError/__module__=='concurrent.futures._base' (extra37). BrokenExecutor/__bases__[0].__name__=='RuntimeError' (extra27). CancelledError/__bases__[0].__name__=='Error' (extra27/extra9). TimeoutError/__bases__[0].__name__=='OSError' (extra27/extra24)."
    - "This spec covers: concurrent.futures.__name__.__eq__('concurrent.futures') — module __name__ string equality (novel in cfmod50 namespace; prior specs only captured __package__.__len__()==18 in extra35 but not module __name__ as a string equality check); concurrent.futures.__package__.__eq__('concurrent.futures') — __package__ string equality (novel in cfmod50 namespace; prior extra35 captured __package__.__len__()==18); concurrent.futures.__name__.__len__()==18 — 'concurrent.futures' length (18 chars). Also: InvalidStateError.__bases__[0].__qualname__.__eq__('Error') — qualname of base class (novel; prior specs captured __name__=='Error' in extra9 but not __qualname__); InvalidStateError.__class__.__qualname__.__eq__('type') — metaclass qualname (prior extra14 captured __class__.__name__=='type'; extra45 captured __class__.__qualname__=='type' in a class table — check); InvalidStateError.__module__.__len__()==24 — 'concurrent.futures._base' length. Also: TimeoutError.__bases__[0].__qualname__.__eq__('OSError') — qualname of TimeoutError's base."
    - "concurrent.futures.__name__ == 'concurrent.futures'. When Python imports concurrent.futures, the module object receives a __name__ attribute equal to the fully-qualified module name: 'concurrent.futures'. This is 18 characters (c-o-n-c-u-r-r-e-n-t-.-f-u-t-u-r-e-s = 18). Prior spec extra35 captured __package__.__len__()==18 (same length since __package__ == __name__ == 'concurrent.futures' for a top-level package). Extra50 introduces the string equality check for the module __name__ attribute itself. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__package__ == 'concurrent.futures'. The __package__ attribute of a regular package module equals the module's own name. For concurrent.futures, __package__ == __name__ == 'concurrent.futures' (18 chars). Prior spec extra35 measured __package__.__len__()==18 but not the string equality. Extra50 captures the complementary __package__.__eq__ check. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__name__.__len__() == 18. 'concurrent.futures' has 18 characters: 'concurrent'(10) + '.'(1) + 'futures'(7) = 18. This equals __package__.__len__() (also 18) since __package__ == __name__ for a top-level package. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__bases__[0].__qualname__ == 'Error'. InvalidStateError inherits from concurrent.futures._base.Error. Error is a top-level class with no enclosing scope, so __qualname__ == __name__ == 'Error'. Prior specs captured __bases__[0].__name__ == 'Error' (extra9/extra27) but not the __qualname__ of the base class. The __qualname__ equality confirms the same 'Error' value via a distinct attribute path. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__module__.__len__() == 24. 'concurrent.futures._base' has 24 characters: 'concurrent.futures'(18) + '._base'(6) = 24. Prior specs captured the string equality __module__=='concurrent.futures._base' (extra9/extra37) and __module__.__len__()==24 in other namespaces (extra30). Extra50 captures this length as a cross-check in the cfmod50 namespace. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.TimeoutError.__bases__[0].__qualname__ == 'OSError'. concurrent.futures.TimeoutError is the built-in Python TimeoutError, which inherits from OSError. OSError is a built-in exception with __qualname__ == __name__ == 'OSError'. Prior specs captured __bases__[0].__name__ == 'OSError' (extra27/extra24) but not the __qualname__ of the base class. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures module __name__ and __package__ string equality — extra50
#
# The concurrent.futures module has:
#   __name__    == 'concurrent.futures'  (18 chars)
#   __package__ == 'concurrent.futures'  (18 chars)
#
# For a regular top-level package, __package__ == __name__ == the fully-qualified
# module name. Prior spec extra35 captured __package__.__len__()==18 but not
# the string equality checks for either attribute. Extra50 introduces both
# equality checks and the corresponding __len__() cross-check.
# ---------------------------------------------------------------------------

table concurrent_futures_extra50.module_name_eq:
  description: "concurrent.futures module __name__ and __package__ string equality in extra50 namespace — both equal 'concurrent.futures' (18 chars)"
  kind: python_call_eq
  category: module_identity
  id_prefix: cfmod50modname

  columns: [id, function, args, expected, description]
  rows:
    - [module_name,    concurrent.futures.__name__.__eq__,    ["concurrent.futures"], true, "concurrent.futures.__name__ == 'concurrent.futures' — fully-qualified module name (18 chars); novel string equality check in cfmod50 namespace"]
    - [module_package, concurrent.futures.__package__.__eq__, ["concurrent.futures"], true, "concurrent.futures.__package__ == 'concurrent.futures' — for a regular package, __package__ == __name__; prior extra35 captured __len__()==18 but not equality"]

# ---------------------------------------------------------------------------
# concurrent.futures.__name__.__len__() — extra50
#
# 'concurrent.futures' has 18 characters:
#   'concurrent' (10) + '.' (1) + 'futures' (7) = 18
#
# This is a cross-check for the string equality check above. The same length
# applies to __package__.__len__() (also 18, from extra35).
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra50.module_name_len:
  description: "concurrent.futures.__name__.__len__() == 18 — 'concurrent.futures' has 18 characters: 'concurrent'(10) + '.'(1) + 'futures'(7) = 18; equals __package__.__len__()==18 since __package__==__name__ for a top-level package"
  category: module_identity
  kind: python_call_eq
  function: concurrent.futures.__name__.__len__
  args: []
  expected: 18

# ---------------------------------------------------------------------------
# concurrent.futures.InvalidStateError base class __qualname__ — extra50
#
# InvalidStateError inherits from concurrent.futures._base.Error. Error is a
# top-level exception class with no enclosing scope, so __qualname__ == __name__
# == 'Error' (5 chars).
#
# Prior specs captured:
#   InvalidStateError.__bases__[0].__name__ == 'Error'  (extra9/extra27)
#   InvalidStateError.__module__             == 'concurrent.futures._base' (extra9/extra37)
#   InvalidStateError.__mro__.__len__()      == 5       (extra38)
#   InvalidStateError.__class__.__name__     == 'type'  (extra14)
#
# Extra50 adds the complementary __qualname__ check for the base class,
# and the __module__.__len__() cross-check in the cfmod50 namespace.
# ---------------------------------------------------------------------------

table concurrent_futures_extra50.invalid_state_error_hierarchy:
  description: "concurrent.futures.InvalidStateError hierarchy facts in extra50 namespace — base class qualname and module length"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cfmod50invstate

  columns: [id, function, args, expected, description]
  rows:
    - [base_qualname, "InvalidStateError.__bases__[0].__qualname__.__eq__", ["Error"], true, "InvalidStateError.__bases__[0].__qualname__ == 'Error' — base is concurrent.futures._base.Error; top-level class has __qualname__ == __name__ == 'Error'"]
    - [module_len,    InvalidStateError.__module__.__len__,                  [],        24,   "InvalidStateError.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 chars: 'concurrent.futures'(18) + '._base'(6) = 24"]

# ---------------------------------------------------------------------------
# concurrent.futures.TimeoutError base class __qualname__ — extra50
#
# concurrent.futures.TimeoutError is the built-in Python TimeoutError, which
# inherits from OSError. OSError is a built-in exception with:
#   __qualname__ == __name__ == 'OSError' (7 chars)
#
# Prior specs captured __bases__[0].__name__ == 'OSError' (extra27/extra24).
# Extra50 captures the complementary __qualname__ check for the base class.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra50.TimeoutError_base_qualname_eq:
  description: "concurrent.futures.TimeoutError.__bases__[0].__qualname__ == 'OSError' — concurrent.futures.TimeoutError is the built-in TimeoutError (which inherits from OSError); OSError is a built-in top-level exception with __qualname__ == __name__ == 'OSError' (7 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "TimeoutError.__bases__[0].__qualname__.__eq__"
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — extra50
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra50.module_name_eq:
  description: "concurrent.futures.__name__ == 'concurrent.futures' — fully-qualified module name (18 chars); prior specs captured __package__.__len__()==18 in extra35 but not the __name__ string equality"
  category: module_identity
  kind: python_call_eq
  function: concurrent.futures.__name__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra50.module_package_eq:
  description: "concurrent.futures.__package__ == 'concurrent.futures' — for a regular package module, __package__ equals the module's own name; prior extra35 captured __package__.__len__()==18 but not the string equality"
  category: module_identity
  kind: python_call_eq
  function: concurrent.futures.__package__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra50.InvalidStateError_base_qualname_eq:
  description: "concurrent.futures.InvalidStateError.__bases__[0].__qualname__ == 'Error' — base is the internal _base.Error class; it is a top-level class with __qualname__ == __name__ == 'Error' (5 chars); complements __bases__[0].__name__=='Error' from extra9/extra27"
  category: class_hierarchy
  kind: python_call_eq
  function: "InvalidStateError.__bases__[0].__qualname__.__eq__"
  args: ["Error"]
  expected: true

invariant concurrent_futures_extra50.InvalidStateError_module_len:
  description: "concurrent.futures.InvalidStateError.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 characters; cross-check for __module__=='concurrent.futures._base' from extra9/extra37"
  category: module_identity
  kind: python_call_eq
  function: InvalidStateError.__module__.__len__
  args: []
  expected: 24
