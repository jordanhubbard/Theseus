spec: multiprocessing_extra50
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — Pool documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing_extra49.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__ tables, DefaultContext method qualname lengths, BaseProcess metadata, function __name__.__len__() tables, pool result class tables, Process/__name__=='Process', Process/__module__=='multiprocessing.context', Queue/__name__=='Queue', Pipe/__name__=='Pipe', Process method __qualname__ string equality for start/run/join/terminate/kill/is_alive/close (all == 'BaseProcess.<method>'), function __name__/__module__ equality for cpu_count/current_process/active_children, AuthenticationError/__name__/__module__/__bases__[0].__name__, ProcessError/__name__/__bases__[0].__name__, exception __module__ equality, ProcessError/__mro__.__len__()==4, exception subclass MRO depths, class/function qualname string equality tables, context class tables (extra40–extra44), Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__name__=='function', ProcessError/AuthenticationError/__class__.__name__=='type' (extra45), Process/__class__.__qualname__=='type', ProcessError/__class__.__qualname__=='type', current_process/__class__.__qualname__=='function', cpu_count/__class__.__qualname__=='method', Process/__class__.__module__=='builtins', current_process/__class__.__module__=='builtins', cpu_count/__class__.__module__=='builtins' (extra46), ProcessError/__bases__[0].__name__=='Exception', AuthenticationError/__bases__[0].__name__=='ProcessError', ProcessError/__mro__.__len__()==4, AuthenticationError/__mro__.__len__()==5, ProcessError/__module__=='multiprocessing.context', AuthenticationError/__module__=='multiprocessing.context', Queue/__class__.__name__=='method', Pipe/__class__.__name__=='method' (extra47), Process/__doc__/__class__/__name__=='str', ProcessError/__doc__/__class__/__name__=='str', AuthenticationError/__doc__/__class__/__name__=='str', module __doc__/__class__/__name__=='str', Process/__doc__/__class__/__qualname__=='str', ProcessError/__doc__/__class__/__qualname__=='str', Process/__doc__/__class__/__module__=='builtins', BufferTooShort/__bases__[0].__name__=='ProcessError', BufferTooShort/__mro__.__len__()==5, TimeoutError/__mro__.__len__()==5 (extra48). Process property descriptor __class__.__name__=='property' for pid/name/daemon/exitcode/authkey/sentinel; Process.__init__.__qualname__=='BaseProcess.__init__' (extra49). Pool/__class__.__name__=='type' (multiprocessing_extra). Pool/__name__=='Pool', Pool/__module__=='multiprocessing.pool', Pool/__qualname__=='Pool', Pool/__bases__[0].__name__=='object', Pool/__bases__[0].__name__.__len__()==6, Pool/__mro__.__len__()==2 (various prior specs). current_process/__module__=='multiprocessing.process', active_children/__module__=='multiprocessing.process' (extra38, extra23)."
    - "This spec covers: Pool/__class__.__qualname__=='type'; Pool/__doc__/__class__/__name__=='str'; Pool/__doc__/__class__.__qualname__=='str'; Pool/__doc__/__class__/__module__=='builtins'; BufferTooShort/__doc__/__class__/__name__=='str'; TimeoutError/__doc__/__class__/__name__=='str'; Pool/__name__.__len__()==4; Pool/__module__.__len__()==20."
    - "multiprocessing.Pool.__class__.__qualname__ == 'type'. Pool is a plain Python class defined in Lib/multiprocessing/pool.py; its metaclass is the built-in 'type'. The built-in 'type' has no enclosing class or function scope, so __qualname__ == __name__ == 'type' (4 chars). Prior specs captured Pool.__class__.__name__ == 'type' (multiprocessing_extra) but not Pool.__class__.__qualname__. Extra50 supplies the complementary __qualname__ check. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__doc__.__class__.__name__ == 'str'. Pool is a class with a docstring describing its process pool API. Python stores class docstrings as plain str instances; __class__.__name__ == 'str'. Prior specs surveyed __doc__.__class__.__name__ for Process, ProcessError, AuthenticationError, and the module (extra48) but did not cover Pool. Extra50 extends the __doc__ survey to Pool. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__doc__.__class__.__qualname__ == 'str'. The built-in str type has __qualname__ == __name__ == 'str' (no enclosing scope). Pool's docstring is a str instance; str.__qualname__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__doc__.__class__.__module__ == 'builtins'. The str type is a built-in type defined in the builtins module; every str instance's __class__.__module__ == 'builtins'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.BufferTooShort.__doc__.__class__.__name__ == 'str'. BufferTooShort is raised when a result object is too large for a provided buffer. It has a docstring stored as a plain Python string; __class__.__name__ == 'str'. Prior extra48 covered Process/ProcessError/AuthenticationError __doc__ but not BufferTooShort. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.TimeoutError.__doc__.__class__.__name__ == 'str'. multiprocessing.TimeoutError (a subclass of ProcessError, distinct from the built-in TimeoutError) has a docstring stored as a plain Python string; __class__.__name__ == 'str'. Prior extra48 covered Process/ProcessError/AuthenticationError but not TimeoutError. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__name__.__len__() == 4. 'Pool' has 4 characters. This is a length cross-check for the string equality 'Pool' captured in prior specs. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__module__.__len__() == 20. 'multiprocessing.pool' has 20 characters: m-u-l-t-i-p-r-o-c-e-s-s-i-n-g-.-p-o-o-l = 20. This cross-checks the string equality Pool.__module__ == 'multiprocessing.pool' captured in extra13/extra30. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Pool __class__.__qualname__ — extra50
#
# Pool is a plain Python class defined in Lib/multiprocessing/pool.py. Its
# metaclass is the built-in 'type'. Prior specs (multiprocessing_extra) verified
# Pool.__class__.__name__ == 'type'. Extra50 adds the complementary
# __class__.__qualname__ check: since 'type' has no enclosing scope,
# __qualname__ == __name__ == 'type' (4 chars).
# ---------------------------------------------------------------------------

invariant multiprocessing_extra50.Pool_class_qualname_eq:
  description: "multiprocessing.Pool.__class__.__qualname__ == 'type' — Pool is a plain Python class; its metaclass is the built-in 'type'; 'type' has __qualname__ == __name__ == 'type' (4 chars); complements Pool.__class__.__name__=='type' from multiprocessing_extra"
  category: class_names
  kind: python_call_eq
  function: Pool.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing.Pool __doc__.__class__ attributes — extra50
#
# Pool has a class docstring describing its process pool interface. Python
# stores docstrings as plain str instances. Three dimensions are checked:
#   Pool.__doc__.__class__.__name__    == 'str'
#   Pool.__doc__.__class__.__qualname__== 'str'
#   Pool.__doc__.__class__.__module__  == 'builtins'
#
# Prior spec extra48 covered Process, ProcessError, AuthenticationError, and
# the module __doc__ but did not cover Pool. Extra50 extends the __doc__ survey.
# ---------------------------------------------------------------------------

table multiprocessing_extra50.pool_doc_class_eq:
  description: "multiprocessing.Pool __doc__.__class__ attributes in extra50 namespace — class docstring is a str instance; str is a built-in type"
  kind: python_call_eq
  category: class_names
  id_prefix: mppool50pooldoc

  columns: [id, function, args, expected, description]
  rows:
    - [name,     Pool.__doc__.__class__.__name__.__eq__,     ["str"],      true, "Pool.__doc__.__class__.__name__ == 'str' — Pool has a class docstring stored as a plain Python string"]
    - [qualname, Pool.__doc__.__class__.__qualname__.__eq__, ["str"],      true, "Pool.__doc__.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str' (no enclosing scope)"]
    - [module,   Pool.__doc__.__class__.__module__.__eq__,   ["builtins"], true, "Pool.__doc__.__class__.__module__ == 'builtins' — str is a built-in type; every str instance has __class__.__module__ == 'builtins'"]

# ---------------------------------------------------------------------------
# multiprocessing exception __doc__.__class__.__name__ — extra50
#
# Prior spec extra48 surveyed __doc__.__class__.__name__ for Process, ProcessError,
# AuthenticationError, and the module, but not BufferTooShort or TimeoutError.
# Extra50 extends the __doc__ survey to these two remaining exception classes:
#   BufferTooShort.__doc__.__class__.__name__ == 'str'
#   TimeoutError.__doc__.__class__.__name__   == 'str'
# Both have docstrings stored as plain Python strings, consistent with the
# universal Python invariant that docstrings are always str instances.
# ---------------------------------------------------------------------------

table multiprocessing_extra50.exc_doc_class_name_eq:
  description: "multiprocessing exception __doc__.__class__.__name__ string equality in extra50 namespace — BufferTooShort and TimeoutError docstrings are str instances"
  kind: python_call_eq
  category: class_names
  id_prefix: mppool50excdocname

  columns: [id, function, args, expected, description]
  rows:
    - [BufferTooShort, BufferTooShort.__doc__.__class__.__name__.__eq__, ["str"], true, "BufferTooShort.__doc__.__class__.__name__ == 'str' — exception raised when a result is too large for the provided buffer; docstring is a plain Python string"]
    - [TimeoutError,   TimeoutError.__doc__.__class__.__name__.__eq__,   ["str"], true, "TimeoutError.__doc__.__class__.__name__ == 'str' — multiprocessing.TimeoutError (subclass of ProcessError, distinct from built-in TimeoutError); docstring is a plain Python string"]

# ---------------------------------------------------------------------------
# multiprocessing.Pool __name__.__len__() and __module__.__len__() — extra50
#
# Pool.__name__ == 'Pool' (4 chars) — string equality was captured in extra4/extra5.
# Pool.__module__ == 'multiprocessing.pool' (20 chars) — string equality covered
# in extra13/extra30. Extra50 captures the __len__() cross-checks in the mppool50
# namespace, pairing with the string equality checks from prior specs.
# ---------------------------------------------------------------------------

table multiprocessing_extra50.pool_identity_len:
  description: "multiprocessing.Pool __name__.__len__() and __module__.__len__() in extra50 namespace — 'Pool'==4, 'multiprocessing.pool'==20"
  kind: python_call_eq
  category: module_identity
  id_prefix: mppool50identlen

  columns: [id, function, args, expected, description]
  rows:
    - [name_len,   Pool.__name__.__len__,   [], 4,  "Pool.__name__.__len__() == 4 — 'Pool' has 4 characters; cross-check for Pool.__name__=='Pool' from prior specs"]
    - [module_len, Pool.__module__.__len__, [], 20, "Pool.__module__.__len__() == 20 — 'multiprocessing.pool' has 20 characters: 'multiprocessing'(15) + '.'(1) + 'pool'(4) = 20"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra50
# ---------------------------------------------------------------------------

invariant multiprocessing_extra50.Pool_doc_class_name_eq:
  description: "multiprocessing.Pool.__doc__.__class__.__name__ == 'str' — Pool has a class docstring stored as a plain Python string; __class__ is the built-in str type; first __doc__ survey of Pool across all multiprocessing specs"
  category: class_names
  kind: python_call_eq
  function: Pool.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant multiprocessing_extra50.Pool_doc_class_qualname_eq:
  description: "multiprocessing.Pool.__doc__.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str'; no enclosing scope"
  category: class_names
  kind: python_call_eq
  function: Pool.__doc__.__class__.__qualname__.__eq__
  args: ["str"]
  expected: true

invariant multiprocessing_extra50.Pool_doc_class_module_eq:
  description: "multiprocessing.Pool.__doc__.__class__.__module__ == 'builtins' — str is a built-in type defined in the builtins module; every str instance has __class__.__module__ == 'builtins'"
  category: module_identity
  kind: python_call_eq
  function: Pool.__doc__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant multiprocessing_extra50.BufferTooShort_doc_class_name_eq:
  description: "multiprocessing.BufferTooShort.__doc__.__class__.__name__ == 'str' — BufferTooShort is an exception raised when a result is too large for a provided buffer; its docstring is a plain Python string"
  category: class_names
  kind: python_call_eq
  function: BufferTooShort.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant multiprocessing_extra50.TimeoutError_doc_class_name_eq:
  description: "multiprocessing.TimeoutError.__doc__.__class__.__name__ == 'str' — multiprocessing.TimeoutError is a ProcessError subclass (not the built-in TimeoutError); its docstring is a plain Python string"
  category: class_names
  kind: python_call_eq
  function: TimeoutError.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant multiprocessing_extra50.Pool_name_len:
  description: "multiprocessing.Pool.__name__.__len__() == 4 — 'Pool' has 4 characters; cross-check for Pool.__name__=='Pool' from extra4/extra5"
  category: module_identity
  kind: python_call_eq
  function: Pool.__name__.__len__
  args: []
  expected: 4

invariant multiprocessing_extra50.Pool_module_len:
  description: "multiprocessing.Pool.__module__.__len__() == 20 — 'multiprocessing.pool' has 20 characters; cross-check for Pool.__module__=='multiprocessing.pool' from extra13/extra30"
  category: module_identity
  kind: python_call_eq
  function: Pool.__module__.__len__
  args: []
  expected: 20
