spec: he
version: ">=1.0.0"
backend: node(he)

docs: https://www.npmjs.com/package/he

provenance:
  derived_from:
    - "he README — https://www.npmjs.com/package/he"
    - "Test vectors verified with he via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "he source"
  notes:
    - "he is an npm package. Install: npm install he"
    - "he.encode(str) converts special chars to hex HTML entities (e.g. < → &#x3C;)."
    - "he.escape(str) converts only &<>\"' to named entities (e.g. < → &lt;)."
    - "he.decode(str) / he.unescape(str) reverse the above."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns encoded or decoded string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table he.encode:
  kind: node_module_call_eq
  function: encode
  category: encode
  id_prefix: heenc

  columns: [id, args, expected]
  rows:
    - [html, ["<p>Hello & World</p>"],
       "&#x3C;p&#x3E;Hello &#x26; World&#x3C;/p&#x3E;"]

table he.decode:
  kind: node_module_call_eq
  function: decode
  category: decode
  id_prefix: hedec

  columns: [id, args, expected]
  rows:
    - [html, ["&lt;p&gt;Hello &amp; World&lt;/p&gt;"],
       "<p>Hello & World</p>"]

table he.escape:
  kind: node_module_call_eq
  function: escape
  category: encode
  id_prefix: heesc

  columns: [id, args, expected]
  rows:
    - [html, ["<p>test</p>"], "&lt;p&gt;test&lt;/p&gt;"]

table he.unescape:
  kind: node_module_call_eq
  function: unescape
  category: decode
  id_prefix: heunesc

  columns: [id, args, expected]
  rows:
    - [html, ["&lt;p&gt;test&lt;/p&gt;"], "<p>test</p>"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
