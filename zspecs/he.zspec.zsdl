spec: he
version: ">=1.0.0"
backend: node(he)

docs: https://github.com/mathiasbynens/he#readme

provenance:
  derived_from:
    - "he README — https://github.com/mathiasbynens/he#readme"
    - "HTML 5 named character references — https://html.spec.whatwg.org/multipage/named-characters.html"
    - "Test vectors verified with he@1.2.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "he source: he.js"
  notes:
    - "he exports an object with encode() and decode() methods."
    - "encode() converts special characters to HTML numeric/named entities."
    - "decode() converts HTML entities back to characters (named, numeric decimal, and numeric hex)."
    - "he.encode uses numeric hex entities (&#x26; not &amp;) by default."
    - "he.decode('&copy;') → '©' (named entity), he.decode('&#65;') → 'A' (numeric)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "encode/decode return the transformed string. No errors for valid inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table he.encode:
  kind: node_module_call_eq
  function: encode
  category: encode
  id_prefix: encode

  columns: [id, args, expected]
  rows:
    - [ampersand,    ["&"],       "&#x26;"]
    - [less_than,    ["<"],       "&#x3C;"]
    - [greater_than, [">"],       "&#x3E;"]
    - [double_quote, ["\""],      "&#x22;"]
    - [plain,        ["hello"],   "hello"]

table he.decode:
  kind: node_module_call_eq
  function: decode
  category: decode
  id_prefix: decode

  columns: [id, args, expected]
  rows:
    - [amp,      ["&amp;"],   "&"]
    - [lt,       ["&lt;"],    "<"]
    - [named,    ["&copy;"],  "©"]
    - [numeric,  ["&#65;"],   "A"]
