spec: uuid_extra319
version: ">=3.2"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module identity attributes
# uuid.__package__ is '' (empty string) — the uuid module has no package.
# uuid does NOT define __all__; checking __all__ existence would raise AttributeError.
# ---------------------------------------------------------------------------

invariant uuid_extra319.module.name:
  description: "uuid.__name__ == 'uuid'"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra319.module.package:
  description: "uuid.__package__ == '' (empty string — uuid is a top-level module, not a package)"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant uuid_extra319.module.spec_name:
  description: "uuid.__spec__.name == 'uuid'"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__doc__ — type and length
# Verified: uuid.__doc__.__len__() == 1948 on Python 3.14.3 macOS
# ---------------------------------------------------------------------------

invariant uuid_extra319.doc.class_name:
  description: "uuid.__doc__.__class__.__name__ == 'str' (module docstring is a str)"
  category: module_identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant uuid_extra319.doc.length:
  description: "uuid.__doc__.__len__() == 1948 (verified against Python 3.14.3)"
  category: module_identity
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 1948

# ---------------------------------------------------------------------------
# Function and class qualnames
# uuid.uuid4.__qualname__ == 'uuid4' (simple top-level function)
# uuid.UUID.__qualname__ == 'UUID' (top-level class)
# uuid.SafeUUID.__qualname__ == 'SafeUUID' (top-level enum class)
# ---------------------------------------------------------------------------

table uuid_extra319.qualnames:
  description: "uuid module top-level functions and classes have matching __qualname__"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [uuid4,     uuid4.__qualname__.__eq__,     ["uuid4"],     true]
    - [UUID,      UUID.__qualname__.__eq__,      ["UUID"],      true]
    - [SafeUUID,  SafeUUID.__qualname__.__eq__,  ["SafeUUID"],  true]
