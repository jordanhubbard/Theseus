spec: warnings_extra21
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
  notes:
    - "This spec extends prior warnings specs through warnings_extra20.zspec.zsdl."
    - "warnings_extra14 covers: filterwarnings/__name__/__module__ and simplefilter/__name__/__module__ via table."
    - "warnings_extra15 covers: resetwarnings/__name__/__module__ and warn/__name__ via table."
    - "warnings_extra18 covers: warn/warn_explicit/filterwarnings/simplefilter/resetwarnings function __qualname__ and catch_warnings class __qualname__."
    - "warnings_extra20 covers: WarningMessage/__module__, catch_warnings/__module__, catch_warnings base class, WarningMessage.__init__.__qualname__, PendingDeprecationWarning.__qualname__."
    - "Focus: __class__.__name__ for warn and warn_explicit (builtin_function_or_method vs function); __qualname__ and __module__ for DeprecationWarning, ResourceWarning, and SyntaxWarning builtin warning classes."
    - "warnings.warn.__class__.__name__ == 'builtin_function_or_method' — warn is implemented in C (_warnings). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.warn_explicit.__class__.__name__ == 'builtin_function_or_method' — warn_explicit is implemented in C. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.filterwarnings.__class__.__name__ == 'function' — filterwarnings is a pure-Python function. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.simplefilter.__class__.__name__ == 'function' — simplefilter is a pure-Python function. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.resetwarnings.__class__.__name__ == 'function' — resetwarnings is a pure-Python function. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "DeprecationWarning.__qualname__ == 'DeprecationWarning' — builtin warning class. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "ResourceWarning.__qualname__ == 'ResourceWarning' — builtin warning class. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "SyntaxWarning.__qualname__ == 'SyntaxWarning' — builtin warning class. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "ResourceWarning.__bases__[0].__name__ == 'Warning' — inherits directly from Warning. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# warn and warn_explicit __class__.__name__
#
# warnings.warn and warnings.warn_explicit are implemented in C (_warnings
# extension). Their __class__.__name__ == 'builtin_function_or_method'.
# warnings_extra15 records warn.__name__; warnings_extra18 records
# warn.__qualname__. No prior warnings spec records __class__.__name__ for
# warn or warn_explicit as standalone named invariants.
# ---------------------------------------------------------------------------

invariant warnings_extra21.warn.class_name:
  description: "warnings.warn.__class__.__name__ == 'builtin_function_or_method' — warn is a C builtin"
  category: function_type
  kind: python_call_eq
  function: warn.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant warnings_extra21.warn_explicit.class_name:
  description: "warnings.warn_explicit.__class__.__name__ == 'builtin_function_or_method' — warn_explicit is a C builtin"
  category: function_type
  kind: python_call_eq
  function: warn_explicit.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# filterwarnings, simplefilter, resetwarnings __class__.__name__
#
# These three functions are pure Python (defined in Lib/warnings.py /
# _py_warnings). Their __class__.__name__ == 'function'. warnings_extra14 and
# warnings_extra15 record __name__ and __module__ for these functions.
# No prior warnings spec records __class__.__name__ for any of them as a
# standalone named invariant in the extra21 namespace.
# ---------------------------------------------------------------------------

invariant warnings_extra21.filterwarnings.class_name:
  description: "warnings.filterwarnings.__class__.__name__ == 'function' — pure-Python function"
  category: function_type
  kind: python_call_eq
  function: filterwarnings.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant warnings_extra21.simplefilter.class_name:
  description: "warnings.simplefilter.__class__.__name__ == 'function' — pure-Python function"
  category: function_type
  kind: python_call_eq
  function: simplefilter.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant warnings_extra21.resetwarnings.class_name:
  description: "warnings.resetwarnings.__class__.__name__ == 'function' — pure-Python function"
  category: function_type
  kind: python_call_eq
  function: resetwarnings.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# DeprecationWarning, ResourceWarning, SyntaxWarning __qualname__
#
# warnings_extra19 covers FutureWarning, UserWarning, RuntimeWarning
# __qualname__. warnings_extra20 covers PendingDeprecationWarning.__qualname__.
# No prior warnings spec records __qualname__ for DeprecationWarning,
# ResourceWarning, or SyntaxWarning as standalone named invariants.
# ---------------------------------------------------------------------------

invariant warnings_extra21.DeprecationWarning.qualname:
  description: "DeprecationWarning.__qualname__ == 'DeprecationWarning' — builtin warning class qualname equals class name"
  category: class_qualname
  kind: python_call_eq
  function: DeprecationWarning.__qualname__.__eq__
  args: ["DeprecationWarning"]
  expected: true

invariant warnings_extra21.ResourceWarning.qualname:
  description: "ResourceWarning.__qualname__ == 'ResourceWarning' — builtin warning class qualname equals class name"
  category: class_qualname
  kind: python_call_eq
  function: ResourceWarning.__qualname__.__eq__
  args: ["ResourceWarning"]
  expected: true

invariant warnings_extra21.SyntaxWarning.qualname:
  description: "SyntaxWarning.__qualname__ == 'SyntaxWarning' — builtin warning class qualname equals class name"
  category: class_qualname
  kind: python_call_eq
  function: SyntaxWarning.__qualname__.__eq__
  args: ["SyntaxWarning"]
  expected: true

# ---------------------------------------------------------------------------
# ResourceWarning base class
#
# ResourceWarning inherits directly from Warning. No prior warnings spec
# records ResourceWarning.__bases__[0].__name__ as a standalone invariant
# in the extra21 namespace (extra3 and others cover DeprecationWarning and
# SyntaxWarning bases via __getitem__ method_chain style).
# ---------------------------------------------------------------------------

invariant warnings_extra21.ResourceWarning.base_name:
  description: "ResourceWarning.__bases__[0].__name__ == 'Warning' — ResourceWarning inherits directly from Warning"
  category: class_hierarchy
  kind: python_call_eq
  function: "ResourceWarning.__bases__[0].__name__.__eq__"
  args: ["Warning"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all nine function-type and class-qualname checks
#
# Covers warn/warn_explicit __class__.__name__ (2), filterwarnings/
# simplefilter/resetwarnings __class__.__name__ (3), DeprecationWarning/
# ResourceWarning/SyntaxWarning __qualname__ (3), and ResourceWarning
# base class (1).
# ---------------------------------------------------------------------------

table warnings_extra21.function_types_and_class_qualnames:
  description: "__class__.__name__ for warning functions and __qualname__ for builtin warning classes"
  kind: python_call_eq
  category: function_type

  columns: [id, function, args, expected]
  rows:
    - [warn_class_name,            warn.__class__.__name__.__eq__,                    ["builtin_function_or_method"], true]
    - [warn_explicit_class_name,   warn_explicit.__class__.__name__.__eq__,           ["builtin_function_or_method"], true]
    - [filterwarnings_class_name,  filterwarnings.__class__.__name__.__eq__,          ["function"],                   true]
    - [simplefilter_class_name,    simplefilter.__class__.__name__.__eq__,            ["function"],                   true]
    - [resetwarnings_class_name,   resetwarnings.__class__.__name__.__eq__,           ["function"],                   true]
    - [DeprecationWarning_qualname, DeprecationWarning.__qualname__.__eq__,           ["DeprecationWarning"],          true]
    - [ResourceWarning_qualname,   ResourceWarning.__qualname__.__eq__,               ["ResourceWarning"],             true]
    - [SyntaxWarning_qualname,     SyntaxWarning.__qualname__.__eq__,                 ["SyntaxWarning"],               true]
    - [ResourceWarning_base,       "ResourceWarning.__bases__[0].__name__.__eq__",    ["Warning"],                    true]
