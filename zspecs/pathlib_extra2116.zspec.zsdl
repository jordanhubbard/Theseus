  columns: [id, function, args, expected]
  rows:
    - ["pl2116013", "pathlib.PurePath.__dict__.__contains__",        ["__and__"],  false]
    - ["pl2116014", "pathlib.PurePath.__dict__.__contains__",        ["__rand__"], false]
    - ["pl2116015", "pathlib.PurePath.__dict__.__contains__",        ["__iand__"], false]
    - ["pl2116016", "pathlib.PurePosixPath.__dict__.__contains__",   ["__and__"],  false]
    - ["pl2116017", "pathlib.PurePosixPath.__dict__.__contains__",   ["__rand__"], false]
    - ["pl2116018", "pathlib.PurePosixPath.__dict__.__contains__",   ["__iand__"], false]
    - ["pl2116019", "pathlib.PureWindowsPath.__dict__.__contains__", ["__and__"],  false]
    - ["pl2116020", "pathlib.PureWindowsPath.__dict__.__contains__", ["__rand__"], false]
    - ["pl2116021", "pathlib.PureWindowsPath.__dict__.__contains__", ["__iand__"], false]
    - ["pl2116022", "pathlib.Path.__dict__.__contains__",            ["__and__"],  false]
    - ["pl2116023", "pathlib.Path.__dict__.__contains__",            ["__rand__"], false]
    - ["pl2116024", "pathlib.Path.__dict__.__contains__",            ["__iand__"], false]

