  columns: [id, function, args, expected]
  rows:
    - ["pl2116025", "pathlib.PurePath.__dict__.__contains__",        ["__xor__"],  false]
    - ["pl2116026", "pathlib.PurePath.__dict__.__contains__",        ["__rxor__"], false]
    - ["pl2116027", "pathlib.PurePath.__dict__.__contains__",        ["__ixor__"], false]
    - ["pl2116028", "pathlib.PurePosixPath.__dict__.__contains__",   ["__xor__"],  false]
    - ["pl2116029", "pathlib.PurePosixPath.__dict__.__contains__",   ["__rxor__"], false]
