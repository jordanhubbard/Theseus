spec: pathlib_extra2116
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2116: __or__/__ror__/__ior__, __and__/__rand__/__iand__, __xor__/__rxor__/__ixor__ dict-presence checks."
    - "pathlib.Path, PurePath, PurePosixPath, PureWindowsPath are filesystem path classes."
    - "None of these pathlib classes define set/dict merge operators (__or__, __ror__, __ior__) in their own __dict__."
    - "None of these pathlib classes define set-intersection operators (__and__, __rand__, __iand__) in their own __dict__."
    - "None of these pathlib classes define set-symmetric-difference operators (__xor__, __rxor__, __ixor__) in their own __dict__."
    - "pathlib paths use __truediv__ (/) for path joining, not __or__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __or__ / __ror__ / __ior__ — dict-merge / set-union dict-presence
# None of the pathlib path classes define these operators
# ---------------------------------------------------------------------------

table pathlib_extra2116.or_protocol:
  description: "pathlib types __or__/__ror__/__ior__ dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2116

  columns: [id, function, args, expected]
  rows:
    - ["pl2116001", "pathlib.PurePath.__dict__.__contains__",        ["__or__"],  false]
    - ["pl2116002", "pathlib.PurePath.__dict__.__contains__",        ["__ror__"], false]
    - ["pl2116003", "pathlib.PurePath.__dict__.__contains__",        ["__ior__"], false]
    - ["pl2116004", "pathlib.PurePosixPath.__dict__.__contains__",   ["__or__"],  false]
    - ["pl2116005", "pathlib.PurePosixPath.__dict__.__contains__",   ["__ror__"], false]
    - ["pl2116006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__ior__"], false]
    - ["pl2116007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__or__"],  false]
    - ["pl2116008", "pathlib.PureWindowsPath.__dict__.__contains__", ["__ror__"], false]
    - ["pl2116009", "pathlib.PureWindowsPath.__dict__.__contains__", ["__ior__"], false]
    - ["pl2116010", "pathlib.Path.__dict__.__contains__",            ["__or__"],  false]
    - ["pl2116011", "pathlib.Path.__dict__.__contains__",            ["__ror__"], false]
    - ["pl2116012", "pathlib.Path.__dict__.__contains__",            ["__ior__"], false]

