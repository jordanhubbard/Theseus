spec: functools_extra51
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra50.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps/partial/lru_cache/total_ordering/singledispatch/cached_property/reduce/cmp_to_key/partialmethod/singledispatchmethod/update_wrapper; __qualname__.__len__() for update_wrapper/partialmethod/singledispatchmethod/cache/total_ordering/singledispatch/cmp_to_key/cached_property/lru_cache/wraps/reduce/partial; WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES lengths; __all__ lengths; partial/__class__.__name__; cached_property/__set_name__/__get__/__init__.__qualname__; partial/__new__.__qualname__; class __dict__.__class__.__name__.__len__ for partial/partialmethod/singledispatchmethod/cached_property; reduce with initial value; lru_cache(128).__ne__(None)==True; lru_cache(maxsize=2) behavioral; reduce/__qualname__=='reduce'; lru_cache/__qualname__=='lru_cache'; cache/__name__/__qualname__/__module__; cached_property/__name__/__qualname__/__module__/__bases__[0].__name__; total_ordering/__name__/__qualname__/__module__; singledispatch/__name__/__qualname__/__module__; wraps/__name__/__qualname__/__module__; update_wrapper/__name__/__qualname__/__module__; partial/__bases__[0].__name__=='object'; partial/__name__/__qualname__/__module__; lru_cache/__name__/__module__; cmp_to_key/__name__=='cmp_to_key'/__qualname__/'_functools'; partialmethod/__name__/__qualname__/__module__/__bases__[0].__name__; singledispatchmethod/__name__/__module__/__qualname__; singledispatchmethod/__mro__.__len__()==2; partial/__mro__.__len__()==2; partialmethod/__mro__.__len__()==2; cached_property/__mro__.__len__()==2; reduce/__module__.__len__()==10; cached_property/__bases__[0].__qualname__=='object'; partialmethod/__bases__[0].__qualname__=='object'; partial/__bases__[0].__qualname__=='object'; singledispatchmethod/__bases__[0].__qualname__=='object'."
    - "This spec covers: functools.reduce.__class__.__name__ == 'builtin_function_or_method'; functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'; functools.wraps.__class__.__name__ == 'function'; functools.lru_cache.__class__.__name__ == 'function'; functools.update_wrapper.__class__.__name__ == 'function'; functools.singledispatch.__class__.__name__ == 'function'; functools.total_ordering.__class__.__name__ == 'function'; functools.cache.__class__.__name__ == 'function'; functools.partial.__class__.__name__ == 'type'; functools.cached_property.__class__.__name__ == 'type'; functools.partialmethod.__class__.__name__ == 'type'; functools.singledispatchmethod.__class__.__name__ == 'type'."
    - "Key findings: functools objects fall into three runtime categories by __class__.__name__. C-extension functions (reduce, cmp_to_key) are 'builtin_function_or_method' (26 chars) — implemented in Modules/_functoolsmodule.c; __class__ is the built-in type for C-level functions. Pure-Python function objects (wraps, lru_cache, update_wrapper, singledispatch, total_ordering, cache) are 'function' (8 chars) — the standard Python function type for def-statements in Lib/functools.py. Class objects (partial, cached_property, partialmethod, singledispatchmethod) are 'type' (4 chars) — their __class__ is the built-in type metaclass regardless of whether they are C-extension types (partial) or pure-Python classes (the other three). No prior spec recorded __class__.__name__ string equality for any functools module-level object; prior specs only recorded __dict__.__class__.__name__.__len__() (for class __dict__) and the top-level class names (__name__). All twelve invariants are new to extra51."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools C-extension functions __class__.__name__ — extra51 namespace
#
# functools.reduce and functools.cmp_to_key are C-extension functions defined
# in Modules/_functoolsmodule.c. Their __class__.__name__ is
# 'builtin_function_or_method' (26 chars) — the type of all C-level built-in
# functions and methods. This is the same type as e.g. len, print, and other
# C-implemented callables. Prior specs recorded reduce.__module__=='_functools',
# reduce.__qualname__=='reduce', cmp_to_key.__name__=='cmp_to_key', and
# cmp_to_key.__module__=='_functools', but no prior spec recorded
# __class__.__name__ string equality for either. Both are new to extra51.
# ---------------------------------------------------------------------------

table functools_extra51.c_extension_class_names:
  description: "functools.reduce and cmp_to_key __class__.__name__ == 'builtin_function_or_method' — C-extension functions; __class__ is the built-in type for C-level callables; 26-char type name"
  kind: python_call_eq
  category: identity
  id_prefix: cext51

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_name,
       reduce.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — C-extension function in Modules/_functoolsmodule.c; __class__ is the built-in type for C-level functions; same type as len, print, and other C built-ins"]
    - [cmp_to_key_class_name,
       cmp_to_key.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — C-extension function in Modules/_functoolsmodule.c; wraps an old-style comparison function as a key function; same C-level type as reduce"]

# ---------------------------------------------------------------------------
# functools pure-Python function objects __class__.__name__ — extra51 namespace
#
# functools.wraps, lru_cache, update_wrapper, singledispatch, total_ordering,
# and cache are all pure-Python functions (def-statements) defined in
# Lib/functools.py. Their __class__.__name__ is 'function' (8 chars) — the
# standard CPython type for Python-level function objects created by def
# statements. No prior spec recorded __class__.__name__ string equality for
# any of these objects. All six are new to extra51.
# ---------------------------------------------------------------------------

table functools_extra51.pure_python_function_class_names:
  description: "functools pure-Python function objects __class__.__name__ == 'function' — wraps/lru_cache/update_wrapper/singledispatch/total_ordering/cache are all def-statement functions in Lib/functools.py; 8-char type name"
  kind: python_call_eq
  category: identity
  id_prefix: ppfn51

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_class_name,
       wraps.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.wraps.__class__.__name__ == 'function' — pure-Python decorator function in Lib/functools.py; def-statement creates a Python function object; __class__.__name__ is 'function' (8 chars)"]
    - [lru_cache_class_name,
       lru_cache.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__ == 'function' — pure-Python decorator function in Lib/functools.py; memoizes calls using a bounded LRU cache; __class__.__name__ is 'function'"]
    - [update_wrapper_class_name,
       update_wrapper.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.update_wrapper.__class__.__name__ == 'function' — pure-Python function in Lib/functools.py; updates a wrapper function to look like the wrapped function; __class__.__name__ is 'function'"]
    - [singledispatch_class_name,
       singledispatch.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.singledispatch.__class__.__name__ == 'function' — pure-Python decorator function in Lib/functools.py; enables single-dispatch generic functions; __class__.__name__ is 'function'"]
    - [total_ordering_class_name,
       total_ordering.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.total_ordering.__class__.__name__ == 'function' — pure-Python decorator function in Lib/functools.py; fills in missing comparison methods given __eq__ and one ordering method; __class__.__name__ is 'function'"]
    - [cache_class_name,
       cache.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.cache.__class__.__name__ == 'function' — pure-Python decorator function in Lib/functools.py added in Python 3.9; equivalent to lru_cache(maxsize=None); unbounded memoization; __class__.__name__ is 'function'"]

# ---------------------------------------------------------------------------
# functools class objects __class__.__name__ — extra51 namespace
#
# functools.partial, cached_property, partialmethod, and singledispatchmethod
# are all class objects — their __class__ is the metaclass 'type'. Whether they
# are C-extension types (partial, defined in Modules/_functoolsmodule.c) or
# pure-Python classes (the other three, defined in Lib/functools.py), their
# __class__.__name__ is 'type' (4 chars). The 'type' metaclass is the class of
# all classes in Python. Prior specs recorded __dict__.__class__.__name__.__len__()
# for these four (the __dict__ is a mappingproxy whose __class__.__name__ is
# 'mappingproxy'), but no prior spec recorded the outer __class__.__name__
# (the metaclass name 'type') as a string equality invariant. All four are new.
# ---------------------------------------------------------------------------

table functools_extra51.class_objects_metaclass_names:
  description: "functools class objects __class__.__name__ == 'type' — partial/cached_property/partialmethod/singledispatchmethod are all class objects; __class__ is the built-in 'type' metaclass; 4-char type name"
  kind: python_call_eq
  category: identity
  id_prefix: cls51

  columns: [id, function, args, expected, description]
  rows:
    - [partial_class_name,
       partial.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partial.__class__.__name__ == 'type' — C-extension type in Modules/_functoolsmodule.c; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
    - [cached_property_class_name,
       cached_property.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.cached_property.__class__.__name__ == 'type' — pure-Python class in Lib/functools.py; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
    - [partialmethod_class_name,
       partialmethod.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partialmethod.__class__.__name__ == 'type' — pure-Python class in Lib/functools.py; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
    - [singledispatchmethod_class_name,
       singledispatchmethod.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.singledispatchmethod.__class__.__name__ == 'type' — pure-Python class in Lib/functools.py; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
