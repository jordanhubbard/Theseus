table asyncio_extra139.timeout_identity:
  description: "asyncio.timeout qualname, module, and code attribute checks — timeout.__qualname__.__eq__('timeout')==True (len=7: 'timeout' is 7 chars); timeout.__module__.__eq__('asyncio.timeouts')==True (len=16: 'asyncio'=7+'.'=1+'timeouts'=8=16); timeout.__code__.co_argcount==1 ('delay' is the only positional param); timeout.__code__.co_varnames.__len__()==2 ('delay','loop'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotimeout139

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,        asyncio.timeout.__qualname__.__eq__,              ["timeout"],          true, "asyncio.timeout.__qualname__ == 'timeout' (len=7); verified with Python 3.14.3"]
    - [qn_len,       asyncio.timeout.__qualname__.__len__,              [],                  7,    "asyncio.timeout.__qualname__.__len__() == 7; verified with Python 3.14.3"]
    - [mod_eq,       asyncio.timeout.__module__.__eq__,                ["asyncio.timeouts"], true, "asyncio.timeout.__module__ == 'asyncio.timeouts' (len=16); verified with Python 3.14.3"]
    - [mod_len,      asyncio.timeout.__module__.__len__,                [],                  16,   "asyncio.timeout.__module__.__len__() == 16; verified with Python 3.14.3"]
    - [argc,         asyncio.timeout.__code__.co_argcount.__eq__,      [1],                  true, "asyncio.timeout.__code__.co_argcount == 1 ('delay' is the only positional param); verified with Python 3.14.3"]
    - [varnames_len, asyncio.timeout.__code__.co_varnames.__len__,      [],                  2,    "asyncio.timeout.__code__.co_varnames.__len__() == 2 ('delay','loop'); verified with Python 3.14.3"]
    - [delay_in,     asyncio.timeout.__code__.co_varnames.__contains__, ["delay"],            true, "asyncio.timeout.__code__.co_varnames contains 'delay'; verified with Python 3.14.3"]

