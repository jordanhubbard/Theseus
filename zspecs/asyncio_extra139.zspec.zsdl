spec: asyncio_extra139
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio task functions documentation"
    - "https://docs.python.org/3/library/asyncio-timeouts.html — Python asyncio timeouts documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/timeouts.py"
  notes:
    - "This spec covers: asyncio.timeout and asyncio.timeout_at — module-level functions defined in asyncio.timeouts. asyncio.timeout.__qualname__=='timeout' (len=7); asyncio.timeout.__module__=='asyncio.timeouts' (len=16); asyncio.timeout.__code__.co_argcount==1 ('delay'); asyncio.timeout.__code__.co_varnames.__len__()==2 ('delay','loop'). asyncio.timeout_at.__qualname__=='timeout_at' (len=10); asyncio.timeout_at.__module__=='asyncio.timeouts' (len=16); asyncio.timeout_at.__code__.co_argcount==1 ('when'); asyncio.timeout_at.__code__.co_varnames.__len__()==1 ('when'). asyncio.Timeout class: __name__=='Timeout' (len=7); __module__=='asyncio.timeouts' (len=16); __bases__[0].__name__=='object'. Timeout.__init__.__qualname__=='Timeout.__init__' (len=16); Timeout.reschedule.__qualname__=='Timeout.reschedule' (len=18). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.timeout and asyncio.timeout_at are regular Python functions (not coroutine functions in Python 3.14.3). Both return asyncio.Timeout context manager instances. Both live in asyncio.timeouts (len=16). asyncio.timeout.__code__.co_argcount==1 ('delay' is positional; no keyword-only args, co_kwonlyargcount==0); asyncio.timeout_at.__code__.co_argcount==1 ('when' is positional). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

