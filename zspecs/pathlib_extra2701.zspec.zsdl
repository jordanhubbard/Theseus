spec: pathlib_extra2701
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers existing pathlib invariants"
    - "pathlib_extra2686.zspec.zsdl — covers __and__/__or__/__xor__ dict-presence"
  notes:
    - "Wave 627 (pathlib_extra2701) theme: __lshift__, __rshift__, and __invert__ dict-presence checks."
    - "None of the pathlib classes define __lshift__, __rshift__, or __invert__ in their own __dict__."
    - "__lshift__ is the left-shift operator (<<); pathlib path objects are filesystem path types, not integers."
    - "__rshift__ is the right-shift operator (>>); pathlib path objects do not implement bit-shift semantics."
    - "__invert__ is the bitwise NOT operator (~); pathlib path objects do not implement bitwise inversion."
    - "pathlib uses __truediv__ (the / operator) for path joining — none of __lshift__, __rshift__, or __invert__ are used."
    - "Covers pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, and pathlib.Path."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __lshift__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2701.no_lshift_in_pathlib_classes:
  description: "__lshift__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the left-shift protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2701

  columns: [id, function, args, expected]
  rows:
    - ["pp2701001", "pathlib.PurePath.__dict__.__contains__",        ["__lshift__"], false]
    - ["pp2701002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__lshift__"], false]
    - ["pp2701003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__lshift__"], false]
    - ["pp2701004", "pathlib.Path.__dict__.__contains__",            ["__lshift__"], false]

# ---------------------------------------------------------------------------
# __rshift__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2701.no_rshift_in_pathlib_classes:
  description: "__rshift__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the right-shift protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2701

  columns: [id, function, args, expected]
  rows:
    - ["pp2701005", "pathlib.PurePath.__dict__.__contains__",        ["__rshift__"], false]
    - ["pp2701006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__rshift__"], false]
    - ["pp2701007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__rshift__"], false]
    - ["pp2701008", "pathlib.Path.__dict__.__contains__",            ["__rshift__"], false]

# ---------------------------------------------------------------------------
# __invert__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2701.no_invert_in_pathlib_classes:
  description: "__invert__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the bitwise NOT protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2701

  columns: [id, function, args, expected]
  rows:
    - ["pp2701009", "pathlib.PurePath.__dict__.__contains__",        ["__invert__"], false]
    - ["pp2701010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__invert__"], false]
    - ["pp2701011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__invert__"], false]
    - ["pp2701012", "pathlib.Path.__dict__.__contains__",            ["__invert__"], false]

# ---------------------------------------------------------------------------
# Complementary: pathlib classes have path-manipulation methods but not bit-shift or bitwise-NOT hooks
# Confirms that path objects use __truediv__ for joining and have no __lshift__/__rshift__/__invert__ semantics
# ---------------------------------------------------------------------------

table pathlib_extra2701.pathlib_has_path_methods_not_shift_hooks:
  description: "pathlib.PurePath defines __str__/__truediv__/__fspath__ but NOT __lshift__/__rshift__/__invert__; pathlib.Path defines stat/exists/open but NOT __lshift__/__rshift__/__invert__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2701

  columns: [id, function, args, expected]
  rows:
    - ["pp2701013", "pathlib.PurePath.__dict__.__contains__", ["__str__"],     true]
    - ["pp2701014", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"], true]
    - ["pp2701015", "pathlib.PurePath.__dict__.__contains__", ["__fspath__"],  true]
    - ["pp2701016", "pathlib.PurePath.__dict__.__contains__", ["__lshift__"],  false]
    - ["pp2701017", "pathlib.PurePath.__dict__.__contains__", ["__rshift__"],  false]
    - ["pp2701018", "pathlib.PurePath.__dict__.__contains__", ["__invert__"],  false]
    - ["pp2701019", "pathlib.Path.__dict__.__contains__",     ["stat"],        true]
    - ["pp2701020", "pathlib.Path.__dict__.__contains__",     ["exists"],      true]
    - ["pp2701021", "pathlib.Path.__dict__.__contains__",     ["open"],        true]
    - ["pp2701022", "pathlib.Path.__dict__.__contains__",     ["__lshift__"],  false]
    - ["pp2701023", "pathlib.Path.__dict__.__contains__",     ["__rshift__"],  false]
    - ["pp2701024", "pathlib.Path.__dict__.__contains__",     ["__invert__"],  false]
