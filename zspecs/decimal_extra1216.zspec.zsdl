spec: decimal_extra1216
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal.Decimal.__dict__.__contains__ checks for arithmetic dunder methods: __add__, __sub__, __mul__, __truediv__, __mod__, __pow__, __neg__, __abs__; decimal.Context.__dict__.__contains__ checks for context methods: add, subtract, multiply, divide, power, abs"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks decimal.Decimal.__dict__.__contains__ for arithmetic dunder method names; checks decimal.Context.__dict__.__contains__ for context arithmetic method names; checks decimal.Decimal.__dict__.__contains__ for comparison dunder names; none of these __dict__.__contains__ membership checks were covered in _extra1186, _extra1201, decimal_extra118, or any prior decimal_extra spec"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1216.decimal_dict_contains_arithmetic:
  description: "decimal.Decimal.__dict__.__contains__ checks for arithmetic dunder methods — __add__, __sub__, __mul__, __truediv__, __mod__, __pow__, __neg__, __abs__ all present in Decimal.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1216da
  columns: [id, function, args, expected]
  rows:
    - [dc1216da001, decimal.Decimal.__dict__.__contains__, ["__add__"],      true]
    - [dc1216da002, decimal.Decimal.__dict__.__contains__, ["__sub__"],      true]
    - [dc1216da003, decimal.Decimal.__dict__.__contains__, ["__mul__"],      true]
    - [dc1216da004, decimal.Decimal.__dict__.__contains__, ["__truediv__"],  true]
    - [dc1216da005, decimal.Decimal.__dict__.__contains__, ["__mod__"],      true]
    - [dc1216da006, decimal.Decimal.__dict__.__contains__, ["__pow__"],      true]
    - [dc1216da007, decimal.Decimal.__dict__.__contains__, ["__neg__"],      true]
    - [dc1216da008, decimal.Decimal.__dict__.__contains__, ["__abs__"],      true]
    - [dc1216da009, decimal.Decimal.__dict__.__contains__, ["__radd__"],     true]
    - [dc1216da010, decimal.Decimal.__dict__.__contains__, ["__floordiv__"], true]

table decimal_extra1216.decimal_dict_contains_comparison:
  description: "decimal.Decimal.__dict__.__contains__ checks for comparison and conversion dunder methods — __eq__, __lt__, __le__, __gt__, __ge__ and conversion methods __int__, __float__, __str__ present; absent names like __len__ not present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1216dc
  columns: [id, function, args, expected]
  rows:
    - [dc1216dc001, decimal.Decimal.__dict__.__contains__, ["__eq__"],    true]
    - [dc1216dc002, decimal.Decimal.__dict__.__contains__, ["__lt__"],    true]
    - [dc1216dc003, decimal.Decimal.__dict__.__contains__, ["__le__"],    true]
    - [dc1216dc004, decimal.Decimal.__dict__.__contains__, ["__gt__"],    true]
    - [dc1216dc005, decimal.Decimal.__dict__.__contains__, ["__ge__"],    true]
    - [dc1216dc006, decimal.Decimal.__dict__.__contains__, ["__int__"],   true]
    - [dc1216dc007, decimal.Decimal.__dict__.__contains__, ["__float__"], true]
    - [dc1216dc008, decimal.Decimal.__dict__.__contains__, ["__str__"],   true]
    - [dc1216dc009, decimal.Decimal.__dict__.__contains__, ["__len__"],   false]
    - [dc1216dc010, decimal.Decimal.__dict__.__contains__, ["__iter__"],  false]

table decimal_extra1216.context_dict_contains:
  description: "decimal.Context.__dict__.__contains__ checks for context arithmetic methods — add, subtract, multiply, divide, power, abs present; Decimal-only dunders absent from Context"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1216cc
  columns: [id, function, args, expected]
  rows:
    - [dc1216cc001, decimal.Context.__dict__.__contains__, ["add"],      true]
    - [dc1216cc002, decimal.Context.__dict__.__contains__, ["subtract"], true]
    - [dc1216cc003, decimal.Context.__dict__.__contains__, ["multiply"], true]
    - [dc1216cc004, decimal.Context.__dict__.__contains__, ["divide"],   true]
    - [dc1216cc005, decimal.Context.__dict__.__contains__, ["power"],    true]
    - [dc1216cc006, decimal.Context.__dict__.__contains__, ["abs"],      true]
    - [dc1216cc007, decimal.Context.__dict__.__contains__, ["__add__"],  false]
    - [dc1216cc008, decimal.Context.__dict__.__contains__, ["__sub__"],  false]
    - [dc1216cc009, decimal.Context.__dict__.__contains__, ["sqrt"],     true]
    - [dc1216cc010, decimal.Context.__dict__.__contains__, ["__neg__"],  false]
