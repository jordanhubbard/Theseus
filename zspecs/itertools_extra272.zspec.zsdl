spec: itertools_extra272
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "itertools.chain.from_iterable is a builtin_function_or_method (not classmethod_descriptor)."
    - "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'."
    - "itertools.chain.__new__, cycle.__new__, and product.__new__ are all builtin_function_or_method."
    - "itertools.chain, count, and repeat are all of type 'type' (they are C-level types)."
    - "itertools.chain.from_iterable.__doc__ is a str."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.chain class-level method identity — from_iterable and __new__
#
# chain.from_iterable.__name__ == 'from_iterable'; __qualname__ == 'chain.from_iterable'.
# chain.from_iterable.__class__.__name__ == 'builtin_function_or_method'.
# chain.__new__.__name__ == '__new__'; chain.__new__.__class__.__name__ == 'builtin_function_or_method'.
# ---------------------------------------------------------------------------

table itertools_extra272.chain_classmethods_identity:
  description: "itertools.chain class-level methods — from_iterable.__name__=='from_iterable', __qualname__=='chain.from_iterable', __class__=='builtin_function_or_method'; __new__.__name__=='__new__'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex272ch

  columns: [id, function, args, expected, description]
  rows:
    - [fi_name_eq,               chain.from_iterable.__name__.__eq__,         ["from_iterable"],              true, "itertools.chain.from_iterable.__name__ == 'from_iterable'; verified with Python 3.14.3"]
    - [fi_name_len,              chain.from_iterable.__name__.__len__,        [],                             13,   "itertools.chain.from_iterable.__name__.__len__() == 13; verified with Python 3.14.3"]
    - [fi_qn_eq,                 chain.from_iterable.__qualname__.__eq__,     ["chain.from_iterable"],        true, "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'; verified with Python 3.14.3"]
    - [fi_cls_eq,                chain.from_iterable.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3"]
    - [fi_doc_cls_eq,            chain.from_iterable.__doc__.__class__.__name__.__eq__, ["str"],              true, "itertools.chain.from_iterable.__doc__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [cn_name_eq,               chain.__new__.__name__.__eq__,               ["__new__"],                    true, "itertools.chain.__new__.__name__ == '__new__'; verified with Python 3.14.3"]
    - [cn_cls_eq,                chain.__new__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true, "itertools.chain.__new__.__class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3"]
    - [yn_cls_eq,                cycle.__new__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true, "itertools.cycle.__new__.__class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3"]
    - [pn_cls_eq,                product.__new__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true, "itertools.product.__new__.__class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# itertools type class identity — chain, count, repeat are type instances
#
# All three are C-level types; their __class__.__name__ == 'type'.
# chain.from_iterable is accessible and has a string doc.
# ---------------------------------------------------------------------------

table itertools_extra272.itertools_type_class_identity:
  description: "itertools C types are instances of 'type': chain.__class__.__name__=='type', count.__class__.__name__=='type', repeat.__class__.__name__=='type'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex272ty

  columns: [id, function, args, expected, description]
  rows:
    - [ch_cls_eq,                chain.__class__.__name__.__eq__,             ["type"],                       true, "itertools.chain.__class__.__name__ == 'type' — chain is a C-level type; verified with Python 3.14.3"]
    - [co_cls_eq,                count.__class__.__name__.__eq__,             ["type"],                       true, "itertools.count.__class__.__name__ == 'type' — count is a C-level type; verified with Python 3.14.3"]
    - [re_cls_eq,                repeat.__class__.__name__.__eq__,            ["type"],                       true, "itertools.repeat.__class__.__name__ == 'type' — repeat is a C-level type; verified with Python 3.14.3"]
    - [ch_name_eq,               chain.__name__.__eq__,                       ["chain"],                      true, "itertools.chain.__name__ == 'chain'; verified with Python 3.14.3"]
    - [co_name_eq,               count.__name__.__eq__,                       ["count"],                      true, "itertools.count.__name__ == 'count'; verified with Python 3.14.3"]
    - [re_name_eq,               repeat.__name__.__eq__,                      ["repeat"],                     true, "itertools.repeat.__name__ == 'repeat'; verified with Python 3.14.3"]
    - [yn_name_eq,               cycle.__new__.__name__.__eq__,               ["__new__"],                    true, "itertools.cycle.__new__.__name__ == '__new__'; verified with Python 3.14.3"]
    - [pn_name_eq,               product.__new__.__name__.__eq__,             ["__new__"],                    true, "itertools.product.__new__.__name__ == '__new__'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra272
# ---------------------------------------------------------------------------

invariant itertools_extra272.chain_from_iterable_name:
  description: "itertools.chain.from_iterable.__name__ == 'from_iterable' (len=13)"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__name__.__eq__
  args: ["from_iterable"]
  expected: true

invariant itertools_extra272.chain_from_iterable_qualname:
  description: "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — qualname includes enclosing class"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__eq__
  args: ["chain.from_iterable"]
  expected: true

invariant itertools_extra272.chain_from_iterable_class:
  description: "itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra272.chain_new_class:
  description: "itertools.chain.__new__.__class__.__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: chain.__new__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra272.chain_class_is_type:
  description: "itertools.chain.__class__.__name__ == 'type' — chain is a C-level type object"
  category: identity
  kind: python_call_eq
  function: chain.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra272.count_class_is_type:
  description: "itertools.count.__class__.__name__ == 'type' — count is a C-level type object"
  category: identity
  kind: python_call_eq
  function: count.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra272.repeat_class_is_type:
  description: "itertools.repeat.__class__.__name__ == 'type' — repeat is a C-level type object"
  category: identity
  kind: python_call_eq
  function: repeat.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra272.chain_from_iterable_doc_is_str:
  description: "itertools.chain.from_iterable.__doc__.__class__.__name__ == 'str' — from_iterable has a string docstring"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
