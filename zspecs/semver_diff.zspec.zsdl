spec: semver_diff
version: ">=4.0.0"
backend: node(semver-diff)

docs: https://github.com/sindresorhus/semver-diff#readme

provenance:
  derived_from:
    - "semver-diff README — https://github.com/sindresorhus/semver-diff#readme"
    - "Semantic Versioning 2.0.0 — https://semver.org/"
    - "Test vectors verified with semver-diff via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "semver-diff source"
  notes:
    - "semver-diff classifies the change between two semver strings."
    - "Install: npm install semver-diff"
    - "v4 is ESM with a CJS shim; default export is the function."
    - "Returns: 'major' | 'minor' | 'patch' | 'premajor' | 'preminor' | 'prepatch' | 'prerelease' | 'build' | undefined."
    - "Returns undefined when versions are equal or when the second arg is older."
  rfcs:
    - "Semantic Versioning 2.0.0 — https://semver.org/"
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on valid semver strings."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table semver_diff.classify:
  kind: node_chain_eq
  category: classify
  entry: named
  function: default
  chain: []
  id_prefix: diff

  columns: [id, entry_args, expected]
  rows:
    - [major,         ["1.0.0", "2.0.0"],            "major"]
    - [minor,         ["1.0.0", "1.1.0"],            "minor"]
    - [patch,         ["1.0.0", "1.0.1"],            "patch"]
    - [equal,         ["1.0.0", "1.0.0"],            ~]
    - [older_returns_undefined, ["2.0.0", "1.0.0"],  ~]
    - [premajor,      ["1.0.0", "2.0.0-rc"],         "premajor"]
    - [preminor,      ["1.0.0", "1.1.0-beta"],       "preminor"]
    - [prepatch,      ["1.0.0", "1.0.1-beta"],       "prepatch"]
    - [prerelease,    ["1.0.0-alpha", "1.0.0-beta"], "prerelease"]
