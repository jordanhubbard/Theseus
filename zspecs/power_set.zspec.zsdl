spec: power_set
version: ">=1.1.8"
backend: node(power-set)

docs: https://www.npmjs.com/package/power-set

provenance:
  derived_from:
    - "power-set README — https://www.npmjs.com/package/power-set"
    - "Test vectors verified with power-set via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "power-set source"
  notes:
    - "power-set is an npm package. Install: npm install power-set"
    - "Returns all subsets of an array (the power set)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of arrays."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table power_set.powerSet:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: powset

  columns: [id, args, expected]
  rows:
    - [two,   [[1, 2]],      [[1, 2], [1], [2]]]
    - [one,   [[5]],         [[5]]]
    - [empty, [[]],          []]
