spec: decimal_extra486
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal.Decimal method identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Checks class-level method __name__ attributes on decimal.Decimal"
    - "as_integer_ratio was added in Python 3.9"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra486.decimal_method_names:
  description: "decimal.Decimal class-level method __name__ identity"
  kind: python_call_eq
  category: method_identity
  id_prefix: dec

  columns: [id, function, args, expected]
  rows:
    - [dec001, decimal.Decimal.sqrt.__name__.__eq__,             ["sqrt"],             true]
    - [dec002, decimal.Decimal.exp.__name__.__eq__,              ["exp"],              true]
    - [dec003, decimal.Decimal.ln.__name__.__eq__,               ["ln"],               true]
    - [dec004, decimal.Decimal.log10.__name__.__eq__,            ["log10"],            true]
    - [dec005, decimal.Decimal.quantize.__name__.__eq__,         ["quantize"],         true]
    - [dec006, decimal.Decimal.normalize.__name__.__eq__,        ["normalize"],        true]
    - [dec007, decimal.Decimal.to_eng_string.__name__.__eq__,    ["to_eng_string"],    true]
    - [dec008, decimal.Decimal.as_tuple.__name__.__eq__,         ["as_tuple"],         true]
    - [dec009, decimal.Decimal.as_integer_ratio.__name__.__eq__, ["as_integer_ratio"], true]
    - [dec010, decimal.Decimal.is_finite.__name__.__eq__,        ["is_finite"],        true]
    - [dec011, decimal.Decimal.is_infinite.__name__.__eq__,      ["is_infinite"],      true]
    - [dec012, decimal.Decimal.is_nan.__name__.__eq__,           ["is_nan"],           true]
    - [dec013, decimal.Decimal.is_signed.__name__.__eq__,        ["is_signed"],        true]
    - [dec014, decimal.Decimal.is_zero.__name__.__eq__,          ["is_zero"],          true]
