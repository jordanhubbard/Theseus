spec: re_extra207
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra206.zspec.zsdl — covers previous re module invariants"
    - "re_extra.zspec.zsdl — covers re module constants and function metadata"
  notes:
    - "re.Pattern.__mro__ is a tuple; len == 2; MRO is [Pattern, object]; confirmed Python 3.14.3 macOS."
    - "re.Match.__mro__ is a tuple; len == 2; MRO is [Match, object]; confirmed Python 3.14.3 macOS."
    - "re.error.__mro__ is a tuple; len == 4; MRO is [PatternError, Exception, BaseException, object]; confirmed Python 3.14.3 macOS."
    - "re.error.__mro__[0].__name__ == 'PatternError'; re.error was renamed to PatternError in Python 3.13+; confirmed Python 3.14.3 macOS."
    - "Index access on __mro__ uses bracket notation — function paths containing '[' must be double-quoted."
    - "re.Pattern and re.Match are both direct subclasses of object with no intermediate abstract base classes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.Pattern.__mro__ type identity and length
# __class__.__name__ == 'tuple', __len__() == 2
# ---------------------------------------------------------------------------

table re_extra207.pattern_mro_type_and_len:
  description: "re.Pattern.__mro__ type identity and length"
  kind: python_call_eq
  category: mro_identity
  id_prefix: remro207

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_mro_class_name_eq,  Pattern.__mro__.__class__.__name__.__eq__,  ["tuple"], true,  "re.Pattern.__mro__.__class__.__name__ == 'tuple'; MRO is always a tuple; confirmed Python 3.14.3 macOS"]
    - [pattern_mro_class_name_len, Pattern.__mro__.__class__.__name__.__len__,  [],        5,     "re.Pattern.__mro__.__class__.__name__.__len__() == 5; 'tuple' has 5 characters; confirmed Python 3.14.3 macOS"]
    - [pattern_mro_len_eq,         Pattern.__mro__.__len__,                    [],        2,     "re.Pattern.__mro__.__len__() == 2; MRO is [Pattern, object]; confirmed Python 3.14.3 macOS"]
    - [pattern_mro0_name_eq,       "Pattern.__mro__[0].__name__.__eq__",       ["Pattern"], true, "re.Pattern.__mro__[0].__name__ == 'Pattern'; the class itself is first in its own MRO; confirmed Python 3.14.3 macOS"]
    - [pattern_mro1_name_eq,       "Pattern.__mro__[1].__name__.__eq__",       ["object"],  true, "re.Pattern.__mro__[1].__name__ == 'object'; Pattern directly inherits from object; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.Match.__mro__ type identity and length
# __class__.__name__ == 'tuple', __len__() == 2
# ---------------------------------------------------------------------------

table re_extra207.match_mro_type_and_len:
  description: "re.Match.__mro__ type identity and length"
  kind: python_call_eq
  category: mro_identity
  id_prefix: remro207

  columns: [id, function, args, expected, description]
  rows:
    - [match_mro_class_name_eq,  Match.__mro__.__class__.__name__.__eq__,  ["tuple"], true,  "re.Match.__mro__.__class__.__name__ == 'tuple'; MRO is always a tuple; confirmed Python 3.14.3 macOS"]
    - [match_mro_class_name_len, Match.__mro__.__class__.__name__.__len__,  [],        5,     "re.Match.__mro__.__class__.__name__.__len__() == 5; 'tuple' has 5 characters; confirmed Python 3.14.3 macOS"]
    - [match_mro_len_eq,         Match.__mro__.__len__,                    [],        2,     "re.Match.__mro__.__len__() == 2; MRO is [Match, object]; confirmed Python 3.14.3 macOS"]
    - [match_mro0_name_eq,       "Match.__mro__[0].__name__.__eq__",       ["Match"],  true, "re.Match.__mro__[0].__name__ == 'Match'; the class itself is first in its own MRO; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.error.__mro__ length and element names
# len == 4; [0] == 'PatternError', [1] == 'Exception', [2] == 'BaseException'
# ---------------------------------------------------------------------------

table re_extra207.error_mro:
  description: "re.error.__mro__ length and element names"
  kind: python_call_eq
  category: mro_members
  id_prefix: remro207

  columns: [id, function, args, expected, description]
  rows:
    - [error_mro_len_eq,    error.__mro__.__len__,                        [],                  4,     "re.error.__mro__.__len__() == 4; MRO is [PatternError, Exception, BaseException, object]; confirmed Python 3.14.3 macOS"]
    - [error_mro0_name_eq,  "error.__mro__[0].__name__.__eq__",            ["PatternError"],    true,  "re.error.__mro__[0].__name__ == 'PatternError'; re.error was renamed to PatternError in Python 3.13+; confirmed Python 3.14.3 macOS"]
    - [error_mro1_name_eq,  "error.__mro__[1].__name__.__eq__",            ["Exception"],       true,  "re.error.__mro__[1].__name__ == 'Exception'; PatternError inherits from Exception; confirmed Python 3.14.3 macOS"]
    - [error_mro2_name_eq,  "error.__mro__[2].__name__.__eq__",            ["BaseException"],   true,  "re.error.__mro__[2].__name__ == 'BaseException'; BaseException is the root exception class; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra207.pattern_mro_class_name_eq:
  description: "re.Pattern.__mro__.__class__.__name__ == 'tuple' — MRO is always a tuple; confirmed Python 3.14.3 macOS"
  category: mro_identity
  kind: python_call_eq
  function: Pattern.__mro__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant re_extra207.pattern_mro_len_eq:
  description: "re.Pattern.__mro__.__len__() == 2 — MRO is [Pattern, object]; confirmed Python 3.14.3 macOS"
  category: mro_identity
  kind: python_call_eq
  function: Pattern.__mro__.__len__
  args: []
  expected: 2

invariant re_extra207.pattern_mro0_name_eq:
  description: "re.Pattern.__mro__[0].__name__ == 'Pattern' — the class itself is first in its own MRO; confirmed Python 3.14.3 macOS"
  category: mro_members
  kind: python_call_eq
  function: "Pattern.__mro__[0].__name__.__eq__"
  args: ["Pattern"]
  expected: true

invariant re_extra207.match_mro_len_eq:
  description: "re.Match.__mro__.__len__() == 2 — MRO is [Match, object]; confirmed Python 3.14.3 macOS"
  category: mro_identity
  kind: python_call_eq
  function: Match.__mro__.__len__
  args: []
  expected: 2

invariant re_extra207.match_mro0_name_eq:
  description: "re.Match.__mro__[0].__name__ == 'Match' — the class itself is first in its own MRO; confirmed Python 3.14.3 macOS"
  category: mro_members
  kind: python_call_eq
  function: "Match.__mro__[0].__name__.__eq__"
  args: ["Match"]
  expected: true

invariant re_extra207.error_mro_len_eq:
  description: "re.error.__mro__.__len__() == 4 — MRO is [PatternError, Exception, BaseException, object]; confirmed Python 3.14.3 macOS"
  category: mro_identity
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 4

invariant re_extra207.error_mro0_name_eq:
  description: "re.error.__mro__[0].__name__ == 'PatternError' — re.error was renamed to PatternError in Python 3.13+; confirmed Python 3.14.3 macOS"
  category: mro_members
  kind: python_call_eq
  function: "error.__mro__[0].__name__.__eq__"
  args: ["PatternError"]
  expected: true

invariant re_extra207.error_mro2_name_eq:
  description: "re.error.__mro__[2].__name__ == 'BaseException' — BaseException is the root exception class; confirmed Python 3.14.3 macOS"
  category: mro_members
  kind: python_call_eq
  function: "error.__mro__[2].__name__.__eq__"
  args: ["BaseException"]
  expected: true
