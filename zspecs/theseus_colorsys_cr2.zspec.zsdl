spec: theseus_colorsys_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_colorsys_cr2)
blocks: colorsys

docs: https://docs.python.org/3/library/colorsys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/colorsys.html"
    - "https://en.wikipedia.org/wiki/HLS_color_space"
    - "https://en.wikipedia.org/wiki/YIQ"
  notes:
    - "Clean-room extended colorsys utilities. Do NOT import colorsys."
    - "hls_to_rgb(h, l, s): convert HLS to RGB; all values in [0, 1]."
    - "yiq_to_rgb(y, i, q): convert YIQ to RGB; clamp to [0, 1]."
    - "rgb_to_yiq(r, g, b): convert RGB to YIQ; return (y, i, q) tuple."
    - "colorsys2_hls_to_rgb(): hls_to_rgb(0, 0.5, 0) == (0.5, 0.5, 0.5) — achromatic."
    - "colorsys2_yiq_to_rgb(): all components of yiq_to_rgb(0.5, 0, 0) are in [0.0, 1.0]."
    - "colorsys2_rgb_to_yiq(): rgb_to_yiq(1, 1, 1)[0] is close to 1.0 — returns True."
    - "Zero-arg invariant signatures — def colorsys2_hls_to_rgb(): return hardcoded_result"
    - "Export: hls_to_rgb(h,l,s), yiq_to_rgb(y,i,q), rgb_to_yiq(r,g,b)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_colorsys_cr2.hls_to_rgb:
  description: "hls_to_rgb(0, 0.5, 0) == (0.5, 0.5, 0.5) (achromatic)"
  category: hls_to_rgb
  kind: python_call_eq
  function: colorsys2_hls_to_rgb
  args: []
  expected: [0.5, 0.5, 0.5]

invariant theseus_colorsys_cr2.yiq_to_rgb:
  description: "all components of yiq_to_rgb(0.5, 0, 0) are in [0, 1]"
  category: yiq_to_rgb
  kind: python_call_eq
  function: colorsys2_yiq_to_rgb
  args: []
  expected: true

invariant theseus_colorsys_cr2.rgb_to_yiq:
  description: "rgb_to_yiq(1, 1, 1)[0] is close to 1.0"
  category: rgb_to_yiq
  kind: python_call_eq
  function: colorsys2_rgb_to_yiq
  args: []
  expected: true
