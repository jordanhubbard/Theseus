invariant functools_extra155.reduce_module_eq__functools:
  description: "functools.reduce.__module__ == '_functools' — reduce is defined in _functoolsmodule.c; wave 279; new to extra155"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra155.cache_info_class_method_descriptor:
  description: "functools._lru_cache_wrapper.cache_info.__class__.__name__ == 'method_descriptor' — cache_info is a C method_descriptor; wave 279; new to extra155"
  kind: python_call_eq
  function: _lru_cache_wrapper.cache_info.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant functools_extra155.cache_clear_class_method_descriptor:
  description: "functools._lru_cache_wrapper.cache_clear.__class__.__name__ == 'method_descriptor' — cache_clear is a C method_descriptor; wave 279; new to extra155"
  kind: python_call_eq
  function: _lru_cache_wrapper.cache_clear.__class__.__name__.__eq__
  args: ["method_descriptor"]
