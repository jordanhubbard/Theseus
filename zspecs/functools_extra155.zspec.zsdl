spec: functools_extra155
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools._lru_cache_wrapper method qualnames — cache_info.__qualname__ '_lru_cache_wrapper.cache_info' len 29, cache_clear.__qualname__ '_lru_cache_wrapper.cache_clear' len 30; functools._lru_cache_wrapper.__dict__ contains 'cache_info' and 'cache_clear'; functools.reduce.__doc__.__len__() 389; functools.reduce.__module__.__eq__('_functools') True (Wave 279)."
    - "functools._lru_cache_wrapper.cache_info.__qualname__ == '_lru_cache_wrapper.cache_info' (len 29) — cache_info is a method_descriptor on the _lru_cache_wrapper C extension type; its __qualname__ includes the class prefix. Verified with Python 3.14.3."
    - "functools._lru_cache_wrapper.cache_clear.__qualname__ == '_lru_cache_wrapper.cache_clear' (len 30) — cache_clear is a method_descriptor on the _lru_cache_wrapper C extension type. Verified with Python 3.14.3."
    - "functools._lru_cache_wrapper.__dict__.__contains__('cache_info') == True — cache_info is stored in the class __dict__ of _lru_cache_wrapper. Verified with Python 3.14.3."
    - "functools._lru_cache_wrapper.__dict__.__contains__('cache_clear') == True — cache_clear is stored in the class __dict__ of _lru_cache_wrapper. Verified with Python 3.14.3."
    - "functools.reduce.__doc__.__len__() == 389 — the reduce C builtin docstring has 389 characters. Verified with Python 3.14.3."
    - "functools.reduce.__module__.__eq__('_functools') == True — reduce is defined in Modules/_functoolsmodule.c and its __module__ is '_functools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools._lru_cache_wrapper method qualnames
#
# Wave 279 theme: _lru_cache_wrapper method_descriptor __qualname__ attributes.
#
# _lru_cache_wrapper.cache_info.__qualname__ == '_lru_cache_wrapper.cache_info'
# len == 29
# _lru_cache_wrapper.cache_clear.__qualname__ == '_lru_cache_wrapper.cache_clear'
# len == 30
#
# Both cache_info and cache_clear are method_descriptors on the
# _lru_cache_wrapper C extension type. Their __qualname__ includes the
# class prefix '_lru_cache_wrapper.'. New to extra155.
# ---------------------------------------------------------------------------

table functools_extra155.lru_cache_wrapper_method_qualnames:
  description: "functools._lru_cache_wrapper method qualnames: cache_info '_lru_cache_wrapper.cache_info' len 29, cache_clear '_lru_cache_wrapper.cache_clear' len 30; both method_descriptors; wave 279; new to extra155"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolslcwmq155

  columns: [id, function, args, expected, description]
  rows:
    - [cache_info_qualname_eq,
       "_lru_cache_wrapper.cache_info.__qualname__.__eq__",
       ["_lru_cache_wrapper.cache_info"],
       true,
       "functools._lru_cache_wrapper.cache_info.__qualname__.__eq__('_lru_cache_wrapper.cache_info') == True — cache_info is a method_descriptor on _lru_cache_wrapper; its __qualname__ includes the class prefix '_lru_cache_wrapper.cache_info'; str.__eq__ returns True; new to extra155"]
    - [cache_info_qualname_len_eq_29,
       "_lru_cache_wrapper.cache_info.__qualname__.__len__",
       [],
       29,
       "functools._lru_cache_wrapper.cache_info.__qualname__.__len__() == 29 — '_lru_cache_wrapper.cache_info' has 29 characters; len('_lru_cache_wrapper.cache_info') == 29; new to extra155"]
    - [cache_info_class_eq_method_descriptor,
       "_lru_cache_wrapper.cache_info.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools._lru_cache_wrapper.cache_info.__class__.__name__.__eq__('method_descriptor') == True — cache_info is exposed as a method_descriptor C slot; __class__.__name__ is 'method_descriptor'; str.__eq__ returns True; new to extra155"]
    - [cache_clear_qualname_eq,
       "_lru_cache_wrapper.cache_clear.__qualname__.__eq__",
       ["_lru_cache_wrapper.cache_clear"],
       true,
       "functools._lru_cache_wrapper.cache_clear.__qualname__.__eq__('_lru_cache_wrapper.cache_clear') == True — cache_clear is a method_descriptor on _lru_cache_wrapper; its __qualname__ is '_lru_cache_wrapper.cache_clear'; str.__eq__ returns True; new to extra155"]
    - [cache_clear_qualname_len_eq_30,
       "_lru_cache_wrapper.cache_clear.__qualname__.__len__",
       [],
       30,
       "functools._lru_cache_wrapper.cache_clear.__qualname__.__len__() == 30 — '_lru_cache_wrapper.cache_clear' has 30 characters; len('_lru_cache_wrapper.cache_clear') == 30; new to extra155"]
    - [cache_clear_class_eq_method_descriptor,
       "_lru_cache_wrapper.cache_clear.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools._lru_cache_wrapper.cache_clear.__class__.__name__.__eq__('method_descriptor') == True — cache_clear is a method_descriptor; __class__.__name__ is 'method_descriptor'; str.__eq__ returns True; new to extra155"]

# ---------------------------------------------------------------------------
# Table 2: functools._lru_cache_wrapper.__dict__ contains cache_info/cache_clear
#
# Wave 279 theme: _lru_cache_wrapper class __dict__ membership checks.
#
# _lru_cache_wrapper.__dict__.__contains__('cache_info') == True
# _lru_cache_wrapper.__dict__.__contains__('cache_clear') == True
# _lru_cache_wrapper.__dict__.__contains__('__call__') == True
# _lru_cache_wrapper.__dict__.__contains__('__reduce__') == True
#
# The _lru_cache_wrapper class dict (len 11) stores these method_descriptors.
# New to extra155.
# ---------------------------------------------------------------------------

table functools_extra155.lru_cache_wrapper_dict_contains:
  description: "functools._lru_cache_wrapper.__dict__ contains cache_info, cache_clear, __call__, __reduce__; class dict membership checks; wave 279; new to extra155"
  kind: python_call_eq
  category: identity
  id_prefix: functoolslcwdc155

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_wrapper_dict_contains_cache_info,
       "_lru_cache_wrapper.__dict__.__contains__",
       ["cache_info"],
       true,
       "functools._lru_cache_wrapper.__dict__.__contains__('cache_info') == True — cache_info is a method_descriptor stored in the _lru_cache_wrapper class dict; dict.__contains__('cache_info') returns True; new to extra155"]
    - [lru_cache_wrapper_dict_contains_cache_clear,
       "_lru_cache_wrapper.__dict__.__contains__",
       ["cache_clear"],
       true,
       "functools._lru_cache_wrapper.__dict__.__contains__('cache_clear') == True — cache_clear is a method_descriptor stored in the _lru_cache_wrapper class dict; dict.__contains__('cache_clear') returns True; new to extra155"]
    - [lru_cache_wrapper_dict_contains_call,
       "_lru_cache_wrapper.__dict__.__contains__",
       ["__call__"],
       true,
       "functools._lru_cache_wrapper.__dict__.__contains__('__call__') == True — __call__ is stored as a wrapper_descriptor in the _lru_cache_wrapper class dict; dict.__contains__('__call__') returns True; new to extra155"]
    - [lru_cache_wrapper_dict_contains_reduce,
       "_lru_cache_wrapper.__dict__.__contains__",
       ["__reduce__"],
       true,
       "functools._lru_cache_wrapper.__dict__.__contains__('__reduce__') == True — __reduce__ is stored in the _lru_cache_wrapper class dict; dict.__contains__('__reduce__') returns True; new to extra155"]
    - [lru_cache_wrapper_dict_len_eq_11,
       "_lru_cache_wrapper.__dict__.__len__",
       [],
       11,
       "functools._lru_cache_wrapper.__dict__.__len__() == 11 — the _lru_cache_wrapper class dict has 11 entries: __new__, __call__, __get__, cache_info, cache_clear, __reduce__, __copy__, __deepcopy__, __dict__, __doc__, __module__; len == 11; new to extra155"]

# ---------------------------------------------------------------------------
# Table 3: functools.reduce — doc length and module
#
# Wave 279 theme: functools.reduce C builtin attributes.
#
# functools.reduce.__doc__.__len__() == 389
# functools.reduce.__module__.__eq__('_functools') == True
# functools.reduce.__qualname__ == 'reduce' (len 6)
#
# reduce is a C builtin defined in Modules/_functoolsmodule.c and exposed
# in both functools and _functools. Its __module__ is '_functools'.
# New to extra155.
# ---------------------------------------------------------------------------

table functools_extra155.reduce_builtin_identity:
  description: "functools.reduce: C builtin, __doc__ len 389, __module__ '_functools', __qualname__ 'reduce' len 6; wave 279; new to extra155"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsreduce155

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_doc_len_eq_389,
       "reduce.__doc__.__len__",
       [],
       389,
       "functools.reduce.__doc__.__len__() == 389 — the reduce C builtin docstring has 389 characters in Python 3.14.3; len(__doc__) == 389; verified with Python 3.14.3; new to extra155"]
    - [reduce_module_eq__functools,
       "reduce.__module__.__eq__",
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is defined in Modules/_functoolsmodule.c; its __module__ is '_functools' (the C extension module), not 'functools'; str.__eq__('_functools') returns True; new to extra155"]
    - [reduce_module_len_eq_10,
       "reduce.__module__.__len__",
       [],
       10,
       "functools.reduce.__module__.__len__() == 10 — __module__ is '_functools' which has 10 characters; len('_functools') == 10; new to extra155"]
    - [reduce_qualname_eq,
       "reduce.__qualname__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — the C builtin's __qualname__ is 'reduce' (no class prefix since it is a top-level function); str.__eq__('reduce') returns True; new to extra155"]
    - [reduce_qualname_len_eq_6,
       "reduce.__qualname__.__len__",
       [],
       6,
       "functools.reduce.__qualname__.__len__() == 6 — __qualname__ is 'reduce' which has 6 characters; len('reduce') == 6; new to extra155"]
    - [reduce_class_eq_builtin_function_or_method,
       "reduce.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C builtin function from _functoolsmodule.c; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__ returns True; new to extra155"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra155
# ---------------------------------------------------------------------------

invariant functools_extra155.cache_info_qualname_eq:
  description: "functools._lru_cache_wrapper.cache_info.__qualname__ == '_lru_cache_wrapper.cache_info' — method_descriptor qualname includes class prefix; wave 279; new to extra155"
  kind: python_call_eq
  function: _lru_cache_wrapper.cache_info.__qualname__.__eq__
  args: ["_lru_cache_wrapper.cache_info"]
  expected: true

invariant functools_extra155.cache_info_qualname_len:
  description: "len(functools._lru_cache_wrapper.cache_info.__qualname__) == 29 — '_lru_cache_wrapper.cache_info' has 29 characters; wave 279; new to extra155"
  kind: python_call_eq
  function: _lru_cache_wrapper.cache_info.__qualname__.__len__
  args: []
  expected: 29

invariant functools_extra155.cache_clear_qualname_len:
  description: "len(functools._lru_cache_wrapper.cache_clear.__qualname__) == 30 — '_lru_cache_wrapper.cache_clear' has 30 characters; wave 279; new to extra155"
  kind: python_call_eq
  function: _lru_cache_wrapper.cache_clear.__qualname__.__len__
  args: []
  expected: 30

invariant functools_extra155.lru_cache_wrapper_dict_has_cache_info:
  description: "functools._lru_cache_wrapper.__dict__.__contains__('cache_info') == True — cache_info is in the class dict; wave 279; new to extra155"
  kind: python_call_eq
  function: _lru_cache_wrapper.__dict__.__contains__
  args: ["cache_info"]
  expected: true

invariant functools_extra155.lru_cache_wrapper_dict_has_cache_clear:
  description: "functools._lru_cache_wrapper.__dict__.__contains__('cache_clear') == True — cache_clear is in the class dict; wave 279; new to extra155"
  kind: python_call_eq
  function: _lru_cache_wrapper.__dict__.__contains__
  args: ["cache_clear"]
  expected: true

invariant functools_extra155.lru_cache_wrapper_dict_len:
  description: "len(functools._lru_cache_wrapper.__dict__) == 11 — _lru_cache_wrapper class dict has 11 entries; wave 279; new to extra155"
  kind: python_call_eq
  function: _lru_cache_wrapper.__dict__.__len__
  args: []
  expected: 11

invariant functools_extra155.reduce_doc_len:
  description: "len(functools.reduce.__doc__) == 389 — reduce docstring has 389 characters; wave 279; new to extra155"
  kind: python_call_eq
  function: reduce.__doc__.__len__
  args: []
