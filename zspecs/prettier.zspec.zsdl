spec: prettier
version: ">=3.0.0"
backend: node(prettier)

docs: https://prettier.io/docs/en/

provenance:
  derived_from:
    - "prettier documentation — https://prettier.io/docs/en/"
    - "Test vectors verified with prettier@3.8.1 via Node.js 22.20.0 on macOS/Darwin 25.4.0, 2026-04-05"
    - "prettier@3.x source — MIT license — format options (semi, singleQuote, tabWidth, printWidth, parser) verified from source and documentation, 2026-04-08"
  not_derived_from:
    - "prettier source: src/index.js"
  notes:
    - "prettier is a CJS module (require('prettier') works); the node backend uses require()."
    - "prettier 3.x is async-first: format(), check(), resolveConfig(), and getSupportInfo() all return Promises. There is no formatSync() in v3."
    - "All formatting and check invariants use cli_stdout_contains with inline async IIFE node scripts, since node_module_call_eq does not await Promises."
    - "version is a string property, not a function — accessed via inline node script."
    - "api invariants verify that key properties exist using typeof checks."
    - "format() always appends a trailing newline to the output."
    - "check() returns true if the input is already formatted, false otherwise."
  created_at: "2026-04-05T00:00:00Z"

error_model:
  semantics: "prettier functions return Promises that resolve to formatted strings or booleans. Malformed inputs cause the Promise to reject. node exits 0 for all invariants in this spec."
  stderr: "null under normal use"
  stickiness: "N/A — each function call is stateless."
  codes: {}

# --- version ---

invariant prettier.version.contains_dot:
  description: "prettier.version is a string containing a dot (e.g. '3.8.1')"
  category: version
  kind: cli_stdout_contains
  args: ["-e", "const p=require('prettier');process.stdout.write(p.version)"]
  expected_substring: "."

invariant prettier.version.major_3:
  description: "prettier major version is 3 (v3.x release series)"
  category: version
  kind: cli_stdout_contains
  args: ["-e", "const p=require('prettier');process.stdout.write(p.version.split('.')[0])"]
  expected_substring: "3"

# --- api ---

invariant prettier.api.format_is_function:
  description: "prettier.format is a function"
  category: api
  kind: cli_stdout_contains
  args: ["-e", "const p=require('prettier');process.stdout.write(typeof p.format)"]
  expected_substring: "function"

invariant prettier.api.check_is_function:
  description: "prettier.check is a function"
  category: api
  kind: cli_stdout_contains
  args: ["-e", "const p=require('prettier');process.stdout.write(typeof p.check)"]
  expected_substring: "function"

invariant prettier.api.getSupportInfo_is_function:
  description: "prettier.getSupportInfo is a function"
  category: api
  kind: cli_stdout_contains
  args: ["-e", "const p=require('prettier');process.stdout.write(typeof p.getSupportInfo)"]
  expected_substring: "function"

# --- format ---

invariant prettier.format.babel_basic:
  description: "format('const x=1', {parser:'babel'}) produces formatted JS with spaces"
  category: format
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.format('const x=1',{parser:'babel'});process.stdout.write(r)})()"]
  expected_substring: "const x = 1"

invariant prettier.format.babel_trailing_newline:
  description: "format() always appends a trailing newline"
  category: format
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.format('const x=1',{parser:'babel'});process.stdout.write(r.endsWith('\\n').toString())})()"]
  expected_substring: "true"

invariant prettier.format.css_basic:
  description: "format('.foo{color:red}', {parser:'css'}) produces expanded CSS"
  category: format
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.format('.foo{color:red}',{parser:'css'});process.stdout.write(r)})()"]
  expected_substring: "color: red"

# --- check ---

invariant prettier.check.already_formatted:
  description: "check('const x = 1;\\n', {parser:'babel'}) returns true for already-formatted code"
  category: check
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.check('const x = 1;\\n',{parser:'babel'});process.stdout.write(String(r))})()"]
  expected_substring: "true"

invariant prettier.check.needs_formatting:
  description: "check('const x=1', {parser:'babel'}) returns false for unformatted code"
  category: check
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.check('const x=1',{parser:'babel'});process.stdout.write(String(r))})()"]
  expected_substring: "false"

# --- format (extended) ---

invariant prettier.format.json_basic:
  description: "format('{\"a\":1}', {parser:'json'}) produces space after colon"
  category: format
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.format('{\"a\":1}',{parser:'json'});process.stdout.write(r)})()"]
  expected_substring: '"a": 1'

invariant prettier.format.json_trailing_newline:
  description: "format('{\"a\":1}', {parser:'json'}) output ends with a newline"
  category: format
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.format('{\"a\":1}',{parser:'json'});process.stdout.write(r.endsWith('\\n').toString())})()"]
  expected_substring: "true"

invariant prettier.format.typescript_basic:
  description: "format('const x:number=1', {parser:'typescript'}) adds spaces around colon"
  category: format
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.format('const x:number=1',{parser:'typescript'});process.stdout.write(r)})()"]
  expected_substring: "const x: number = 1"

invariant prettier.format.markdown_basic:
  description: "format('# Hello', {parser:'markdown'}) preserves heading"
  category: format
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.format('# Hello',{parser:'markdown'});process.stdout.write(r)})()"]
  expected_substring: "# Hello"

invariant prettier.format.html_basic:
  description: "format('<div><p>hi</p></div>', {parser:'html'}) preserves div tag"
  category: format
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.format('<div><p>hi</p></div>',{parser:'html'});process.stdout.write(r)})()"]
  expected_substring: "<div>"

invariant prettier.format.print_width_40:
  description: "format() with printWidth:40 wraps a long line (output contains newline)"
  category: format
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.format('const aVeryLongVariableName = \"some value that might wrap\";',{parser:'babel',printWidth:40});process.stdout.write(r.includes('\\n').toString())})()"]
  expected_substring: "true"

invariant prettier.format.semi_false:
  description: "format('const x = 1', {parser:'babel', semi:false}) omits the semicolon"
  category: format
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.format('const x = 1',{parser:'babel',semi:false});process.stdout.write(r)})()"]
  expected_substring: "const x = 1"

invariant prettier.format.single_quote:
  description: "format('const x = \"hello\"', {parser:'babel', singleQuote:true}) uses single quotes"
  category: format
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.format('const x = \"hello\"',{parser:'babel',singleQuote:true});process.stdout.write(r)})()"]
  expected_substring: "'hello'"

invariant prettier.format.tab_width_4:
  description: "format() with tabWidth:4 indents with 4 spaces"
  category: format
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.format('function f() {\\nconst x = 1\\n}',{parser:'babel',tabWidth:4});process.stdout.write(r)})()"]
  expected_substring: "    const"

invariant prettier.format.css_selector:
  description: "format('button.active{color:blue}', {parser:'css'}) preserves selector"
  category: format
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.format('button.active{color:blue}',{parser:'css'});process.stdout.write(r)})()"]
  expected_substring: "button.active"

invariant prettier.format.arrow_function:
  description: "format('const f=x=>x+1', {parser:'babel'}) formats arrow function with parens"
  category: format
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.format('const f=x=>x+1',{parser:'babel'});process.stdout.write(r)})()"]
  expected_substring: "=>"

# --- api (extended) ---

invariant prettier.api.resolveConfig_is_function:
  description: "prettier.resolveConfig is a function"
  category: api
  kind: cli_stdout_contains
  args: ["-e", "const p=require('prettier');process.stdout.write(typeof p.resolveConfig)"]
  expected_substring: "function"

invariant prettier.api.getFileInfo_is_function:
  description: "prettier.getFileInfo is a function"
  category: api
  kind: cli_stdout_contains
  args: ["-e", "const p=require('prettier');process.stdout.write(typeof p.getFileInfo)"]
  expected_substring: "function"

invariant prettier.api.parsers_babel_supported:
  description: "getSupportInfo() languages include 'babel' parser"
  category: api
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const info=await p.getSupportInfo();const parsers=info.languages.map(l=>l.parsers).flat();process.stdout.write(parsers.includes('babel').toString())})()"]
  expected_substring: "true"

# --- check (extended) ---

invariant prettier.check.json_formatted:
  description: "check('{ \"a\": 1 }\\n', {parser:'json'}) returns true for already-formatted JSON"
  category: check
  kind: cli_stdout_contains
  args: ["-e", "(async()=>{const p=require('prettier');const r=await p.check('{ \"a\": 1 }\\n',{parser:'json'});process.stdout.write(String(r))})()"]
  expected_substring: "true"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: infeasible
  model: claude-cli
  attempted_at: 2026-04-15T11:03:54Z
  iterations: 1
  pass_count: 0
  fail_count: 0
  total_invariants: 25
  notes: "LLM unavailable: claude CLI timed out after 300s"
  infeasible_reason: llm_unavailable
  invariant_annotations: {}
