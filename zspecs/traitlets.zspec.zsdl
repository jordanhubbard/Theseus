spec: traitlets
version: ">=5.0"
backend: python_module(traitlets)

docs: https://traitlets.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "traitlets documentation — https://traitlets.readthedocs.io/en/stable/"
    - "traitlets API reference — https://traitlets.readthedocs.io/en/stable/api.html"
    - "Test vectors verified with traitlets 5.14.3 on Python 3.14 / macOS Darwin 25.4.0, 2026-04-05"
  not_derived_from:
    - "traitlets source: traitlets/traitlets.py"
    - "traitlets source: traitlets/_version.py"
    - "traitlets source: traitlets/config/application.py"
  notes:
    - "traitlets provides a system for type-checked attributes (traits) in Python classes."
    - "__version__ is a plain string in semver form (e.g. '5.14.3') — always contains dots."
    - "TraitType is the base class for all trait descriptors."
    - "HasTraits is the base class all trait-bearing classes must inherit from."
    - "Int, Unicode, Bool, Float, List, Dict are the core built-in trait types."
    - "TraitType instances expose a default() method that returns the default value."
    - "default() accepts an optional obj argument (default None) — callable with zero args."
  created_at: "2026-04-05T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version — __version__ is a string containing dots
# ---------------------------------------------------------------------------

invariant traitlets.version.is_string:
  description: "__version__.__class__.__name__ == 'str' — __version__ is a plain string"
  category: version
  kind: python_call_eq
  function: __version__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant traitlets.version.contains_dot:
  description: "__version__ contains a dot — semver form like '5.14.3'"
  category: version
  kind: python_call_eq
  function: __version__.__contains__
  args: ["."]
  expected: true

# ---------------------------------------------------------------------------
# trait_types — class __name__ attributes for core trait types
# ---------------------------------------------------------------------------

table traitlets.trait_types.names:
  kind: python_call_eq
  category: trait_types
  id_prefix: trait_type
  expected: true

  columns: [id, function, args]
  rows:
    - [int_name,       Int.__name__.__eq__,       ["Int"]      ]
    - [unicode_name,   Unicode.__name__.__eq__,   ["Unicode"]  ]
    - [bool_name,      Bool.__name__.__eq__,      ["Bool"]     ]
    - [float_name,     Float.__name__.__eq__,     ["Float"]    ]
    - [list_name,      List.__name__.__eq__,      ["List"]     ]
    - [dict_name,      Dict.__name__.__eq__,      ["Dict"]     ]

# ---------------------------------------------------------------------------
# has_traits — base class names
# ---------------------------------------------------------------------------

invariant traitlets.has_traits.class_name:
  description: "HasTraits.__name__ == 'HasTraits' — base class for trait-bearing objects"
  category: has_traits
  kind: python_call_eq
  function: HasTraits.__name__.__eq__
  args: ["HasTraits"]
  expected: true

invariant traitlets.has_traits.trait_type_name:
  description: "TraitType.__name__ == 'TraitType' — base class for all trait descriptors"
  category: has_traits
  kind: python_call_eq
  function: TraitType.__name__.__eq__
  args: ["TraitType"]
  expected: true

# ---------------------------------------------------------------------------
# defaults — TraitType instances return correct default values
# ---------------------------------------------------------------------------

invariant traitlets.defaults.int_five:
  description: "Int(5).default() == 5 — Int trait default is the constructor arg"
  category: defaults
  kind: python_call_eq
  function: Int
  args: [5]
  method: default
  expected: 5

invariant traitlets.defaults.unicode_hello:
  description: "Unicode('hello').default() == 'hello' — Unicode trait default is the constructor arg"
  category: defaults
  kind: python_call_eq
  function: Unicode
  args: ["hello"]
  method: default
  expected: "hello"

invariant traitlets.defaults.bool_true:
  description: "Bool(True).default() == True — Bool trait default is the constructor arg"
  category: defaults
  kind: python_call_eq
  function: Bool
  args: [true]
  method: default
  expected: true

invariant traitlets.defaults.float_pi:
  description: "Float(3.14).default() == 3.14 — Float trait default is the constructor arg"
  category: defaults
  kind: python_call_eq
  function: Float
  args: [3.14]
  method: default
  expected: 3.14

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-04-14T23:50:04Z
  iterations: 1
  pass_count: 14
  fail_count: 0
  total_invariants: 14
  notes: Synthesis succeeded in 1 iteration(s). 14 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
