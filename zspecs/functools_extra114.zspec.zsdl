# ---------------------------------------------------------------------------
# Table 1: functools.cached_property __get__ and __set_name__ descriptor
# methods — type names, qualnames, and co_argcount values
#
# Wave 261 theme: functools.cached_property is a pure-Python descriptor class
# defined in Lib/functools.py. Its __get__ and __set_name__ are plain Python
# 'function' objects (accessed unbound from the class). __get__ takes 3
# arguments (self, instance, owner), and __set_name__ takes 3 arguments
# (self, owner, name). Both qualnames follow the 'cached_property.method_name'
# pattern.
#
# type(functools.cached_property.__get__).__name__ == 'function'
# functools.cached_property.__get__.__qualname__ == 'cached_property.__get__'
# functools.cached_property.__get__.__code__.co_argcount == 3
# type(functools.cached_property.__set_name__).__name__ == 'function'
# functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__'
# functools.cached_property.__set_name__.__code__.co_argcount == 3
#
# New to extra114.
# ---------------------------------------------------------------------------

table functools_extra114.cached_property_get_set_name:
  description: "functools.cached_property.__get__ and __set_name__: both type 'function'; qualnames follow 'cached_property.method_name' pattern; co_argcount 3 each; wave 261; new to extra114"
  kind: python_call_eq
  category: code_identity
  id_prefix: functoolscp114

  columns: [id, function, args, expected, description]
  rows:
    - [cp_get_type_function,
       "cached_property.__get__.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.cached_property.__get__.__class__.__name__.__eq__('function') == True — functools.cached_property is a pure-Python descriptor class; its __get__ method is a plain Python function defined inside the class body; accessed unbound it is a 'function' object (not a 'method_descriptor'); str.__eq__('function') returns True; new to extra114"]
    - [cp_get_qualname_eq,
       "cached_property.__get__.__qualname__.__eq__",
       ["cached_property.__get__"],
       true,
       "functools.cached_property.__get__.__qualname__.__eq__('cached_property.__get__') == True — cached_property.__get__ is defined inside the cached_property class body; its __qualname__ is 'cached_property.__get__'; the dotted form indicates class membership; str.__eq__('cached_property.__get__') returns True; new to extra114"]
    - [cp_get_co_argcount_3,
       "cached_property.__get__.__code__.co_argcount.__eq__",
       [3],
       true,
       "functools.cached_property.__get__.__code__.co_argcount.__eq__(3) == True — cached_property.__get__ takes 3 positional arguments: self (the descriptor), instance (the object being accessed), and owner (the owning class); for data descriptors __get__ receives all 3; co_argcount is 3; int.__eq__(3) returns True; new to extra114"]
    - [cp_set_name_type_function,
       "cached_property.__set_name__.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.cached_property.__set_name__.__class__.__name__.__eq__('function') == True — cached_property.__set_name__ is a plain Python function defined inside the cached_property class body; it is called at class creation time to record the attribute name; accessed unbound it is a 'function' object; str.__eq__('function') returns True; new to extra114"]
    - [cp_set_name_qualname_eq,
       "cached_property.__set_name__.__qualname__.__eq__",
       ["cached_property.__set_name__"],
       true,
       "functools.cached_property.__set_name__.__qualname__.__eq__('cached_property.__set_name__') == True — cached_property.__set_name__ is defined inside the cached_property class body; its __qualname__ is 'cached_property.__set_name__'; str.__eq__('cached_property.__set_name__') returns True; new to extra114"]
    - [cp_set_name_co_argcount_3,
       "cached_property.__set_name__.__code__.co_argcount.__eq__",
       [3],
       true,
       "functools.cached_property.__set_name__.__code__.co_argcount.__eq__(3) == True — cached_property.__set_name__ takes 3 positional arguments: self (the descriptor), owner (the owning class), name (the attribute name being assigned); Python calls __set_name__ automatically when a descriptor is defined in a class body; co_argcount is 3; int.__eq__(3) returns True; new to extra114"]

# ---------------------------------------------------------------------------
# Table 2: functools.cached_property __init__ descriptor method
#
# Wave 261 theme: functools.cached_property.__init__ is a plain Python
# 'function' taking 2 arguments (self, func). Its qualname is
# 'cached_property.__init__'. The cached_property class itself is defined
# in the 'functools' module (not 'builtins' or '_functools') and its
# __qualname__ is 'cached_property' (not a nested class).
#
# type(functools.cached_property.__init__).__name__ == 'function'
# functools.cached_property.__init__.__qualname__ == 'cached_property.__init__'
# functools.cached_property.__init__.__code__.co_argcount == 2
# functools.cached_property.__module__ == 'functools'
# functools.cached_property.__qualname__ == 'cached_property'
#
# New to extra114.
# ---------------------------------------------------------------------------

table functools_extra114.cached_property_init_and_class:
  description: "functools.cached_property.__init__: type 'function'; qualname 'cached_property.__init__'; co_argcount 2; cached_property class __module__ == 'functools'; __qualname__ == 'cached_property'; wave 261; new to extra114"
  kind: python_call_eq
  category: code_identity
  id_prefix: functoolscpi114

  columns: [id, function, args, expected, description]
  rows:
    - [cp_init_type_function,
       "cached_property.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.cached_property.__init__.__class__.__name__.__eq__('function') == True — functools.cached_property.__init__ is a plain Python function defined inside the cached_property class body; it initializes the descriptor with the callable to cache; accessed unbound it is a 'function' object; str.__eq__('function') returns True; new to extra114"]
    - [cp_init_qualname_eq,
       "cached_property.__init__.__qualname__.__eq__",
       ["cached_property.__init__"],
       true,
       "functools.cached_property.__init__.__qualname__.__eq__('cached_property.__init__') == True — cached_property.__init__ is defined inside the cached_property class body; its __qualname__ is 'cached_property.__init__'; the dunder name is preserved as-is in the qualname; str.__eq__('cached_property.__init__') returns True; new to extra114"]
    - [cp_init_co_argcount_2,
       "cached_property.__init__.__code__.co_argcount.__eq__",
       [2],
       true,
       "functools.cached_property.__init__.__code__.co_argcount.__eq__(2) == True — cached_property.__init__ takes 2 positional arguments: self (the descriptor being initialized) and func (the callable whose return value will be cached); co_argcount is 2; int.__eq__(2) returns True; new to extra114"]
    - [cp_class_module_functools,
       "cached_property.__module__.__eq__",
       ["functools"],
       true,
       "functools.cached_property.__module__.__eq__('functools') == True — functools.cached_property is a pure-Python class defined in Lib/functools.py; its __module__ is 'functools' (not '_functools' which is the C extension module); str.__eq__('functools') returns True; new to extra114"]
    - [cp_class_qualname_eq,
       "cached_property.__qualname__.__eq__",
       ["cached_property"],
       true,
       "functools.cached_property.__qualname__.__eq__('cached_property') == True — functools.cached_property is a top-level class defined directly in the functools module (not nested inside another class or function); its __qualname__ equals its __name__ which is 'cached_property'; str.__eq__('cached_property') returns True; new to extra114"]

# ---------------------------------------------------------------------------
# Table 3: functools.partial class-level __new__ and __init__ descriptor
# type names and qualnames
#
# Wave 261 theme: functools.partial is a C-extension type defined in
# Modules/_functoolsmodule.c. Its __new__ is a 'builtin_function_or_method'
# with qualname 'partial.__new__'. Its __init__ is a 'wrapper_descriptor'
# (the C-level slot wrapper for object.__init__, since partial overrides
# __new__ but uses the base object.__init__ slot). The partial class itself
# has __module__ == 'functools' (exposed via functools) and __name__ == 'partial'.
#
# type(functools.partial.__new__).__name__ == 'builtin_function_or_method'
# functools.partial.__new__.__qualname__ == 'partial.__new__'
# type(functools.partial.__init__).__name__ == 'wrapper_descriptor'
#
# New to extra114.
# ---------------------------------------------------------------------------

table functools_extra114.partial_new_init_descriptors:
  description: "functools.partial class-level descriptors: __new__ is 'builtin_function_or_method' with qualname 'partial.__new__'; __init__ is 'wrapper_descriptor'; wave 261; new to extra114"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolspa114

  columns: [id, function, args, expected, description]
  rows:
    - [partial_new_type_builtin,
       "partial.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.partial.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — functools.partial is a C-extension type; its __new__ allocator is implemented in C and exposed as a 'builtin_function_or_method'; this contrasts with pure-Python classes where __new__ would be a 'function' or 'staticmethod'; str.__eq__('builtin_function_or_method') returns True; new to extra114"]
    - [partial_new_qualname_eq,
       "partial.__new__.__qualname__.__eq__",
       ["partial.__new__"],
       true,
       "functools.partial.__new__.__qualname__.__eq__('partial.__new__') == True — functools.partial.__new__ is the C-level allocator for partial objects; its __qualname__ follows the 'ClassName.__new__' pattern 'partial.__new__'; str.__eq__('partial.__new__') returns True; new to extra114"]
    - [partial_init_type_wrapper_descriptor,
       "partial.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — functools.partial is a C-extension type whose __init__ is a 'wrapper_descriptor' (the C slot wrapper for object.__init__); C types that do not define a custom tp_init slot use the inherited slot wrapper; str.__eq__('wrapper_descriptor') returns True; new to extra114"]
    - [partial_class_name_eq,
       "partial.__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — functools.partial is the C-extension partial application type; its __name__ is 'partial'; str.__eq__('partial') returns True; new to extra114"]
    - [partial_class_module_functools,
       "partial.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — functools.partial is implemented in Modules/_functoolsmodule.c but exposed via the 'functools' module namespace; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra114"]

