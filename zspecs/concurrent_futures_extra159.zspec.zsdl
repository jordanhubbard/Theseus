spec: concurrent_futures_extra159
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures._base.Future method qualnames (result, exception, set_result, set_exception). Future.result.__qualname__=='Future.result' (len=13: 'Future'=6+'.'=1+'result'=6=13); Future.exception.__qualname__=='Future.exception' (len=16: 'Future'=6+'.'=1+'exception'=9=16); Future.set_result.__qualname__=='Future.set_result' (len=17: 'Future'=6+'.'=1+'set_result'=10=17; 'set_result'='set'=3+'_'=1+'result'=6=10); Future.set_exception.__qualname__=='Future.set_exception' (len=20: 'Future'=6+'.'=1+'set_exception'=13=20; 'set_exception'='set'=3+'_'=1+'exception'=9=13); qualname length ordering: result(13) < exception(16) < set_result(17) < set_exception(20). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures._base.Future.__name__=='Future' (len=6: 'F'+'u'+'t'+'u'+'r'+'e'=6); Future.__module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24; Future lives in the same private _base submodule as the Executor class established in extra158); Future.__bases__[0].__name__=='object' (Future inherits directly from object — it is the root of the concurrent.futures result-holder hierarchy); Future methods (result, exception, set_result, set_exception, cancel, done, add_done_callback) are all defined directly in Future.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Method qualname length analysis: 'Future.result'=13 (6+1+6: 'result'=6); 'Future.exception'=16 (6+1+9: 'exception'=9); 'Future.set_result'=17 (6+1+10: 'set_result'='set'=3+'_'=1+'result'=6=10); 'Future.set_exception'=20 (6+1+13: 'set_exception'='set'=3+'_'=1+'exception'=9=13); the 'set_' prefix adds 4 chars to each: set_result(17)=result(13)+4 and set_exception(20)=exception(16)+4; the qualname prefix 'Future.'=7 (6+1) is constant for all four; the method name lengths are: result(6) < exception(9) < set_result(10) < set_exception(13). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "The 'set_' setter methods have qualname lengths exactly 4 chars more than their corresponding getter methods: set_result(17)=result(13)+4 and set_exception(20)=exception(16)+4; this is because 'set_'=4 is the prefix added to both 'result' and 'exception' to form the setter method names; Future.set_result() and Future.set_exception() are called by the executing thread/process to store the result or exception; Future.result() and Future.exception() are called by the waiting thread/coroutine to retrieve the stored value. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures._base.Future.result and .exception qualnames — extra159
#
# Future.result.__qualname__.__eq__('Future.result')       == True
# Future.exception.__qualname__.__eq__('Future.exception') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra159.cf_future_result_exception_qualnames:
  description: "concurrent.futures._base.Future result and exception method qualname checks in cffutqn159 namespace — Future.result.__qualname__=='Future.result' (len=13: 'Future'=6+'.'=1+'result'=6=13; result() blocks until the future completes and returns the result value; if the future was cancelled or timed out, it raises CancelledError or TimeoutError); Future.exception.__qualname__=='Future.exception' (len=16: 'Future'=6+'.'=1+'exception'=9=16; exception() blocks until done and returns the exception raised by the call, or None if it completed without exception; 'exception'=9 is 3 chars longer than 'result'=6 explaining why exception qualname(16) is 3 longer than result qualname(13)); Future.__name__=='Future' (len=6); Future.__module__=='concurrent.futures._base' (len=24; same module as Executor from extra158); Future.__bases__[0].__name__=='object'; qualname prefix 'Future.'=7 (6+1) is shared by all four method qualnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutqn159

  columns: [id, function, args, expected, description]
  rows:
    - [result_qn_eq,    concurrent.futures._base.Future.result.__qualname__.__eq__,     ["Future.result"],     true,  "Future.result.__qualname__ == 'Future.result' (len=13: 'Future.'=7+'result'=6=13); verified with Python 3.14.3"]
    - [exc_qn_eq,       concurrent.futures._base.Future.exception.__qualname__.__eq__,  ["Future.exception"],  true,  "Future.exception.__qualname__ == 'Future.exception' (len=16: 'Future.'=7+'exception'=9=16); verified with Python 3.14.3"]
    - [result_qn_len,   concurrent.futures._base.Future.result.__qualname__.__len__,    [],                    13,    "Future.result.__qualname__.__len__() == 13 ('Future.result'; shortest of the four qualnames); verified with Python 3.14.3"]
    - [exc_qn_len,      concurrent.futures._base.Future.exception.__qualname__.__len__, [],                    16,    "Future.exception.__qualname__.__len__() == 16 ('Future.exception'; 3 longer than result=13); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures._base.Future.set_result and .set_exception qualnames — extra159
#
# Future.set_result.__qualname__.__eq__('Future.set_result')       == True
# Future.set_exception.__qualname__.__eq__('Future.set_exception') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra159.cf_future_set_result_set_exception_qualnames:
  description: "concurrent.futures._base.Future set_result and set_exception method qualname checks in cffutsetqn159 namespace — Future.set_result.__qualname__=='Future.set_result' (len=17: 'Future'=6+'.'=1+'set_result'=10=17; 'set_result'='set'=3+'_'=1+'result'=6=10; set_result() is called by the executing side to store the result in the Future object; it signals any threads blocked on result()); Future.set_exception.__qualname__=='Future.set_exception' (len=20: 'Future'=6+'.'=1+'set_exception'=13=20; 'set_exception'='set'=3+'_'=1+'exception'=9=13; set_exception() stores an exception in the Future so that exception() or result() will re-raise it); qualname length ordering: result(13) < exception(16) < set_result(17) < set_exception(20); the 'set_' prefix adds exactly 4 chars: set_result(17)=result(13)+4 and set_exception(20)=exception(16)+4; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutsetqn159

  columns: [id, function, args, expected, description]
  rows:
    - [set_result_qn_eq,    concurrent.futures._base.Future.set_result.__qualname__.__eq__,     ["Future.set_result"],     true,  "Future.set_result.__qualname__ == 'Future.set_result' (len=17: 'set_result'=10; setter method); verified with Python 3.14.3"]
    - [set_exc_qn_eq,       concurrent.futures._base.Future.set_exception.__qualname__.__eq__,  ["Future.set_exception"],  true,  "Future.set_exception.__qualname__ == 'Future.set_exception' (len=20: 'set_exception'=13; longest of the four); verified with Python 3.14.3"]
    - [set_result_qn_len,   concurrent.futures._base.Future.set_result.__qualname__.__len__,    [],                        17,    "Future.set_result.__qualname__.__len__() == 17 ('Future.set_result'; 4 more than result=13); verified with Python 3.14.3"]
    - [set_exc_qn_len,      concurrent.futures._base.Future.set_exception.__qualname__.__len__, [],                        20,    "Future.set_exception.__qualname__.__len__() == 20 ('Future.set_exception'; longest qualname in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures._base.Future class identity and qualname comparison — extra159
#
# Future.__name__.__eq__('Future')                              == True
# Future.__module__.__eq__('concurrent.futures._base')         == True
# Future.__bases__[0].__name__.__eq__('object')                == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra159.cf_future_identity_and_lengths:
  description: "concurrent.futures._base.Future class identity and qualname comparison checks in cffutid159 namespace — Future.__name__=='Future' (len=6: 'F'+'u'+'t'+'u'+'r'+'e'=6; the concurrent.futures result-holder class; Future objects are created by Executor.submit() and represent the eventual result of an asynchronous computation); Future.__module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24; same private _base submodule as Executor from extra158 — both Future and Executor live in Lib/concurrent/futures/_base.py); Future.__bases__[0].__name__=='object' (len=6; Future inherits from object directly — it is not a subclass of asyncio.Future or any other base); qualname length ordering for the four Future methods: result(13) < exception(16) < set_result(17) < set_exception(20); compare: Executor.__name__.__len__()==8 > Future.__name__.__len__()==6 (Executor name is 2 chars longer); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutid159

  columns: [id, function, args, expected, description]
  rows:
    - [fut_name_eq,   concurrent.futures._base.Future.__name__.__eq__,                ["Future"],                   true,  "Future.__name__ == 'Future' (len=6; result-holder class for executor-submitted tasks); verified with Python 3.14.3"]
    - [fut_mod_eq,    concurrent.futures._base.Future.__module__.__eq__,               ["concurrent.futures._base"], true,  "Future.__module__ == 'concurrent.futures._base' (len=24; same _base submodule as Executor); verified with Python 3.14.3"]
    - [fut_base_eq,   "concurrent.futures._base.Future.__bases__[0].__name__.__eq__",  ["object"],                   true,  "Future.__bases__[0].__name__ == 'object' (Future inherits from object directly); verified with Python 3.14.3"]
    - [fut_name_len,  concurrent.futures._base.Future.__name__.__len__,                [],                           6,     "Future.__name__.__len__() == 6 ('Future'; 2 shorter than Executor=8); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra159
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra159.cf_Future_result_qualname_eq:
  description: "concurrent.futures._base.Future.result.__qualname__.__eq__('Future.result') returns True — Future.result is defined directly on Future (in Future.__dict__); result.__qualname__=='Future.result' (len=13: 'Future'=6+'.'=1+'result'=6=13); Future.result(timeout=None) blocks the calling thread until the future is done or the optional timeout expires; if the call raised an exception, result() re-raises it; if the future was cancelled, result() raises CancelledError; the qualname prefix 'Future.'=7 (6+1) is the same for all four method qualnames (result, exception, set_result, set_exception); result(13) is the shortest qualname among the four because 'result'=6 is the shortest method name; compare: Future.exception.__qualname__.__len__()==16 (3 longer: 'exception'=9 > 'result'=6); NEW in extra159: first standalone Future.result.__qualname__ identity invariant in cffutqn159 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.Future.result.__qualname__.__eq__
  args: ["Future.result"]
  expected: true

invariant concurrent_futures_extra159.cf_Future_exception_qualname_eq:
  description: "concurrent.futures._base.Future.exception.__qualname__.__eq__('Future.exception') returns True — Future.exception is defined directly on Future; exception.__qualname__=='Future.exception' (len=16: 'Future'=6+'.'=1+'exception'=9=16); Future.exception(timeout=None) blocks the calling thread until the future is done and returns the exception raised by the call, or None if no exception; 'exception'=9 is 3 chars longer than 'result'=6 explaining the 3-char qualname difference: exception(16) vs result(13); exception qualname (16) < set_result qualname (17) by 1 char because 'set_result'=10 > 'exception'=9 by 1; compare: Future.set_exception.__qualname__.__len__()==20 (the 'set_' setter is 4 longer: 20=16+4); NEW in extra159: first standalone Future.exception.__qualname__ identity invariant in cffutqn159 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.Future.exception.__qualname__.__eq__
  args: ["Future.exception"]
  expected: true

invariant concurrent_futures_extra159.cf_Future_set_result_qualname_eq:
  description: "concurrent.futures._base.Future.set_result.__qualname__.__eq__('Future.set_result') returns True — Future.set_result is defined directly on Future; set_result.__qualname__=='Future.set_result' (len=17: 'Future'=6+'.'=1+'set_result'=10=17; 'set_result'='set'=3+'_'=1+'result'=6=10); set_result(result) sets the result of the Future; it should be called by the thread or process that executed the computation (typically done internally by the executor framework); set_result.__qualname__ (len=17) is exactly 4 chars more than result.__qualname__ (len=13) because 'set_'=4 is the prefix added; similarly set_exception(20) = exception(16) + 4; the 'set_' prefix (4 chars) is a consistent 4-char addition to both getter qualname lengths; NEW in extra159: first standalone Future.set_result.__qualname__ identity invariant in cffutsetqn159 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.Future.set_result.__qualname__.__eq__
  args: ["Future.set_result"]
  expected: true

invariant concurrent_futures_extra159.cf_Future_set_exception_qualname_eq:
  description: "concurrent.futures._base.Future.set_exception.__qualname__.__eq__('Future.set_exception') returns True — Future.set_exception is defined directly on Future; set_exception.__qualname__=='Future.set_exception' (len=20: 'Future'=6+'.'=1+'set_exception'=13=20; 'set_exception'='set'=3+'_'=1+'exception'=9=13); set_exception(exception) sets the exception raised by the Future; exception() and result() will then re-raise it; set_exception qualname (len=20) is the longest among the four method qualnames: result(13) < exception(16) < set_result(17) < set_exception(20); set_exception(20) = exception(16) + 4 (the 'set_' prefix adds 4 chars); the qualname length ordering reflects: method name lengths result(6) < exception(9) < set_result(10) < set_exception(13); plus the constant 'Future.'=7 prefix; NEW in extra159: first standalone Future.set_exception.__qualname__ identity invariant in cffutsetqn159 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.Future.set_exception.__qualname__.__eq__
  args: ["Future.set_exception"]
  expected: true

invariant concurrent_futures_extra159.cf_Future_name_eq:
  description: "concurrent.futures._base.Future.__name__.__eq__('Future') returns True — concurrent.futures._base.Future is the result-holder class for the concurrent.futures framework; Future.__name__=='Future' (len=6: 'F'+'u'+'t'+'u'+'r'+'e'=6); a Future represents the result of an asynchronous computation: it starts pending, then transitions to running (when the executor picks it up), and finally to finished (with either a result, exception, or cancellation); Future.__module__=='concurrent.futures._base' (len=24; same private _base submodule as Executor from extra158); Future.__bases__[0].__name__=='object' (inherits from object — this concurrent.futures.Future is distinct from asyncio.Future which is C-accelerated with __module__=='_asyncio'); compare: Executor.__name__.__len__()==8 (Executor name is 2 chars longer than Future=6); NEW in extra159: first standalone cf._base.Future.__name__ identity invariant in cffutid159 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.Future.__name__.__eq__
  args: ["Future"]
  expected: true
