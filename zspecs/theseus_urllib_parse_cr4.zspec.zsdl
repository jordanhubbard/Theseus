spec: theseus_urllib_parse_cr4
version: ">=3.9"
backend: python_cleanroom(theseus_urllib_parse_cr4)
blocks: urllib

docs: https://docs.python.org/3/library/urllib.parse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html"
    - "RFC 3986 — URI Generic Syntax"
  notes:
    - "Clean-room extended urllib.parse utilities. Do NOT import urllib or urllib.parse."
    - "urlunparse(components): reconstruct URL from 6-tuple (scheme,netloc,path,params,query,fragment)."
    - "parse_qs(qs, keep_blank_values=False): parse query string into dict of lists."
    - "urlencode(query): encode mapping or sequence of (key,value) pairs to query string."
    - "urlparse4_unparse(): urlunparse(('http','x.com','/','','a=1','')) == 'http://x.com/?a=1'."
    - "urlparse4_parse_qs_list(): parse_qs('a=1&a=2')['a'] == ['1', '2']."
    - "urlparse4_urlencode_list(): urlencode([('a','1'),('b','2')]) == 'a=1&b=2'."
    - "Zero-arg invariant signatures — def urlparse4_unparse(): return hardcoded_result"
    - "urlunparse: if query is non-empty, join path+'?'+query; if fragment, append '#'+fragment."
    - "parse_qs: split on '&'; split each pair on '='; append value to key's list."
    - "urlencode: percent-encode each key and value; join pairs with '='."
    - "Export: urlunparse, urlparse, parse_qs, parse_qsl, urlencode, quote, unquote."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_urllib_parse_cr4.unparse:
  description: "urlunparse(('http','x.com','/','','a=1','')) == 'http://x.com/?a=1'"
  category: urlunparse
  kind: python_call_eq
  function: urlparse4_unparse
  args: []
  expected: "http://x.com/?a=1"

invariant theseus_urllib_parse_cr4.parse_qs_list:
  description: "parse_qs('a=1&a=2')['a'] == ['1', '2']"
  category: parse_qs
  kind: python_call_eq
  function: urlparse4_parse_qs_list
  args: []
  expected: ["1", "2"]

invariant theseus_urllib_parse_cr4.urlencode_list:
  description: "urlencode([('a','1'),('b','2')]) == 'a=1&b=2'"
  category: urlencode
  kind: python_call_eq
  function: urlparse4_urlencode_list
  args: []
  expected: "a=1&b=2"
