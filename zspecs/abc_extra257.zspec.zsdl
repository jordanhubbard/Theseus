spec: abc_extra257
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "abc.ABC.__bases__[0].__name__ == 'object': ABC has no custom base."
    - "type(abc.ABC).__name__ == 'ABCMeta': ABC's metaclass is ABCMeta."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type': ABCMeta inherits from the built-in type."
    - "abc.abstractmethod.__class__.__name__ == 'function': abstractmethod is a plain Python function."
    - "abc.abstractmethod.__call__.__class__.__name__ == 'method-wrapper': __call__ on a function is a method-wrapper."
    - "abc.abstractclassmethod exists and inherits from classmethod (deprecated but present on Python 3.14)."
    - "abc.abstractstaticmethod exists and inherits from staticmethod (deprecated but present on Python 3.14)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC class identity
# ---------------------------------------------------------------------------

invariant abc_extra257.abc_class.name:
  description: "abc.ABC.__name__ == 'ABC'"
  category: identity
  kind: python_call_eq
  function: ABC.__name__.__eq__
  args: ["ABC"]
  expected: true

invariant abc_extra257.abc_class.module:
  description: "abc.ABC.__module__ == 'abc'"
  category: identity
  kind: python_call_eq
  function: ABC.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra257.abc_class.base:
  description: "abc.ABC.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: ABC.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant abc_extra257.abc_class.metaclass:
  description: "type(abc.ABC).__name__ == 'ABCMeta'"
  category: identity
  kind: python_call_eq
  function: ABC.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

# ---------------------------------------------------------------------------
# abc.ABCMeta metaclass identity
# ---------------------------------------------------------------------------

invariant abc_extra257.abcmeta.name:
  description: "abc.ABCMeta.__name__ == 'ABCMeta'"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra257.abcmeta.module:
  description: "abc.ABCMeta.__module__ == 'abc'"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra257.abcmeta.base:
  description: "abc.ABCMeta.__bases__[0].__name__ == 'type'"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__bases__[0].__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# abc.abstractmethod decorator identity
# ---------------------------------------------------------------------------

invariant abc_extra257.abstractmethod.name:
  description: "abc.abstractmethod.__name__ == 'abstractmethod'"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__name__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra257.abstractmethod.qualname:
  description: "abc.abstractmethod.__qualname__ == 'abstractmethod'"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__qualname__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra257.abstractmethod.module:
  description: "abc.abstractmethod.__module__ == 'abc'"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra257.abstractmethod.class:
  description: "type(abc.abstractmethod).__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant abc_extra257.abstractmethod.call_class:
  description: "type(abc.abstractmethod.__call__).__name__ == 'method-wrapper'"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__call__.__class__.__name__.__eq__
  args: ["method-wrapper"]
  expected: true

# ---------------------------------------------------------------------------
# abc.abstractclassmethod (deprecated) identity
# ---------------------------------------------------------------------------

invariant abc_extra257.abstractclassmethod.name:
  description: "abc.abstractclassmethod.__name__ == 'abstractclassmethod'"
  category: identity
  kind: python_call_eq
  function: abstractclassmethod.__name__.__eq__
  args: ["abstractclassmethod"]
  expected: true

invariant abc_extra257.abstractclassmethod.module:
  description: "abc.abstractclassmethod.__module__ == 'abc'"
  category: identity
  kind: python_call_eq
  function: abstractclassmethod.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra257.abstractclassmethod.base:
  description: "abc.abstractclassmethod.__bases__[0].__name__ == 'classmethod'"
  category: identity
  kind: python_call_eq
  function: abstractclassmethod.__bases__[0].__name__.__eq__
  args: ["classmethod"]
  expected: true

# ---------------------------------------------------------------------------
# abc.abstractstaticmethod (deprecated) identity
# ---------------------------------------------------------------------------

invariant abc_extra257.abstractstaticmethod.name:
  description: "abc.abstractstaticmethod.__name__ == 'abstractstaticmethod'"
  category: identity
  kind: python_call_eq
  function: abstractstaticmethod.__name__.__eq__
  args: ["abstractstaticmethod"]
  expected: true

invariant abc_extra257.abstractstaticmethod.module:
  description: "abc.abstractstaticmethod.__module__ == 'abc'"
  category: identity
  kind: python_call_eq
  function: abstractstaticmethod.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra257.abstractstaticmethod.base:
  description: "abc.abstractstaticmethod.__bases__[0].__name__ == 'staticmethod'"
  category: identity
  kind: python_call_eq
  function: abstractstaticmethod.__bases__[0].__name__.__eq__
  args: ["staticmethod"]
  expected: true
