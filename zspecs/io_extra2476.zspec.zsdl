spec: io_extra2476
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "Theme: __contains__ and __getitem__ dict-presence — checking whether io classes define membership test and item access protocol in their class __dict__."
    - "io stream classes (BytesIO, StringIO, BufferedReader) are pure I/O objects — they expose no __contains__ or __getitem__ in their own __dict__."
    - "io.BytesIO.__dict__ does NOT contain '__contains__' (False) — BytesIO is a stream, not a container."
    - "io.BytesIO.__dict__ does NOT contain '__getitem__' (False) — BytesIO does not support subscript access."
    - "io.StringIO.__dict__ does NOT contain '__contains__' (False) — StringIO is a stream, not a container."
    - "io.StringIO.__dict__ does NOT contain '__getitem__' (False) — StringIO does not support subscript access."
    - "io.BufferedReader.__dict__ does NOT contain '__contains__' (False)."
    - "io.BufferedReader.__dict__ does NOT contain '__getitem__' (False)."
    - "io.BytesIO.__dict__ DOES contain 'read', 'write', 'seek', 'tell', 'getvalue', 'getbuffer', 'close', 'readline', 'truncate', 'flush' (all True)."
    - "io.StringIO.__dict__ DOES contain 'read', 'write', 'seek', 'tell', 'getvalue', 'close', 'readline', 'truncate' (all True)."
    - "io.BufferedReader.__dict__ DOES contain 'read', 'read1', 'readline', 'peek' (all True)."
    - "Accessing a missing key via io.BytesIO.__dict__.__getitem__ raises KeyError."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO.__dict__.__contains__ — protocol presence checks
# BytesIO is a byte-stream object; it defines no __contains__ or __getitem__.
# Confirms that stream classes do not participate in the container protocol.
# ---------------------------------------------------------------------------

table io_extra2476.BytesIO_dict_protocol_absence:
  description: "io.BytesIO.__dict__ does not contain __contains__ or __getitem__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: io2476

  columns: [id, function, args, expected]
  rows:
    - ["io2476001", io.BytesIO.__dict__.__contains__, ["__contains__"], false]
    - ["io2476002", io.BytesIO.__dict__.__contains__, ["__getitem__"],  false]

# ---------------------------------------------------------------------------
# io.BytesIO.__dict__.__contains__ — methods that ARE defined on BytesIO
# These confirm the stream API is present in __dict__, providing contrast to
# the absent container protocol entries above.
# ---------------------------------------------------------------------------

table io_extra2476.BytesIO_dict_method_presence:
  description: "io.BytesIO.__dict__ contains its stream methods (read, write, seek, tell, getvalue, getbuffer, close, readline, truncate, flush)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: io2476

  columns: [id, function, args, expected]
  rows:
    - ["io2476003", io.BytesIO.__dict__.__contains__, ["read"],      true]
    - ["io2476004", io.BytesIO.__dict__.__contains__, ["write"],     true]
    - ["io2476005", io.BytesIO.__dict__.__contains__, ["seek"],      true]
    - ["io2476006", io.BytesIO.__dict__.__contains__, ["tell"],      true]
    - ["io2476007", io.BytesIO.__dict__.__contains__, ["getvalue"],  true]
    - ["io2476008", io.BytesIO.__dict__.__contains__, ["getbuffer"], true]
    - ["io2476009", io.BytesIO.__dict__.__contains__, ["readline"],  true]
    - ["io2476010", io.BytesIO.__dict__.__contains__, ["truncate"],  true]

# ---------------------------------------------------------------------------
# io.BytesIO.__dict__.__getitem__ — KeyError for missing keys
# Confirms that accessing a key absent from BytesIO.__dict__ via __getitem__
# raises KeyError, consistent with dict/mappingproxy semantics.
# ---------------------------------------------------------------------------

table io_extra2476.BytesIO_dict_getitem_missing:
  description: "io.BytesIO.__dict__.__getitem__ raises KeyError for absent keys"
  kind: python_call_raises
  category: dict_membership
  id_prefix: io2476

  columns: [id, function, args, expected]
  rows:
    - ["io2476011", io.BytesIO.__dict__.__getitem__, ["__contains__"], KeyError]
    - ["io2476012", io.BytesIO.__dict__.__getitem__, ["__getitem__"],  KeyError]

# ---------------------------------------------------------------------------
# io.StringIO.__dict__.__contains__ — protocol presence checks
# StringIO is a text-stream object; it defines no __contains__ or __getitem__.
# ---------------------------------------------------------------------------

table io_extra2476.StringIO_dict_protocol_absence:
  description: "io.StringIO.__dict__ does not contain __contains__ or __getitem__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: io2476

  columns: [id, function, args, expected]
  rows:
    - ["io2476013", io.StringIO.__dict__.__contains__, ["__contains__"], false]
    - ["io2476014", io.StringIO.__dict__.__contains__, ["__getitem__"],  false]

# ---------------------------------------------------------------------------
# io.StringIO.__dict__.__contains__ — methods that ARE defined on StringIO
# ---------------------------------------------------------------------------

table io_extra2476.StringIO_dict_method_presence:
  description: "io.StringIO.__dict__ contains its stream methods (read, write, seek, tell, getvalue, close, readline, truncate)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: io2476

  columns: [id, function, args, expected]
  rows:
    - ["io2476015", io.StringIO.__dict__.__contains__, ["read"],     true]
    - ["io2476016", io.StringIO.__dict__.__contains__, ["write"],    true]
    - ["io2476017", io.StringIO.__dict__.__contains__, ["seek"],     true]
    - ["io2476018", io.StringIO.__dict__.__contains__, ["tell"],     true]
    - ["io2476019", io.StringIO.__dict__.__contains__, ["getvalue"], true]
    - ["io2476020", io.StringIO.__dict__.__contains__, ["readline"], true]

# ---------------------------------------------------------------------------
# io.BufferedReader.__dict__.__contains__ — protocol absence and method presence
# BufferedReader is a buffered byte-stream; no container protocol in __dict__.
# ---------------------------------------------------------------------------

table io_extra2476.BufferedReader_dict_presence:
  description: "io.BufferedReader.__dict__: no __contains__/__getitem__; has read, read1, readline, peek"
  kind: python_call_eq
  category: dict_membership
  id_prefix: io2476

  columns: [id, function, args, expected]
  rows:
    - ["io2476021", io.BufferedReader.__dict__.__contains__, ["__contains__"], false]
    - ["io2476022", io.BufferedReader.__dict__.__contains__, ["__getitem__"],  false]
    - ["io2476023", io.BufferedReader.__dict__.__contains__, ["read"],         true]
    - ["io2476024", io.BufferedReader.__dict__.__contains__, ["read1"],        true]
    - ["io2476025", io.BufferedReader.__dict__.__contains__, ["readline"],     true]
    - ["io2476026", io.BufferedReader.__dict__.__contains__, ["peek"],         true]
