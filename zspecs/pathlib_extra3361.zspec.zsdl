spec: pp3361
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 671 (pp3361): __invert__, __floor__, __ceil__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __invert__, __floor__, __ceil__ dict-presence (~x, math.floor(x), math.ceil(x))."
    - "No pathlib class defines __invert__ in its own __dict__: path objects are filesystem path abstractions, not integer types; bitwise inversion has no meaning for paths."
    - "No pathlib class defines __floor__ in its own __dict__: path objects are not numeric types; math.floor() has no semantic meaning for filesystem path objects."
    - "No pathlib class defines __ceil__ in its own __dict__: path objects are not numeric types; math.ceil() has no semantic meaning for filesystem path objects."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all bitwise and rounding operators absent from pathlib class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __invert__ dict-presence — operator.contains(Cls.__dict__, '__invert__')
#
# No pathlib class defines __invert__ in its own __dict__; all false.
# pathlib path objects are filesystem path abstractions, not integer types;
# the ~x operator has no semantic meaning for path objects.
# ---------------------------------------------------------------------------

table pp3361.invert:
  description: "pathlib types __invert__ dict-presence checks; wave 671"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3361

  columns: [id, function, args, expected]
  rows:
    - ["pp3361001", operator.contains, [pathlib.PurePath.__dict__,         "__invert__"], false]
    - ["pp3361002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__invert__"], false]
    - ["pp3361003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__invert__"], false]
    - ["pp3361004", operator.contains, [pathlib.Path.__dict__,             "__invert__"], false]
    - ["pp3361005", operator.contains, [pathlib.PosixPath.__dict__,        "__invert__"], false]

