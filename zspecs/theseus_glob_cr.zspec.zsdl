spec: theseus_glob_cr
version: ">=3.8"
backend: python_cleanroom(theseus_glob_cr)
blocks: glob

docs: https://docs.python.org/3/library/glob.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/glob.html"
  not_derived_from:
    - "CPython source: Lib/glob.py (internal implementation)"
  notes:
    - "Clean-room glob module. Do NOT import glob."
    - "glob(pathname): return list of paths matching pattern."
    - "iglob(pathname): return iterator of matching paths."
    - "escape(pathname): escape special characters in pathname."

error_model: python_exceptions

invariant theseus_glob_cr.glob2_star:
  description: "glob('*.py') returns at least one result in a Python directory"
  category: glob
  kind: python_call_eq
  function: glob2_star
  args: []
  expected: true

invariant theseus_glob_cr.glob2_escape:
  description: "escape('[') returns '\\[' to treat it literally"
  category: escape
  kind: python_call_eq
  function: glob2_escape
  args: []
  expected: true

invariant theseus_glob_cr.glob2_iglob:
  description: "iglob returns an iterator"
  category: iglob
  kind: python_call_eq
  function: glob2_iglob
  args: []
  expected: true
