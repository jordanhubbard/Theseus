spec: decimal_extra3
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "Python decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal.zspec.zsdl — covers class names (Decimal, Context, DecimalException, InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded, Subnormal, FloatOperation, ROUND_UP/DOWN/CEILING/FLOOR/HALF_UP/HALF_DOWN/HALF_EVEN/05UP constants), getcontext/setcontext/localcontext function names"
    - "decimal_extra.zspec.zsdl — covers Decimal('3.14') + Decimal('1.0') == Decimal('4.14'), Decimal('10') / Decimal('3') class name, Decimal.__module__ == 'decimal', getcontext().__class__.__name__ == 'Context', ROUND_HALF_UP == 'ROUND_HALF_UP', Decimal('Infinity').__class__.__name__ == 'Decimal'"
    - "decimal_extra2.zspec.zsdl — covers Decimal.__name__, Context.__name__, DecimalException.__name__, InvalidOperation.__name__, DivisionByZero.__name__, Overflow.__name__, Decimal('0').is_zero() == True, Decimal('1').is_finite() == True, Decimal('Infinity').is_infinite() == True, Decimal('NaN').is_nan() == True"
  notes:
    - "This spec extends decimal.zspec.zsdl, decimal_extra.zspec.zsdl, and decimal_extra2.zspec.zsdl."
    - "Focus: class hierarchy (__bases__[0].__name__) for Decimal, Context, and exception types; function __name__ and __module__ attributes for getcontext/setcontext/localcontext; Decimal.as_tuple() return type; MAX_PREC and MAX_EMAX type checks."
    - "decimal.Decimal.__bases__[0].__name__ == 'object' — Decimal inherits directly from object."
    - "decimal.Context.__bases__[0].__name__ == 'object' — Context inherits directly from object."
    - "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — base exception hierarchy."
    - "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException'."
    - "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException'."
    - "decimal.Overflow.__bases__[0].__name__ == 'DecimalException'."
    - "decimal.Underflow.__bases__[0].__name__ == 'DecimalException'."
    - "decimal.getcontext.__name__ == 'getcontext'; decimal.setcontext.__name__ == 'setcontext'; decimal.localcontext.__name__ == 'localcontext'."
    - "decimal.getcontext.__module__ == 'decimal'."
    - "decimal.Decimal('3.14').as_tuple().__class__.__name__ == 'DecimalTuple'."
    - "decimal.Decimal.__module__ == 'decimal' — additional confirmation."
    - "decimal.MAX_PREC.__class__.__name__ == 'int'; decimal.MAX_EMAX.__class__.__name__ == 'int'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class hierarchy — __bases__[0].__name__ checks
# ---------------------------------------------------------------------------

invariant decimal_extra3.Decimal.base_is_object:
  description: "decimal.Decimal.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: Decimal.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant decimal_extra3.Context.base_is_object:
  description: "decimal.Context.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: Context.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant decimal_extra3.DecimalException.base_is_ArithmeticError:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError'"
  category: class_hierarchy
  kind: python_call_eq
  function: DecimalException.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ArithmeticError"

invariant decimal_extra3.InvalidOperation.base_is_DecimalException:
  description: "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException'"
  category: class_hierarchy
  kind: python_call_eq
  function: InvalidOperation.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "DecimalException"

invariant decimal_extra3.DivisionByZero.base_is_DecimalException:
  description: "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException'"
  category: class_hierarchy
  kind: python_call_eq
  function: DivisionByZero.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "DecimalException"

invariant decimal_extra3.Overflow.base_is_DecimalException:
  description: "decimal.Overflow.__bases__[0].__name__ == 'DecimalException'"
  category: class_hierarchy
  kind: python_call_eq
  function: Overflow.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "DecimalException"

invariant decimal_extra3.Underflow.base_is_DecimalException:
  description: "decimal.Underflow.__bases__[0].__name__ == 'DecimalException'"
  category: class_hierarchy
  kind: python_call_eq
  function: Underflow.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "DecimalException"

# ---------------------------------------------------------------------------
# Function __name__ and __module__ checks
# ---------------------------------------------------------------------------

invariant decimal_extra3.getcontext.dunder_name:
  description: "decimal.getcontext.__name__ == 'getcontext'"
  category: function_names
  kind: python_call_eq
  function: getcontext.__name__.__eq__
  args: ["getcontext"]
  expected: true

invariant decimal_extra3.setcontext.dunder_name:
  description: "decimal.setcontext.__name__ == 'setcontext'"
  category: function_names
  kind: python_call_eq
  function: setcontext.__name__.__eq__
  args: ["setcontext"]
  expected: true

invariant decimal_extra3.localcontext.dunder_name:
  description: "decimal.localcontext.__name__ == 'localcontext'"
  category: function_names
  kind: python_call_eq
  function: localcontext.__name__.__eq__
  args: ["localcontext"]
  expected: true

invariant decimal_extra3.getcontext.module:
  description: "decimal.getcontext.__module__ == 'decimal'"
  category: function_names
  kind: python_call_eq
  function: getcontext.__module__.__eq__
  args: ["decimal"]
  expected: true

# ---------------------------------------------------------------------------
# Decimal.__module__ — class-level module attribute
# ---------------------------------------------------------------------------

invariant decimal_extra3.Decimal.module:
  description: "decimal.Decimal.__module__ == 'decimal'"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

# ---------------------------------------------------------------------------
# Decimal.as_tuple() — return type is DecimalTuple (a namedtuple)
# ---------------------------------------------------------------------------

invariant decimal_extra3.Decimal.as_tuple_class:
  description: "decimal.Decimal('3.14').as_tuple().__class__.__name__ == 'DecimalTuple'"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["3.14"]
  method: as_tuple
  method_args: []
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["DecimalTuple"]
  expected: true

# ---------------------------------------------------------------------------
# MAX_PREC and MAX_EMAX — integer type checks
# ---------------------------------------------------------------------------

invariant decimal_extra3.MAX_PREC.class_name:
  description: "decimal.MAX_PREC.__class__.__name__ == 'int'"
  category: module_constants
  kind: python_call_eq
  function: MAX_PREC.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant decimal_extra3.MAX_EMAX.class_name:
  description: "decimal.MAX_EMAX.__class__.__name__ == 'int'"
  category: module_constants
  kind: python_call_eq
  function: MAX_EMAX.__class__.__name__.__eq__
  args: ["int"]
  expected: true
