spec: pathlib_extra115
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra114.zspec.zsdl."
    - "This spec covers: pathlib.Path.resolve, absolute, expanduser, is_mount, samefile, hardlink_to, relative_to, is_relative_to method qualnames and co_argcounts."
    - "pathlib.Path.resolve.__qualname__ == 'Path.resolve' (len 12); co_argcount == 2 (self, strict)."
    - "pathlib.Path.absolute.__qualname__ == 'Path.absolute' (len 13); co_argcount == 1 (self only)."
    - "pathlib.Path.expanduser.__qualname__ == 'Path.expanduser' (len 15); co_argcount == 1 (self only)."
    - "pathlib.Path.is_mount.__qualname__ == 'Path.is_mount' (len 13); co_argcount == 1 (self only)."
    - "pathlib.Path.samefile.__qualname__ == 'Path.samefile' (len 13); co_argcount == 2 (self, other_path)."
    - "pathlib.Path.hardlink_to.__qualname__ == 'Path.hardlink_to' (len 16); co_argcount == 2 (self, target)."
    - "pathlib.Path.relative_to.__qualname__ == 'PurePath.relative_to' (len 20); co_argcount == 2 (self, other); defined on PurePath."
    - "pathlib.Path.is_relative_to.__qualname__ == 'PurePath.is_relative_to' (len 23); defined on PurePath."
    - "resolve/absolute/expanduser/is_mount/samefile/hardlink_to use 'Path.' prefix (defined on Path)."
    - "relative_to/is_relative_to use 'PurePath.' prefix (inherited from PurePath)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.resolve, absolute, expanduser qualnames and co_argcounts
# resolve: 'Path.resolve' (12 chars); co_argcount == 2 (self, strict).
# absolute: 'Path.absolute' (13 chars); co_argcount == 1 (self only).
# expanduser: 'Path.expanduser' (15 chars); co_argcount == 1 (self only).
# All three are defined on Path (use 'Path.' prefix, not 'PurePath.').
# ---------------------------------------------------------------------------

table pathlib_extra115.Path_resolve_absolute_expanduser_qualnames:
  description: "pathlib.Path resolve/absolute/expanduser __qualname__: resolve='Path.resolve'(12), absolute='Path.absolute'(13), expanduser='Path.expanduser'(15); co_argcounts: resolve=2, absolute=1, expanduser=1"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn115a

  columns: [id, function, args, expected, description]
  rows:
    - [resolve_qn_eq,        "Path.resolve.__qualname__.__eq__",           ["Path.resolve"],    true,  "pathlib.Path.resolve.__qualname__ == 'Path.resolve' (defined on Path, not PurePath)"]
    - [resolve_qn_len,       "Path.resolve.__qualname__.__len__",          [],                  12,    "pathlib.Path.resolve.__qualname__.__len__() == 12 ('Path.resolve' has 12 chars)"]
    - [resolve_argcount,     "Path.resolve.__code__.co_argcount.__eq__",   [2],                 true,  "pathlib.Path.resolve.__code__.co_argcount == 2 (self, strict; strict=False by default)"]
    - [absolute_qn_eq,       "Path.absolute.__qualname__.__eq__",          ["Path.absolute"],   true,  "pathlib.Path.absolute.__qualname__ == 'Path.absolute' (defined on Path)"]
    - [absolute_qn_len,      "Path.absolute.__qualname__.__len__",         [],                  13,    "pathlib.Path.absolute.__qualname__.__len__() == 13 ('Path.absolute' has 13 chars)"]
    - [absolute_argcount,    "Path.absolute.__code__.co_argcount.__eq__",  [1],                 true,  "pathlib.Path.absolute.__code__.co_argcount == 1 (self only; no additional parameters)"]
    - [expanduser_qn_eq,     "Path.expanduser.__qualname__.__eq__",        ["Path.expanduser"], true,  "pathlib.Path.expanduser.__qualname__ == 'Path.expanduser' (defined on Path)"]
    - [expanduser_qn_len,    "Path.expanduser.__qualname__.__len__",       [],                  15,    "pathlib.Path.expanduser.__qualname__.__len__() == 15 ('Path.expanduser' has 15 chars; longest in this group)"]
    - [expanduser_argcount,  "Path.expanduser.__code__.co_argcount.__eq__",[1],                 true,  "pathlib.Path.expanduser.__code__.co_argcount == 1 (self only; expands ~ in path)"]
    - [resolve_lt_absolute,  "Path.resolve.__qualname__.__len__.__lt__",   [13],                true,  "len('Path.resolve') < len('Path.absolute') (12 < 13)"]

# ---------------------------------------------------------------------------
# pathlib.Path.is_mount, samefile, hardlink_to qualnames and co_argcounts
# is_mount: 'Path.is_mount' (13 chars); co_argcount == 1 (self only).
# samefile: 'Path.samefile' (13 chars); co_argcount == 2 (self, other_path).
# hardlink_to: 'Path.hardlink_to' (16 chars); co_argcount == 2 (self, target).
# All three are defined on Path (use 'Path.' prefix).
# ---------------------------------------------------------------------------

table pathlib_extra115.Path_is_mount_samefile_hardlink_qualnames:
  description: "pathlib.Path is_mount/samefile/hardlink_to __qualname__: is_mount='Path.is_mount'(13), samefile='Path.samefile'(13), hardlink_to='Path.hardlink_to'(16); co_argcounts: is_mount=1, samefile=2, hardlink_to=2"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn115b

  columns: [id, function, args, expected, description]
  rows:
    - [is_mount_qn_eq,      "Path.is_mount.__qualname__.__eq__",           ["Path.is_mount"],     true,  "pathlib.Path.is_mount.__qualname__ == 'Path.is_mount' (defined on Path)"]
    - [is_mount_qn_len,     "Path.is_mount.__qualname__.__len__",          [],                    13,    "pathlib.Path.is_mount.__qualname__.__len__() == 13 ('Path.is_mount' has 13 chars)"]
    - [is_mount_argcount,   "Path.is_mount.__code__.co_argcount.__eq__",   [1],                   true,  "pathlib.Path.is_mount.__code__.co_argcount == 1 (self only; returns True if path is a mount point)"]
    - [samefile_qn_eq,      "Path.samefile.__qualname__.__eq__",           ["Path.samefile"],     true,  "pathlib.Path.samefile.__qualname__ == 'Path.samefile' (defined on Path)"]
    - [samefile_qn_len,     "Path.samefile.__qualname__.__len__",          [],                    13,    "pathlib.Path.samefile.__qualname__.__len__() == 13 ('Path.samefile' has 13 chars; same length as is_mount)"]
    - [samefile_argcount,   "Path.samefile.__code__.co_argcount.__eq__",   [2],                   true,  "pathlib.Path.samefile.__code__.co_argcount == 2 (self, other_path; compares inode/device)"]
    - [hardlink_qn_eq,      "Path.hardlink_to.__qualname__.__eq__",        ["Path.hardlink_to"],  true,  "pathlib.Path.hardlink_to.__qualname__ == 'Path.hardlink_to' (defined on Path; available Python 3.10+)"]
    - [hardlink_qn_len,     "Path.hardlink_to.__qualname__.__len__",       [],                    16,    "pathlib.Path.hardlink_to.__qualname__.__len__() == 16 ('Path.hardlink_to' has 16 chars; longest in this group)"]
    - [hardlink_argcount,   "Path.hardlink_to.__code__.co_argcount.__eq__",[2],                   true,  "pathlib.Path.hardlink_to.__code__.co_argcount == 2 (self, target; creates a hard link)"]
    - [is_mount_eq_samefile_len, "Path.is_mount.__qualname__.__len__.__eq__", [13],               true,  "len('Path.is_mount') == len('Path.samefile') == 13 (both share identical qualname length)"]

# ---------------------------------------------------------------------------
# pathlib.Path.relative_to and is_relative_to qualnames
# Both are defined on PurePath (use 'PurePath.' prefix).
# relative_to: 'PurePath.relative_to' (20 chars); co_argcount == 2.
# is_relative_to: 'PurePath.is_relative_to' (23 chars); co_argcount == 2.
# ---------------------------------------------------------------------------

table pathlib_extra115.Path_relative_to_qualnames:
  description: "pathlib.Path.relative_to and is_relative_to __qualname__: relative_to='PurePath.relative_to'(20), is_relative_to='PurePath.is_relative_to'(23); both defined on PurePath"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn115c

  columns: [id, function, args, expected, description]
  rows:
    - [relto_qn_eq,        "Path.relative_to.__qualname__.__eq__",       ["PurePath.relative_to"],    true,  "pathlib.Path.relative_to.__qualname__ == 'PurePath.relative_to' (defined on PurePath, not Path)"]
    - [relto_qn_len,       "Path.relative_to.__qualname__.__len__",      [],                          20,    "pathlib.Path.relative_to.__qualname__.__len__() == 20 ('PurePath.relative_to' has 20 chars)"]
    - [relto_argcount,     "Path.relative_to.__code__.co_argcount.__eq__",[2],                        true,  "pathlib.Path.relative_to.__code__.co_argcount == 2 (self, other)"]
    - [isrelto_qn_eq,      "Path.is_relative_to.__qualname__.__eq__",    ["PurePath.is_relative_to"], true,  "pathlib.Path.is_relative_to.__qualname__ == 'PurePath.is_relative_to' (defined on PurePath)"]
    - [isrelto_qn_len,     "Path.is_relative_to.__qualname__.__len__",   [],                          23,    "pathlib.Path.is_relative_to.__qualname__.__len__() == 23 ('PurePath.is_relative_to' has 23 chars; longest PurePath qualname)"]
    - [isrelto_argcount,   "Path.is_relative_to.__code__.co_argcount.__eq__",[2],                     true,  "pathlib.Path.is_relative_to.__code__.co_argcount == 2 (self, other)"]
    - [relto_ne_path_prefix,  "Path.relative_to.__qualname__.__eq__",    ["Path.relative_to"],        false, "pathlib.Path.relative_to.__qualname__ != 'Path.relative_to' (qualname uses 'PurePath.' prefix because it is defined on PurePath)"]
    - [isrelto_longer_relto, "Path.is_relative_to.__qualname__.__len__.__gt__", [20],                 true,  "len('PurePath.is_relative_to') > len('PurePath.relative_to') (23 > 20)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra115.Path.resolve_qualname:
  description: "pathlib.Path.resolve.__qualname__ == 'Path.resolve' (length 12; resolve is defined on Path with co_argcount == 2 for self and strict; contrast with absolute.__qualname__ == 'Path.absolute' at length 13)"
  category: qualnames
  kind: python_call_eq
  function: "Path.resolve.__qualname__.__eq__"
  args: ["Path.resolve"]
  expected: true

invariant pathlib_extra115.Path.expanduser_qualname_len:
  description: "pathlib.Path.expanduser.__qualname__.__len__() == 15 ('Path.expanduser' has 15 characters; co_argcount == 1 since it takes only self; expands a leading ~ or ~user component using the home directory)"
  category: qualnames
  kind: python_call_eq
  function: "Path.expanduser.__qualname__.__len__"
  args: []
  expected: 15

invariant pathlib_extra115.Path.hardlink_to_qualname_len:
  description: "pathlib.Path.hardlink_to.__qualname__.__len__() == 16 ('Path.hardlink_to' has 16 characters; it is defined on Path so uses 'Path.' prefix; co_argcount == 2 for self and target)"
  category: qualnames
  kind: python_call_eq
  function: "Path.hardlink_to.__qualname__.__len__"
  args: []
  expected: 16

invariant pathlib_extra115.Path.relative_to_purepath_qualname:
  description: "pathlib.Path.relative_to.__qualname__ == 'PurePath.relative_to' (length 20; relative_to is inherited from PurePath so its qualname carries the 'PurePath.' prefix, just as joinpath/with_name/with_suffix do; contrast with resolve/samefile which use 'Path.' prefix)"
  category: qualnames
  kind: python_call_eq
  function: "Path.relative_to.__qualname__.__eq__"
  args: ["PurePath.relative_to"]
  expected: true

invariant pathlib_extra115.Path.is_relative_to_qualname_len:
  description: "pathlib.Path.is_relative_to.__qualname__.__len__() == 23 ('PurePath.is_relative_to' has 23 characters; it is the longest qualname among all pathlib methods examined; co_argcount == 2 for self and other)"
  category: qualnames
  kind: python_call_eq
  function: "Path.is_relative_to.__qualname__.__len__"
  args: []
  expected: 23
