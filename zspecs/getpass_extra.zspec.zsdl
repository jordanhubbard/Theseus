spec: getpass_extra
version: ">=3.3"
backend: python_module(getpass)

docs: https://docs.python.org/3/library/getpass.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/getpass.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "getpass source: terminal/tty interaction internals"
  notes:
    - "This spec covers getpass behaviors not present in getpass.zspec.zsdl."
    - "On POSIX systems, getpass.getpass is bound to unix_getpass, so getpass.getpass.__name__ == 'unix_getpass'."
    - "getpass.getpass.__module__ == 'getpass' — the underlying function is defined in the getpass module."
    - "GetPassWarning.__name__ == 'GetPassWarning' and __module__ == 'getpass' confirm class identity."
    - "GetPassWarning.__bases__[0].__name__ == 'UserWarning' confirms the inheritance hierarchy."
    - "getuser() returns the current login name as a str; getuser().__class__.__name__ == 'str' confirms the return type."
    - "All expected values verified by running Python 3.14.3 getpass module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant getpass_extra.function_names.getuser_name:
  description: "getpass.getuser.__name__ == 'getuser'"
  category: function_names
  kind: python_call_eq
  function: getuser.__name__.__eq__
  args: ["getuser"]
  expected: true

invariant getpass_extra.function_names.getuser_module:
  description: "getpass.getuser.__module__ == 'getpass'"
  category: function_names
  kind: python_call_eq
  function: getuser.__module__.__eq__
  args: ["getpass"]
  expected: true

# ---------------------------------------------------------------------------
# getpass function — module membership
#
# On POSIX systems the module-level 'getpass' name is bound to unix_getpass,
# so __name__ reflects the underlying function name ('unix_getpass'), not the
# alias. However __module__ is always 'getpass'.
# ---------------------------------------------------------------------------

invariant getpass_extra.function_names.getpass_module:
  description: "getpass.getpass.__module__ == 'getpass'"
  category: function_names
  kind: python_call_eq
  function: getpass.__module__.__eq__
  args: ["getpass"]
  expected: true

# ---------------------------------------------------------------------------
# GetPassWarning — class name and inheritance
# ---------------------------------------------------------------------------

invariant getpass_extra.GetPassWarning.name:
  description: "getpass.GetPassWarning.__name__ == 'GetPassWarning'"
  category: GetPassWarning
  kind: python_call_eq
  function: GetPassWarning.__name__.__eq__
  args: ["GetPassWarning"]
  expected: true

invariant getpass_extra.GetPassWarning.module:
  description: "getpass.GetPassWarning.__module__ == 'getpass'"
  category: GetPassWarning
  kind: python_call_eq
  function: GetPassWarning.__module__.__eq__
  args: ["getpass"]
  expected: true

invariant getpass_extra.GetPassWarning.base:
  description: "getpass.GetPassWarning.__bases__[0].__name__ == 'UserWarning'"
  category: GetPassWarning
  kind: python_call_eq
  function: GetPassWarning.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "UserWarning"

# ---------------------------------------------------------------------------
# getuser() — return type is str
#
# getuser() returns the login name of the current user as a plain Python str.
# The return type is confirmed via __class__.__name__.
# ---------------------------------------------------------------------------

invariant getpass_extra.getuser.returns_str:
  description: "getpass.getuser().__class__.__name__ == 'str' — getuser() returns a str"
  category: getuser
  kind: python_call_eq
  function: getuser
  args: []
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true
