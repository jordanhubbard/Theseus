spec: luhn
version: ">=1.0.0"
backend: node(luhn)

docs: https://www.npmjs.com/package/luhn

provenance:
  derived_from:
    - "luhn README — https://www.npmjs.com/package/luhn"
    - "Test vectors verified with luhn via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "luhn source"
  notes:
    - "luhn is an npm package. Install: npm install luhn"
    - "luhn.validate(str) checks a numeric string using the Luhn algorithm."
    - "Used for credit card number validation."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table luhn.validate:
  kind: node_module_call_eq
  function: validate
  category: validate
  id_prefix: luhnv

  columns: [id, args, expected]
  rows:
    - [visa_test,   ["4532015112830366"], true]
    - [mc_test,     ["5425233430109903"], true]
    - [amex_test,   ["4111111111111111"], true]
    - [invalid,     ["1234567890123456"], false]
