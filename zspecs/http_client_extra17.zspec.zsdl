spec: http_client_extra17
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
    - "http_client_extra16.zspec.zsdl — covers __module__.__len__()==11 for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException; __name__.__len__() for all four classes; HTTPConnection.__qualname__.__len__()==14; parse_headers/__name__/__qualname__/__name__.__len__."
    - "http_client_extra15.zspec.zsdl — covers HTTPConnection.__init__.__name__, HTTPResponse.__bases__[0].__name__, NotConnected/InvalidURL __name__/__bases__[0].__name__, UnknownProtocol/__name__, RemoteDisconnected/__name__/__bases__[0].__name__, IncompleteRead/__name__."
    - "http_client_extra14.zspec.zsdl — covers HTTPConnection/__qualname__/__module__, HTTPSConnection/__qualname__/__module__, HTTP_PORT/HTTPS_PORT constants, BadStatusLine/CannotSendRequest exception attributes."
    - "http_client_extra10.zspec.zsdl — covers __qualname__.__len__() for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException/NotConnected and __module__.__len__()==11."
    - "http_client_extra9.zspec.zsdl — covers __name__.__len__() for several classes."
  notes:
    - "This spec extends http_client_extra16.zspec.zsdl."
    - "Prior specs covered: HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException __name__/__module__/__qualname__/__bases__, HTTP_PORT/HTTPS_PORT, status codes, __init__.__name__ for HTTPConnection, exception class __name__/__bases__, parse_headers/__name__/__qualname__, __module__.__len__()==11 for four classes, __name__.__len__() for four classes, HTTPConnection.__qualname__.__len__()==14."
    - "This spec covers: __qualname__.__len__() for HTTPSConnection/HTTPResponse/HTTPException (cross-namespace anchors from extra17); __name__.__len__() for HTTPConnection method names (request/connect/close/send); __qualname__.__len__() for HTTPConnection.request/connect/close/send; __name__.__len__() for HTTPResponse methods (read/close/geturl/info); parse_headers.__module__.__len__() == 11."
    - "http.client.HTTPSConnection.__qualname__ == 'HTTPSConnection' — len 15. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.__qualname__ == 'HTTPResponse' — len 12. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPException.__qualname__ == 'HTTPException' — len 13. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.request.__qualname__ == 'HTTPConnection.request' — len 22. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.connect.__qualname__ == 'HTTPConnection.connect' — len 22. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.close.__qualname__ == 'HTTPConnection.close' — len 20. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.send.__qualname__ == 'HTTPConnection.send' — len 19. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.request.__name__ == 'request' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.connect.__name__ == 'connect' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.close.__name__ == 'close' — len 5. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.send.__name__ == 'send' — len 4. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.read.__name__ == 'read' — len 4. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.close.__name__ == 'close' — len 5. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.geturl.__name__ == 'geturl' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.info.__name__ == 'info' — len 4. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.parse_headers.__module__ == 'http.client' — len 11. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for HTTPSConnection, HTTPResponse, HTTPException
#
# http_client_extra10 covers __qualname__.__len__() for HTTPConnection (==14).
# http_client_extra16 re-anchors HTTPConnection.__qualname__.__len__() from
# extra16 namespace. No prior spec covers __qualname__.__len__() for
# HTTPSConnection, HTTPResponse, or HTTPException from the extra17 namespace.
# HTTPSConnection: 15, HTTPResponse: 12, HTTPException: 13.
# ---------------------------------------------------------------------------

table http_client_extra17.class_qualname_lengths:
  description: "len(__qualname__) for HTTPSConnection (15), HTTPResponse (12), HTTPException (13) — cross-namespace anchors from extra17"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: cql17

  columns: [id, function, args, expected]
  rows:
    - [HTTPSConnection, HTTPSConnection.__qualname__.__len__, [], 15]
    - [HTTPResponse,    HTTPResponse.__qualname__.__len__,    [], 12]
    - [HTTPException,   HTTPException.__qualname__.__len__,   [], 13]

# ---------------------------------------------------------------------------
# __name__.__len__() for HTTPConnection method names: request, connect, close, send
#
# No prior spec checks __name__.__len__() for any HTTPConnection method.
# Method names: request=7, connect=7, close=5, send=4.
# ---------------------------------------------------------------------------

invariant http_client_extra17.HTTPConnection.request.name_len:
  description: "len(http.client.HTTPConnection.request.__name__) == 7 — len('request') == 7"
  category: method_names
  kind: python_call_eq
  function: HTTPConnection.request.__name__.__len__
  args: []
  expected: 7

invariant http_client_extra17.HTTPConnection.connect.name_len:
  description: "len(http.client.HTTPConnection.connect.__name__) == 7 — len('connect') == 7"
  category: method_names
  kind: python_call_eq
  function: HTTPConnection.connect.__name__.__len__
  args: []
  expected: 7

table http_client_extra17.connection_method_name_lengths:
  description: "len(__name__) for HTTPConnection.close (5) and HTTPConnection.send (4)"
  kind: python_call_eq
  category: method_names
  id_prefix: cmnl17

  columns: [id, function, args, expected]
  rows:
    - [close, HTTPConnection.close.__name__.__len__, [], 5]
    - [send,  HTTPConnection.send.__name__.__len__,  [], 4]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for HTTPConnection.request, connect, close, send
#
# No prior spec checks __qualname__.__len__() for any HTTPConnection method.
# Qualname format is 'HTTPConnection.<method>':
#   request='HTTPConnection.request' len 22
#   connect='HTTPConnection.connect' len 22
#   close='HTTPConnection.close'   len 20
#   send='HTTPConnection.send'     len 19
# ---------------------------------------------------------------------------

table http_client_extra17.connection_method_qualname_lengths:
  description: "len(__qualname__) for HTTPConnection methods request/connect/close/send — novel invariants"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: cmql17

  columns: [id, function, args, expected]
  rows:
    - [request, HTTPConnection.request.__qualname__.__len__, [], 22]
    - [connect, HTTPConnection.connect.__qualname__.__len__, [], 22]
    - [close,   HTTPConnection.close.__qualname__.__len__,   [], 20]
    - [send,    HTTPConnection.send.__qualname__.__len__,    [], 19]

# ---------------------------------------------------------------------------
# __name__.__len__() for HTTPResponse methods: read, close, geturl, info
#
# No prior spec checks __name__.__len__() for any HTTPResponse method.
# read=4, close=5, geturl=6, info=4.
# ---------------------------------------------------------------------------

invariant http_client_extra17.HTTPResponse.read.name_len:
  description: "len(http.client.HTTPResponse.read.__name__) == 4 — len('read') == 4"
  category: method_names
  kind: python_call_eq
  function: HTTPResponse.read.__name__.__len__
  args: []
  expected: 4

invariant http_client_extra17.HTTPResponse.geturl.name_len:
  description: "len(http.client.HTTPResponse.geturl.__name__) == 6 — len('geturl') == 6"
  category: method_names
  kind: python_call_eq
  function: HTTPResponse.geturl.__name__.__len__
  args: []
  expected: 6

table http_client_extra17.response_method_name_lengths:
  description: "len(__name__) for HTTPResponse.close (5) and HTTPResponse.info (4)"
  kind: python_call_eq
  category: method_names
  id_prefix: rmnl17

  columns: [id, function, args, expected]
  rows:
    - [close, HTTPResponse.close.__name__.__len__, [], 5]
    - [info,  HTTPResponse.info.__name__.__len__,  [], 4]

# ---------------------------------------------------------------------------
# parse_headers.__module__.__len__()
#
# http_client_extra16 covers parse_headers.__name__.__len__()==13 and
# parse_headers.__qualname__.__eq__('parse_headers').
# No prior spec checks parse_headers.__module__.__len__().
# parse_headers.__module__ == 'http.client' (len 11).
# ---------------------------------------------------------------------------

invariant http_client_extra17.parse_headers.module_len:
  description: "len(http.client.parse_headers.__module__) == 11 — 'http.client' has 11 characters; novel invariant"
  category: function_module
  kind: python_call_eq
  function: parse_headers.__module__.__len__
  args: []
  expected: 11
