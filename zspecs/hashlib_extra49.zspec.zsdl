spec: hashlib_extra49
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra48.zspec.zsdl — covers blake2b/blake2s __name__.__eq__ string eq and __mro__ entry __name__.__eq__."
    - "hashlib_extra47.zspec.zsdl — covers sha3_512.__module__.__eq__('_hashlib') and sha3_512.__module__.__len__()==8."
    - "hashlib_extra44.zspec.zsdl — covers blake2b/blake2s __class__.__name__.__eq__('type')."
    - "hashlib_extra18.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/new __name__.__eq__ and __qualname__.__eq__ string values."
    - "hashlib_extra6.zspec.zsdl — covers blake2b/blake2s __module__.__eq__('_blake2')."
  notes:
    - "This spec extends hashlib through hashlib_extra48; it does NOT duplicate invariants present in those files."
    - "Coverage gap: No prior hashlib spec checks __class__.__name__.__eq__ for sha256, md5, sha1, pbkdf2_hmac, new, sha3_256 as module-level callables. hashlib_extra44 covers blake2b/blake2s __class__.__name__.__eq__('type') only. The __class__.__name__ axis identifies whether each callable is a C builtin function, a Python function, or a type, providing structural regression vectors independent of __name__/__qualname__/__module__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method'. sha256 is a C-level constructor exposed as a builtin_function_or_method. No prior spec checks sha256.__class__.__name__.__eq__('builtin_function_or_method'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.md5.__class__.__name__ == 'builtin_function_or_method'. Same C-level calling convention as sha256. No prior spec checks md5.__class__.__name__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__class__.__name__ == 'builtin_function_or_method'. Same C-level calling convention as sha256 and md5. No prior spec checks sha1.__class__.__name__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__class__.__name__ == 'type'. blake2b is a C extension type, not a builtin function. hashlib_extra44 already covers this invariant — it is listed in not_derived_from to prevent duplication."
    - "hashlib.blake2s.__class__.__name__ == 'type'. Same as blake2b. hashlib_extra44 already covers this — listed in not_derived_from."
    - "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'. pbkdf2_hmac is a C builtin function in the _hashlib extension. No prior spec checks pbkdf2_hmac.__class__.__name__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.new.__class__.__name__ == 'function'. new is a Python-level wrapper function, not a C builtin. No prior spec checks new.__class__.__name__.__eq__('function'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__class__.__name__ == 'builtin_function_or_method'. sha3_256 is exposed as a C-level builtin_function_or_method (openssl-backed). No prior spec checks sha3_256.__class__.__name__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib module-level callable __class__.__name__.__eq__ string values
#
# hashlib_extra44 covers blake2b/blake2s __class__.__name__.__eq__('type').
# No prior spec checks __class__.__name__.__eq__ for sha256, md5, sha1,
# pbkdf2_hmac, sha3_256 (all 'builtin_function_or_method') or for new ('function').
# This axis distinguishes C builtins from Python functions from C extension types.
# blake2b and blake2s are excluded from this table (covered by extra44).
# ---------------------------------------------------------------------------

table hashlib_extra49.callable_class_names:
  description: "hashlib sha256/md5/sha1/pbkdf2_hmac/sha3_256 __class__.__name__.__eq__('builtin_function_or_method') and new __class__.__name__.__eq__('function') — novel: extra44 covers blake2b/blake2s only; no prior spec checks __class__.__name__.__eq__ for any of these callables"
  kind: python_call_eq
  category: type_structure
  id_prefix: hcn49

  columns: [id, function, args, expected]
  rows:
    - [sha256_class_name_eq,      sha256.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [md5_class_name_eq,         md5.__class__.__name__.__eq__,         ["builtin_function_or_method"], true]
    - [sha1_class_name_eq,        sha1.__class__.__name__.__eq__,        ["builtin_function_or_method"], true]
    - [pbkdf2_hmac_class_name_eq, pbkdf2_hmac.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [sha3_256_class_name_eq,    sha3_256.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [new_class_name_eq,         new.__class__.__name__.__eq__,         ["function"],                   true]
