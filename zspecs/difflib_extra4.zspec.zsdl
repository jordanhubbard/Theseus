spec: difflib_extra4
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec extends difflib.zspec.zsdl and prior extras."
    - "difflib.zspec.zsdl covers: SequenceMatcher ratio/find_longest/get_matching_blocks/get_opcodes tables; get_close_matches table; IS_CHARACTER_JUNK/IS_LINE_JUNK tables; Differ/__name__; HtmlDiff/__name__; function names."
    - "difflib_extra covers: SequenceMatcher.__name__/__module__; Differ/__name__; HtmlDiff/__name__; unified_diff/__name__; context_diff/__name__; ndiff/__name__; get_close_matches/__name__; behavioral get_close_matches vectors."
    - "difflib_extra2 covers: SequenceMatcher/Differ/HtmlDiff __name__ table; base class checks (all subclass object); function_modules table (unified_diff/ndiff/context_diff/get_close_matches); unified_diff first line; ndiff prefix; IS_LINE_JUNK/__name__; IS_CHARACTER_JUNK/__name__; SequenceMatcher.ratio_identical."
    - "difflib_extra3 covers: __qualname__ for SequenceMatcher/Differ/HtmlDiff/ndiff/unified_diff/context_diff/get_close_matches/restore; __module__ standalone for SequenceMatcher and get_close_matches; get_close_matches('appel',['ape','apple','peach','puppy'])."
    - "This spec adds: SequenceMatcher/__name__/__module__/__qualname__ as extra4 anchors; Differ/__name__/__qualname__ as extra4 anchors; HtmlDiff/__name__/__qualname__ as extra4 anchors."
    - "difflib.SequenceMatcher.__module__ == 'difflib' — covered in difflib_extra and difflib_extra3; added here as extra4 anchor."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SequenceMatcher — name, module, qualname anchors in extra4 namespace
# ---------------------------------------------------------------------------

invariant difflib_extra4.SequenceMatcher.name:
  description: "difflib.SequenceMatcher.__name__ == 'SequenceMatcher'"
  category: class_identity
  kind: python_call_eq
  function: SequenceMatcher.__name__.__eq__
  args: ["SequenceMatcher"]
  expected: true

invariant difflib_extra4.SequenceMatcher.module:
  description: "difflib.SequenceMatcher.__module__ == 'difflib'"
  category: class_identity
  kind: python_call_eq
  function: SequenceMatcher.__module__.__eq__
  args: ["difflib"]
  expected: true

invariant difflib_extra4.SequenceMatcher.qualname:
  description: "difflib.SequenceMatcher.__qualname__ == 'SequenceMatcher'"
  category: class_identity
  kind: python_call_eq
  function: SequenceMatcher.__qualname__.__eq__
  args: ["SequenceMatcher"]
  expected: true

# ---------------------------------------------------------------------------
# Differ — name, qualname anchors in extra4 namespace
# ---------------------------------------------------------------------------

invariant difflib_extra4.Differ.name:
  description: "difflib.Differ.__name__ == 'Differ'"
  category: class_identity
  kind: python_call_eq
  function: Differ.__name__.__eq__
  args: ["Differ"]
  expected: true

invariant difflib_extra4.Differ.qualname:
  description: "difflib.Differ.__qualname__ == 'Differ'"
  category: class_identity
  kind: python_call_eq
  function: Differ.__qualname__.__eq__
  args: ["Differ"]
  expected: true

# ---------------------------------------------------------------------------
# HtmlDiff — name, qualname anchors in extra4 namespace
# ---------------------------------------------------------------------------

invariant difflib_extra4.HtmlDiff.name:
  description: "difflib.HtmlDiff.__name__ == 'HtmlDiff'"
  category: class_identity
  kind: python_call_eq
  function: HtmlDiff.__name__.__eq__
  args: ["HtmlDiff"]
  expected: true

invariant difflib_extra4.HtmlDiff.qualname:
  description: "difflib.HtmlDiff.__qualname__ == 'HtmlDiff'"
  category: class_identity
  kind: python_call_eq
  function: HtmlDiff.__qualname__.__eq__
  args: ["HtmlDiff"]
  expected: true
