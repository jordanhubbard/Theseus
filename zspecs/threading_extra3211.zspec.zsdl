spec: th3211
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 661 (th3211): __and__, __or__, __xor__ dict-presence checks for threading types."
    - "Theme: __and__, __or__, __xor__ dict-presence (bitwise logical operators)."
    - "All values False — these types have no bitwise logical protocol."
    - "None of the threading types define __and__, __or__, or __xor__ in their own __dict__."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier, and threading.local are Python-level classes."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3211.and_:
  description: "threading types __and__ dict-presence checks; wave 661"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3211
  columns: [id, function, args, expected]
  rows:
    - ["th3211001", operator.contains, [threading.Thread.__dict__,           "__and__"], false]
    - ["th3211002", operator.contains, [type(threading.Lock()).__dict__,     "__and__"], false]
    - ["th3211003", operator.contains, [type(threading.RLock()).__dict__,    "__and__"], false]
    - ["th3211004", operator.contains, [threading.Event.__dict__,            "__and__"], false]
    - ["th3211005", operator.contains, [threading.Condition.__dict__,        "__and__"], false]
    - ["th3211006", operator.contains, [threading.Semaphore.__dict__,        "__and__"], false]
    - ["th3211007", operator.contains, [threading.BoundedSemaphore.__dict__, "__and__"], false]
    - ["th3211008", operator.contains, [threading.Timer.__dict__,            "__and__"], false]
    - ["th3211009", operator.contains, [threading.Barrier.__dict__,          "__and__"], false]
    - ["th3211010", operator.contains, [threading.local.__dict__,            "__and__"], false]

