spec: threading_extra115
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra114.zspec.zsdl."
    - "This spec covers: threading.Thread method code attributes — start/run/join/is_alive/__init__ qualnames and co_argcount values; Thread class name/module/qualname; property fget qualnames; wave 265."
    - "threading.Thread.start.__qualname__ == 'Thread.start' (len 12). Verified with Python 3.14.3."
    - "threading.Thread.run.__qualname__ == 'Thread.run' (len 10). Verified with Python 3.14.3."
    - "threading.Thread.join.__qualname__ == 'Thread.join' (len 11). Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__qualname__ == 'Thread.is_alive' (len 15). Verified with Python 3.14.3."
    - "threading.Thread.__init__.__qualname__ == 'Thread.__init__' (len 15). Verified with Python 3.14.3."
    - "threading.Thread.start.__code__.co_argcount == 1 (self only). Verified with Python 3.14.3."
    - "threading.Thread.run.__code__.co_argcount == 1 (self only). Verified with Python 3.14.3."
    - "threading.Thread.join.__code__.co_argcount == 2 (self + timeout). Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__code__.co_argcount == 1 (self only). Verified with Python 3.14.3."
    - "threading.Thread.__init__.__code__.co_argcount == 6 (self+group+target+name+args+kwargs; daemon via kwonly). Verified with Python 3.14.3."
    - "threading.Thread.__name__ == 'Thread' (len 6). Verified with Python 3.14.3."
    - "threading.Thread.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Thread.daemon.fget.__qualname__ == 'Thread.daemon'. Verified with Python 3.14.3."
    - "threading.Thread.name.fget.__qualname__ == 'Thread.name'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread method __qualname__ attributes
#
# Wave 265 theme: threading.Thread is a pure-Python class in Lib/threading.py.
# Its methods follow the 'Thread.<method>' qualname pattern. Lengths:
# Thread.start => 'Thread.start' (12), Thread.run => 'Thread.run' (10),
# Thread.join => 'Thread.join' (11), Thread.is_alive => 'Thread.is_alive' (15),
# Thread.__init__ => 'Thread.__init__' (15). is_alive and __init__ share the
# same qualname length of 15. The co_name values strip the 'Thread.' prefix:
# start, run, join, is_alive, __init__.
#
# threading.Thread.start.__qualname__ == 'Thread.start'      (len 12)
# threading.Thread.run.__qualname__ == 'Thread.run'          (len 10)
# threading.Thread.join.__qualname__ == 'Thread.join'        (len 11)
# threading.Thread.is_alive.__qualname__ == 'Thread.is_alive' (len 15)
# threading.Thread.__init__.__qualname__ == 'Thread.__init__' (len 15)
#
# New to extra115.
# ---------------------------------------------------------------------------

table threading_extra115.thread_method_qualnames:
  description: "threading.Thread method qualnames: start='Thread.start'(12), run='Thread.run'(10), join='Thread.join'(11), is_alive='Thread.is_alive'(15), __init__='Thread.__init__'(15); is_alive and __init__ share len 15; wave 265; new to extra115"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtmq115

  columns: [id, function, args, expected, description]
  rows:
    - [thread_start_qualname,
       "Thread.start.__qualname__.__eq__",
       ["Thread.start"],
       true,
       "threading.Thread.start.__qualname__.__eq__('Thread.start') == True — Thread.start is defined inside the Thread class; its qualname follows 'ClassName.method' pattern; str.__eq__('Thread.start') returns True; new to extra115"]
    - [thread_start_qualname_len,
       "Thread.start.__qualname__.__len__",
       [],
       12,
       "threading.Thread.start.__qualname__.__len__() == 12 — 'Thread.start' has 12 characters: T-h-r-e-a-d(6) + dot(1) + s-t-a-r-t(5); str.__len__() returns 12; new to extra115"]
    - [thread_run_qualname,
       "Thread.run.__qualname__.__eq__",
       ["Thread.run"],
       true,
       "threading.Thread.run.__qualname__.__eq__('Thread.run') == True — Thread.run is the method subclasses override; its qualname is 'Thread.run'; str.__eq__('Thread.run') returns True; new to extra115"]
    - [thread_run_qualname_len,
       "Thread.run.__qualname__.__len__",
       [],
       10,
       "threading.Thread.run.__qualname__.__len__() == 10 — 'Thread.run' has 10 characters: T-h-r-e-a-d(6) + dot(1) + r-u-n(3); shortest of the five method qualnames; str.__len__() returns 10; new to extra115"]
    - [thread_join_qualname,
       "Thread.join.__qualname__.__eq__",
       ["Thread.join"],
       true,
       "threading.Thread.join.__qualname__.__eq__('Thread.join') == True — Thread.join waits for the thread to finish; its qualname is 'Thread.join'; str.__eq__('Thread.join') returns True; new to extra115"]
    - [thread_join_qualname_len,
       "Thread.join.__qualname__.__len__",
       [],
       11,
       "threading.Thread.join.__qualname__.__len__() == 11 — 'Thread.join' has 11 characters: T-h-r-e-a-d(6) + dot(1) + j-o-i-n(4); str.__len__() returns 11; new to extra115"]
    - [thread_is_alive_qualname,
       "Thread.is_alive.__qualname__.__eq__",
       ["Thread.is_alive"],
       true,
       "threading.Thread.is_alive.__qualname__.__eq__('Thread.is_alive') == True — Thread.is_alive returns True if the thread is running; its qualname is 'Thread.is_alive'; str.__eq__('Thread.is_alive') returns True; new to extra115"]
    - [thread_is_alive_qualname_len,
       "Thread.is_alive.__qualname__.__len__",
       [],
       15,
       "threading.Thread.is_alive.__qualname__.__len__() == 15 — 'Thread.is_alive' has 15 chars: T-h-r-e-a-d(6)+dot(1)+i-s-_-a-l-i-v-e(8); same length as Thread.__init__; str.__len__() returns 15; new to extra115"]
    - [thread_init_qualname,
       "Thread.__init__.__qualname__.__eq__",
       ["Thread.__init__"],
       true,
       "threading.Thread.__init__.__qualname__.__eq__('Thread.__init__') == True — Thread.__init__ is the constructor; its qualname is 'Thread.__init__'; str.__eq__('Thread.__init__') returns True; new to extra115"]
    - [thread_init_qualname_len,
       "Thread.__init__.__qualname__.__len__",
       [],
       15,
       "threading.Thread.__init__.__qualname__.__len__() == 15 — 'Thread.__init__' has 15 chars: T-h-r-e-a-d(6)+dot(1)+__init__(8); same length as Thread.is_alive; str.__len__() returns 15; new to extra115"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread method co_argcount values
#
# Wave 265 theme: threading.Thread methods have varying co_argcount values.
# start, run, and is_alive each take only self (co_argcount == 1). join takes
# self and an optional timeout parameter (co_argcount == 2). __init__ takes
# self plus group, target, name, args, and kwargs (co_argcount == 6). The
# co_name for each method matches the short name (without 'Thread.' prefix):
# 'start', 'run', 'join', 'is_alive', '__init__'.
#
# Thread.start.__code__.co_argcount == 1
# Thread.run.__code__.co_argcount == 1
# Thread.join.__code__.co_argcount == 2
# Thread.is_alive.__code__.co_argcount == 1
# Thread.__init__.__code__.co_argcount == 6
#
# New to extra115.
# ---------------------------------------------------------------------------

table threading_extra115.thread_method_co_argcount:
  description: "threading.Thread method co_argcount: start=1, run=1, join=2, is_alive=1, __init__=6; join has timeout param; __init__ has group/target/name/args/kwargs; wave 265; new to extra115"
  kind: python_call_eq
  category: code_identity
  id_prefix: threadingtmc115

  columns: [id, function, args, expected, description]
  rows:
    - [thread_start_co_argcount,
       "Thread.start.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Thread.start.__code__.co_argcount.__eq__(1) == True — Thread.start(self) takes only self; no additional parameters; co_argcount is 1; int.__eq__(1) returns True; new to extra115"]
    - [thread_run_co_argcount,
       "Thread.run.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Thread.run.__code__.co_argcount.__eq__(1) == True — Thread.run(self) takes only self; subclasses override this to define thread behavior; co_argcount is 1; int.__eq__(1) returns True; new to extra115"]
    - [thread_join_co_argcount,
       "Thread.join.__code__.co_argcount.__eq__",
       [2],
       true,
       "threading.Thread.join.__code__.co_argcount.__eq__(2) == True — Thread.join(self, timeout=None) has 2 positional-or-keyword parameters: self and timeout; co_argcount is 2; int.__eq__(2) returns True; new to extra115"]
    - [thread_is_alive_co_argcount,
       "Thread.is_alive.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Thread.is_alive.__code__.co_argcount.__eq__(1) == True — Thread.is_alive(self) takes only self; returns True if thread is running; co_argcount is 1; int.__eq__(1) returns True; new to extra115"]
    - [thread_init_co_argcount,
       "Thread.__init__.__code__.co_argcount.__eq__",
       [6],
       true,
       "threading.Thread.__init__.__code__.co_argcount.__eq__(6) == True — Thread.__init__(self, group, target, name, args, kwargs) has 6 positional-or-keyword params; daemon is keyword-only (not counted in co_argcount); int.__eq__(6) returns True; new to extra115"]
    - [thread_start_co_name,
       "Thread.start.__code__.co_name.__eq__",
       ["start"],
       true,
       "threading.Thread.start.__code__.co_name.__eq__('start') == True — co_name is the function name from the def statement without the class prefix; str.__eq__('start') returns True; new to extra115"]
    - [thread_join_co_name,
       "Thread.join.__code__.co_name.__eq__",
       ["join"],
       true,
       "threading.Thread.join.__code__.co_name.__eq__('join') == True — co_name is the function name from the def statement; str.__eq__('join') returns True; new to extra115"]
    - [thread_is_alive_co_name,
       "Thread.is_alive.__code__.co_name.__eq__",
       ["is_alive"],
       true,
       "threading.Thread.is_alive.__code__.co_name.__eq__('is_alive') == True — co_name is 'is_alive' (with underscore); matches the def-statement name; str.__eq__('is_alive') returns True; new to extra115"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread class identity and property fget qualnames
#
# Wave 265 theme: threading.Thread is a pure-Python class with __name__
# 'Thread' (length 6) and __module__ 'threading'. Its __qualname__ equals
# its __name__ (top-level class). The daemon and name properties expose their
# getter via .fget; the fget qualnames follow 'Thread.daemon' and 'Thread.name'
# patterns. Thread.ident.fget.__qualname__ is 'Thread.ident'.
#
# threading.Thread.__name__ == 'Thread'     (len 6)
# threading.Thread.__module__ == 'threading'
# threading.Thread.__qualname__ == 'Thread'
# threading.Thread.daemon.fget.__qualname__ == 'Thread.daemon'
# threading.Thread.name.fget.__qualname__ == 'Thread.name'
# threading.Thread.ident.fget.__qualname__ == 'Thread.ident'
#
# New to extra115.
# ---------------------------------------------------------------------------

table threading_extra115.thread_class_identity:
  description: "threading.Thread class identity: __name__='Thread'(6), __module__='threading', __qualname__='Thread'; property fget qualnames: daemon='Thread.daemon', name='Thread.name', ident='Thread.ident'; wave 265; new to extra115"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingtci115

  columns: [id, function, args, expected, description]
  rows:
    - [thread_class_name,
       "Thread.__name__.__eq__",
       ["Thread"],
       true,
       "threading.Thread.__name__.__eq__('Thread') == True — threading.Thread is a pure-Python class in Lib/threading.py; its __name__ is 'Thread' (len 6); str.__eq__('Thread') returns True; new to extra115"]
    - [thread_class_name_len,
       "Thread.__name__.__len__",
       [],
       6,
       "threading.Thread.__name__.__len__() == 6 — 'Thread' has 6 characters: T-h-r-e-a-d; str.__len__() returns 6; new to extra115"]
    - [thread_class_module,
       "Thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — Thread is defined in the threading module; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra115"]
    - [thread_class_qualname,
       "Thread.__qualname__.__eq__",
       ["Thread"],
       true,
       "threading.Thread.__qualname__.__eq__('Thread') == True — Thread is a top-level class; __qualname__ equals __name__; str.__eq__('Thread') returns True; new to extra115"]
    - [thread_daemon_fget_qualname,
       "Thread.daemon.fget.__qualname__.__eq__",
       ["Thread.daemon"],
       true,
       "threading.Thread.daemon.fget.__qualname__.__eq__('Thread.daemon') == True — the daemon property getter has qualname 'Thread.daemon'; properties expose their getter via .fget; str.__eq__('Thread.daemon') returns True; new to extra115"]
    - [thread_name_fget_qualname,
       "Thread.name.fget.__qualname__.__eq__",
       ["Thread.name"],
       true,
       "threading.Thread.name.fget.__qualname__.__eq__('Thread.name') == True — the name property getter has qualname 'Thread.name'; str.__eq__('Thread.name') returns True; new to extra115"]
    - [thread_ident_fget_qualname,
       "Thread.ident.fget.__qualname__.__eq__",
       ["Thread.ident"],
       true,
       "threading.Thread.ident.fget.__qualname__.__eq__('Thread.ident') == True — the ident property getter has qualname 'Thread.ident'; str.__eq__('Thread.ident') returns True; new to extra115"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra115
# ---------------------------------------------------------------------------

invariant threading_extra115.thread_start_qualname:
  description: "threading.Thread.start.__qualname__ == 'Thread.start' — method qualname follows ClassName.method pattern; length 12; wave 265; new to extra115"
  kind: python_call_eq
  function: Thread.start.__qualname__.__eq__
  args: ["Thread.start"]
  expected: true

invariant threading_extra115.thread_run_qualname_len:
  description: "len(threading.Thread.run.__qualname__) == 10 — 'Thread.run' is the shortest of the five method qualnames; wave 265; new to extra115"
  kind: python_call_eq
  function: Thread.run.__qualname__.__len__
  args: []
  expected: 10

invariant threading_extra115.thread_join_co_argcount:
  description: "threading.Thread.join.__code__.co_argcount == 2 — join takes self and timeout; more args than start/run/is_alive (1); wave 265; new to extra115"
  kind: python_call_eq
  function: Thread.join.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant threading_extra115.thread_init_co_argcount:
  description: "threading.Thread.__init__.__code__.co_argcount == 6 — __init__ takes self+group+target+name+args+kwargs; most args of all Thread methods; wave 265; new to extra115"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_argcount.__eq__
  args: [6]
  expected: true

invariant threading_extra115.thread_class_name:
  description: "threading.Thread.__name__ == 'Thread' — pure-Python class at module scope; length 6; __module__ is 'threading'; wave 265; new to extra115"
  kind: python_call_eq
  function: Thread.__name__.__eq__
  args: ["Thread"]
  expected: true
