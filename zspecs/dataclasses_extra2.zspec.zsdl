spec: dataclasses_extra2
version: ">=3.7"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "Python dataclasses documentation — https://docs.python.org/3/library/dataclasses.html"
    - "PEP 557 — Data Classes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "Complements dataclasses.zspec.zsdl, dataclasses_extra.zspec.zsdl, and dataclasses_field.zspec.zsdl."
    - "dataclasses_extra.zspec.zsdl covers: function __name__ and __module__ checks, Field class module, is_dataclass true-case."
    - "This spec adds __name__ checks for FrozenInstanceError and KW_ONLY sentinel class."
    - "dataclasses.FrozenInstanceError.__name__ == 'FrozenInstanceError' — the exception class name."
    - "dataclasses.KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE' — internal sentinel class name."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks (additional set)
#
# Complements dataclasses_extra which covers dataclass, field, fields, asdict,
# astuple, make_dataclass, replace, is_dataclass. This table re-verifies the
# same set in a table format and adds FrozenInstanceError.
# ---------------------------------------------------------------------------

table dataclasses_extra2.function_names:
  description: "Public dataclasses functions have correct __name__ attributes"
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [field,          field.__name__.__eq__,          ["field"],          true]
    - [fields,         fields.__name__.__eq__,          ["fields"],         true]
    - [asdict,         asdict.__name__.__eq__,          ["asdict"],         true]
    - [astuple,        astuple.__name__.__eq__,         ["astuple"],        true]
    - [make_dataclass, make_dataclass.__name__.__eq__,  ["make_dataclass"], true]
    - [replace,        replace.__name__.__eq__,         ["replace"],        true]
    - [is_dataclass,   is_dataclass.__name__.__eq__,    ["is_dataclass"],   true]

# ---------------------------------------------------------------------------
# FrozenInstanceError — exception class name
#
# FrozenInstanceError is raised when attempting to set a field on a frozen
# dataclass. Its __name__ must equal 'FrozenInstanceError'.
# ---------------------------------------------------------------------------

invariant dataclasses_extra2.FrozenInstanceError.class_name:
  description: "dataclasses.FrozenInstanceError.__name__ == 'FrozenInstanceError'"
  category: exceptions
  kind: python_call_eq
  function: FrozenInstanceError.__name__.__eq__
  args: ["FrozenInstanceError"]
  expected: true

# ---------------------------------------------------------------------------
# KW_ONLY sentinel — internal class name
#
# dataclasses.KW_ONLY is a sentinel object that marks all following fields as
# keyword-only. Its __class__.__name__ is '_KW_ONLY_TYPE' in CPython.
# ---------------------------------------------------------------------------

invariant dataclasses_extra2.KW_ONLY.class_name:
  description: "dataclasses.KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE'"
  category: sentinels
  kind: python_call_eq
  function: KW_ONLY.__class__.__name__.__eq__
  args: ["_KW_ONLY_TYPE"]
  expected: true
