spec: argparse_extra3
version: ">=3.9"
backend: python_module(argparse)

docs: https://docs.python.org/3/library/argparse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/argparse.html — Python argparse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/argparse.py"
  notes:
    - "This spec extends prior argparse specs."
    - "Focus: class names and constants not yet covered."
    - "argparse.ArgumentParser.__name__ == 'ArgumentParser'."
    - "argparse.Namespace.__name__ == 'Namespace'."
    - "argparse.Action.__name__ == 'Action'."
    - "argparse.ArgumentError.__name__ == 'ArgumentError'."
    - "argparse.ArgumentTypeError.__name__ == 'ArgumentTypeError'."
    - "argparse.FileType.__name__ == 'FileType'."
    - "argparse.HelpFormatter.__name__ == 'HelpFormatter'."
    - "argparse.RawTextHelpFormatter.__name__ == 'RawTextHelpFormatter'."
    - "argparse.SUPPRESS == '==SUPPRESS=='."
    - "argparse.REMAINDER == 'A...'."
    - "argparse.ONE_OR_MORE == '+'."
    - "argparse.ZERO_OR_MORE == '*'."
    - "argparse.OPTIONAL == '?'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table argparse_extra3.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [ArgumentParser,      ArgumentParser.__name__.__eq__,      ["ArgumentParser"],      true]
    - [Namespace,           Namespace.__name__.__eq__,           ["Namespace"],           true]
    - [Action,              Action.__name__.__eq__,              ["Action"],              true]
    - [ArgumentError,       ArgumentError.__name__.__eq__,       ["ArgumentError"],       true]
    - [ArgumentTypeError,   ArgumentTypeError.__name__.__eq__,   ["ArgumentTypeError"],   true]
    - [FileType,            FileType.__name__.__eq__,            ["FileType"],            true]
    - [HelpFormatter,       HelpFormatter.__name__.__eq__,       ["HelpFormatter"],       true]
    - [RawTextHelpFormatter, RawTextHelpFormatter.__name__.__eq__, ["RawTextHelpFormatter"], true]

table argparse_extra3.nargs_constants:
  kind: python_call_eq
  category: constants
  id_prefix: nargs

  columns: [id, function, args, expected]
  rows:
    - [ONE_OR_MORE,  ONE_OR_MORE.__eq__,  ["+"],           true]
    - [ZERO_OR_MORE, ZERO_OR_MORE.__eq__, ["*"],           true]
    - [OPTIONAL,     OPTIONAL.__eq__,     ["?"],           true]
    - [REMAINDER,    REMAINDER.__eq__,    ["A..."],        true]
    - [SUPPRESS,     SUPPRESS.__eq__,     ["==SUPPRESS=="], true]

invariant argparse_extra3.ArgumentParser.module:
  description: "argparse.ArgumentParser.__module__ == 'argparse'"
  category: module
  kind: python_call_eq
  function: ArgumentParser.__module__.__eq__
  args: ["argparse"]
  expected: true

invariant argparse_extra3.Namespace.instance:
  description: "argparse.Namespace(x=1).__class__.__name__ == 'Namespace'"
  category: Namespace
  kind: python_call_eq
  function: Namespace
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Namespace"]
  expected: true

invariant argparse_extra3.ArgumentError.base:
  description: "argparse.ArgumentError.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: ArgumentError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant argparse_extra3.ArgumentTypeError.base:
  description: "argparse.ArgumentTypeError.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: ArgumentTypeError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant argparse_extra3.ArgumentParser.prog_default:
  description: "argparse.ArgumentParser().prog.__class__.__name__ == 'str'"
  category: ArgumentParser
  kind: python_call_eq
  function: ArgumentParser
  args: []
  method: prog.__class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true
