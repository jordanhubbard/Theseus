spec: schedule_rust
version: ">=3.9"
backend: rust_module(schedule_rust)

docs: https://schedule.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://schedule.readthedocs.io/en/stable/ — schedule documentation"
  not_derived_from:
    - "schedule source: schedule/__init__.py"
  notes:
    - "schedule provides job scheduling for Python."
    - "schedule.Scheduler is available."
    - "schedule.every(10).minutes — fluent API."
    - "schedule.__version__ is a non-empty string."
    - "schedule.Scheduler().__class__.__name__ == 'Scheduler'."
    - "Expose schedule_scheduler_name() -> str: schedule.Scheduler().__class__.__name__."
    - "Expose schedule_version_nonempty() -> bool: len(schedule.__version__) > 0."
    - "Expose schedule_has_every() -> bool: hasattr(schedule, 'every')."
    - "All test vectors verified against schedule 1.2.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# schedule_scheduler_name — Scheduler class name
invariant schedule_rust.scheduler.class_name:
  description: "schedule.Scheduler().__class__.__name__ == 'Scheduler'"
  category: scheduler
  kind: python_call_eq
  function: schedule_scheduler_name
  args: []
  expected: "Scheduler"

# schedule_version_nonempty — version non-empty
invariant schedule_rust.version.nonempty:
  description: "schedule.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: schedule_version_nonempty
  args: []
  expected: true

# schedule_has_every — every function present
invariant schedule_rust.module.has_every:
  description: "schedule.every is available"
  category: module
  kind: python_call_eq
  function: schedule_has_every
  args: []
  expected: true

