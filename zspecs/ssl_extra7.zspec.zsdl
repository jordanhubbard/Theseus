spec: ssl_extra7
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
  notes:
    - "This spec extends prior ssl specs."
    - "Focus: SSLContext function names and class names not yet covered."
    - "ssl.SSLContext.__name__ == 'SSLContext'."
    - "ssl.SSLSocket.__name__ == 'SSLSocket'."
    - "ssl.SSLObject.__name__ == 'SSLObject'."
    - "ssl.SSLError.__name__ == 'SSLError'."
    - "ssl.SSLCertVerificationError.__name__ == 'SSLCertVerificationError'."
    - "ssl.SSLZeroReturnError.__name__ == 'SSLZeroReturnError'."
    - "ssl.SSLWantReadError.__name__ == 'SSLWantReadError'."
    - "ssl.SSLWantWriteError.__name__ == 'SSLWantWriteError'."
    - "ssl.create_default_context.__name__ == 'create_default_context'."
    - "ssl.get_default_verify_paths.__name__ == 'get_default_verify_paths'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table ssl_extra7.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [SSLContext,               SSLContext.__name__.__eq__,               ["SSLContext"],               true]
    - [SSLSocket,                SSLSocket.__name__.__eq__,                ["SSLSocket"],                true]
    - [SSLObject,                SSLObject.__name__.__eq__,                ["SSLObject"],                true]
    - [SSLError,                 SSLError.__name__.__eq__,                 ["SSLError"],                 true]
    - [SSLCertVerificationError, SSLCertVerificationError.__name__.__eq__, ["SSLCertVerificationError"], true]
    - [SSLZeroReturnError,       SSLZeroReturnError.__name__.__eq__,       ["SSLZeroReturnError"],       true]
    - [SSLWantReadError,         SSLWantReadError.__name__.__eq__,         ["SSLWantReadError"],         true]
    - [SSLWantWriteError,        SSLWantWriteError.__name__.__eq__,        ["SSLWantWriteError"],        true]

table ssl_extra7.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [create_default_context,   create_default_context.__name__.__eq__,   ["create_default_context"],   true]
    - [get_default_verify_paths, get_default_verify_paths.__name__.__eq__, ["get_default_verify_paths"], true]
    - [RAND_bytes,               RAND_bytes.__name__.__eq__,               ["RAND_bytes"],               true]
    - [RAND_status,              RAND_status.__name__.__eq__,              ["RAND_status"],              true]

invariant ssl_extra7.SSLError.base:
  description: "ssl.SSLError.__bases__[0].__name__ == 'OSError'"
  category: exceptions
  kind: python_call_eq
  function: SSLError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

invariant ssl_extra7.SSLCertVerificationError.base:
  description: "ssl.SSLCertVerificationError.__bases__[0].__name__ == 'SSLError'"
  category: exceptions
  kind: python_call_eq
  function: SSLCertVerificationError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "SSLError"

invariant ssl_extra7.SSLContext.module:
  description: "ssl.SSLContext.__module__ == 'ssl'"
  category: module
  kind: python_call_eq
  function: SSLContext.__module__.__eq__
  args: ["ssl"]
  expected: true

invariant ssl_extra7.SSLError.module:
  description: "ssl.SSLError.__module__ == 'ssl'"
  category: module
  kind: python_call_eq
  function: SSLError.__module__.__eq__
  args: ["ssl"]
  expected: true

invariant ssl_extra7.RAND_bytes.module:
  description: "ssl.RAND_bytes.__module__ == 'ssl'"
  category: module
  kind: python_call_eq
  function: RAND_bytes.__module__.__eq__
  args: ["ssl"]
  expected: true
