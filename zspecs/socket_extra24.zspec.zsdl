spec: socket_extra24
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra8.zspec.zsdl — covers __qualname__.__eq__ for socket class, error/timeout/gaierror/herror exceptions as exception class table."
    - "socket_extra20.zspec.zsdl — covers __qualname__.__len__() for socket.socket class and module-level functions."
    - "socket_extra21.zspec.zsdl — covers __qualname__.__len__() for socket exception classes."
    - "socket_extra22.zspec.zsdl — covers __qualname__.__eq__ for socket.socket instance methods connect/bind/listen/accept/close/recv/send."
    - "socket_extra23.zspec.zsdl — covers __qualname__.__eq__ and __len__() for setsockopt/getsockopt/getsockname/getpeername/setblocking/settimeout/gettimeout/fileno and cross-namespace anchors for gaierror/herror."
  notes:
    - "This spec extends the socket chain through socket_extra23; it does NOT duplicate invariants in any prior spec."
    - "Focus: (1) socket.socket class-level __qualname__ and __module__ — extra23 covers method qualnames but not the class __module__; (2) socket.socket.__bases__[0].__name__ == 'socket' — the C-level base class is also named 'socket'; (3) socket.AddressFamily and socket.SocketKind enum class __qualname__ and __module__; (4) socket.AF_INET and socket.SOCK_STREAM instance __class__.__qualname__ — verifying the enum membership via __class__; (5) socket.error and socket.timeout __qualname__ — these alias OSError and TimeoutError; socket_extra8 covers them in a table but extra24 anchors them as standalone invariants from the extra24 namespace."
    - "socket.socket.__qualname__ == 'socket' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.__module__ == 'socket' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.__bases__[0].__name__ == 'socket' — the internal C extension base class is also named 'socket'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__qualname__ == 'AddressFamily' — len 13. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__module__ == 'socket' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__qualname__ == 'SocketKind' — len 10. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__module__ == 'socket' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__qualname__ == 'AddressFamily' — AF_INET is an AddressFamily enum member. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__qualname__ == 'SocketKind' — SOCK_STREAM is a SocketKind enum member. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.error.__qualname__ == 'OSError' — socket.error is an alias for OSError. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.timeout.__qualname__ == 'TimeoutError' — socket.timeout is an alias for TimeoutError. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket class __qualname__ and __module__
#
# socket_extra23 covers method __qualname__ values for socket.socket instance
# methods. No prior spec checks socket.socket.__module__. The class __qualname__
# == 'socket' (len 6) and __module__ == 'socket' (len 6).
# ---------------------------------------------------------------------------

invariant socket_extra24.socket_class.qualname_eq:
  description: "socket.socket.__qualname__ == 'socket' — top-level class; len 6"
  category: class_qualnames
  kind: python_call_eq
  function: socket.__qualname__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra24.socket_class.qualname_len:
  description: "len(socket.socket.__qualname__) == 6 — len('socket') == 6"
  category: class_qualnames
  kind: python_call_eq
  function: socket.__qualname__.__len__
  args: []
  expected: 6

invariant socket_extra24.socket_class.module_eq:
  description: "socket.socket.__module__ == 'socket' — class is defined in the socket module"
  category: class_module
  kind: python_call_eq
  function: socket.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra24.socket_class.module_len:
  description: "len(socket.socket.__module__) == 6 — len('socket') == 6"
  category: class_module
  kind: python_call_eq
  function: socket.__module__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# socket.socket.__bases__[0].__name__
#
# socket.socket inherits from the internal C-level '_socket.socket' class,
# which also exposes its __name__ as 'socket'. No prior spec checks this
# attribute.
# ---------------------------------------------------------------------------

invariant socket_extra24.socket_class.bases0_name_eq:
  description: "socket.socket.__bases__[0].__name__ == 'socket' — C-extension base class is also named 'socket'"
  category: class_hierarchy
  kind: python_call_eq
  "function": "socket.__bases__[0].__name__.__eq__"
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AddressFamily and socket.SocketKind enum class __qualname__ and __module__
#
# AddressFamily and SocketKind are IntEnum classes defined in the socket module.
# No prior spec checks their __qualname__ or __module__ as standalone invariants.
# AddressFamily.__qualname__ == 'AddressFamily' (len 13).
# SocketKind.__qualname__ == 'SocketKind' (len 10).
# Both have __module__ == 'socket'.
# ---------------------------------------------------------------------------

table socket_extra24.enum_class_qualnames:
  description: "__qualname__.__eq__ for socket.AddressFamily and socket.SocketKind enum classes"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: ecqn24

  columns: [id, function, args, expected]
  rows:
    - [AddressFamily, AddressFamily.__qualname__.__eq__, ["AddressFamily"], true]
    - [SocketKind,    SocketKind.__qualname__.__eq__,    ["SocketKind"],    true]

table socket_extra24.enum_class_qualname_lengths:
  description: "Length of __qualname__ strings for socket.AddressFamily and socket.SocketKind"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: ecqlen24

  columns: [id, function, args, expected]
  rows:
    - [AddressFamily, AddressFamily.__qualname__.__len__, [], 13]
    - [SocketKind,    SocketKind.__qualname__.__len__,    [], 10]

table socket_extra24.enum_class_modules:
  description: "__module__.__eq__ for socket.AddressFamily and socket.SocketKind enum classes"
  kind: python_call_eq
  category: class_module
  id_prefix: ecmod24

  columns: [id, function, args, expected]
  rows:
    - [AddressFamily, AddressFamily.__module__.__eq__, ["socket"], true]
    - [SocketKind,    SocketKind.__module__.__eq__,    ["socket"], true]

# ---------------------------------------------------------------------------
# socket.AF_INET and socket.SOCK_STREAM instance __class__.__qualname__
#
# AF_INET and SOCK_STREAM are enum members. Their __class__.__qualname__
# identifies the enum class they belong to. No prior spec checks this.
# AF_INET.__class__.__qualname__ == 'AddressFamily'.
# SOCK_STREAM.__class__.__qualname__ == 'SocketKind'.
# ---------------------------------------------------------------------------

invariant socket_extra24.AF_INET.class_qualname_eq:
  description: "socket.AF_INET.__class__.__qualname__ == 'AddressFamily' — AF_INET is an AddressFamily enum member"
  category: enum_membership
  kind: python_call_eq
  "function": "AF_INET.__class__.__qualname__.__eq__"
  args: ["AddressFamily"]
  expected: true

invariant socket_extra24.SOCK_STREAM.class_qualname_eq:
  description: "socket.SOCK_STREAM.__class__.__qualname__ == 'SocketKind' — SOCK_STREAM is a SocketKind enum member"
  category: enum_membership
  kind: python_call_eq
  "function": "SOCK_STREAM.__class__.__qualname__.__eq__"
  args: ["SocketKind"]
  expected: true

# ---------------------------------------------------------------------------
# socket.error and socket.timeout __qualname__ — cross-namespace anchors
#
# socket_extra8 covers socket.error and socket.timeout in its exception class
# table. These standalone invariants anchor them from the extra24 namespace.
# socket.error is an alias for OSError; its __qualname__ == 'OSError'.
# socket.timeout is an alias for TimeoutError; its __qualname__ == 'TimeoutError'.
# ---------------------------------------------------------------------------

invariant socket_extra24.error.qualname_eq:
  description: "socket.error.__qualname__ == 'OSError' — socket.error is an alias for OSError; cross-namespace anchor from extra24"
  category: class_qualnames
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["OSError"]
  expected: true

invariant socket_extra24.timeout.qualname_eq:
  description: "socket.timeout.__qualname__ == 'TimeoutError' — socket.timeout is an alias for TimeoutError; cross-namespace anchor from extra24"
  category: class_qualnames
  kind: python_call_eq
  function: timeout.__qualname__.__eq__
  args: ["TimeoutError"]
  expected: true
