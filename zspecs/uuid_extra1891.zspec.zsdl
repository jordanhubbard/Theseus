spec: uuid_extra1891
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Tests unary arithmetic protocol, async iteration protocol, __fspath__, and uuid module public API membership"
    - "UUID is not a numeric type; it does not implement __abs__, __neg__, __pos__, __round__, __floor__, __ceil__, __trunc__"
    - "SafeUUID is an enum and does not implement numeric or async iteration protocols"
    - "SafeUUID has enum members 'safe' and 'unsafe'; it does NOT have 'unknown'"
    - "uuid module dict contains uuid1, uuid3, uuid4, uuid5, getnode, RESERVED_NCS, RFC_4122"
  created_at: "2026-04-12"

table uuid_extra1891.unary_arithmetic:
  columns: [id, function, args, expected]
  rows:
    - ["uu1891-ua-001", "uuid.UUID.__dict__.__contains__", ["__abs__"], false]
    - ["uu1891-ua-002", "uuid.UUID.__dict__.__contains__", ["__neg__"], false]
    - ["uu1891-ua-003", "uuid.UUID.__dict__.__contains__", ["__pos__"], false]
    - ["uu1891-ua-004", "uuid.UUID.__dict__.__contains__", ["__round__"], false]
    - ["uu1891-ua-005", "uuid.UUID.__dict__.__contains__", ["__floor__"], false]
    - ["uu1891-ua-006", "uuid.UUID.__dict__.__contains__", ["__ceil__"], false]
    - ["uu1891-ua-007", "uuid.UUID.__dict__.__contains__", ["__trunc__"], false]
    - ["uu1891-ua-008", "uuid.SafeUUID.__dict__.__contains__", ["__abs__"], false]

table uuid_extra1891.fspath_aiter_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["uu1891-fa-001", "uuid.UUID.__dict__.__contains__", ["__fspath__"], false]
    - ["uu1891-fa-002", "uuid.UUID.__dict__.__contains__", ["__aiter__"], false]
    - ["uu1891-fa-003", "uuid.UUID.__dict__.__contains__", ["__anext__"], false]
    - ["uu1891-fa-004", "uuid.SafeUUID.__dict__.__contains__", ["__fspath__"], false]
    - ["uu1891-fa-005", "uuid.SafeUUID.__dict__.__contains__", ["__aiter__"], false]
    - ["uu1891-fa-006", "uuid.SafeUUID.__dict__.__contains__", ["__anext__"], false]
    - ["uu1891-fa-007", "uuid.UUID.__dict__.__contains__", ["__length_hint__"], false]
    - ["uu1891-fa-008", "uuid.SafeUUID.__dict__.__contains__", ["__length_hint__"], false]

table uuid_extra1891.uuid_safeuuid_enum_members:
  columns: [id, function, args, expected]
  rows:
    - ["uu1891-em-001", "uuid.SafeUUID.__dict__.__contains__", ["safe"], true]
    - ["uu1891-em-002", "uuid.SafeUUID.__dict__.__contains__", ["unsafe"], true]
    - ["uu1891-em-003", "uuid.SafeUUID.__dict__.__contains__", ["unknown"], false]
    - ["uu1891-em-004", "uuid.__dict__.__contains__", ["uuid1"], true]
    - ["uu1891-em-005", "uuid.__dict__.__contains__", ["uuid3"], true]
    - ["uu1891-em-006", "uuid.__dict__.__contains__", ["uuid4"], true]
    - ["uu1891-em-007", "uuid.__dict__.__contains__", ["uuid5"], true]
    - ["uu1891-em-008", "uuid.__dict__.__contains__", ["getnode"], true]
    - ["uu1891-em-009", "uuid.__dict__.__contains__", ["RESERVED_NCS"], true]
    - ["uu1891-em-010", "uuid.__dict__.__contains__", ["RFC_4122"], true]
