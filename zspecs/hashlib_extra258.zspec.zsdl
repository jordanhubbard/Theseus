spec: hashlib_extra258
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
  notes:
    - "Wave 258 theme: hmac.HMAC class method __name__ and __qualname__ identity."
    - "hmac.HMAC.update.__name__ == 'update'. HMAC.update is a plain Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.HMAC.update.__qualname__ == 'HMAC.update'. Qualname carries the class prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.HMAC.digest.__name__ == 'digest'. HMAC.digest is a plain Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.HMAC.digest.__qualname__ == 'HMAC.digest'. Qualname carries the class prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.HMAC.hexdigest.__name__ == 'hexdigest'. HMAC.hexdigest is a plain Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.HMAC.hexdigest.__qualname__ == 'HMAC.hexdigest'. Qualname carries the class prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.HMAC.copy.__name__ == 'copy'. HMAC.copy is a plain Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.HMAC.copy.__qualname__ == 'HMAC.copy'. Qualname carries the class prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.HMAC.update.__class__.__name__ == 'function'. All HMAC instance methods are plain Python functions (hmac is a pure Python module). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: HMAC is defined in Lib/hmac.py as a pure Python class. All its methods (update, digest, hexdigest, copy) are plain Python functions with __class__.__name__ == 'function', unlike C extension classes whose methods are method_descriptor objects."
    - "Note: __qualname__ for HMAC methods is 'HMAC.<method>' (e.g., 'HMAC.update'), confirming they are class-bound Python functions. __name__ is the bare method name without the class prefix."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hmac.HMAC.update.__name__.__eq__('update')
# hmac.HMAC.digest.__name__.__eq__('digest')
# hmac.HMAC.hexdigest.__name__.__eq__('hexdigest')
# hmac.HMAC.copy.__name__.__eq__('copy')
#
# Wave 258 theme: hmac.HMAC class method __name__ identity.
#
# HMAC is a pure Python class defined in Lib/hmac.py. Its four public instance
# methods — update, digest, hexdigest, and copy — are plain Python functions.
# Each method's __name__ attribute equals the bare method name without any class
# prefix. update() feeds new data into the HMAC computation. digest() and
# hexdigest() finalize the hash, returning bytes or hex string respectively.
# copy() creates an independent clone of the current HMAC state.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra258.HMAC_method_name_identity:
  description: "hmac.HMAC method __name__ identity — update/digest/hexdigest/copy all have __name__ equal to their bare method name — HMAC is a pure Python class in Lib/hmac.py; all methods are Python functions with unqualified __name__; update feeds data, digest/hexdigest finalize, copy clones state; wave 258 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hmacmeth258a

  columns: [id, function, args, expected, description]
  rows:
    - [update_name,    HMAC.update.__name__.__eq__,    ["update"],    true, "hmac.HMAC.update.__name__ == 'update'; feeds new data into the HMAC computation; Python function"]
    - [digest_name,    HMAC.digest.__name__.__eq__,    ["digest"],    true, "hmac.HMAC.digest.__name__ == 'digest'; finalizes and returns digest as bytes; Python function"]
    - [hexdigest_name, HMAC.hexdigest.__name__.__eq__,  ["hexdigest"], true, "hmac.HMAC.hexdigest.__name__ == 'hexdigest'; finalizes and returns digest as hex string; Python function"]
    - [copy_name,      HMAC.copy.__name__.__eq__,      ["copy"],      true, "hmac.HMAC.copy.__name__ == 'copy'; returns independent clone of current HMAC state; Python function"]

# ---------------------------------------------------------------------------
# hmac.HMAC.update.__qualname__.__eq__('HMAC.update')
# hmac.HMAC.digest.__qualname__.__eq__('HMAC.digest')
# hmac.HMAC.hexdigest.__qualname__.__eq__('HMAC.hexdigest')
# hmac.HMAC.copy.__qualname__.__eq__('HMAC.copy')
#
# Wave 258 theme: hmac.HMAC class method __qualname__ identity.
#
# Each HMAC method's __qualname__ is the class-prefixed form 'HMAC.<method>'.
# This confirms the functions are defined inside the HMAC class body (not at
# module level). The __qualname__ carries the class nesting context while
# __name__ is always the bare method name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra258.HMAC_method_qualname_identity:
  description: "hmac.HMAC method __qualname__ identity — update/digest/hexdigest/copy all have __qualname__ of the form 'HMAC.<method>' — qualname carries class nesting context confirming methods are defined inside the HMAC class body; __qualname__ is 'HMAC.update' / 'HMAC.digest' / 'HMAC.hexdigest' / 'HMAC.copy'; wave 258 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hmacmeth258b

  columns: [id, function, args, expected, description]
  rows:
    - [update_qualname,    HMAC.update.__qualname__.__eq__,    ["HMAC.update"],    true, "hmac.HMAC.update.__qualname__ == 'HMAC.update'; class-prefixed qualname confirms method defined in HMAC body"]
    - [digest_qualname,    HMAC.digest.__qualname__.__eq__,    ["HMAC.digest"],    true, "hmac.HMAC.digest.__qualname__ == 'HMAC.digest'; class-prefixed qualname confirms method defined in HMAC body"]
    - [hexdigest_qualname, HMAC.hexdigest.__qualname__.__eq__,  ["HMAC.hexdigest"], true, "hmac.HMAC.hexdigest.__qualname__ == 'HMAC.hexdigest'; class-prefixed qualname confirms method defined in HMAC body"]
    - [copy_qualname,      HMAC.copy.__qualname__.__eq__,      ["HMAC.copy"],      true, "hmac.HMAC.copy.__qualname__ == 'HMAC.copy'; class-prefixed qualname confirms method defined in HMAC body"]

# ---------------------------------------------------------------------------
# hmac.HMAC.update.__class__.__name__.__eq__('function')
# hmac.HMAC.digest.__class__.__name__.__eq__('function')
# hmac.HMAC.hexdigest.__class__.__name__.__eq__('function')
# hmac.HMAC.copy.__class__.__name__.__eq__('function')
#
# Wave 258 theme: hmac.HMAC method class type identity.
#
# All four HMAC public methods have __class__.__name__ == 'function' because
# HMAC is a pure Python class (Lib/hmac.py). This is distinct from C extension
# types whose methods are method_descriptor objects. The 'function' type
# confirms these are Python-level implementations, not C builtins.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra258.HMAC_method_class_identity:
  description: "hmac.HMAC methods are Python function objects — update/digest/hexdigest/copy all have __class__.__name__ == 'function' — HMAC is a pure Python class in Lib/hmac.py; methods are Python functions not C method_descriptors; 'function' type confirms Python-level implementation; wave 258 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hmacmeth258c

  columns: [id, function, args, expected, description]
  rows:
    - [update_class,    HMAC.update.__class__.__name__.__eq__,    ["function"], true, "hmac.HMAC.update.__class__.__name__ == 'function'; Python function not C method_descriptor"]
    - [digest_class,    HMAC.digest.__class__.__name__.__eq__,    ["function"], true, "hmac.HMAC.digest.__class__.__name__ == 'function'; Python function not C method_descriptor"]
    - [hexdigest_class, HMAC.hexdigest.__class__.__name__.__eq__,  ["function"], true, "hmac.HMAC.hexdigest.__class__.__name__ == 'function'; Python function not C method_descriptor"]
    - [copy_class,      HMAC.copy.__class__.__name__.__eq__,      ["function"], true, "hmac.HMAC.copy.__class__.__name__ == 'function'; Python function not C method_descriptor"]

# ---------------------------------------------------------------------------
# hmac.HMAC.update.__name__.__eq__('update') — standalone
#
# hmac.HMAC.update.__name__ is 'update'. HMAC.update(msg) feeds new data into
# the running HMAC computation. It is the primary input method: it accepts a
# bytes-like object and appends it to the internal hash state. Multiple calls
# to update() are equivalent to a single call with the concatenation of all
# arguments. HMAC.update is a plain Python function defined in Lib/hmac.py
# (not a C builtin), so its __class__.__name__ is 'function'. Its __name__
# is 'update' (bare, without the class prefix). This is the first standalone
# anchor for HMAC.update.__name__ under hmacmeth258a.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra258.HMAC_update_name:
  description: "hmac.HMAC.update.__name__.__eq__('update') == True — HMAC.update(msg) feeds bytes-like data into the running HMAC computation; multiple update() calls equivalent to one call with concatenated data; pure Python function in Lib/hmac.py with __class__.__name__=='function'; __name__=='update' (bare name, no class prefix); first standalone for HMAC.update.__name__ under hmacmeth258a; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: HMAC.update.__name__.__eq__
  args: ["update"]
  expected: true

# ---------------------------------------------------------------------------
# hmac.HMAC.digest.__qualname__.__eq__('HMAC.digest') — standalone
#
# hmac.HMAC.digest.__qualname__ is 'HMAC.digest'. HMAC.digest() finalizes
# the current HMAC computation and returns the digest as a bytes object whose
# length equals digest_size. The HMAC object itself is left unchanged after
# calling digest() — subsequent update() calls continue the computation.
# digest() works by copying the internal state (to avoid modifying the original)
# and finalizing the copy. The __qualname__ 'HMAC.digest' confirms the function
# is defined inside the HMAC class body. This is the first standalone anchor
# for HMAC.digest.__qualname__ under hmacmeth258b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra258.HMAC_digest_qualname:
  description: "hmac.HMAC.digest.__qualname__.__eq__('HMAC.digest') == True — HMAC.digest() finalizes and returns HMAC as bytes of length digest_size; HMAC object unchanged after call (copies internal state before finalizing); subsequent update() calls continue the computation; __qualname__=='HMAC.digest' confirms defined inside HMAC class body; first standalone for HMAC.digest.__qualname__ under hmacmeth258b; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: HMAC.digest.__qualname__.__eq__
  args: ["HMAC.digest"]
  expected: true
