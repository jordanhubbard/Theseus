    - [io1591bc029, io.BufferedRandom.__dict__.__contains__,  ["read"],       true]
    - [io1591bc030, io.BufferedRandom.__dict__.__contains__,  ["__next__"],   true]

table io_extra1591.iobase_protocol_present:
  description: "_io._IOBase (the C base for all io classes) defines iterator and context manager protocols, but not the descriptor protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1591bp

  columns: [id, function, args, expected]
  rows:
    - [io1591bp001, _io._IOBase.__dict__.__contains__, ["__get__"],       false]
    - [io1591bp002, _io._IOBase.__dict__.__contains__, ["__set__"],       false]
    - [io1591bp003, _io._IOBase.__dict__.__contains__, ["__delete__"],    false]
    - [io1591bp004, _io._IOBase.__dict__.__contains__, ["__iter__"],      true]
    - [io1591bp005, _io._IOBase.__dict__.__contains__, ["__next__"],      true]
    - [io1591bp006, _io._IOBase.__dict__.__contains__, ["__enter__"],     true]
    - [io1591bp007, _io._IOBase.__dict__.__contains__, ["__exit__"],      true]
    - [io1591bp008, _io._IOBase.__dict__.__contains__, ["close"],         true]
    - [io1591bp009, _io._IOBase.__dict__.__contains__, ["flush"],         true]
    - [io1591bp010, _io._IOBase.__dict__.__contains__, ["readline"],      true]
    - [io1591bp011, _io._IOBase.__dict__.__contains__, ["readlines"],     true]
    - [io1591bp012, _io._IOBase.__dict__.__contains__, ["writelines"],    true]
    - [io1591bp013, _io._IOBase.__dict__.__contains__, ["seek"],          true]
    - [io1591bp014, _io._IOBase.__dict__.__contains__, ["tell"],          true]
    - [io1591bp015, _io._IOBase.__dict__.__contains__, ["seekable"],      true]
    - [io1591bp016, _io._IOBase.__dict__.__contains__, ["readable"],      true]
    - [io1591bp017, _io._IOBase.__dict__.__contains__, ["writable"],      true]
    - [io1591bp018, _io._IOBase.__dict__.__contains__, ["fileno"],        true]
    - [io1591bp019, _io._IOBase.__dict__.__contains__, ["isatty"],        true]
    - [io1591bp020, _io._IOBase.__dict__.__contains__, ["closed"],        true]
    - [io1591bp021, _io._IOBase.__dict__.__contains__, ["truncate"],      true]
    - [io1591bp022, _io._IOBase.__dict__.__contains__, ["__call__"],      false]
    - [io1591bp023, _io._IOBase.__dict__.__contains__, ["__set_name__"],  false]
    - [io1591bp024, _io._IOBase.__dict__.__contains__, ["__del__"],       true]
