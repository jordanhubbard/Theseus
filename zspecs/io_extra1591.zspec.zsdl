spec: io_extra1591
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — descriptor protocol checks via __dict__.__contains__ for io stream classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for descriptor protocol: io stream classes (StringIO, BytesIO, TextIOWrapper, BufferedReader, BufferedWriter, FileIO, BufferedRandom) do not implement the descriptor protocol and therefore have no __get__, __set__, or __delete__ in their own __dict__"
    - "io.IOBase is a Python ABC wrapper; the actual C implementation with __iter__, __next__, __enter__, __exit__ lives in _io._IOBase — io.BytesIO however directly defines __iter__ and __next__"
  created_at: "2026-04-12"
error_model: python_exceptions

table io_extra1591.stream_classes_no_descriptor:
  description: "io.StringIO and io.BytesIO are stream objects, not descriptors — none define __get__, __set__, or __delete__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1591sc

  columns: [id, function, args, expected]
  rows:
    - [io1591sc001, io.StringIO.__dict__.__contains__,    ["__get__"],    false]
    - [io1591sc002, io.StringIO.__dict__.__contains__,    ["__set__"],    false]
    - [io1591sc003, io.StringIO.__dict__.__contains__,    ["__delete__"], false]
    - [io1591sc004, io.BytesIO.__dict__.__contains__,     ["__get__"],    false]
    - [io1591sc005, io.BytesIO.__dict__.__contains__,     ["__set__"],    false]
    - [io1591sc006, io.BytesIO.__dict__.__contains__,     ["__delete__"], false]
    - [io1591sc007, io.StringIO.__dict__.__contains__,    ["read"],       true]
    - [io1591sc008, io.StringIO.__dict__.__contains__,    ["write"],      true]
    - [io1591sc009, io.StringIO.__dict__.__contains__,    ["seek"],       true]
    - [io1591sc010, io.StringIO.__dict__.__contains__,    ["tell"],       true]
    - [io1591sc011, io.StringIO.__dict__.__contains__,    ["close"],      true]
    - [io1591sc012, io.StringIO.__dict__.__contains__,    ["getvalue"],   true]
    - [io1591sc013, io.StringIO.__dict__.__contains__,    ["readline"],   true]
    - [io1591sc014, io.StringIO.__dict__.__contains__,    ["__next__"],   true]
    - [io1591sc015, io.StringIO.__dict__.__contains__,    ["__iter__"],   false]
    - [io1591sc016, io.BytesIO.__dict__.__contains__,     ["read"],       true]
    - [io1591sc017, io.BytesIO.__dict__.__contains__,     ["write"],      true]
    - [io1591sc018, io.BytesIO.__dict__.__contains__,     ["getvalue"],   true]
    - [io1591sc019, io.BytesIO.__dict__.__contains__,     ["getbuffer"],  true]
    - [io1591sc020, io.BytesIO.__dict__.__contains__,     ["__iter__"],   true]
    - [io1591sc021, io.BytesIO.__dict__.__contains__,     ["__next__"],   true]
    - [io1591sc022, io.BytesIO.__dict__.__contains__,     ["readline"],   true]
    - [io1591sc023, io.BytesIO.__dict__.__contains__,     ["readlines"],  true]
    - [io1591sc024, io.BytesIO.__dict__.__contains__,     ["read1"],      true]
    - [io1591sc025, io.StringIO.__dict__.__contains__,    ["seekable"],   true]
    - [io1591sc026, io.StringIO.__dict__.__contains__,    ["readable"],   true]
    - [io1591sc027, io.StringIO.__dict__.__contains__,    ["writable"],   true]

table io_extra1591.buffered_classes_no_descriptor:
