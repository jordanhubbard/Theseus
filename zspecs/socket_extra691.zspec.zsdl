spec: socket_extra691
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket.socket method documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket.socket method __name__ identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra691.socket_method_names:
  description: "socket.socket method __name__ identity"
  kind: python_call_eq
  category: socket_method_names
  id_prefix: sk691mn
  columns: [id, function, args, expected]
  rows:
    - [sk691mn001, socket.socket.__init__.__name__.__eq__,      ["__init__"],    true]
    - [sk691mn002, socket.socket.connect.__name__.__eq__,       ["connect"],     true]
    - [sk691mn003, socket.socket.bind.__name__.__eq__,          ["bind"],        true]
    - [sk691mn004, socket.socket.listen.__name__.__eq__,        ["listen"],      true]
    - [sk691mn005, socket.socket.accept.__name__.__eq__,        ["accept"],      true]
    - [sk691mn006, socket.socket.send.__name__.__eq__,          ["send"],        true]
    - [sk691mn007, socket.socket.recv.__name__.__eq__,          ["recv"],        true]
    - [sk691mn008, socket.socket.close.__name__.__eq__,         ["close"],       true]
    - [sk691mn009, socket.socket.shutdown.__name__.__eq__,      ["shutdown"],    true]
    - [sk691mn010, socket.socket.setblocking.__name__.__eq__,   ["setblocking"], true]
    - [sk691mn011, socket.socket.settimeout.__name__.__eq__,    ["settimeout"],  true]
    - [sk691mn012, socket.socket.getsockname.__name__.__eq__,   ["getsockname"], true]
