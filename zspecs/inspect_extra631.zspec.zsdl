spec: inspect_extra631
version: ">=3.9"
backend: python_module(inspect)
docs: "inspect.Parameter constant identity checks: empty, ParameterKind members, and their names."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers inspect.Parameter.empty and all five ParameterKind members for __class__.__name__, .name, and __qualname__"
  created_at: "2026-04-12T00:00:00Z"

table inspect_extra631.parameter_class_names:
  description: "__class__.__name__ checks for inspect.Parameter constants"
  kind: python_call_eq
  category: inspect_parameter
  id_prefix: in631pa
  columns: [id, function, args, expected]
  rows:
    - [in631pa001, inspect.Parameter.empty.__class__.__name__.__eq__, ["type"], true]
    - [in631pa002, inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__, ["ParameterKind"], true]
    - [in631pa003, inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__, ["ParameterKind"], true]
    - [in631pa004, inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__, ["ParameterKind"], true]
    - [in631pa005, inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__, ["ParameterKind"], true]
    - [in631pa006, inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__, ["ParameterKind"], true]

table inspect_extra631.parameter_kind_names:
  description: ".name attribute checks for ParameterKind enum members"
  kind: python_call_eq
  category: inspect_parameter
  id_prefix: in631fn
  columns: [id, function, args, expected]
  rows:
    - [in631fn001, inspect.Parameter.POSITIONAL_ONLY.name.__eq__, ["POSITIONAL_ONLY"], true]
    - [in631fn002, inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__, ["POSITIONAL_OR_KEYWORD"], true]
    - [in631fn003, inspect.Parameter.VAR_POSITIONAL.name.__eq__, ["VAR_POSITIONAL"], true]
    - [in631fn004, inspect.Parameter.KEYWORD_ONLY.name.__eq__, ["KEYWORD_ONLY"], true]
    - [in631fn005, inspect.Parameter.VAR_KEYWORD.name.__eq__, ["VAR_KEYWORD"], true]

table inspect_extra631.parameter_empty_qualname:
  description: "__qualname__ check for inspect.Parameter.empty"
  kind: python_call_eq
  category: inspect_parameter
  id_prefix: in631eq
  columns: [id, function, args, expected]
  rows:
    - [in631eq001, inspect.Parameter.empty.__qualname__.__eq__, ["Parameter.empty"], true]
