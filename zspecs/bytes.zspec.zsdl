spec: bytes
version: ">=3.0.0"
backend: node(bytes)

docs: https://www.npmjs.com/package/bytes

provenance:
  derived_from:
    - "bytes README — https://www.npmjs.com/package/bytes"
    - "Test vectors verified with bytes via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "bytes source"
  notes:
    - "bytes is an npm package. Install: npm install bytes"
    - "bytes(n) converts an integer byte count to a human-readable string."
    - "bytes(str) parses a human-readable byte string to an integer."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns formatted string or integer byte count."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table bytes.format:
  kind: node_module_call_eq
  function: ~
  category: format
  id_prefix: bytesfmt

  columns: [id, args, expected]
  rows:
    - [one_kb, [1024],    "1KB"]
    - [one_mb, [1048576], "1MB"]

table bytes.parse:
  kind: node_module_call_eq
  function: ~
  category: parse
  id_prefix: bytesparse

  columns: [id, args, expected]
  rows:
    - [kb,  ["1kb"],   1024]
    - [mb,  ["1.5MB"], 1572864]
