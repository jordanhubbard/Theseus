spec: bytes
version: ">=3.0.0"
backend: node(bytes)

docs: https://github.com/visionmedia/bytes.js#readme

provenance:
  derived_from:
    - "bytes README — https://github.com/visionmedia/bytes.js#readme"
    - "Test vectors verified with bytes@3.1.2 via Node.js 25.6.0 on macOS/Darwin 25.4.0, 2026-04-09"
    - "bytes source: index.js (MIT; source inspection permitted)"
  not_derived_from: []
  notes:
    - "bytes exports a function that converts between byte sizes and human-readable strings."
    - "bytes(number) — formats a byte count as a string using IEC binary units (1 KB = 1024 B)."
    - "bytes(string) — parses a human-readable byte string and returns the number of bytes."
    - "bytes.format(number, [options]) — explicit format function."
    - "bytes.parse(string) — explicit parse function."
    - "The default threshold for using KB vs B is 1024; values below 1024 are shown as B."
    - "bytes(null) and bytes(undefined) return null."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "bytes returns null for non-numeric/non-string inputs. node exits 0 for all invariants."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# bytes.format(number) — number of bytes → human-readable string
# ---------------------------------------------------------------------------

table bytes.format:
  kind: node_module_call_eq
  function: format
  category: format
  id_prefix: format

  columns: [id, args, expected]
  rows:
    - [zero,         [0],            "0B"]
    - [one_kb_exact, [1024],         "1KB"]
    - [under_kb,     [1000],         "1000B"]
    - [one_mb,       [1048576],      "1MB"]
    - [one_gb,       [1073741824],   "1GB"]
    - [half_mb,      [524288],       "512KB"]
    - [one_half_mb,  [1572864],      "1.5MB"]
    - [with_unit_b,  [1024, {"unit": "B"}], "1024B"]

# ---------------------------------------------------------------------------
# bytes.parse(string) — human-readable string → number of bytes
# ---------------------------------------------------------------------------

table bytes.parse:
  kind: node_module_call_eq
  function: parse
  category: parse
  id_prefix: parse

  columns: [id, args, expected]
  rows:
    - [one_kb,      ["1KB"],   1024]
    - [one_mb,      ["1MB"],   1048576]
    - [one_gb,      ["1GB"],   1073741824]
    - [five_hundred_b, ["500B"], 500]
    - [one_half_kb, ["1.5KB"], 1536]
    - [zero_b,      ["0B"],    0]
    - [bare_number, ["100"],   100]
