spec: bytes
version: ">=3.0.0"
backend: node(bytes)

docs: https://www.npmjs.com/package/bytes

provenance:
  derived_from:
    - "bytes README — https://www.npmjs.com/package/bytes"
    - "Test vectors verified with bytes@3.1.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "bytes source"
  notes:
    - "bytes exports a function directly as module.exports."
    - "bytes(number) formats a byte count as a human-readable string."
    - "bytes(string) parses a byte string to a number."
    - "Default output uses decimal prefixes (1 KB = 1000 bytes) — wait, actually 1 KB = 1024 bytes in this lib."
    - "bytes uses binary prefixes: 1 KB = 1024 bytes."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns string (from number) or number (from string)."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table bytes.bytes:
  kind: node_module_call_eq
  function: ~
  category: bytes
  id_prefix: bytes

  columns: [id, args, expected]
  rows:
    - [one_kb,     [1024],        "1KB"]
    - [one_mb,     [1048576],     "1MB"]
    - [parse_kb,   ["1KB"],       1024]
    - [parse_mb,   ["1MB"],       1048576]
