spec: concurrent_futures_extra88
version: ">=3.9"
backend: python_module(concurrent.futures)
extends: concurrent_futures_extra87

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra87.zspec.zsdl."
    - "This spec covers: wave 251 theme — concurrent.futures module identity: __name__, __package__, __spec__, __loader__. NEW in extra88: concurrent.futures.__name__.__eq__('concurrent.futures')==True; concurrent.futures.__package__.__eq__('concurrent.futures')==True (concurrent.futures is a subpackage); concurrent.futures.__spec__.__class__.__name__.__eq__('ModuleSpec')==True; concurrent.futures.__spec__.name.__eq__('concurrent.futures')==True; concurrent.futures.__loader__.__class__.__name__.__eq__('SourceFileLoader')==True; concurrent.futures.__file__.__class__.__name__.__eq__('str')==True; concurrent.futures.__doc__.__class__.__name__.__eq__('str')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__name__ == 'concurrent.futures'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__package__ == 'concurrent.futures'. concurrent.futures is a package (has an __init__.py); its __package__ equals the full module name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__spec__.__class__.__name__ == 'ModuleSpec'. The module spec is a ModuleSpec instance from importlib. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__spec__.name == 'concurrent.futures'. The ModuleSpec name field equals the full module name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__loader__.__class__.__name__ == 'SourceFileLoader'. concurrent.futures is a pure-Python package loaded from source. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__file__.__class__.__name__ == 'str'. The __file__ attribute is a str path to the __init__.py file. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__doc__.__class__.__name__ == 'str'. concurrent.futures has a docstring. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

