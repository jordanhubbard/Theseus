invariant concurrent_futures_extra88.module_name_is_concurrent_futures:
  description: "concurrent.futures.__name__.__eq__('concurrent.futures') returns True — the module's __name__ attribute is 'concurrent.futures', the canonical dotted name of the module; NEW in extra88: first standalone __name__ equality invariant for concurrent.futures in cfmoduleid88 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra88.module_package_is_concurrent_futures:
  description: "concurrent.futures.__package__.__eq__('concurrent.futures') returns True — concurrent.futures is a package (not a simple module); its __package__ equals its own full name; this contrasts with submodules like concurrent.futures.thread where __package__ would be 'concurrent.futures'; NEW in extra88: first standalone __package__ equality invariant for concurrent.futures in cfmoduleid88 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra88.module_spec_is_ModuleSpec:
  description: "concurrent.futures.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — the module's __spec__ is a ModuleSpec instance from importlib._bootstrap; this is the standard module specification object used by the import system; NEW in extra88: first standalone __spec__ class name invariant for concurrent.futures in cfmoduleid88 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant concurrent_futures_extra88.module_loader_is_SourceFileLoader:
  description: "concurrent.futures.__loader__.__class__.__name__.__eq__('SourceFileLoader') returns True — concurrent.futures is a pure-Python package loaded from source files; its loader is a SourceFileLoader instance from importlib._bootstrap_external; NEW in extra88: first standalone __loader__ class name invariant for concurrent.futures in cfmoduleid88 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant concurrent_futures_extra88.module_spec_name_is_concurrent_futures:
  description: "concurrent.futures.__spec__.name.__eq__('concurrent.futures') returns True — the ModuleSpec's name field equals the module name 'concurrent.futures'; this is the fully qualified module name stored in the spec; NEW in extra88: first standalone __spec__.name equality invariant for concurrent.futures in cfmoduleid88 namespace; wave 251; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["concurrent.futures"]
  expected: true
