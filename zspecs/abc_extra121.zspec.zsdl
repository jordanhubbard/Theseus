spec: abc_extra121
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: wave 255 theme — abc.ABC class dunder method identity attributes. NEW in extra121: abc.ABC.__init_subclass__.__class__.__name__=='builtin_function_or_method'; abc.ABC.__init_subclass__.__qualname__=='ABC.__init_subclass__' (len=21); abc.ABC.__subclasshook__.__class__.__name__=='builtin_function_or_method'; abc.ABC.__subclasshook__.__qualname__=='ABC.__subclasshook__' (len=20); abc.ABC.__dict__.__class__.__name__=='mappingproxy'; abc.ABC.__doc__.__class__.__name__=='str'; abc.ABC.__abstractmethods__.__class__.__name__=='frozenset'; abc.ABC.__abstractmethods__.__len__()==0; abc.ABC.__module__.__len__()==3; abc.ABCMeta.__subclasshook__.__qualname__.__len__()==24 (longest: 'ABCMeta.__subclasshook__'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__init_subclass__.__class__.__name__ == 'builtin_function_or_method'. ABC inherits __init_subclass__ from object — it is a C-level built-in classmethod, not Python-defined. Has no __func__ attribute (unlike Python classmethods). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (len=20). 'ABC.'=4+'__subclasshook__'=16=20 chars. Note that ABCMeta.__subclasshook__.__qualname__ is 'ABCMeta.__subclasshook__' (len=24: 'ABCMeta.'=8+'__subclasshook__'=16=24). The ABC-level qualname is shorter because the 'ABC.' prefix (4 chars) is shorter than 'ABCMeta.' (8 chars). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy'. Class __dict__ is always a mappingproxy (read-only view of the class namespace), not a plain dict. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset'. The set of abstract methods on ABC is an empty frozenset (len=0) because ABC itself defines no abstract methods — it is a helper base class with no abstract method requirements. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC dunder classmethod identity — extra121
#
# Wave 255 theme: abc.ABC class dunder method identity attributes.
#
# abc.ABC.__init_subclass__.__class__.__name__    == 'builtin_function_or_method'
# abc.ABC.__init_subclass__.__qualname__          == 'ABC.__init_subclass__'  (len=21)
# abc.ABC.__subclasshook__.__class__.__name__     == 'builtin_function_or_method'
# abc.ABC.__subclasshook__.__qualname__           == 'ABC.__subclasshook__'   (len=20)
# abc.ABCMeta.__subclasshook__.__qualname__.__len__() == 24
# ---------------------------------------------------------------------------

table abc_extra121.abc_ABC_dunder_classmethods:
  description: "abc.ABC dunder classmethod identity checks in abcabcdunder121 namespace — wave 255 theme: abc.ABC.__init_subclass__.__class__.__name__.__eq__('builtin_function_or_method')==True (ABC inherits __init_subclass__ from object; it is a C-level built-in classmethod with no Python-level __func__ attribute; class name is 'builtin_function_or_method'); abc.ABC.__init_subclass__.__qualname__.__eq__('ABC.__init_subclass__')==True (len=21: 'ABC.'=4+'__init_subclass__'=17=21); abc.ABC.__init_subclass__.__qualname__.__len__()==21; abc.ABC.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method')==True (ABC.__subclasshook__ is also a built-in classmethod inherited from ABCMeta's implementation; both __init_subclass__ and __subclasshook__ are 'builtin_function_or_method'); abc.ABC.__subclasshook__.__qualname__.__eq__('ABC.__subclasshook__')==True (len=20: 'ABC.'=4+'__subclasshook__'=16=20; one char shorter than __init_subclass__ qualname len=21 because '__subclasshook__'=16 < '__init_subclass__'=17); abc.ABC.__subclasshook__.__qualname__.__len__()==20; abc.ABCMeta.__subclasshook__.__qualname__.__len__()==24 (ABCMeta-level qualname is 'ABCMeta.__subclasshook__': 'ABCMeta.'=8+'__subclasshook__'=16=24, four chars longer than ABC-level because 'ABCMeta.'=8 vs 'ABC.'=4); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcdunder121

  columns: [id, function, args, expected, description]
  rows:
    - [initsub_cls,    abc.ABC.__init_subclass__.__class__.__name__.__eq__,    ["builtin_function_or_method"], true, "abc.ABC.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (C-level built-in classmethod from object); verified with Python 3.14.3"]
    - [initsub_qn_eq,  abc.ABC.__init_subclass__.__qualname__.__eq__,           ["ABC.__init_subclass__"],      true, "abc.ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__' (len=21); verified with Python 3.14.3"]
    - [initsub_qn_len, abc.ABC.__init_subclass__.__qualname__.__len__,          [],                             21,   "abc.ABC.__init_subclass__.__qualname__.__len__() == 21 ('ABC.'=4+'__init_subclass__'=17=21); verified with Python 3.14.3"]
    - [hook_cls,       abc.ABC.__subclasshook__.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "abc.ABC.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' (built-in classmethod); verified with Python 3.14.3"]
    - [hook_qn_eq,     abc.ABC.__subclasshook__.__qualname__.__eq__,            ["ABC.__subclasshook__"],       true, "abc.ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (len=20); verified with Python 3.14.3"]
    - [hook_qn_len,    abc.ABC.__subclasshook__.__qualname__.__len__,           [],                             20,   "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 ('ABC.'=4+'__subclasshook__'=16=20); verified with Python 3.14.3"]
    - [meta_hook_qlen, abc.ABCMeta.__subclasshook__.__qualname__.__len__,       [],                             24,   "abc.ABCMeta.__subclasshook__.__qualname__.__len__() == 24 ('ABCMeta.'=8+'__subclasshook__'=16=24; ABCMeta prefix adds 4 more chars than ABC prefix); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC __dict__, __doc__, __abstractmethods__ dunder identity — extra121
#
# abc.ABC.__dict__.__class__.__name__          == 'mappingproxy'
# abc.ABC.__doc__.__class__.__name__           == 'str'
# abc.ABC.__abstractmethods__.__class__.__name__== 'frozenset'
# abc.ABC.__abstractmethods__.__len__()        == 0
# abc.ABC.__module__.__len__()                 == 3
# abc.ABC.__name__.__len__()                   == 3
# abc.ABC.__mro__.__len__()                    == 2
# ---------------------------------------------------------------------------

table abc_extra121.abc_ABC_dunder_attribute_types:
  description: "abc.ABC dunder attribute type identity checks in abcabcdunder121 namespace — wave 255 theme: abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy')==True (class __dict__ is always a mappingproxy — a read-only view of the class namespace dict; accessing ABC.__dict__ returns a mappingproxy, not a plain dict); abc.ABC.__doc__.__class__.__name__.__eq__('str')==True (ABC has a non-None docstring: 'Helper class that provides a standard way to create an ABC using inheritance.'; its class is 'str'); abc.ABC.__abstractmethods__.__class__.__name__.__eq__('frozenset')==True (ABC itself has no abstract methods — it is a helper base class; the set of abstract methods is stored as an empty frozenset); abc.ABC.__abstractmethods__.__len__()==0 (empty frozenset, len==0); abc.ABC.__module__.__len__()==3 (module is 'abc', len=3: 'abc'=3, the shortest module name in any abc spec); abc.ABC.__name__.__len__()==3 (class name 'ABC' also has len=3: 'ABC'=3); abc.ABC.__mro__.__len__()==2 ([ABC, object]: minimal 2-element MRO); abc.ABC.__class__.__name__.__eq__('ABCMeta')==True (ABC's metaclass is ABCMeta, not the default type — covered in abc_extra120 but referenced here for completeness); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcdunder121a

  columns: [id, function, args, expected, description]
  rows:
    - [dict_cls,     abc.ABC.__dict__.__class__.__name__.__eq__,              ["mappingproxy"], true, "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy' (class __dict__ is always a read-only mappingproxy); verified with Python 3.14.3"]
    - [doc_cls,      abc.ABC.__doc__.__class__.__name__.__eq__,               ["str"],          true, "abc.ABC.__doc__.__class__.__name__ == 'str' (ABC has a non-None docstring); verified with Python 3.14.3"]
    - [absmeth_cls,  abc.ABC.__abstractmethods__.__class__.__name__.__eq__,   ["frozenset"],    true, "abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset' (abstract methods stored as frozenset); verified with Python 3.14.3"]
    - [absmeth_len,  abc.ABC.__abstractmethods__.__len__,                     [],               0,    "abc.ABC.__abstractmethods__.__len__() == 0 (empty frozenset; ABC defines no abstract methods); verified with Python 3.14.3"]
    - [mod_len,      abc.ABC.__module__.__len__,                              [],               3,    "abc.ABC.__module__.__len__() == 3 ('abc'=3, the shortest module name in any abc spec); verified with Python 3.14.3"]
    - [name_len,     abc.ABC.__name__.__len__,                                [],               3,    "abc.ABC.__name__.__len__() == 3 ('ABC'=3, same length as module name 'abc'=3); verified with Python 3.14.3"]
    - [mro_len,      abc.ABC.__mro__.__len__,                                 [],               2,    "abc.ABC.__mro__.__len__() == 2 ([ABC, object]: minimal MRO, ABC directly subclasses object); verified with Python 3.14.3"]
    - [meta_cls,     abc.ABC.__class__.__name__.__eq__,                       ["ABCMeta"],      true, "abc.ABC.__class__.__name__ == 'ABCMeta' (ABC metaclass is ABCMeta; covered in extra120 but referenced for completeness); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC __subclasshook__ vs ABCMeta.__subclasshook__ comparison — extra121
#
# ABC.__subclasshook__.__qualname__       == 'ABC.__subclasshook__'    (len=20)
# ABCMeta.__subclasshook__.__qualname__   == 'ABCMeta.__subclasshook__'(len=24)
# ABC.__init_subclass__.__qualname__      == 'ABC.__init_subclass__'   (len=21)
# ABCMeta.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'
# ---------------------------------------------------------------------------

table abc_extra121.abc_ABC_vs_ABCMeta_subclasshook:
  description: "abc.ABC.__subclasshook__ vs abc.ABCMeta.__subclasshook__ qualname comparison checks in abcabcdunder121 namespace — wave 255 theme: abc.ABC.__subclasshook__.__qualname__.__len__()==20 (ABC-level: 'ABC.'=4+'__subclasshook__'=16=20); abc.ABCMeta.__subclasshook__.__qualname__.__len__()==24 (ABCMeta-level: 'ABCMeta.'=8+'__subclasshook__'=16=24; 4 chars longer because 'ABCMeta.'=8 vs 'ABC.'=4); the difference of 4 chars exactly equals the length difference between 'ABCMeta' (7 chars) and 'ABC' (3 chars) plus the shared dot separator; abc.ABC.__init_subclass__.__qualname__.__len__()==21 (one more than hook's 20: 'ABC.'=4+'__init_subclass__'=17=21 vs 'ABC.'=4+'__subclasshook__'=16=20); abc.ABCMeta.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method')==True (same class as ABC.__subclasshook__); abc.ABC.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method')==True; abc.ABCMeta.__subclasshook__.__qualname__.__eq__('ABCMeta.__subclasshook__')==True; abc.ABC.__mro__.__len__()==2; abc.ABC.__abstractmethods__.__len__()==0; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcdunder121b

  columns: [id, function, args, expected, description]
  rows:
    - [abc_hook_qlen,    abc.ABC.__subclasshook__.__qualname__.__len__,             [],                             20,   "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 ('ABC.'=4+'__subclasshook__'=16=20); verified with Python 3.14.3"]
    - [meta_hook_qeq,    abc.ABCMeta.__subclasshook__.__qualname__.__eq__,          ["ABCMeta.__subclasshook__"],   true, "abc.ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (len=24); verified with Python 3.14.3"]
    - [meta_hook_qlen2,  abc.ABCMeta.__subclasshook__.__qualname__.__len__,         [],                             24,   "abc.ABCMeta.__subclasshook__.__qualname__.__len__() == 24 (4 more than ABC-level len=20); verified with Python 3.14.3"]
    - [meta_hook_cls,    abc.ABCMeta.__subclasshook__.__class__.__name__.__eq__,    ["builtin_function_or_method"], true, "abc.ABCMeta.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' (same class as ABC-level); verified with Python 3.14.3"]
    - [abc_initsub_qlen, abc.ABC.__init_subclass__.__qualname__.__len__,            [],                             21,   "abc.ABC.__init_subclass__.__qualname__.__len__() == 21 (1 more than hook=20; '__init_subclass__'=17 vs '__subclasshook__'=16); verified with Python 3.14.3"]
    - [abc_mro_len,      abc.ABC.__mro__.__len__,                                   [],                             2,    "abc.ABC.__mro__.__len__() == 2 ([ABC, object]); verified with Python 3.14.3"]
    - [abc_absmeth_len,  abc.ABC.__abstractmethods__.__len__,                       [],                             0,    "abc.ABC.__abstractmethods__.__len__() == 0 (empty frozenset); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra121
# ---------------------------------------------------------------------------

invariant abc_extra121.ABC_init_subclass_is_builtin:
  description: "abc.ABC.__init_subclass__.__class__.__name__.__eq__('builtin_function_or_method') returns True — abc.ABC inherits __init_subclass__ from object (not from ABCMeta); it is a C-level built-in classmethod with class name 'builtin_function_or_method'; abc.ABC.__init_subclass__ has no __func__ attribute (unlike Python classmethods which wrap a function via __func__); __init_subclass__.__qualname__ is 'ABC.__init_subclass__' (len=21: 'ABC.'=4+'__init_subclass__'=17=21); compare with abc.ABC.__subclasshook__.__class__.__name__ which is also 'builtin_function_or_method' — both ABC dunder classmethods are C-level built-ins; compare with abc.ABCMeta.register.__class__.__name__ which is 'function' (Python-defined in abc.py, covered in abc_extra99); NEW in extra121: first standalone ABC.__init_subclass__ class name invariant in abcabcdunder121 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__init_subclass__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra121.ABC_abstractmethods_is_empty_frozenset:
  description: "abc.ABC.__abstractmethods__.__len__() == 0 — abc.ABC.__abstractmethods__ is an empty frozenset (len=0); abc.ABC is designed as a helper base class that provides the ABCMeta metaclass mechanism without requiring any abstract method implementations; users subclass abc.ABC and then use @abstractmethod to declare abstract methods in their subclass; the frozenset being empty means a concrete class can inherit from ABC without implementing any methods; abc.ABC.__abstractmethods__.__class__.__name__ is 'frozenset' (the class of the empty abstract methods container); abc.ABC.__mro__.__len__() is 2 ([ABC, object]); abc.ABC.__dict__.__class__.__name__ is 'mappingproxy'; NEW in extra121: first standalone ABC.__abstractmethods__ length invariant in abcabcdunder121 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__abstractmethods__.__len__
  args: []
  expected: 0

invariant abc_extra121.ABC_dict_is_mappingproxy:
  description: "abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — abc.ABC.__dict__ is a mappingproxy object (a read-only view of the class namespace); the mappingproxy type is the standard class for class-level __dict__ in CPython — it prevents direct modification of the class namespace via the __dict__ attribute; abc.ABC.__dict__.__class__.__name__ is 'mappingproxy'; this is consistent across all Python classes regardless of their metaclass; abc.ABC.__class__.__name__ is 'ABCMeta' (the metaclass is ABCMeta); abc.ABC.__abstractmethods__.__class__.__name__ is 'frozenset' (empty); abc.ABC.__doc__.__class__.__name__ is 'str'; NEW in extra121: first standalone ABC.__dict__ class name invariant in abcabcdunder121 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra121.ABC_subclasshook_qualname_len_20:
  description: "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 — abc.ABC.__subclasshook__.__qualname__ is 'ABC.__subclasshook__' (20 chars: 'ABC.'=4+'__subclasshook__'=16=20); this is one less than abc.ABC.__init_subclass__.__qualname__.__len__()==21 (because '__subclasshook__'=16 < '__init_subclass__'=17); abc.ABCMeta.__subclasshook__.__qualname__.__len__() is 24 (four more than ABC-level=20, due to 'ABCMeta.'=8 vs 'ABC.'=4 prefix); abc.ABC.__subclasshook__.__class__.__name__ is 'builtin_function_or_method'; __subclasshook__ is a classmethod that can be overridden by subclasses of ABCMeta to customize issubclass() checks for the ABC; the default implementation in ABCMeta returns NotImplemented; NEW in extra121: first standalone ABC.__subclasshook__ qualname length invariant in abcabcdunder121 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__subclasshook__.__qualname__.__len__
  args: []
  expected: 20

invariant abc_extra121.ABC_abstractmethods_is_frozenset:
  description: "abc.ABC.__abstractmethods__.__class__.__name__.__eq__('frozenset') returns True — abc.ABC.__abstractmethods__ is a frozenset (an immutable set); CPython stores abstract method names in a frozenset on each class object; for ABC itself, this frozenset is empty (len=0) since ABC defines no abstract methods; subclasses created with @abstractmethod would have non-empty frozensets; abc.ABC.__abstractmethods__.__len__() is 0; abc.ABC.__dict__.__class__.__name__ is 'mappingproxy'; abc.ABC.__doc__.__class__.__name__ is 'str'; abc.ABC.__module__ is 'abc' (len=3); abc.ABC.__name__ is 'ABC' (len=3); abc.ABC.__mro__.__len__() is 2; NEW in extra121: first standalone ABC.__abstractmethods__ class name invariant in abcabcdunder121 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true
