spec: concurrent_futures_extra410
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "concurrent.futures.wait.__name__ == 'wait', __module__ == 'concurrent.futures._base'"
    - "concurrent.futures.as_completed.__name__ == 'as_completed', __module__ == 'concurrent.futures._base'"
    - "concurrent.futures.ProcessPoolExecutor.__doc__ is None (NoneType); __doc__.__class__.__name__ == 'NoneType'"
    - "concurrent.futures.ThreadPoolExecutor.__doc__ is None (NoneType); __doc__.__class__.__name__ == 'NoneType'"
    - "concurrent.futures.Future.__doc__.__class__.__name__ == 'str'"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra410.module_function_names:
  description: "Verify __name__ attribute of concurrent.futures module-level functions wait and as_completed"
  kind: python_call_eq
  category: identity
  id_prefix: cf410fn

  columns: [id, function, args, expected]
  rows:
    - [cf410fn001, concurrent.futures.wait.__name__.__eq__, ["wait"], true]
    - [cf410fn002, concurrent.futures.as_completed.__name__.__eq__, ["as_completed"], true]

table concurrent_futures_extra410.module_function_modules:
  description: "Verify __module__ attribute of concurrent.futures module-level functions (defined in concurrent.futures._base)"
  kind: python_call_eq
  category: identity
  id_prefix: cf410fm

  columns: [id, function, args, expected]
  rows:
    - [cf410fm001, concurrent.futures.wait.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf410fm002, concurrent.futures.as_completed.__module__.__eq__, ["concurrent.futures._base"], true]

table concurrent_futures_extra410.executor_doc_class_names:
  description: "Verify __doc__.__class__.__name__ for ProcessPoolExecutor, ThreadPoolExecutor (None docstrings) and Future (str docstring)"
  kind: python_call_eq
  category: identity
  id_prefix: cf410dc

  columns: [id, function, args, expected]
  rows:
    - [cf410dc001, concurrent.futures.ProcessPoolExecutor.__doc__.__class__.__name__.__eq__, ["NoneType"], true]
    - [cf410dc002, concurrent.futures.ThreadPoolExecutor.__doc__.__class__.__name__.__eq__, ["NoneType"], true]
    - [cf410dc003, concurrent.futures.Future.__doc__.__class__.__name__.__eq__, ["str"], true]
