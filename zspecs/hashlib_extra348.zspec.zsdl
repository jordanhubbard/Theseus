spec: hashlib_extra348
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "hashlib._hashlib.__name__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.openssl_md5.__name__ == 'openssl_md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.openssl_sha256.__name__ == 'openssl_sha256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.HASH.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.hmac_new.__name__ == 'hmac_new'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib._hashlib.openssl_md5.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib._hashlib is the C extension backing the Python hashlib module. It is accessed as an attribute of the hashlib module (not imported directly). Its __name__ is '_hashlib'."
    - "Note: HASH is the C-level type returned by openssl_md5, openssl_sha256, etc. Its base is object (single-level C type hierarchy)."
    - "Note: hmac_new is the C-level function used by the hmac module for HMAC construction via the _hashlib backend."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib._hashlib.__name__.__eq__('_hashlib')
# hashlib._hashlib.openssl_md5.__name__.__eq__('openssl_md5')
# hashlib._hashlib.openssl_sha256.__name__.__eq__('openssl_sha256')
# hashlib._hashlib.HASH.__name__.__eq__('HASH')
# hashlib._hashlib.HASH.__module__.__eq__('_hashlib')
#
# Wave 348 theme: hashlib._hashlib C extension — module and type identity.
#
# hashlib._hashlib is the C extension (Modules/_hashopenssl.c) backing
# the hashlib module. Its __name__ is '_hashlib'. openssl_md5 and
# openssl_sha256 are C-level constructor functions; their __name__ matches
# the function name. HASH is the C type returned by these constructors;
# its __name__ is 'HASH' and __module__ is '_hashlib'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra348.hashlib_internal_identity:
  description: "hashlib._hashlib.__name__.__eq__('_hashlib')==True / openssl_md5.__name__.__eq__('openssl_md5')==True / openssl_sha256.__name__.__eq__('openssl_sha256')==True / HASH.__name__.__eq__('HASH')==True / HASH.__module__.__eq__('_hashlib')==True — hashlib._hashlib C extension identity: module name is '_hashlib'; openssl_md5 and openssl_sha256 are C-level constructors; HASH is the C type returned by constructors; first hashlibid348 anchor for _hashlib C extension identity"
  kind: python_call_eq
  category: c_extension_identity
  id_prefix: hashlibid348

  columns: [id, function, args, expected, description]
  rows:
    - [hashlib_internal_name,     "_hashlib.__name__.__eq__",            ["_hashlib"],       true, "hashlib._hashlib.__name__ is '_hashlib' — C extension module name (Modules/_hashopenssl.c)"]
    - [openssl_md5_name,          "_hashlib.openssl_md5.__name__.__eq__", ["openssl_md5"],   true, "hashlib._hashlib.openssl_md5.__name__ is 'openssl_md5' — C-level MD5 constructor name"]
    - [openssl_sha256_name,       "_hashlib.openssl_sha256.__name__.__eq__", ["openssl_sha256"], true, "hashlib._hashlib.openssl_sha256.__name__ is 'openssl_sha256' — C-level SHA-256 constructor name"]
    - [hash_type_name,            "_hashlib.HASH.__name__.__eq__",       ["HASH"],           true, "hashlib._hashlib.HASH.__name__ is 'HASH' — C type returned by openssl_* constructors"]
    - [hash_type_module,          "_hashlib.HASH.__module__.__eq__",     ["_hashlib"],       true, "hashlib._hashlib.HASH.__module__ is '_hashlib' — HASH type is defined in the C extension"]

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.__bases__[0].__name__.__eq__('object')
# hashlib._hashlib.hmac_new.__name__.__eq__('hmac_new')
# hashlib._hashlib.openssl_md5.__module__.__eq__('_hashlib')
#
# Wave 348 theme: hashlib._hashlib — HASH base class, hmac_new, and
# constructor module attribute.
#
# HASH.__bases__[0].__name__ is 'object' — HASH is a C type that inherits
# directly from object (single-level C type hierarchy; no Python intermediate).
# hmac_new is the C-level function used by the hmac module for HMAC
# construction; its __name__ is 'hmac_new'. openssl_md5.__module__ is
# '_hashlib' — the C-level constructor is defined in the C extension, not
# in the Python hashlib wrapper.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra348.hashlib_internal_bases_hmac:
  description: "hashlib._hashlib.HASH.__bases__[0].__name__.__eq__('object')==True / hmac_new.__name__.__eq__('hmac_new')==True / openssl_md5.__module__.__eq__('_hashlib')==True — HASH C type inherits directly from object (single-level C hierarchy); hmac_new is the C-level HMAC constructor used by the hmac module; openssl_md5.__module__ confirms the constructor belongs to the _hashlib C extension; first hashlibid348 anchor for HASH bases and hmac_new"
  kind: python_call_eq
  category: c_extension_identity
  id_prefix: hashlibid348

  columns: [id, function, args, expected, description]
  rows:
    - [hash_bases0_name,   "_hashlib.HASH.__bases__[0].__name__.__eq__", ["object"],    true, "hashlib._hashlib.HASH.__bases__[0].__name__ is 'object' — HASH inherits directly from object (C type, single-level hierarchy)"]
    - [hmac_new_name,      "_hashlib.hmac_new.__name__.__eq__",          ["hmac_new"],  true, "hashlib._hashlib.hmac_new.__name__ is 'hmac_new' — C-level HMAC constructor used by the hmac module"]
    - [openssl_md5_module, "_hashlib.openssl_md5.__module__.__eq__",     ["_hashlib"],  true, "hashlib._hashlib.openssl_md5.__module__ is '_hashlib' — C-level constructor defined in the C extension"]

# ---------------------------------------------------------------------------
# hashlib._hashlib.__name__.__eq__('_hashlib') — standalone
#
# hashlib._hashlib.__name__ is '_hashlib'. The C extension is accessed via
# the hashlib module attribute hashlib._hashlib. Its __name__ attribute is
# '_hashlib' — the canonical name of the C extension module, distinct from
# the Python-level 'hashlib' wrapper. This confirms that accessing hashlib._hashlib
# yields the underlying C module, not the wrapper itself.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra348.hashlib_internal_name_is__hashlib:
  description: "hashlib._hashlib.__name__.__eq__('_hashlib') == True — hashlib._hashlib.__name__ is '_hashlib', the C extension module name; accessed via hashlib module attribute, distinct from the Python wrapper 'hashlib'; first standalone for _hashlib.__name__ under hashlibid348"
  category: c_extension_identity
  kind: python_call_eq
  function: _hashlib.__name__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.__name__.__eq__('HASH') — standalone
#
# hashlib._hashlib.HASH.__name__ is 'HASH'. HASH is the C-level type object
# (PyTypeObject) exposed by the _hashlib extension. All openssl_* constructors
# return HASH instances. The __name__ 'HASH' is set in the C source at the
# PyTypeObject.tp_name field. It is not to be confused with the Python-level
# hashlib._hashlib.HASHXOF type which exists for XOF (variable-length output)
# functions like SHAKE.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra348.HASH_name_is_HASH:
  description: "hashlib._hashlib.HASH.__name__.__eq__('HASH') == True — HASH is the C-level type (PyTypeObject) returned by openssl_* constructors; __name__ 'HASH' is set in C source tp_name field; distinct from HASHXOF (XOF/variable-length output); first standalone for HASH.__name__ under hashlibid348"
  category: c_extension_identity
  kind: python_call_eq
  function: _hashlib.HASH.__name__.__eq__
  args: ["HASH"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib._hashlib.HASH.__bases__[0].__name__.__eq__('object') — standalone
#
# hashlib._hashlib.HASH.__bases__[0].__name__ is 'object'. HASH is a C
# extension type that inherits directly from Python's object type — a
# single-level inheritance hierarchy typical of C extension types. It does
# not have intermediate Python base classes. This means HASH instances support
# the standard Python object protocol but have no Python-level parent class
# adding behavior.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra348.HASH_bases0_is_object:
  description: "hashlib._hashlib.HASH.__bases__[0].__name__.__eq__('object') == True — HASH C type inherits directly from Python object type; single-level C type hierarchy with no intermediate Python base classes; HASH instances support standard object protocol; first standalone for HASH.__bases__[0].__name__ under hashlibid348"
  category: c_extension_identity
  kind: python_call_eq
  function: "_hashlib.HASH.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib._hashlib.hmac_new.__name__.__eq__('hmac_new') — standalone
#
# hashlib._hashlib.hmac_new.__name__ is 'hmac_new'. hmac_new is the C-level
# built-in function used internally by the Python hmac module to construct
# HMAC objects when the underlying hash function is implemented via OpenSSL.
# It takes a key, message, and digest name and returns an HMAC object backed
# by the _hashlib C extension.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra348.hmac_new_name_is_hmac_new:
  description: "hashlib._hashlib.hmac_new.__name__.__eq__('hmac_new') == True — hmac_new is the C-level built-in function for HMAC construction (used by the Python hmac module when hash is OpenSSL-backed); takes key, message, and digest name; first standalone for hmac_new.__name__ under hashlibid348"
  category: c_extension_identity
  kind: python_call_eq
  function: _hashlib.hmac_new.__name__.__eq__
  args: ["hmac_new"]
  expected: true
