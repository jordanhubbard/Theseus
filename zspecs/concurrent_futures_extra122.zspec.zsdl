invariant concurrent_futures_extra122.ThreadPoolExecutor_qualname_len_18:
  description: "concurrent.futures.ThreadPoolExecutor.__qualname__.__len__() == 18 — ThreadPoolExecutor.__qualname__ is 'ThreadPoolExecutor' (18 chars: 'Thread'=6+'Pool'=4+'Executor'=8=18); qualname equals name for module-level classes; compare class qualname lengths in spec: Future=6, Executor=8, ThreadPoolExecutor=18, ProcessPoolExecutor=19; ThreadPoolExecutor.__module__ is 'concurrent.futures.thread'; ThreadPoolExecutor.__bases__[0].__name__ is 'Executor'; ThreadPoolExecutor.__mro__.__len__() is 3 ([ThreadPoolExecutor, Executor, object]); ThreadPoolExecutor.submit.__qualname__.__len__() is 25 ('ThreadPoolExecutor.'=19+suffix); NEW in extra122: first standalone ThreadPoolExecutor qualname length invariant in cfexecident122 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__qualname__.__len__"
  args: []
  expected: 18

