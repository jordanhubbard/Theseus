spec: concurrent_futures_extra122
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers: wave 256 theme — concurrent.futures executor and Future class __name__, __qualname__, __module__, and __mro__ identity. NEW in extra122: concurrent.futures.ThreadPoolExecutor.__qualname__=='ThreadPoolExecutor' (len=18); ThreadPoolExecutor.__name__.__len__()==18; ThreadPoolExecutor.__module__=='concurrent.futures.thread'; ThreadPoolExecutor.__bases__[0].__name__=='Executor'; ThreadPoolExecutor.__mro__.__len__()==3; concurrent.futures.ProcessPoolExecutor.__qualname__=='ProcessPoolExecutor' (len=19); ProcessPoolExecutor.__module__=='concurrent.futures.process'; ProcessPoolExecutor.__mro__.__len__()==3; concurrent.futures.Executor.__qualname__=='Executor' (len=8); Executor.__module__=='concurrent.futures._base'; Executor.__mro__.__len__()==2; concurrent.futures.Future.__qualname__=='Future' (len=6); Future.__module__=='concurrent.futures._base'; Future.__mro__.__len__()==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.__qualname__.__len__() == 18. 'ThreadPoolExecutor' is 18 chars: 'Thread'=6+'Pool'=4+'Executor'=8=18. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__() == 19. 'ProcessPoolExecutor' is 19 chars: 'Process'=7+'Pool'=4+'Executor'=8=19. One char longer than ThreadPoolExecutor (19 vs 18) because 'Process'=7 > 'Thread'=6. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "ThreadPoolExecutor.__mro__ == [ThreadPoolExecutor, Executor, object] (length=3). Both ThreadPoolExecutor and ProcessPoolExecutor share the same MRO structure — each inherits directly from Executor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.__qualname__.__len__() == 6. 'Future' is 6 chars. concurrent.futures.Future is Python-defined in _base.py (class='function' methods), unlike asyncio.Future which is a C extension class (method_descriptor methods). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures ThreadPoolExecutor and ProcessPoolExecutor identity
# — extra122
#
# Wave 256 theme: executor class __qualname__, __name__, __module__, __mro__.
#
# ThreadPoolExecutor.__qualname__          == 'ThreadPoolExecutor'  (len=18)
# ThreadPoolExecutor.__name__              == 'ThreadPoolExecutor'  (len=18)
# ThreadPoolExecutor.__module__            == 'concurrent.futures.thread'
# ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'
# ThreadPoolExecutor.__mro__.__len__()     == 3
# ProcessPoolExecutor.__qualname__         == 'ProcessPoolExecutor' (len=19)
# ProcessPoolExecutor.__module__           == 'concurrent.futures.process'
# ProcessPoolExecutor.__mro__.__len__()    == 3
# ---------------------------------------------------------------------------

table concurrent_futures_extra122.cf_executor_class_identity:
  description: "concurrent.futures ThreadPoolExecutor and ProcessPoolExecutor class identity checks in cfexecident122 namespace — wave 256 theme: ThreadPoolExecutor.__qualname__.__eq__('ThreadPoolExecutor')==True (len=18: 'Thread'=6+'Pool'=4+'Executor'=8=18; qualname equals name for module-level classes); ThreadPoolExecutor.__qualname__.__len__()==18; ThreadPoolExecutor.__name__.__len__()==18 (same as qualname since they are equal for top-level classes); ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread')==True (defined in Lib/concurrent/futures/thread.py); ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True (direct subclass of Executor); ThreadPoolExecutor.__mro__.__len__()==3 ([ThreadPoolExecutor, Executor, object], 3-element MRO); ProcessPoolExecutor.__qualname__.__eq__('ProcessPoolExecutor')==True (len=19: 'Process'=7+'Pool'=4+'Executor'=8=19, one char longer than ThreadPoolExecutor because 'Process'=7 > 'Thread'=6); ProcessPoolExecutor.__qualname__.__len__()==19; ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process')==True (defined in Lib/concurrent/futures/process.py); ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True (same direct base as ThreadPoolExecutor); ProcessPoolExecutor.__mro__.__len__()==3 (same MRO depth); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexecident122

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_qn_eq,    "concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__",              ["ThreadPoolExecutor"],         true, "ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' (len=18); verified with Python 3.14.3"]
    - [tpe_qn_len,   "concurrent.futures.ThreadPoolExecutor.__qualname__.__len__",             [],                             18,   "ThreadPoolExecutor.__qualname__.__len__() == 18 ('Thread'=6+'Pool'=4+'Executor'=8=18); verified with Python 3.14.3"]
    - [tpe_nm_len,   "concurrent.futures.ThreadPoolExecutor.__name__.__len__",                 [],                             18,   "ThreadPoolExecutor.__name__.__len__() == 18 (same as qualname for module-level class); verified with Python 3.14.3"]
    - [tpe_mod_eq,   "concurrent.futures.ThreadPoolExecutor.__module__.__eq__",                ["concurrent.futures.thread"],  true, "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (defined in thread.py); verified with Python 3.14.3"]
    - [tpe_base0,    "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__",     ["Executor"],                   true, "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' (direct subclass of Executor); verified with Python 3.14.3"]
    - [tpe_mro_len,  "concurrent.futures.ThreadPoolExecutor.__mro__.__len__",                  [],                             3,    "ThreadPoolExecutor.__mro__.__len__() == 3 ([ThreadPoolExecutor, Executor, object]); verified with Python 3.14.3"]
    - [ppe_qn_eq,    "concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__",             ["ProcessPoolExecutor"],        true, "ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' (len=19, one more than ThreadPoolExecutor); verified with Python 3.14.3"]
    - [ppe_qn_len,   "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__",            [],                             19,   "ProcessPoolExecutor.__qualname__.__len__() == 19 ('Process'=7+'Pool'=4+'Executor'=8=19); verified with Python 3.14.3"]
    - [ppe_mod_eq,   "concurrent.futures.ProcessPoolExecutor.__module__.__eq__",               ["concurrent.futures.process"], true, "ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (defined in process.py); verified with Python 3.14.3"]
    - [ppe_base0,    "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__",    ["Executor"],                   true, "ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' (same base as ThreadPoolExecutor); verified with Python 3.14.3"]
    - [ppe_mro_len,  "concurrent.futures.ProcessPoolExecutor.__mro__.__len__",                 [],                             3,    "ProcessPoolExecutor.__mro__.__len__() == 3 (same MRO depth as ThreadPoolExecutor); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures Executor and Future class identity — extra122
#
# Executor.__qualname__          == 'Executor' (len=8)
# Executor.__name__              == 'Executor' (len=8)
# Executor.__module__            == 'concurrent.futures._base'
# Executor.__bases__[0].__name__ == 'object'
# Executor.__mro__.__len__()     == 2
# Future.__qualname__            == 'Future'   (len=6)
# Future.__name__                == 'Future'   (len=6)
# Future.__module__              == 'concurrent.futures._base'
# Future.__mro__.__len__()       == 2
# ---------------------------------------------------------------------------

table concurrent_futures_extra122.cf_executor_future_base_identity:
  description: "concurrent.futures.Executor and concurrent.futures.Future base class identity checks in cfexecident122 namespace — wave 256 theme: Executor.__qualname__.__eq__('Executor')==True (len=8: 'Executor'=8; the abstract base class for both ThreadPoolExecutor and ProcessPoolExecutor); Executor.__qualname__.__len__()==8; Executor.__module__.__eq__('concurrent.futures._base')==True (defined in Lib/concurrent/futures/_base.py); Executor.__bases__[0].__name__.__eq__('object')==True (Executor is a direct subclass of object); Executor.__mro__.__len__()==2 ([Executor, object], minimal 2-element MRO — contrast with ThreadPoolExecutor and ProcessPoolExecutor which have MRO length 3); Future.__qualname__.__eq__('Future')==True (len=6: 'Future'=6, the shortest qualname in this spec — Future < Executor < ThreadPoolExecutor < ProcessPoolExecutor: 6 < 8 < 18 < 19); Future.__qualname__.__len__()==6; Future.__module__.__eq__('concurrent.futures._base')==True (same module as Executor); Future.__bases__[0].__name__.__eq__('object')==True (direct subclass of object); Future.__mro__.__len__()==2 (same minimal depth as Executor); Future methods (result, cancel, done, exception, set_result, add_done_callback) are Python 'function' class, unlike asyncio.Future methods which are C-level 'method_descriptor'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexecident122a

  columns: [id, function, args, expected, description]
  rows:
    - [ex_qn_eq,    "concurrent.futures.Executor.__qualname__.__eq__",       ["Executor"],                   true, "Executor.__qualname__ == 'Executor' (len=8); verified with Python 3.14.3"]
    - [ex_qn_len,   "concurrent.futures.Executor.__qualname__.__len__",      [],                             8,    "Executor.__qualname__.__len__() == 8; verified with Python 3.14.3"]
    - [ex_mod_eq,   "concurrent.futures.Executor.__module__.__eq__",         ["concurrent.futures._base"],   true, "Executor.__module__ == 'concurrent.futures._base' (defined in _base.py); verified with Python 3.14.3"]
    - [ex_base0,    "concurrent.futures.Executor.__bases__[0].__name__.__eq__", ["object"],                  true, "Executor.__bases__[0].__name__ == 'object' (direct subclass of object); verified with Python 3.14.3"]
    - [ex_mro_len,  "concurrent.futures.Executor.__mro__.__len__",           [],                             2,    "Executor.__mro__.__len__() == 2 ([Executor, object], shorter than subclasses at 3); verified with Python 3.14.3"]
    - [fut_qn_eq,   "concurrent.futures.Future.__qualname__.__eq__",         ["Future"],                     true, "Future.__qualname__ == 'Future' (len=6, shortest qualname in spec); verified with Python 3.14.3"]
    - [fut_qn_len,  "concurrent.futures.Future.__qualname__.__len__",        [],                             6,    "Future.__qualname__.__len__() == 6 ('Future'=6, shortest: Future<Executor<ThreadPoolExecutor<ProcessPoolExecutor); verified with Python 3.14.3"]
    - [fut_mod_eq,  "concurrent.futures.Future.__module__.__eq__",           ["concurrent.futures._base"],   true, "Future.__module__ == 'concurrent.futures._base' (same module as Executor); verified with Python 3.14.3"]
    - [fut_base0,   "concurrent.futures.Future.__bases__[0].__name__.__eq__", ["object"],                    true, "Future.__bases__[0].__name__ == 'object' (direct subclass of object, like Executor); verified with Python 3.14.3"]
    - [fut_mro_len, "concurrent.futures.Future.__mro__.__len__",             [],                             2,    "Future.__mro__.__len__() == 2 ([Future, object], same minimal depth as Executor); verified with Python 3.14.3"]

