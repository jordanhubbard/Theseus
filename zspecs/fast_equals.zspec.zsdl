spec: fast_equals
version: ">=5.0.0"
backend: node(fast-equals)

docs: https://github.com/planttheidea/fast-equals#readme

provenance:
  derived_from:
    - "fast-equals README — https://github.com/planttheidea/fast-equals#readme"
    - "Test vectors verified with fast-equals via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "fast-equals source"
  notes:
    - "Performance-focused deep/shallow equality utility, used by react-redux and other hot paths."
    - "Install: npm install fast-equals"
    - "Functions: deepEqual, shallowEqual, sameValueEqual, sameValueZeroEqual, plus circular-aware variants."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure boolean predicates; never throw."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# deepEqual — recursive
table fast_equals.deepEqual:
  kind: node_module_call_eq
  category: deepEqual
  function: deepEqual
  id_prefix: deep

  columns: [id, args, expected]
  rows:
    - [identical_objects,        [{a: 1}, {a: 1}],                     true]
    - [different_values,         [{a: 1}, {a: 2}],                     false]
    - [nested_arrays,            [{a: [1, 2]}, {a: [1, 2]}],           true]
    - [nested_arrays_diff,       [{a: [1, 2]}, {a: [1, 3]}],           false]
    - [primitives_eq,            [42, 42],                              true]
    - [primitives_ne,            [42, 43],                              false]
    - [string_eq,                ["abc", "abc"],                         true]
    - [array_diff_lengths,       [[1, 2, 3], [1, 2]],                   false]
    - [empty_objects,            [{}, {}],                              true]
    - [empty_arrays,             [[], []],                              true]
    - [extra_key,                [{a: 1}, {a: 1, b: 2}],                false]
    - [null_vs_undefined,        [~, ~],                                 true]

# shallowEqual — top-level only
table fast_equals.shallowEqual:
  kind: node_module_call_eq
  category: shallowEqual
  function: shallowEqual
  id_prefix: shallow

  columns: [id, args, expected]
  rows:
    - [identical_top,         [{a: 1, b: 2}, {a: 1, b: 2}],         true]
    - [different_top,         [{a: 1, b: 2}, {a: 1, b: 3}],         false]
    - [primitive,             [1, 1],                                 true]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:51:33Z
  iterations: 1
  pass_count: 15
  fail_count: 0
  total_invariants: 15
  notes: Synthesis succeeded in 1 iteration(s). 15 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
