spec: asyncio_extra27
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "https://docs.python.org/3/library/asyncio-exceptions.html — asyncio Exceptions"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/exceptions.py"
    - "CPython source: Lib/asyncio/mixins.py"
  notes:
    - "This spec extends asyncio.zspec.zsdl and prior extras through asyncio_extra26.zspec.zsdl."
    - "asyncio_extra26 covers: Queue/PriorityQueue/LifoQueue __module__ (asyncio.queues); Lock/Event/Semaphore __module__ (asyncio.locks); Task/Future __module__ (_asyncio); gather/sleep/create_task __qualname__ and __module__."
    - "asyncio_extra9 covers: Condition/BoundedSemaphore __module__ (asyncio.locks); PriorityQueue/LifoQueue __bases__[0].__name__ (Queue); CancelledError/TimeoutError/InvalidStateError __bases__[0].__name__; InvalidStateError/IncompleteReadError __module__."
    - "NOT yet covered in any prior spec: asyncio.Queue.__bases__[0].__name__ (== '_LoopBoundMixin') in extra27 namespace."
    - "NOT yet covered: asyncio.QueueEmpty.__bases__[0].__name__ (== 'Exception') in extra27 namespace."
    - "NOT yet covered: asyncio.QueueFull.__bases__[0].__name__ (== 'Exception') in extra27 namespace."
    - "NOT yet covered: asyncio.CancelledError.__module__ (== 'asyncio.exceptions') in extra27 namespace."
    - "NOT yet covered: asyncio.TimeoutError.__module__ (== 'builtins') in extra27 namespace."
    - "NOT yet covered: asyncio.InvalidStateError.__module__ (== 'asyncio.exceptions') in extra27 namespace."
    - "Queue.__bases__[0].__name__ == '_LoopBoundMixin' — asyncio.Queue inherits from asyncio.mixins._LoopBoundMixin (length 15)."
    - "QueueEmpty.__bases__[0].__name__ == 'Exception' — QueueEmpty is a direct Exception subclass (length 9)."
    - "QueueFull.__bases__[0].__name__ == 'Exception' — QueueFull is a direct Exception subclass (length 9)."
    - "CancelledError.__module__ == 'asyncio.exceptions' — defined in Lib/asyncio/exceptions.py (length 18)."
    - "TimeoutError.__module__ == 'builtins' — asyncio.TimeoutError is the builtin TimeoutError (length 8)."
    - "InvalidStateError.__module__ == 'asyncio.exceptions' — defined in Lib/asyncio/exceptions.py (length 18)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Queue exception class base names — extra27 namespace
#
# asyncio.QueueEmpty and asyncio.QueueFull are both direct subclasses of
# Exception. Their __bases__[0].__name__ == 'Exception' (length 9). No prior
# spec checks __bases__[0].__name__ for either of these queue exception classes.
# ---------------------------------------------------------------------------

table asyncio_extra27.queue_exception_bases:
  description: "asyncio QueueEmpty and QueueFull __bases__[0].__name__ values in extra27 namespace"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: qexcbase27

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [QueueEmpty, QueueEmpty.__bases__.__getitem__, [0], "Exception", __name__, [], "asyncio.QueueEmpty.__bases__[0].__name__ == 'Exception'"]
    - [QueueFull,  QueueFull.__bases__.__getitem__,  [0], "Exception", __name__, [], "asyncio.QueueFull.__bases__[0].__name__ == 'Exception'"]

# ---------------------------------------------------------------------------
# Exception class __module__ table — extra27 namespace
#
# asyncio.CancelledError.__module__ == 'asyncio.exceptions' (length 18).
# asyncio.TimeoutError is the builtin TimeoutError, so its __module__ is
# 'builtins' (length 8) — not 'asyncio' or 'asyncio.exceptions'.
# asyncio.InvalidStateError.__module__ == 'asyncio.exceptions' (length 18).
# No prior spec groups these three exception __module__ values in one table.
# ---------------------------------------------------------------------------

table asyncio_extra27.exception_modules:
  description: "asyncio exception class __module__ values in extra27 namespace"
  kind: python_call_eq
  category: class_modules
  id_prefix: excmod27

  columns: [id, function, args, expected]
  rows:
    - [CancelledError,    CancelledError.__module__.__eq__,    ["asyncio.exceptions"], true]
    - [TimeoutError,      TimeoutError.__module__.__eq__,      ["builtins"],           true]
    - [InvalidStateError, InvalidStateError.__module__.__eq__, ["asyncio.exceptions"], true]

# ---------------------------------------------------------------------------
# Exception class __module__ length table — extra27 namespace
#
# Lengths: asyncio.exceptions(18), builtins(8), asyncio.exceptions(18).
# ---------------------------------------------------------------------------

table asyncio_extra27.exception_module_lengths:
  description: "asyncio exception class __module__ lengths in extra27 namespace"
  kind: python_call_eq
  category: class_modules
  id_prefix: excmodlen27

  columns: [id, function, args, expected]
  rows:
    - [CancelledError,    CancelledError.__module__.__len__,    [], 18]
    - [TimeoutError,      TimeoutError.__module__.__len__,      [], 8]
    - [InvalidStateError, InvalidStateError.__module__.__len__, [], 18]

# ---------------------------------------------------------------------------
# asyncio.Queue.__bases__[0].__name__ — standalone extra27 invariant
#
# asyncio.Queue inherits from asyncio.mixins._LoopBoundMixin, not from object
# directly. Queue.__bases__[0].__name__ == '_LoopBoundMixin' (length 15).
# No prior spec has checked Queue.__bases__[0].__name__. This is an unusual
# base class — it enforces that Queue operations occur within an event loop.
# ---------------------------------------------------------------------------

invariant asyncio_extra27.Queue.bases_name:
  description: "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin' — Queue inherits from the loop-bound mixin"
  category: class_hierarchy
  kind: python_call_eq
  function: Queue.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_LoopBoundMixin"
