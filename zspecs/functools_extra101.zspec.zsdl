spec: functools_extra101
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra100

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra100.zspec.zsdl."
    - "This spec covers: functools partial C-type method class names + partialmethod Python-class method class names; partial.__dict__ membership; functools.__all__ class name and length (Wave 254)."
    - "functools.partial.__new__.__class__.__name__ == 'builtin_function_or_method' — __new__ is a C-level static method. Verified with Python 3.14.3."
    - "functools.partial.__repr__.__class__.__name__ == 'wrapper_descriptor' — __repr__ is a C slot wrapper. Verified with Python 3.14.3."
    - "functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor' — __call__ is a C slot wrapper. Verified with Python 3.14.3."
    - "functools.partial.__reduce__.__class__.__name__ == 'method_descriptor' — __reduce__ is a C method descriptor. Verified with Python 3.14.3."
    - "functools.partial.__setstate__.__class__.__name__ == 'method_descriptor' — __setstate__ is a C method descriptor. Verified with Python 3.14.3."
    - "functools.partial.__getattribute__.__class__.__name__ == 'wrapper_descriptor' — __getattribute__ is a C slot wrapper. Verified with Python 3.14.3."
    - "functools.partial.__init__.__class__.__name__ == 'wrapper_descriptor' — __init__ is a C slot wrapper. Verified with Python 3.14.3."
    - "functools.partial.__class_getitem__.__class__.__name__ == 'builtin_function_or_method' — __class_getitem__ is a C built-in method. Verified with Python 3.14.3."
    - "functools.partial.__dict__.__contains__('func') == True — partial exposes the wrapped function as .func. Verified with Python 3.14.3."
    - "functools.partial.__dict__.__contains__('args') == True — partial exposes frozen positional args as .args. Verified with Python 3.14.3."
    - "functools.partial.__dict__.__contains__('keywords') == True — partial exposes frozen keyword args as .keywords. Verified with Python 3.14.3."
    - "functools.partialmethod.__init__.__class__.__name__ == 'wrapper_descriptor' — __init__ inherited from object. Verified with Python 3.14.3."
    - "functools.partialmethod.__repr__.__class__.__name__ == 'function' — __repr__ is a Python function. Verified with Python 3.14.3."
    - "functools.partialmethod.__get__.__class__.__name__ == 'function' — __get__ is a Python function (descriptor protocol). Verified with Python 3.14.3."
    - "functools.partialmethod.__isabstractmethod__.__class__.__name__ == 'property' — __isabstractmethod__ is a Python property. Verified with Python 3.14.3."
    - "functools.__all__.__class__.__name__ == 'list'. Verified with Python 3.14.3."
    - "functools.__all__.__len__() == 15. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: partial C-type method class names
#
# Wave 254 theme: functools.partial C-type method class names.
#
# functools.partial.__new__.__class__.__name__ == 'builtin_function_or_method'
# functools.partial.__repr__.__class__.__name__ == 'wrapper_descriptor'
# functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor'
# functools.partial.__reduce__.__class__.__name__ == 'method_descriptor'
# functools.partial.__setstate__.__class__.__name__ == 'method_descriptor'
# functools.partial.__getattribute__.__class__.__name__ == 'wrapper_descriptor'
# functools.partial.__init__.__class__.__name__ == 'wrapper_descriptor'
# functools.partial.__class_getitem__.__class__.__name__ == 'builtin_function_or_method'
#
# partial is a C extension type; its methods are C-level descriptors.
# New to extra101.
# ---------------------------------------------------------------------------

table functools_extra101.partial_method_class_names:
  description: "functools.partial C-type method class names: __new__, __repr__, __call__, __reduce__, __setstate__, __getattribute__, __init__, __class_getitem__; wave 254; new to extra101"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartialmethods101

  columns: [id, function, args, expected, description]
  rows:
    - [partial_new_class_name_eq_builtin,
       "partial.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.partial.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — partial is a C extension type; __new__ is a C-level static method defined in Modules/_functoolsmodule.c; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra101"]
    - [partial_repr_class_name_eq_wrapper_descriptor,
       "partial.__repr__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__repr__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial.__repr__ is a C slot wrapper defined in Modules/_functoolsmodule.c; its __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra101"]
    - [partial_call_class_name_eq_wrapper_descriptor,
       "partial.__call__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__call__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial.__call__ is a C slot wrapper implementing the tp_call slot; __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra101"]
    - [partial_reduce_class_name_eq_method_descriptor,
       "partial.__reduce__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.partial.__reduce__.__class__.__name__.__eq__('method_descriptor') == True — partial.__reduce__ is a C method descriptor for pickling support; __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra101"]
    - [partial_setstate_class_name_eq_method_descriptor,
       "partial.__setstate__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.partial.__setstate__.__class__.__name__.__eq__('method_descriptor') == True — partial.__setstate__ is a C method descriptor for unpickling support; __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra101"]
    - [partial_getattribute_class_name_eq_wrapper_descriptor,
       "partial.__getattribute__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__getattribute__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial.__getattribute__ is a C slot wrapper for attribute lookup; __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra101"]
    - [partial_init_class_name_eq_wrapper_descriptor,
       "partial.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial.__init__ is a C slot wrapper implementing tp_init; __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra101"]
    - [partial_class_getitem_class_name_eq_builtin,
       "partial.__class_getitem__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.partial.__class_getitem__.__class__.__name__.__eq__('builtin_function_or_method') == True — partial.__class_getitem__ supports generics syntax (partial[T]); it is a C built-in method; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra101"]

# ---------------------------------------------------------------------------
# Table 2: partial.__dict__ membership for attributes
#
# Wave 254 theme: functools.partial attribute membership in type __dict__.
#
# functools.partial.__dict__.__contains__('func') == True
# functools.partial.__dict__.__contains__('args') == True
# functools.partial.__dict__.__contains__('keywords') == True
# functools.partial.__dict__.__contains__('__doc__') == True
# functools.partial.__dict__.__contains__('__module__') == True
#
# partial exposes func, args, keywords as data descriptors in its type __dict__.
# New to extra101.
# ---------------------------------------------------------------------------

table functools_extra101.partial_dict_membership:
  description: "functools.partial.__dict__ membership for func, args, keywords, __doc__, __module__; C extension type attributes; wave 254; new to extra101"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartialmethods101

  columns: [id, function, args, expected, description]
  rows:
    - [partial_dict_contains_func,
       "partial.__dict__.__contains__",
       ["func"],
       true,
       "functools.partial.__dict__.__contains__('func') == True — partial exposes the wrapped callable as a data descriptor 'func' in its type __dict__; mappingproxy.__contains__('func') returns True; new to extra101"]
    - [partial_dict_contains_args,
       "partial.__dict__.__contains__",
       ["args"],
       true,
       "functools.partial.__dict__.__contains__('args') == True — partial exposes the frozen positional arguments tuple as a data descriptor 'args' in its type __dict__; mappingproxy.__contains__('args') returns True; new to extra101"]
    - [partial_dict_contains_keywords,
       "partial.__dict__.__contains__",
       ["keywords"],
       true,
       "functools.partial.__dict__.__contains__('keywords') == True — partial exposes the frozen keyword arguments dict as a data descriptor 'keywords' in its type __dict__; mappingproxy.__contains__('keywords') returns True; new to extra101"]
    - [partial_dict_contains_doc,
       "partial.__dict__.__contains__",
       ["__doc__"],
       true,
       "functools.partial.__dict__.__contains__('__doc__') == True — partial's type __dict__ contains the docstring descriptor '__doc__'; mappingproxy.__contains__('__doc__') returns True; new to extra101"]
    - [partial_dict_contains_module,
       "partial.__dict__.__contains__",
       ["__module__"],
       true,
       "functools.partial.__dict__.__contains__('__module__') == True — partial's type __dict__ contains '__module__' set to 'functools'; mappingproxy.__contains__('__module__') returns True; new to extra101"]

