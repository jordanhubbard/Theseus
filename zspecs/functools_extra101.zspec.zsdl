# __init__ is inherited wrapper_descriptor from object; __isabstractmethod__ is a property.
# New to extra101.
# ---------------------------------------------------------------------------

table functools_extra101.partialmethod_method_class_names:
  description: "functools.partialmethod Python-class method class names: __init__ (wrapper_descriptor), __repr__ (function), __get__ (function), __isabstractmethod__ (property); wave 254; new to extra101"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartialmethods101

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_init_class_name_eq_wrapper_descriptor,
       "partialmethod.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partialmethod.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — partialmethod does not define its own __init__; it inherits __init__ from object which is a C wrapper_descriptor; __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra101"]
    - [partialmethod_repr_class_name_eq_function,
       "partialmethod.__repr__.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.partialmethod.__repr__.__class__.__name__.__eq__('function') == True — partialmethod.__repr__ is a Python function defined in Lib/functools.py as 'def __repr__(self):'; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra101"]
    - [partialmethod_get_class_name_eq_function,
       "partialmethod.__get__.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.partialmethod.__get__.__class__.__name__.__eq__('function') == True — partialmethod.__get__ is a Python function implementing the descriptor protocol in Lib/functools.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra101"]
    - [partialmethod_isabstractmethod_class_name_eq_property,
       "partialmethod.__isabstractmethod__.__class__.__name__.__eq__",
       ["property"],
       true,
       "functools.partialmethod.__isabstractmethod__.__class__.__name__.__eq__('property') == True — partialmethod.__isabstractmethod__ is a Python property defined in Lib/functools.py to support abstract method detection; __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra101"]

