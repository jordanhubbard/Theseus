spec: trace_extra4
version: ">=3.3"
backend: python_module(trace)

docs: https://docs.python.org/3/library/trace.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/trace.html — Python trace documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/trace.py"
    - "trace.zspec.zsdl — covers Trace/__name__/__module__, CoverageResults/__name__/__module__, Trace/__bases__[0]/__name__, CoverageResults/__bases__[0]/__name__, Trace methods __name__ (run/runfunc/runctx/results), CoverageResults methods __name__ (update/write_results), trace.__name__"
    - "trace_extra.zspec.zsdl — covers Trace/__name__/__module__, CoverageResults/__name__, Trace/__bases__[0]/__name__, PRAGMA_NOCOVER/__class__/__name__"
    - "trace_extra2.zspec.zsdl — covers Trace/__qualname__, CoverageResults/__qualname__, CoverageResults/__module__, find_lines_from_code/__name__/__module__/__qualname__, find_executable_linenos/__name__/__module__/__qualname__"
    - "trace_extra3.zspec.zsdl — covers Trace method __qualname__ (run/runfunc/runctx/results), CoverageResults method __qualname__ (update/write_results), Trace.run/__module__, Trace.results/__module__, Trace/__bases__[0]/__name__, CoverageResults/__bases__[0]/__name__"
  notes:
    - "This spec extends trace.zspec.zsdl through trace_extra3.zspec.zsdl."
    - "Focus: Trace.__bases__.__len__ (base count); Trace method __class__.__name__ (type checks); CoverageResults method __module__ (update/write_results); Trace.runfunc/__module__ and Trace.runctx/__module__ (extra3 covers only run and results)."
    - "Trace has exactly one direct base class (object): len(Trace.__bases__) == 1."
    - "CoverageResults has exactly one direct base class (object): len(CoverageResults.__bases__) == 1."
    - "Trace methods are plain Python functions: __class__.__name__ == 'function'."
    - "CoverageResults.update.__module__ == 'trace' — defined in Lib/trace.py."
    - "CoverageResults.write_results.__module__ == 'trace' — defined in Lib/trace.py."
    - "Trace.runfunc.__module__ == 'trace' — not covered by trace_extra3 (which covers run and results only)."
    - "Trace.runctx.__module__ == 'trace' — not covered by trace_extra3."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Trace raises ValueError on invalid constructor arguments."
  stderr: "null"
  stickiness: "N/A — Trace instances are independent."
  codes: {}

# ---------------------------------------------------------------------------
# Base class count
# No prior trace spec checks __bases__.__len__ for Trace or CoverageResults.
# ---------------------------------------------------------------------------

invariant trace_extra4.Trace.bases_len:
  description: "len(trace.Trace.__bases__) == 1 — Trace has exactly one direct base class"
  category: hierarchy
  kind: python_call_eq
  function: Trace.__bases__.__len__
  args: []
  expected: 1

invariant trace_extra4.CoverageResults.bases_len:
  description: "len(trace.CoverageResults.__bases__) == 1 — CoverageResults has exactly one direct base class"
  category: hierarchy
  kind: python_call_eq
  function: CoverageResults.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Trace method type checks — __class__.__name__ == 'function'
# No prior trace spec verifies that Trace methods are plain Python functions.
# ---------------------------------------------------------------------------

table trace_extra4.Trace_method_types:
  description: "Trace methods are plain Python functions"
  kind: python_call_eq
  category: method_types
  id_prefix: Trace_mtype

  columns: [id, function, args, expected]
  rows:
    - [run,     Trace.run.__class__.__name__.__eq__,     ["function"], true]
    - [runfunc, Trace.runfunc.__class__.__name__.__eq__, ["function"], true]
    - [runctx,  Trace.runctx.__class__.__name__.__eq__,  ["function"], true]
    - [results, Trace.results.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# CoverageResults method __module__ checks
# trace_extra3 covers Trace.run.__module__ and Trace.results.__module__.
# No prior spec covers CoverageResults method __module__.
# ---------------------------------------------------------------------------

invariant trace_extra4.CoverageResults.update.module:
  description: "trace.CoverageResults.update.__module__ == 'trace'"
  category: method_attrs
  kind: python_call_eq
  function: CoverageResults.update.__module__.__eq__
  args: ["trace"]
  expected: true

invariant trace_extra4.CoverageResults.write_results.module:
  description: "trace.CoverageResults.write_results.__module__ == 'trace'"
  category: method_attrs
  kind: python_call_eq
  function: CoverageResults.write_results.__module__.__eq__
  args: ["trace"]
  expected: true

# ---------------------------------------------------------------------------
# Trace.runfunc and Trace.runctx __module__ checks
# trace_extra3 covers Trace.run.__module__ and Trace.results.__module__ only.
# runfunc and runctx are missing from the method __module__ coverage.
# ---------------------------------------------------------------------------

invariant trace_extra4.Trace.runfunc.module:
  description: "trace.Trace.runfunc.__module__ == 'trace'"
  category: method_attrs
  kind: python_call_eq
  function: Trace.runfunc.__module__.__eq__
  args: ["trace"]
  expected: true

invariant trace_extra4.Trace.runctx.module:
  description: "trace.Trace.runctx.__module__ == 'trace'"
  category: method_attrs
  kind: python_call_eq
  function: Trace.runctx.__module__.__eq__
  args: ["trace"]
  expected: true
