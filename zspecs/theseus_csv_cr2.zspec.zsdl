spec: theseus_csv_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_csv_cr2)
blocks: csv

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html"
  notes:
    - "Clean-room extended CSV processing. Do NOT import csv."
    - "DictReader(f, fieldnames=None): reads CSV rows as dicts."
    - "DictWriter(f, fieldnames): writes dicts as CSV rows."
    - "Dialect: customizable quoting, delimiter, line terminator."
    - "csv2_dictreader(): DictReader(['name,age', 'alice,30'])[0]['name'] == 'alice'."
    - "csv2_dictwriter(): DictWriter write + read roundtrip recovers values."
    - "csv2_dialect_pipe(): reader with delimiter='|' splits on pipe."
    - "Export: DictReader, DictWriter, Dialect."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_csv_cr2.dictreader:
  description: "DictReader parses CSV row into dict with correct 'name' key"
  category: dictreader
  kind: python_call_eq
  function: csv2_dictreader
  args: []
  expected: "alice"

invariant theseus_csv_cr2.dictwriter:
  description: "DictWriter roundtrip recovers written value"
  category: dictwriter
  kind: python_call_eq
  function: csv2_dictwriter
  args: []
  expected: true

invariant theseus_csv_cr2.dialect_pipe:
  description: "reader with delimiter='|' splits 'a|b|c' into 3 fields"
  category: dialect
  kind: python_call_eq
  function: csv2_dialect_pipe
  args: []
  expected: ["a", "b", "c"]
