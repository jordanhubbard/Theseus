spec: abc_extra2206
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "abc.zspec.zsdl"
    - "abc_extra.zspec.zsdl"
    - "abc_extra2.zspec.zsdl"
    - "abc_extra2056.zspec.zsdl"
  notes:
    - "Wave _extra2206: rich comparison operator protocol dict-presence checks for abc classes."
    - "Covers __lt__, __le__, __gt__, __ge__, __eq__, __ne__ presence in ABCMeta, ABC, abstractmethod class dicts."
    - "abc.ABCMeta is the metaclass for abstract base classes; it defines __instancecheck__ and __subclasscheck__ but no comparison operators."
    - "abc.ABC is the helper base class for creating ABCs; it defines no comparison operators in its own __dict__."
    - "abc.abstractmethod is a function decorator; it defines no comparison operators."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra2206.ABCMeta_comparison_protocol:
  description: "abc.ABCMeta __lt__/__le__/__gt__/__ge__/__eq__/__ne__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2206

  columns: [id, function, args, expected]
  rows:
    - ["ab2206001", "abc.ABCMeta.__dict__.__contains__", ["__lt__"], false]
    - ["ab2206002", "abc.ABCMeta.__dict__.__contains__", ["__le__"], false]
    - ["ab2206003", "abc.ABCMeta.__dict__.__contains__", ["__gt__"], false]
    - ["ab2206004", "abc.ABCMeta.__dict__.__contains__", ["__ge__"], false]
    - ["ab2206005", "abc.ABCMeta.__dict__.__contains__", ["__eq__"], false]
    - ["ab2206006", "abc.ABCMeta.__dict__.__contains__", ["__ne__"], false]

