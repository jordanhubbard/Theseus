spec: itertools_extra2206
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2206: rich comparison operator protocol dict-presence — __lt__, __le__, __gt__, __ge__, __eq__, __ne__."
    - "None of the itertools iterator types define any comparison operators in their own __dict__. All are C extension types that inherit identity comparison from object."
    - "itertools.chain does define __class_getitem__, __doc__, __getattribute__, __iter__, __module__, __new__, __next__ in its own __dict__."
    - "itertools.cycle does define __doc__, __iter__, __module__, __new__, __next__ in its own __dict__."
    - "itertools.count does define __doc__, __iter__, __module__, __new__, __next__, __repr__ in its own __dict__."
    - "itertools.zip_longest does define __doc__, __iter__, __module__, __new__, __next__ in its own __dict__."
    - "itertools.product does define __doc__, __iter__, __module__, __new__, __next__, __sizeof__ in its own __dict__."
    - "itertools.combinations does define __doc__, __iter__, __module__, __new__, __next__, __sizeof__ in its own __dict__."
    - "itertools.permutations does define __doc__, __iter__, __module__, __new__, __next__, __sizeof__ in its own __dict__."
    - "itertools.islice does define __doc__, __iter__, __module__, __new__, __next__ in its own __dict__."
    - "itertools.repeat does define __doc__, __iter__, __length_hint__, __module__, __new__, __next__, __repr__ in its own __dict__."
    - "itertools.starmap, compress, dropwhile, filterfalse, groupby, accumulate, takewhile, pairwise each define __doc__, __iter__, __module__, __new__, __next__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table itertools_extra2206.chain_comparison_protocol:
  description: "itertools.chain dict-presence — no comparison operators; defines iterator protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2206

  columns: [id, function, args, expected]
  rows:
    - ["it2206001", "itertools.chain.__dict__.__contains__", ["__lt__"], false]
    - ["it2206002", "itertools.chain.__dict__.__contains__", ["__le__"], false]
    - ["it2206003", "itertools.chain.__dict__.__contains__", ["__gt__"], false]
    - ["it2206004", "itertools.chain.__dict__.__contains__", ["__ge__"], false]
    - ["it2206005", "itertools.chain.__dict__.__contains__", ["__eq__"], false]
    - ["it2206006", "itertools.chain.__dict__.__contains__", ["__ne__"], false]
    - ["it2206007", "itertools.chain.__dict__.__contains__", ["__iter__"], true]
    - ["it2206008", "itertools.chain.__dict__.__contains__", ["__next__"], true]

