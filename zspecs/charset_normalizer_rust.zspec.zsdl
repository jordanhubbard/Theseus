  function: charset_normalizer_best_notnone
  args: []
  expected: true

invariant charset_normalizer_rust.version_nonempty:
  description: "charset_normalizer.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: charset_normalizer_version_nonempty
  args: []
  expected: true

