spec: pathlib_extra452
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib.Path property names and descriptor identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Confirms that Path attributes name, stem, suffix, suffixes, parent, parents, parts, drive, root, anchor are all property descriptors"
    - "Checks __class__.__name__ of each descriptor object against the string 'property'"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra452.path_properties:
  description: "Confirm pathlib.Path attributes are property descriptors"
  kind: python_call_eq
  category: class_identity
  id_prefix: PPR

  columns: [id, function, args, expected]
  rows:
    - [PPR001, pathlib.Path.name.__class__.__name__.__eq__,    ["property"], true]
    - [PPR002, pathlib.Path.stem.__class__.__name__.__eq__,    ["property"], true]
    - [PPR003, pathlib.Path.suffix.__class__.__name__.__eq__,  ["property"], true]
    - [PPR004, pathlib.Path.suffixes.__class__.__name__.__eq__, ["property"], true]
    - [PPR005, pathlib.Path.parent.__class__.__name__.__eq__,  ["property"], true]
    - [PPR006, pathlib.Path.parents.__class__.__name__.__eq__, ["property"], true]
    - [PPR007, pathlib.Path.parts.__class__.__name__.__eq__,   ["property"], true]
    - [PPR008, pathlib.Path.drive.__class__.__name__.__eq__,   ["property"], true]
    - [PPR009, pathlib.Path.root.__class__.__name__.__eq__,    ["property"], true]
    - [PPR010, pathlib.Path.anchor.__class__.__name__.__eq__,  ["property"], true]
