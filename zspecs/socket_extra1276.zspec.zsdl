spec: socket_extra1276
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "_socket_extra.zspec.zsdl — covers the _socket C-extension level checks."
    - "_socket.zspec.zsdl — covers low-level socket constants and types."
  notes:
    - "Wave 532 (_extra1276): class attribute TYPE checks. socket.socket.__subclasses__() returns a list; socket.socket.__mro__ and socket.socket.__bases__ are tuples. Same pattern applied to socket.error and socket.timeout."
    - "socket.socket.__mro__ == (socket, socket, object) on CPython — the inner socket class wraps the C extension. socket.socket.__bases__ == (socket,). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error is an alias for OSError. socket.timeout is an alias for TimeoutError. Both have tuple __mro__ and __bases__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1276.socket_class_type_checks:
  description: "socket.socket __subclasses__() is a list; __mro__ and __bases__ are tuples — direct class attribute type checks"
  kind: python_call_eq
  category: class_type_checks
  id_prefix: sk1276sc
  columns: [id, function, args, expected]
  rows:
    - [sk1276sc001, socket.socket.__subclasses__().__class__.__name__.__eq__, ["list"],  true]
    - [sk1276sc002, socket.socket.__subclasses__().__class__.__name__.__eq__, ["tuple"], false]
    - [sk1276sc003, socket.socket.__mro__.__class__.__name__.__eq__,         ["tuple"], true]
    - [sk1276sc004, socket.socket.__mro__.__class__.__name__.__eq__,         ["list"],  false]
    - [sk1276sc005, socket.socket.__bases__.__class__.__name__.__eq__,       ["tuple"], true]
    - [sk1276sc006, socket.socket.__bases__.__class__.__name__.__eq__,       ["list"],  false]
    - [sk1276sc007, socket.socket.__mro__.__class__.__bases__.__class__.__name__.__eq__,   ["tuple"], true]
    - [sk1276sc008, socket.socket.__bases__.__class__.__mro__.__class__.__name__.__eq__,   ["tuple"], true]
    - [sk1276sc009, socket.socket.__subclasses__().__class__.__mro__.__class__.__name__.__eq__, ["tuple"], true]
    - [sk1276sc010, socket.socket.__mro__.__class__.__name__.__eq__,         ["set"],   false]
    - [sk1276sc011, socket.socket.__bases__.__class__.__name__.__eq__,       ["set"],   false]
    - [sk1276sc012, socket.socket.__subclasses__().__class__.__name__.__eq__, ["set"],   false]

table socket_extra1276.error_timeout_class_type_checks:
  description: "socket.error and socket.timeout __subclasses__() is a list; __mro__ and __bases__ are tuples — both are OSError aliases"
  kind: python_call_eq
  category: class_type_checks
  id_prefix: sk1276et
  columns: [id, function, args, expected]
  rows:
    - [sk1276et001, socket.error.__subclasses__().__class__.__name__.__eq__,   ["list"],  true]
    - [sk1276et002, socket.error.__subclasses__().__class__.__name__.__eq__,   ["tuple"], false]
    - [sk1276et003, socket.error.__mro__.__class__.__name__.__eq__,            ["tuple"], true]
    - [sk1276et004, socket.error.__mro__.__class__.__name__.__eq__,            ["list"],  false]
    - [sk1276et005, socket.error.__bases__.__class__.__name__.__eq__,          ["tuple"], true]
    - [sk1276et006, socket.error.__bases__.__class__.__name__.__eq__,          ["list"],  false]
    - [sk1276et007, socket.timeout.__subclasses__().__class__.__name__.__eq__, ["list"],  true]
    - [sk1276et008, socket.timeout.__subclasses__().__class__.__name__.__eq__, ["tuple"], false]
    - [sk1276et009, socket.timeout.__mro__.__class__.__name__.__eq__,         ["tuple"], true]
    - [sk1276et010, socket.timeout.__mro__.__class__.__name__.__eq__,         ["list"],  false]
    - [sk1276et011, socket.timeout.__bases__.__class__.__name__.__eq__,       ["tuple"], true]
    - [sk1276et012, socket.timeout.__bases__.__class__.__name__.__eq__,       ["list"],  false]

table socket_extra1276.class_neg_checks:
  description: "socket.socket, socket.error, socket.timeout class attribute types are not dict, frozenset, or str — negative identity checks"
  kind: python_call_eq
  category: class_neg_checks
  id_prefix: sk1276ng
  columns: [id, function, args, expected]
  rows:
    - [sk1276ng001, socket.socket.__subclasses__().__class__.__name__.__eq__, ["dict"],      false]
    - [sk1276ng002, socket.socket.__subclasses__().__class__.__name__.__eq__, ["frozenset"], false]
    - [sk1276ng003, socket.socket.__mro__.__class__.__name__.__eq__,          ["dict"],      false]
    - [sk1276ng004, socket.socket.__mro__.__class__.__name__.__eq__,          ["frozenset"], false]
    - [sk1276ng005, socket.socket.__bases__.__class__.__name__.__eq__,        ["dict"],      false]
    - [sk1276ng006, socket.socket.__bases__.__class__.__name__.__eq__,        ["frozenset"], false]
    - [sk1276ng007, socket.error.__subclasses__().__class__.__name__.__eq__,  ["dict"],      false]
    - [sk1276ng008, socket.error.__mro__.__class__.__name__.__eq__,           ["dict"],      false]
    - [sk1276ng009, socket.error.__bases__.__class__.__name__.__eq__,         ["dict"],      false]
    - [sk1276ng010, socket.timeout.__subclasses__().__class__.__name__.__eq__, ["dict"],     false]
    - [sk1276ng011, socket.timeout.__mro__.__class__.__name__.__eq__,         ["dict"],      false]
    - [sk1276ng012, socket.timeout.__bases__.__class__.__name__.__eq__,       ["frozenset"], false]
