spec: multiprocessing_extra571
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing class and exception identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers class and exception identity for core multiprocessing types; Pipe, Lock, Event, Semaphore are factory functions, not classes"
  created_at: "2026-04-12T00:00:00Z"

table multiprocessing_extra571.class_identity:
  description: "Identity checks for multiprocessing objects via __class__.__name__"
  kind: python_call_eq
  category: class_identity
  id_prefix: MPEX571
  columns: [id, function, args, expected]
  rows:
    - [MPEX571001, multiprocessing.Process.__class__.__name__.__eq__, ["type"], true]
    - [MPEX571002, multiprocessing.Queue.__class__.__name__.__eq__, ["type"], true]
    - [MPEX571003, multiprocessing.Pipe.__class__.__name__.__eq__, ["function"], true]
    - [MPEX571004, multiprocessing.Lock.__class__.__name__.__eq__, ["function"], true]
    - [MPEX571005, multiprocessing.Event.__class__.__name__.__eq__, ["function"], true]
    - [MPEX571006, multiprocessing.Semaphore.__class__.__name__.__eq__, ["function"], true]
table multiprocessing_extra571.class_qualname:
  description: "Qualname checks for multiprocessing.Process and its methods"
  kind: python_call_eq
  category: class_qualname
  id_prefix: MPEX571Q
  columns: [id, function, args, expected]
  rows:
    - [MPEX571Q001, multiprocessing.Process.__qualname__.__eq__, ["Process"], true]
    - [MPEX571Q002, multiprocessing.Process.__init__.__qualname__.__eq__, ["Process.__init__"], true]
    - [MPEX571Q003, multiprocessing.Process.__repr__.__qualname__.__eq__, ["Process.__repr__"], true]
table multiprocessing_extra571.exception_identity:
  description: "Identity checks for multiprocessing exception types via __qualname__"
  kind: python_call_eq
  category: exception_identity
  id_prefix: MPEX571E
  columns: [id, function, args, expected]
  rows:
    - [MPEX571E001, multiprocessing.AuthenticationError.__qualname__.__eq__, ["AuthenticationError"], true]
    - [MPEX571E002, multiprocessing.BufferTooShort.__qualname__.__eq__, ["BufferTooShort"], true]
    - [MPEX571E003, multiprocessing.ProcessError.__qualname__.__eq__, ["ProcessError"], true]