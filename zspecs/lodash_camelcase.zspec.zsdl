spec: lodash_camelcase
version: ">=4.0.0"
backend: node(lodash.camelcase)

docs: https://lodash.com/docs/#camelCase

provenance:
  derived_from:
    - "lodash.camelcase README — https://www.npmjs.com/package/lodash.camelcase"
    - "Test vectors verified with lodash.camelcase@4.3.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.camelcase exports the _.camelCase function directly as module.exports."
    - "camelCase converts string to camel case."
    - "Handles spaces, dashes, underscores, and mixed input."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns camelCased string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_camelcase.camelcase:
  kind: node_module_call_eq
  function: ~
  category: camelcase
  id_prefix: lcc

  columns: [id, args, expected]
  rows:
    - [space,      ["foo bar"],        "fooBar"]
    - [dash,       ["foo-bar-baz"],    "fooBarBaz"]
    - [underscore, ["foo_bar"],        "fooBar"]
    - [upper,      ["FOO BAR"],        "fooBar"]
    - [mixed,      ["  foo  bar  "],   "fooBar"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:18:25Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
