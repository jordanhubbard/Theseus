spec: lodash_camelcase
version: ">=4.0.0"
backend: node(lodash.camelcase)

docs: https://lodash.com/docs/#camelCase

provenance:
  derived_from:
    - "lodash.camelcase README — https://www.npmjs.com/package/lodash.camelcase"
    - "Test vectors verified with lodash.camelcase@4.3.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.camelcase exports the _.camelCase function directly as module.exports."
    - "Converts a string to camelCase by splitting on spaces, hyphens, underscores, and mixed case."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns camelCase string. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_camelcase.convert:
  kind: node_module_call_eq
  function: ~
  category: convert
  id_prefix: lcamel

  columns: [id, args, expected]
  rows:
    - [snake,   ["hello_world"],  "helloWorld"]
    - [kebab,   ["foo-bar"],      "fooBar"]
    - [space,   ["foo bar"],      "fooBar"]
