spec: functools_extra278
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.reduce is a C builtin in _functools; __class__.__name__ == 'builtin_function_or_method'."
    - "reduce with initializer: reduce(f, [], init) == init; reduce(f, [x], init) == f(init, x)."
    - "reduce on empty sequence without initializer raises TypeError."
    - "functools.total_ordering and functools.lru_cache are pure-Python functions; __module__ == 'functools'."
    - "functools.cached_property is a class (type); __class__.__name__ == 'type'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.reduce — behavior with initializer and edge cases
#
# reduce(f, seq) applies f left-to-right across seq.
# reduce(f, seq, init) starts with init as the accumulator.
# reduce(f, [], init) == init   (initializer returned immediately).
# reduce(f, [x], f) == f(init, x)  (one application).
# reduce(f, []) raises TypeError.
#
# reduce is a C builtin: __module__ == '_functools'.
# ---------------------------------------------------------------------------

table functools_extra278.reduce_behavior:
  description: "functools.reduce behavior — initializer cases, empty-with-init, single-element; reduce is a C builtin in _functools; verified with Python 3.14.3"
  kind: python_call_eq
  category: behavior
  id_prefix: ftex278rb

  columns: [id, function, args, expected, description]
  rows:
    - [rd_sum_no_init,     reduce.__call__,    ["<lambda:add>", [1, 2, 3, 4]],         10,   "reduce(add, [1,2,3,4]) == 10; verified with Python 3.14.3"]
    - [rd_sum_with_init,   reduce.__call__,    ["<lambda:add>", [1, 2, 3, 4], 10],     20,   "reduce(add, [1,2,3,4], 10) == 20 (initializer prepended); verified with Python 3.14.3"]
    - [rd_empty_with_init, reduce.__call__,    ["<lambda:add>", [], 42],                42,   "reduce(add, [], 42) == 42 (empty seq, returns initializer); verified with Python 3.14.3"]
    - [rd_single_no_init,  reduce.__call__,    ["<lambda:add>", [5]],                  5,    "reduce(add, [5]) == 5 (single element, no f call); verified with Python 3.14.3"]
    - [rd_single_with_init,reduce.__call__,    ["<lambda:add>", [5], 10],              15,   "reduce(add, [5], 10) == 15 (init=10 + 5); verified with Python 3.14.3"]
    - [rd_mul_no_init,     reduce.__call__,    ["<lambda:mul>", [2, 3, 4]],            24,   "reduce(mul, [2,3,4]) == 24; verified with Python 3.14.3"]
    - [rd_mul_zero_init,   reduce.__call__,    ["<lambda:mul>", [2, 3, 4], 0],         0,    "reduce(mul, [2,3,4], 0) == 0 (zero init absorbs product); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools.total_ordering and functools.lru_cache — function identity
#
# Both are pure-Python functions in functools.
# total_ordering.__name__ len == 14 (same as singledispatch).
# lru_cache.__name__ len == 9.
# cached_property is a class (type), not a function.
# ---------------------------------------------------------------------------

table functools_extra278.decorator_identity:
  description: "functools.total_ordering, lru_cache, cached_property identity — __name__, __module__, __class__.__name__; cached_property is a class (type); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex278di

  columns: [id, function, args, expected, description]
  rows:
    - [to_name_eq,   total_ordering.__name__.__eq__,           ["total_ordering"],  true,     "functools.total_ordering.__name__ == 'total_ordering' (len=14); verified with Python 3.14.3"]
    - [to_name_len,  total_ordering.__name__.__len__,          [],                  14,       "functools.total_ordering.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [to_mod_eq,    total_ordering.__module__.__eq__,         ["functools"],       true,     "functools.total_ordering.__module__ == 'functools'; verified with Python 3.14.3"]
    - [to_cls_eq,    total_ordering.__class__.__name__.__eq__, ["function"],        true,     "functools.total_ordering.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [to_qn_eq,     total_ordering.__qualname__.__eq__,       ["total_ordering"],  true,     "functools.total_ordering.__qualname__ == 'total_ordering'; verified with Python 3.14.3"]
    - [lc_name_eq,   lru_cache.__name__.__eq__,                ["lru_cache"],       true,     "functools.lru_cache.__name__ == 'lru_cache' (len=9); verified with Python 3.14.3"]
    - [lc_name_len,  lru_cache.__name__.__len__,               [],                  9,        "functools.lru_cache.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [lc_mod_eq,    lru_cache.__module__.__eq__,              ["functools"],       true,     "functools.lru_cache.__module__ == 'functools'; verified with Python 3.14.3"]
    - [lc_cls_eq,    lru_cache.__class__.__name__.__eq__,      ["function"],        true,     "functools.lru_cache.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [cp_name_eq,   cached_property.__name__.__eq__,          ["cached_property"], true,     "functools.cached_property.__name__ == 'cached_property' (len=15); verified with Python 3.14.3"]
    - [cp_name_len,  cached_property.__name__.__len__,         [],                  15,       "functools.cached_property.__name__.__len__() == 15; verified with Python 3.14.3"]
    - [cp_mod_eq,    cached_property.__module__.__eq__,        ["functools"],       true,     "functools.cached_property.__module__ == 'functools'; verified with Python 3.14.3"]
    - [cp_cls_eq,    cached_property.__class__.__name__.__eq__, ["type"],           true,     "functools.cached_property.__class__.__name__ == 'type' (it is a class, not a function); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra278
# ---------------------------------------------------------------------------

invariant functools_extra278.reduce_empty_with_initializer_returns_initializer:
  description: "functools.reduce(f, [], 42) == 42 — when sequence is empty, reduce returns the initializer unchanged"
  category: behavior
  kind: python_call_eq
  function: reduce
  args: ["<lambda:add>", [], 42]
  expected: 42

invariant functools_extra278.reduce_empty_no_init_raises_typeerror:
  description: "functools.reduce(f, []) raises TypeError — empty sequence with no initializer is not allowed"
  category: error_handling
  kind: python_call_raises
  function: reduce
  args: ["<lambda:add>", []]
  raises: TypeError

invariant functools_extra278.reduce_single_element_no_init_returns_element:
  description: "functools.reduce(f, [5]) == 5 — single-element sequence with no initializer returns that element, f is never called"
  category: behavior
  kind: python_call_eq
  function: reduce
  args: ["<lambda:add>", [5]]
  expected: 5

invariant functools_extra278.reduce_module_is_c_functools:
  description: "functools.reduce.__module__ == '_functools' — reduce is implemented in C extension _functools, not pure-Python functools"
  category: identity
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra278.reduce_class_is_builtin_function_or_method:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — confirms C extension origin"
  category: identity
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra278.total_ordering_module_is_functools:
  description: "functools.total_ordering.__module__ == 'functools' — pure-Python decorator defined in functools"
  category: identity
  kind: python_call_eq
  function: total_ordering.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra278.cached_property_is_type_not_function:
  description: "functools.cached_property.__class__.__name__ == 'type' — cached_property is a class (descriptor), not a plain function"
  category: identity
  kind: python_call_eq
  function: cached_property.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra278.lru_cache_name_length_is_nine:
  description: "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters"
  category: identity
  kind: python_call_eq
  function: lru_cache.__name__.__len__
  args: []
  expected: 9
