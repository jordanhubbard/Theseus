  not_derived_from: []
  notes: "Covers asyncio.Queue method qualnames and LifoQueue/PriorityQueue class qualnames"
  created_at: "2026-04-12"

table asyncio_extra736.queue_qualnames:
  description: "asyncio.Queue and related class method qualname identity checks"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: as736xx
  columns: [id, function, args, expected]
  rows:
    - ["as736xx001", "asyncio.Queue.__init__.__qualname__.__eq__", ["Queue.__init__"], true]
    - ["as736xx002", "asyncio.Queue.put.__qualname__.__eq__", ["Queue.put"], true]
    - ["as736xx003", "asyncio.Queue.put_nowait.__qualname__.__eq__", ["Queue.put_nowait"], true]
    - ["as736xx004", "asyncio.Queue.get.__qualname__.__eq__", ["Queue.get"], true]
    - ["as736xx005", "asyncio.Queue.get_nowait.__qualname__.__eq__", ["Queue.get_nowait"], true]
    - ["as736xx006", "asyncio.Queue.empty.__qualname__.__eq__", ["Queue.empty"], true]
    - ["as736xx007", "asyncio.Queue.full.__qualname__.__eq__", ["Queue.full"], true]
    - ["as736xx008", "asyncio.Queue.qsize.__qualname__.__eq__", ["Queue.qsize"], true]
    - ["as736xx009", "asyncio.Queue.task_done.__qualname__.__eq__", ["Queue.task_done"], true]
    - ["as736xx010", "asyncio.Queue.join.__qualname__.__eq__", ["Queue.join"], true]
    - ["as736xx011", "asyncio.LifoQueue.__qualname__.__eq__", ["LifoQueue"], true]
    - ["as736xx012", "asyncio.PriorityQueue.__qualname__.__eq__", ["PriorityQueue"], true]
