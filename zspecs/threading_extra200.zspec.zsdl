spec: threading_extra200
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading module-level attributes — __name__, __package__, __spec__.name, __file__.__class__.__name__, and __name__.__len__() for Thread, Lock, Event, Condition."
    - "threading.__name__ == 'threading' — the module's __name__ attribute is its fully-qualified import name. Verified with Python 3.14.3."
    - "threading.__package__ == '' — threading is a top-level module with no package prefix; __package__ is the empty string. Verified with Python 3.14.3."
    - "threading.__spec__.name == 'threading' — the ModuleSpec object's .name attribute equals the module name. Verified with Python 3.14.3."
    - "threading.__file__.__class__.__name__ == 'str' — __file__ is a plain Python string path to threading.py; its __class__.__name__ is 'str'. Verified with Python 3.14.3."
    - "threading.Thread.__name__.__len__() == 6 — 'Thread' has 6 characters. Verified with Python 3.14.3."
    - "threading.Lock.__name__.__len__() == 4 — threading.Lock is the C extension type from _thread; its internal __name__ is lowercase 'lock' (4 chars). Verified with Python 3.14.3."
    - "threading.Event.__name__.__len__() == 5 — 'Event' has 5 characters. Verified with Python 3.14.3."
    - "threading.Condition.__name__.__len__() == 9 — 'Condition' has 9 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading module identity — __name__, __package__, __spec__.name
#
# threading.__name__.__eq__('threading') == True
# threading.__package__.__eq__('') == True
# threading.__spec__.name.__eq__('threading') == True
#
# threading is a top-level stdlib module; __package__ is the empty string
# and __spec__.name matches __name__. New to extra200.
# ---------------------------------------------------------------------------

table threading_extra200.module_identity:
  description: "threading module __name__, __package__, __spec__.name; top-level stdlib module; __package__ is empty string; __spec__.name matches __name__; new to extra200"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingmodule200

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq_threading,
       __name__.__eq__,
       ["threading"],
       true,
       "threading.__name__.__eq__('threading') == True — the module's __name__ attribute is its fully-qualified import name 'threading'; str.__eq__('threading') returns True; new to extra200"]
    - [module_package_eq_empty,
       __package__.__eq__,
       [""],
       true,
       "threading.__package__.__eq__('') == True — threading is a top-level module with no package prefix; __package__ is the empty string; str.__eq__('') returns True; new to extra200"]
    - [module_spec_name_eq_threading,
       __spec__.name.__eq__,
       ["threading"],
       true,
       "threading.__spec__.name.__eq__('threading') == True — __spec__ is a ModuleSpec object; its .name attribute equals the module name 'threading'; str.__eq__('threading') returns True; new to extra200"]

# ---------------------------------------------------------------------------
# Table 2: threading module __file__ class and Thread/Lock name lengths
#
# threading.__file__.__class__.__name__.__eq__('str') == True
# threading.Thread.__name__.__len__() == 6
# threading.Lock.__name__.__len__() == 4
#
# __file__ is a plain str path; Thread.__name__ is 'Thread' (6 chars);
# Lock.__name__ is 'lock' (lowercase, 4 chars — C type from _thread).
# New to extra200.
# ---------------------------------------------------------------------------

table threading_extra200.file_class_and_thread_lock_lens:
  description: "threading __file__.__class__.__name__=='str'; Thread.__name__.__len__()==6; Lock.__name__.__len__()==4 ('lock' lowercase C type); new to extra200"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmodule200

  columns: [id, function, args, expected, description]
  rows:
    - [file_class_name_eq_str,
       __file__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.__file__.__class__.__name__.__eq__('str') == True — __file__ is a plain Python string path to threading.py; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra200"]
    - [thread_name_len_6,
       Thread.__name__.__len__,
       [],
       6,
       "threading.Thread.__name__.__len__() == 6 — Thread.__name__ is 'Thread' which has 6 characters; str.__len__() returns 6; new to extra200"]
    - [lock_name_len_4,
       Lock.__name__.__len__,
       [],
       4,
       "threading.Lock.__name__.__len__() == 4 — threading.Lock is the C extension type from _thread; its internal __name__ is lowercase 'lock' (4 chars), not 'Lock'; str.__len__() returns 4; new to extra200"]

# ---------------------------------------------------------------------------
# Table 3: threading Event and Condition name lengths
#
# threading.Event.__name__.__len__() == 5
# threading.Condition.__name__.__len__() == 9
#
# Event is a pure-Python class in Lib/threading.py; 'Event' has 5 chars.
# Condition is a pure-Python class in Lib/threading.py; 'Condition' has 9 chars.
# New to extra200.
# ---------------------------------------------------------------------------

table threading_extra200.event_condition_name_lens:
  description: "threading Event.__name__.__len__()==5; Condition.__name__.__len__()==9; both pure-Python classes in Lib/threading.py; new to extra200"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmodule200

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_len_5,
       Event.__name__.__len__,
       [],
       5,
       "threading.Event.__name__.__len__() == 5 — Event.__name__ is 'Event' which has 5 characters; str.__len__() returns 5; new to extra200"]
    - [condition_name_len_9,
       Condition.__name__.__len__,
       [],
       9,
       "threading.Condition.__name__.__len__() == 9 — Condition.__name__ is 'Condition' which has 9 characters; str.__len__() returns 9; new to extra200"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra200
# ---------------------------------------------------------------------------

invariant threading_extra200.module_name:
  description: "threading.__name__ == 'threading' — top-level stdlib module name; new to extra200"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra200.module_package:
  description: "threading.__package__ == '' — top-level module; __package__ is empty string; new to extra200"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant threading_extra200.module_spec_name:
  description: "threading.__spec__.name == 'threading' — ModuleSpec.name matches module __name__; new to extra200"
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra200.file_class_name:
  description: "threading.__file__.__class__.__name__ == 'str' — __file__ is a plain Python string path; new to extra200"
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant threading_extra200.thread_name_len:
  description: "threading.Thread.__name__.__len__() == 6 — 'Thread' has 6 characters; new to extra200"
  kind: python_call_eq
  function: Thread.__name__.__len__
  args: []
  expected: 6

invariant threading_extra200.lock_name_len:
  description: "threading.Lock.__name__.__len__() == 4 — C extension type from _thread; internal __name__ is lowercase 'lock' (4 chars); new to extra200"
  kind: python_call_eq
  function: Lock.__name__.__len__
  args: []
  expected: 4

invariant threading_extra200.event_name_len:
  description: "threading.Event.__name__.__len__() == 5 — 'Event' has 5 characters; new to extra200"
  kind: python_call_eq
  function: Event.__name__.__len__
  args: []
  expected: 5

invariant threading_extra200.condition_name_len:
  description: "threading.Condition.__name__.__len__() == 9 — 'Condition' has 9 characters; new to extra200"
  kind: python_call_eq
  function: Condition.__name__.__len__
  args: []
  expected: 9

