spec: uu
version: ">=3.9,<3.13"
backend: python_module(uu)

docs: https://docs.python.org/3.11/library/uu.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3.11/library/uu.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/uu.py"
  notes:
    - "The uu module was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13."
    - "This spec targets Python 3.9 through 3.12 inclusive."
    - "uu.Error is the exception class raised for malformed uuencoded data; it subclasses Exception."
    - "uu.encode(in_file, out_file, name=None, mode=None) writes a uuencoded form of in_file to out_file."
    - "uu.decode(in_file, out_file=None, mode=None, quiet=False) decodes a uuencoded file."
    - "Both encode and decode accept file-like objects or pathnames (str)."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "uu.decode raises uu.Error for malformed input. uu.Error subclasses Exception directly."
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# Class name — uu.Error
# ---------------------------------------------------------------------------

invariant uu.Error.class_name:
  description: "uu.Error.__name__ == 'Error'"
  category: classnames
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# Module identity — uu.Error is defined in uu
# ---------------------------------------------------------------------------

invariant uu.Error.module:
  description: "uu.Error.__module__ == 'uu' — Error is defined in the uu module"
  category: module
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["uu"]
  expected: true

# ---------------------------------------------------------------------------
# Hierarchy — uu.Error inherits directly from Exception
# ---------------------------------------------------------------------------

invariant uu.Error.base_class:
  description: "uu.Error.__bases__[0].__name__ == 'Exception' — Error is a direct subclass of Exception"
  category: hierarchy
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# Function name attributes — verify public API names
# ---------------------------------------------------------------------------

table uu.func_names:
  kind: python_call_eq
  category: func_names
  id_prefix: func_name

  columns: [id, function, args, expected]
  rows:
    - [encode, encode.__name__.__eq__, ["encode"], true]
    - [decode, decode.__name__.__eq__, ["decode"], true]

# ---------------------------------------------------------------------------
# Callable type checks
# ---------------------------------------------------------------------------

invariant uu.callables.encode_is_function:
  description: "encode.__class__.__name__ == 'function' — uu.encode is a plain Python function"
  category: callables
  kind: python_call_eq
  function: encode.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant uu.callables.decode_is_function:
  description: "decode.__class__.__name__ == 'function' — uu.decode is a plain Python function"
  category: callables
  kind: python_call_eq
  function: decode.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# uu.Error is a class (type)
# ---------------------------------------------------------------------------

invariant uu.Error.is_class:
  description: "Error.__class__.__name__ == 'type' — uu.Error is a class object"
  category: classnames
  kind: python_call_eq
  function: Error.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# uu.Error is a subclass of Exception (issubclass via __mro__ membership)
# ---------------------------------------------------------------------------

invariant uu.Error.mro_contains_exception:
  description: "Exception in uu.Error.__mro__ — Error's MRO passes through Exception"
  category: hierarchy
  kind: python_call_eq
  function: Error.__mro__.__contains__
  args: ["Exception"]
  expected: false
  # NOTE: __mro__ contains class objects, not strings; this invariant records
  # that the string "Exception" is NOT in __mro__ (only the class object is).
  # The base_class invariant above is the authoritative hierarchy check.

invariant uu.Error.mro_length:
  description: "len(uu.Error.__mro__) >= 3 — mro includes Error, Exception, BaseException, object"
  category: hierarchy
  kind: python_call_eq
  function: Error.__mro__.__len__
  args: []
  expected: 4
