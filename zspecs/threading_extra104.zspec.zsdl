spec: threading_extra104
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra103

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra103.zspec.zsdl."
    - "This spec covers: threading.Semaphore and threading.Event method __qualname__ values and lengths; threading.Condition and threading.Barrier method __qualname__ values; wave 260."
    - "threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (len 17). Verified with Python 3.14.3."
    - "threading.Semaphore.release.__qualname__ == 'Semaphore.release' (len 17). Verified with Python 3.14.3."
    - "threading.Semaphore.__enter__.__qualname__ == 'Semaphore.acquire' (len 17) — __enter__ is an alias for acquire. Verified with Python 3.14.3."
    - "threading.Semaphore.__exit__.__qualname__ == 'Semaphore.__exit__' (len 18). Verified with Python 3.14.3."
    - "threading.Event.set.__qualname__ == 'Event.set' (len 9). Verified with Python 3.14.3."
    - "threading.Event.clear.__qualname__ == 'Event.clear' (len 11). Verified with Python 3.14.3."
    - "threading.Event.wait.__qualname__ == 'Event.wait' (len 10). Verified with Python 3.14.3."
    - "threading.Event.is_set.__qualname__ == 'Event.is_set' (len 12). Verified with Python 3.14.3."
    - "threading.Condition.wait.__qualname__ == 'Condition.wait' (len 14). Verified with Python 3.14.3."
    - "threading.Condition.notify.__qualname__ == 'Condition.notify' (len 16). Verified with Python 3.14.3."
    - "threading.Barrier.wait.__qualname__ == 'Barrier.wait' (len 12). Verified with Python 3.14.3."
    - "threading.Barrier.reset.__qualname__ == 'Barrier.reset' (len 13). Verified with Python 3.14.3."
    - "threading.Barrier.abort.__qualname__ == 'Barrier.abort' (len 13). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Semaphore method __qualname__ values and lengths
#
# Wave 260 theme: threading.Semaphore method __qualname__ identity.
#
# threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (len 17)
# threading.Semaphore.release.__qualname__ == 'Semaphore.release' (len 17)
# threading.Semaphore.__enter__.__qualname__ == 'Semaphore.acquire' (len 17)
# threading.Semaphore.__exit__.__qualname__ == 'Semaphore.__exit__' (len 18)
#
# Semaphore is a pure-Python class defined in Lib/threading.py.
# __enter__ is implemented as an alias to acquire, so its __qualname__ is
# 'Semaphore.acquire' rather than 'Semaphore.__enter__'.
# New to extra104.
# ---------------------------------------------------------------------------

table threading_extra104.semaphore_method_qualnames:
  description: "threading.Semaphore method __qualname__ lengths: acquire/release/__enter__ 17, __exit__ 18; __enter__ qualname is 'Semaphore.acquire' (alias); wave 260; new to extra104"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingsem104

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_acquire_qualname_len_eq_17,
       "Semaphore.acquire.__qualname__.__len__",
       [],
       17,
       "threading.Semaphore.acquire.__qualname__.__len__() == 17 — Semaphore.acquire is a pure-Python method in Lib/threading.py; its __qualname__ is 'Semaphore.acquire'; len('Semaphore.acquire') == 17 (S-e-m-a-p-h-o-r-e-.-a-c-q-u-i-r-e); new to extra104"]
    - [semaphore_release_qualname_len_eq_17,
       "Semaphore.release.__qualname__.__len__",
       [],
       17,
       "threading.Semaphore.release.__qualname__.__len__() == 17 — Semaphore.release is a pure-Python method in Lib/threading.py; its __qualname__ is 'Semaphore.release'; len('Semaphore.release') == 17 (S-e-m-a-p-h-o-r-e-.-r-e-l-e-a-s-e); new to extra104"]
    - [semaphore_enter_qualname_len_eq_17,
       "Semaphore.__enter__.__qualname__.__len__",
       [],
       17,
       "threading.Semaphore.__enter__.__qualname__.__len__() == 17 — Semaphore.__enter__ is assigned as self.__enter__ = self.acquire in Lib/threading.py, so its __qualname__ is 'Semaphore.acquire' not 'Semaphore.__enter__'; len('Semaphore.acquire') == 17; new to extra104"]
    - [semaphore_enter_qualname_eq_acquire,
       "Semaphore.__enter__.__qualname__.__eq__",
       ["Semaphore.acquire"],
       true,
       "threading.Semaphore.__enter__.__qualname__.__eq__('Semaphore.acquire') == True — Semaphore.__enter__ is the acquire method itself (not a wrapper); its __qualname__ is therefore 'Semaphore.acquire'; str.__eq__('Semaphore.acquire') returns True; new to extra104"]
    - [semaphore_exit_qualname_len_eq_18,
       "Semaphore.__exit__.__qualname__.__len__",
       [],
       18,
       "threading.Semaphore.__exit__.__qualname__.__len__() == 18 — Semaphore.__exit__ is a proper method defined in Lib/threading.py that releases the semaphore; its __qualname__ is 'Semaphore.__exit__'; len('Semaphore.__exit__') == 18 (S-e-m-a-p-h-o-r-e-.-_-_-e-x-i-t-_-_); new to extra104"]
    - [semaphore_acquire_qualname_eq,
       "Semaphore.acquire.__qualname__.__eq__",
       ["Semaphore.acquire"],
       true,
       "threading.Semaphore.acquire.__qualname__.__eq__('Semaphore.acquire') == True — Semaphore.acquire acquires the semaphore, blocking if needed; its __qualname__ is 'Semaphore.acquire'; str.__eq__('Semaphore.acquire') returns True; new to extra104"]

# ---------------------------------------------------------------------------
# Table 2: threading.Event method __qualname__ values and lengths
#
# Wave 260 theme: threading.Event method __qualname__ identity.
#
# threading.Event.set.__qualname__ == 'Event.set' (len 9)
# threading.Event.clear.__qualname__ == 'Event.clear' (len 11)
# threading.Event.wait.__qualname__ == 'Event.wait' (len 10)
# threading.Event.is_set.__qualname__ == 'Event.is_set' (len 12)
#
# Event is a pure-Python class in Lib/threading.py that wraps a Condition.
# New to extra104.
# ---------------------------------------------------------------------------

table threading_extra104.event_method_qualnames:
  description: "threading.Event method __qualname__ lengths: set 9, wait 10, clear 11, is_set 12; wave 260; new to extra104"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingevent104

  columns: [id, function, args, expected, description]
  rows:
    - [event_set_qualname_len_eq_9,
       "Event.set.__qualname__.__len__",
       [],
       9,
       "threading.Event.set.__qualname__.__len__() == 9 — Event.set sets the internal flag to True and wakes all threads waiting for it; its __qualname__ is 'Event.set'; len('Event.set') == 9 (E-v-e-n-t-.-s-e-t); new to extra104"]
    - [event_clear_qualname_len_eq_11,
       "Event.clear.__qualname__.__len__",
       [],
       11,
       "threading.Event.clear.__qualname__.__len__() == 11 — Event.clear resets the internal flag to False; its __qualname__ is 'Event.clear'; len('Event.clear') == 11 (E-v-e-n-t-.-c-l-e-a-r); new to extra104"]
    - [event_wait_qualname_len_eq_10,
       "Event.wait.__qualname__.__len__",
       [],
       10,
       "threading.Event.wait.__qualname__.__len__() == 10 — Event.wait blocks until the internal flag is True or an optional timeout expires; its __qualname__ is 'Event.wait'; len('Event.wait') == 10 (E-v-e-n-t-.-w-a-i-t); new to extra104"]
    - [event_is_set_qualname_len_eq_12,
       "Event.is_set.__qualname__.__len__",
       [],
       12,
       "threading.Event.is_set.__qualname__.__len__() == 12 — Event.is_set returns True if the internal flag is True; its __qualname__ is 'Event.is_set'; len('Event.is_set') == 12 (E-v-e-n-t-.-i-s-_-s-e-t); new to extra104"]
    - [event_set_qualname_eq,
       "Event.set.__qualname__.__eq__",
       ["Event.set"],
       true,
       "threading.Event.set.__qualname__.__eq__('Event.set') == True — Event.set is a method of the Event class in Lib/threading.py; its __qualname__ is 'Event.set'; str.__eq__('Event.set') returns True; new to extra104"]
    - [event_is_set_qualname_eq,
       "Event.is_set.__qualname__.__eq__",
       ["Event.is_set"],
       true,
       "threading.Event.is_set.__qualname__.__eq__('Event.is_set') == True — Event.is_set is a method of the Event class in Lib/threading.py; its __qualname__ is 'Event.is_set'; str.__eq__('Event.is_set') returns True; new to extra104"]

# ---------------------------------------------------------------------------
# Table 3: threading.Condition and threading.Barrier method __qualname__ lengths
#
# Wave 260 theme: threading.Condition and Barrier method __qualname__ identity.
#
# threading.Condition.wait.__qualname__ == 'Condition.wait' (len 14)
# threading.Condition.notify.__qualname__ == 'Condition.notify' (len 16)
# threading.Barrier.wait.__qualname__ == 'Barrier.wait' (len 12)
# threading.Barrier.reset.__qualname__ == 'Barrier.reset' (len 13)
# threading.Barrier.abort.__qualname__ == 'Barrier.abort' (len 13)
#
# Condition and Barrier are pure-Python synchronization classes in Lib/threading.py.
# New to extra104.
# ---------------------------------------------------------------------------

table threading_extra104.condition_barrier_qualnames:
  description: "threading.Condition and Barrier method __qualname__ lengths: Barrier.wait 12, Barrier.reset/abort 13, Condition.wait 14, Condition.notify 16; wave 260; new to extra104"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingcb104

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_wait_qualname_len_eq_12,
       "Barrier.wait.__qualname__.__len__",
       [],
       12,
       "threading.Barrier.wait.__qualname__.__len__() == 12 — Barrier.wait blocks until all parties have called wait(); its __qualname__ is 'Barrier.wait'; len('Barrier.wait') == 12 (B-a-r-r-i-e-r-.-w-a-i-t); new to extra104"]
    - [barrier_reset_qualname_len_eq_13,
       "Barrier.reset.__qualname__.__len__",
       [],
       13,
       "threading.Barrier.reset.__qualname__.__len__() == 13 — Barrier.reset resets the barrier to its initial state; its __qualname__ is 'Barrier.reset'; len('Barrier.reset') == 13 (B-a-r-r-i-e-r-.-r-e-s-e-t); new to extra104"]
    - [barrier_abort_qualname_len_eq_13,
       "Barrier.abort.__qualname__.__len__",
       [],
       13,
       "threading.Barrier.abort.__qualname__.__len__() == 13 — Barrier.abort puts the barrier into a broken state causing waiting threads to receive BrokenBarrierError; its __qualname__ is 'Barrier.abort'; len('Barrier.abort') == 13 (B-a-r-r-i-e-r-.-a-b-o-r-t); new to extra104"]
    - [condition_wait_qualname_len_eq_14,
       "Condition.wait.__qualname__.__len__",
       [],
       14,
       "threading.Condition.wait.__qualname__.__len__() == 14 — Condition.wait releases the underlying lock and waits until notified or timed out; its __qualname__ is 'Condition.wait'; len('Condition.wait') == 14 (C-o-n-d-i-t-i-o-n-.-w-a-i-t); new to extra104"]
    - [condition_notify_qualname_len_eq_16,
       "Condition.notify.__qualname__.__len__",
       [],
       16,
       "threading.Condition.notify.__qualname__.__len__() == 16 — Condition.notify wakes one thread waiting on the condition; its __qualname__ is 'Condition.notify'; len('Condition.notify') == 16 (C-o-n-d-i-t-i-o-n-.-n-o-t-i-f-y); new to extra104"]
    - [barrier_wait_qualname_eq,
       "Barrier.wait.__qualname__.__eq__",
       ["Barrier.wait"],
       true,
       "threading.Barrier.wait.__qualname__.__eq__('Barrier.wait') == True — Barrier.wait is a method of the Barrier synchronization primitive in Lib/threading.py; its __qualname__ is 'Barrier.wait'; str.__eq__('Barrier.wait') returns True; new to extra104"]
    - [condition_notify_qualname_eq,
       "Condition.notify.__qualname__.__eq__",
       ["Condition.notify"],
       true,
       "threading.Condition.notify.__qualname__.__eq__('Condition.notify') == True — Condition.notify wakes a waiting thread; its __qualname__ is 'Condition.notify'; str.__eq__('Condition.notify') returns True; new to extra104"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra104
# ---------------------------------------------------------------------------

invariant threading_extra104.semaphore_acquire_qualname_len:
  description: "len(threading.Semaphore.acquire.__qualname__) == 17 — qualname is 'Semaphore.acquire'; wave 260; new to extra104"
  kind: python_call_eq
  function: Semaphore.acquire.__qualname__.__len__
  args: []
  expected: 17

invariant threading_extra104.semaphore_enter_qualname:
  description: "threading.Semaphore.__enter__.__qualname__ == 'Semaphore.acquire' — __enter__ is acquire alias; wave 260; new to extra104"
  kind: python_call_eq
  function: Semaphore.__enter__.__qualname__.__eq__
  args: ["Semaphore.acquire"]
  expected: true

invariant threading_extra104.event_set_qualname_len:
  description: "len(threading.Event.set.__qualname__) == 9 — qualname is 'Event.set'; wave 260; new to extra104"
  kind: python_call_eq
  function: Event.set.__qualname__.__len__
  args: []
  expected: 9

invariant threading_extra104.event_is_set_qualname_len:
  description: "len(threading.Event.is_set.__qualname__) == 12 — qualname is 'Event.is_set'; wave 260; new to extra104"
  kind: python_call_eq
  function: Event.is_set.__qualname__.__len__
  args: []
  expected: 12

invariant threading_extra104.condition_notify_qualname_len:
  description: "len(threading.Condition.notify.__qualname__) == 16 — qualname is 'Condition.notify'; wave 260; new to extra104"
  kind: python_call_eq
  function: Condition.notify.__qualname__.__len__
  args: []
  expected: 16

invariant threading_extra104.barrier_wait_qualname:
  description: "threading.Barrier.wait.__qualname__ == 'Barrier.wait' — wave 260; new to extra104"
  kind: python_call_eq
  function: Barrier.wait.__qualname__.__eq__
  args: ["Barrier.wait"]
  expected: true
