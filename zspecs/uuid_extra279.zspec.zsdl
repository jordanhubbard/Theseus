spec: uuid_extra279
version: ">=3.9"
backend: python_module(uuid)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — UUID objects according to RFC 4122"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "uuid module does NOT expose __all__ (hasattr(uuid, '__all__') is False)"
    - "uuid1, uuid3, uuid4, uuid5, getnode are all plain Python functions (class: function)"
    - "UUID is a type (class: type); NAMESPACE_DNS is a UUID instance (class: UUID)"
    - "All uuid functions have __module__ == 'uuid'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table uuid_extra279.function_names:
  description: "uuid generator functions have correct __name__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: uuex279

  columns: [id, function, args, expected, description]
  rows:
    - [uuex279_001, uuid.uuid1.__name__, [], uuid1, "uuid1 __name__"]
    - [uuex279_002, uuid.uuid3.__name__, [], uuid3, "uuid3 __name__"]
    - [uuex279_003, uuid.uuid4.__name__, [], uuid4, "uuid4 __name__"]
    - [uuex279_004, uuid.uuid5.__name__, [], uuid5, "uuid5 __name__"]
    - [uuex279_005, uuid.getnode.__name__, [], getnode, "getnode __name__"]

table uuid_extra279.function_module_and_class:
  description: "uuid generator functions __module__ and __class__.__name__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: uuex279b

  columns: [id, function, args, expected, description]
  rows:
    - [uuex279b_001, uuid.uuid1.__module__, [], uuid, "uuid1 __module__"]
    - [uuex279b_002, uuid.uuid3.__module__, [], uuid, "uuid3 __module__"]
    - [uuex279b_003, uuid.uuid4.__module__, [], uuid, "uuid4 __module__"]
    - [uuex279b_004, uuid.uuid5.__module__, [], uuid, "uuid5 __module__"]
    - [uuex279b_005, uuid.uuid1.__class__.__name__, [], function, "uuid1 class name"]
    - [uuex279b_006, uuid.uuid3.__class__.__name__, [], function, "uuid3 class name"]
    - [uuex279b_007, uuid.uuid4.__class__.__name__, [], function, "uuid4 class name"]
    - [uuex279b_008, uuid.uuid5.__class__.__name__, [], function, "uuid5 class name"]
    - [uuex279b_009, uuid.getnode.__module__, [], uuid, "getnode __module__"]
    - [uuex279b_010, uuid.getnode.__class__.__name__, [], function, "getnode class name"]

invariant uuid_extra279.UUID_is_type:
  description: "uuid.UUID is a type"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__class__.__name__
  args: []
  expected: type

invariant uuid_extra279.UUID_name:
  description: "uuid.UUID __name__ is UUID"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__name__
  args: []
  expected: UUID

invariant uuid_extra279.UUID_module:
  description: "uuid.UUID __module__ is uuid"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__module__
  args: []
  expected: uuid

invariant uuid_extra279.NAMESPACE_DNS_class:
  description: "uuid.NAMESPACE_DNS is a UUID instance"
  category: identity
  kind: python_call_eq
  function: uuid.NAMESPACE_DNS.__class__.__name__
  args: []
  expected: UUID
