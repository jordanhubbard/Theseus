spec: content_type
version: ">=1.0.0"
backend: node(content-type)

docs: https://github.com/jshttp/content-type#readme

provenance:
  derived_from:
    - "content-type README — https://github.com/jshttp/content-type#readme"
    - "RFC 7231 — HTTP/1.1: Semantics and Content — Content-Type header"
    - "Test vectors verified with content-type@1.0.5 via Node.js 25.6.0 on macOS/Darwin 25.4.0, 2026-04-09"
    - "content-type source: index.js (MIT; source inspection permitted)"
  not_derived_from:
    - "content-type source: internal token parsing details"
  notes:
    - "content-type exports parse() and format() as named methods on the module object."
    - "parse() accepts a Content-Type header string and returns {parameters: object, type: string}."
    - "Parameters keys and values are lower-cased as returned from the header string."
    - "format() accepts {type, parameters} and returns the canonical header string."
    - "format() with an empty or absent parameters object omits the parameter section entirely."
    - "parse() throws TypeError for invalid or missing input; format() throws TypeError for invalid type."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Throws TypeError for invalid input. node exits 0 for valid invariants."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# content-type.parse — header string to {parameters, type}
# ---------------------------------------------------------------------------

table content_type.parse.basic:
  kind: node_module_call_eq
  function: parse
  id_prefix: parse

  columns: [id, category, args, expected]
  rows:
    - [simple_type,           parse, ["text/html"],                            {parameters: {}, type: "text/html"}]
    - [with_charset,          parse, ["text/html; charset=utf-8"],             {parameters: {charset: "utf-8"}, type: "text/html"}]
    - [application_json,      parse, ["application/json"],                     {parameters: {}, type: "application/json"}]
    - [json_with_charset,     parse, ["application/json; charset=utf-8"],      {parameters: {charset: "utf-8"}, type: "application/json"}]
    - [image_png,             parse, ["image/png"],                            {parameters: {}, type: "image/png"}]
    - [octet_stream,          parse, ["application/octet-stream"],             {parameters: {}, type: "application/octet-stream"}]
    - [text_plain_charset,    parse, ["text/plain; charset=UTF-8"],            {parameters: {charset: "UTF-8"}, type: "text/plain"}]
    - [multipart_boundary,    parse, ["multipart/form-data; boundary=--abc"],  {parameters: {boundary: "--abc"}, type: "multipart/form-data"}]

# ---------------------------------------------------------------------------
# content-type.format — {type, parameters} to header string
# ---------------------------------------------------------------------------

table content_type.format.basic:
  kind: node_module_call_eq
  function: format
  id_prefix: format

  columns: [id, category, args, expected]
  rows:
    - [simple_type,           format, [{type: "text/html"}],                                    "text/html"]
    - [with_charset,          format, [{type: "text/html", parameters: {charset: "utf-8"}}],    "text/html; charset=utf-8"]
    - [application_json,      format, [{type: "application/json"}],                              "application/json"]
    - [json_with_charset,     format, [{type: "application/json", parameters: {charset: "utf-8"}}], "application/json; charset=utf-8"]
    - [image_png,             format, [{type: "image/png"}],                                    "image/png"]
    - [image_png_empty_params,format, [{type: "image/png", parameters: {}}],                    "image/png"]
    - [multipart_boundary,    format, [{type: "multipart/form-data", parameters: {boundary: "--abc"}}], "multipart/form-data; boundary=--abc"]
