spec: unicodedata_extra17
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends unicodedata.zspec.zsdl and prior extras through unicodedata_extra16.zspec.zsdl."
    - "unicodedata_extra16 covers: lookup/name/decimal/digit/numeric/category/normalize/bidirectional __qualname__ attributes."
    - "No prior spec verifies combining.__qualname__, east_asian_width.__qualname__, mirrored.__qualname__, decomposition.__qualname__, or is_normalized.__qualname__ as standalone invariants."
    - "This spec covers: combining/__qualname__=='combining'; east_asian_width/__qualname__=='east_asian_width'; mirrored/__qualname__=='mirrored'; decomposition/__qualname__=='decomposition'; is_normalized/__qualname__=='is_normalized'."
    - "unicodedata built-in functions are C-level builtins; their __qualname__ equals their simple name (no owning class prefix). Verified at runtime."
    - "unicodedata.combining.__qualname__ == 'combining' — C builtin qualname is flat. Verified at runtime."
    - "unicodedata.east_asian_width.__qualname__ == 'east_asian_width' — C builtin qualname is flat. Verified at runtime."
    - "unicodedata.mirrored.__qualname__ == 'mirrored' — C builtin qualname is flat. Verified at runtime."
    - "unicodedata.decomposition.__qualname__ == 'decomposition' — C builtin qualname is flat. Verified at runtime."
    - "unicodedata.is_normalized.__qualname__ == 'is_normalized' — C builtin qualname is flat. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# unicodedata built-in function __qualname__ — combining and east_asian_width
#
# unicodedata_extra16 covers __qualname__ for lookup/name/decimal/digit/numeric/
# category/normalize/bidirectional. No prior spec verifies combining.__qualname__
# or east_asian_width.__qualname__ as standalone invariants. C-level built-in
# functions have a flat __qualname__ equal to their simple name.
# Verified: combining.__qualname__=='combining',
#           east_asian_width.__qualname__=='east_asian_width'.
# ---------------------------------------------------------------------------

invariant unicodedata_extra17.combining.qualname:
  description: "unicodedata.combining.__qualname__ == 'combining' — C builtin qualname is flat"
  category: function_identity
  kind: python_call_eq
  function: combining.__qualname__.__eq__
  args: ["combining"]
  expected: true

invariant unicodedata_extra17.east_asian_width.qualname:
  description: "unicodedata.east_asian_width.__qualname__ == 'east_asian_width' — C builtin qualname is flat"
  category: function_identity
  kind: python_call_eq
  function: east_asian_width.__qualname__.__eq__
  args: ["east_asian_width"]
  expected: true

# ---------------------------------------------------------------------------
# unicodedata built-in function __qualname__ — mirrored, decomposition, is_normalized
#
# No prior spec verifies mirrored.__qualname__, decomposition.__qualname__, or
# is_normalized.__qualname__ as standalone invariants.
# Verified at runtime: each __qualname__ equals the function's simple name.
# ---------------------------------------------------------------------------

invariant unicodedata_extra17.mirrored.qualname:
  description: "unicodedata.mirrored.__qualname__ == 'mirrored' — C builtin qualname is flat"
  category: function_identity
  kind: python_call_eq
  function: mirrored.__qualname__.__eq__
  args: ["mirrored"]
  expected: true

invariant unicodedata_extra17.decomposition.qualname:
  description: "unicodedata.decomposition.__qualname__ == 'decomposition' — C builtin qualname is flat"
  category: function_identity
  kind: python_call_eq
  function: decomposition.__qualname__.__eq__
  args: ["decomposition"]
  expected: true

invariant unicodedata_extra17.is_normalized.qualname:
  description: "unicodedata.is_normalized.__qualname__ == 'is_normalized' — C builtin qualname is flat"
  category: function_identity
  kind: python_call_eq
  function: is_normalized.__qualname__.__eq__
  args: ["is_normalized"]
  expected: true

# ---------------------------------------------------------------------------
# Table: unicodedata built-in function __qualname__ — remaining functions
#
# Groups the five qualname checks not covered by unicodedata_extra16 in one
# indexed table. No prior table covers combining/east_asian_width/mirrored/
# decomposition/is_normalized __qualname__ attributes.
# All verified at runtime: each __qualname__ equals the function's simple name.
# ---------------------------------------------------------------------------

table unicodedata_extra17.function_qualnames:
  description: "unicodedata built-in function __qualname__ attributes — remaining functions not covered by extra16"
  kind: python_call_eq
  category: function_identity
  id_prefix: ud17fq

  columns: [id, function, args, expected]
  rows:
    - [combining,        combining.__qualname__.__eq__,        ["combining"],        true]
    - [east_asian_width, east_asian_width.__qualname__.__eq__, ["east_asian_width"], true]
    - [mirrored,         mirrored.__qualname__.__eq__,         ["mirrored"],         true]
    - [decomposition,    decomposition.__qualname__.__eq__,    ["decomposition"],    true]
    - [is_normalized,    is_normalized.__qualname__.__eq__,    ["is_normalized"],    true]
