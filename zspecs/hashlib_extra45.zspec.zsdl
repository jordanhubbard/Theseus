spec: hashlib_extra45
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra44.zspec.zsdl — covers shake_128.__qualname__.__eq__('openssl_shake_128') and shake_128.__module__.__eq__('_hashlib'); blake2b/blake2s __class__.__name__.__eq__('type')."
    - "hashlib_extra43.zspec.zsdl — covers scrypt.__qualname__.__eq__('scrypt'); algorithms_available.__contains__('sha224') and ('sha384'); pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac')."
    - "hashlib_extra36.zspec.zsdl — covers sha3_224/sha3_384 __name__.__len__()==16 and __module__.__len__()==8; shake_128/shake_256 __qualname__.__len__()==17 (length checks only, NOT string eq values for sha3_224/sha3_384)."
    - "hashlib_extra28.zspec.zsdl — covers sha3_256/sha3_512/blake2b/blake2s __qualname__.__eq__ and __qualname__.__len__(). sha3_224 and sha3_384 are absent from extra28's qualname eq table."
    - "hashlib_extra10.zspec.zsdl — covers sha3_224.__qualname__.__eq__('sha3_224') and sha3_256.__qualname__.__eq__('sha3_256') with stale pre-OpenSSL values. On Python 3.14/macOS the actual values are 'openssl_sha3_224' and 'openssl_sha3_256'. extra10 invariants fail on OpenSSL-backed CPython 3.12+."
    - "hashlib_extra8.zspec.zsdl — covers sha256/sha512/sha1/md5/sha224/sha384 __qualname__.__eq__ (openssl_sha* values)."
  notes:
    - "This spec extends hashlib through hashlib_extra44; it does NOT duplicate invariants present in those files."
    - "Coverage gap: hashlib_extra28 covers sha3_256.__qualname__.__eq__('openssl_sha3_256') and sha3_512.__qualname__.__eq__('openssl_sha3_512'). hashlib_extra36 covers sha3_224.__name__.__len__()==16 and sha3_384.__name__.__len__()==16 (name length only). hashlib_extra10 has stale values ('sha3_224' and 'sha3_256' pre-OpenSSL). NO prior spec checks sha3_224.__qualname__.__eq__('openssl_sha3_224') or sha3_384.__qualname__.__eq__('openssl_sha3_384') as correct string eq values. These are the symmetric counterparts for SHA3-224 and SHA3-384 that are covered for SHA3-256 and SHA3-512 in extra28. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__qualname__ == 'openssl_sha3_224'. On OpenSSL-backed CPython 3.12+, the SHA3-224 constructor has __qualname__ == __name__ == 'openssl_sha3_224'. extra36 covers __name__.__len__()==16 (length only); extra10 has stale value 'sha3_224'; no prior spec checks __qualname__.__eq__('openssl_sha3_224'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__qualname__ == 'openssl_sha3_384'. Same pattern as sha3_224. extra36 covers __name__.__len__()==16 (length only); no prior spec checks __qualname__.__eq__('openssl_sha3_384'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "sha3_224.__qualname__.__len__() == 16. len('openssl_sha3_224') == 16. extra28 covers sha3_256.__qualname__.__len__()==16 and sha3_512.__qualname__.__len__()==16; sha3_224 and sha3_384 qualname lengths are absent from extra28's length table. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "sha3_384.__qualname__.__len__() == 16. len('openssl_sha3_384') == 16. Same coverage gap as sha3_224. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha3_224 and sha3_384 __qualname__.__eq__ string values
#
# hashlib_extra28 covers sha3_256/sha3_512 __qualname__.__eq__ ('openssl_sha3_256',
# 'openssl_sha3_512') and __qualname__.__len__()==16 for both.
# hashlib_extra36 covers sha3_224/sha3_384 __name__.__len__()==16 (name length only).
# hashlib_extra10 has stale pre-OpenSSL values 'sha3_224'/'sha3_256' for __qualname__.__eq__.
# NO prior spec checks sha3_224.__qualname__.__eq__('openssl_sha3_224') or
# sha3_384.__qualname__.__eq__('openssl_sha3_384') as correct string eq values.
# ---------------------------------------------------------------------------

table hashlib_extra45.sha3_224_384_qualname_eq:
  description: "hashlib.sha3_224/sha3_384 __qualname__.__eq__ string values — novel: extra28 covers sha3_256/sha3_512 qualname eq; extra36 covers sha3_224/sha3_384 __name__.__len__; extra10 has stale pre-OpenSSL values; no prior spec has correct openssl_sha3_224/openssl_sha3_384 qualname eq"
  kind: python_call_eq
  category: function_names
  id_prefix: hs3qe45

  columns: [id, function, args, expected]
  rows:
    - [sha3_224_qualname_eq, sha3_224.__qualname__.__eq__, ["openssl_sha3_224"], true]
    - [sha3_384_qualname_eq, sha3_384.__qualname__.__eq__, ["openssl_sha3_384"], true]

# ---------------------------------------------------------------------------
# hashlib.sha3_224 and sha3_384 __qualname__.__len__()
#
# hashlib_extra28 covers sha3_256.__qualname__.__len__()==16 and
# sha3_512.__qualname__.__len__()==16.
# sha3_224 and sha3_384 are absent from extra28's length table.
# hashlib_extra36 covers sha3_224/__name__.__len__()==16 (name axis, not qualname axis).
# These are distinct attribute chains: __name__.__len__() vs __qualname__.__len__().
# ---------------------------------------------------------------------------

table hashlib_extra45.sha3_224_384_qualname_len:
  description: "hashlib.sha3_224/sha3_384 __qualname__.__len__() == 16 — novel: extra28 covers sha3_256/sha3_512 qualname len; sha3_224/sha3_384 absent from extra28's length table; extra36 covers __name__.__len__ (different attribute chain)"
  kind: python_call_eq
  category: function_names
  id_prefix: hs3ql45

  columns: [id, function, args, expected]
  rows:
    - [sha3_224_qualname_len, sha3_224.__qualname__.__len__, [], 16]
    - [sha3_384_qualname_len, sha3_384.__qualname__.__len__, [], 16]
