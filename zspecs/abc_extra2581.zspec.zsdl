spec: abc_extra2581
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 2581 theme: __call__ dict-presence — checking whether abc classes/descriptors define __call__ in their own __dict__."
    - "abc.abstractmethod is a plain function (not a class); its __dict__ is empty — no __call__, no __isabstractmethod__."
    - "abc.ABCMeta is a metaclass; its __dict__ contains register, __instancecheck__, __subclasscheck__, _dump_registry — but NOT __call__."
    - "abc.ABC is a trivial abstract base class; its __dict__ contains __slots__, __abstractmethods__, _abc_impl — but NOT __call__."
    - "abc.abstractproperty is a deprecated class wrapping property; its __dict__ contains __isabstractmethod__ — but NOT __call__."
    - "abc.abstractclassmethod and abc.abstractstaticmethod are also deprecated; both contain __isabstractmethod__ and __init__ — but NOT __call__."
    - "None of the abc module's public objects define __call__ directly in their own class/function __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# abc.ABCMeta — no __call__; metaclass API methods present
# ---------------------------------------------------------------------------

table abc_extra2581.abcmeta_call_dict:
  description: "abc.ABCMeta does not define __call__ in its class __dict__; metaclass methods are present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2581

  columns: [id, function, args, expected]
  rows:
    - ["ab2581001", "abc.ABCMeta.__dict__.__contains__", ["__call__"],          false]
    - ["ab2581002", "abc.ABCMeta.__dict__.__contains__", ["register"],          true]
    - ["ab2581003", "abc.ABCMeta.__dict__.__contains__", ["__instancecheck__"], true]
    - ["ab2581004", "abc.ABCMeta.__dict__.__contains__", ["__subclasscheck__"], true]

