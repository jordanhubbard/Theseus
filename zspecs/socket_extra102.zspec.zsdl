spec: socket_extra102
version: ">=3.9"
backend: python_module(socket)
extends: socket_extra99

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra99.zspec.zsdl — covers socket.gethostname/gethostbyname/getaddrinfo/setdefaulttimeout/getdefaulttimeout __qualname__.__len__() / SocketIO __class__.__name__=='ABCMeta' / SocketIO __module__=='socket' / SocketIO __bases__[0].__name__=='RawIOBase' (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket Python method class/module / socket.socket.send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout class names / getaddrinfo Python function (table + invariants)."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length (table + invariants)."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names (table + invariants)."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names (table + invariants)."
  notes:
    - "This spec extends socket through socket_extra99; it does NOT duplicate invariants present in those files."
    - "Wave 265 theme: socket class __qualname__ lengths / socket.error and socket.timeout alias identity / herror/gaierror __qualname__ lengths and __module__ / socket.socket __qualname__/__name__ lengths / AddressFamily/SocketKind __qualname__/__name__ lengths."
    - "socket.socket.__qualname__.__len__() == 6 ('socket'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__name__.__len__() == 6 ('socket'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__name__ == 'OSError' (socket.error is OSError). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__qualname__ == 'OSError' (len==7). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__name__ == 'TimeoutError' (socket.timeout is TimeoutError). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__qualname__.__len__() == 12 ('TimeoutError'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__qualname__ == 'herror' (len==6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__qualname__ == 'gaierror' (len==8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__bases__[0].__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__bases__[0].__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__qualname__.__len__() == 13 ('AddressFamily'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__qualname__.__len__() == 10 ('SocketKind'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.error is OSError and socket.timeout is TimeoutError — they are aliases for built-in exceptions (module 'builtins'), not socket-defined exceptions."
    - "Note: socket.herror and socket.gaierror are genuine socket exceptions defined in Lib/socket.py, both inheriting from OSError."
    - "Note: socket.socket.__qualname__ is just 'socket' (6 chars), same as __name__, because the Python-level socket class has no enclosing class scope."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__qualname__.__len__()==6
# socket.socket.__name__.__len__()==6
# socket.error.__name__.__eq__('OSError')
# socket.error.__qualname__.__len__()==7
# socket.timeout.__name__.__eq__('TimeoutError')
# socket.timeout.__qualname__.__len__()==12
#
# Wave 265 theme: socket class/alias __qualname__/__name__ lengths.
#
# socket.socket.__qualname__ is 'socket' (6 chars) — the Python-level wrapper
# class for OS socket objects. socket.error is an alias for the builtin OSError
# (7 chars), and socket.timeout is an alias for the builtin TimeoutError (12
# chars). Both error aliases are defined in Lib/socket.py but point to builtins.
# No prior socket spec anchors these lengths or alias identities under
# sockqlen102. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra102.socket_class_and_alias_qualname_lengths:
  description: "socket.socket/__qualname__/__len__()==6 / socket.socket/__name__/__len__()==6 / socket.error/__name__.__eq__('OSError')==True / socket.error/__qualname__/__len__()==7 / socket.timeout/__name__.__eq__('TimeoutError')==True / socket.timeout/__qualname__/__len__()==12 — socket.socket qualname and name are both 'socket' (6 chars); error is alias for OSError (7 chars); timeout is alias for TimeoutError (12 chars); first sockqlen102 anchor for these class and alias qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: sockqlen102

  columns: [id, function, args, expected, description]
  rows:
    - [socket_qlen,       socket.__qualname__.__len__,      [], 6,    "'socket' is 6 chars (the Python-level wrapper class)"]
    - [socket_nlen,       socket.__name__.__len__,          [], 6,    "'socket' is 6 chars; __name__ == __qualname__ for top-level class"]
    - [error_name_eq,     "error.__name__.__eq__",          ["OSError"],      true, "socket.error is an alias for the builtin OSError exception"]
    - [error_qlen,        error.__qualname__.__len__,       [], 7,    "'OSError' is 7 chars (socket.error is OSError)"]
    - [timeout_name_eq,   "timeout.__name__.__eq__",        ["TimeoutError"], true, "socket.timeout is an alias for the builtin TimeoutError exception"]
    - [timeout_qlen,      timeout.__qualname__.__len__,     [], 12,   "'TimeoutError' is 12 chars (socket.timeout is TimeoutError)"]

# ---------------------------------------------------------------------------
# socket.herror.__qualname__.__len__()==6
# socket.herror.__module__.__eq__('socket')
# socket.herror.__bases__[0].__name__.__eq__('OSError')
# socket.gaierror.__qualname__.__len__()==8
# socket.gaierror.__module__.__eq__('socket')
# socket.gaierror.__bases__[0].__name__.__eq__('OSError')
#
# Wave 265 theme: socket.herror and socket.gaierror class identity.
#
# socket.herror (host error, for DNS host lookup failures) and socket.gaierror
# (getaddrinfo error, for address-related errors) are genuine socket exceptions
# defined in Lib/socket.py. Both inherit directly from OSError. Their __module__
# is 'socket' (not 'builtins'), distinguishing them from the error/timeout aliases.
# herror __qualname__ is 'herror' (6 chars) and gaierror is 'gaierror' (8 chars).
# No prior socket spec anchors herror/gaierror __qualname__ lengths, __module__,
# or __bases__ names under sockqlen102. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra102.herror_gaierror_identity:
  description: "socket.herror/__qualname__/__len__()==6 / herror/__module__.__eq__('socket')==True / herror/__bases__[0]/__name__.__eq__('OSError')==True / socket.gaierror/__qualname__/__len__()==8 / gaierror/__module__.__eq__('socket')==True / gaierror/__bases__[0]/__name__.__eq__('OSError')==True — herror/gaierror are genuine socket exceptions defined in Lib/socket.py (not builtins aliases); both inherit from OSError; herror is 6 chars, gaierror is 8 chars; first sockqlen102 anchor for herror/gaierror identity"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: sockqlen102

  columns: [id, function, args, expected, description]
  rows:
    - [herror_qlen,       herror.__qualname__.__len__,                [], 6,    "'herror' is 6 chars (DNS host lookup failure exception)"]
    - [herror_module,     "herror.__module__.__eq__",                 ["socket"], true, "herror is defined in Lib/socket.py, __module__ is 'socket'"]
    - [herror_base,       "herror.__bases__[0].__name__.__eq__",      ["OSError"], true, "herror inherits directly from OSError"]
    - [gaierror_qlen,     gaierror.__qualname__.__len__,              [], 8,    "'gaierror' is 8 chars (getaddrinfo/address resolution error exception)"]
    - [gaierror_module,   "gaierror.__module__.__eq__",               ["socket"], true, "gaierror is defined in Lib/socket.py, __module__ is 'socket'"]
    - [gaierror_base,     "gaierror.__bases__[0].__name__.__eq__",    ["OSError"], true, "gaierror inherits directly from OSError"]

# ---------------------------------------------------------------------------
# socket.AddressFamily.__qualname__.__len__()==13
# socket.AddressFamily.__module__.__eq__('socket')
# socket.SocketKind.__qualname__.__len__()==10
# socket.SocketKind.__module__.__eq__('socket')
#
# Wave 265 theme: AddressFamily and SocketKind enum __qualname__ lengths and __module__.
#
# socket.AddressFamily is an IntEnum enumerating address family constants (e.g.
# AF_INET, AF_UNIX, AF_INET6). Its __qualname__ is 'AddressFamily' (13 chars).
# socket.SocketKind is an IntEnum enumerating socket type constants (e.g.
# SOCK_STREAM, SOCK_DGRAM). Its __qualname__ is 'SocketKind' (10 chars). Both
# are defined in Lib/socket.py so __module__ is 'socket'. socket_extra96 anchors
# AddressFamily/SocketKind __bases__; socket_extra95 anchors enum member values;
# no prior spec anchors __qualname__ lengths or __module__ for these enums under
# sockqlen102. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra102.AddressFamily_SocketKind_qualname_lengths:
  description: "socket.AddressFamily/__qualname__/__len__()==13 / AddressFamily/__module__.__eq__('socket')==True / socket.SocketKind/__qualname__/__len__()==10 / SocketKind/__module__.__eq__('socket')==True — AddressFamily is 13 chars; SocketKind is 10 chars; both defined in Lib/socket.py (__module__=='socket'); extra96 anchors __bases__; extra95 anchors enum members; first sockqlen102 anchor for AddressFamily/SocketKind qualname lengths and __module__"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: sockqlen102

  columns: [id, function, args, expected, description]
  rows:
    - [AddressFamily_qlen,    AddressFamily.__qualname__.__len__,       [], 13,   "'AddressFamily' is 13 chars (IntEnum of AF_* address family constants)"]
    - [AddressFamily_module,  "AddressFamily.__module__.__eq__",        ["socket"], true, "AddressFamily is defined in Lib/socket.py, __module__ is 'socket'"]
    - [SocketKind_qlen,       SocketKind.__qualname__.__len__,          [], 10,   "'SocketKind' is 10 chars (IntEnum of SOCK_* socket type constants)"]
    - [SocketKind_module,     "SocketKind.__module__.__eq__",           ["socket"], true, "SocketKind is defined in Lib/socket.py, __module__ is 'socket'"]

# ---------------------------------------------------------------------------
# socket.socket.__qualname__.__len__()==6 — standalone
#
# socket.socket.__qualname__.__len__() is 6. socket.socket is the Python-level
# socket class defined in Lib/socket.py. It inherits from _socket.socket (the
# C-level socket class from socketmodule.c). Its __qualname__ is 'socket' (6
# chars), same as its __name__, because it is a top-level class with no
# enclosing scope. The Python-level class adds convenience methods like
# makefile(), accept(), and __enter__/__exit__ to the C-level class.
# No prior socket spec anchors socket.socket.__qualname__.__len__()==6 as a
# standalone under sockqlen102. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra102.socket_qualname_len_6:
  description: "socket.socket.__qualname__.__len__() == 6 — socket.socket.__qualname__ is 'socket' (6 chars); top-level Python-level class wrapping _socket.socket from socketmodule.c; adds makefile/accept/__enter__/__exit__ etc.; no prior socket spec anchors socket.__qualname__.__len__() as a standalone; first standalone under sockqlen102"
  category: qualname_lengths
  kind: python_call_eq
  function: socket.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# socket.error.__name__.__eq__('OSError') — standalone
#
# socket.error.__name__ is 'OSError'. socket.error is not a socket-specific
# exception class — it is an alias for the builtin OSError. This alias exists
# for backward compatibility with older Python code that caught socket.error.
# Since socket.error is OSError itself, its __name__ is 'OSError' and its
# __module__ is 'builtins', not 'socket'. No prior socket spec anchors
# socket.error.__name__.__eq__('OSError') as a standalone under sockqlen102.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra102.error_name_OSError:
  description: "socket.error.__name__.__eq__('OSError') == True — socket.error is an alias for the builtin OSError (not a socket-specific exception); __name__ is 'OSError' and __module__ is 'builtins'; alias exists for backward compatibility; no prior socket spec anchors socket.error.__name__ as a standalone; first standalone under sockqlen102"
  category: qualname_lengths
  kind: python_call_eq
  function: "error.__name__.__eq__"
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.herror.__module__.__eq__('socket') — standalone
#
# socket.herror.__module__ is 'socket'. Unlike socket.error (an alias for the
# builtin OSError with __module__=='builtins'), socket.herror is a genuine
# socket-specific exception defined in Lib/socket.py. It is raised when a
# host-related error occurs (DNS lookup failures, etc.). Its __module__ is
# 'socket', confirming it is defined in the socket Python module rather than
# being a builtin alias. No prior socket spec anchors herror.__module__.__eq__
# as a standalone under sockqlen102. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra102.herror_module_socket:
  description: "socket.herror.__module__.__eq__('socket') == True — herror is a genuine socket-specific exception defined in Lib/socket.py (not a builtin alias like socket.error); raised for DNS host lookup failures; __module__ is 'socket' (not 'builtins'); no prior socket spec anchors herror.__module__ as a standalone; first standalone under sockqlen102"
  category: qualname_lengths
  kind: python_call_eq
  function: "herror.__module__.__eq__"
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AddressFamily.__qualname__.__len__()==13 — standalone
#
# socket.AddressFamily.__qualname__.__len__() is 13. AddressFamily is an
# IntEnum that collects all the AF_* address family constants (AF_INET,
# AF_INET6, AF_UNIX, etc.) into a named enumeration. Its __qualname__ is
# 'AddressFamily' (13 chars). socket_extra96 anchors AddressFamily.__bases__;
# socket_extra95 anchors AddressFamily enum member values and names; no prior
# spec anchors AddressFamily.__qualname__.__len__()==13 as a standalone under
# sockqlen102. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra102.AddressFamily_qualname_len_13:
  description: "socket.AddressFamily.__qualname__.__len__() == 13 — AddressFamily.__qualname__ is 'AddressFamily' (13 chars); IntEnum collecting AF_INET/AF_INET6/AF_UNIX etc. address family constants; extra96 anchors __bases__; extra95 anchors enum member values; no prior socket spec anchors AddressFamily.__qualname__.__len__() as a standalone; first standalone under sockqlen102"
  category: qualname_lengths
  kind: python_call_eq
  function: AddressFamily.__qualname__.__len__
  args: []
  expected: 13

