backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 677 (dc3451): __getitem__, __setitem__, __delitem__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "Theme: __getitem__/__setitem__/__delitem__ dict-presence (subscript access)."
    - "No decimal class defines __getitem__ in its own __dict__: decimal types are numeric and exception types, not containers; subscript access is not defined."
    - "No decimal class defines __setitem__ in its own __dict__: decimal types do not implement item assignment."
    - "No decimal class defines __delitem__ in its own __dict__: decimal types do not implement item deletion."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all subscript protocols absent from decimal class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __getitem__ dict-presence — operator.contains(Cls.__dict__, '__getitem__')
#
# No decimal class defines __getitem__ in its own __dict__; all false.
# decimal.Decimal is a numeric type, not a container; [] access is not
# defined. Context and exception subclasses are also false.
# ---------------------------------------------------------------------------

