spec: inspect_extra1831
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 569 (_extra1831): descriptor protocol (__get__/__set__/__set_name__); __call__ callable protocol; inspect module function presence for inspect types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table inspect_extra1831.descriptor_protocol:
  description: "inspect types descriptor protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1831

  columns: [id, function, args, expected]
  rows:
    - ["in1831001", "inspect.Parameter.__dict__.__contains__", ["__get__"], false]
    - ["in1831002", "inspect.Parameter.__dict__.__contains__", ["__set__"], false]
    - ["in1831003", "inspect.Signature.__dict__.__contains__", ["__get__"], false]
    - ["in1831004", "inspect.Signature.__dict__.__contains__", ["__set__"], false]
    - ["in1831005", "inspect.BoundArguments.__dict__.__contains__", ["__get__"], false]
    - ["in1831006", "inspect.BoundArguments.__dict__.__contains__", ["__set__"], false]
    - ["in1831007", "inspect.Parameter.__dict__.__contains__", ["__set_name__"], false]
    - ["in1831008", "inspect.Signature.__dict__.__contains__", ["__set_name__"], false]

table inspect_extra1831.callable_protocol:
  description: "inspect types __call__ and __init__ callable protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1831

  columns: [id, function, args, expected]
  rows:
    - ["in1831101", "inspect.Parameter.__dict__.__contains__", ["__call__"], false]
    - ["in1831102", "inspect.Signature.__dict__.__contains__", ["__call__"], false]
    - ["in1831103", "inspect.BoundArguments.__dict__.__contains__", ["__call__"], false]
    - ["in1831104", "inspect.Parameter.__dict__.__contains__", ["__init__"], true]
    - ["in1831105", "inspect.Signature.__dict__.__contains__", ["__init__"], true]
    - ["in1831106", "inspect.BoundArguments.__dict__.__contains__", ["__init__"], true]
    - ["in1831107", "inspect.Parameter.__dict__.__contains__", ["__new__"], false]
    - ["in1831108", "inspect.Signature.__dict__.__contains__", ["__new__"], false]

table inspect_extra1831.inspect_module_functions:
  description: "inspect module-level function and attribute presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1831

  columns: [id, function, args, expected]
  rows:
    - ["in1831201", "inspect.__dict__.__contains__", ["signature"], true]
    - ["in1831202", "inspect.__dict__.__contains__", ["getmembers"], true]
    - ["in1831203", "inspect.__dict__.__contains__", ["isclass"], true]
    - ["in1831204", "inspect.__dict__.__contains__", ["isfunction"], true]
    - ["in1831205", "inspect.__dict__.__contains__", ["ismethod"], true]
    - ["in1831206", "inspect.__dict__.__contains__", ["isbuiltin"], true]
    - ["in1831207", "inspect.__dict__.__contains__", ["isgenerator"], true]
    - ["in1831208", "inspect.__dict__.__contains__", ["iscoroutine"], true]
    - ["in1831209", "inspect.__dict__.__contains__", ["isawaitable"], true]
    - ["in1831210", "inspect.__dict__.__contains__", ["getsource"], true]
