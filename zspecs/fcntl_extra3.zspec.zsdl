spec: fcntl_extra3
version: ">=3.9"
backend: python_module(fcntl)

docs: https://docs.python.org/3/library/fcntl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fcntl.html — Python fcntl documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/fcntlmodule.c"
  notes:
    - "This spec extends fcntl.zspec.zsdl and prior extras."
    - "fcntl.zspec.zsdl covers: all four function __name__ checks, LOCK_SH/EX/NB/UN values, F_GETFL/SETFL/GETFD/SETFD/FD_CLOEXEC type checks, LOCK_SH|LOCK_NB==5."
    - "fcntl_extra.zspec.zsdl covers: function __name__ and is_builtin for all four, LOCK_* types and value pins."
    - "fcntl_extra2.zspec.zsdl covers: F_GETLK/F_SETLK/F_SETLKW types, FD_CLOEXEC==1, LOCK_EX|LOCK_NB==6, LOCK_UN|LOCK_NB==12, LOCK_* type table, function __qualname__ table."
    - "New here: fcntl module __name__ (module-level, not function-level), function __module__ attributes, LOCK constant arithmetic (addition/subtraction), F_GETFL/F_SETFL/F_GETFD/F_SETFD value pins on macOS."
    - "fcntl.__name__ == 'fcntl' — the module's own __name__ attribute; not the function fcntl.__name__."
    - "All four C-level functions have __module__ == 'fcntl' — they are defined in the fcntl extension module."
    - "LOCK_SH + LOCK_EX == 3 — arithmetic identity following from values 1 and 2."
    - "LOCK_UN - LOCK_NB == 4 — arithmetic identity following from values 8 and 4."
    - "F_GETFL==3, F_SETFL==4, F_GETFD==1, F_SETFD==2 on macOS (BSD/POSIX standard values)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module __name__ — not covered in any prior spec
# Prior specs check fcntl.fcntl.__name__ (the function), not fcntl.__name__ (the module).
# ---------------------------------------------------------------------------

invariant fcntl_extra3.module.name:
  description: "fcntl.__name__ == 'fcntl' — the module's own __name__ attribute"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["fcntl"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ attributes — not covered in any prior spec
# All four C-level functions are defined in the 'fcntl' extension module.
# ---------------------------------------------------------------------------

table fcntl_extra3.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [fcntl, fcntl.__module__.__eq__, ["fcntl"], true]
    - [ioctl, ioctl.__module__.__eq__, ["fcntl"], true]
    - [flock, flock.__module__.__eq__, ["fcntl"], true]
    - [lockf, lockf.__module__.__eq__, ["fcntl"], true]

# ---------------------------------------------------------------------------
# LOCK constant arithmetic — not covered in any prior spec
# fcntl.zspec.zsdl covers LOCK_SH|LOCK_NB==5; fcntl_extra2 covers LOCK_EX|LOCK_NB==6.
# New: LOCK_SH + LOCK_EX == 3 (sum of values 1 + 2), LOCK_UN - LOCK_NB == 4 (8 - 4).
# ---------------------------------------------------------------------------

invariant fcntl_extra3.constants.lock_sh_add_lock_ex:
  description: "fcntl.LOCK_SH + fcntl.LOCK_EX == 3 — arithmetic sum of values 1 + 2"
  category: constants
  kind: python_call_eq
  function: LOCK_SH.__add__
  args: [2]
  expected: 3

invariant fcntl_extra3.constants.lock_un_sub_lock_nb:
  description: "fcntl.LOCK_UN - fcntl.LOCK_NB == 4 — arithmetic difference of values 8 - 4"
  category: constants
  kind: python_call_eq
  function: LOCK_UN.__sub__
  args: [4]
  expected: 4

# ---------------------------------------------------------------------------
# F_GETFL, F_SETFL, F_GETFD, F_SETFD — value pins on macOS
# Prior specs only verify types (is_int). Values are platform-specific but
# standardized on macOS/BSD: F_GETFD==1, F_SETFD==2, F_GETFL==3, F_SETFL==4.
# ---------------------------------------------------------------------------

table fcntl_extra3.constants.f_flag_values:
  kind: python_call_eq
  category: constants
  id_prefix: fval

  columns: [id, function, args, expected]
  rows:
    - [F_GETFD, F_GETFD.__eq__, [1], true]
    - [F_SETFD, F_SETFD.__eq__, [2], true]
    - [F_GETFL, F_GETFL.__eq__, [3], true]
    - [F_SETFL, F_SETFL.__eq__, [4], true]
