spec: gc_extra24
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "This spec extends prior gc specs through gc_extra23.zspec.zsdl."
    - "gc_extra21 covers: get_stats/__qualname__/__module__/__class__.__name__ and DEBUG_* values."
    - "gc_extra23 covers: gc.get_stats() return structure (list length 3, per-element dict with 3 keys)."
    - "gc_extra15/gc_extra18 cover: garbage.__class__.__name__ == 'list'."
    - "Focus: __qualname__ values for gc built-in functions (collect, enable, disable, isenabled, get_count, get_threshold, set_threshold, get_objects) and the type of gc.garbage."
    - "gc built-in functions are C-level; their __qualname__ equals their simple name."
    - "gc.garbage.__class__.__name__ == 'list' — garbage list holds uncollectable objects."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# gc built-in function __qualname__ values
#
# gc functions are implemented in C (builtin_function_or_method).
# Their __qualname__ attribute equals the simple function name string.
# gc_extra21 records get_stats.__qualname__. No prior gc spec records
# __qualname__ for collect/enable/disable/isenabled/get_count/get_threshold/
# set_threshold/get_objects.
# ---------------------------------------------------------------------------

invariant gc_extra24.collect.qualname:
  description: "gc.collect.__qualname__ == 'collect'"
  category: function_qualname
  kind: python_call_eq
  function: collect.__qualname__.__eq__
  args: ["collect"]
  expected: true

invariant gc_extra24.enable.qualname:
  description: "gc.enable.__qualname__ == 'enable'"
  category: function_qualname
  kind: python_call_eq
  function: enable.__qualname__.__eq__
  args: ["enable"]
  expected: true

invariant gc_extra24.disable.qualname:
  description: "gc.disable.__qualname__ == 'disable'"
  category: function_qualname
  kind: python_call_eq
  function: disable.__qualname__.__eq__
  args: ["disable"]
  expected: true

invariant gc_extra24.isenabled.qualname:
  description: "gc.isenabled.__qualname__ == 'isenabled'"
  category: function_qualname
  kind: python_call_eq
  function: isenabled.__qualname__.__eq__
  args: ["isenabled"]
  expected: true

invariant gc_extra24.get_count.qualname:
  description: "gc.get_count.__qualname__ == 'get_count'"
  category: function_qualname
  kind: python_call_eq
  function: get_count.__qualname__.__eq__
  args: ["get_count"]
  expected: true

invariant gc_extra24.get_threshold.qualname:
  description: "gc.get_threshold.__qualname__ == 'get_threshold'"
  category: function_qualname
  kind: python_call_eq
  function: get_threshold.__qualname__.__eq__
  args: ["get_threshold"]
  expected: true

invariant gc_extra24.set_threshold.qualname:
  description: "gc.set_threshold.__qualname__ == 'set_threshold'"
  category: function_qualname
  kind: python_call_eq
  function: set_threshold.__qualname__.__eq__
  args: ["set_threshold"]
  expected: true

invariant gc_extra24.get_objects.qualname:
  description: "gc.get_objects.__qualname__ == 'get_objects'"
  category: function_qualname
  kind: python_call_eq
  function: get_objects.__qualname__.__eq__
  args: ["get_objects"]
  expected: true

# ---------------------------------------------------------------------------
# gc.garbage type — __class__.__name__ == 'list'
#
# gc_extra15 and gc_extra18 record this in their own namespaces.
# Re-anchored here in the extra24 namespace as a standalone invariant
# paired with the function __qualname__ checks above.
# ---------------------------------------------------------------------------

invariant gc_extra24.garbage.class_name:
  description: "gc.garbage.__class__.__name__ == 'list' — garbage holds uncollectable objects"
  category: module_attrs
  kind: python_call_eq
  function: garbage.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all nine __qualname__ and type checks
#
# Covers collect/enable/disable/isenabled/get_count/get_threshold/
# set_threshold/get_objects (__qualname__) and garbage (__class__.__name__).
# ---------------------------------------------------------------------------

table gc_extra24.function_qualnames:
  description: "__qualname__ values for gc built-in functions and gc.garbage class name"
  kind: python_call_eq
  category: function_qualname

  columns: [id, function, args, expected]
  rows:
    - [collect,       collect.__qualname__.__eq__,       ["collect"],       true]
    - [enable,        enable.__qualname__.__eq__,        ["enable"],        true]
    - [disable,       disable.__qualname__.__eq__,       ["disable"],       true]
    - [isenabled,     isenabled.__qualname__.__eq__,     ["isenabled"],     true]
    - [get_count,     get_count.__qualname__.__eq__,     ["get_count"],     true]
    - [get_threshold, get_threshold.__qualname__.__eq__,  ["get_threshold"], true]
    - [set_threshold, set_threshold.__qualname__.__eq__,  ["set_threshold"], true]
    - [get_objects,   get_objects.__qualname__.__eq__,   ["get_objects"],   true]
    - [garbage,       garbage.__class__.__name__.__eq__,  ["list"],          true]
