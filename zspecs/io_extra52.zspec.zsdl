spec: io_extra52
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra51.zspec.zsdl — covers FileIO/BufferedWriter/BufferedReader/BufferedRandom __mro__.__len__()==4; UnsupportedOperation.__mro__.__len__()==6; UnsupportedOperation.__bases__.__len__()==2."
    - "io_extra50.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase/FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader __qualname__.__len__()."
    - "io_extra42.zspec.zsdl — covers BufferedRandom.__qualname__.__len__()==14; BufferedRandom method __qualname__.__len__(); IncrementalNewlineDecoder method __qualname__.__len__()."
    - "io_extra35.zspec.zsdl — covers TextIOWrapper.__name__.__len__()==13; TextIOWrapper.__module__.__len__()==3; TextIOWrapper.__qualname__.__len__()==13."
    - "io_extra26.zspec.zsdl — covers BufferedRandom.__name__.__eq__('BufferedRandom'); BufferedRandom.__module__.__eq__('_io')."
    - "io_extra16.zspec.zsdl — covers IncrementalNewlineDecoder.__qualname__.__eq__('IncrementalNewlineDecoder')."
    - "io_extra14.zspec.zsdl — covers IncrementalNewlineDecoder.__module__.__eq__('_io')."
    - "io_extra13.zspec.zsdl — covers IncrementalNewlineDecoder.__name__.__eq__('IncrementalNewlineDecoder')."
    - "io_extra36.zspec.zsdl — covers IOBase/StringIO/BytesIO/RawIOBase/BufferedIOBase/TextIOBase __mro__.__len__() in table."
  notes:
    - "This spec extends io_extra51.zspec.zsdl."
    - "Prior specs collectively covered: io_extra26 checks BufferedRandom.__name__.__eq__ and __module__.__eq__ (equality checks, not __len__()); io_extra42 checks BufferedRandom.__qualname__.__len__()==14 but NOT __name__.__len__() or __module__.__len__(); io_extra35 checks TextIOWrapper.__name__.__len__()==13/__module__.__len__()==3/__qualname__.__len__()==13; io_extra13/14/16 check IncrementalNewlineDecoder.__name__/__module__/__qualname__ equality but NOT __name__.__len__() or __module__.__len__() or __qualname__.__len__(); io_extra42 checks IncrementalNewlineDecoder method qualname lengths but not the class identity lengths."
    - "This spec covers: io.BufferedRandom.__name__.__len__()==14 (NOVEL — io_extra26 checks the equality string; io_extra42 checks __qualname__.__len__() but NOT __name__.__len__(); novel __name__ length anchor in io_extra52 namespace); io.BufferedRandom.__module__.__len__()==3 (NOVEL — io_extra26 checks equality == '_io'; no prior io spec checks BufferedRandom.__module__.__len__(); novel module name length anchor); io.IncrementalNewlineDecoder.__name__.__len__()==25 (NOVEL — io_extra13 checks equality; io_extra42 checks IncrementalNewlineDecoder method qualname lengths; but no prior io spec checks IncrementalNewlineDecoder.__name__.__len__(); novel); io.IncrementalNewlineDecoder.__module__.__len__()==3 (NOVEL — io_extra14 checks equality == '_io'; no prior io spec checks IncrementalNewlineDecoder.__module__.__len__(); novel); io.IncrementalNewlineDecoder.__qualname__.__len__()==25 (NOVEL — io_extra16 checks equality; no prior io spec checks IncrementalNewlineDecoder.__qualname__.__len__(); novel — __qualname__==__name__ for top-level C classes, both 25 chars)."
    - "io.BufferedRandom.__name__ == 'BufferedRandom' — 14 characters. io_extra26 checks the equality string; io_extra42 checks __qualname__.__len__()==14 (same value since __name__==__qualname__ for top-level C classes); no prior io spec explicitly checks __name__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedRandom.__module__ == '_io' — 3 characters. io_extra26 checks the equality string; no prior io spec checks BufferedRandom.__module__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder' — 25 characters. io_extra13/io_extra2 check the equality string; io_extra42 checks IncrementalNewlineDecoder method qualname lengths; no prior io spec checks IncrementalNewlineDecoder.__name__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.IncrementalNewlineDecoder.__module__ == '_io' — 3 characters. io_extra14 checks the equality string; no prior io spec checks IncrementalNewlineDecoder.__module__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.IncrementalNewlineDecoder.__qualname__ == 'IncrementalNewlineDecoder' — 25 characters. io_extra16 checks the equality string; __qualname__ equals __name__ for top-level C classes; no prior io spec checks IncrementalNewlineDecoder.__qualname__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedRandom class identity lengths
#
# BufferedRandom is the concrete read-write buffered I/O class in the io
# module, implemented in the C extension _io. Its class identity attributes
# are all straightforward:
#
#   BufferedRandom.__name__   == 'BufferedRandom'   -> len 14
#   BufferedRandom.__module__ == '_io'              -> len 3
#
# io_extra26 covers BufferedRandom.__name__.__eq__ and __module__.__eq__
# (equality checks). io_extra42 covers BufferedRandom.__qualname__.__len__()==14
# (same 14 chars since __qualname__==__name__ for top-level C classes).
# No prior io spec checks BufferedRandom.__name__.__len__() or
# BufferedRandom.__module__.__len__().
#
# Both invariants are novel in the io_extra52 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra52.BufferedRandom_name_len:
  description: "io.BufferedRandom.__name__.__len__() == 14 — 'BufferedRandom' has 14 characters; io_extra26 checks __name__.__eq__; io_extra42 checks __qualname__.__len__()==14 (same value); no prior io spec checks __name__.__len__(); novel in io_extra52 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: BufferedRandom.__name__.__len__
  args: []
  expected: 14

invariant io_extra52.BufferedRandom_module_len:
  description: "io.BufferedRandom.__module__.__len__() == 3 — '_io' has 3 characters; io_extra26 checks __module__.__eq__('_io'); no prior io spec checks BufferedRandom.__module__.__len__(); novel in io_extra52 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: BufferedRandom.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# io.IncrementalNewlineDecoder class identity lengths
#
# IncrementalNewlineDecoder is a codec wrapper class for translating newlines
# in byte streams, implemented in the C extension _io. Its class identity
# attributes have their standard form:
#
#   IncrementalNewlineDecoder.__name__   == 'IncrementalNewlineDecoder'  -> len 25
#   IncrementalNewlineDecoder.__module__ == '_io'                        -> len 3
#   IncrementalNewlineDecoder.__qualname__== 'IncrementalNewlineDecoder' -> len 25
#
# Prior io specs covering IncrementalNewlineDecoder:
#   io_extra13/io_extra2: __name__.__eq__('IncrementalNewlineDecoder')
#   io_extra14:           __module__.__eq__('_io')
#   io_extra16:           __qualname__.__eq__('IncrementalNewlineDecoder')
#   io_extra42:           IncrementalNewlineDecoder method __qualname__.__len__()
#
# No prior io spec checks __name__.__len__(), __module__.__len__(), or
# __qualname__.__len__() for IncrementalNewlineDecoder itself.
#
# All three length anchors are novel in the io_extra52 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra52.IncrementalNewlineDecoder_identity_lens:
  description: "io.IncrementalNewlineDecoder __name__/__module__/__qualname__ string lengths: name(25)/__module__(3)/__qualname__(25) — prior specs check equality strings but NOT __len__(); __qualname__==__name__==25 chars for this top-level C class; all three novel length anchors in io_extra52 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: ind52

  columns: [id, function, args, expected]
  rows:
    - [name_len,     IncrementalNewlineDecoder.__name__.__len__,     [], 25]
    - [module_len,   IncrementalNewlineDecoder.__module__.__len__,   [], 3]
    - [qualname_len, IncrementalNewlineDecoder.__qualname__.__len__, [], 25]
