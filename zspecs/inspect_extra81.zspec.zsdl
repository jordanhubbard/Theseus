spec: inspect_extra81
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra80

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra80.zspec.zsdl."
    - "This spec covers: inspect Signature/__init__/BoundArguments/__init__/Parameter/__init__ code attributes and BoundArguments.args/kwargs class names (Wave 245)."
    - "Signature.__init__.__code__.co_name == '__init__' — Signature is a pure-Python class in Lib/inspect.py. Verified with Python 3.14.3."
    - "Signature.__init__.__code__.co_argcount == 2 — (self, parameters); return_annotation and __validate_parameters__ are keyword-only (co_kwonlyargcount==2). Verified with Python 3.14.3."
    - "Signature.__init__.__code__.co_varnames.__len__() == 12 — 12 local variables in __init__. Verified with Python 3.14.3."
    - "BoundArguments.__init__.__code__.co_name == '__init__' — BoundArguments is a pure-Python class. Verified with Python 3.14.3."
    - "BoundArguments.__init__.__code__.co_argcount == 3 — (self, signature, arguments). Verified with Python 3.14.3."
    - "BoundArguments.__init__.__code__.co_varnames.__len__() == 3 — only the 3 parameters. Verified with Python 3.14.3."
    - "Parameter.__init__.__code__.co_name == '__init__' — Parameter is a pure-Python class. Verified with Python 3.14.3."
    - "Parameter.__init__.__code__.co_argcount == 3 — (self, name, kind); default and annotation are keyword-only. Verified with Python 3.14.3."
    - "Parameter.__init__.__code__.co_varnames.__len__() == 7 — (self, name, kind, default, annotation, msg, is_keyword). Verified with Python 3.14.3."
    - "Signature.__str__.__code__.co_name == '__str__' — Signature.__str__ is a pure-Python method. Verified with Python 3.14.3."
    - "Signature.__str__.__code__.co_argcount == 1 — (self) only. Verified with Python 3.14.3."
    - "Signature.__eq__.__code__.co_name == '__eq__' — Signature.__eq__ is a pure-Python method. Verified with Python 3.14.3."
    - "Signature.__eq__.__code__.co_argcount == 2 — (self, other). Verified with Python 3.14.3."
    - "BoundArguments.args.__class__.__name__ == 'property' — args is a property descriptor on BoundArguments. Verified with Python 3.14.3."
    - "BoundArguments.kwargs.__class__.__name__ == 'property' — kwargs is a property descriptor on BoundArguments. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Signature.__init__ code attributes — extra81
#
# Wave 245 theme: inspect.Signature.__init__ code object attributes.
#
# inspect.Signature.__init__.__code__.co_name                    == '__init__'
# inspect.Signature.__init__.__code__.co_argcount                == 2
# inspect.Signature.__init__.__code__.co_varnames.__len__()      == 12
#
# No prior inspect spec checks Signature.__init__ code attrs via inspectextra81. New to extra81.
# ---------------------------------------------------------------------------

table inspect_extra81.Signature_init_code:
  description: "Signature.__init__.__code__.co_name=='__init__', co_argcount==2, co_varnames len==12; wave 245 Signature.__init__ code attrs; new to extra81"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra81

  columns: [id, function, args, expected, description]
  rows:
    - [Signature_init_code_co_name_eq___init__,
       Signature.__init__.__code__.co_name.__eq__,
       ["__init__"],
       true,
       "inspect.Signature.__init__.__code__.co_name.__eq__('__init__') == True — Signature is a pure-Python class defined in Lib/inspect.py; its __init__ method's code object co_name records the method name '__init__' (8 chars); str.__eq__('__init__') returns True; no prior inspect spec checks Signature.__init__.__code__.co_name via inspectextra81; new to extra81"]
    - [Signature_init_code_co_argcount_eq_2,
       Signature.__init__.__code__.co_argcount.__eq__,
       [2],
       true,
       "inspect.Signature.__init__.__code__.co_argcount.__eq__(2) == True — Signature.__init__(self, parameters=None, *, return_annotation, __validate_parameters__=True) has 2 positional-or-keyword arguments (self and parameters); return_annotation and __validate_parameters__ are keyword-only (co_kwonlyargcount==2); int.__eq__(2) returns True; no prior inspect spec checks Signature.__init__.__code__.co_argcount via inspectextra81; new to extra81"]
    - [Signature_init_code_varnames_len_eq_12,
       Signature.__init__.__code__.co_varnames.__len__,
       [],
       12,
       "inspect.Signature.__init__.__code__.co_varnames.__len__() == 12 — Signature.__init__ has 12 local variable names: (self, parameters, return_annotation, __validate_parameters__, params, top_kind, seen_default, seen_var_parameters, param, kind, name, msg); tuple.__len__() returns 12; no prior inspect spec checks Signature.__init__.__code__.co_varnames.__len__() via inspectextra81; new to extra81"]

# ---------------------------------------------------------------------------
# BoundArguments.__init__ code attributes — extra81
#
# Wave 245 theme: inspect.BoundArguments.__init__ code object attributes.
#
# inspect.BoundArguments.__init__.__code__.co_name                == '__init__'
# inspect.BoundArguments.__init__.__code__.co_argcount            == 3
# inspect.BoundArguments.__init__.__code__.co_varnames.__len__()  == 3
#
# No prior inspect spec checks BoundArguments.__init__ code attrs via inspectextra81. New to extra81.
# ---------------------------------------------------------------------------

table inspect_extra81.BoundArguments_init_code:
  description: "BoundArguments.__init__.__code__.co_name=='__init__', co_argcount==3, co_varnames len==3; wave 245 BoundArguments.__init__ code attrs; new to extra81"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra81

  columns: [id, function, args, expected, description]
  rows:
    - [BoundArguments_init_code_co_name_eq___init__,
       BoundArguments.__init__.__code__.co_name.__eq__,
       ["__init__"],
       true,
       "inspect.BoundArguments.__init__.__code__.co_name.__eq__('__init__') == True — BoundArguments is a pure-Python class defined in Lib/inspect.py; its __init__ method's code object co_name records the method name '__init__' (8 chars); str.__eq__('__init__') returns True; no prior inspect spec checks BoundArguments.__init__.__code__.co_name via inspectextra81; new to extra81"]
    - [BoundArguments_init_code_co_argcount_eq_3,
       BoundArguments.__init__.__code__.co_argcount.__eq__,
       [3],
       true,
       "inspect.BoundArguments.__init__.__code__.co_argcount.__eq__(3) == True — BoundArguments.__init__(self, signature, arguments) takes three positional-or-keyword arguments; the code object's co_argcount is 3; int.__eq__(3) returns True; no prior inspect spec checks BoundArguments.__init__.__code__.co_argcount via inspectextra81; new to extra81"]
    - [BoundArguments_init_code_varnames_len_eq_3,
       BoundArguments.__init__.__code__.co_varnames.__len__,
       [],
       3,
       "inspect.BoundArguments.__init__.__code__.co_varnames.__len__() == 3 — BoundArguments.__init__ has exactly 3 local variable names: (self, signature, arguments); there are no additional local variables; tuple.__len__() returns 3; no prior inspect spec checks BoundArguments.__init__.__code__.co_varnames.__len__() via inspectextra81; new to extra81"]

# ---------------------------------------------------------------------------
# Parameter.__init__ code attributes — extra81
#
# Wave 245 theme: inspect.Parameter.__init__ code object attributes.
#
# inspect.Parameter.__init__.__code__.co_name                == '__init__'
# inspect.Parameter.__init__.__code__.co_argcount            == 3
# inspect.Parameter.__init__.__code__.co_varnames.__len__()  == 7
#
# No prior inspect spec checks Parameter.__init__ code attrs via inspectextra81. New to extra81.
# ---------------------------------------------------------------------------

table inspect_extra81.Parameter_init_code:
  description: "Parameter.__init__.__code__.co_name=='__init__', co_argcount==3, co_varnames len==7; wave 245 Parameter.__init__ code attrs; new to extra81"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra81

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_init_code_co_name_eq___init__,
       Parameter.__init__.__code__.co_name.__eq__,
       ["__init__"],
       true,
       "inspect.Parameter.__init__.__code__.co_name.__eq__('__init__') == True — Parameter is a pure-Python class defined in Lib/inspect.py; its __init__ method's code object co_name records the method name '__init__' (8 chars); str.__eq__('__init__') returns True; no prior inspect spec checks Parameter.__init__.__code__.co_name via inspectextra81; new to extra81"]
    - [Parameter_init_code_co_argcount_eq_3,
       Parameter.__init__.__code__.co_argcount.__eq__,
       [3],
       true,
       "inspect.Parameter.__init__.__code__.co_argcount.__eq__(3) == True — Parameter.__init__(self, name, kind, *, default, annotation) takes 3 positional-or-keyword arguments (self, name, kind); default and annotation are keyword-only (co_kwonlyargcount==2); int.__eq__(3) returns True; no prior inspect spec checks Parameter.__init__.__code__.co_argcount via inspectextra81; new to extra81"]
    - [Parameter_init_code_varnames_len_eq_7,
       Parameter.__init__.__code__.co_varnames.__len__,
       [],
       7,
       "inspect.Parameter.__init__.__code__.co_varnames.__len__() == 7 — Parameter.__init__ has 7 local variable names: (self, name, kind, default, annotation, msg, is_keyword); tuple.__len__() returns 7; no prior inspect spec checks Parameter.__init__.__code__.co_varnames.__len__() via inspectextra81; new to extra81"]

# ---------------------------------------------------------------------------
# Signature.__str__/__eq__ and BoundArguments.args/kwargs class names — extra81
#
# Wave 245 theme: Signature.__str__/__eq__ code attrs and BoundArguments property class names.
#
# inspect.Signature.__str__.__code__.co_name     == '__str__'
# inspect.Signature.__str__.__code__.co_argcount == 1
# inspect.Signature.__eq__.__code__.co_name      == '__eq__'
# inspect.Signature.__eq__.__code__.co_argcount  == 2
# inspect.BoundArguments.args.__class__.__name__ == 'property'
# inspect.BoundArguments.kwargs.__class__.__name__ == 'property'
#
# No prior inspect spec checks Signature.__str__/__eq__ code attrs and BoundArguments.args/kwargs class names via inspectextra81. New to extra81.
# ---------------------------------------------------------------------------

table inspect_extra81.Signature_str_eq_and_BoundArguments_props:
  description: "Signature.__str__ co_name=='__str__' co_argcount==1; __eq__ co_name=='__eq__' co_argcount==2; BoundArguments.args/kwargs __class__.__name__=='property'; wave 245; new to extra81"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra81

  columns: [id, function, args, expected, description]
  rows:
    - [Signature_str_code_co_name_eq___str__,
       Signature.__str__.__code__.co_name.__eq__,
       ["__str__"],
       true,
       "inspect.Signature.__str__.__code__.co_name.__eq__('__str__') == True — Signature is a pure-Python class in Lib/inspect.py; its __str__ method's code object co_name records '__str__' (7 chars); str.__eq__('__str__') returns True; no prior inspect spec checks Signature.__str__.__code__.co_name via inspectextra81; new to extra81"]
    - [Signature_str_code_co_argcount_eq_1,
       Signature.__str__.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.Signature.__str__.__code__.co_argcount.__eq__(1) == True — Signature.__str__(self) takes exactly one positional argument, self; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks Signature.__str__.__code__.co_argcount via inspectextra81; new to extra81"]
    - [Signature_eq_code_co_name_eq___eq__,
       Signature.__eq__.__code__.co_name.__eq__,
       ["__eq__"],
       true,
       "inspect.Signature.__eq__.__code__.co_name.__eq__('__eq__') == True — Signature is a pure-Python class in Lib/inspect.py; its __eq__ method's code object co_name records '__eq__' (6 chars); str.__eq__('__eq__') returns True; no prior inspect spec checks Signature.__eq__.__code__.co_name via inspectextra81; new to extra81"]
    - [Signature_eq_code_co_argcount_eq_2,
       Signature.__eq__.__code__.co_argcount.__eq__,
       [2],
       true,
       "inspect.Signature.__eq__.__code__.co_argcount.__eq__(2) == True — Signature.__eq__(self, other) takes two positional-or-keyword arguments: self and other; the code object's co_argcount is 2; int.__eq__(2) returns True; no prior inspect spec checks Signature.__eq__.__code__.co_argcount via inspectextra81; new to extra81"]
    - [BoundArguments_args_class_name_eq_property,
       BoundArguments.args.__class__.__name__.__eq__,
       ["property"],
       true,
       "inspect.BoundArguments.args.__class__.__name__.__eq__('property') == True — BoundArguments.args is a property descriptor defined on the BoundArguments class in Lib/inspect.py; accessing it on the class returns the property object whose __class__.__name__ is 'property' (8 chars); str.__eq__('property') returns True; no prior inspect spec checks BoundArguments.args.__class__.__name__ via inspectextra81; new to extra81"]
    - [BoundArguments_kwargs_class_name_eq_property,
       BoundArguments.kwargs.__class__.__name__.__eq__,
       ["property"],
       true,
       "inspect.BoundArguments.kwargs.__class__.__name__.__eq__('property') == True — BoundArguments.kwargs is a property descriptor defined on the BoundArguments class in Lib/inspect.py; accessing it on the class returns the property object whose __class__.__name__ is 'property' (8 chars); str.__eq__('property') returns True; no prior inspect spec checks BoundArguments.kwargs.__class__.__name__ via inspectextra81; new to extra81"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra81
# ---------------------------------------------------------------------------

invariant inspect_extra81.Signature_init_co_name:
  description: "inspect.Signature.__init__.__code__.co_name.__eq__('__init__') == True — Signature.__init__ code object name is '__init__'; wave 245 Signature.__init__ code attrs; new to extra81"
  kind: python_call_eq
  function: Signature.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

invariant inspect_extra81.Signature_init_co_argcount:
  description: "inspect.Signature.__init__.__code__.co_argcount.__eq__(2) == True — Signature.__init__ has 2 positional-or-keyword args (self, parameters); wave 245 Signature.__init__ code attrs; new to extra81"
  kind: python_call_eq
  function: Signature.__init__.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra81.BoundArguments_init_co_argcount:
  description: "inspect.BoundArguments.__init__.__code__.co_argcount.__eq__(3) == True — BoundArguments.__init__ has 3 positional-or-keyword args (self, signature, arguments); wave 245 BoundArguments.__init__ code attrs; new to extra81"
  kind: python_call_eq
  function: BoundArguments.__init__.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant inspect_extra81.Parameter_init_co_argcount:
  description: "inspect.Parameter.__init__.__code__.co_argcount.__eq__(3) == True — Parameter.__init__ has 3 positional-or-keyword args (self, name, kind); wave 245 Parameter.__init__ code attrs; new to extra81"
  kind: python_call_eq
  function: Parameter.__init__.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant inspect_extra81.BoundArguments_args_class_name:
  description: "inspect.BoundArguments.args.__class__.__name__.__eq__('property') == True — BoundArguments.args is a property descriptor on the class; wave 245 BoundArguments property class names; new to extra81"
  kind: python_call_eq
  function: BoundArguments.args.__class__.__name__.__eq__
  args: ["property"]
  expected: true
