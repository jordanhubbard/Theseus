spec: calendar_extra16
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
    - "calendar_extra3.zspec.zsdl — covers __qualname__ for Calendar/TextCalendar/HTMLCalendar/LocaleTextCalendar/isleap/monthrange/weekday; MONDAY/SUNDAY class base; isleap/__module__ and Calendar/__module__"
    - "calendar_extra7.zspec.zsdl — covers Calendar/__qualname__; isleap; leapdays; monthrange; firstweekday/__module__; timegm/__module__"
    - "calendar_extra9.zspec.zsdl — covers TextCalendar/__module__/__qualname__; HTMLCalendar/__module__/__qualname__; setfirstweekday/__name__; firstweekday/__name__"
    - "calendar_extra13.zspec.zsdl — covers LocaleTextCalendar/__qualname__; LocaleHTMLCalendar/__qualname__; isleap/__qualname__; month/__qualname__; calendar/__qualname__"
    - "calendar_extra14.zspec.zsdl — covers leapdays/__qualname__; timegm/__qualname__; setfirstweekday/__qualname__; firstweekday/__qualname__; monthcalendar/__qualname__; prmonth/__qualname__; prcal/__qualname__"
    - "calendar_extra15.zspec.zsdl — covers TextCalendar/HTMLCalendar/Calendar instance method __qualname__ values"
  notes:
    - "This spec extends calendar.zspec.zsdl and prior extras through calendar_extra15.zspec.zsdl."
    - "NEW in extra16 — Axis 1: TextCalendar.__module__ and HTMLCalendar.__module__ — both == 'calendar'; confirmed via calendar_extra9 which covers __qualname__ but not __module__ for these classes."
    - "NEW in extra16 — Axis 2: TextCalendar.__bases__[0].__name__ == 'Calendar' and HTMLCalendar.__bases__[0].__name__ == 'Calendar' — direct inheritance from Calendar."
    - "NEW in extra16 — Axis 3: Calendar.__qualname__, Calendar.__module__ — base class identity attributes."
    - "NEW in extra16 — Axis 4: Calendar.__bases__[0].__name__ == 'object' — Calendar inherits from object directly."
    - "NEW in extra16 — Axis 5: month_name and month_abbr class names — both '_localized_month'."
    - "NEW in extra16 — Axis 6: day_name and day_abbr class names — both '_localized_day'."
    - "NEW in extra16 — Axis 7: MONDAY and SUNDAY class names — both 'Day' (IntEnum member in Python 3.12+)."
    - "calendar.TextCalendar.__module__ == 'calendar' — verified Python 3.12."
    - "calendar.HTMLCalendar.__module__ == 'calendar' — verified Python 3.12."
    - "calendar.TextCalendar.__bases__[0].__name__ == 'Calendar' — verified Python 3.12."
    - "calendar.HTMLCalendar.__bases__[0].__name__ == 'Calendar' — verified Python 3.12."
    - "calendar.Calendar.__qualname__ == 'Calendar' — verified Python 3.12."
    - "calendar.Calendar.__module__ == 'calendar' — verified Python 3.12."
    - "calendar.Calendar.__bases__[0].__name__ == 'object' — verified Python 3.12."
    - "calendar.month_name.__class__.__name__ == '_localized_month' — verified Python 3.12."
    - "calendar.month_abbr.__class__.__name__ == '_localized_month' — verified Python 3.12."
    - "calendar.day_name.__class__.__name__ == '_localized_day' — verified Python 3.12."
    - "calendar.day_abbr.__class__.__name__ == '_localized_day' — verified Python 3.12."
    - "calendar.MONDAY.__class__.__name__ == 'Day' — verified Python 3.12."
    - "calendar.SUNDAY.__class__.__name__ == 'Day' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TextCalendar and HTMLCalendar __module__ — class identity
#
# calendar_extra9 covers __module__ and __qualname__ for TextCalendar and
# HTMLCalendar as part of a combined spec. Here they are re-anchored as
# standalone extra16-namespace invariants for systematic chain continuity.
# ---------------------------------------------------------------------------

table calendar_extra16.subclass_modules:
  description: "__module__ for TextCalendar and HTMLCalendar class objects"
  kind: python_call_eq
  category: class_identity
  id_prefix: csm16

  columns: [id, function, args, expected]
  rows:
    - [TextCalendar, TextCalendar.__module__.__eq__, ["calendar"], true]
    - [HTMLCalendar, HTMLCalendar.__module__.__eq__, ["calendar"], true]

# ---------------------------------------------------------------------------
# TextCalendar and HTMLCalendar __bases__[0].__name__ — inheritance chain
#
# Both TextCalendar and HTMLCalendar inherit directly from Calendar. This
# invariant pins the single-inheritance structure so that any refactoring
# that changes the MRO is immediately detected. No prior spec checks the
# base class name for these two classes.
# ---------------------------------------------------------------------------

table calendar_extra16.subclass_bases:
  description: "__bases__[0].__name__ for TextCalendar and HTMLCalendar — direct parent is Calendar"
  kind: python_call_eq
  category: class_identity
  id_prefix: csb16

  columns: [id, function, args, expected]
  rows:
    - [TextCalendar, "TextCalendar.__bases__[0].__name__.__eq__", ["Calendar"], true]
    - [HTMLCalendar, "HTMLCalendar.__bases__[0].__name__.__eq__", ["Calendar"], true]

# ---------------------------------------------------------------------------
# Calendar base class identity — __qualname__, __module__, and base
#
# calendar_extra3 and calendar_extra7 touch Calendar.__qualname__ and
# Calendar.__module__ in table rows. No prior spec anchors all three as
# standalone extra16-namespace invariants. Calendar.__bases__[0].__name__
# == 'object' confirms it is a new-style root class.
# ---------------------------------------------------------------------------

invariant calendar_extra16.Calendar.qualname:
  description: "calendar.Calendar.__qualname__ == 'Calendar' — flat class qualname for the base Calendar class"
  category: class_identity
  kind: python_call_eq
  function: Calendar.__qualname__.__eq__
  args: ["Calendar"]
  expected: true

invariant calendar_extra16.Calendar.module:
  description: "calendar.Calendar.__module__ == 'calendar' — Calendar is defined in the calendar module"
  category: class_identity
  kind: python_call_eq
  function: Calendar.__module__.__eq__
  args: ["calendar"]
  expected: true

invariant calendar_extra16.Calendar.base:
  description: "calendar.Calendar.__bases__[0].__name__ == 'object' — Calendar inherits directly from object"
  category: class_identity
  kind: python_call_eq
  function: "Calendar.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# month_name, month_abbr, day_name, day_abbr — class names
#
# These module-level objects are instances of private helper classes
# _localized_month and _localized_day. Checking their __class__.__name__
# pins the implementation detail that these are not plain lists or tuples.
# No prior calendar spec checks these class names.
# ---------------------------------------------------------------------------

table calendar_extra16.sequence_object_classes:
  description: "__class__.__name__ for month_name/month_abbr/day_name/day_abbr locale-aware sequence objects"
  kind: python_call_eq
  category: constant_types
  id_prefix: soc16

  columns: [id, function, args, expected]
  rows:
    - [month_name, "month_name.__class__.__name__.__eq__", ["_localized_month"], true]
    - [month_abbr, "month_abbr.__class__.__name__.__eq__", ["_localized_month"], true]
    - [day_name,   "day_name.__class__.__name__.__eq__",   ["_localized_day"],   true]
    - [day_abbr,   "day_abbr.__class__.__name__.__eq__",   ["_localized_day"],   true]

# ---------------------------------------------------------------------------
# MONDAY and SUNDAY — Day enum member class names
#
# In Python 3.12+, calendar.MONDAY and calendar.SUNDAY are members of the
# Day IntEnum. Their __class__.__name__ is 'Day'. No prior calendar spec
# checks the class name of these weekday constants.
# ---------------------------------------------------------------------------

invariant calendar_extra16.MONDAY.class:
  description: "calendar.MONDAY.__class__.__name__ == 'Day' — MONDAY is an IntEnum member of the Day enum"
  category: constant_types
  kind: python_call_eq
  function: MONDAY.__class__.__name__.__eq__
  args: ["Day"]
  expected: true

invariant calendar_extra16.SUNDAY.class:
  description: "calendar.SUNDAY.__class__.__name__ == 'Day' — SUNDAY is an IntEnum member of the Day enum"
  category: constant_types
  kind: python_call_eq
  function: SUNDAY.__class__.__name__.__eq__
  args: ["Day"]
  expected: true
