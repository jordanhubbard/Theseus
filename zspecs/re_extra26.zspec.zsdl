# ---------------------------------------------------------------------------
# Table: consolidated re.Pattern and re.Match method __qualname__ values
#
# Groups all eleven method __qualname__ checks from this spec into a single
# table: seven Pattern methods (match, search, findall, finditer, sub, split,
# fullmatch) and four Match methods (group, groups, start, end).
# All values verified at runtime.
# ---------------------------------------------------------------------------

table re_extra26.pattern_match_method_qualnames:
  description: "re.Pattern and re.Match method __qualname__ values — seven Pattern methods and four Match methods"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [Pattern_match,
       Pattern.match.__qualname__.__eq__,
       ["Pattern.match"],
       true,
       "Pattern.match.__qualname__ == 'Pattern.match'"]
    - [Pattern_search,
       Pattern.search.__qualname__.__eq__,
       ["Pattern.search"],
       true,
       "Pattern.search.__qualname__ == 'Pattern.search'"]
    - [Pattern_findall,
       Pattern.findall.__qualname__.__eq__,
       ["Pattern.findall"],
       true,
       "Pattern.findall.__qualname__ == 'Pattern.findall'"]
    - [Pattern_finditer,
       Pattern.finditer.__qualname__.__eq__,
       ["Pattern.finditer"],
       true,
       "Pattern.finditer.__qualname__ == 'Pattern.finditer'"]
    - [Pattern_sub,
       Pattern.sub.__qualname__.__eq__,
       ["Pattern.sub"],
       true,
       "Pattern.sub.__qualname__ == 'Pattern.sub'"]
    - [Pattern_split,
       Pattern.split.__qualname__.__eq__,
       ["Pattern.split"],
       true,
       "Pattern.split.__qualname__ == 'Pattern.split'"]
    - [Pattern_fullmatch,
       Pattern.fullmatch.__qualname__.__eq__,
       ["Pattern.fullmatch"],
       true,
       "Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch'"]
    - [Match_group,
       Match.group.__qualname__.__eq__,
       ["Match.group"],
       true,
       "Match.group.__qualname__ == 'Match.group'"]
    - [Match_groups,
       Match.groups.__qualname__.__eq__,
       ["Match.groups"],
       true,
       "Match.groups.__qualname__ == 'Match.groups'"]
    - [Match_start,
       Match.start.__qualname__.__eq__,
       ["Match.start"],
       true,
       "Match.start.__qualname__ == 'Match.start'"]
    - [Match_end,
       Match.end.__qualname__.__eq__,
       ["Match.end"],
       true,
       "Match.end.__qualname__ == 'Match.end'"]
