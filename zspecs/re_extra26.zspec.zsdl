spec: re_extra26
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and prior extras through re_extra25.zspec.zsdl."
    - "re_extra8 covers: compile/match/search/fullmatch/sub/split/findall/finditer __qualname__ via .__eq__ table (top-level functions)."
    - "re_extra25 covers: compile/match/search/findall/finditer/sub/subn/split/fullmatch/escape top-level function __qualname__ standalone invariants."
    - "No prior spec covers re.Pattern.match.__qualname__, re.Pattern.search.__qualname__, or any Pattern/Match method __qualname__ as standalone invariants."
    - "re.Pattern.match.__qualname__ == 'Pattern.match' — compiled pattern method qualname includes owning class. Verified at runtime."
    - "re.Pattern.search.__qualname__ == 'Pattern.search' — compiled pattern method qualname includes owning class. Verified at runtime."
    - "re.Pattern.findall.__qualname__ == 'Pattern.findall' — compiled pattern method qualname includes owning class. Verified at runtime."
    - "re.Pattern.finditer.__qualname__ == 'Pattern.finditer' — compiled pattern method qualname includes owning class. Verified at runtime."
    - "re.Pattern.sub.__qualname__ == 'Pattern.sub' — compiled pattern method qualname includes owning class. Verified at runtime."
    - "re.Pattern.split.__qualname__ == 'Pattern.split' — compiled pattern method qualname includes owning class. Verified at runtime."
    - "re.Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch' — compiled pattern method qualname includes owning class. Verified at runtime."
    - "re.Match.group.__qualname__ == 'Match.group' — match object method qualname includes owning class. Verified at runtime."
    - "re.Match.groups.__qualname__ == 'Match.groups' — match object method qualname includes owning class. Verified at runtime."
    - "re.Match.start.__qualname__ == 'Match.start' — match object method qualname includes owning class. Verified at runtime."
    - "re.Match.end.__qualname__ == 'Match.end' — match object method qualname includes owning class. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern.match — __qualname__
#
# No prior spec verifies Pattern.match.__qualname__ as a standalone invariant.
# For a method defined in class Pattern, __qualname__ takes the form
# 'Pattern.match'. Verified at runtime: 'Pattern.match'.
# ---------------------------------------------------------------------------

invariant re_extra26.Pattern.match_qualname:
  description: "re.Pattern.match.__qualname__ == 'Pattern.match' — compiled pattern method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Pattern.match.__qualname__.__eq__
  args: ["Pattern.match"]
  expected: true

