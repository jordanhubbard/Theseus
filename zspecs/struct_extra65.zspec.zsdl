spec: struct_extra65
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra64.zspec.zsdl — covers pack_into/unpack_from/iter_unpack __qualname__/__module__/__class__/__name__ / Struct.pack_into/__class__/__name__=='method_descriptor' / Struct.unpack_from/__class__/__name__=='method_descriptor' (table + invariants)."
    - "struct_extra63.zspec.zsdl — covers pack/unpack/calcsize __qualname__/__module__/__class__/__name__ / Struct.unpack_from/__qualname__ / Struct.iter_unpack/__qualname__ / pack/unpack/calcsize __class__.__name__=='builtin_function_or_method' (table + invariants)."
    - "struct_extra62.zspec.zsdl — covers Struct.pack/__qualname__ lengths / Struct.pack/__class__.__name__=='method_descriptor' / Struct.unpack/__class__.__name__=='method_descriptor' (table + invariants)."
    - "struct.zspec — covers struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra64; it does NOT duplicate invariants present in those files."
    - "Wave 236 theme: struct.Struct class __dict__ contents + module-level function __doc__ content checks."
    - "struct.Struct.__dict__.__class__.__name__ == 'mappingproxy' — the __dict__ of the Struct C extension type is a mappingproxy. No prior struct spec checks Struct.__dict__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('pack') — Struct defines 'pack' as a C method in _struct.c; it is present in Struct.__dict__. No prior struct spec checks Struct.__dict__.__contains__ for any method. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('unpack') — Struct defines 'unpack' as a C method; present in Struct.__dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('pack_into') — Struct defines 'pack_into' as a C method. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('unpack_from') — Struct defines 'unpack_from' as a C method. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('iter_unpack') — Struct defines 'iter_unpack' as a C method. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('size') — Struct.size is a C property/getter on the Struct type; present in Struct.__dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('format') — Struct.format is a C property/getter on the Struct type; present in Struct.__dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__doc__.__contains__('values') — the docstring for the module-level pack function describes packing 'values'; no prior struct spec checks pack.__doc__.__contains__('values'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__doc__.__contains__('values') — the docstring for the module-level unpack function describes returning 'values'; no prior struct spec checks unpack.__doc__.__contains__('values'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model:
  semantics: "struct.error is raised for mismatched buffer sizes and invalid format strings. It is a subclass of Exception."
  stderr: "null"
  stickiness: "N/A — struct functions are pure; Struct objects are immutable after construction."
  codes: {}

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__class__.__name__ == 'mappingproxy'
#
# Wave 236 theme: Struct class __dict__ type identity.
#
# struct.Struct is a C extension type. The __dict__ of a C type is a
# mappingproxy. No prior struct spec checks Struct.__dict__.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra65.Struct_dict_mappingproxy:
  description: "struct.Struct.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Struct is a C extension type; its __dict__ is a mappingproxy; no prior struct spec checks Struct.__dict__.__class__.__name__; first mappingproxy type anchor for struct.Struct.__dict__"
  category: class_dict
  kind: python_call_eq
  function: Struct.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__ checks for core C methods
#
# Wave 236 theme: Struct class defines C methods in its __dict__.
#
# struct.Struct is a C extension type defined in _struct.c. Its C methods
# pack, unpack, pack_into, unpack_from, and iter_unpack are defined on the
# type and are present in Struct.__dict__. No prior struct spec checks
# Struct.__dict__.__contains__ for any of these methods.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra65.Struct_dict_methods:
  description: "struct.Struct.__dict__.__contains__('pack')==True / __contains__('unpack')==True / __contains__('pack_into')==True / __contains__('unpack_from')==True / __contains__('iter_unpack')==True — Struct defines all five pack/unpack methods as C methods in _struct.c; they are present in Struct.__dict__; no prior struct spec checks Struct.__dict__.__contains__ for any method; first Struct.__dict__ method content anchor"
  kind: python_call_eq
  category: class_dict
  id_prefix: structspec65

  columns: [id, function, args, expected]
  rows:
    - [Struct_dict_has_pack,        Struct.__dict__.__contains__, ["pack"],        true]
    - [Struct_dict_has_unpack,      Struct.__dict__.__contains__, ["unpack"],      true]
    - [Struct_dict_has_pack_into,   Struct.__dict__.__contains__, ["pack_into"],   true]
    - [Struct_dict_has_unpack_from, Struct.__dict__.__contains__, ["unpack_from"], true]
    - [Struct_dict_has_iter_unpack, Struct.__dict__.__contains__, ["iter_unpack"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__ checks for size and format properties
#
# Wave 236 theme: Struct class __dict__ has size and format getters.
#
# struct.Struct.size and struct.Struct.format are C property descriptors on
# the Struct type, stored in Struct.__dict__. No prior struct spec checks
# Struct.__dict__.__contains__ for 'size' or 'format'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra65.Struct_dict_properties:
  description: "struct.Struct.__dict__.__contains__('size')==True / __contains__('format')==True — Struct.size and Struct.format are C property descriptors on the Struct type; they are present in Struct.__dict__; no prior struct spec checks Struct.__dict__.__contains__ for 'size' or 'format'; first Struct.__dict__ property content anchor"
  kind: python_call_eq
  category: class_dict
  id_prefix: structspec65

  columns: [id, function, args, expected]
  rows:
    - [Struct_dict_has_size,   Struct.__dict__.__contains__, ["size"],   true]
    - [Struct_dict_has_format, Struct.__dict__.__contains__, ["format"], true]

# ---------------------------------------------------------------------------
# struct.pack and struct.unpack __doc__.__contains__('values')
#
# Wave 236 theme: module-level function docstring content.
#
# struct.pack packs values into bytes and its docstring mentions 'values'.
# struct.unpack unpacks bytes returning values and its docstring mentions
# 'values'. No prior struct spec checks __doc__.__contains__('values') for
# pack or unpack. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra65.struct_func_doc_contains:
  description: "struct.pack/__doc__.__contains__('values')==True / struct.unpack/__doc__.__contains__('values')==True — the docstrings for pack and unpack describe packing/unpacking 'values'; no prior struct spec checks __doc__.__contains__('values') for pack or unpack; first docstring content anchor for struct module-level pack and unpack functions"
  kind: python_call_eq
  category: docstrings
  id_prefix: structspec65

  columns: [id, function, args, expected]
  rows:
    - [pack_doc_values,   pack.__doc__.__contains__,   ["values"], true]
    - [unpack_doc_values, unpack.__doc__.__contains__,  ["values"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('pack') — standalone
#
# struct.Struct.pack is a C method defined in _struct.c. It is present in
# Struct.__dict__. No prior struct spec checks Struct.__dict__.__contains__.
# First Struct.__dict__ content standalone for 'pack'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra65.Struct_dict_has_pack:
  description: "struct.Struct.__dict__.__contains__('pack') == True — Struct.pack is a C method in _struct.c; it is in Struct.__dict__; no prior struct spec checks Struct.__dict__.__contains__; first Struct.__dict__ content standalone for 'pack'"
  category: class_dict
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('size') — standalone
#
# struct.Struct.size is a C property descriptor on the Struct type. It is
# present in Struct.__dict__. No prior struct spec checks
# Struct.__dict__.__contains__('size').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra65.Struct_dict_has_size:
  description: "struct.Struct.__dict__.__contains__('size') == True — Struct.size is a C property descriptor on the Struct type; it is in Struct.__dict__; no prior struct spec checks Struct.__dict__.__contains__('size'); first size property content standalone for struct.Struct.__dict__"
  category: class_dict
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["size"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('format') — standalone
#
# struct.Struct.format is a C property descriptor on the Struct type. It is
# present in Struct.__dict__. No prior struct spec checks
# Struct.__dict__.__contains__('format').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra65.Struct_dict_has_format:
  description: "struct.Struct.__dict__.__contains__('format') == True — Struct.format is a C property descriptor on the Struct type; it is in Struct.__dict__; no prior struct spec checks Struct.__dict__.__contains__('format'); first format property content standalone for struct.Struct.__dict__"
  category: class_dict
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["format"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack.__doc__.__contains__('values') — standalone
#
# struct.pack is a C builtin function. Its docstring describes packing values
# and contains 'values'. No prior struct spec checks pack.__doc__.__contains__.
# First docstring content standalone for struct.pack.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra65.pack_doc_values:
  description: "struct.pack.__doc__.__contains__('values') == True — pack's docstring describes packing values and contains 'values'; no prior struct spec checks pack.__doc__.__contains__('values'); first docstring content standalone for struct.pack"
  category: docstrings
  kind: python_call_eq
  function: pack.__doc__.__contains__
  args: ["values"]
  expected: true
