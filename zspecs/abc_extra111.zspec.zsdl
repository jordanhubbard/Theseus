spec: abc_extra111
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "CPython source: Lib/importlib/_bootstrap.py"
  notes:
    - "This spec extends abc_extra110.zspec.zsdl."
    - "This spec covers: wave 256 theme — abc module __spec__ and __loader__ attributes not covered in extra33-extra110. Prior specs covered: abc.__spec__.__class__.__name__ via membership (extra33-extra41), abc.__loader__ class name (extra54-extra67), abc.__spec__.name (extra89). NOT previously covered as standalone invariants or table rows: abc.__spec__.__class__.__name__=='ModuleSpec' (len=10), abc.__spec__.__class__.__module__=='_frozen_importlib' (len=17), abc.__spec__.origin=='frozen' (len=6), abc.__spec__.origin.__class__.__name__=='str', abc.__loader__.__class__.__name__=='type' (len=4), abc.__loader__.__class__.__module__=='builtins' (len=8), abc.__loader__.__name__=='FrozenImporter' (len=14), abc.__loader__.__module__=='_frozen_importlib' (len=17). NEW in extra111: all of the above as fresh coverage. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__spec__.__class__.__name__ == 'ModuleSpec' (len=10). abc.__spec__ is an instance of importlib._bootstrap.ModuleSpec whose __class__.__module__ is '_frozen_importlib' (len=17). abc.__spec__.name == 'abc' (len=3). abc.__spec__.origin == 'frozen' (len=6) — abc is a frozen module in Python 3.11+. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__loader__ is the FrozenImporter class itself (not an instance). abc.__loader__.__class__.__name__ == 'type' (it is a class, so its class is 'type'). abc.__loader__.__name__ == 'FrozenImporter' (len=14). abc.__loader__.__module__ == '_frozen_importlib' (len=17, same as abc.__spec__.__class__.__module__). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.__spec__ class and origin attributes — extra111
#
# Wave 256 theme: abc.__spec__ ModuleSpec class name and module, origin value.
#
# abc.__spec__.__class__.__name__    == 'ModuleSpec'          (len=10)
# abc.__spec__.__class__.__module__  == '_frozen_importlib'   (len=17)
# abc.__spec__.name                  == 'abc'                 (len=3)
# abc.__spec__.origin                == 'frozen'              (len=6)
# abc.__spec__.origin.__class__.__name__  == 'str'
# ---------------------------------------------------------------------------

table abc_extra111.abc_spec_class_attrs:
  description: "abc.__spec__ class and origin attribute checks in abcspec111 namespace — wave 256 theme: abc.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (len=10: 'ModuleSpec'=10; abc.__spec__ is an instance of importlib._bootstrap.ModuleSpec; in Python 3.11+ abc is frozen, so its loader and spec come from _frozen_importlib rather than importlib._bootstrap_external; ModuleSpec is the standard class representing a module's import metadata); abc.__spec__.__class__.__name__.__len__()==10; abc.__spec__.__class__.__module__.__eq__('_frozen_importlib')==True (len=17: '_frozen_importlib'=17; this is the C-level frozen importlib bootstrap module, distinct from the Python-level 'importlib._bootstrap'; the underscore prefix indicates it is an internal implementation); abc.__spec__.__class__.__module__.__len__()==17; abc.__spec__.name.__eq__('abc')==True (len=3: the module name is 'abc', consistent with import abc; this is the canonical module name used in sys.modules); abc.__spec__.name.__len__()==3; abc.__spec__.origin.__eq__('frozen')==True (len=6: 'frozen'=6; the origin is 'frozen' rather than a file path because abc is compiled into the Python interpreter as a frozen module in Python 3.11+; frozen modules load faster because they bypass file I/O); abc.__spec__.origin.__len__()==6; abc.__spec__.origin.__class__.__name__.__eq__('str')==True (origin is a string value 'frozen', so its class is str); compare: __spec__.__class__.__name__ len=10 > __spec__.origin len=6 > __spec__.name len=3 (ModuleSpec longest, abc name shortest); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcspec111

  columns: [id, function, args, expected, description]
  rows:
    - [spec_cls_eq,    abc.__spec__.__class__.__name__.__eq__,        ["ModuleSpec"],        true, "abc.__spec__.__class__.__name__ == 'ModuleSpec' (len=10); verified with Python 3.14.3"]
    - [spec_cls_len,   abc.__spec__.__class__.__name__.__len__,       [],                   10,   "abc.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec'=10); verified with Python 3.14.3"]
    - [spec_mod_eq,    abc.__spec__.__class__.__module__.__eq__,      ["_frozen_importlib"], true, "abc.__spec__.__class__.__module__ == '_frozen_importlib' (len=17); verified with Python 3.14.3"]
    - [spec_mod_len,   abc.__spec__.__class__.__module__.__len__,     [],                   17,   "abc.__spec__.__class__.__module__.__len__() == 17 ('_frozen_importlib'=17); verified with Python 3.14.3"]
    - [spec_name_eq,   abc.__spec__.name.__eq__,                      ["abc"],               true, "abc.__spec__.name == 'abc' (len=3, the module name); verified with Python 3.14.3"]
    - [spec_name_len,  abc.__spec__.name.__len__,                     [],                   3,    "abc.__spec__.name.__len__() == 3 ('abc'=3); verified with Python 3.14.3"]
    - [spec_orig_eq,   abc.__spec__.origin.__eq__,                    ["frozen"],            true, "abc.__spec__.origin == 'frozen' (len=6; abc is a frozen module); verified with Python 3.14.3"]
    - [spec_orig_len,  abc.__spec__.origin.__len__,                   [],                   6,    "abc.__spec__.origin.__len__() == 6 ('frozen'=6); verified with Python 3.14.3"]
    - [spec_orig_cls,  abc.__spec__.origin.__class__.__name__.__eq__, ["str"],               true, "abc.__spec__.origin.__class__.__name__ == 'str' (origin is a string); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.__loader__ class and name attributes — extra111
#
# Wave 256 theme: abc.__loader__ FrozenImporter class attributes.
#
# abc.__loader__.__class__.__name__    == 'type'               (len=4)
# abc.__loader__.__class__.__module__  == 'builtins'           (len=8)
# abc.__loader__.__name__              == 'FrozenImporter'     (len=14)
# abc.__loader__.__module__            == '_frozen_importlib'  (len=17)
# ---------------------------------------------------------------------------

table abc_extra111.abc_loader_attrs:
  description: "abc.__loader__ class and name attribute checks in abcspec111 namespace — wave 256 theme: abc.__loader__ is the FrozenImporter class (not an instance); abc.__loader__.__class__.__name__.__eq__('type')==True (len=4: FrozenImporter is a class, and classes are instances of 'type' in Python; so __loader__.__class__.__name__=='type'; compare: an instance of FrozenImporter would have __class__.__name__=='FrozenImporter' instead); abc.__loader__.__class__.__name__.__len__()==4; abc.__loader__.__class__.__module__.__eq__('builtins')==True (len=8: 'builtins'=8; the metaclass 'type' is defined in the builtins module); abc.__loader__.__class__.__module__.__len__()==8; abc.__loader__.__name__.__eq__('FrozenImporter')==True (len=14: 'FrozenImporter'=14; this is the class name of the frozen module loader — abc.__loader__ is the class itself, so __name__ gives the class name); abc.__loader__.__name__.__len__()==14; abc.__loader__.__module__.__eq__('_frozen_importlib')==True (len=17: '_frozen_importlib'=17; same as abc.__spec__.__class__.__module__; FrozenImporter is defined in the internal frozen bootstrap module); abc.__loader__.__module__.__len__()==17; compare: __loader__.__name__ len=14 ('FrozenImporter') vs __spec__.__class__.__name__ len=10 ('ModuleSpec') — FrozenImporter name is 4 chars longer; compare: __loader__.__class__.__module__ len=8 ('builtins') vs __loader__.__module__ len=17 ('_frozen_importlib') — __module__ is 9 chars longer; note: __loader__.__module__==abc.__spec__.__class__.__module__=='_frozen_importlib' (len=17, both refer to the frozen bootstrap); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcspec111a

  columns: [id, function, args, expected, description]
  rows:
    - [ldr_cls_eq,    abc.__loader__.__class__.__name__.__eq__,     ["type"],              true, "abc.__loader__.__class__.__name__ == 'type' (FrozenImporter is a class, metaclass is type); verified with Python 3.14.3"]
    - [ldr_cls_len,   abc.__loader__.__class__.__name__.__len__,    [],                   4,    "abc.__loader__.__class__.__name__.__len__() == 4 ('type'=4); verified with Python 3.14.3"]
    - [ldr_clsmod_eq, abc.__loader__.__class__.__module__.__eq__,   ["builtins"],          true, "abc.__loader__.__class__.__module__ == 'builtins' (len=8; metaclass type is in builtins); verified with Python 3.14.3"]
    - [ldr_clsmod_len,abc.__loader__.__class__.__module__.__len__,  [],                   8,    "abc.__loader__.__class__.__module__.__len__() == 8 ('builtins'=8); verified with Python 3.14.3"]
    - [ldr_name_eq,   abc.__loader__.__name__.__eq__,               ["FrozenImporter"],   true, "abc.__loader__.__name__ == 'FrozenImporter' (len=14; __loader__ is the class itself); verified with Python 3.14.3"]
    - [ldr_name_len,  abc.__loader__.__name__.__len__,              [],                   14,   "abc.__loader__.__name__.__len__() == 14 ('FrozenImporter'=14); verified with Python 3.14.3"]
    - [ldr_mod_eq,    abc.__loader__.__module__.__eq__,             ["_frozen_importlib"], true, "abc.__loader__.__module__ == '_frozen_importlib' (len=17; same as __spec__.__class__.__module__); verified with Python 3.14.3"]
    - [ldr_mod_len,   abc.__loader__.__module__.__len__,            [],                   17,   "abc.__loader__.__module__.__len__() == 17 ('_frozen_importlib'=17, ties with spec class module); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.__spec__ and __loader__ cross-checks — extra111
#
# Wave 256 theme: comparing __spec__ and __loader__ lengths and module names.
#
# abc.__spec__.__class__.__module__  == abc.__loader__.__module__  (both '_frozen_importlib', len=17)
# abc.__loader__.__name__ len=14     > abc.__spec__.__class__.__name__ len=10  (difference=4)
# abc.__spec__.origin len=6          > abc.__spec__.name len=3  (difference=3)
# ---------------------------------------------------------------------------

table abc_extra111.abc_spec_loader_crosscheck:
  description: "abc.__spec__ and __loader__ cross-check comparisons in abcspec111 namespace — wave 256 theme: confirming module name equality and relative magnitude comparisons; abc.__spec__.__class__.__module__.__eq__('_frozen_importlib')==True AND abc.__loader__.__module__.__eq__('_frozen_importlib')==True (both '_frozen_importlib', len=17 — both ModuleSpec and FrozenImporter are defined in the same frozen bootstrap internal module); abc.__spec__.__class__.__module__.__len__()==17 (same value as abc.__loader__.__module__.__len__()==17, confirmed tie); abc.__loader__.__name__.__len__()==14 (FrozenImporter=14 chars, longer than ModuleSpec=10 by 4); abc.__spec__.__class__.__name__.__len__()==10 (ModuleSpec=10 chars, shorter than FrozenImporter=14); abc.__spec__.origin.__len__()==6 ('frozen'=6, longer than abc.__spec__.name.__len__()==3 by 3); abc.__spec__.name.__len__()==3 (shortest string value in spec: 'abc'=3); abc.__loader__.__class__.__module__.__len__()==8 ('builtins'=8); compare all string lengths in spec: abc.__spec__.name=3 (shortest) < abc.__loader__.__class__.__name__=4 < abc.__spec__.origin=6 < abc.__loader__.__class__.__module__=8 < abc.__spec__.__class__.__name__=10 < abc.__loader__.__name__=14 < abc.__spec__.__class__.__module__==abc.__loader__.__module__=17 (longest, tied); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcspec111b

  columns: [id, function, args, expected, description]
  rows:
    - [spec_clsmod_17,  abc.__spec__.__class__.__module__.__len__,     [], 17, "abc.__spec__.__class__.__module__.__len__() == 17 ('_frozen_importlib'=17); verified with Python 3.14.3"]
    - [ldr_mod_17,      abc.__loader__.__module__.__len__,             [], 17, "abc.__loader__.__module__.__len__() == 17 (tied with spec class module, both '_frozen_importlib'); verified with Python 3.14.3"]
    - [ldr_name_14,     abc.__loader__.__name__.__len__,               [], 14, "abc.__loader__.__name__.__len__() == 14 ('FrozenImporter'=14, 4 more than ModuleSpec=10); verified with Python 3.14.3"]
    - [spec_cls_10,     abc.__spec__.__class__.__name__.__len__,       [], 10, "abc.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec'=10, 4 less than FrozenImporter=14); verified with Python 3.14.3"]
    - [spec_orig_6,     abc.__spec__.origin.__len__,                   [], 6,  "abc.__spec__.origin.__len__() == 6 ('frozen'=6, 3 more than name 'abc'=3); verified with Python 3.14.3"]
    - [spec_name_3,     abc.__spec__.name.__len__,                     [], 3,  "abc.__spec__.name.__len__() == 3 ('abc'=3, shortest string in spec); verified with Python 3.14.3"]
    - [ldr_clsmod_8,    abc.__loader__.__class__.__module__.__len__,   [], 8,  "abc.__loader__.__class__.__module__.__len__() == 8 ('builtins'=8); verified with Python 3.14.3"]
    - [ldr_cls_4,       abc.__loader__.__class__.__name__.__len__,     [], 4,  "abc.__loader__.__class__.__name__.__len__() == 4 ('type'=4); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra111
# ---------------------------------------------------------------------------

invariant abc_extra111.spec_class_name_ModuleSpec:
  description: "abc.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — abc.__spec__ is an instance of importlib._bootstrap.ModuleSpec (exposed as _frozen_importlib.ModuleSpec in the C layer); ModuleSpec is the standard Python class that holds module import metadata: name, loader, origin, submodule_search_locations, etc.; abc.__spec__.__class__.__name__.__len__()==10 ('ModuleSpec'=10); abc.__spec__.__class__.__module__=='_frozen_importlib' (len=17); abc.__spec__.name=='abc' (len=3); abc.__spec__.origin=='frozen' (len=6; abc is a frozen module); compare: abc.__loader__.__name__=='FrozenImporter' (len=14 > ModuleSpec len=10 by 4); first standalone abc.__spec__ class name string equality invariant in abcspec111 namespace; wave 256; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant abc_extra111.spec_origin_frozen:
  description: "abc.__spec__.origin.__eq__('frozen') returns True — abc.__spec__.origin == 'frozen' (len=6); in Python 3.11+ the abc module is compiled as a frozen module (embedded directly in the interpreter binary); frozen modules do not have a file path as their origin — instead, origin is the string 'frozen'; compare: a normal source-code module would have origin set to its .py file path; abc.__spec__.origin.__class__.__name__=='str' (origin is a plain string, not None or a Path); abc.__spec__.name=='abc' (len=3); abc.__spec__.__class__.__name__=='ModuleSpec'; abc.__spec__.submodule_search_locations is None (abc is not a package); note: 'frozen'=6 chars, 3 chars longer than 'abc'=3 chars; first standalone abc.__spec__.origin=='frozen' invariant in abcspec111 namespace; wave 256; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__spec__.origin.__eq__
  args: ["frozen"]
  expected: true

invariant abc_extra111.loader_name_FrozenImporter:
  description: "abc.__loader__.__name__.__eq__('FrozenImporter') returns True — abc.__loader__ is the FrozenImporter class itself (not an instance); abc.__loader__.__name__=='FrozenImporter' (len=14); abc.__loader__.__module__=='_frozen_importlib' (len=17); abc.__loader__.__class__.__name__=='type' (FrozenImporter is a class, so its metaclass is 'type'); abc.__loader__.__class__.__module__=='builtins' (type is defined in builtins); compare: __loader__.__name__ len=14 > __spec__.__class__.__name__ len=10 ('ModuleSpec'=10; FrozenImporter is 4 chars longer); __loader__.__module__==__spec__.__class__.__module__=='_frozen_importlib' (len=17, tied); FrozenImporter is the loader class used by Python's frozen module import mechanism to load .pyc bytecode embedded directly in the interpreter; first standalone abc.__loader__.__name__ string equality invariant in abcspec111 namespace; wave 256; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__loader__.__name__.__eq__
  args: ["FrozenImporter"]
  expected: true

invariant abc_extra111.loader_module_len_17:
  description: "abc.__loader__.__module__.__len__() == 17 — '__module__=='_frozen_importlib' (len=17: '_frozen_importlib'=17 chars); abc.__loader__ is the FrozenImporter class whose defining module is '_frozen_importlib' (the C-level frozen bootstrap); this ties with abc.__spec__.__class__.__module__.__len__()==17 (also '_frozen_importlib') — both ModuleSpec and FrozenImporter are defined in the same internal frozen bootstrap module; compare: abc.__loader__.__class__.__module__=='builtins' (len=8, much shorter than '_frozen_importlib'=17); abc.__loader__.__name__.__len__()==14 (FrozenImporter=14, 3 shorter than the module name=17); abc.__spec__.origin.__len__()==6; first standalone abc.__loader__ module length invariant in abcspec111 namespace; wave 256; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__loader__.__module__.__len__
  args: []
  expected: 17

invariant abc_extra111.spec_class_module_len_17:
  description: "abc.__spec__.__class__.__module__.__len__() == 17 — '__class__.__module__=='_frozen_importlib' (len=17: '_frozen_importlib'=17 chars); this is the module where ModuleSpec (the class of abc.__spec__) is defined; '_frozen_importlib' is the internal C-level frozen bootstrap module distinct from the Python-level 'importlib._bootstrap' (which has len=21); abc.__spec__.__class__.__name__=='ModuleSpec' (len=10); abc.__spec__.name=='abc' (len=3); abc.__spec__.origin=='frozen' (len=6); note: abc.__spec__.__class__.__module__.__len__()==17 ties with abc.__loader__.__module__.__len__()==17 (both '_frozen_importlib'); compare all lengths: name=3 < type_name=4 < origin=6 < builtins=8 < ModuleSpec=10 < FrozenImporter=14 < _frozen_importlib=17 (longest, tied); first standalone abc.__spec__.__class__.__module__ length invariant in abcspec111 namespace; wave 256; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__spec__.__class__.__module__.__len__
  args: []
  expected: 17

