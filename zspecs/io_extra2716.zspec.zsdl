spec: io_extra2716
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
    - "io_extra.zspec.zsdl — covers existing io invariants"
    - "io_extra2701.zspec.zsdl — covers __lshift__/__rshift__/__invert__ dict-presence"
  notes:
    - "Wave 628 (io_extra2716) theme: __neg__, __pos__, and __abs__ dict-presence checks."
    - "None of the io classes define __neg__, __pos__, or __abs__ in their own __dict__."
    - "__neg__ is the unary negation operator (-x); io stream classes are sequential I/O objects, not numeric types."
    - "__pos__ is the unary positive operator (+x); io stream classes do not implement unary numeric semantics."
    - "__abs__ is the absolute value operator (abs(x)); io stream classes do not implement absolute-value semantics."
    - "Covers io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, and io.TextIOWrapper."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __neg__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2716.no_neg_in_io_classes:
  description: "__neg__ is absent from all io class __dict__s — io stream classes do not implement the unary negation protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2716

  columns: [id, function, args, expected]
  rows:
    - ["io2716001", "io.IOBase.__dict__.__contains__",         ["__neg__"], false]
    - ["io2716002", "io.RawIOBase.__dict__.__contains__",      ["__neg__"], false]
    - ["io2716003", "io.BufferedIOBase.__dict__.__contains__", ["__neg__"], false]
    - ["io2716004", "io.TextIOBase.__dict__.__contains__",     ["__neg__"], false]
    - ["io2716005", "io.BytesIO.__dict__.__contains__",        ["__neg__"], false]
    - ["io2716006", "io.StringIO.__dict__.__contains__",       ["__neg__"], false]

# ---------------------------------------------------------------------------
# __pos__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2716.no_pos_in_io_classes:
  description: "__pos__ is absent from all io class __dict__s — io stream classes do not implement the unary positive protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2716

  columns: [id, function, args, expected]
  rows:
    - ["io2716007", "io.IOBase.__dict__.__contains__",          ["__pos__"], false]
    - ["io2716008", "io.FileIO.__dict__.__contains__",          ["__pos__"], false]
    - ["io2716009", "io.BufferedReader.__dict__.__contains__",  ["__pos__"], false]
    - ["io2716010", "io.BufferedWriter.__dict__.__contains__",  ["__pos__"], false]
    - ["io2716011", "io.BufferedRandom.__dict__.__contains__",  ["__pos__"], false]
    - ["io2716012", "io.TextIOWrapper.__dict__.__contains__",   ["__pos__"], false]

# ---------------------------------------------------------------------------
# __abs__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2716.no_abs_in_io_classes:
  description: "__abs__ is absent from all io class __dict__s — io stream classes do not implement the absolute-value protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2716

  columns: [id, function, args, expected]
  rows:
    - ["io2716013", "io.IOBase.__dict__.__contains__",         ["__abs__"], false]
    - ["io2716014", "io.BytesIO.__dict__.__contains__",        ["__abs__"], false]
    - ["io2716015", "io.StringIO.__dict__.__contains__",       ["__abs__"], false]
    - ["io2716016", "io.FileIO.__dict__.__contains__",         ["__abs__"], false]
    - ["io2716017", "io.BufferedReader.__dict__.__contains__", ["__abs__"], false]
    - ["io2716018", "io.BufferedWriter.__dict__.__contains__", ["__abs__"], false]

# ---------------------------------------------------------------------------
# Complementary: io stream classes have I/O methods but not unary numeric hooks
# Confirms that io classes are sequential I/O objects, not numeric types
# ---------------------------------------------------------------------------

table io_extra2716.io_has_stream_methods_not_unary_numeric_hooks:
  description: "io.BytesIO defines read/write/seek/tell but NOT __neg__/__pos__/__abs__; io.StringIO similarly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2716

  columns: [id, function, args, expected]
  rows:
    - ["io2716019", "io.BytesIO.__dict__.__contains__",  ["read"],    true]
    - ["io2716020", "io.BytesIO.__dict__.__contains__",  ["write"],   true]
    - ["io2716021", "io.BytesIO.__dict__.__contains__",  ["seek"],    true]
    - ["io2716022", "io.BytesIO.__dict__.__contains__",  ["tell"],    true]
    - ["io2716023", "io.BytesIO.__dict__.__contains__",  ["__neg__"], false]
    - ["io2716024", "io.BytesIO.__dict__.__contains__",  ["__pos__"], false]
    - ["io2716025", "io.BytesIO.__dict__.__contains__",  ["__abs__"], false]
    - ["io2716026", "io.StringIO.__dict__.__contains__", ["read"],    true]
    - ["io2716027", "io.StringIO.__dict__.__contains__", ["write"],   true]
    - ["io2716028", "io.StringIO.__dict__.__contains__", ["seek"],    true]
    - ["io2716029", "io.StringIO.__dict__.__contains__", ["tell"],    true]
    - ["io2716030", "io.StringIO.__dict__.__contains__", ["__neg__"], false]
    - ["io2716031", "io.StringIO.__dict__.__contains__", ["__pos__"], false]
    - ["io2716032", "io.StringIO.__dict__.__contains__", ["__abs__"], false]
