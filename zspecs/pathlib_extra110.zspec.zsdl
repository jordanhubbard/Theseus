spec: pathlib_extra110
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra109

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra109.zspec.zsdl."
    - "This spec covers: pathlib class __module__ string values and __module__.__len__() for all public pathlib classes."
    - "pathlib.PurePath.__module__ = 'pathlib' (length 7)."
    - "pathlib.PurePosixPath.__module__ = 'pathlib' (length 7)."
    - "pathlib.PureWindowsPath.__module__ = 'pathlib' (length 7)."
    - "pathlib.Path.__module__ = 'pathlib' (length 7)."
    - "pathlib.PosixPath.__module__ = 'pathlib' (length 7)."
    - "pathlib.WindowsPath.__module__ = 'pathlib' (length 7)."
    - "All six public pathlib classes share __module__ == 'pathlib' with len == 7."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib pure path classes: __module__ == 'pathlib'
# PurePath, PurePosixPath, PureWindowsPath all report __module__ == 'pathlib'.
# The string 'pathlib' has length 7.
# ---------------------------------------------------------------------------

table pathlib_extra110.pure_path_modules:
  description: "pathlib pure path classes have __module__ == 'pathlib' (len=7): PurePath, PurePosixPath, PureWindowsPath"
  kind: python_call_eq
  category: class_names
  id_prefix: pathlibmodule110a

  columns: [id, function, args, expected, description]
  rows:
    - [pp_mod_eq,      PurePath.__module__.__eq__,         ["pathlib"], true,  "pathlib.PurePath.__module__ == 'pathlib'"]
    - [pp_mod_len,     PurePath.__module__.__len__,         [],          7,     "pathlib.PurePath.__module__.__len__() == 7 ('pathlib' has 7 characters)"]
    - [ppp_mod_eq,     PurePosixPath.__module__.__eq__,     ["pathlib"], true,  "pathlib.PurePosixPath.__module__ == 'pathlib'"]
    - [ppp_mod_len,    PurePosixPath.__module__.__len__,    [],          7,     "pathlib.PurePosixPath.__module__.__len__() == 7"]
    - [pwp_mod_eq,     PureWindowsPath.__module__.__eq__,   ["pathlib"], true,  "pathlib.PureWindowsPath.__module__ == 'pathlib'"]
    - [pwp_mod_len,    PureWindowsPath.__module__.__len__,  [],          7,     "pathlib.PureWindowsPath.__module__.__len__() == 7"]
    - [pp_mod_not_os,  PurePath.__module__.__eq__,          ["os"],     false,  "pathlib.PurePath.__module__ != 'os' (pathlib is distinct from os.path)"]
    - [ppp_mod_not_pp, PurePosixPath.__module__.__eq__,     ["posixpath"], false, "pathlib.PurePosixPath.__module__ != 'posixpath'"]

# ---------------------------------------------------------------------------
# pathlib concrete path classes: __module__ == 'pathlib'
# Path, PosixPath, WindowsPath all report __module__ == 'pathlib'.
# The string 'pathlib' has length 7.
# On non-Windows, WindowsPath class attributes are accessible even though
# instantiation raises NotImplementedError.
# ---------------------------------------------------------------------------

table pathlib_extra110.concrete_path_modules:
  description: "pathlib concrete path classes have __module__ == 'pathlib' (len=7): Path, PosixPath, WindowsPath"
  kind: python_call_eq
  category: class_names
  id_prefix: pathlibmodule110b

  columns: [id, function, args, expected, description]
  rows:
    - [path_mod_eq,    Path.__module__.__eq__,         ["pathlib"], true,  "pathlib.Path.__module__ == 'pathlib'"]
    - [path_mod_len,   Path.__module__.__len__,         [],          7,     "pathlib.Path.__module__.__len__() == 7"]
    - [posixp_mod_eq,  PosixPath.__module__.__eq__,     ["pathlib"], true,  "pathlib.PosixPath.__module__ == 'pathlib'"]
    - [posixp_mod_len, PosixPath.__module__.__len__,    [],          7,     "pathlib.PosixPath.__module__.__len__() == 7"]
    - [winp_mod_eq,    WindowsPath.__module__.__eq__,   ["pathlib"], true,  "pathlib.WindowsPath.__module__ == 'pathlib'"]
    - [winp_mod_len,   WindowsPath.__module__.__len__,  [],          7,     "pathlib.WindowsPath.__module__.__len__() == 7"]
    - [path_mod_not_io, Path.__module__.__eq__,         ["io"],     false,  "pathlib.Path.__module__ != 'io'"]
    - [winp_not_ntpath, WindowsPath.__module__.__eq__,  ["ntpath"], false,  "pathlib.WindowsPath.__module__ != 'ntpath'"]

# ---------------------------------------------------------------------------
# All six classes share __module__ len == 7
# Confirming uniformity across the entire public pathlib API.
# ---------------------------------------------------------------------------

table pathlib_extra110.all_module_lengths_equal_7:
  description: "All six public pathlib classes share __module__.__len__() == 7 ('pathlib' is 7 characters)"
  kind: python_call_eq
  category: class_names
  id_prefix: pathlibmodule110c

  columns: [id, function, args, expected, description]
  rows:
    - [pp_len7,   PurePath.__module__.__len__,      [], 7, "pathlib.PurePath.__module__.__len__() == 7"]
    - [ppp_len7,  PurePosixPath.__module__.__len__,  [], 7, "pathlib.PurePosixPath.__module__.__len__() == 7"]
    - [pwp_len7,  PureWindowsPath.__module__.__len__, [], 7, "pathlib.PureWindowsPath.__module__.__len__() == 7"]
    - [p_len7,    Path.__module__.__len__,           [], 7, "pathlib.Path.__module__.__len__() == 7"]
    - [posixp_l7, PosixPath.__module__.__len__,      [], 7, "pathlib.PosixPath.__module__.__len__() == 7"]
    - [winp_l7,   WindowsPath.__module__.__len__,    [], 7, "pathlib.WindowsPath.__module__.__len__() == 7"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra110.PurePath.module_eq_pathlib:
  description: "pathlib.PurePath.__module__ == 'pathlib' (PurePath is the pure Python abstract root defined at the top level of the pathlib package)"
  category: class_names
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra110.PurePath.module_len_7:
  description: "pathlib.PurePath.__module__.__len__() == 7 ('pathlib' has exactly 7 characters: p-a-t-h-l-i-b)"
  category: class_names
  kind: python_call_eq
  function: PurePath.__module__.__len__
  args: []
  expected: 7

invariant pathlib_extra110.WindowsPath.module_eq_pathlib:
  description: "pathlib.WindowsPath.__module__ == 'pathlib' (class attributes including __module__ are accessible even on non-Windows platforms)"
  category: class_names
  kind: python_call_eq
  function: WindowsPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra110.PosixPath.module_len_7:
  description: "pathlib.PosixPath.__module__.__len__() == 7 ('pathlib' is 7 characters; all six public pathlib classes share this module string length)"
  category: class_names
  kind: python_call_eq
  function: PosixPath.__module__.__len__
  args: []
  expected: 7

invariant pathlib_extra110.Path.module_ne_os:
  description: "pathlib.Path.__module__ != 'os' (pathlib.Path is not from the os module; os.path is a separate path utility module)"
  category: class_names
  kind: python_call_eq
  function: Path.__module__.__eq__
  args: ["os"]
  expected: false
