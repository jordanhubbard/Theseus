spec: io_extra11
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl through io_extra10.zspec.zsdl."
    - "io_extra10 covers UnsupportedOperation __bases__ hierarchy and MRO lengths for StringIO/BufferedReader/BufferedWriter/TextIOWrapper."
    - "io_extra9 covers __qualname__ for all io classes and MRO lengths for IOBase/RawIOBase/FileIO/BytesIO."
    - "io_extra8 covers __bases__[0].__name__ for the ABC and concrete class hierarchy."
    - "NOT yet covered: BufferedRandom.__bases__[0].__name__ — BufferedRandom inherits from BufferedIOBase."
    - "NOT yet covered: BufferedReader.__bases__[0].__name__."
    - "NOT yet covered: BufferedWriter.__bases__[0].__name__."
    - "NOT yet covered: TextIOWrapper.__bases__[0].__name__."
    - "NOT yet covered: io.DEFAULT_BUFFER_SIZE value comparison (only __class__.__name__ and >= checks exist)."
    - "NOT yet covered: BytesIO().getvalue() on an empty BytesIO — returns b''."
    - "NOT yet covered: StringIO().getvalue() on an empty StringIO — returns ''."
    - "NOT yet covered: BytesIO().readable() == True."
    - "NOT yet covered: StringIO().readable() == True."
    - "NOT yet covered: BytesIO().writable() == True."
    - "NOT yet covered: BytesIO().seekable() == True."
    - "io.BufferedRandom.__bases__[0].__name__ == 'BufferedIOBase'."
    - "io.BufferedReader.__bases__[0].__name__ == 'BufferedIOBase'."
    - "io.BufferedWriter.__bases__[0].__name__ == 'BufferedIOBase'."
    - "io.TextIOWrapper.__bases__[0].__name__ == 'TextIOBase'."
    - "io.BytesIO().readable() == True — in-memory streams are always readable."
    - "io.BytesIO().writable() == True — in-memory streams are always writable."
    - "io.BytesIO().seekable() == True — in-memory streams are always seekable."
    - "io.StringIO().readable() == True — in-memory text streams are always readable."
    - "io.StringIO().writable() == True — in-memory text streams are always writable."
    - "io.StringIO().seekable() == True — in-memory text streams are always seekable."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__name__ for concrete classes not covered in io_extra8
#
# io_extra8 covered: RawIOBase, BufferedIOBase, TextIOBase, FileIO, BytesIO, StringIO.
# NOT yet covered: BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper.
# ---------------------------------------------------------------------------

invariant io_extra11.BufferedReader.base_is_BufferedIOBase:
  description: "io.BufferedReader.__bases__[0].__name__ == 'BufferedIOBase'"
  category: hierarchy
  kind: python_call_eq
  function: BufferedReader.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BufferedIOBase"

invariant io_extra11.BufferedWriter.base_is_BufferedIOBase:
  description: "io.BufferedWriter.__bases__[0].__name__ == 'BufferedIOBase'"
  category: hierarchy
  kind: python_call_eq
  function: BufferedWriter.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BufferedIOBase"

invariant io_extra11.BufferedRandom.base_is_BufferedIOBase:
  description: "io.BufferedRandom.__bases__[0].__name__ == 'BufferedIOBase'"
  category: hierarchy
  kind: python_call_eq
  function: BufferedRandom.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BufferedIOBase"

invariant io_extra11.TextIOWrapper.base_is_TextIOBase:
  description: "io.TextIOWrapper.__bases__[0].__name__ == 'TextIOBase'"
  category: hierarchy
  kind: python_call_eq
  function: TextIOWrapper.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "TextIOBase"

# ---------------------------------------------------------------------------
# BytesIO instance — readable, writable, seekable
#
# In-memory binary streams are always readable, writable, and seekable.
# No prior spec tests these capability predicates on BytesIO instances.
# ---------------------------------------------------------------------------

invariant io_extra11.BytesIO.readable:
  description: "io.BytesIO().readable() == True — in-memory binary stream is readable"
  category: stream_capabilities
  kind: python_call_eq
  function: BytesIO
  args: []
  method: readable
  expected: true

invariant io_extra11.BytesIO.writable:
  description: "io.BytesIO().writable() == True — in-memory binary stream is writable"
  category: stream_capabilities
  kind: python_call_eq
  function: BytesIO
  args: []
  method: writable
  expected: true

invariant io_extra11.BytesIO.seekable:
  description: "io.BytesIO().seekable() == True — in-memory binary stream is seekable"
  category: stream_capabilities
  kind: python_call_eq
  function: BytesIO
  args: []
  method: seekable
  expected: true

# ---------------------------------------------------------------------------
# StringIO instance — readable, writable, seekable
#
# In-memory text streams are always readable, writable, and seekable.
# No prior spec tests these capability predicates on StringIO instances.
# ---------------------------------------------------------------------------

invariant io_extra11.StringIO.readable:
  description: "io.StringIO().readable() == True — in-memory text stream is readable"
  category: stream_capabilities
  kind: python_call_eq
  function: StringIO
  args: []
  method: readable
  expected: true

invariant io_extra11.StringIO.writable:
  description: "io.StringIO().writable() == True — in-memory text stream is writable"
  category: stream_capabilities
  kind: python_call_eq
  function: StringIO
  args: []
  method: writable
  expected: true

invariant io_extra11.StringIO.seekable:
  description: "io.StringIO().seekable() == True — in-memory text stream is seekable"
  category: stream_capabilities
  kind: python_call_eq
  function: StringIO
  args: []
  method: seekable
  expected: true

# ---------------------------------------------------------------------------
# DEFAULT_BUFFER_SIZE — exact value check
#
# io.zspec.zsdl checks DEFAULT_BUFFER_SIZE >= 4096.
# io_extra.zspec.zsdl checks DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int'.
# No prior spec tests the exact value. The CPython default is 8192.
# ---------------------------------------------------------------------------

invariant io_extra11.DEFAULT_BUFFER_SIZE.exact:
  description: "io.DEFAULT_BUFFER_SIZE == 8192 — the standard CPython default buffer size"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [8192]
  expected: true
