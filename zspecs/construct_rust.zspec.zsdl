spec: construct_rust
version: ">=3.9"
backend: rust_module(construct_rust)

docs: https://construct.readthedocs.io/

provenance:
  derived_from:
    - "https://construct.readthedocs.io/ — construct library documentation"
  not_derived_from:
    - "construct source: construct/core.py"
  notes:
    - "construct is a declarative binary data parsing and building library."
    - "construct.Byte.parse(b'\\x42') == 0x42 == 66."
    - "construct.Int16ub.parse(b'\\x01\\x00') == 256 — unsigned big-endian 16-bit."
    - "construct.Int32ub.parse(b'\\x00\\x00\\x00\\x01') == 1."
    - "construct.Byte.build(66) == b'\\x42'."
    - "Expose parse_byte(b) -> int: construct.Byte.parse(b)."
    - "Expose parse_int16ub(b) -> int: construct.Int16ub.parse(b)."
    - "Expose build_byte(n) -> bytes: construct.Byte.build(n)."
    - "Expose parse_bytes_n(b, n) -> bytes: construct.Bytes(n).parse(b)."
    - "All test vectors verified against construct 2.10.70."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# parse_byte — parse single byte to integer
table construct_rust.byte.parse:
  kind: python_call_eq
  category: parse_byte
  id_prefix: cs_byte
  function: parse_byte

  columns: [id, args, expected]
  rows:
    - [zero,  [!hex 00], 0]
    - [one,   [!hex 01], 1]
    - [hex42, [!hex 42], 66]
    - [xff,   [!hex ff], 255]

# parse_int16ub — unsigned big-endian 16-bit
table construct_rust.int16ub.parse:
  kind: python_call_eq
  category: parse_int16ub
  id_prefix: cs_i16
  function: parse_int16ub

  columns: [id, args, expected]
  rows:
    - [zero,  [!hex 0000], 0]
    - [one,   [!hex 0001], 1]
    - [big,   [!hex 0100], 256]
    - [max,   [!hex ffff], 65535]

# build_byte — integer to byte
invariant construct_rust.byte.build_66:
  description: "construct.Byte.build(66) == b'\\x42'"
  category: build
  kind: python_call_eq
  function: build_byte
  args: [66]
  expected: !hex 42

invariant construct_rust.byte.build_zero:
  description: "construct.Byte.build(0) == b'\\x00'"
  category: build
  kind: python_call_eq
  function: build_byte
  args: [0]
  expected: !hex 00

