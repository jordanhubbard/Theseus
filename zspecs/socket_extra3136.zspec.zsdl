spec: sk3136
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 656 (sk3136): __call__, __len__, __getitem__ dict-presence checks for socket types."
    - "socket.socket is a Python class; it does not define __call__, __len__, or __getitem__ in its __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses (EnumType metaclass)."
    - "Neither socket.AddressFamily nor socket.SocketKind defines __call__, __len__, or __getitem__ in its own __dict__; these methods are not part of the enum/int protocol at the class level."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk3136.call:
  description: "socket types __call__ dict-presence checks; wave 656"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk3136
  columns: [id, function, args, expected]
  rows:
    - ["sk3136001", operator.contains, [socket.socket.__dict__,        "__call__"], false]
    - ["sk3136002", operator.contains, [socket.AddressFamily.__dict__, "__call__"], false]
    - ["sk3136003", operator.contains, [socket.SocketKind.__dict__,    "__call__"], false]

