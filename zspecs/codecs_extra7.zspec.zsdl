spec: codecs_extra7
version: ">=3.9"
backend: python_module(codecs)

docs: https://docs.python.org/3/library/codecs.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/codecs.html — Python codecs documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/codecs.py"
    - "codecs.zspec.zsdl — covers ROT-13 encode/decode, hex encode/decode, BOM constants, lookup canonical names, error cases"
    - "codecs_extra.zspec.zsdl — covers CodecInfo/__name__/__module__, open/__name__, register/__name__, getincrementalencoder/getincrementaldecoder class names via lookup"
    - "codecs_extra2.zspec.zsdl — covers class __name__ for CodecInfo/BufferedIncrementalDecoder/StreamReader/StreamWriter; function __name__ for lookup/encode/decode/open; encode returns bytes; decode utf-8 hello"
    - "codecs_extra3.zspec.zsdl — covers __qualname__ for encode/decode/open/lookup/register (table); open/__module__, register/__module__; Codec/__name__/__qualname__/__module__; IncrementalEncoder/__name__/__qualname__/__module__; IncrementalDecoder/__name__/__qualname__/__module__; StreamReader/__qualname__/__module__; StreamWriter/__qualname__/__module__; CodecInfo/__qualname__; BOM lengths; lookup utf-32/utf-8-sig; encode ascii"
    - "codecs_extra4.zspec.zsdl — covers function __name__ table for encode/decode/lookup/register/open; encode/decode type checks; lookup codec_info_class; lookup utf-8/ascii name; CodecInfo/__name__/__module__"
    - "codecs_extra5.zspec.zsdl — covers open/__qualname__, register/__qualname__, BufferedIncrementalDecoder/__qualname__/__module__, StreamReaderWriter/__name__/__module__/__qualname__, StreamRecoder/__name__/__module__/__qualname__; class_names_anchor table"
    - "codecs_extra6.zspec.zsdl — covers getreader/getwriter/getincrementalencoder/getincrementaldecoder (__name__/__qualname__/__module__); StreamReader/StreamWriter base is Codec; BufferedIncrementalDecoder base is IncrementalDecoder; CodecInfo base is tuple; Codec base is object"
  notes:
    - "This spec adds new axes: IncrementalEncoder/__bases__[0]/__name__ (not in any prior spec); IncrementalDecoder/__bases__[0]/__name__ (not in any prior spec); BOM_UTF8 length 3 / BOM_UTF16_LE length 2 / BOM_UTF32_LE length 4 / BOM_UTF16_BE length 2 / BOM_UTF32_BE length 4 (extra3 covers BOM_UTF16 and BOM_UTF32 lengths, but not LE/BE variants separately); lookup('ascii').name == 'ascii'; lookup('latin-1').name == 'iso8859-1'; decode(b'world', 'utf-8') == 'world'; decode(b'hello', 'ascii') == 'hello'; StreamReaderWriter/__bases__[0]/__name__ == 'object'; StreamRecoder/__bases__[0]/__name__ == 'object'."
    - "codecs.IncrementalEncoder.__bases__[0].__name__ == 'object' — top-level class; not checked in any prior spec."
    - "codecs.IncrementalDecoder.__bases__[0].__name__ == 'object' — top-level class; not checked in any prior spec."
    - "codecs_extra3 covers len(BOM_UTF16) and len(BOM_UTF32) (the platform-native BOMs). The explicit LE/BE variants have not been individually size-checked."
    - "codecs.lookup('ascii').name == 'ascii' — canonical codec name lookup not tested in any prior spec for ascii."
    - "codecs.lookup('latin-1').name == 'iso8859-1' — alias normalization: 'latin-1' maps to canonical 'iso8859-1'."
    - "codecs.decode(b'world', 'utf-8') == 'world' — round-trip decode not tested for 'world' in any prior spec."
    - "codecs.decode(b'hello', 'ascii') == 'hello' — ascii decode not tested in any prior spec."
    - "codecs.StreamReaderWriter.__bases__[0].__name__ == 'object' — not checked in any prior spec."
    - "codecs.StreamRecoder.__bases__[0].__name__ == 'object' — not checked in any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IncrementalEncoder and IncrementalDecoder __bases__[0]
# codecs_extra6 checks StreamReader/StreamWriter/BufferedIncrementalDecoder/CodecInfo/Codec
# base classes but does NOT check IncrementalEncoder or IncrementalDecoder themselves.
# Both are top-level classes with __bases__[0] == object.
# ---------------------------------------------------------------------------

invariant codecs_extra7.IncrementalEncoder.base_is_object:
  description: "codecs.IncrementalEncoder.__bases__[0].__name__ == 'object' — top-level class"
  category: hierarchy
  kind: python_call_eq
  function: IncrementalEncoder.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant codecs_extra7.IncrementalDecoder.base_is_object:
  description: "codecs.IncrementalDecoder.__bases__[0].__name__ == 'object' — top-level class"
  category: hierarchy
  kind: python_call_eq
  function: IncrementalDecoder.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# StreamReaderWriter and StreamRecoder __bases__[0]
# codecs_extra5 covers StreamReaderWriter and StreamRecoder __name__/__module__/__qualname__
# but not their base classes. Both inherit directly from object.
# ---------------------------------------------------------------------------

invariant codecs_extra7.StreamReaderWriter.base_is_object:
  description: "codecs.StreamReaderWriter.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: StreamReaderWriter.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant codecs_extra7.StreamRecoder.base_is_object:
  description: "codecs.StreamRecoder.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: StreamRecoder.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# BOM byte-order mark lengths — LE/BE explicit variants
# codecs_extra3 covers len(BOM_UTF16) and len(BOM_UTF32) (platform-native aliases).
# The explicit BOM_UTF8/BOM_UTF16_LE/BOM_UTF16_BE/BOM_UTF32_LE/BOM_UTF32_BE
# variants have not been individually size-checked in any prior spec.
# ---------------------------------------------------------------------------

table codecs_extra7.bom_lengths:
  kind: python_call_eq
  category: bom_constants
  id_prefix: bomlen

  columns: [id, function, args, expected]
  rows:
    - [BOM_UTF8,     BOM_UTF8.__len__,     [], 3]
    - [BOM_UTF16_LE, BOM_UTF16_LE.__len__, [], 2]
    - [BOM_UTF16_BE, BOM_UTF16_BE.__len__, [], 2]
    - [BOM_UTF32_LE, BOM_UTF32_LE.__len__, [], 4]
    - [BOM_UTF32_BE, BOM_UTF32_BE.__len__, [], 4]

# ---------------------------------------------------------------------------
# lookup() canonical name checks
# codecs_extra3 checks lookup('utf-32') and lookup('utf-8-sig') names.
# codecs_extra4 checks lookup('utf-8') and lookup('ascii') type only.
# New here: lookup('ascii').name == 'ascii'; lookup('latin-1').name == 'iso8859-1'.
# The latin-1 case demonstrates alias normalization (the canonical name differs).
# ---------------------------------------------------------------------------

invariant codecs_extra7.lookup.ascii_name:
  description: "codecs.lookup('ascii').name == 'ascii' — canonical codec name"
  category: lookup
  kind: python_call_eq
  function: lookup
  args: ["ascii"]
  method: name.__eq__
  method_args: ["ascii"]
  expected: true

invariant codecs_extra7.lookup.latin1_name:
  description: "codecs.lookup('latin-1').name == 'iso8859-1' — alias maps to canonical name"
  category: lookup
  kind: python_call_eq
  function: lookup
  args: ["latin-1"]
  method: name.__eq__
  method_args: ["iso8859-1"]
  expected: true

# ---------------------------------------------------------------------------
# decode() round-trip checks
# codecs_extra2 checks decode(b'hello', 'utf-8') result type.
# No prior spec checks the decoded string value for these inputs.
# ---------------------------------------------------------------------------

invariant codecs_extra7.decode.utf8_world:
  description: "codecs.decode(b'world', 'utf-8') == 'world'"
  category: decode
  kind: python_call_eq
  function: decode
  args: ["world", "utf-8"]
  expected: "world"

invariant codecs_extra7.decode.ascii_hello:
  description: "codecs.decode(b'hello', 'ascii') == 'hello'"
  category: decode
  kind: python_call_eq
  function: decode
  args: ["hello", "ascii"]
  expected: "hello"
