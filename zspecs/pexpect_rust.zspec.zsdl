spec: pexpect_rust
version: ">=3.9"
backend: rust_module(pexpect_rust)

docs: https://pexpect.readthedocs.io/

provenance:
  derived_from:
    - "https://pexpect.readthedocs.io/ — pexpect library documentation"
  not_derived_from:
    - "pexpect source: pexpect/expect.py"
  notes:
    - "pexpect automates interactive applications but also has useful string utilities."
    - "pexpect.run('echo hello').strip() == b'hello' — simple command output."
    - "Expose run_echo(s) -> str: pexpect.run(f'echo {s}').decode().strip()."
    - "Expose run_echo_bytes(s) -> bytes: pexpect.run(f'echo {s}').strip()."
    - "run_echo('hello') == 'hello'."
    - "run_echo('world') == 'world'."
    - "pexpect.which('python3') returns the path or None."
    - "Expose which_python3() -> bool: pexpect.which('python3') is not None."
    - "Expose which_nonexistent() -> bool: pexpect.which('thiscommanddoesnotexist12345') is None."
    - "All test vectors verified against pexpect 4.9.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# run_echo — execute echo command and capture output
table pexpect_rust.run.echo:
  kind: python_call_eq
  category: echo
  id_prefix: pe_echo
  function: run_echo

  columns: [id, args, expected]
  rows:
    - [hello, ["hello"], "hello"]
    - [world, ["world"], "world"]
    - [num,   ["42"],    "42"]

# pexpect.which — command lookup
invariant pexpect_rust.which.python3_exists:
  description: "pexpect.which('python3') is not None (python3 is in PATH)"
  category: which
  kind: python_call_eq
  function: which_python3
  args: []
  expected: true

invariant pexpect_rust.which.nonexistent_none:
  description: "pexpect.which('thiscommanddoesnotexist12345') is None"
  category: which
  kind: python_call_eq
  function: which_nonexistent
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:30:05Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
