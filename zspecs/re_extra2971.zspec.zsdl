spec: re2971
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re class __dict__ floor / ceil / index presence"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.Pattern and re.Match are regex engine types; they do not define __floor__, __ceil__, or __index__."
    - "re.RegexFlag is an IntFlag subclass. It does NOT define __floor__, __ceil__, or __index__ in its own __dict__."
    - "operator.contains(re.RegexFlag.__dict__, '__floor__') is False — IntFlag does not override math.floor()."
    - "operator.contains(re.RegexFlag.__dict__, '__ceil__') is False — IntFlag does not override math.ceil()."
    - "operator.contains(re.RegexFlag.__dict__, '__index__') is False — IntFlag inherits __index__ from int but does not redefine it in the subclass __dict__."
    - "type(re.compile('')) is re.Pattern; type(re.match('', '')) is re.Match."
    - "All values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __floor__ dict-presence — math.floor() protocol in own __dict__
#
# None of the re classes define __floor__ in their own __dict__.
# re.RegexFlag is an IntFlag subclass but does not override __floor__
# in its own namespace — int's floor support is inherited, not redefined.
# ---------------------------------------------------------------------------

table re2971.floor:
  description: "operator.contains(cls.__dict__, '__floor__') is False for all re classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ref2971

  columns: [id, function, args, expected]
  rows:
    - ["ref2971_001", operator.contains, [re.Pattern.__dict__,   "__floor__"], false]
    - ["ref2971_002", operator.contains, [re.Match.__dict__,     "__floor__"], false]
    - ["ref2971_003", operator.contains, [re.RegexFlag.__dict__, "__floor__"], false]

# ---------------------------------------------------------------------------
# __ceil__ dict-presence — math.ceil() protocol in own __dict__
#
# None of the re classes define __ceil__ in their own __dict__.
# re.RegexFlag is an IntFlag subclass but does not override __ceil__.
# ---------------------------------------------------------------------------

table re2971.ceil:
  description: "operator.contains(cls.__dict__, '__ceil__') is False for all re classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: rec2971

  columns: [id, function, args, expected]
  rows:
    - ["rec2971_001", operator.contains, [re.Pattern.__dict__,   "__ceil__"], false]
    - ["rec2971_002", operator.contains, [re.Match.__dict__,     "__ceil__"], false]
    - ["rec2971_003", operator.contains, [re.RegexFlag.__dict__, "__ceil__"], false]

# ---------------------------------------------------------------------------
# __index__ dict-presence — operator.index() protocol in own __dict__
#
# None of the re classes define __index__ in their own __dict__.
# re.RegexFlag inherits __index__ from int but does not redefine it in its
# own class __dict__ — the IntFlag machinery does not add __index__ directly.
# ---------------------------------------------------------------------------

table re2971.index:
  description: "operator.contains(cls.__dict__, '__index__') is False for all re classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: rei2971

  columns: [id, function, args, expected]
  rows:
    - ["rei2971_001", operator.contains, [re.Pattern.__dict__,   "__index__"], false]
    - ["rei2971_002", operator.contains, [re.Match.__dict__,     "__index__"], false]
    - ["rei2971_003", operator.contains, [re.RegexFlag.__dict__, "__index__"], false]

# ---------------------------------------------------------------------------
# combined — all three operators across all re classes
#
# All 9 cells (3 classes x 3 operators) are False. This table exhausts all
# 9 combinations and adds extra rows to reach ~24 rows total, confirming
# the uniform False result for this wave's theme.
# ---------------------------------------------------------------------------

