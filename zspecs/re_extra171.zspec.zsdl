spec: re_extra171
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module public function __name__ and __module__ attributes for split, subn, escape, and purge, plus function name lengths."
    - "re.split.__name__ == 'split' (len=5)."
    - "re.split.__module__ == 're' (len=2) — all re public functions share __module__ == 're'."
    - "re.subn.__name__ == 'subn' (len=4: 'sub'(3)+'n'(1)=4)."
    - "re.subn.__module__ == 're' (len=2)."
    - "re.escape.__name__ == 'escape' (len=6)."
    - "re.escape.__module__ == 're' (len=2)."
    - "re.purge.__name__ == 'purge' (len=5)."
    - "re.purge.__module__ == 're' (len=2)."
    - "Function name lengths: subn(4) < split(5)=purge(5) < escape(6)."
    - "subn (4) is formed by appending 'n' to 'sub' (3): subn.__name__.__len__() == 4 == sub.__name__.__len__() + 1."
    - "split (5) ties with purge (5) in name length — a two-way tie at 5."
    - "escape (6) is the longest function name in this spec: subn(4) < split(5)=purge(5) < escape(6)."
    - "re.split.__name__.__len__() == 5; re.escape.__name__.__len__() == 6; re.subn.__name__.__len__() == 4."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.split function identity
# split.__name__ == 'split' (len=5), split.__module__ == 're' (len=2)
# split (5) ties with purge (5) in name length
# ---------------------------------------------------------------------------

table re_extra171.split_identity:
  description: "re.split.__name__=='split' (len=5), re.split.__module__=='re' (len=2); split (5) ties with purge (5) — two-way tie at 5; split (5) > subn (4) by 1; split (5) < escape (6) by 1; re.split() splits a string at each pattern match"
  kind: python_call_eq
  category: identity
  id_prefix: resplt171

  columns: [id, function, args, expected, description]
  rows:
    - [split_name,   re.split.__name__.__eq__,   ["split"], true, "re.split.__name__ == 'split' — the function that splits a string by occurrences of the pattern; 'split' has 5 characters: 's-p-l-i-t'; split (5 chars) ties with purge (5 chars) — a two-way tie at 5 in the name length family of this spec; split (5) > subn (4) by 1; split (5) < escape (6) by 1: split is consecutive with both subn and escape in the ascending length sequence subn(4) < split(5)=purge(5) < escape(6); re.split(pattern, string, maxsplit=0) returns a list of substrings by splitting at each non-overlapping match of pattern; 'split' (5 chars) == len('match') (5 chars) from re_extra170 — cross-spec tie within the re module; confirmed Python 3.14.3 macOS"]
    - [split_module, re.split.__module__.__eq__,  ["re"],   true, "re.split.__module__ == 're' — re.split is defined in the public 're' module; 're' has 2 characters; re.split.__module__ (2: 're') == re.subn.__module__ (2: 're') == re.escape.__module__ (2: 're') == re.purge.__module__ (2: 're'): all four functions in this spec share the 2-character module name 're'; the uniform module attribution 're' (2 chars) is consistent with the seven functions covered in re_extra170 (compile, search, match, fullmatch, sub, findall, finditer); 're' (2 chars) < 'split' (5 chars) by 3; confirmed Python 3.14.3 macOS"]
    - [split_ne_sub, re.split.__name__.__eq__,   ["sub"],  false, "re.split.__name__.__eq__('sub') == False — 'split' (5 chars) != 'sub' (3 chars); split and sub are different functions: re.split() partitions a string into a list while re.sub() replaces pattern occurrences in a string; split (5 chars) > sub (3 chars) by 2; the two functions serve opposite transformation roles: sub() contracts (replaces matches) while split() expands (returns a list of parts); re.split.__name__ (5: 'split') != re.sub.__name__ (3: 'sub') in both content and length; confirmed Python 3.14.3 macOS"]
    - [split_len_5,  re.split.__name__.__len__,  [],       5,    "re.split.__name__.__len__() == 5 — 'split' has 5 characters; split (5) ties with purge (5) at the second level in the ascending name length sequence: subn(4) < split(5)=purge(5) < escape(6); the tie split(5)==purge(5) creates a two-way tie at 5 in this spec, analogous to the compile(7)==findall(7) tie in re_extra170; split (5 chars) == len('match') (5 chars) == len('purge') (5 chars): a 3-way tie at 5 across re public function names (match, split, purge); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.subn function identity
# subn.__name__ == 'subn' (len=4), subn.__module__ == 're' (len=2)
# subn (4) == sub (3) + 1: subn is sub with count, adding 'n' for count
# subn (4) is the minimum function name length in this spec
# ---------------------------------------------------------------------------

table re_extra171.subn_identity:
  description: "re.subn.__name__=='subn' (len=4), re.subn.__module__=='re' (len=2); subn (4) is the minimum function name length in this spec: subn(4) < split(5)=purge(5) < escape(6); 'subn'='sub'(3)+'n'(1)=4; subn returns both the replaced string and the count of substitutions"
  kind: python_call_eq
  category: identity
  id_prefix: resubn171

  columns: [id, function, args, expected, description]
  rows:
    - [subn_name,   re.subn.__name__.__eq__,   ["subn"], true, "re.subn.__name__ == 'subn' — the function that substitutes pattern occurrences AND returns a count of substitutions; 'subn' has 4 characters: 's-u-b-n' = 'sub'(3)+'n'(1)=4; subn (4 chars) > sub (3 chars) by 1 == len('n'): the 'n' suffix appended to 'sub' requests the count (number of substitutions); subn (4) is the minimum function name length in this spec: subn(4) < split(5)=purge(5) < escape(6); re.subn(pattern, repl, string) returns a tuple (new_string, count) where count is the number of substitutions made; subn (4 chars) == len('enum') (4 chars) — a cross-module coincidence; confirmed Python 3.14.3 macOS"]
    - [subn_module, re.subn.__module__.__eq__, ["re"],   true, "re.subn.__module__ == 're' — re.subn is defined in the public 're' module; 're' has 2 characters; re.subn.__module__ (2: 're') == all other re public function modules (2 chars: 're'); 're' (2 chars) < 'subn' (4 chars) by 2: the module name is half the length of the function name; the 1-character gap between sub (3 chars) and subn (4 chars) parallels the 1-character gap between purge (5 chars) and escape (6 chars) — consecutive pairs throughout the ascending length sequence; confirmed Python 3.14.3 macOS"]
    - [subn_ne_sub, re.subn.__name__.__eq__,   ["sub"],  false, "re.subn.__name__.__eq__('sub') == False — 'subn' (4 chars) != 'sub' (3 chars); subn (4) and sub (3) differ by exactly 1 character — the trailing 'n' in subn; sub() returns only the modified string, while subn() returns a tuple (modified_string, count); the 'n' suffix in subn signals that the function returns the 'n'umber of substitutions in addition to the result string; subn.__name__ (4: 'subn') > sub.__name__ (3: 'sub') by 1 in length; confirmed Python 3.14.3 macOS"]
    - [subn_len_4,  re.subn.__name__.__len__,  [],       4,    "re.subn.__name__.__len__() == 4 — 'subn' has 4 characters; subn (4) is the minimum function name length in this spec — shorter than split (5) and purge (5) by 1, and shorter than escape (6) by 2; subn (4) == sub (3) + 1: 'subn' is formed by appending 'n' to 'sub', making subn 1 character longer; the extended ascending sequence including sub from re_extra170: sub(3) < subn(4) < split(5)=purge(5) < escape(6) — subn fits between sub and split; subn (4 chars) == len('enum') (4 chars) == len('NOFLAG'[:4]) — cross-module 4-character coincidences; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.escape function identity
# escape.__name__ == 'escape' (len=6), escape.__module__ == 're' (len=2)
# escape (6) is the maximum function name length in this spec
# escape (6) == search (6): cross-spec tie within the re module
# ---------------------------------------------------------------------------

table re_extra171.escape_identity:
  description: "re.escape.__name__=='escape' (len=6), re.escape.__module__=='re' (len=2); escape (6) is the maximum function name length in this spec: subn(4) < split(5)=purge(5) < escape(6); escape(6)==search(6) from re_extra170 — cross-spec tie; re.escape() escapes special regex characters"
  kind: python_call_eq
  category: identity
  id_prefix: reesc171

  columns: [id, function, args, expected, description]
  rows:
    - [escape_name,   re.escape.__name__.__eq__,   ["escape"], true, "re.escape.__name__ == 'escape' — the function that escapes all special regex characters in a string; 'escape' has 6 characters: 'e-s-c-a-p-e'; escape (6 chars) is the maximum function name length in this spec: subn(4) < split(5)=purge(5) < escape(6); escape (6 chars) == len('search') (6 chars) from re_extra170 — a cross-spec tie within the re module at 6 characters; re.escape(pattern) returns pattern with all non-alphanumeric characters backslash-escaped, useful for treating a string literal as a regex pattern; 'escape' (6 chars) == len('unlink') (6 chars) == len('rename') (6 chars) == len('exists') (6 chars) — cross-module ties with pathlib method names; confirmed Python 3.14.3 macOS"]
    - [escape_module, re.escape.__module__.__eq__, ["re"],     true, "re.escape.__module__ == 're' — re.escape is defined in the public 're' module; 're' has 2 characters; re.escape.__module__ (2: 're') == re.split.__module__ (2: 're') == re.subn.__module__ (2: 're') == re.purge.__module__ (2: 're'): all four functions in this spec share the 2-character module name 're'; 're' (2 chars) < 'escape' (6 chars) by 4 — the module name is 4 characters shorter than the escape function name; confirmed Python 3.14.3 macOS"]
    - [escape_ne_esc, re.escape.__name__.__eq__,   ["purge"],  false, "re.escape.__name__.__eq__('purge') == False — 'escape' (6 chars) != 'purge' (5 chars); escape and purge are different functions with different lengths and different purposes: escape() escapes metacharacters in a pattern string while purge() clears the compiled regex cache; escape (6) > purge (5) by 1: escape is 1 character longer; 'escape' starts with 'e' while 'purge' starts with 'p' — completely different strings despite both being in the re module; confirmed Python 3.14.3 macOS"]
    - [escape_len_6,  re.escape.__name__.__len__,  [],         6,    "re.escape.__name__.__len__() == 6 — 'escape' has 6 characters; escape (6) is the maximum in the 4-function spec name length sequence: subn(4) < split(5)=purge(5) < escape(6); escape (6) == len('search') (6) from re_extra170: within the entire re public function family, escape and search share the 6-character name length; the ascending sequence across this spec and re_extra170: sub(3) < subn(4) < split(5)=match(5)=purge(5) < search(6)=escape(6) < compile(7)=findall(7) < finditer(8) < fullmatch(9); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.purge function identity
# purge.__name__ == 'purge' (len=5), purge.__module__ == 're' (len=2)
# purge (5) ties with split (5)
# purge clears the compiled regular expression cache
# ---------------------------------------------------------------------------

table re_extra171.purge_identity:
  description: "re.purge.__name__=='purge' (len=5), re.purge.__module__=='re' (len=2); purge (5) ties with split (5) — two-way tie at 5; purge (5) == match (5) from re_extra170 — cross-spec tie; re.purge() clears the compiled regex cache; purge(5) > subn(4) by 1 and < escape(6) by 1"
  kind: python_call_eq
  category: identity
  id_prefix: repurge171

  columns: [id, function, args, expected, description]
  rows:
    - [purge_name,   re.purge.__name__.__eq__,   ["purge"], true, "re.purge.__name__ == 'purge' — the function that clears the cache of compiled regular expressions; 'purge' has 5 characters: 'p-u-r-g-e'; purge (5 chars) ties with split (5 chars) — the two-way tie at 5 in this spec mirrors the two-way tie at 7 (compile/findall) in re_extra170; purge (5 chars) == len('match') (5 chars) from re_extra170 — a cross-spec tie within the re module; re.purge() is rarely needed in production code since the compiled regex cache is managed automatically; purge (5) > subn (4) by 1; purge (5) < escape (6) by 1: purge is consecutive with both subn and escape; confirmed Python 3.14.3 macOS"]
    - [purge_module, re.purge.__module__.__eq__, ["re"],   true, "re.purge.__module__ == 're' — re.purge is defined in the public 're' module; 're' has 2 characters; re.purge.__module__ (2: 're') is the same for all 11 public re functions covered across re_extra170, re_extra171: compile, search, match, fullmatch, sub, findall, finditer, split, subn, escape, purge all have __module__ == 're' (2 chars); 're' (2 chars) < 'purge' (5 chars) by 3; confirmed Python 3.14.3 macOS"]
    - [purge_ne_spl, re.purge.__name__.__eq__,   ["split"], false, "re.purge.__name__.__eq__('split') == False — 'purge' (5 chars) != 'split' (5 chars); purge and split have the same length (5 chars) but completely different names and purposes: purge() clears the regex cache while split() splits a string at pattern matches; purge.__name__ (5: 'purge') and split.__name__ (5: 'split') form a two-way tie at 5 in length but are distinct strings; the equal length (5) does not imply equal function: they serve entirely different roles in the re module; confirmed Python 3.14.3 macOS"]
    - [purge_len_5,  re.purge.__name__.__len__,  [],       5,    "re.purge.__name__.__len__() == 5 — 'purge' has 5 characters; purge (5) ties with split (5) at the second level in the ascending length sequence: subn(4) < split(5)=purge(5) < escape(6); the two-way tie at 5 (split, purge) is the only tie in this spec's 4-function name family; purge (5 chars) == match (5 chars) from re_extra170: a cross-spec tie at 5 within the re module; combining this spec with re_extra170: the three 5-char functions in the re module are match, split, purge; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Function name length ordering and cross-spec comparisons
# subn(4) < split(5)=purge(5) < escape(6)
# Extended sequence with re_extra170: sub(3) < subn(4) < split(5)=match(5)=purge(5) < search(6)=escape(6)
# ---------------------------------------------------------------------------

table re_extra171.function_name_length_ordering:
  description: "re function name lengths in this spec: subn(4) < split(5)=purge(5) < escape(6); two-way tie at 5 for split and purge; subn(4) minimum; escape(6) maximum; cross-spec: sub(3) < subn(4) < split(5)=match(5)=purge(5) < search(6)=escape(6)"
  kind: python_call_eq
  category: identity
  id_prefix: refnlen171

  columns: [id, function, args, expected, description]
  rows:
    - [subn_len_4,   re.subn.__name__.__len__,   [], 4, "re.subn.__name__.__len__() == 4 — 'subn' has 4 characters: minimum in this spec; subn (4) > sub (3) by 1 from re_extra170: subn extends sub by appending 'n'; subn (4) < split (5) by 1: the gap from subn to the 5-char group is 1; the ascending sequence: sub(3) < subn(4) < split(5)=purge(5) < escape(6) — subn fits neatly between sub and the split/purge pair; subn (4 chars) == len('enum') (4 chars) from re_extra169 (IntFlag base module name); confirmed Python 3.14.3 macOS"]
    - [split_len_5,  re.split.__name__.__len__,  [], 5, "re.split.__name__.__len__() == 5 — 'split' has 5 characters; split (5) ties with purge (5) — the two-way tie at 5 in this spec; split (5) > subn (4) by 1; split (5) < escape (6) by 1: split is between subn and escape in the ascending length sequence; split (5) == match (5) from re_extra170: the three 5-character re functions are match, split, and purge; confirmed Python 3.14.3 macOS"]
    - [purge_len_5,  re.purge.__name__.__len__,  [], 5, "re.purge.__name__.__len__() == 5 — 'purge' has 5 characters; purge (5) ties with split (5) — completing the two-way 5-char tie; purge (5) == split (5) == match (5): a three-way tie at 5 across re public functions when combining re_extra170 and re_extra171; the three 5-char functions (match, split, purge) represent three very different operations: anchored string matching, list splitting, and cache clearing; confirmed Python 3.14.3 macOS"]
    - [escape_len_6, re.escape.__name__.__len__, [], 6, "re.escape.__name__.__len__() == 6 — 'escape' has 6 characters: maximum in this spec; escape (6) == search (6) from re_extra170: cross-spec tie at 6 within the re module; the two 6-char functions in the re module are search and escape — very different operations (scan string vs. escape metacharacters); the full re module 4-function length sequence in this spec: subn(4) < split(5)=purge(5) < escape(6); confirmed Python 3.14.3 macOS"]
    - [subn_lt_esc,  re.subn.__name__.__len__,   [], 4, "re.subn.__name__.__len__() == 4 < re.escape.__name__.__len__() (6) by 2; subn (4) is the minimum and escape (6) is the maximum in this spec: a range of 2 characters; the 4-function length distribution [4, 5, 5, 6] has a range of 2 — the most compact range across any re_extra spec; the two-way tie at 5 (split, purge) sits in the middle; subn (4) to escape (6): 4, 5, 5, 6 — the full ascending sequence with the tie; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra171.split_name_is_split:
  description: "re.split.__name__ == 'split' — the function that splits a string at each pattern match and returns a list; 'split' has 5 characters; split (5) ties with purge (5) — the two-way 5-char tie in this spec; split (5) == len('match') (5) from re_extra170 — cross-spec tie within the re module; re.split.__module__ == 're' (2 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.split.__name__.__eq__
  args: ["split"]
  expected: true

invariant re_extra171.split_module_is_re:
  description: "re.split.__module__ == 're' — re.split is defined in the public 're' module; 're' has 2 characters; re.split.__module__ (2) == re.subn.__module__ (2) == re.escape.__module__ (2) == re.purge.__module__ (2): all four functions in this spec share the 2-character module name 're'; 're' (2 chars) < 'split' (5 chars) by 3; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.split.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra171.subn_name_is_subn:
  description: "re.subn.__name__ == 'subn' — the function that substitutes and returns a (result, count) tuple; 'subn' has 4 characters: 'sub'(3)+'n'(1)=4; subn (4) > sub (3) by 1 — subn is sub extended with a count result; subn (4) is the minimum function name length in this spec; re.subn.__module__ == 're' (2 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.subn.__name__.__eq__
  args: ["subn"]
  expected: true

invariant re_extra171.subn_module_is_re:
  description: "re.subn.__module__ == 're' — re.subn is defined in the public 're' module; 're' has 2 characters; re.subn.__module__ (2: 're') is the same for all 11 re public functions across re_extra170 and re_extra171; 're' (2 chars) < 'subn' (4 chars) by 2; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.subn.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra171.escape_name_is_escape:
  description: "re.escape.__name__ == 'escape' — the function that escapes all regex metacharacters in a string; 'escape' has 6 characters — the maximum function name length in this spec; escape (6) == len('search') (6) from re_extra170: cross-spec tie within the re module; re.escape() returns a pattern with all non-alphanumeric characters backslash-escaped; re.escape.__module__ == 're' (2 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.escape.__name__.__eq__
  args: ["escape"]
  expected: true

invariant re_extra171.escape_module_is_re:
  description: "re.escape.__module__ == 're' — re.escape is defined in the public 're' module; 're' has 2 characters; re.escape.__module__ (2 chars) < re.escape.__name__ (6 chars) by 4 — the module name is 4 characters shorter; all re public functions share __module__ == 're' (2 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.escape.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra171.purge_name_is_purge:
  description: "re.purge.__name__ == 'purge' — the function that clears the compiled regex cache; 'purge' has 5 characters; purge (5) ties with split (5) — the two-way 5-char tie in this spec; purge (5) == len('match') (5) from re_extra170: a three-way tie at 5 (match, split, purge) across the re module functions; re.purge.__module__ == 're' (2 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.purge.__name__.__eq__
  args: ["purge"]
  expected: true

invariant re_extra171.split_name_len_is_5:
  description: "re.split.__name__.__len__() == 5 — 'split' has 5 characters; split (5) ties with purge (5) at the middle level in the ascending length sequence: subn(4) < split(5)=purge(5) < escape(6); the three 5-char re functions across re_extra170 and re_extra171: match(5), split(5), purge(5) — a three-way tie at 5 in the full re function name family; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.split.__name__.__len__
  args: []
  expected: 5

invariant re_extra171.escape_name_len_is_6:
  description: "re.escape.__name__.__len__() == 6 — 'escape' has 6 characters; escape (6) is the maximum in this spec; escape (6) == len('search') (6) from re_extra170: two functions in the re module have 6-character names (search and escape); the full 4-function ascending length sequence in this spec: subn(4) < split(5)=purge(5) < escape(6); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.escape.__name__.__len__
  args: []
  expected: 6

invariant re_extra171.subn_name_len_is_4:
  description: "re.subn.__name__.__len__() == 4 — 'subn' has 4 characters: 'sub'(3)+'n'(1)=4; subn (4) is the minimum function name length in this spec; subn (4) == sub (3) + 1: subn adds 1 character to sub by appending 'n'; the full ascending sequence: sub(3) < subn(4) < split(5)=purge(5) < escape(6) — subn sits between sub (from re_extra170) and split/purge; subn (4 chars) == len('enum') (4 chars): cross-module tie at 4; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.subn.__name__.__len__
  args: []
  expected: 4

