spec: uuid_extra337
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid._uuid.__name__ == '_uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_NCS.__len__() == 30 (length of 'reserved for NCS compatibility'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RFC_4122.__len__() == 21 (length of 'specified in RFC 4122'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_MICROSOFT.__len__() == 36 (length of 'reserved for Microsoft compatibility'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_FUTURE.__len__() == 30 (length of 'reserved for future definition'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__qualname__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.int.__class__.__name__ == 'member_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid._uuid is the C extension (lib-dynload/_uuid.cpython-*.so) backing time-based UUID generation; its __name__ is '_uuid'."
    - "Note: RESERVED_NCS and RESERVED_FUTURE both have length 30 (different strings, same character count)."
    - "Note: uuid.UUID.int is a member_descriptor (C-level slot) because UUID stores its 128-bit integer in a C struct slot via __slots__."
    - "Note: uuid.UUID.version is a Python property (not a C slot) because UUID version is optional and conditionally set."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid._uuid.__name__.__eq__('_uuid')
# uuid.UUID.__qualname__.__eq__('UUID')
# uuid.UUID.version.__class__.__name__.__eq__('property')
# uuid.UUID.hex.__class__.__name__.__eq__('property')
# uuid.UUID.int.__class__.__name__.__eq__('member_descriptor')
#
# Wave 337 theme: uuid._uuid C extension identity and UUID class descriptor types.
#
# uuid._uuid is the C extension backing time-based UUID generation; its
# __name__ is '_uuid'. uuid.UUID.__qualname__ is 'UUID' (not a nested class).
# uuid.UUID.version and uuid.UUID.hex are Python property objects — version is
# optional (not always present) and validated on set; hex formats the UUID as
# a 32-char hex string. uuid.UUID.int is a member_descriptor because UUID
# stores its 128-bit integer in a C struct slot (via __slots__).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra337.uuid_internal_and_class_descriptors:
  description: "uuid._uuid.__name__.__eq__('_uuid')==True / UUID.__qualname__.__eq__('UUID')==True / UUID.version.__class__.__name__.__eq__('property')==True / UUID.hex.__class__.__name__.__eq__('property')==True / UUID.int.__class__.__name__.__eq__('member_descriptor')==True — uuid._uuid C extension name; UUID qualname; version and hex are Python properties (optional/validated); int is a member_descriptor (C struct slot via __slots__); first uuidid337 anchor"
  kind: python_call_eq
  category: c_extension_identity
  id_prefix: uuidid337

  columns: [id, function, args, expected, description]
  rows:
    - [uuid_internal_name,     "_uuid.__name__.__eq__",                         ["_uuid"],             true, "uuid._uuid.__name__ is '_uuid' — C extension for time-based UUID generation"]
    - [uuid_class_qualname,    "UUID.__qualname__.__eq__",                      ["UUID"],              true, "uuid.UUID.__qualname__ is 'UUID' — top-level class, not nested"]
    - [version_is_property,    "UUID.version.__class__.__name__.__eq__",        ["property"],          true, "uuid.UUID.version is a Python property — optional, validated on set"]
    - [hex_is_property,        "UUID.hex.__class__.__name__.__eq__",            ["property"],          true, "uuid.UUID.hex is a Python property — formats UUID as 32-char hex string"]
    - [int_is_member_desc,     "UUID.int.__class__.__name__.__eq__",            ["member_descriptor"], true, "uuid.UUID.int is a member_descriptor — 128-bit integer stored in C struct slot via __slots__"]

# ---------------------------------------------------------------------------
# uuid.RESERVED_NCS.__len__()==30
# uuid.RFC_4122.__len__()==21
# uuid.RESERVED_MICROSOFT.__len__()==36
# uuid.RESERVED_FUTURE.__len__()==30
#
# Wave 337 theme: uuid variant string constant lengths.
#
# The four UUID variant string constants have these lengths:
#   RESERVED_NCS: 'reserved for NCS compatibility' — 30 chars
#   RFC_4122: 'specified in RFC 4122' — 21 chars
#   RESERVED_MICROSOFT: 'reserved for Microsoft compatibility' — 36 chars
#   RESERVED_FUTURE: 'reserved for future definition' — 30 chars
# Note: RESERVED_NCS and RESERVED_FUTURE both have length 30 (coincidence —
# different strings with the same character count). These lengths are stable
# Python constants that will not change across Python versions.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra337.variant_constant_lengths:
  description: "uuid.RESERVED_NCS.__len__()==30 / RFC_4122.__len__()==21 / RESERVED_MICROSOFT.__len__()==36 / RESERVED_FUTURE.__len__()==30 — four UUID variant string constant lengths: RESERVED_NCS('reserved for NCS compatibility')==30; RFC_4122('specified in RFC 4122')==21; RESERVED_MICROSOFT('reserved for Microsoft compatibility')==36; RESERVED_FUTURE('reserved for future definition')==30; RESERVED_NCS and RESERVED_FUTURE share length 30 by coincidence; first uuidid337 anchor for variant constant lengths"
  kind: python_call_eq
  category: variant_constants
  id_prefix: uuidid337

  columns: [id, function, args, expected, description]
  rows:
    - [reserved_ncs_len,   "RESERVED_NCS.__len__",       [], 30, "uuid.RESERVED_NCS.__len__() == 30 — 'reserved for NCS compatibility' is 30 chars"]
    - [rfc_4122_len,       "RFC_4122.__len__",           [], 21, "uuid.RFC_4122.__len__() == 21 — 'specified in RFC 4122' is 21 chars"]
    - [reserved_ms_len,    "RESERVED_MICROSOFT.__len__", [], 36, "uuid.RESERVED_MICROSOFT.__len__() == 36 — 'reserved for Microsoft compatibility' is 36 chars"]
    - [reserved_future_len, "RESERVED_FUTURE.__len__",   [], 30, "uuid.RESERVED_FUTURE.__len__() == 30 — 'reserved for future definition' is 30 chars"]

# ---------------------------------------------------------------------------
# uuid._uuid.__name__.__eq__('_uuid') — standalone
#
# uuid._uuid.__name__ is '_uuid'. uuid._uuid is the C extension that provides
# time-based UUID generation (uuid.uuid1) with optional system-level
# generate_time_safe support. Its __name__ attribute is '_uuid', confirming
# it is a distinct C module from the Python uuid wrapper. It is loaded from
# lib-dynload/_uuid.cpython-*.so on macOS.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra337.uuid_internal_name_is__uuid:
  description: "uuid._uuid.__name__.__eq__('_uuid') == True — uuid._uuid is the C extension providing time-based UUID generation (uuid1); __name__ is '_uuid', distinct from the Python wrapper 'uuid'; loaded from lib-dynload/_uuid.cpython-*.so on macOS; first standalone for _uuid.__name__ under uuidid337"
  category: c_extension_identity
  kind: python_call_eq
  function: _uuid.__name__.__eq__
  args: ["_uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.int.__class__.__name__.__eq__('member_descriptor') — standalone
#
# uuid.UUID.int.__class__.__name__ is 'member_descriptor'. UUID stores its
# 128-bit integer value in a C struct slot named 'int' declared via __slots__.
# When a class uses __slots__ at the C level, slot accessors appear as
# member_descriptor objects on the class. This is distinct from a Python
# property (which involves a getter/setter/deleter triple). The 'int' slot
# is the canonical internal representation of a UUID — all other attributes
# (hex, bytes, fields, etc.) are computed from it via Python properties.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra337.UUID_int_is_member_descriptor:
  description: "uuid.UUID.int.__class__.__name__.__eq__('member_descriptor') == True — UUID.int is a member_descriptor (C struct slot via __slots__); the 128-bit integer is the canonical UUID representation; all other attributes (hex, bytes, fields) are Python properties computed from it; member_descriptor differs from property (no getter/setter/deleter triple); first standalone for UUID.int descriptor type under uuidid337"
  category: class_descriptor
  kind: python_call_eq
  function: UUID.int.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__qualname__.__eq__('UUID') — standalone
#
# uuid.UUID.__qualname__ is 'UUID'. UUID is a top-level class in the uuid
# module — it is not a nested class or a class defined inside a function.
# Its __qualname__ therefore equals its simple __name__. uuid.UUID is the
# central class of the uuid module, representing a universally unique
# identifier with 128 bits (16 bytes).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra337.UUID_qualname_is_UUID:
  description: "uuid.UUID.__qualname__.__eq__('UUID') == True — UUID.__qualname__ is 'UUID', confirming it is a top-level class (not nested or closure-defined); __qualname__ equals __name__ for top-level classes; UUID represents a 128-bit universally unique identifier; first standalone for UUID.__qualname__ under uuidid337"
  category: class_descriptor
  kind: python_call_eq
  function: UUID.__qualname__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.RESERVED_MICROSOFT.__len__()==36 — standalone
#
# uuid.RESERVED_MICROSOFT.__len__() is 36. The string 'reserved for Microsoft
# compatibility' has 36 characters. This is the longest of the four UUID
# variant string constants. It describes the UUID variant used by COM/DCOM
# and other Microsoft software (variant bits '110' in the most-significant
# bits of the clock-seq-and-reserved field). UUIDs generated by older Microsoft
# tools often use this variant.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra337.RESERVED_MICROSOFT_len_36:
  description: "uuid.RESERVED_MICROSOFT.__len__() == 36 — 'reserved for Microsoft compatibility' is 36 chars; longest of the four UUID variant constants; describes the COM/DCOM Microsoft UUID variant (bits '110' in variant field); first standalone for RESERVED_MICROSOFT.__len__() under uuidid337"
  category: variant_constants
  kind: python_call_eq
  function: RESERVED_MICROSOFT.__len__
  args: []
  expected: 36

# ---------------------------------------------------------------------------
# uuid.RFC_4122.__len__()==21 — standalone
#
# uuid.RFC_4122.__len__() is 21. The string 'specified in RFC 4122' has
# 21 characters. This is the shortest of the four UUID variant constants.
# RFC 4122 is the standard that defines UUID formats for versions 1-5.
# All UUIDs generated by uuid.uuid1/uuid3/uuid4/uuid5 use this variant.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra337.RFC_4122_len_21:
  description: "uuid.RFC_4122.__len__() == 21 — 'specified in RFC 4122' is 21 chars; shortest of the four UUID variant constants; describes the standard RFC 4122 variant used by all uuid1/3/4/5-generated UUIDs; first standalone for RFC_4122.__len__() under uuidid337"
  category: variant_constants
  kind: python_call_eq
  function: RFC_4122.__len__
  args: []
  expected: 21
