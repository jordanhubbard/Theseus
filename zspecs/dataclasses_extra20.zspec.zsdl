spec: dataclasses_extra20
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses documentation"
    - "PEP 557 — Data Classes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses.zspec.zsdl, dataclasses_field.zspec.zsdl, and dataclasses_extra through dataclasses_extra19.zspec.zsdl."
    - "dataclasses_extra19 covers: field().metadata.__class__.__name__ == 'mappingproxy'; field().hash.__class__.__name__ == 'NoneType'; field().__class__.__name__ via method_chain; fields/asdict/astuple/is_dataclass __qualname__.__eq__ standalone; fields/__name__.__len__/is_dataclass/__name__.__len__/make_dataclass/__name__.__len__ standalone."
    - "dataclasses_extra18 covers: MISSING/__class__.__name__.__len__(); KW_ONLY/__class__.__name__.__len__(); replace/__qualname__.__eq__; make_dataclass/__qualname__.__eq__; asdict/__qualname__.__len__; astuple/__qualname__.__len__; replace/__qualname__.__len__."
    - "dataclasses_extra17 covers: field/__qualname__.__len__; dataclass/__qualname__.__len__; field/__qualname__.__eq__; FrozenInstanceError/__qualname__.__eq__; FrozenInstanceError/__name__.__eq__; InitVar/__qualname__.__eq__; Field/__qualname__.__eq__; dataclass/__name__.__eq__; fields/__qualname__.__eq__."
    - "dataclasses_extra16 covers: fields/asdict/astuple/replace __qualname__.__len__; FrozenInstanceError MRO[0]; fields/asdict/astuple/make_dataclass/is_dataclass __module__ standalone."
    - "Focus of this spec: (1) combined __name__ table for dataclass/field/fields/asdict/astuple/make_dataclass/replace; (2) combined __module__ table for the same seven functions; (3) FrozenInstanceError.__qualname__ standalone; (4) KW_ONLY.__class__.__name__ standalone."
    - "NOT yet covered (entering this spec): combined __name__ table for all seven functions; combined __module__ table for all seven functions; FrozenInstanceError.__qualname__ standalone invariant; KW_ONLY.__class__.__name__ standalone invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ for dataclass, field, fields, asdict, astuple, make_dataclass,
# replace
#
# These are the core public functions/decorators in the dataclasses module.
# Each __name__ matches its identifier. No prior spec has all seven together
# in a single combined table.
# dataclass(9), field(5), fields(6), asdict(6), astuple(7),
# make_dataclass(14), replace(7).
# ---------------------------------------------------------------------------

table dataclasses_extra20.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [dataclass,      dataclass.__name__.__eq__,      ["dataclass"],      true]
    - [field,          field.__name__.__eq__,          ["field"],          true]
    - [fields,         fields.__name__.__eq__,         ["fields"],         true]
    - [asdict,         asdict.__name__.__eq__,         ["asdict"],         true]
    - [astuple,        astuple.__name__.__eq__,        ["astuple"],        true]
    - [make_dataclass, make_dataclass.__name__.__eq__, ["make_dataclass"], true]
    - [replace,        replace.__name__.__eq__,        ["replace"],        true]

# ---------------------------------------------------------------------------
# __module__ for dataclass, field, fields, asdict, astuple, make_dataclass,
# replace
#
# All seven are defined in the dataclasses module; __module__ == 'dataclasses'.
# dataclasses_extra16 covers fields/asdict/astuple/make_dataclass/is_dataclass
# __module__ as standalone invariants. No prior spec has all seven core
# functions together in a single combined __module__ table.
# ---------------------------------------------------------------------------

table dataclasses_extra20.function_modules:
  kind: python_call_eq
  category: modules
  id_prefix: fmodule

  columns: [id, function, args, expected]
  rows:
    - [dataclass,      dataclass.__module__.__eq__,      ["dataclasses"], true]
    - [field,          field.__module__.__eq__,          ["dataclasses"], true]
    - [fields,         fields.__module__.__eq__,         ["dataclasses"], true]
    - [asdict,         asdict.__module__.__eq__,         ["dataclasses"], true]
    - [astuple,        astuple.__module__.__eq__,        ["dataclasses"], true]
    - [make_dataclass, make_dataclass.__module__.__eq__, ["dataclasses"], true]
    - [replace,        replace.__module__.__eq__,        ["dataclasses"], true]

# ---------------------------------------------------------------------------
# FrozenInstanceError.__qualname__ standalone
#
# dataclasses_extra17 covers FrozenInstanceError/__qualname__.__eq__ in a
# table row. No prior spec has FrozenInstanceError.__qualname__.__eq__ as a
# standalone boolean invariant for isolated machine-readable indexing.
# FrozenInstanceError.__qualname__ == 'FrozenInstanceError'.
# ---------------------------------------------------------------------------

invariant dataclasses_extra20.FrozenInstanceError.qualname_eq:
  description: "dataclasses.FrozenInstanceError.__qualname__ == 'FrozenInstanceError' — standalone boolean invariant"
  category: qualnames
  kind: python_call_eq
  function: FrozenInstanceError.__qualname__.__eq__
  args: ["FrozenInstanceError"]
  expected: true

# ---------------------------------------------------------------------------
# KW_ONLY.__class__.__name__ standalone
#
# dataclasses.KW_ONLY is a sentinel object used as a field default marker to
# indicate keyword-only fields. Its class is the private _KW_ONLY_TYPE.
# dataclasses_extra18 covers KW_ONLY/__class__.__name__.__len__() == 11.
# No prior spec checks KW_ONLY.__class__.__name__.__eq__('_KW_ONLY_TYPE') as
# a standalone invariant.
# ---------------------------------------------------------------------------

invariant dataclasses_extra20.KW_ONLY.class_name_eq:
  description: "dataclasses.KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE' — sentinel class name"
  category: class_names
  kind: python_call_eq
  function: KW_ONLY.__class__.__name__.__eq__
  args: ["_KW_ONLY_TYPE"]
  expected: true
