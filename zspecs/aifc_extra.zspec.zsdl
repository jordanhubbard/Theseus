  function: Aifc_read.getnframes.__name__.__eq__
  args: ["getnframes"]
  expected: true

invariant aifc_extra.Aifc_read.getnchannels_name:
  description: "aifc.Aifc_read.getnchannels.__name__ == 'getnchannels'"
  category: methods
  kind: python_call_eq
  function: Aifc_read.getnchannels.__name__.__eq__
  args: ["getnchannels"]
  expected: true

