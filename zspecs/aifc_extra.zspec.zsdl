spec: aifc_extra
version: ">=3.9,<3.13"
backend: python_module(aifc)

docs: https://docs.python.org/3/library/aifc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/aifc.html — Python aifc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/aifc.py"
  notes:
    - "Extends aifc.zspec.zsdl with additional function name, class name, and method name invariants."
    - "The aifc module was deprecated in Python 3.11 and removed in Python 3.13; this spec applies to >=3.9,<3.13."
    - "aifc.open is the primary entry point; its __name__ == 'open' and __module__ == 'aifc'."
    - "aifc.Error is the module exception; it inherits from Exception and has __module__ == 'aifc'."
    - "Aifc_read and Aifc_write are the internal implementation classes returned by aifc.open."
    - "Methods like getsampwidth, getframerate, getnframes, getnchannels are defined on Aifc_read and Aifc_write."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# open() function — name and module affiliation
# ---------------------------------------------------------------------------

invariant aifc_extra.open.name:
  description: "aifc.open.__name__ == 'open'"
  category: functions
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

invariant aifc_extra.open.module:
  description: "aifc.open.__module__ == 'aifc'"
  category: functions
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["aifc"]
  expected: true

# ---------------------------------------------------------------------------
# Error class — name, module, and hierarchy
# ---------------------------------------------------------------------------

invariant aifc_extra.Error.name:
  description: "aifc.Error.__name__ == 'Error'"
  category: classes
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant aifc_extra.Error.module:
  description: "aifc.Error.__module__ == 'aifc'"
  category: classes
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["aifc"]
  expected: true

invariant aifc_extra.Error.base_is_Exception:
  description: "aifc.Error.__bases__[0].__name__ == 'Exception'"
  category: classes
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

invariant aifc_extra.Error.bases_len:
  description: "len(aifc.Error.__bases__) == 1 — Error has exactly one direct base"
  category: classes
  kind: python_call_eq
  function: Error.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Aifc_read — class name and method names for read objects
# ---------------------------------------------------------------------------

invariant aifc_extra.Aifc_read.name:
  description: "aifc.Aifc_read.__name__ == 'Aifc_read'"
  category: classes
  kind: python_call_eq
  function: Aifc_read.__name__.__eq__
  args: ["Aifc_read"]
  expected: true

invariant aifc_extra.Aifc_read.module:
  description: "aifc.Aifc_read.__module__ == 'aifc'"
  category: classes
  kind: python_call_eq
  function: Aifc_read.__module__.__eq__
  args: ["aifc"]
  expected: true

invariant aifc_extra.Aifc_read.getsampwidth_name:
  description: "aifc.Aifc_read.getsampwidth.__name__ == 'getsampwidth'"
  category: methods
  kind: python_call_eq
  function: Aifc_read.getsampwidth.__name__.__eq__
  args: ["getsampwidth"]
  expected: true

invariant aifc_extra.Aifc_read.getframerate_name:
