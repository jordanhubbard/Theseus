# ---------------------------------------------------------------------------

invariant aifc_extra.Aifc_write.name:
  description: "aifc.Aifc_write.__name__ == 'Aifc_write'"
  category: classes
  kind: python_call_eq
  function: Aifc_write.__name__.__eq__
