spec: inspect_extra210
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra209.zspec.zsdl — covers Signature.__dict__ and Parameter.__dict__ membership, annotation class name checks"
    - "inspect_extra.zspec.zsdl — covers __name__ and __module__ identity checks for inspect functions"
  notes:
    - "inspect.Parameter.empty is the sentinel class itself (a type); type(inspect.Parameter.empty).__name__ == 'type'. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY is an instance of _ParameterKind (an IntEnum); type().__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "All five kind constants (POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD) have __class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec is a namedtuple with _fields: ('args', 'varargs', 'varkw', 'defaults', 'kwonlyargs', 'kwonlydefaults', 'annotations'). Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__doc__ == 'FullArgSpec(args, varargs, varkw, defaults, kwonlyargs, kwonlydefaults, annotations)'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter kind constant __class__.__name__ checks
#
# Parameter.POSITIONAL_ONLY.__class__.__name__      == '_ParameterKind'
# Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'
# Parameter.VAR_POSITIONAL.__class__.__name__        == '_ParameterKind'
# Parameter.KEYWORD_ONLY.__class__.__name__          == '_ParameterKind'
# ---------------------------------------------------------------------------

table inspect_extra210.parameter_kind_class_names:
  description: "inspect.Parameter kind constant __class__.__name__ checks in inspectrepr210 namespace — POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY are all instances of _ParameterKind (an IntEnum subclass); each __class__.__name__.__eq__('_ParameterKind') returns True; these are the four most common parameter kinds; verified with Python 3.14.3"
  kind: python_call_eq
  category: parameter_kind
  id_prefix: inspectrepr210

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_class_name,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — POSITIONAL_ONLY is an instance of _ParameterKind (IntEnum) with integer value 0; represents parameters that can only be passed positionally (before a /); __class__.__name__.__eq__('_ParameterKind') returns True; verified with Python 3.14.3"]
    - [positional_or_keyword_class_name,
       "Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind' — POSITIONAL_OR_KEYWORD is an instance of _ParameterKind with integer value 1; represents the default parameter kind (can be passed positionally or as keyword); __class__.__name__.__eq__('_ParameterKind') returns True; verified with Python 3.14.3"]
    - [var_positional_class_name,
       "Parameter.VAR_POSITIONAL.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind' — VAR_POSITIONAL is an instance of _ParameterKind with integer value 2; represents *args parameters; __class__.__name__.__eq__('_ParameterKind') returns True; verified with Python 3.14.3"]
    - [keyword_only_class_name,
       "Parameter.KEYWORD_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind' — KEYWORD_ONLY is an instance of _ParameterKind with integer value 3; represents parameters that must be passed as keyword arguments (after *args); __class__.__name__.__eq__('_ParameterKind') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter.VAR_KEYWORD and Parameter.empty class name checks
#
# Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind'
# Parameter.empty.__class__.__name__       == 'type'
# Negative: Parameter.empty.__class__.__name__ != '_ParameterKind'
# Negative: Parameter.POSITIONAL_ONLY.__class__.__name__ != 'type'
# ---------------------------------------------------------------------------

table inspect_extra210.parameter_empty_and_var_keyword:
  description: "inspect.Parameter.VAR_KEYWORD and Parameter.empty __class__.__name__ checks in inspectrepr210e namespace — VAR_KEYWORD.__class__.__name__ == '_ParameterKind' (value 4, represents **kwargs parameters); Parameter.empty.__class__.__name__ == 'type' (empty is the sentinel class itself, a type object, not a _ParameterKind instance); negative: empty class is not '_ParameterKind'; negative: POSITIONAL_ONLY class is not 'type'; verified with Python 3.14.3"
  kind: python_call_eq
  category: parameter_kind
  id_prefix: inspectrepr210e

  columns: [id, function, args, expected, description]
  rows:
    - [var_keyword_class_name,
       "Parameter.VAR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind' — VAR_KEYWORD is an instance of _ParameterKind with integer value 4; represents **kwargs parameters; __class__.__name__.__eq__('_ParameterKind') returns True; verified with Python 3.14.3"]
    - [empty_class_name_type,
       "Parameter.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is the sentinel class itself (a type object used as a default when no default or annotation is provided); its __class__ is 'type'; __eq__('type') returns True; verified with Python 3.14.3"]
    - [empty_not_parameter_kind,
       "Parameter.empty.__class__.__name__.__eq__",
       ["_ParameterKind"],
       false,
       "inspect.Parameter.empty.__class__.__name__.__eq__('_ParameterKind') == False — Parameter.empty is a type (class), not an instance of _ParameterKind; __eq__('_ParameterKind') returns False; negative cross-check; verified with Python 3.14.3"]
    - [positional_only_not_type,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__",
       ["type"],
       false,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('type') == False — POSITIONAL_ONLY is an instance of _ParameterKind, not a type; __eq__('type') returns False; negative cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: inspect.FullArgSpec docstring __contains__ checks
#
# FullArgSpec.__doc__.__contains__('varkw')       == True
# FullArgSpec.__doc__.__contains__('varargs')     == True
# FullArgSpec.__doc__.__contains__('annotations') == True
# FullArgSpec.__doc__.__contains__('args')        == True
# ---------------------------------------------------------------------------

table inspect_extra210.fullargspec_doc_contains:
  description: "inspect.FullArgSpec.__doc__ __contains__ checks in inspectrepr210f namespace — FullArgSpec is a namedtuple; its __doc__ is 'FullArgSpec(args, varargs, varkw, defaults, kwonlyargs, kwonlydefaults, annotations)'; 'varkw' is present (the **kwargs name in FullArgSpec, distinct from 'varkw' field); 'varargs' is present (*args field); 'annotations' is present; 'args' is present; all four __contains__ calls return True; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc_contains
  id_prefix: inspectrepr210f

  columns: [id, function, args, expected, description]
  rows:
    - [fullargspec_doc_has_varkw,
       "FullArgSpec.__doc__.__contains__",
       ["varkw"],
       true,
       "inspect.FullArgSpec.__doc__.__contains__('varkw') == True — the FullArgSpec namedtuple docstring lists 'varkw' as the field for **kwargs; __contains__('varkw') returns True; verified with Python 3.14.3"]
    - [fullargspec_doc_has_varargs,
       "FullArgSpec.__doc__.__contains__",
       ["varargs"],
       true,
       "inspect.FullArgSpec.__doc__.__contains__('varargs') == True — the FullArgSpec namedtuple docstring lists 'varargs' as the field for *args; __contains__('varargs') returns True; verified with Python 3.14.3"]
    - [fullargspec_doc_has_annotations,
       "FullArgSpec.__doc__.__contains__",
       ["annotations"],
       true,
       "inspect.FullArgSpec.__doc__.__contains__('annotations') == True — the FullArgSpec namedtuple docstring lists 'annotations' as the field for the annotations dict; __contains__('annotations') returns True; verified with Python 3.14.3"]
    - [fullargspec_doc_has_args,
       "FullArgSpec.__doc__.__contains__",
       ["args"],
       true,
       "inspect.FullArgSpec.__doc__.__contains__('args') == True — the FullArgSpec namedtuple docstring lists 'args' as the first field; __contains__('args') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra210
# ---------------------------------------------------------------------------

invariant inspect_extra210.parameter_empty_class_name_type:
  description: "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is the sentinel class itself (a type object), not an instance of _ParameterKind; new to extra210; verified with Python 3.14.3"
  category: parameter_kind
  kind: python_call_eq
  function: "Parameter.empty.__class__.__name__.__eq__"
  args: ["type"]
  expected: true

invariant inspect_extra210.parameter_positional_only_class_name:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — POSITIONAL_ONLY is an IntEnum instance of _ParameterKind with value 0; new to extra210; verified with Python 3.14.3"
  category: parameter_kind
  kind: python_call_eq
  function: "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__"
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra210.parameter_positional_or_keyword_class_name:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind' — POSITIONAL_OR_KEYWORD is an IntEnum instance of _ParameterKind with value 1; new to extra210; verified with Python 3.14.3"
  category: parameter_kind
  kind: python_call_eq
  function: "Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__"
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra210.parameter_var_positional_class_name:
  description: "inspect.Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind' — VAR_POSITIONAL is an IntEnum instance of _ParameterKind with value 2; new to extra210; verified with Python 3.14.3"
  category: parameter_kind
  kind: python_call_eq
  function: "Parameter.VAR_POSITIONAL.__class__.__name__.__eq__"
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra210.parameter_keyword_only_class_name:
  description: "inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind' — KEYWORD_ONLY is an IntEnum instance of _ParameterKind with value 3; new to extra210; verified with Python 3.14.3"
  category: parameter_kind
  kind: python_call_eq
  function: "Parameter.KEYWORD_ONLY.__class__.__name__.__eq__"
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra210.parameter_var_keyword_class_name:
  description: "inspect.Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind' — VAR_KEYWORD is an IntEnum instance of _ParameterKind with value 4; new to extra210; verified with Python 3.14.3"
  category: parameter_kind
  kind: python_call_eq
  function: "Parameter.VAR_KEYWORD.__class__.__name__.__eq__"
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra210.fullargspec_doc_has_varkw:
  description: "inspect.FullArgSpec.__doc__.__contains__('varkw') == True — the FullArgSpec namedtuple docstring lists 'varkw' as the **kwargs field; new to extra210; verified with Python 3.14.3"
  category: doc_contains
  kind: python_call_eq
  function: "FullArgSpec.__doc__.__contains__"
  args: ["varkw"]
  expected: true

invariant inspect_extra210.fullargspec_doc_has_annotations:
  description: "inspect.FullArgSpec.__doc__.__contains__('annotations') == True — the FullArgSpec namedtuple docstring lists 'annotations' as the annotations field; new to extra210; verified with Python 3.14.3"
  category: doc_contains
  kind: python_call_eq
  function: "FullArgSpec.__doc__.__contains__"
  args: ["annotations"]
  expected: true

