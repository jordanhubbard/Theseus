spec: hashlib_extra856
python: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython/Lib/hashlib.py"
    - "cpython/Modules/_hashopenssl.c"
  not_derived_from:
    - "any third-party hashing library"
  notes:
    - "Covers method __qualname__ attributes on md5, sha1, sha256 hash objects"
    - "Qualnames are of the form '<algname>.<methodname>' per CPython convention"
  created_at: "2026-04-12"

table hashlib_extra856.method_qualnames:
  description: "Verify __qualname__ strings on md5, sha1, and sha256 method objects"
  kind: python_call_eq
  category: introspection
  id_prefix: hl856xx
  columns: [id, function, args, expected]
  rows:
    - [hl856xx001, "hashlib.md5.update.__qualname__.__eq__", ["md5.update"], true]
    - [hl856xx002, "hashlib.md5.digest.__qualname__.__eq__", ["md5.digest"], true]
    - [hl856xx003, "hashlib.md5.hexdigest.__qualname__.__eq__", ["md5.hexdigest"], true]
    - [hl856xx004, "hashlib.md5.copy.__qualname__.__eq__", ["md5.copy"], true]
    - [hl856xx005, "hashlib.sha1.update.__qualname__.__eq__", ["sha1.update"], true]
    - [hl856xx006, "hashlib.sha1.digest.__qualname__.__eq__", ["sha1.digest"], true]
    - [hl856xx007, "hashlib.sha1.hexdigest.__qualname__.__eq__", ["sha1.hexdigest"], true]
    - [hl856xx008, "hashlib.sha1.copy.__qualname__.__eq__", ["sha1.copy"], true]
    - [hl856xx009, "hashlib.sha256.update.__qualname__.__eq__", ["sha256.update"], true]
    - [hl856xx010, "hashlib.sha256.digest.__qualname__.__eq__", ["sha256.digest"], true]
    - [hl856xx011, "hashlib.sha256.hexdigest.__qualname__.__eq__", ["sha256.hexdigest"], true]
    - [hl856xx012, "hashlib.sha256.copy.__qualname__.__eq__", ["sha256.copy"], true]
