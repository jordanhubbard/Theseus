spec: decimal_extra2491
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "Theme: __setitem__, __delitem__, and __missing__ dict-presence — checking whether decimal classes define mutable item access and missing-key protocol in their class __dict__."
    - "decimal.Decimal is an immutable numeric type — it defines no mutable item access in its class __dict__."
    - "decimal.Decimal.__dict__ does NOT contain '__setitem__' (False) — Decimal values are immutable."
    - "decimal.Decimal.__dict__ does NOT contain '__delitem__' (False) — item deletion is not supported."
    - "decimal.Decimal.__dict__ does NOT contain '__missing__' (False) — Decimal has no missing-key protocol."
    - "decimal.Context.__dict__ does NOT contain '__setitem__', '__delitem__', or '__missing__' (all False) — Context uses attribute access, not item access."
    - "decimal.DecimalTuple.__dict__ does NOT contain '__setitem__', '__delitem__', or '__missing__' (all False) — DecimalTuple is a namedtuple and immutable."
    - "decimal.InvalidOperation.__dict__ does NOT contain '__setitem__', '__delitem__', or '__missing__' (all False) — exception signal class, not a mapping."
    - "decimal.Decimal.__dict__ DOES contain arithmetic operators: __add__, __sub__, __mul__, __truediv__, __neg__, __abs__ (all True)."
    - "decimal.Decimal.__dict__ DOES contain 'normalize', 'quantize', 'is_nan', 'is_finite', 'is_infinite', 'sqrt', 'exp', 'ln' (all True)."
    - "decimal.Context.__dict__ DOES contain 'normalize', 'quantize', 'add', 'subtract', 'multiply', 'divide', 'sqrt' (all True) — arithmetic context operations."
    - "Accessing '__setitem__' via decimal.Decimal.__dict__.__getitem__ raises KeyError — the key is genuinely absent."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__ — mutable item access protocol absence
# Decimal is an immutable numeric type; it defines no __setitem__,
# __delitem__, or __missing__ in its class __dict__.
# ---------------------------------------------------------------------------

table decimal_extra2491.Decimal_mutable_item_absence:
  description: "decimal.Decimal.__dict__ does not contain __setitem__, __delitem__, or __missing__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: dc2491

  columns: [id, function, args, expected]
  rows:
    - ["dc2491001", Decimal.__dict__.__contains__, ["__setitem__"], false]
    - ["dc2491002", Decimal.__dict__.__contains__, ["__delitem__"], false]
    - ["dc2491003", Decimal.__dict__.__contains__, ["__missing__"], false]

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__ — arithmetic operators and methods that ARE present
# Confirms the numeric API is defined directly on Decimal, contrasting with
# the absent mutable-mapping protocol entries.
# ---------------------------------------------------------------------------

table decimal_extra2491.Decimal_arithmetic_presence:
  description: "decimal.Decimal.__dict__ contains arithmetic operators: __add__, __sub__, __mul__, __truediv__, __neg__, __abs__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: dc2491

  columns: [id, function, args, expected]
  rows:
    - ["dc2491004", Decimal.__dict__.__contains__, ["__add__"],     true]
    - ["dc2491005", Decimal.__dict__.__contains__, ["__sub__"],     true]
    - ["dc2491006", Decimal.__dict__.__contains__, ["__mul__"],     true]
    - ["dc2491007", Decimal.__dict__.__contains__, ["__truediv__"], true]
    - ["dc2491008", Decimal.__dict__.__contains__, ["__neg__"],     true]
    - ["dc2491009", Decimal.__dict__.__contains__, ["__abs__"],     true]
    - ["dc2491010", Decimal.__dict__.__contains__, ["normalize"],   true]
    - ["dc2491011", Decimal.__dict__.__contains__, ["quantize"],    true]
    - ["dc2491012", Decimal.__dict__.__contains__, ["is_nan"],      true]
    - ["dc2491013", Decimal.__dict__.__contains__, ["is_finite"],   true]
    - ["dc2491014", Decimal.__dict__.__contains__, ["sqrt"],        true]

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__.__getitem__ — KeyError for mutable-item keys
# Accessing an absent key via __getitem__ raises KeyError, consistent with
# mappingproxy semantics. Confirms the protocol keys are genuinely absent.
# ---------------------------------------------------------------------------

table decimal_extra2491.Decimal_dict_getitem_raises:
  description: "decimal.Decimal.__dict__.__getitem__ raises KeyError for __setitem__, __delitem__, __missing__"
  kind: python_call_raises
  category: dict_membership
  id_prefix: dc2491

  columns: [id, function, args, expected]
  rows:
    - ["dc2491015", Decimal.__dict__.__getitem__, ["__setitem__"], KeyError]
    - ["dc2491016", Decimal.__dict__.__getitem__, ["__delitem__"], KeyError]
    - ["dc2491017", Decimal.__dict__.__getitem__, ["__missing__"], KeyError]

# ---------------------------------------------------------------------------
# decimal.Context.__dict__ — mutable item access protocol absence
# Context uses attribute access (ctx.prec, ctx.rounding) for its settings,
# not item access. __setitem__, __delitem__, and __missing__ are absent.
# ---------------------------------------------------------------------------

