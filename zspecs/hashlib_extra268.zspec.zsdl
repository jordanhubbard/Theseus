spec: hashlib_extra268
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha3module.c"
    - "hashlib_extra267.zspec.zsdl — covers sha256/sha512/md5/sha1 constructor __name__ and __class__.__name__; hexdigest length; known test vectors for sha256/sha512/md5/sha1."
    - "hashlib_extra266.zspec.zsdl — covers hashlib module identity (__name__, __package__, __spec__, __loader__), __all__ type, and new/__hash_new function identity."
    - "hashlib_extra107.zspec.zsdl — covers HASH class identity, HASH method qualname lengths, hash algorithm digest_size and block_size values."
    - "hashlib.zspec.zsdl — covers sha256/sha1/md5/sha512/sha3_256/sha3_512/blake2b/blake2s known vectors using hash_known_vector kind; incremental update; digest consistency; copy independence; api equivalence."
  notes:
    - "hashlib.sha3_256.__name__ == 'openssl_sha3_256' — SHA-3/256 is backed by OpenSSL in CPython. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha3_512.__name__ == 'openssl_sha3_512' — SHA-3/512 is backed by OpenSSL in CPython. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.shake_128.__name__ == 'openssl_shake_128' — SHAKE-128 is backed by OpenSSL in CPython. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.shake_256.__name__ == 'openssl_shake_256' — SHAKE-256 is backed by OpenSSL in CPython. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.scrypt.__name__ == 'scrypt' — scrypt is a C builtin_function_or_method backed by OpenSSL (_hashlib). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac' — PBKDF2-HMAC is a C builtin_function_or_method backed by OpenSSL (_hashlib). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.algorithms_available.__class__.__name__ == 'set' — the set of all available hash algorithm names. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — the set of guaranteed hash algorithm names. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SHA-3 and SHAKE constructor identity — __name__ and __class__.__name__
# sha3_256, sha3_512, shake_128, shake_256 are all OpenSSL-backed C builtins
# with __module__ == '_hashlib'.
# ---------------------------------------------------------------------------

table hashlib_extra268.sha3_shake_constructor_identity:
  description: "hashlib sha3_256/sha3_512/shake_128/shake_256 constructor __name__ and __class__.__name__ — all OpenSSL-backed C builtin_function_or_method; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashsha3_268

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_name,    sha3_256.__name__.__eq__,               ["openssl_sha3_256"],           true, "hashlib.sha3_256.__name__ == 'openssl_sha3_256' — OpenSSL-backed SHA-3/256 constructor name"]
    - [sha3_256_class,   sha3_256.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "hashlib.sha3_256.__class__.__name__ == 'builtin_function_or_method' — C-level constructor"]
    - [sha3_512_name,    sha3_512.__name__.__eq__,               ["openssl_sha3_512"],           true, "hashlib.sha3_512.__name__ == 'openssl_sha3_512' — OpenSSL-backed SHA-3/512 constructor name"]
    - [sha3_512_class,   sha3_512.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "hashlib.sha3_512.__class__.__name__ == 'builtin_function_or_method' — C-level constructor"]
    - [shake_128_name,   shake_128.__name__.__eq__,              ["openssl_shake_128"],          true, "hashlib.shake_128.__name__ == 'openssl_shake_128' — OpenSSL-backed SHAKE-128 constructor name"]

# ---------------------------------------------------------------------------
# scrypt and pbkdf2_hmac key derivation function identity
# Both are C builtin_function_or_method objects from _hashlib (OpenSSL).
# scrypt.__name__ == 'scrypt', pbkdf2_hmac.__name__ == 'pbkdf2_hmac'
# ---------------------------------------------------------------------------

table hashlib_extra268.kdf_function_identity:
  description: "hashlib scrypt and pbkdf2_hmac key-derivation function __name__, __module__, __class__.__name__ — both are C builtins from _hashlib; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashkdf268

  columns: [id, function, args, expected, description]
  rows:
    - [scrypt_name,         scrypt.__name__.__eq__,               ["scrypt"],                    true, "hashlib.scrypt.__name__ == 'scrypt'"]
    - [scrypt_module,       scrypt.__module__.__eq__,             ["_hashlib"],                  true, "hashlib.scrypt.__module__ == '_hashlib' — provided by the C extension"]
    - [scrypt_class,        scrypt.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "hashlib.scrypt.__class__.__name__ == 'builtin_function_or_method' — C-level function"]
    - [pbkdf2_name,         pbkdf2_hmac.__name__.__eq__,          ["pbkdf2_hmac"],               true, "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac'"]
    - [pbkdf2_module,       pbkdf2_hmac.__module__.__eq__,        ["_hashlib"],                  true, "hashlib.pbkdf2_hmac.__module__ == '_hashlib' — provided by the C extension"]

# ---------------------------------------------------------------------------
# algorithms_available and algorithms_guaranteed — both are set instances
# hashlib.algorithms_available is the set of all available hash names
# hashlib.algorithms_guaranteed is the set of names available on all platforms
# ---------------------------------------------------------------------------

invariant hashlib_extra268.algorithms_available_class:
  description: "hashlib.algorithms_available.__class__.__name__ == 'set' — the set of available algorithm names is a plain Python set"
  category: identity
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

invariant hashlib_extra268.algorithms_guaranteed_class:
  description: "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — the set of guaranteed algorithm names is a plain Python set"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# shake_256 constructor identity
# ---------------------------------------------------------------------------

invariant hashlib_extra268.shake_256_name_eq:
  description: "hashlib.shake_256.__name__ == 'openssl_shake_256' — SHAKE-256 constructor is OpenSSL-backed"
  category: identity
  kind: python_call_eq
  function: shake_256.__name__.__eq__
  args: ["openssl_shake_256"]
  expected: true

invariant hashlib_extra268.shake_256_class_eq:
  description: "hashlib.shake_256.__class__.__name__ == 'builtin_function_or_method' — SHAKE-256 constructor is a C-level builtin"
  category: identity
  kind: python_call_eq
  function: shake_256.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# pbkdf2_hmac identity standalone
# ---------------------------------------------------------------------------

invariant hashlib_extra268.pbkdf2_hmac_name_eq:
  description: "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac' — PBKDF2-HMAC function name"
  category: identity
  kind: python_call_eq
  function: pbkdf2_hmac.__name__.__eq__
  args: ["pbkdf2_hmac"]
  expected: true

invariant hashlib_extra268.pbkdf2_hmac_class_eq:
  description: "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method' — pbkdf2_hmac is a C-level builtin from _hashlib"
  category: identity
  kind: python_call_eq
  function: pbkdf2_hmac.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant hashlib_extra268.scrypt_name_eq:
  description: "hashlib.scrypt.__name__ == 'scrypt' — scrypt key-derivation function name"
  category: identity
  kind: python_call_eq
  function: scrypt.__name__.__eq__
  args: ["scrypt"]
  expected: true

invariant hashlib_extra268.scrypt_class_eq:
  description: "hashlib.scrypt.__class__.__name__ == 'builtin_function_or_method' — scrypt is a C-level builtin from _hashlib"
  category: identity
  kind: python_call_eq
  function: scrypt.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
