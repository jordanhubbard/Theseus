spec: venv_extra
version: ">=3.9"
backend: python_module(venv)

docs: https://docs.python.org/3/library/venv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/venv.html — Python venv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/venv/__init__.py"
  notes:
    - "venv.EnvBuilder is the main class for creating virtual environments."
    - "venv.create is a convenience function that calls EnvBuilder.create()."
    - "EnvBuilder.__name__ == 'EnvBuilder' — class identity confirmed by __name__ attribute."
    - "EnvBuilder.__module__ == 'venv' — the class is defined in the venv module."
    - "create.__name__ == 'create' — the module-level function name."
    - "EnvBuilder is a regular Python class: type(EnvBuilder).__name__ == 'type'."
    - "create is a regular Python function: type(create).__name__ == 'function'."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# EnvBuilder class — name and module affiliation checks
# ---------------------------------------------------------------------------

invariant venv_extra.classes.EnvBuilder_name:
  description: "EnvBuilder.__name__ == 'EnvBuilder' — class name attribute confirms identity"
  category: classes
  kind: python_call_eq
  function: EnvBuilder.__name__.__eq__
  args: ["EnvBuilder"]
  expected: true

invariant venv_extra.module.EnvBuilder_module:
  description: "EnvBuilder.__module__ == 'venv' — the class is defined in the venv module"
  category: module
  kind: python_call_eq
  function: EnvBuilder.__module__.__eq__
  args: ["venv"]
  expected: true

invariant venv_extra.types.EnvBuilder_is_type:
  description: "type(EnvBuilder).__name__ == 'type' — EnvBuilder is a class object"
  category: types
  kind: python_call_eq
  function: EnvBuilder.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# create function — name and type checks
# ---------------------------------------------------------------------------

invariant venv_extra.functions.create_name:
  description: "create.__name__ == 'create' — module-level convenience function name"
  category: functions
  kind: python_call_eq
  function: create.__name__.__eq__
  args: ["create"]
  expected: true

invariant venv_extra.types.create_is_function:
  description: "type(create).__name__ == 'function' — create is a plain Python function"
  category: types
  kind: python_call_eq
  function: create.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder class hierarchy — inheritance checks
# ---------------------------------------------------------------------------

invariant venv_extra.classes.EnvBuilder_base_is_object:
  description: "EnvBuilder.__bases__[0].__name__ == 'object' — EnvBuilder inherits directly from object"
  category: classes
  kind: python_call_eq
  function: EnvBuilder.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder qualname — qualified name in the venv module namespace
# ---------------------------------------------------------------------------

invariant venv_extra.classes.EnvBuilder_qualname:
  description: "EnvBuilder.__qualname__ == 'EnvBuilder' — qualname matches simple class name (not nested)"
  category: classes
  kind: python_call_eq
  function: EnvBuilder.__qualname__.__eq__
  args: ["EnvBuilder"]
  expected: true

# ---------------------------------------------------------------------------
# create qualname — qualified name of the create function
# ---------------------------------------------------------------------------

invariant venv_extra.functions.create_qualname:
  description: "create.__qualname__ == 'create' — qualname matches function name (not nested)"
  category: functions
  kind: python_call_eq
  function: create.__qualname__.__eq__
  args: ["create"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder method presence — key methods exist as callable attributes
# ---------------------------------------------------------------------------

table venv_extra.methods.EnvBuilder_methods:
  kind: python_call_eq
  category: methods
  id_prefix: method

  columns: [id, function, args, expected]
  rows:
    - [setup_python_name,   EnvBuilder.setup_python.__name__.__eq__,   ["setup_python"],   true]
    - [setup_scripts_name,  EnvBuilder.setup_scripts.__name__.__eq__,  ["setup_scripts"],  true]
    - [post_setup_name,     EnvBuilder.post_setup.__name__.__eq__,     ["post_setup"],     true]
    - [create_name,         EnvBuilder.create.__name__.__eq__,         ["create"],         true]

# ---------------------------------------------------------------------------
# Module-level function table — function __name__ checks
# ---------------------------------------------------------------------------

table venv_extra.functions.module_functions:
  kind: python_call_eq
  category: functions
  id_prefix: fn

  columns: [id, function, args, expected]
  rows:
    - [create_name, create.__name__.__eq__, ["create"], true]
