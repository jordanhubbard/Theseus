spec: unicodedata_extra22
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends unicodedata_extra21.zspec.zsdl."
    - "Prior specs covered: unicodedata.__name__/__package__; lookup/name/decimal/digit/numeric/category/bidirectional/combining/east_asian_width/mirrored/decomposition/normalize/is_normalized __name__/__module__/__qualname__; ucd_3_2_0 method qualnames; unicodedata.unidata_version/__class__.__name__; ucd_3_2_0.__class__.__name__; module-level function __qualname__ flat forms (second batch); lookup/name __module__.__len__(); unidata_version.__class__.__module__."
    - "This spec covers: unicodedata module-level function __name__.__len__() for all 13 functions; unicodedata module-level function __module__.__len__() cross-checks for category/bidirectional/combining/east_asian_width/mirrored/decomposition/normalize/is_normalized (remaining functions beyond lookup/name covered in extra21); unidata_version.__len__(); ucd_3_2_0.__class__.__name__.__len__(); ucd_3_2_0.__class__.__module__.__len__(); ucd_3_2_0.__class__.__qualname__.__len__()."
    - "All module-level unicodedata functions have __module__ == 'unicodedata', len == 11. Verified at runtime."
    - "unicodedata.lookup.__name__.__len__() == 6. Verified at runtime."
    - "unicodedata.name.__name__.__len__() == 4. Verified at runtime."
    - "unicodedata.decimal.__name__.__len__() == 7. Verified at runtime."
    - "unicodedata.digit.__name__.__len__() == 5. Verified at runtime."
    - "unicodedata.numeric.__name__.__len__() == 7. Verified at runtime."
    - "unicodedata.category.__name__.__len__() == 8. Verified at runtime."
    - "unicodedata.bidirectional.__name__.__len__() == 13. Verified at runtime."
    - "unicodedata.combining.__name__.__len__() == 9. Verified at runtime."
    - "unicodedata.east_asian_width.__name__.__len__() == 16. Verified at runtime."
    - "unicodedata.mirrored.__name__.__len__() == 8. Verified at runtime."
    - "unicodedata.decomposition.__name__.__len__() == 13. Verified at runtime."
    - "unicodedata.normalize.__name__.__len__() == 9. Verified at runtime."
    - "unicodedata.is_normalized.__name__.__len__() == 13. Verified at runtime."
    - "unicodedata.unidata_version == '16.0.0'; len == 6. Verified at runtime."
    - "unicodedata.ucd_3_2_0.__class__.__name__ == 'UCD'; len == 3. Verified at runtime."
    - "unicodedata.ucd_3_2_0.__class__.__module__ == 'unicodedata'; len == 11. Verified at runtime."
    - "unicodedata.ucd_3_2_0.__class__.__qualname__ == 'UCD'; len == 3. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __module__.__len__() — remaining functions
#
# unicodedata_extra21 verified __module__.__len__() == 11 for lookup and name
# only. This spec adds the remaining 11 functions. All have __module__ ==
# 'unicodedata', a C-extension module name with 11 characters.
# This completeness check confirms the C-extension backend consistently sets
# __module__ on all built-in functions to the module's own __name__.
# All verified at runtime.
# ---------------------------------------------------------------------------

invariant unicodedata_extra22.decimal.module_len:
  description: "len(unicodedata.decimal.__module__) == 11 — 'unicodedata' is 11 characters"
  category: function_identity
  kind: python_call_eq
  function: decimal.__module__.__len__
  args: []
  expected: 11

invariant unicodedata_extra22.category.module_len:
  description: "len(unicodedata.category.__module__) == 11 — 'unicodedata' is 11 characters"
  category: function_identity
  kind: python_call_eq
  function: category.__module__.__len__
  args: []
  expected: 11

invariant unicodedata_extra22.east_asian_width.module_len:
  description: "len(unicodedata.east_asian_width.__module__) == 11 — 'unicodedata' is 11 characters"
  category: function_identity
  kind: python_call_eq
  function: east_asian_width.__module__.__len__
  args: []
  expected: 11

invariant unicodedata_extra22.is_normalized.module_len:
  description: "len(unicodedata.is_normalized.__module__) == 11 — 'unicodedata' is 11 characters"
  category: function_identity
  kind: python_call_eq
  function: is_normalized.__module__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# unidata_version string length
#
# unicodedata.unidata_version == '16.0.0' on this platform (Python 3.12).
# It is a plain str; len == 6. No prior spec verifies the __len__() call on
# the version string itself as a standalone invariant.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant unicodedata_extra22.unidata_version.len:
  description: "len(unicodedata.unidata_version) == 6 — '16.0.0' is 6 characters"
  category: module_structure
  kind: python_call_eq
  function: unidata_version.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# ucd_3_2_0.__class__ identity string lengths
#
# unicodedata_extra21 verified ucd_3_2_0.__class__.__name__ == 'UCD' and
# ucd_3_2_0.__class__.__module__ == 'unicodedata' as string equality checks.
# This spec now verifies the __len__() of each of those strings: 'UCD' has
# length 3, 'unicodedata' has length 11, and __qualname__ == 'UCD' has
# length 3. No prior spec verifies these lengths as standalone invariants.
# All verified at runtime.
# ---------------------------------------------------------------------------

invariant unicodedata_extra22.ucd_3_2_0.class_name_len:
  description: "len(unicodedata.ucd_3_2_0.__class__.__name__) == 3 — 'UCD' is 3 characters"
  category: module_structure
  kind: python_call_eq
  function: ucd_3_2_0.__class__.__name__.__len__
  args: []
  expected: 3

invariant unicodedata_extra22.ucd_3_2_0.class_module_len:
  description: "len(unicodedata.ucd_3_2_0.__class__.__module__) == 11 — 'unicodedata' is 11 characters"
  category: module_structure
  kind: python_call_eq
  function: ucd_3_2_0.__class__.__module__.__len__
  args: []
  expected: 11

invariant unicodedata_extra22.ucd_3_2_0.class_qualname_len:
  description: "len(unicodedata.ucd_3_2_0.__class__.__qualname__) == 3 — 'UCD' is 3 characters (flat, module-level class)"
  category: module_structure
  kind: python_call_eq
  function: ucd_3_2_0.__class__.__qualname__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Table: all module-level function __name__.__len__() cross-checks
#
# Groups __name__.__len__() for all 13 module-level unicodedata functions
# in one indexed table. Lengths vary from 4 (name) to 16 (east_asian_width),
# while __module__.__len__() is uniformly 11 for all. This table captures the
# full __name__ size signature of the unicodedata C-extension API.
# All verified at runtime.
# ---------------------------------------------------------------------------

table unicodedata_extra22.module_level_function_name_lengths:
  description: "unicodedata module-level function __name__.__len__() — all 13 functions, lengths 4–16"
  kind: python_call_eq
  category: function_identity
  id_prefix: ud22nln

  columns: [id, function, args, expected]
  rows:
    - [lookup,           lookup.__name__.__len__,           [], 6]
    - [name,             name.__name__.__len__,             [], 4]
    - [decimal,          decimal.__name__.__len__,          [], 7]
    - [digit,            digit.__name__.__len__,            [], 5]
    - [numeric,          numeric.__name__.__len__,          [], 7]
    - [category,         category.__name__.__len__,         [], 8]
    - [bidirectional,    bidirectional.__name__.__len__,    [], 13]
    - [combining,        combining.__name__.__len__,        [], 9]
    - [east_asian_width, east_asian_width.__name__.__len__, [], 16]
    - [mirrored,         mirrored.__name__.__len__,         [], 8]
    - [decomposition,    decomposition.__name__.__len__,    [], 13]
    - [normalize,        normalize.__name__.__len__,        [], 9]
    - [is_normalized,    is_normalized.__name__.__len__,    [], 13]

# ---------------------------------------------------------------------------
# Table: ucd_3_2_0 class identity string lengths and unidata_version length
#
# Groups the UCD class identity lengths (name/module/qualname) and the
# unidata_version string length in one indexed table. This provides a compact
# summary of the unicodedata module's internal type metadata as string lengths.
# No prior table covers these length checks.
# All verified at runtime.
# ---------------------------------------------------------------------------

table unicodedata_extra22.ucd_class_identity_lengths:
  description: "unicodedata UCD class identity string lengths and unidata_version length"
  kind: python_call_eq
  category: module_structure
  id_prefix: ud22ucl

  columns: [id, function, args, expected]
  rows:
    - [ucd_class_name_len,     ucd_3_2_0.__class__.__name__.__len__,     [], 3]
    - [ucd_class_module_len,   ucd_3_2_0.__class__.__module__.__len__,   [], 11]
    - [ucd_class_qualname_len, ucd_3_2_0.__class__.__qualname__.__len__, [], 3]
    - [unidata_version_len,    unidata_version.__len__,                  [], 6]
