spec: itertools_extra135
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.zip_longest, itertools.islice, itertools.repeat — C extension type identity, __module__, __mro__ len, __name__, and slot qualnames (Wave 263)."
    - "itertools.zip_longest.__class__.__name__ == 'type' — zip_longest is a C extension type. Verified with Python 3.14.3."
    - "itertools.zip_longest.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "len(itertools.zip_longest.__mro__) == 2 — MRO is [zip_longest, object]. Verified with Python 3.14.3."
    - "itertools.zip_longest.__name__ == 'zip_longest' (len 11). Verified with Python 3.14.3."
    - "itertools.zip_longest.__iter__.__qualname__ == 'zip_longest.__iter__' (len 20). Verified with Python 3.14.3."
    - "itertools.zip_longest.__next__.__qualname__ == 'zip_longest.__next__' (len 20). Verified with Python 3.14.3."
    - "itertools.islice.__class__.__name__ == 'type' — islice is a C extension type. Verified with Python 3.14.3."
    - "itertools.islice.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "len(itertools.islice.__mro__) == 2 — MRO is [islice, object]. Verified with Python 3.14.3."
    - "itertools.islice.__name__ == 'islice' (len 6). Verified with Python 3.14.3."
    - "itertools.islice.__iter__.__qualname__ == 'islice.__iter__' (len 15). Verified with Python 3.14.3."
    - "itertools.islice.__next__.__qualname__ == 'islice.__next__' (len 15). Verified with Python 3.14.3."
    - "itertools.repeat.__class__.__name__ == 'type' — repeat is a C extension type. Verified with Python 3.14.3."
    - "itertools.repeat.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "len(itertools.repeat.__mro__) == 2 — MRO is [repeat, object]. Verified with Python 3.14.3."
    - "itertools.repeat.__name__ == 'repeat' (len 6). Verified with Python 3.14.3."
    - "itertools.repeat.__iter__.__qualname__ == 'repeat.__iter__' (len 15). Verified with Python 3.14.3."
    - "itertools.repeat.__next__.__qualname__ == 'repeat.__next__' (len 15). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.zip_longest class identity, __module__, __name__, MRO, and slots
#
# Wave 263 theme: itertools.zip_longest C type identity and slot qualnames.
#
# itertools.zip_longest.__class__.__name__ == 'type'
# itertools.zip_longest.__module__ == 'itertools'
# itertools.zip_longest.__name__ == 'zip_longest' (len 11)
# len(itertools.zip_longest.__mro__) == 2
# itertools.zip_longest.__bases__[0].__name__ == 'object'
# itertools.zip_longest.__iter__.__qualname__ == 'zip_longest.__iter__' (len 20)
# itertools.zip_longest.__next__.__qualname__ == 'zip_longest.__next__' (len 20)
#
# zip_longest is a C extension type in itertoolsmodule.c. New to extra135.
# ---------------------------------------------------------------------------

table itertools_extra135.zip_longest_identity:
  description: "itertools.zip_longest C type identity: __class__.__name__=='type', __module__=='itertools', __name__ len 11, MRO len 2, slot qualnames len 20; wave 263; new to extra135"
