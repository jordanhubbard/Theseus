spec: warnings_extra13
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Modules/_warnings.c"
  notes:
    - "This spec extends warnings.zspec.zsdl through warnings_extra12.zspec.zsdl."
    - "Prior specs cover: __name__/__qualname__/__module__/__class__.__name__ for warn/warn_explicit/filterwarnings/simplefilter/resetwarnings/showwarning/formatwarning/catch_warnings/WarningMessage; __class__.__name__ for warning categories; filters/defaultaction/onceregistry type and value checks."
    - "This spec covers: filterwarnings/__class__.__name__, simplefilter/__class__.__name__, resetwarnings/__class__.__name__, showwarning/__class__.__name__ == 'function' (not yet recorded as standalone invariants for these four functions)."
    - "warnings.filterwarnings, simplefilter, resetwarnings, and showwarning are all pure-Python functions defined in Lib/warnings.py; their metaclass is the builtin 'function'."
    - "warnings.warn.__class__.__name__ and warnings.warn_explicit.__class__.__name__ are already covered in prior specs (both are 'builtin_function_or_method' from the C extension _warnings)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Public function __class__.__name__ — filterwarnings, simplefilter,
# resetwarnings, showwarning
#
# Prior specs record __name__, __qualname__, and __module__ for all four
# of these functions, and __class__.__name__ for warn and warn_explicit,
# but no prior spec records __class__.__name__ for filterwarnings,
# simplefilter, resetwarnings, or showwarning. All four are pure-Python
# functions, so __class__.__name__ == 'function'.
# ---------------------------------------------------------------------------

table warnings_extra13.public_function_class_names:
  description: "__class__.__name__ == 'function' for pure-Python public warnings functions"
  kind: python_call_eq
  category: function_class_names

  columns: [id, function, args, expected]
  rows:
    - [filterwarnings, filterwarnings.__class__.__name__.__eq__, ["function"], true]
    - [simplefilter,   simplefilter.__class__.__name__.__eq__,   ["function"], true]
    - [resetwarnings,  resetwarnings.__class__.__name__.__eq__,  ["function"], true]
    - [showwarning,    showwarning.__class__.__name__.__eq__,    ["function"], true]
