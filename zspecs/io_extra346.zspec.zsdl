spec: io_extra346
version: ">=3.2"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "io.__name__ == 'io' — the module name attribute."
    - "io.__package__ == '' — io is not a package; it is a plain module backed by the _io C extension."
    - "io.__spec__.name == 'io' — the ModuleSpec name matches the module name."
    - "io.__all__ is a list with 24 elements; verified with Python 3.14.3."
    - "io.__all__.__contains__('BytesIO') == True — BytesIO is in the public API."
    - "io.__all__.__contains__('StringIO') == True — StringIO is in the public API."
    - "io.__all__.__contains__('DEFAULT_BUFFER_SIZE') == True — DEFAULT_BUFFER_SIZE is in the public API."
    - "io.__doc__ is a str — the module has a docstring."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.__name__ — module identity
# ---------------------------------------------------------------------------

invariant io_extra346.module_name:
  description: "io.__name__ == 'io'"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__eq__
  args: ["io"]
  expected: true

# ---------------------------------------------------------------------------
# io.__package__ — not a package; package attribute is the empty string
# ---------------------------------------------------------------------------

invariant io_extra346.module_package:
  description: "io.__package__ == '' — io is a plain module, not a package"
  category: module_metadata
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# io.__spec__.name — ModuleSpec name
# ---------------------------------------------------------------------------

invariant io_extra346.spec_name:
  description: "io.__spec__.name == 'io'"
  category: module_metadata
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["io"]
  expected: true

# ---------------------------------------------------------------------------
# io.__all__ — class and length
# ---------------------------------------------------------------------------

invariant io_extra346.all_is_list:
  description: "io.__all__.__class__.__name__ == 'list'"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant io_extra346.all_len:
  description: "len(io.__all__) == 24"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 24

# ---------------------------------------------------------------------------
# io.__all__ membership — selected public names
# ---------------------------------------------------------------------------

invariant io_extra346.all_contains_BytesIO:
  description: "io.__all__.__contains__('BytesIO') == True"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__contains__
  args: ["BytesIO"]
  expected: true

invariant io_extra346.all_contains_StringIO:
  description: "io.__all__.__contains__('StringIO') == True"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__contains__
  args: ["StringIO"]
  expected: true

invariant io_extra346.all_contains_DEFAULT_BUFFER_SIZE:
  description: "io.__all__.__contains__('DEFAULT_BUFFER_SIZE') == True"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__contains__
  args: ["DEFAULT_BUFFER_SIZE"]
  expected: true

# ---------------------------------------------------------------------------
# io.__doc__ — module has a docstring (type check)
# ---------------------------------------------------------------------------

invariant io_extra346.doc_is_str:
  description: "io.__doc__.__class__.__name__ == 'str'"
  category: module_metadata
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
