spec: decimal_extra106
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra105.zspec.zsdl."
    - "This spec covers: decimal.Decimal copy methods (copy_abs, copy_negate, copy_sign) and unary arithmetic dunder methods (__round__, __ceil__, __floor__, __trunc__)."
    - "All these methods have type 'method_descriptor' (C extension tp_methods entries on Decimal)."
    - "decimal.Decimal.copy_abs.__qualname__ == 'Decimal.copy_abs' (len 16)."
    - "decimal.Decimal.copy_negate.__qualname__ == 'Decimal.copy_negate' (len 19; longest copy method qualname)."
    - "decimal.Decimal.copy_sign.__qualname__ == 'Decimal.copy_sign' (len 17)."
    - "decimal.Decimal.__round__.__qualname__ == 'Decimal.__round__' (len 17)."
    - "decimal.Decimal.__ceil__.__qualname__ == 'Decimal.__ceil__' (len 16)."
    - "decimal.Decimal.__floor__.__qualname__ == 'Decimal.__floor__' (len 17)."
    - "decimal.Decimal.__trunc__.__qualname__ == 'Decimal.__trunc__' (len 17)."
    - "copy_sign/__round__/__ceil__/__floor__/__trunc__ all have len 16 or 17."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.copy_abs, copy_negate, copy_sign qualnames and types
# All three are 'method_descriptor' (C extension tp_methods entries).
# copy_abs: 'Decimal.copy_abs' (16 chars).
# copy_negate: 'Decimal.copy_negate' (19 chars; longest copy method qualname).
# copy_sign: 'Decimal.copy_sign' (17 chars).
# ---------------------------------------------------------------------------

table decimal_extra106.Decimal_copy_abs_negate_sign_qualnames:
  description: "decimal.Decimal copy_abs/copy_negate/copy_sign: type='method_descriptor'; copy_abs='Decimal.copy_abs'(16), copy_negate='Decimal.copy_negate'(19), copy_sign='Decimal.copy_sign'(17)"
  kind: python_call_eq
  category: qualnames
  id_prefix: deccopy106a

  columns: [id, function, args, expected, description]
  rows:
    - [copy_abs_type,        "Decimal.copy_abs.__class__.__name__.__eq__",     ["method_descriptor"],    true,  "type(decimal.Decimal.copy_abs).__name__ == 'method_descriptor' (C extension method in tp_methods)"]
    - [copy_abs_qn_eq,       "Decimal.copy_abs.__qualname__.__eq__",           ["Decimal.copy_abs"],     true,  "decimal.Decimal.copy_abs.__qualname__ == 'Decimal.copy_abs' (returns copy with absolute value)"]
    - [copy_abs_qn_len,      "Decimal.copy_abs.__qualname__.__len__",          [],                       16,    "decimal.Decimal.copy_abs.__qualname__.__len__() == 16 ('Decimal.copy_abs' has 16 chars)"]
    - [copy_negate_type,     "Decimal.copy_negate.__class__.__name__.__eq__",  ["method_descriptor"],    true,  "type(decimal.Decimal.copy_negate).__name__ == 'method_descriptor'"]
    - [copy_negate_qn_eq,    "Decimal.copy_negate.__qualname__.__eq__",        ["Decimal.copy_negate"],  true,  "decimal.Decimal.copy_negate.__qualname__ == 'Decimal.copy_negate' (returns copy with negated sign)"]
    - [copy_negate_qn_len,   "Decimal.copy_negate.__qualname__.__len__",       [],                       19,    "decimal.Decimal.copy_negate.__qualname__.__len__() == 19 ('Decimal.copy_negate' has 19 chars; longest copy method qualname)"]
    - [copy_sign_type,       "Decimal.copy_sign.__class__.__name__.__eq__",    ["method_descriptor"],    true,  "type(decimal.Decimal.copy_sign).__name__ == 'method_descriptor'"]
    - [copy_sign_qn_eq,      "Decimal.copy_sign.__qualname__.__eq__",          ["Decimal.copy_sign"],    true,  "decimal.Decimal.copy_sign.__qualname__ == 'Decimal.copy_sign' (returns copy with sign of another Decimal)"]
    - [copy_sign_qn_len,     "Decimal.copy_sign.__qualname__.__len__",         [],                       17,    "decimal.Decimal.copy_sign.__qualname__.__len__() == 17 ('Decimal.copy_sign' has 17 chars)"]
    - [copy_negate_gt_sign,  "Decimal.copy_negate.__qualname__.__len__.__gt__", [17],                    true,  "len('Decimal.copy_negate') > len('Decimal.copy_sign') (19 > 17; copy_negate is the longest copy method qualname)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.__round__ and __ceil__ qualnames and types
# Both are 'method_descriptor' (C extension tp_methods entries).
# __round__: 'Decimal.__round__' (17 chars).
# __ceil__: 'Decimal.__ceil__' (16 chars).
# These support the built-in round() and math.ceil() functions.
# ---------------------------------------------------------------------------

table decimal_extra106.Decimal_round_ceil_qualnames:
  description: "decimal.Decimal __round__/__ceil__: type='method_descriptor'; __round__='Decimal.__round__'(17), __ceil__='Decimal.__ceil__'(16)"
  kind: python_call_eq
  category: qualnames
  id_prefix: deccopy106b

  columns: [id, function, args, expected, description]
  rows:
    - [round_type,        "Decimal.__round__.__class__.__name__.__eq__",   ["method_descriptor"],   true,  "type(decimal.Decimal.__round__).__name__ == 'method_descriptor' (C extension method supporting round())"]
    - [round_qn_eq,       "Decimal.__round__.__qualname__.__eq__",         ["Decimal.__round__"],   true,  "decimal.Decimal.__round__.__qualname__ == 'Decimal.__round__' (called by built-in round(); takes optional ndigits)"]
    - [round_qn_len,      "Decimal.__round__.__qualname__.__len__",        [],                      17,    "decimal.Decimal.__round__.__qualname__.__len__() == 17 ('Decimal.__round__' has 17 chars)"]
    - [ceil_type,         "Decimal.__ceil__.__class__.__name__.__eq__",    ["method_descriptor"],   true,  "type(decimal.Decimal.__ceil__).__name__ == 'method_descriptor' (C extension method supporting math.ceil())"]
    - [ceil_qn_eq,        "Decimal.__ceil__.__qualname__.__eq__",          ["Decimal.__ceil__"],    true,  "decimal.Decimal.__ceil__.__qualname__ == 'Decimal.__ceil__' (called by math.ceil(); rounds toward positive infinity)"]
    - [ceil_qn_len,       "Decimal.__ceil__.__qualname__.__len__",         [],                      16,    "decimal.Decimal.__ceil__.__qualname__.__len__() == 16 ('Decimal.__ceil__' has 16 chars)"]
    - [round_gt_ceil,     "Decimal.__round__.__qualname__.__len__.__gt__", [16],                    true,  "len('Decimal.__round__') > len('Decimal.__ceil__') (17 > 16; __round__ has one extra char from the 'round' vs 'ceil' name difference)"]
    - [round_ne_ceil,     "Decimal.__round__.__qualname__.__eq__",         ["Decimal.__ceil__"],    false, "decimal.Decimal.__round__.__qualname__ != 'Decimal.__ceil__' (distinct dunder methods with different names and lengths)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.__floor__ and __trunc__ qualnames and types
# Both are 'method_descriptor' (C extension tp_methods entries).
# __floor__: 'Decimal.__floor__' (17 chars; same length as __round__).
# __trunc__: 'Decimal.__trunc__' (17 chars; same length as __round__ and __floor__).
# ---------------------------------------------------------------------------

table decimal_extra106.Decimal_floor_trunc_qualnames:
  description: "decimal.Decimal __floor__/__trunc__: type='method_descriptor'; __floor__='Decimal.__floor__'(17), __trunc__='Decimal.__trunc__'(17); both share length 17 with __round__"
  kind: python_call_eq
  category: qualnames
  id_prefix: deccopy106c

  columns: [id, function, args, expected, description]
  rows:
    - [floor_type,        "Decimal.__floor__.__class__.__name__.__eq__",   ["method_descriptor"],   true,  "type(decimal.Decimal.__floor__).__name__ == 'method_descriptor' (C extension method supporting math.floor())"]
    - [floor_qn_eq,       "Decimal.__floor__.__qualname__.__eq__",         ["Decimal.__floor__"],   true,  "decimal.Decimal.__floor__.__qualname__ == 'Decimal.__floor__' (called by math.floor(); rounds toward negative infinity)"]
    - [floor_qn_len,      "Decimal.__floor__.__qualname__.__len__",        [],                      17,    "decimal.Decimal.__floor__.__qualname__.__len__() == 17 ('Decimal.__floor__' has 17 chars; same length as __round__)"]
    - [trunc_type,        "Decimal.__trunc__.__class__.__name__.__eq__",   ["method_descriptor"],   true,  "type(decimal.Decimal.__trunc__).__name__ == 'method_descriptor' (C extension method supporting math.trunc())"]
    - [trunc_qn_eq,       "Decimal.__trunc__.__qualname__.__eq__",         ["Decimal.__trunc__"],   true,  "decimal.Decimal.__trunc__.__qualname__ == 'Decimal.__trunc__' (called by math.trunc(); rounds toward zero)"]
    - [trunc_qn_len,      "Decimal.__trunc__.__qualname__.__len__",        [],                      17,    "decimal.Decimal.__trunc__.__qualname__.__len__() == 17 ('Decimal.__trunc__' has 17 chars; same length as __round__ and __floor__)"]
    - [floor_eq_trunc_len, "Decimal.__floor__.__qualname__.__len__.__eq__", [17],                   true,  "len('Decimal.__floor__') == len('Decimal.__trunc__') == 17 (floor and trunc share identical qualname length)"]
    - [ceil_lt_floor,     "Decimal.__ceil__.__qualname__.__len__.__lt__",  [17],                    true,  "len('Decimal.__ceil__') < len('Decimal.__floor__') (16 < 17; __ceil__ is the shortest dunder method qualname at 16 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra106.Decimal.copy_abs_qualname:
  description: "decimal.Decimal.copy_abs.__qualname__ == 'Decimal.copy_abs' (length 16; type is 'method_descriptor'; 'Decimal.' (8) + 'copy_abs' (8) == 16; copy_abs returns a copy of the operand with the sign set to 0 — equivalent to abs() but without using the context)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.copy_abs.__qualname__.__eq__"
  args: ["Decimal.copy_abs"]
  expected: true

invariant decimal_extra106.Decimal.copy_negate_qualname_len:
  description: "decimal.Decimal.copy_negate.__qualname__.__len__() == 19 ('Decimal.copy_negate' has 19 characters; it is the longest qualname among the copy and unary arithmetic methods examined; 'Decimal.' (8) + 'copy_negate' (11) == 19; copy_negate returns a copy with the sign flipped)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.copy_negate.__qualname__.__len__"
  args: []
  expected: 19

invariant decimal_extra106.Decimal.__round___qualname_len:
  description: "decimal.Decimal.__round__.__qualname__.__len__() == 17 ('Decimal.__round__' has 17 characters; type is 'method_descriptor'; 'Decimal.' (8) + '__round__' (9) == 17; __round__ is called by the built-in round() function; same length as __floor__ and __trunc__)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__round__.__qualname__.__len__"
  args: []
  expected: 17

invariant decimal_extra106.Decimal.__ceil___qualname_len:
  description: "decimal.Decimal.__ceil__.__qualname__.__len__() == 16 ('Decimal.__ceil__' has 16 characters; it is the shortest dunder method qualname among the unary arithmetic methods examined — __round__(17)/__ceil__(16)/__floor__(17)/__trunc__(17); 'Decimal.' (8) + '__ceil__' (8) == 16)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__ceil__.__qualname__.__len__"
  args: []
  expected: 16

invariant decimal_extra106.Decimal.__trunc___type_method_descriptor:
  description: "type(decimal.Decimal.__trunc__).__name__ == 'method_descriptor' (all Decimal copy and unary arithmetic methods — copy_abs, copy_negate, copy_sign, __round__, __ceil__, __floor__, __trunc__ — are C extension method_descriptor objects when accessed on the class)"
  category: class_names
  kind: python_call_eq
  function: "Decimal.__trunc__.__class__.__name__.__eq__"
  args: ["method_descriptor"]
  expected: true
