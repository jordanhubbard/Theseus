spec: itertools_extra168
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.filterfalse.__name__ 'filterfalse'; itertools.filterfalse.__module__ 'itertools'; itertools.pairwise.__name__ 'pairwise' (added in Python 3.10); itertools.pairwise.__module__ 'itertools'; itertools.batched.__name__ 'batched' (added in Python 3.12, present in 3.14); itertools.batched.__module__ 'itertools'; itertools.count.__name__ 'count'; itertools.count.__module__ 'itertools' (Wave 297)."
    - "itertools.filterfalse.__name__ == 'filterfalse' — itertools.filterfalse is a C extension type in itertoolsmodule.c that makes an iterator returning elements of an iterable for which a predicate is False; its type __name__ is 'filterfalse'. Verified with Python 3.14.3."
    - "itertools.filterfalse.__module__ == 'itertools' — filterfalse is declared in the itertools C extension module; its __module__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "itertools.pairwise.__name__ == 'pairwise' — itertools.pairwise is a C extension type added in Python 3.10 in itertoolsmodule.c; it returns successive overlapping pairs taken from an iterable; its type __name__ is 'pairwise'. Verified with Python 3.14.3."
    - "itertools.pairwise.__module__ == 'itertools' — pairwise is declared in the itertools C extension module; its __module__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "itertools.batched.__name__ == 'batched' — itertools.batched is a C extension type added in Python 3.12 in itertoolsmodule.c; it batches elements of an iterable into tuples of at most n items; its type __name__ is 'batched'. Present and verified in Python 3.14.3."
    - "itertools.batched.__module__ == 'itertools' — batched is declared in the itertools C extension module; its __module__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "itertools.count.__name__ == 'count' — itertools.count is a C extension type in itertoolsmodule.c that makes an iterator returning evenly spaced values starting from a number; its type __name__ is 'count'. Verified with Python 3.14.3."
    - "itertools.count.__module__ == 'itertools' — count is declared in the itertools C extension module; its __module__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.filterfalse C extension type identity
#
# Wave 297 theme: itertools.filterfalse C extension type — __name__, __module__,
# __bases__[0], and __class__.__name__.
#
# itertools.filterfalse.__name__ == 'filterfalse'
# itertools.filterfalse.__module__ == 'itertools'
# itertools.filterfalse.__bases__[0].__name__ == 'object'
# itertools.filterfalse.__class__.__name__ == 'type'
#
# itertools.filterfalse(predicate, iterable) makes an iterator returning elements
# of the iterable for which the predicate is False. If predicate is None, returns
# elements that are false. It is the complement of the built-in filter() function
# (which returns elements for which predicate is True). It is a C extension type
# in itertoolsmodule.c that inherits directly from object. New to extra168.
# ---------------------------------------------------------------------------

table itertools_extra168.filterfalse_identity:
  description: "itertools.filterfalse: __name__ 'filterfalse', __module__ 'itertools', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 297; new to extra168"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsffi168

  columns: [id, function, args, expected, description]
  rows:
    - [ff_name_filterfalse,
       "filterfalse.__name__.__eq__",
       ["filterfalse"],
       true,
       "itertools.filterfalse.__name__.__eq__('filterfalse') == True — filterfalse is a C extension type in itertoolsmodule.c that returns elements of an iterable for which a predicate is False (the complement of the built-in filter()); its type __name__ attribute is 'filterfalse'; str.__eq__('filterfalse') returns True; new to extra168"]
    - [ff_module_itertools,
       "filterfalse.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.filterfalse.__module__.__eq__('itertools') == True — filterfalse is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra168"]
    - ["ff_bases_0_object",
       "filterfalse.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.filterfalse.__bases__[0].__name__.__eq__('object') == True — filterfalse is a C extension type that returns elements for which a predicate is False; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra168"]
    - [ff_class_name_type,
       "filterfalse.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.filterfalse.__class__.__name__.__eq__('type') == True — filterfalse is a class object (C extension type); its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra168"]

# ---------------------------------------------------------------------------
# Table 2: itertools.pairwise C extension type identity (added in Python 3.10)
#
# Wave 297 theme: itertools.pairwise C extension type — __name__, __module__,
# __bases__[0], and __class__.__name__.
#
# itertools.pairwise.__name__ == 'pairwise'
# itertools.pairwise.__module__ == 'itertools'
# itertools.pairwise.__bases__[0].__name__ == 'object'
# itertools.pairwise.__class__.__name__ == 'type'
#
# itertools.pairwise(iterable) — added in Python 3.10 — returns successive
# overlapping pairs taken from the iterable. The number of 2-tuples produced
# is one fewer than the number of inputs. For example,
# pairwise('ABCDE') yields AB, BC, CD, DE. It is a C extension type in
# itertoolsmodule.c that inherits directly from object. New to extra168.
# ---------------------------------------------------------------------------

table itertools_extra168.pairwise_identity:
  description: "itertools.pairwise: __name__ 'pairwise', __module__ 'itertools', __bases__[0].__name__ 'object', __class__.__name__ 'type'; added in 3.10; wave 297; new to extra168"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolspwi168

  columns: [id, function, args, expected, description]
  rows:
    - [pw_name_pairwise,
       "pairwise.__name__.__eq__",
       ["pairwise"],
       true,
       "itertools.pairwise.__name__.__eq__('pairwise') == True — pairwise is a C extension type added in Python 3.10 in itertoolsmodule.c that returns successive overlapping pairs from an iterable; its type __name__ attribute is 'pairwise'; str.__eq__('pairwise') returns True; new to extra168"]
    - [pw_module_itertools,
       "pairwise.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.pairwise.__module__.__eq__('itertools') == True — pairwise is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra168"]
    - ["pw_bases_0_object",
       "pairwise.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.pairwise.__bases__[0].__name__.__eq__('object') == True — pairwise is a C extension type (added in Python 3.10) that yields successive overlapping pairs from an iterable; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra168"]
    - [pw_class_name_type,
       "pairwise.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.pairwise.__class__.__name__.__eq__('type') == True — pairwise is a class object (C extension type); its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra168"]

# ---------------------------------------------------------------------------
# Table 3: itertools.batched C extension type identity (added in Python 3.12)
#
# Wave 297 theme: itertools.batched C extension type — __name__, __module__,
# __bases__[0], and __class__.__name__.
#
# itertools.batched.__name__ == 'batched'
# itertools.batched.__module__ == 'itertools'
# itertools.batched.__bases__[0].__name__ == 'object'
# itertools.batched.__class__.__name__ == 'type'
#
# itertools.batched(iterable, n) — added in Python 3.12, present in 3.14 —
# batches the elements of an iterable into tuples of at most n items. The last
# batch may be shorter than n. For example, batched('ABCDE', 2) yields
# ('A','B'), ('C','D'), ('E',). It is a C extension type in itertoolsmodule.c
# that inherits directly from object. New to extra168.
# ---------------------------------------------------------------------------

table itertools_extra168.batched_identity:
  description: "itertools.batched: __name__ 'batched', __module__ 'itertools', __bases__[0].__name__ 'object', __class__.__name__ 'type'; added in 3.12, in 3.14; wave 297; new to extra168"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsbi168

  columns: [id, function, args, expected, description]
  rows:
    - [batched_name_batched,
       "batched.__name__.__eq__",
       ["batched"],
       true,
       "itertools.batched.__name__.__eq__('batched') == True — batched is a C extension type added in Python 3.12 in itertoolsmodule.c that batches iterable elements into tuples of at most n items; present and verified in Python 3.14.3; its type __name__ attribute is 'batched'; str.__eq__('batched') returns True; new to extra168"]
    - [batched_module_itertools,
       "batched.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.batched.__module__.__eq__('itertools') == True — batched is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra168"]
    - ["batched_bases_0_object",
       "batched.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.batched.__bases__[0].__name__.__eq__('object') == True — batched is a C extension type (added in Python 3.12) that batches iterable elements into fixed-size chunks; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra168"]
    - [batched_class_name_type,
       "batched.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.batched.__class__.__name__.__eq__('type') == True — batched is a class object (C extension type); its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra168"]

# ---------------------------------------------------------------------------
# Table 4: itertools.count C extension type identity
#
# Wave 297 theme: itertools.count C extension type — __name__, __module__,
# __bases__[0], and __class__.__name__.
#
# itertools.count.__name__ == 'count'
# itertools.count.__module__ == 'itertools'
# itertools.count.__bases__[0].__name__ == 'object'
# itertools.count.__class__.__name__ == 'type'
#
# itertools.count(start=0, step=1) makes an iterator returning evenly spaced
# values starting with start. Counts forever by default. Equivalent to:
# (start + step * i for i in range(maxsize ** 10)). It is a C extension type
# in itertoolsmodule.c that inherits directly from object. New to extra168.
# ---------------------------------------------------------------------------

table itertools_extra168.count_identity:
  description: "itertools.count: __name__ 'count', __module__ 'itertools', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 297; new to extra168"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscoi168

  columns: [id, function, args, expected, description]
  rows:
    - [count_name_count,
       "count.__name__.__eq__",
       ["count"],
       true,
       "itertools.count.__name__.__eq__('count') == True — count is a C extension type in itertoolsmodule.c that makes an iterator returning evenly spaced values starting from a given number (default start=0, step=1); its type __name__ attribute is 'count'; str.__eq__('count') returns True; new to extra168"]
    - [count_module_itertools,
       "count.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.count.__module__.__eq__('itertools') == True — count is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra168"]
    - ["count_bases_0_object",
       "count.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.count.__bases__[0].__name__.__eq__('object') == True — count is a C extension type that makes an infinite iterator of evenly spaced values; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra168"]
    - [count_class_name_type,
       "count.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.count.__class__.__name__.__eq__('type') == True — count is a class object (C extension type); its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra168"]

# ---------------------------------------------------------------------------
# Table 5: Cross-checks — filterfalse, pairwise, batched, count are distinct
#
# Wave 297 theme: cross-checks between the four new C extension types to confirm
# distinct __name__ values and that none shares a name with another.
#
# itertools.filterfalse.__name__ != 'pairwise'
# itertools.pairwise.__name__ != 'batched'
# itertools.batched.__name__ != 'count'
# itertools.count.__module__ != 'builtins'
#   (count is in itertools, not builtins)
#
# All four (filterfalse, pairwise, batched, count) are distinct C extension
# types in itertoolsmodule.c with different __name__ values. They all share
# __module__ 'itertools' and __bases__[0].__name__ 'object'. New to extra168.
# ---------------------------------------------------------------------------

table itertools_extra168.new_types_cross_checks:
  description: "itertools: filterfalse.__name__ != 'pairwise', pairwise.__name__ != 'batched', batched.__name__ != 'count', count.__module__ != 'builtins'; wave 297; new to extra168"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsntcc168

  columns: [id, function, args, expected, description]
  rows:
    - [ff_name_ne_pairwise,
       "filterfalse.__name__.__eq__",
       ["pairwise"],
       false,
       "itertools.filterfalse.__name__.__eq__('pairwise') == False — filterfalse.__name__ is 'filterfalse', not 'pairwise'; they are distinct C extension iterator types in itertoolsmodule.c; str.__eq__('pairwise') returns False; new to extra168"]
    - [pw_name_ne_batched,
       "pairwise.__name__.__eq__",
       ["batched"],
       false,
       "itertools.pairwise.__name__.__eq__('batched') == False — pairwise.__name__ is 'pairwise', not 'batched'; pairwise (added in 3.10) produces overlapping pairs while batched (added in 3.12) produces fixed-size chunks; they are distinct types; str.__eq__('batched') returns False; new to extra168"]
    - [batched_name_ne_count,
       "batched.__name__.__eq__",
       ["count"],
       false,
       "itertools.batched.__name__.__eq__('count') == False — batched.__name__ is 'batched', not 'count'; batched groups elements into fixed-size tuples while count generates an infinite sequence of evenly spaced values; they are distinct types; str.__eq__('count') returns False; new to extra168"]
    - [count_module_not_builtins,
       "count.__module__.__eq__",
       ["builtins"],
       false,
       "itertools.count.__module__.__eq__('builtins') == False — itertools.count is declared in the itertools C extension module, not in builtins; its __module__ is 'itertools', not 'builtins'; str.__eq__('builtins') returns False; new to extra168"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra168
# ---------------------------------------------------------------------------

invariant itertools_extra168.filterfalse_name_filterfalse:
  description: "itertools.filterfalse.__name__ == 'filterfalse' — C extension type returning elements for which predicate is False; complement of built-in filter(); wave 297; new to extra168"
  kind: python_call_eq
  function: filterfalse.__name__.__eq__
  args: ["filterfalse"]
  expected: true

invariant itertools_extra168.filterfalse_module_itertools:
  description: "itertools.filterfalse.__module__ == 'itertools' — filterfalse is declared in itertoolsmodule.c; wave 297; new to extra168"
  kind: python_call_eq
  function: filterfalse.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra168.pairwise_name_pairwise:
  description: "itertools.pairwise.__name__ == 'pairwise' — C extension type (added in 3.10) returning successive overlapping pairs from an iterable; wave 297; new to extra168"
  kind: python_call_eq
  function: pairwise.__name__.__eq__
  args: ["pairwise"]
  expected: true

invariant itertools_extra168.pairwise_module_itertools:
  description: "itertools.pairwise.__module__ == 'itertools' — pairwise is declared in itertoolsmodule.c; wave 297; new to extra168"
  kind: python_call_eq
  function: pairwise.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra168.batched_name_batched:
  description: "itertools.batched.__name__ == 'batched' — C extension type (added in 3.12, in 3.14) batching iterable elements into fixed-size tuples; wave 297; new to extra168"
  kind: python_call_eq
  function: batched.__name__.__eq__
  args: ["batched"]
  expected: true

invariant itertools_extra168.batched_module_itertools:
  description: "itertools.batched.__module__ == 'itertools' — batched is declared in itertoolsmodule.c; wave 297; new to extra168"
  kind: python_call_eq
  function: batched.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra168.count_name_count:
  description: "itertools.count.__name__ == 'count' — C extension type making an infinite iterator of evenly spaced values; wave 297; new to extra168"
  kind: python_call_eq
  function: count.__name__.__eq__
  args: ["count"]
  expected: true

invariant itertools_extra168.count_module_itertools:
  description: "itertools.count.__module__ == 'itertools' — count is declared in itertoolsmodule.c; wave 297; new to extra168"
  kind: python_call_eq
  function: count.__module__.__eq__
  args: ["itertools"]
  expected: true
