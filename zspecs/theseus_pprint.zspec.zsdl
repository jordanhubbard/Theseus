spec: theseus_pprint
version: ">=3.9"
backend: python_cleanroom(theseus_pprint)
blocks: pprint

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html"
  notes:
    - "Clean-room pretty-printer for Python data structures. Do NOT import pprint."
    - "pformat(obj, width=80) returns string representation, one item per line for long sequences."
    - "pformat({'a': 1}) == \"{'a': 1}\"."
    - "pformat([1,2,3]) == '[1, 2, 3]'."
    - "Nested dicts/lists are indented when they exceed width."
    - "Export: pformat(obj, indent=1, width=80, depth=None) -> str, pprint(obj) -> None."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_pprint.format_dict:
  description: "pformat({'a': 1}) == \"{'a': 1}\""
  category: format
  kind: python_call_eq
  function: pprint_format_dict
  args: []
  expected: "{'a': 1}"

invariant theseus_pprint.format_list:
  description: "pformat([1, 2, 3]) == '[1, 2, 3]'"
  category: format
  kind: python_call_eq
  function: pprint_format_list
  args: []
  expected: "[1, 2, 3]"

invariant theseus_pprint.format_string:
  description: "pformat('hello') == \"'hello'\""
  category: format
  kind: python_call_eq
  function: pprint_format_string
  args: []
  expected: "'hello'"
