spec: hashlib_extra214
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "This spec extends hashlib_extra213.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "hashlib.new.__qualname__ == '__hash_new' (internal name differs from public attribute name)."
    - "hashlib.file_digest.__qualname__ == 'file_digest' (qualname matches public name)."
    - "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac' (C extension function in _hashlib)."
    - "hashlib.md5.__qualname__ == 'openssl_md5' (OpenSSL backend function; qualname reveals implementation)."
    - "hashlib.sha256.__qualname__ == 'openssl_sha256'; hashlib.sha512.__qualname__ == 'openssl_sha512'."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib' (defined in the C extension module)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "hashlib raises ValueError for unknown algorithm names. __qualname__ attribute accesses do not raise."
  stderr: "null"
  stickiness: "N/A — qualname attributes are read-only and immutable."
  codes: {}

# ---------------------------------------------------------------------------
# hashlib.new and hashlib.file_digest — __qualname__ checks
#
# hashlib.new.__qualname__ == '__hash_new'
# hashlib.file_digest.__qualname__ == 'file_digest'
# ---------------------------------------------------------------------------

table hashlib_extra214.new_and_file_digest_qualnames:
  description: "hashlib.new and hashlib.file_digest __qualname__ equality checks in hashlibqualname214 namespace — wave 258 theme: hashlib.new.__qualname__=='__hash_new' (public name 'new' but internal name '__hash_new'); hashlib.file_digest.__qualname__=='file_digest' (qualname matches public attribute name); hashlib.new.__module__=='hashlib'; hashlib.file_digest.__module__=='hashlib'; both are module-level functions defined in Lib/hashlib.py; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibqualname214

  columns: [id, function, args, expected, description]
  rows:
    - [new_qualname_eq,          hashlib.new.__qualname__.__eq__,           ["__hash_new"],  true, "hashlib.new.__qualname__ == '__hash_new'; internal CPython alias name; verified with Python 3.14.3"]
    - [file_digest_qualname_eq,  hashlib.file_digest.__qualname__.__eq__,   ["file_digest"], true, "hashlib.file_digest.__qualname__ == 'file_digest'; qualname matches public name; verified with Python 3.14.3"]
    - [new_module_eq,            hashlib.new.__module__.__eq__,             ["hashlib"],     true, "hashlib.new.__module__ == 'hashlib'; defined in Lib/hashlib.py; verified with Python 3.14.3"]
    - [file_digest_module_eq,    hashlib.file_digest.__module__.__eq__,     ["hashlib"],     true, "hashlib.file_digest.__module__ == 'hashlib'; defined in Lib/hashlib.py; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac — __qualname__ and __module__ checks
#
# hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac'
# hashlib.pbkdf2_hmac.__module__ == '_hashlib'
# ---------------------------------------------------------------------------

table hashlib_extra214.pbkdf2_hmac_qualname:
  description: "hashlib.pbkdf2_hmac __qualname__ and __module__ checks in hashlibqualname214a namespace — wave 258 theme: hashlib.pbkdf2_hmac.__qualname__=='pbkdf2_hmac'; hashlib.pbkdf2_hmac.__module__=='_hashlib' (C extension module, not Lib/hashlib.py); pbkdf2_hmac is a C builtin that computes password-based key derivation using HMAC; its qualname matches the public attribute name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibqualname214a

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_qualname_eq,    hashlib.pbkdf2_hmac.__qualname__.__eq__,  ["pbkdf2_hmac"], true, "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac'; C builtin qualname matches public name; verified with Python 3.14.3"]
    - [pbkdf2_module_eq,      hashlib.pbkdf2_hmac.__module__.__eq__,    ["_hashlib"],    true, "hashlib.pbkdf2_hmac.__module__ == '_hashlib'; defined in C extension _hashlib; verified with Python 3.14.3"]
    - [pbkdf2_qualname_ne_new, hashlib.pbkdf2_hmac.__qualname__.__eq__, ["__hash_new"],  false, "hashlib.pbkdf2_hmac.__qualname__ != '__hash_new'; pbkdf2_hmac is not hashlib.new; verified with Python 3.14.3"]
    - [pbkdf2_qualname_ne_fd,  hashlib.pbkdf2_hmac.__qualname__.__eq__, ["file_digest"], false, "hashlib.pbkdf2_hmac.__qualname__ != 'file_digest'; distinct C builtin; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.md5, hashlib.sha256, hashlib.sha512 — __qualname__ checks
#
# hashlib.md5.__qualname__ == 'openssl_md5'
# hashlib.sha256.__qualname__ == 'openssl_sha256'
# hashlib.sha512.__qualname__ == 'openssl_sha512'
# ---------------------------------------------------------------------------

table hashlib_extra214.openssl_hash_qualnames:
  description: "hashlib.md5, hashlib.sha256, hashlib.sha512 __qualname__ checks in hashlibqualname214b namespace — wave 258 theme: hashlib.md5.__qualname__=='openssl_md5' (OpenSSL backend name revealed by qualname); hashlib.sha256.__qualname__=='openssl_sha256'; hashlib.sha512.__qualname__=='openssl_sha512'; these are OpenSSL-backed constructors exposed at module level; the 'openssl_' prefix in the qualname reveals the backend implementation detail; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibqualname214b

  columns: [id, function, args, expected, description]
  rows:
    - [md5_qualname_eq,    hashlib.md5.__qualname__.__eq__,    ["openssl_md5"],    true, "hashlib.md5.__qualname__ == 'openssl_md5'; OpenSSL backend name; verified with Python 3.14.3"]
    - [sha256_qualname_eq, hashlib.sha256.__qualname__.__eq__, ["openssl_sha256"], true, "hashlib.sha256.__qualname__ == 'openssl_sha256'; OpenSSL backend name; verified with Python 3.14.3"]
    - [sha512_qualname_eq, hashlib.sha512.__qualname__.__eq__, ["openssl_sha512"], true, "hashlib.sha512.__qualname__ == 'openssl_sha512'; OpenSSL backend name; verified with Python 3.14.3"]
    - [md5_qualname_ne_md5, hashlib.md5.__qualname__.__eq__,  ["md5"],            false, "hashlib.md5.__qualname__ != 'md5'; qualname reveals OpenSSL backend, not plain 'md5'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — hashlib_extra214
# ---------------------------------------------------------------------------

invariant hashlib_extra214.new_qualname_is_hash_new:
  description: "hashlib.new.__qualname__.__eq__('__hash_new') returns True — hashlib.new is bound to the internal function __hash_new in Lib/hashlib.py; the public attribute name 'new' differs from the function's internal qualname '__hash_new'; the dunder prefix in '__hash_new' signals it is an implementation detail; co_name and qualname both equal '__hash_new'; this distinguishes hashlib.new from all other hashlib functions whose qualnames match their public names; NEW in hashlib_extra214: first standalone new.__qualname__ invariant in hashlibqualname214 namespace; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.new.__qualname__.__eq__
  args: ["__hash_new"]
  expected: true

invariant hashlib_extra214.file_digest_qualname_is_file_digest:
  description: "hashlib.file_digest.__qualname__.__eq__('file_digest') returns True — file_digest is a module-level function in Lib/hashlib.py whose qualname equals its public name 'file_digest' (no internal alias renaming); hashlib.file_digest was added in Python 3.11 to provide a standard way to hash a file object; its qualname differs from hashlib.new.__qualname__ ('__hash_new') which uses an internal alias; compare: hashlib.md5.__qualname__=='openssl_md5' (backend-specific name); NEW in hashlib_extra214: first standalone file_digest.__qualname__ invariant in hashlibqualname214 namespace; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.file_digest.__qualname__.__eq__
  args: ["file_digest"]
  expected: true

invariant hashlib_extra214.pbkdf2_hmac_qualname_is_pbkdf2_hmac:
  description: "hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac') returns True — pbkdf2_hmac is a C builtin defined in the _hashlib C extension module; its qualname equals its public attribute name 'pbkdf2_hmac'; pbkdf2_hmac implements the PBKDF2 password-based key derivation function using HMAC (RFC 2898); __module__ is '_hashlib' (not 'hashlib'), indicating it lives in the underlying C extension; compare: hashlib.new.__module__=='hashlib' (pure Python); NEW in hashlib_extra214: first standalone pbkdf2_hmac.__qualname__ invariant in hashlibqualname214 namespace; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.pbkdf2_hmac.__qualname__.__eq__
  args: ["pbkdf2_hmac"]
  expected: true

invariant hashlib_extra214.pbkdf2_hmac_module_is_hashlib_c:
  description: "hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') returns True — pbkdf2_hmac is implemented in the C extension _hashlib (Modules/_hashopenssl.c); it is re-exported as hashlib.pbkdf2_hmac but its __module__ attribute retains the C module name '_hashlib'; this contrasts with hashlib.new.__module__=='hashlib' (Lib/hashlib.py) and hashlib.file_digest.__module__=='hashlib'; the '_' prefix in '_hashlib' follows Python's convention for private C extensions backing public modules; NEW in hashlib_extra214: first standalone pbkdf2_hmac.__module__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.pbkdf2_hmac.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra214.md5_qualname_is_openssl_md5:
  description: "hashlib.md5.__qualname__.__eq__('openssl_md5') returns True — hashlib.md5 is an OpenSSL-backed hash constructor whose qualname 'openssl_md5' reveals the backend implementation; the 'openssl_' prefix is a CPython convention for hash constructors provided via OpenSSL rather than a pure-Python or built-in C implementation; on systems where OpenSSL provides MD5, the qualname is 'openssl_md5'; this is a macOS/Darwin 25.4.0 observation with Python 3.14.3; compare: hashlib.sha256.__qualname__=='openssl_sha256'; NEW in hashlib_extra214: first standalone md5.__qualname__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.md5.__qualname__.__eq__
  args: ["openssl_md5"]
  expected: true

invariant hashlib_extra214.sha256_qualname_is_openssl_sha256:
  description: "hashlib.sha256.__qualname__.__eq__('openssl_sha256') returns True — hashlib.sha256 is an OpenSSL-backed hash constructor with qualname 'openssl_sha256'; the 'openssl_' prefix in the qualname exposes the backend; SHA-256 is defined in FIPS 180-4 as a 256-bit secure hash algorithm; on macOS with OpenSSL, hashlib delegates SHA-256 to OpenSSL rather than using the _sha256 C module; the qualname distinguishes the OpenSSL-backed version from a hypothetical pure-C implementation; NEW in hashlib_extra214: first standalone sha256.__qualname__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.sha256.__qualname__.__eq__
  args: ["openssl_sha256"]
  expected: true

invariant hashlib_extra214.sha512_qualname_is_openssl_sha512:
  description: "hashlib.sha512.__qualname__.__eq__('openssl_sha512') returns True — hashlib.sha512 is an OpenSSL-backed hash constructor with qualname 'openssl_sha512'; SHA-512 is a 512-bit hash from the SHA-2 family defined in FIPS 180-4; on macOS with OpenSSL the qualname reveals 'openssl_sha512' rather than a plain 'sha512'; the pattern is consistent: md5 -> 'openssl_md5', sha256 -> 'openssl_sha256', sha512 -> 'openssl_sha512'; all three have the 'openssl_' prefix on this platform; NEW in hashlib_extra214: first standalone sha512.__qualname__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.sha512.__qualname__.__eq__
  args: ["openssl_sha512"]
  expected: true

invariant hashlib_extra214.new_module_is_hashlib:
  description: "hashlib.new.__module__.__eq__('hashlib') returns True — hashlib.new is defined in Lib/hashlib.py (the pure Python hashlib module); its __module__ attribute is 'hashlib' (not '_hashlib'); this contrasts with hashlib.pbkdf2_hmac.__module__=='_hashlib' (C extension) and hashlib.md5 which has no __module__ attribute at the module level (it is a type); hashlib.new acts as a factory function dispatching to the appropriate implementation; its __qualname__ is '__hash_new' but its __module__ is 'hashlib'; NEW in hashlib_extra214: first standalone new.__module__ invariant in hashlibqualname214 namespace; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.new.__module__.__eq__
  args: ["hashlib"]
  expected: true

