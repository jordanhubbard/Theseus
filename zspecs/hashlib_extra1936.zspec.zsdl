spec: hashlib_extra1936
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 576 (_extra1936): __get__/__set__/__delete__ descriptor protocol dict-presence checks, __set_name__ dict presence, __class__.__name__ checks."
    - "hashlib.HASH is a C extension type; it does NOT define descriptor protocol methods (__get__/__set__/__delete__) in its own __dict__."
    - "Neither the hashlib module nor the HASH type define __set_name__ in their __dict__."
    - "hashlib.__class__.__name__ is 'module'; type(hashlib.new('md5')).__class__.__name__ is 'type'."
    - "HASH instances report __class__.__name__ as 'HASH' (the C extension type name)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra1936.hash_type_descriptor_protocol:
  description: "hashlib HASH type __get__/__set__/__delete__ dict-presence checks (C extension — no descriptor protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1936

  columns: [id, function, args, expected]
  rows:
    - ["hl1936001", "type(hashlib.new('md5')).__dict__.__contains__", ["__get__"], false]
    - ["hl1936002", "type(hashlib.new('md5')).__dict__.__contains__", ["__set__"], false]
    - ["hl1936003", "type(hashlib.new('md5')).__dict__.__contains__", ["__delete__"], false]

table hashlib_extra1936.hash_type_set_name:
  description: "hashlib HASH type __set_name__ dict-presence check"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1936

  columns: [id, function, args, expected]
  rows:
    - ["hl1936011", "type(hashlib.new('md5')).__dict__.__contains__", ["__set_name__"], false]

table hashlib_extra1936.module_descriptor_protocol:
  description: "hashlib module-level __get__/__set__/__delete__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1936

  columns: [id, function, args, expected]
  rows:
    - ["hl1936021", "hashlib.__dict__.__contains__", ["__get__"], false]
    - ["hl1936022", "hashlib.__dict__.__contains__", ["__set__"], false]
    - ["hl1936023", "hashlib.__dict__.__contains__", ["__delete__"], false]
    - ["hl1936024", "hashlib.__dict__.__contains__", ["__set_name__"], false]

table hashlib_extra1936.hash_type_known_members:
  description: "hashlib HASH type dict-presence checks for well-known members"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1936

  columns: [id, function, args, expected]
  rows:
    - ["hl1936031", "type(hashlib.new('md5')).__dict__.__contains__", ["update"], true]
    - ["hl1936032", "type(hashlib.new('md5')).__dict__.__contains__", ["digest"], true]
    - ["hl1936033", "type(hashlib.new('md5')).__dict__.__contains__", ["hexdigest"], true]
    - ["hl1936034", "type(hashlib.new('md5')).__dict__.__contains__", ["copy"], true]
    - ["hl1936035", "type(hashlib.new('md5')).__dict__.__contains__", ["name"], true]
    - ["hl1936036", "type(hashlib.new('md5')).__dict__.__contains__", ["digest_size"], true]
    - ["hl1936037", "type(hashlib.new('md5')).__dict__.__contains__", ["block_size"], true]
    - ["hl1936038", "type(hashlib.new('md5')).__dict__.__contains__", ["__doc__"], true]
    - ["hl1936039", "type(hashlib.new('md5')).__dict__.__contains__", ["__module__"], true]

table hashlib_extra1936.module_known_members:
  description: "hashlib module dict-presence checks for well-known members"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1936

  columns: [id, function, args, expected]
  rows:
    - ["hl1936041", "hashlib.__dict__.__contains__", ["new"], true]
    - ["hl1936042", "hashlib.__dict__.__contains__", ["md5"], true]
    - ["hl1936043", "hashlib.__dict__.__contains__", ["sha256"], true]
    - ["hl1936044", "hashlib.__dict__.__contains__", ["sha512"], true]
    - ["hl1936045", "hashlib.__dict__.__contains__", ["__name__"], true]
    - ["hl1936046", "hashlib.__dict__.__contains__", ["__doc__"], true]
    - ["hl1936047", "hashlib.__dict__.__contains__", ["sha1"], true]
    - ["hl1936048", "hashlib.__dict__.__contains__", ["sha224"], true]
    - ["hl1936049", "hashlib.__dict__.__contains__", ["sha384"], true]
    - ["hl1936050", "hashlib.__dict__.__contains__", ["algorithms_available"], true]
    - ["hl1936051", "hashlib.__dict__.__contains__", ["algorithms_guaranteed"], true]
    - ["hl1936052", "hashlib.__dict__.__contains__", ["pbkdf2_hmac"], true]

table hashlib_extra1936.class_name_checks:
  description: "hashlib __class__.__name__ checks for module and type instances"
  kind: python_call_eq
  category: attribute_value
  id_prefix: hl1936

  columns: [id, function, args, expected]
  rows:
    - ["hl1936051", "hashlib.__class__.__name__.__eq__", ["module"], true]
    - ["hl1936052", "type(hashlib.new('md5')).__class__.__name__.__eq__", ["type"], true]
    - ["hl1936053", "hashlib.new('md5').__class__.__name__.__eq__", ["HASH"], true]
    - ["hl1936054", "hashlib.new('sha256').__class__.__name__.__eq__", ["HASH"], true]
