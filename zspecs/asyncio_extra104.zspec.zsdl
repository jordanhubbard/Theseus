table asyncio_extra104.asyncio_lock_qualnames:
  description: "asyncio Lock class __qualname__ equality and length checks in asyncioqnlock104 namespace — wave 254 theme: asyncio lock classes defined in Lib/asyncio/locks.py; all are module-level so __qualname__ equals __name__; asyncio.Lock.__qualname__.__eq__('Lock')==True (len=4, shortest lock qualname — tied with asyncio.Task); asyncio.Lock.__qualname__.__len__()==4; asyncio.Event.__qualname__.__eq__('Event')==True (len=5: tied with asyncio.Queue); asyncio.Event.__qualname__.__len__()==5; asyncio.Semaphore.__qualname__.__eq__('Semaphore')==True (len=9: tied with LifoQueue, QueueFull, and Condition); asyncio.Semaphore.__qualname__.__len__()==9; asyncio.BoundedSemaphore.__qualname__.__eq__('BoundedSemaphore')==True (len=16: 'Bounded'=7 + 'Semaphore'=9, longest lock/queue qualname in this spec); asyncio.BoundedSemaphore.__qualname__.__len__()==16; asyncio.Condition.__qualname__.__eq__('Condition')==True (len=9: tied with Semaphore and LifoQueue); asyncio.Condition.__qualname__.__len__()==9; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_names
  id_prefix: asyncioqnlock104a

  columns: [id, function, args, expected, description]
  rows:
    - [lock_qn_eq,      asyncio.Lock.__qualname__.__eq__,             ["Lock"],             true, "asyncio.Lock.__qualname__ == 'Lock' (len=4, shortest in spec); verified with Python 3.14.3"]
    - [lock_qn_len,     asyncio.Lock.__qualname__.__len__,            [],                   4,    "asyncio.Lock.__qualname__.__len__() == 4 (shortest lock qualname, tied with Task); verified with Python 3.14.3"]
    - [event_qn_eq,     asyncio.Event.__qualname__.__eq__,            ["Event"],            true, "asyncio.Event.__qualname__ == 'Event' (len=5, tied with Queue); verified with Python 3.14.3"]
    - [event_qn_len,    asyncio.Event.__qualname__.__len__,           [],                   5,    "asyncio.Event.__qualname__.__len__() == 5 (tied with asyncio.Queue); verified with Python 3.14.3"]
    - [sema_qn_eq,      asyncio.Semaphore.__qualname__.__eq__,        ["Semaphore"],        true, "asyncio.Semaphore.__qualname__ == 'Semaphore' (len=9); verified with Python 3.14.3"]
    - [sema_qn_len,     asyncio.Semaphore.__qualname__.__len__,       [],                   9,    "asyncio.Semaphore.__qualname__.__len__() == 9 (tied with LifoQueue, QueueFull, Condition); verified with Python 3.14.3"]
    - [bsema_qn_eq,     asyncio.BoundedSemaphore.__qualname__.__eq__, ["BoundedSemaphore"], true, "asyncio.BoundedSemaphore.__qualname__ == 'BoundedSemaphore' (len=16, longest in spec); verified with Python 3.14.3"]
    - [bsema_qn_len,    asyncio.BoundedSemaphore.__qualname__.__len__,[], 16, "asyncio.BoundedSemaphore.__qualname__.__len__() == 16 ('Bounded'=7+'Semaphore'=9, longest lock/queue qualname); verified with Python 3.14.3"]
    - [cond_qn_eq,      asyncio.Condition.__qualname__.__eq__,        ["Condition"],        true, "asyncio.Condition.__qualname__ == 'Condition' (len=9, tied with Semaphore); verified with Python 3.14.3"]
    - [cond_qn_len,     asyncio.Condition.__qualname__.__len__,        [],                  9,    "asyncio.Condition.__qualname__.__len__() == 9 (tied with Semaphore and LifoQueue); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra104
# ---------------------------------------------------------------------------

invariant asyncio_extra104.BoundedSemaphore_qualname_longest:
  description: "asyncio.BoundedSemaphore.__qualname__.__len__() == 16 — BoundedSemaphore.__qualname__ is 'BoundedSemaphore' (16 chars: 'Bounded'=7 + 'Semaphore'=9); this is the longest qualname among asyncio queue and lock classes in this spec; compare lengths: Lock=4, Event=5 (tie Queue), Queue=5, LifoQueue=9, QueueFull=9, Semaphore=9, Condition=9, QueueEmpty=10, PriorityQueue=13, BoundedSemaphore=16; asyncio.BoundedSemaphore.__module__ is 'asyncio.locks' (Lib/asyncio/locks.py); BoundedSemaphore inherits from Semaphore so BoundedSemaphore.__bases__[0].__name__ is 'Semaphore'; NEW in extra104: first standalone BoundedSemaphore qualname length invariant in asyncioqnlock104 namespace; wave 254; verified with Python 3.14.3"
  category: class_names
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.__qualname__.__len__
  args: []
  expected: 16

invariant asyncio_extra104.Lock_qualname_shortest:
  description: "asyncio.Lock.__qualname__.__len__() == 4 — Lock.__qualname__ is 'Lock' (4 chars); this is the shortest lock/queue class qualname in this spec; asyncio.Lock.__qualname__.__len__()==4 is tied with asyncio.Task.__qualname__.__len__()==4 (both are 4-char class names); asyncio.Lock.__module__ is 'asyncio.locks' (Lib/asyncio/locks.py); compare lock class qualname lengths: Lock=4 (shortest), Event=5, Semaphore=9, Condition=9, BoundedSemaphore=16 (longest); all lock/queue classes are module-level so __qualname__ equals __name__; NEW in extra104: first standalone Lock qualname shortest invariant in asyncioqnlock104 namespace; wave 254; verified with Python 3.14.3"
  category: class_names
  kind: python_call_eq
  function: asyncio.Lock.__qualname__.__len__
  args: []
  expected: 4

invariant asyncio_extra104.QueueEmpty_qualname_eq:
  description: "asyncio.QueueEmpty.__qualname__.__eq__('QueueEmpty') returns True — QueueEmpty.__qualname__ is 'QueueEmpty' (10 chars: 'Queue'=5 + 'Empty'=5); QueueEmpty is an exception class raised by Queue.get_nowait() when the queue is empty; asyncio.QueueEmpty.__module__ is 'asyncio.queues' (Lib/asyncio/queues.py); QueueEmpty.__bases__[0].__name__ is 'Exception'; QueueEmpty.__mro__.__len__() == 4 ([QueueEmpty, Exception, BaseException, object]); compare queue exception qualname lengths: QueueFull=9, QueueEmpty=10; NEW in extra104: first standalone QueueEmpty qualname eq invariant in asyncioqnlock104 namespace; wave 254; verified with Python 3.14.3"
  category: class_names
  kind: python_call_eq
  function: asyncio.QueueEmpty.__qualname__.__eq__
  args: ["QueueEmpty"]
  expected: true

invariant asyncio_extra104.PriorityQueue_qualname_len:
  description: "asyncio.PriorityQueue.__qualname__.__len__() == 13 — PriorityQueue.__qualname__ is 'PriorityQueue' (13 chars: 'Priority'=8 + 'Queue'=5); this is the second longest queue/lock class qualname in this spec (after BoundedSemaphore at 16); asyncio.PriorityQueue.__module__ is 'asyncio.queues' (Lib/asyncio/queues.py); PriorityQueue.__bases__[0].__name__ is 'Queue' (inherits from Queue); PriorityQueue.__mro__.__len__() == 4 ([PriorityQueue, Queue, _LoopBoundMixin, object]); all items dequeued from PriorityQueue in lowest-first order; NEW in extra104: first standalone PriorityQueue qualname length invariant in asyncioqnlock104 namespace; wave 254; verified with Python 3.14.3"
  category: class_names
  kind: python_call_eq
  function: asyncio.PriorityQueue.__qualname__.__len__
  args: []
  expected: 13

invariant asyncio_extra104.Semaphore_qualname_eq:
  description: "asyncio.Semaphore.__qualname__.__eq__('Semaphore') returns True — Semaphore.__qualname__ is 'Semaphore' (9 chars); asyncio.Semaphore.__module__ is 'asyncio.locks' (Lib/asyncio/locks.py); Semaphore is used to limit concurrent access to a resource; BoundedSemaphore inherits from Semaphore; the length 9 appears four times among the queue/lock class qualnames: LifoQueue=9, QueueFull=9, Semaphore=9, Condition=9; all asyncio queue and lock class qualnames are plain str objects; NEW in extra104: first standalone Semaphore qualname eq invariant in asyncioqnlock104 namespace; wave 254; verified with Python 3.14.3"
  category: class_names
  kind: python_call_eq
  function: asyncio.Semaphore.__qualname__.__eq__
  args: ["Semaphore"]
  expected: true

