spec: asyncio_extra104
version: ">=3.9"
backend: python_module(asyncio)
extends: asyncio_extra99

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra99.zspec.zsdl."
    - "This spec covers: wave 254 theme — asyncio Queue and Lock class __qualname__ values. NEW in extra104: asyncio.Queue.__qualname__=='Queue' (len=5); asyncio.PriorityQueue.__qualname__=='PriorityQueue' (len=13); asyncio.LifoQueue.__qualname__=='LifoQueue' (len=9); asyncio.QueueEmpty.__qualname__=='QueueEmpty' (len=10); asyncio.QueueFull.__qualname__=='QueueFull' (len=9); asyncio.Lock.__qualname__=='Lock' (len=4, shortest); asyncio.Event.__qualname__=='Event' (len=5); asyncio.Semaphore.__qualname__=='Semaphore' (len=9); asyncio.BoundedSemaphore.__qualname__=='BoundedSemaphore' (len=16, longest queue/lock class qualname); asyncio.Condition.__qualname__=='Condition' (len=9). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__module__ == 'asyncio.queues'. Queue, PriorityQueue, LifoQueue, QueueEmpty, QueueFull are all defined in Lib/asyncio/queues.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__module__ == 'asyncio.locks'. Lock, Event, Semaphore, BoundedSemaphore, Condition are all defined in Lib/asyncio/locks.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.__qualname__.__len__() == 16. 'BoundedSemaphore' is 16 chars: 'Bounded'=7 + 'Semaphore'=9. This is the longest queue/lock class qualname in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__qualname__.__len__() == 4. 'Lock' is the shortest qualname in this spec (4 chars), tied with asyncio.Task.__qualname__ (also 4). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Queue class __qualname__ values — extra104
#
# Wave 254 theme: asyncio Queue and Lock class __qualname__ values.
# All queue/lock classes are module-level so __qualname__ equals __name__.
#
# asyncio.Queue.__qualname__           == 'Queue'           (len=5)
# asyncio.PriorityQueue.__qualname__   == 'PriorityQueue'   (len=13)
# asyncio.LifoQueue.__qualname__       == 'LifoQueue'       (len=9)
# asyncio.QueueEmpty.__qualname__      == 'QueueEmpty'      (len=10)
# asyncio.QueueFull.__qualname__       == 'QueueFull'       (len=9)
# ---------------------------------------------------------------------------

table asyncio_extra104.asyncio_queue_qualnames:
  description: "asyncio Queue class __qualname__ equality and length checks in asyncioqnlock104 namespace — wave 254 theme: asyncio queue classes defined in Lib/asyncio/queues.py; all are module-level so __qualname__ equals __name__; asyncio.Queue.__qualname__.__eq__('Queue')==True (len=5); asyncio.Queue.__qualname__.__len__()==5; asyncio.PriorityQueue.__qualname__.__eq__('PriorityQueue')==True (len=13: 'Priority'=8 + 'Queue'=5); asyncio.PriorityQueue.__qualname__.__len__()==13; asyncio.LifoQueue.__qualname__.__eq__('LifoQueue')==True (len=9: 'Lifo'=4 + 'Queue'=5); asyncio.LifoQueue.__qualname__.__len__()==9; asyncio.QueueEmpty.__qualname__.__eq__('QueueEmpty')==True (len=10: 'Queue'=5 + 'Empty'=5); asyncio.QueueEmpty.__qualname__.__len__()==10; asyncio.QueueFull.__qualname__.__eq__('QueueFull')==True (len=9: 'Queue'=5 + 'Full'=4); asyncio.QueueFull.__qualname__.__len__()==9; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_names
  id_prefix: asyncioqnlock104

  columns: [id, function, args, expected, description]
  rows:
    - [queue_qn_eq,     asyncio.Queue.__qualname__.__eq__,         ["Queue"],         true, "asyncio.Queue.__qualname__ == 'Queue' (len=5); verified with Python 3.14.3"]
    - [queue_qn_len,    asyncio.Queue.__qualname__.__len__,         [],                5,    "asyncio.Queue.__qualname__.__len__() == 5; verified with Python 3.14.3"]
    - [priqueue_qn_eq,  asyncio.PriorityQueue.__qualname__.__eq__,  ["PriorityQueue"], true, "asyncio.PriorityQueue.__qualname__ == 'PriorityQueue' (len=13); verified with Python 3.14.3"]
    - [priqueue_qn_len, asyncio.PriorityQueue.__qualname__.__len__, [],                13,   "asyncio.PriorityQueue.__qualname__.__len__() == 13; verified with Python 3.14.3"]
    - [lifoqueue_qn_eq, asyncio.LifoQueue.__qualname__.__eq__,      ["LifoQueue"],     true, "asyncio.LifoQueue.__qualname__ == 'LifoQueue' (len=9); verified with Python 3.14.3"]
    - [lifoqueue_qn_ln, asyncio.LifoQueue.__qualname__.__len__,     [],                9,    "asyncio.LifoQueue.__qualname__.__len__() == 9; verified with Python 3.14.3"]
    - [queuemt_qn_eq,   asyncio.QueueEmpty.__qualname__.__eq__,     ["QueueEmpty"],    true, "asyncio.QueueEmpty.__qualname__ == 'QueueEmpty' (len=10); verified with Python 3.14.3"]
    - [queuemt_qn_len,  asyncio.QueueEmpty.__qualname__.__len__,    [],                10,   "asyncio.QueueEmpty.__qualname__.__len__() == 10; verified with Python 3.14.3"]
    - [queuefl_qn_eq,   asyncio.QueueFull.__qualname__.__eq__,      ["QueueFull"],     true, "asyncio.QueueFull.__qualname__ == 'QueueFull' (len=9); verified with Python 3.14.3"]
    - [queuefl_qn_len,  asyncio.QueueFull.__qualname__.__len__,     [],                9,    "asyncio.QueueFull.__qualname__.__len__() == 9; verified with Python 3.14.3"]

