spec: pathlib_extra1411
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers __sizeof__ method type/presence and __reduce_ex__ method type/presence for pathlib module classes. pathlib.PurePath.__sizeof__.__class__.__name__=='method_descriptor' (inherited from object; '__sizeof__' not in pathlib.PurePath.__dict__). None of the pathlib classes in this batch (PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath) have '__sizeof__' in their own __dict__. Similarly, none define '__reduce_ex__' in their own __dict__. pathlib.PosixPath.__mro__.__len__()==5 (MRO: [PosixPath, Path, PurePosixPath, PurePath, object]; deepest chain in this batch). pathlib.PurePath.__mro__.__len__()==2 ([PurePath, object]; shallowest). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "pathlib.PurePosixPath.__name__.__len__()==13 ('PurePosixPath'=13 chars). pathlib.PureWindowsPath.__name__.__len__()==15 ('PureWindowsPath'=15 chars). pathlib.PosixPath.__mro__.__len__()==5 (MRO: [PosixPath, Path, PurePosixPath, PurePath, object]). pathlib.Path.__mro__.__len__()==3 ([Path, PurePath, object]). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib class __sizeof__ type and dict presence checks — extra1411
#
# pathlib.PurePath.__sizeof__.__class__.__name__         == 'method_descriptor'
# pathlib.PurePath.__dict__.__contains__('__sizeof__')  == False
# pathlib.Path.__sizeof__.__class__.__name__             == 'method_descriptor'
# pathlib.Path.__dict__.__contains__('__sizeof__')      == False
# pathlib.PosixPath.__dict__.__contains__('__sizeof__') == False
# pathlib.PurePosixPath.__dict__.__contains__('__sizeof__') == False
# ---------------------------------------------------------------------------

table pathlib_extra1411.pathlib_sizeof_type:
  description: "pathlib class __sizeof__ method type and __dict__ presence checks — wave 541 extra1411 theme. pathlib.PurePath.__sizeof__.__class__.__name__=='method_descriptor' (PurePath inherits __sizeof__ from object; none of the pathlib classes in this batch define their own __sizeof__). pathlib.PurePath.__dict__.__contains__('__sizeof__')==False. pathlib.Path.__sizeof__.__class__.__name__=='method_descriptor'. pathlib.Path.__dict__.__contains__('__sizeof__')==False. pathlib.PosixPath.__dict__.__contains__('__sizeof__')==False. pathlib.PurePosixPath.__dict__.__contains__('__sizeof__')==False. pathlib.PureWindowsPath.__dict__.__contains__('__sizeof__')==False. All pathlib classes inherit __sizeof__ from object without override. All verified with Python 3.14.3."
  kind: python_call_eq
  category: sizeof_introspection
  id_prefix: pl1411sz

  columns: [id, function, args, expected, description]
  rows:
    - [pl1411sz001, pathlib.PurePath.__sizeof__.__class__.__name__.__eq__,         ["method_descriptor"], true,  "pathlib.PurePath.__sizeof__.__class__.__name__ == 'method_descriptor' (inherited from object); verified with Python 3.14.3"]
    - [pl1411sz002, pathlib.PurePath.__dict__.__contains__,                        ["__sizeof__"],         false, "pathlib.PurePath.__dict__.__contains__('__sizeof__') == False (inherits from object); verified with Python 3.14.3"]
    - [pl1411sz003, pathlib.Path.__sizeof__.__class__.__name__.__eq__,             ["method_descriptor"], true,  "pathlib.Path.__sizeof__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3"]
    - [pl1411sz004, pathlib.Path.__dict__.__contains__,                            ["__sizeof__"],         false, "pathlib.Path.__dict__.__contains__('__sizeof__') == False; verified with Python 3.14.3"]
    - [pl1411sz005, pathlib.PosixPath.__dict__.__contains__,                       ["__sizeof__"],         false, "pathlib.PosixPath.__dict__.__contains__('__sizeof__') == False; verified with Python 3.14.3"]
    - [pl1411sz006, pathlib.PurePosixPath.__dict__.__contains__,                   ["__sizeof__"],         false, "pathlib.PurePosixPath.__dict__.__contains__('__sizeof__') == False; verified with Python 3.14.3"]
    - [pl1411sz007, pathlib.PureWindowsPath.__dict__.__contains__,                 ["__sizeof__"],         false, "pathlib.PureWindowsPath.__dict__.__contains__('__sizeof__') == False; verified with Python 3.14.3"]
    - [pl1411sz008, pathlib.PosixPath.__sizeof__.__class__.__name__.__eq__,        ["method_descriptor"], true,  "pathlib.PosixPath.__sizeof__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3"]

