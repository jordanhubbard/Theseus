spec: asynchat_extra2
version: ">=3.9,<3.12"
backend: python_module(asynchat)

docs: https://docs.python.org/3/library/asynchat.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asynchat.html — Python asynchat documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asynchat.py"
  notes:
    - "This spec extends asynchat.zspec.zsdl and prior extras."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "asynchat raises no module-specific exception class; network errors propagate from asyncore.dispatcher."
  stderr: "null"
  stickiness: "N/A — class-level structural checks only."
  codes: {}

# ---------------------------------------------------------------------------
# async_chat class — qualname
# ---------------------------------------------------------------------------

invariant asynchat_extra2.async_chat_qualname:
  description: "async_chat.__qualname__ == 'async_chat'"
  category: classnames
  kind: python_call_eq
  function: async_chat.__qualname__.__eq__
  args: ["async_chat"]
  expected: true

# ---------------------------------------------------------------------------
# async_chat class — bases[0] qualname
# ---------------------------------------------------------------------------

invariant asynchat_extra2.async_chat_base_qualname:
  description: "async_chat.__bases__[0].__qualname__ == 'dispatcher'"
  category: classnames
  kind: python_call_eq
  function: async_chat.__bases__.__getitem__
  args: [0]
  method: __qualname__
  method_args: []
  expected: "dispatcher"

# ---------------------------------------------------------------------------
# simple_producer class — qualname
# ---------------------------------------------------------------------------

invariant asynchat_extra2.simple_producer_qualname:
  description: "simple_producer.__qualname__ == 'simple_producer'"
  category: classnames
  kind: python_call_eq
  function: simple_producer.__qualname__.__eq__
  args: ["simple_producer"]
  expected: true

# ---------------------------------------------------------------------------
# async_chat class — bases[0] name (cross-check via different approach)
# ---------------------------------------------------------------------------

invariant asynchat_extra2.async_chat_base_name_check:
  description: "async_chat.__bases__[0].__name__ == 'dispatcher' (re-verified in extra2)"
  category: classnames
  kind: python_call_eq
  function: async_chat.__bases__.__getitem__
  args: [0]
  method: __module__
  method_args: []
  expected: "asyncore"

# ---------------------------------------------------------------------------
# simple_producer class — base name
# ---------------------------------------------------------------------------

invariant asynchat_extra2.simple_producer_base_qualname:
  description: "simple_producer.__bases__[0].__qualname__ == 'object'"
  category: classnames
  kind: python_call_eq
  function: simple_producer.__bases__.__getitem__
  args: [0]
  method: __qualname__
  method_args: []
  expected: "object"
