spec: base_62
version: ">=1.0.0"
backend: node(base-62)

docs: https://www.npmjs.com/package/base-62

provenance:
  derived_from:
    - "base-62 README — https://www.npmjs.com/package/base-62"
    - "Test vectors verified with base-62 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "base-62 source"
  notes:
    - "base-62 is an npm package. Install: npm install base-62"
    - "base62.encode(n) encodes an integer to a base-62 string."
    - "base62.decode(str) decodes a base-62 string back to an integer."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns encoded string or decoded integer."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table base_62.encode:
  kind: node_module_call_eq
  function: encode
  category: encode
  id_prefix: b62enc

  columns: [id, args, expected]
  rows:
    - [num,  [12345], "3d7"]
    - [zero, [0],     "0"]

table base_62.decode:
  kind: node_module_call_eq
  function: decode
  category: decode
  id_prefix: b62dec

  columns: [id, args, expected]
  rows:
    - [str,  ["3d7"], 12345]
    - [zero, ["0"],   0]
