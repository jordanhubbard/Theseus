spec: threading_extra140
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.RLock (factory function), threading.Lock (C extension type aliased as 'lock'), threading.TIMEOUT_MAX (float), and threading.Barrier (Python class) — class identity, __name__, __module__, and related attrs (Wave 267)."
    - "threading.RLock is a Python function (factory), NOT a class — isinstance(threading.RLock, type) is False. Verified with Python 3.14.3."
    - "threading.RLock().__class__.__name__ == 'RLock' — the instance's class is the C type 'RLock' from _thread. Verified with Python 3.14.3."
    - "threading.RLock().__class__.__module__ == '_thread'. Verified with Python 3.14.3."
    - "threading.RLock.__class__.__name__ == 'function' — the factory is a plain Python function. Verified with Python 3.14.3."
    - "threading.RLock.__qualname__ == 'RLock' (len 5). Verified with Python 3.14.3."
    - "threading.RLock.__module__ == 'threading' (len 9). Verified with Python 3.14.3."
    - "threading.Lock is a C extension type (isinstance(threading.Lock, type) is True). Verified with Python 3.14.3."
    - "threading.Lock.__name__ == 'lock' (len 4) — the C type's actual name is lowercase 'lock'. Verified with Python 3.14.3."
    - "threading.Lock.__module__ == '_thread' (len 7). Verified with Python 3.14.3."
    - "len(threading.Lock.__mro__) == 2 — MRO is [lock, object]. Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' (len 5). Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__class__.__module__ == 'builtins' (len 8). Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX == 9223372036.0. Verified with Python 3.14.3."
    - "threading.Barrier.__name__ == 'Barrier' (len 7). Verified with Python 3.14.3."
    - "threading.Barrier.__module__ == 'threading' (len 9). Verified with Python 3.14.3."
    - "len(threading.Barrier.__mro__) == 2 — MRO is [Barrier, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.RLock — factory function identity
#
# Wave 267 theme: threading.RLock is a Python function, not a class.
#
# threading.RLock.__class__.__name__ == 'function'
# threading.RLock.__qualname__ == 'RLock' (len 5)
# threading.RLock.__module__ == 'threading' (len 9)
# threading.RLock().__class__.__name__ == 'RLock' (the C type returned)
# threading.RLock().__class__.__module__ == '_thread'
#
# threading.RLock is a factory function defined in Lib/threading.py that
# calls _thread.RLock() to return a C extension RLock instance. New to extra140.
# ---------------------------------------------------------------------------

table threading_extra140.rlock_factory_identity:
  description: "threading.RLock: Python function, __qualname__ len 5, __module__ 'threading' len 9; instance __class__.__name__=='RLock', __module__=='_thread'; wave 267; new to extra140"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingrlock140

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_class_eq_function,
       "RLock.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.RLock.__class__.__name__.__eq__('function') == True — threading.RLock is a Python factory function defined in Lib/threading.py; isinstance(RLock, type) is False; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra140"]
    - [rlock_class_len_eq_8,
       "RLock.__class__.__name__.__len__",
       [],
       8,
       "threading.RLock.__class__.__name__.__len__() == 8 — __class__.__name__ is 'function' which has 8 characters; len('function') == 8; new to extra140"]
    - [rlock_qualname_eq,
       "RLock.__qualname__.__eq__",
       ["RLock"],
       true,
       "threading.RLock.__qualname__.__eq__('RLock') == True — the factory function's __qualname__ is 'RLock'; str.__eq__('RLock') returns True; new to extra140"]
    - [rlock_qualname_len_eq_5,
       "RLock.__qualname__.__len__",
       [],
       5,
       "threading.RLock.__qualname__.__len__() == 5 — __qualname__ is 'RLock' which has 5 characters; len('RLock') == 5; new to extra140"]
    - [rlock_module_eq_threading,
       "RLock.__module__.__eq__",
       ["threading"],
       true,
       "threading.RLock.__module__.__eq__('threading') == True — the factory function is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra140"]
    - [rlock_module_len_eq_9,
       "RLock.__module__.__len__",
       [],
       9,
       "threading.RLock.__module__.__len__() == 9 — __module__ is 'threading' which has 9 characters; len('threading') == 9; new to extra140"]

# ---------------------------------------------------------------------------
# Table 2: threading.Lock — C extension type identity
#
# Wave 267 theme: threading.Lock is the C extension type 'lock' from _thread.
#
# threading.Lock.__class__.__name__ == 'type' (it is a class)
# threading.Lock.__name__ == 'lock' (len 4) — lowercase, the C type's real name
# threading.Lock.__module__ == '_thread' (len 7)
# threading.Lock.__bases__[0].__name__ == 'object'
# len(threading.Lock.__mro__) == 2
#
# threading.Lock is an alias for the _thread.lock C extension type.
# Its __name__ is lowercase 'lock'. New to extra140.
# ---------------------------------------------------------------------------

table threading_extra140.lock_class_identity:
  description: "threading.Lock: C extension type, __name__=='lock' len 4, __module__=='_thread' len 7, MRO len 2; wave 267; new to extra140"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinglock140

  columns: [id, function, args, expected, description]
  rows:
    - [lock_class_eq_type,
       "Lock.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Lock.__class__.__name__.__eq__('type') == True — threading.Lock is a C extension type; isinstance(Lock, type) is True; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra140"]
    - [lock_name_eq_lock,
       "Lock.__name__.__eq__",
       ["lock"],
       true,
       "threading.Lock.__name__.__eq__('lock') == True — threading.Lock is an alias for _thread.lock; the C type's actual __name__ is lowercase 'lock'; str.__eq__('lock') returns True; new to extra140"]
    - [lock_name_len_eq_4,
       "Lock.__name__.__len__",
       [],
       4,
       "threading.Lock.__name__.__len__() == 4 — __name__ is 'lock' which has 4 characters; len('lock') == 4; new to extra140"]
    - [lock_module_eq__thread,
       "Lock.__module__.__eq__",
       ["_thread"],
       true,
       "threading.Lock.__module__.__eq__('_thread') == True — the C extension type is defined in _threadmodule.c; its __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra140"]
    - [lock_module_len_eq_7,
       "Lock.__module__.__len__",
       [],
       7,
       "threading.Lock.__module__.__len__() == 7 — __module__ is '_thread' which has 7 characters; len('_thread') == 7; new to extra140"]
    - [lock_bases_0_eq_object,
       "Lock.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Lock.__bases__[0].__name__.__eq__('object') == True — the lock C type directly inherits from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra140"]
    - [lock_mro_len_eq_2,
       "Lock.__mro__.__len__",
       [],
       2,
       "threading.Lock.__mro__.__len__() == 2 — lock's MRO is [lock, object]; len(__mro__) is 2; new to extra140"]

# ---------------------------------------------------------------------------
# Table 3: threading.TIMEOUT_MAX — float class identity
#
# Wave 267 theme: threading.TIMEOUT_MAX is a Python float constant.
#
# threading.TIMEOUT_MAX.__class__.__name__ == 'float' (len 5)
# threading.TIMEOUT_MAX.__class__.__module__ == 'builtins' (len 8)
# threading.TIMEOUT_MAX.__eq__(9223372036.0) == True
#
# TIMEOUT_MAX is the maximum timeout value for blocking primitives.
# It equals 9223372036.0 (approximately 2^33 seconds). New to extra140.
# ---------------------------------------------------------------------------

table threading_extra140.timeout_max_identity:
  description: "threading.TIMEOUT_MAX: float, class 'float' len 5, module 'builtins' len 8, value 9223372036.0; wave 267; new to extra140"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtm140

  columns: [id, function, args, expected, description]
  rows:
    - [tm_class_eq_float,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — TIMEOUT_MAX is a Python float constant; __class__.__name__ is 'float'; str.__eq__('float') returns True; new to extra140"]
    - [tm_class_len_eq_5,
       "TIMEOUT_MAX.__class__.__name__.__len__",
       [],
       5,
       "threading.TIMEOUT_MAX.__class__.__name__.__len__() == 5 — __class__.__name__ is 'float' which has 5 characters; len('float') == 5; new to extra140"]
    - [tm_class_module_eq_builtins,
       "TIMEOUT_MAX.__class__.__module__.__eq__",
       ["builtins"],
       true,
       "threading.TIMEOUT_MAX.__class__.__module__.__eq__('builtins') == True — float is a built-in type; its __module__ is 'builtins'; str.__eq__('builtins') returns True; new to extra140"]
    - [tm_class_module_len_eq_8,
       "TIMEOUT_MAX.__class__.__module__.__len__",
       [],
       8,
       "threading.TIMEOUT_MAX.__class__.__module__.__len__() == 8 — __class__.__module__ is 'builtins' which has 8 characters; len('builtins') == 8; new to extra140"]
    - [tm_value_eq,
       "TIMEOUT_MAX.__eq__",
       [9223372036.0],
       true,
       "threading.TIMEOUT_MAX.__eq__(9223372036.0) == True — TIMEOUT_MAX equals 9223372036.0 (the maximum allowed blocking timeout); float.__eq__(9223372036.0) returns True; new to extra140"]

# ---------------------------------------------------------------------------
# Table 4: threading.Barrier — Python class identity
#
# Wave 267 theme: threading.Barrier — Python class defined in Lib/threading.py.
#
# threading.Barrier.__class__.__name__ == 'type'
# threading.Barrier.__name__ == 'Barrier' (len 7)
# threading.Barrier.__module__ == 'threading' (len 9)
# threading.Barrier.__bases__[0].__name__ == 'object'
# len(threading.Barrier.__mro__) == 2
#
# Barrier is a synchronization primitive (Python 3.2+) that allows a set of
# threads to wait until all threads have reached a common point. New to extra140.
# ---------------------------------------------------------------------------

table threading_extra140.barrier_class_identity:
  description: "threading.Barrier: Python class, __name__ 'Barrier' len 7, __module__ 'threading' len 9, MRO len 2; wave 267; new to extra140"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingbarrier140

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_class_eq_type,
       "Barrier.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Barrier.__class__.__name__.__eq__('type') == True — threading.Barrier is a Python class defined in Lib/threading.py; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra140"]
    - [barrier_name_eq,
       "Barrier.__name__.__eq__",
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — the class __name__ is 'Barrier'; str.__eq__('Barrier') returns True; new to extra140"]
    - [barrier_name_len_eq_7,
       "Barrier.__name__.__len__",
       [],
       7,
       "threading.Barrier.__name__.__len__() == 7 — __name__ is 'Barrier' which has 7 characters; len('Barrier') == 7; new to extra140"]
    - [barrier_module_eq_threading,
       "Barrier.__module__.__eq__",
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — Barrier is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra140"]
    - [barrier_module_len_eq_9,
       "Barrier.__module__.__len__",
       [],
       9,
       "threading.Barrier.__module__.__len__() == 9 — __module__ is 'threading' which has 9 characters; len('threading') == 9; new to extra140"]
    - [barrier_bases_0_eq_object,
       "Barrier.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Barrier.__bases__[0].__name__.__eq__('object') == True — Barrier directly inherits from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra140"]
    - [barrier_mro_len_eq_2,
       "Barrier.__mro__.__len__",
       [],
       2,
       "threading.Barrier.__mro__.__len__() == 2 — Barrier's MRO is [Barrier, object]; len(__mro__) is 2; new to extra140"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra140
# ---------------------------------------------------------------------------

invariant threading_extra140.rlock_is_function:
  description: "threading.RLock.__class__.__name__ == 'function' — RLock is a Python factory function, not a class; wave 267; new to extra140"
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra140.lock_name_is_lowercase:
  description: "threading.Lock.__name__ == 'lock' — the C extension type's real name is lowercase 'lock', not 'Lock'; wave 267; new to extra140"
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra140.lock_module_is__thread:
  description: "threading.Lock.__module__ == '_thread' — Lock is defined in the _thread C extension, not threading; wave 267; new to extra140"
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra140.timeout_max_is_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a Python float constant; wave 267; new to extra140"
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra140.barrier_module_len:
  description: "len(threading.Barrier.__module__) == 9 — __module__ is 'threading'; wave 267; new to extra140"
  kind: python_call_eq
  function: Barrier.__module__.__len__
  args: []
  expected: 9
