spec: threading_extra1621
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __weakref__ and weak reference protocol"
    - "threading.Thread is a pure Python class without __slots__; it defines __dict__ and __weakref__ as getset_descriptors in its own class __dict__, inherited from object via normal class creation"
    - "threading.Event, Condition, Semaphore, and Barrier are pure Python classes without __slots__; each defines __weakref__ in its own class __dict__"
    - "threading.BoundedSemaphore is a subclass of Semaphore without adding new __slots__; it does NOT add its own __weakref__ or __dict__ descriptors (inherited from Semaphore)"
    - "threading.Timer is a subclass of Thread without adding new __slots__; it does NOT add its own __weakref__ or __dict__ descriptors (inherited from Thread)"
    - "threading.Lock() returns an instance of _thread.lock, a C extension type; Lock is actually a factory function not a class — Lock.__dict__ does not exist in the usual sense"
    - "threading.RLock is a C extension type (_thread.RLock) aliased into the threading namespace; no __weakref__ in its type dict"
    - "threading.local is _thread._local, a C extension type; no __weakref__ descriptor in its type dict"
    - "Instances of Thread, Event, Condition, Semaphore, Barrier are all weakly referenceable because those classes define __weakref__ in their own __dict__"
  created_at: "2026-04-12"
error_model: python_exceptions

table threading_extra1621.thread_no_weakref_dict:
  description: "threading.Thread and pure Python sync primitives each define __weakref__ in their own class __dict__ (no __slots__ defined, so object's __weakref__ descriptor is materialized into each class's own dict)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1621td

  columns: [id, function, args, expected]
  rows:
    - ["th1621td001", "threading.Thread.__dict__.__contains__",    ["__weakref__"],  true]
    - ["th1621td002", "threading.Thread.__dict__.__contains__",    ["__dict__"],     true]
    - ["th1621td003", "threading.Thread.__dict__.__contains__",    ["__slots__"],    false]
    - ["th1621td004", "threading.Thread.__dict__.__contains__",    ["start"],        true]
    - ["th1621td005", "threading.Thread.__dict__.__contains__",    ["run"],          true]
    - ["th1621td006", "threading.Thread.__dict__.__contains__",    ["join"],         true]
    - ["th1621td007", "threading.Thread.__dict__.__contains__",    ["is_alive"],     true]
    - ["th1621td008", "threading.Thread.__dict__.__contains__",    ["name"],         true]
    - ["th1621td009", "threading.Thread.__dict__.__contains__",    ["daemon"],       true]
    - ["th1621td010", "threading.Thread.__dict__.__contains__",    ["ident"],        true]
    - ["th1621td011", "threading.Event.__dict__.__contains__",     ["__weakref__"],  true]
    - ["th1621td012", "threading.Event.__dict__.__contains__",     ["__dict__"],     true]
    - ["th1621td013", "threading.Event.__dict__.__contains__",     ["__slots__"],    false]
    - ["th1621td014", "threading.Event.__dict__.__contains__",     ["is_set"],       true]
    - ["th1621td015", "threading.Event.__dict__.__contains__",     ["set"],          true]
    - ["th1621td016", "threading.Event.__dict__.__contains__",     ["clear"],        true]
    - ["th1621td017", "threading.Event.__dict__.__contains__",     ["wait"],         true]
    - ["th1621td018", "threading.Condition.__dict__.__contains__", ["__weakref__"],  true]
    - ["th1621td019", "threading.Condition.__dict__.__contains__", ["__dict__"],     true]
    - ["th1621td020", "threading.Condition.__dict__.__contains__", ["__slots__"],    false]
    - ["th1621td021", "threading.Condition.__dict__.__contains__", ["wait"],         true]
    - ["th1621td022", "threading.Condition.__dict__.__contains__", ["notify"],       true]
    - ["th1621td023", "threading.Condition.__dict__.__contains__", ["notify_all"],   true]
    - ["th1621td024", "threading.Condition.__dict__.__contains__", ["__enter__"],    true]
    - ["th1621td025", "threading.Condition.__dict__.__contains__", ["__exit__"],     true]
    - ["th1621td026", "threading.Semaphore.__dict__.__contains__", ["__weakref__"],  true]
    - ["th1621td027", "threading.Semaphore.__dict__.__contains__", ["__dict__"],     true]
    - ["th1621td028", "threading.Semaphore.__dict__.__contains__", ["__slots__"],    false]
    - ["th1621td029", "threading.Barrier.__dict__.__contains__",   ["__weakref__"],  true]
    - ["th1621td030", "threading.Barrier.__dict__.__contains__",   ["__dict__"],     true]

table threading_extra1621.c_types_no_weakref:
  description: "C extension threading types (RLock, local) do not have __weakref__ in their type __dict__; BoundedSemaphore and Timer are pure Python subclasses that do not add their own __weakref__ descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1621ct

  columns: [id, function, args, expected]
  rows:
    - ["th1621ct001", "threading.RLock.__dict__.__contains__",              ["__weakref__"],  false]
    - ["th1621ct002", "threading.RLock.__dict__.__contains__",              ["__dict__"],     false]
    - ["th1621ct003", "threading.RLock.__dict__.__contains__",              ["__slots__"],    false]
    - ["th1621ct004", "threading.RLock.__dict__.__contains__",              ["acquire"],      true]
    - ["th1621ct005", "threading.RLock.__dict__.__contains__",              ["release"],      true]
    - ["th1621ct006", "threading.RLock.__dict__.__contains__",              ["__enter__"],    true]
    - ["th1621ct007", "threading.RLock.__dict__.__contains__",              ["__exit__"],     true]
    - ["th1621ct008", "threading.local.__dict__.__contains__",              ["__weakref__"],  false]
    - ["th1621ct009", "threading.local.__dict__.__contains__",              ["__dict__"],     false]
    - ["th1621ct010", "threading.local.__dict__.__contains__",              ["__slots__"],    false]
    - ["th1621ct011", "threading.local.__dict__.__contains__",              ["__getattribute__"], true]
    - ["th1621ct012", "threading.local.__dict__.__contains__",              ["__setattr__"],  true]
    - ["th1621ct013", "threading.local.__dict__.__contains__",              ["__delattr__"],  true]
    - ["th1621ct014", "threading.local.__dict__.__contains__",              ["__new__"],      true]
    - ["th1621ct015", "threading.local.__module__.__eq__",                  ["_thread"],      true]
    - ["th1621ct016", "threading.RLock.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["th1621ct017", "threading.local.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["th1621ct018", "threading.BoundedSemaphore.__dict__.__contains__",   ["__weakref__"],  false]
    - ["th1621ct019", "threading.BoundedSemaphore.__dict__.__contains__",   ["__dict__"],     false]
    - ["th1621ct020", "threading.BoundedSemaphore.__dict__.__contains__",   ["__slots__"],    false]
    - ["th1621ct021", "threading.BoundedSemaphore.__dict__.__contains__",   ["release"],      true]
    - ["th1621ct022", "threading.Timer.__dict__.__contains__",              ["__weakref__"],  false]
    - ["th1621ct023", "threading.Timer.__dict__.__contains__",              ["__dict__"],     false]
    - ["th1621ct024", "threading.Timer.__dict__.__contains__",              ["__slots__"],    false]
    - ["th1621ct025", "threading.Timer.__dict__.__contains__",              ["cancel"],       true]
    - ["th1621ct026", "threading.Timer.__dict__.__contains__",              ["run"],          true]
    - ["th1621ct027", "threading.BoundedSemaphore.__name__.__eq__",         ["BoundedSemaphore"], true]
    - ["th1621ct028", "threading.BoundedSemaphore.__module__.__eq__",       ["threading"],   true]
    - ["th1621ct029", "threading.Timer.__name__.__eq__",                    ["Timer"],        true]
    - ["th1621ct030", "threading.Timer.__module__.__eq__",                  ["threading"],   true]

table threading_extra1621.thread_instances_weakrefable:
  description: "instances of threading classes that define __weakref__ (Thread, Event, Condition, Semaphore, Barrier) support weak references; verify via class-dict membership of __weakref__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1621iw

  columns: [id, function, args, expected]
  rows:
    - ["th1621iw001", "threading.Thread.__dict__.__contains__",    ["__weakref__"],  true]
    - ["th1621iw002", "threading.Event.__dict__.__contains__",     ["__weakref__"],  true]
    - ["th1621iw003", "threading.Condition.__dict__.__contains__", ["__weakref__"],  true]
    - ["th1621iw004", "threading.Semaphore.__dict__.__contains__", ["__weakref__"],  true]
    - ["th1621iw005", "threading.Barrier.__dict__.__contains__",   ["__weakref__"],  true]
    - ["th1621iw006", "threading.RLock.__dict__.__contains__",     ["__weakref__"],  false]
    - ["th1621iw007", "threading.local.__dict__.__contains__",     ["__weakref__"],  false]
    - ["th1621iw008", "threading.BoundedSemaphore.__dict__.__contains__", ["__weakref__"], false]
    - ["th1621iw009", "threading.Timer.__dict__.__contains__",     ["__weakref__"],  false]
    - ["th1621iw010", "threading.Thread.__dict__.__contains__",    ["__dict__"],     true]
    - ["th1621iw011", "threading.Event.__dict__.__contains__",     ["__dict__"],     true]
    - ["th1621iw012", "threading.Condition.__dict__.__contains__", ["__dict__"],     true]
    - ["th1621iw013", "threading.Semaphore.__dict__.__contains__", ["__dict__"],     true]
    - ["th1621iw014", "threading.Barrier.__dict__.__contains__",   ["__dict__"],     true]
    - ["th1621iw015", "threading.Thread.__name__.__eq__",    ["Thread"],             true]
    - ["th1621iw016", "threading.Thread.__module__.__eq__",  ["threading"],          true]
    - ["th1621iw017", "threading.Event.__name__.__eq__",     ["Event"],              true]
    - ["th1621iw018", "threading.Event.__module__.__eq__",   ["threading"],          true]
    - ["th1621iw019", "threading.Condition.__name__.__eq__", ["Condition"],          true]
    - ["th1621iw020", "threading.Condition.__module__.__eq__", ["threading"],        true]
    - ["th1621iw021", "threading.Semaphore.__name__.__eq__", ["Semaphore"],          true]
    - ["th1621iw022", "threading.Semaphore.__module__.__eq__", ["threading"],        true]
    - ["th1621iw023", "threading.Barrier.__name__.__eq__",   ["Barrier"],            true]
    - ["th1621iw024", "threading.Barrier.__module__.__eq__", ["threading"],          true]
    - ["th1621iw025", "threading.Thread.__class__.__name__.__eq__",    ["type"],     true]
    - ["th1621iw026", "threading.Event.__class__.__name__.__eq__",     ["type"],     true]
    - ["th1621iw027", "threading.Condition.__class__.__name__.__eq__", ["type"],     true]
    - ["th1621iw028", "threading.Semaphore.__class__.__name__.__eq__", ["type"],     true]
    - ["th1621iw029", "threading.Barrier.__class__.__name__.__eq__",   ["type"],     true]
    - ["th1621iw030", "threading.Thread.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
